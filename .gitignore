hsg-subjects-mockup.html
taxonomy-review.html
string-match-review.html
dedup-review.html
semantic-dedup-review.html

# Generated mockup data (generated by generate_mockup_data.py)
mockup_subject_data.json
mockup_sidebar_data.json
taxonomy_for_mockup.json

# Intermediate pipeline outputs (regenerated on each run)
variant_groups.json
dedup_groups.json
semantic_dedup_groups.json
document_appearances.json
doc_metadata.json
lcsh_broader_cache.json
lcsh_decisions.json

