                subtype="historical-document" type="document" xml:id="d298">
                <note rend="inline" type="source">893.51/3538: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Schurman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1921-10-29T23:00:00+08:00">
                            <hi rend="italic">October 29, 1921—11 p.m.</hi>
                        </date>
                        <lb/>[Received October 29—3:40 p.m.]</dateline>
                </opener>
                <p>377. Your 288, October 27, 5 p.m. Suggestion in question advanced by the
                    Inspector General of Customs and apparently borrowed by him from his memorandum
                    suggesting measure for emergency financial relief as fully described in my
                    telegram 371, October 26, noon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schurman</hi>
                    </signed>
                </closer>
            </div>
        </body>
