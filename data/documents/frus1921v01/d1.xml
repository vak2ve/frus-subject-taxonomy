                subtype="historical-document" type="document" xml:id="d1">
                <note rend="inline" type="source">763.72119/10799a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in France</hi> (<persName type="to">
                        <hi rend="italic">Wallace</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-12-15T17:00:00-05:00">
                            <hi rend="italic">December 15, 1920—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1703. Discontinuance of participation in meetings of the Council of Ambassadors
                    has practically been decided upon. I should like to have your views as to the
                    best procedure if and when the decision is made effective.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
