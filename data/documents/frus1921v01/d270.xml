                subtype="historical-document" type="document" xml:id="d270">
                <note rend="inline" type="source">893.00/3800: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Crane</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1921-03-25T10:00:00+08:00">
                            <hi rend="italic">March 25, 1921—10 a.m.</hi>
                        </date>
                        <lb/>[Received March 25—2:09 a.m.]</dateline>
                </opener>
                <p>129. Monarchial agitation increasing daily, meeting being held Mukden of
                    adherents friends Chang Tso-lin<note n="1" xml:id="d270fn1">Inspector General of
                        the Three Eastern Provinces.</note> to discuss matter.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Crane</hi>
                    </signed>
                </closer>
            </div>
        </body>
