                subtype="historical-document" type="document" xml:id="d779">
                <note rend="inline" type="source">839.00/2339: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in the Dominican Republic</hi> (<persName
                        type="from">
                        <hi rend="italic">Russell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1921-02-16T17:00:00-04:40">
                            <hi rend="italic">February 16, 1921—5 p.m.</hi>
                        </date>
                        <lb/>[Received February 17—2:15 p.m.]</dateline>
                </opener>
                <p>11. The seven members of the Commission with Judge Ostrand met and organized for
                    business today.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Russell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
