                subtype="historical-document" type="document" xml:id="d266">
                <note rend="inline" type="source">611.429/905: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Harvey</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1921-10-12T12:00:00+00:00">
                            <hi rend="italic">October 12, 1921—noon</hi>
                        </date>.<lb/>[Received October 12—10:08 a.m.]</dateline>
                </opener>
                <p>815. My 768 of September 22, noon, and previous telegrams,<note n="15"
                        xml:id="d266fn15">Not printed.</note> I have just received a note from the
                    Foreign Office stating that they <pb facs="0424" n="300" xml:id="pg_300"/>
                    prefer that the matter be handled direct with the Dominion Government through
                    the British Embassy at Washington.</p>
                <p>I am mailing copies of the note<note n="15a" xml:id="d266fn15a">Not
                        printed.</note> in the next pouch.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Harvey</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
