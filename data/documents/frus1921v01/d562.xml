                subtype="historical-document" type="document" xml:id="d562">
                <note rend="inline" type="source">861.77/2176: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Harvey</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1921-07-25T13:00:00+01:00">
                            <hi rend="italic">July 25, 1921—1 p.m.</hi>
                        </date>
                        <lb/>[Received July 25—12:07 p.m.]</dateline>
                </opener>
                <p>611. Your telegrams 405, July 15, 5 [<hi rend="italic">6</hi>] p.m. and 407, July
                    16, 1 p.m.<note n="17" xml:id="d562fn17">Latter not printed.</note> Foreign
                    Office states that British Minister at Peking has been instructed in the event
                    of the question of the bond issue being raised again by the Chinese Minister of
                    Communications to support view of the United States Government as laid down in
                    memorandum handed to the Chinese Minister at Washington on July 14, 1921.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Harvey</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
