<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1921-11-26T11:00:00-05:00" frus:doc-dateTime-min="1921-11-26T11:00:00-05:00" n="633" subtype="historical-document" type="document" xml:id="d633">
                        <note rend="inline" type="source">818.51/190: Telegram</note>
                        <head><hi rend="italic">The Chargé in Costa Rica</hi> (<persName type="from"><hi rend="italic">Thurston</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">San
                                        José</hi></placeName>, <date calendar="gregorian" when="1921-11-26T10:00:00-06:00"><hi rend="italic">November 26,
                                        1921—10 a.m.</hi></date><lb/>[Received 11:55
                                p.m.]</dateline></opener>
                        <p>136. My 134 November 22, 10 a.m.<note n="23" xml:id="d633fn23">Not
                                printed.</note> Congress last evening by 25 to 13 votes approved
                            committee report unfavorable to Royal Bank loan.</p>
                        <closer><signed><hi rend="smallcaps">Thurston</hi></signed></closer>
                    </div>
