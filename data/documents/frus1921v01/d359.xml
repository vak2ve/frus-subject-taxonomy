                <note rend="inline" type="source">893.51/3603: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Schurman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1921-11-30T20:00:00+08:00">
                            <hi rend="italic">November 30, 1921—8 p.m.</hi>
                        </date>
                        <lb/>[Received November 30—12:11 p.m.]</dateline>
                </opener>
                <p>426. Pacific Development loan extended three months, interest to date paid
                    today.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schurman</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
