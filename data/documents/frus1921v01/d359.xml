<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1921-11-30T07:00:00-05:00" frus:doc-dateTime-min="1921-11-30T07:00:00-05:00" n="359" subtype="historical-document" type="document" xml:id="d359">
                            <note rend="inline" type="source">893.51/3603: Telegram</note>
                            <head><hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">Schurman</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1921-11-30T20:00:00+08:00"><hi rend="italic">November
                                            30, 1921—8 p.m.</hi></date><lb/>[Received November
                                    30—12:11 p.m.]</dateline></opener>
                            <p>426. Pacific Development loan extended three months, interest to date
                                paid today.</p>
                            <closer><signed><hi rend="smallcaps">Schurman</hi></signed></closer>
