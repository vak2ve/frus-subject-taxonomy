    <text>
        <body>
            <div frus:doc-dateTime-max="1921-09-12T23:59:59-05:00"
                frus:doc-dateTime-min="1921-09-12T00:00:00-05:00" n="128"
                subtype="historical-document" type="document" xml:id="d128">
                <note rend="inline" type="source">813.00/1108: Telegram</note>
                <head>
                    <hi rend="italic">The Honduran Acting Minister of Foreign Affairs</hi>
                        (<persName type="from">
                        <hi rend="italic">Reina</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation<note n="36" xml:id="d128fn36">File
                            translation revised.</note>]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1921-09-12">
                            <hi rend="italic">September 12, 1921</hi>
                        </date>.<lb/>[Received 10:40 a.m.]</dateline>
                </opener>
                <p>The Ministry of Foreign Affairs of Honduras, by direction of the Provisional
                    Federal Council of the Republic of Central America, has the honor to inform Your
                    Excellency that the National Constituent Assembly signed the Political
                    Constitution of the new republic yesterday<note n="37" xml:id="d128fn37">The
                        Constitution was signed Sept. 9.</note> in accordance with the stipulations
                    of the covenant of San José, Costa Rica.</p>
                <p>Very respectfully,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">A.R. Reina</hi>, Jr.</signed>
                </closer>
            </div>
        </body>
