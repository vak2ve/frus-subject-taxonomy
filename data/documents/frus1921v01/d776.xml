                <note rend="inline" type="source">839.00/2302: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in the Dominican Republic</hi> (<persName type="to">
                        <hi rend="italic">Russell</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1921-01-25T19:00:00-05:00">
                            <hi rend="italic">January 25, 1921—7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>5. Your 4, January 23, 5 p.m.</p>
                <p>The Department is willing to accept the recommendation offered by the Military
                    Governor and by yourself that the membership of the Commission be limited to
                    seven, …</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
