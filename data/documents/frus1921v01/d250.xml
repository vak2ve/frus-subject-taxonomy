                subtype="historical-document" type="document" xml:id="d250">
                <note rend="inline" type="source">824.00/181: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Bolivia</hi> (<persName type="from">
                        <hi rend="italic">Maginnis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">La Paz</hi>
                        </placeName>, <date calendar="gregorian" when="1921-02-09T17:00:00-04:32">
                            <hi rend="italic">February 9, 1921—5 p.m.</hi>
                        </date>
                        <lb/>[Received February 10—10:40 a.m.]</dateline>
                </opener>
                <p>17. Your February 4, 1 p.m. Recognition extended today at 3 p.m., by United
                    States, Argentina, Chile and Brazil.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Maginnis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
