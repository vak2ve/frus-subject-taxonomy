<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1921-12-14T11:00:00-05:00" frus:doc-dateTime-min="1921-12-14T11:00:00-05:00" n="634" subtype="historical-document" type="document" xml:id="d634">
                        <note rend="inline" type="source">818.6363 Am 6/112: Telegram</note>
                        <head><hi rend="italic">The Chargé in Costa Rica</hi> (<persName type="from"><hi rend="italic">Thurston</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">San
                                        José</hi></placeName>, <date calendar="gregorian" when="1921-12-14T10:00:00-06:00"><hi rend="italic">December 14,
                                        1921—10 a.m.</hi></date><lb/>[Received December 15—9:30
                                a.m.]</dateline></opener>
                        <p>139. My 135.<note n="23" xml:id="d634fn23">Not printed.</note> Congress
                            yesterday approved report of Committee on Foreign Affairs permitting
                            arbitration of Amory petroleum and Royal Bank claims. Details by
                                mail.<note n="23" xml:id="d634fn24">Not printed.</note></p>
                        <closer><signed><hi rend="smallcaps">Thurston</hi></signed></closer>
                    </div>
