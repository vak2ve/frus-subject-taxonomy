                subtype="historical-document" type="document" xml:id="d468">
                <note rend="inline" type="source">893.102 Ic/22: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in China</hi> (<persName type="to">
                        <hi rend="italic">Ruddock</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1921-08-26T11:00:00-04:00">
                            <hi rend="italic">August 26, 1921—11 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>238. Your 295 August 23, 10 p.m.</p>
                <p>Department approves arrangement with attached proviso but reserves right to
                    refuse to support any claim which it believes to be unjust. Mail instruction
                    follows relating specially to compensatory claim.<note n="6" xml:id="d468fn6">No
                        record in Department that mail instruction was sent.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
