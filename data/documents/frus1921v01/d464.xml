                subtype="historical-document" type="document" xml:id="d464">
                <note rend="inline" type="source">893.102 Ic/16: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName type="from">
                        <hi rend="italic">Ruddock</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1921-08-09T22:00:00+08:00">
                            <hi rend="italic">August 9, 1921—10 p.m.</hi>
                        </date>
                        <lb/>[Received August 10—9:26 a.m.]</dateline>
                </opener>
                <p>284. Your 216, July 30th, 5 p.m. No evidence antiforeign feeling or particular
                    consideration for foreigners.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Ruddock</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
