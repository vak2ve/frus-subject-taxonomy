                subtype="historical-document" type="document" xml:id="d512">
                <note rend="inline" type="source">893.113/207: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from">
                        <hi rend="italic">Child</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1921-12-17T14:00:00+01:00">
                            <hi rend="italic">December 17, 1921—2 p.m.</hi>
                        </date>
                        <lb/>[Received December 17—1:35 p.m.]</dateline>
                </opener>
                <p>261. British and French colleagues have been instructed to join in action
                    suggested my cable no. 258, December 13, 1 p.m. They and Japanese Chargé
                    d’Affaires await your instructions to me.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Child</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
