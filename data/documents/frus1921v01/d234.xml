<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1921-11-30T08:00:00-05:00" frus:doc-dateTime-min="1921-11-30T08:00:00-05:00" n="234" subtype="historical-document" type="document" xml:id="d234">
                        <note rend="inline" type="source">123 F 861/134: Telegram</note>
                        <head><hi rend="italic">The Chargé in Austria</hi> (<persName type="from"><hi rend="italic">Frazier</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Vienna</hi></placeName>, <date calendar="gregorian" when="1921-11-30T14:00:00+01:00"><hi rend="italic">November 30,
                                        1921—2 p.m.</hi></date><lb/>[Received 10:10
                            p.m.]</dateline></opener>
                        <p>215. My telegram number 212, November 26, 12 noon.<note n="13" xml:id="d234fn13">Not printed.</note> Austrian Government recognized
                            me as Chargé d’Affaires and received me as such November 26th.</p>
                        <closer><signed><hi rend="smallcaps">Crazier</hi></signed></closer>
                    </div>
                </body></text></TEI>