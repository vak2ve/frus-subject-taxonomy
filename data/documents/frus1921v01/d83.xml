    <text>
        <body>
            <div frus:doc-dateTime-max="1921-09-12T04:00:00-05:00"
                frus:doc-dateTime-min="1921-09-12T04:00:00-05:00" n="83"
                subtype="historical-document" type="document" xml:id="d83">
                <note rend="inline" type="source">500.A41a/3: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Japan</hi> (<persName type="from">
                        <hi rend="italic">Bell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1921-09-12T18:00:00+09:00">
                            <hi rend="italic">September 12, 1921—6 p.m.</hi>
                        </date>
                        <lb/>[Received September 12—9:58 a.m.]</dateline>
                </opener>
                <p>293. Your 151, September 10, 3 p.m.<note n="78" xml:id="d83fn78">See footnote 77,
                            <ref target="#pg_67">p. 67</ref>.</note> Foreign Office inquire what is
                    meant by phrase “Status of Existing Commitments”.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bell</hi>
                    </signed>
                </closer>
            </div>
        </body>
