                subtype="historical-document" type="document" xml:id="d39">
                <note rend="inline" type="source">500.A4/11: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in France</hi> (<persName type="from">
                        <hi rend="italic">Whitehouse</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1921-07-12T11:00:00+01:00">
                            <hi rend="italic">July 12, 1921—11 a.m.</hi>
                        </date>
                        <lb/>[Received 12: 02 p.m.]</dateline>
                </opener>
                <p>439a. My 438 [<hi rend="italic">439</hi>], July 11, noon.<note n="33"
                        xml:id="d39fn33">Not printed.</note> French Government will be very happy to
                    receive an invitation to proposed conference.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Whitehouse</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
