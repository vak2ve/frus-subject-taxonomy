    <text>
        <body>
            <div frus:doc-dateTime-max="1921-06-20T23:59:59-05:00"
                frus:doc-dateTime-min="1921-06-20T00:00:00-05:00" n="674"
                subtype="historical-document" type="document" xml:id="d674">
                <note rend="inline" type="source">837.00/2137</note>
                <head>
                    <hi rend="italic">The Representative on Special Mission in Cuba</hi> (<persName
                        type="from">
                        <hi rend="italic">Crowder</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1921-06-20">
                            <hi rend="italic">June 20, 1921</hi>
                        </date>.<lb/>[Received June 29.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Secretary</hi>: I have the honor to transmit
                    herewith copy of the paraphrase of your No. 121 in the form in which I submitted
                    it to President Zayas.<note n="28" xml:id="d674fn28">No. 121, <hi rend="italic"
                            >supra</hi>; paraphrase not printed.</note>
                </p>
                <p>There are to be noted only such verbal changes as would protect the cipher in
                    which the telegram was translated [<hi rend="italic">transmitted?</hi>]</p>
                <p>Very respectfully,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">E. H. Crowder</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
