                subtype="historical-document" type="document" xml:id="d178">
                <note rend="inline" type="source">718.1915/588: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Costa Rica</hi> (<persName type="from">
                        <hi rend="italic">Thurston</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San José</hi>
                        </placeName>, <date calendar="gregorian" when="1921-09-07T00:00:00-06:00">
                            <hi rend="italic">September 7, 1921—12 a.m.</hi>
                        </date>
                        <lb/>[Received September 8—10:10 a.m.]</dateline>
                </opener>
                <p>125. Messenger has just arrived Punta Arenas announcing that Costa Rican forces
                    took peaceable possession of Coto region late afternoon September 5th.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Thurston</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
