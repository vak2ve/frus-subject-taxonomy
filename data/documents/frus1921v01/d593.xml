                subtype="historical-document" type="document" xml:id="d593">
                <note rend="inline" type="source">861.77/2344: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName type="from">
                        <hi rend="italic">Warren</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1921-12-05T13:00:00+09:00">
                            <hi rend="italic">December 5, 1921—1 p.m.</hi>
                        </date>
                        <lb/>[Received December 9—9:06 a.m.]</dateline>
                </opener>
                <p>413. My 410, December 6, 11 a.m. Following from Caldwell dated December 7, 9
                    p.m.: <pb facs="0737" n="613" xml:id="pg_613"/>
                    <quote rend="blockquote">
                        <p>“Supplementing my 9, December 3, 9 p.m. I have received written statement
                            from Minister for Foreign Affairs confirming his verbal statement that
                            officially he considers that only Soviet Russia and China and to some
                            extent Far Eastern Republic have a right to arrange such matters as
                            international control of Chinese Eastern Railway … [”]</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Warren</hi>
                    </signed>
                </closer>
            </div>
        </body>
