    <text>
        <body>
            <div frus:doc-dateTime-max="1921-01-07T15:00:00-05:00"
                frus:doc-dateTime-min="1921-01-07T15:00:00-05:00" n="761"
                subtype="historical-document" type="document" xml:id="d761">
                <note rend="inline" type="source">837.73/27: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Cuba</hi> (<persName type="to">
                        <hi rend="italic">Long</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1921-01-07T15:00:00-05:00">
                            <hi rend="italic">January 7, 1921—3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>7. Your 360, December 24, 8 p.m.<note n="18" xml:id="d761fn18">
                        <ref target="frus1920v02#pg_69">
                            <hi rend="italic">Ibid.</hi>, p. 69</ref>.</note> Send by mail a copy of
                    the decree suspending the cable permit of the Western Union Telegraph
                    Company.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
