                subtype="historical-document" type="document" xml:id="d290">
                <note rend="inline" type="source">893.00/3979: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName type="from">
                        <hi rend="italic">Ruddock</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1921-07-28T11:00:00+08:00">
                            <hi rend="italic">July 28, 1921—11 a.m.</hi>
                        </date>
                        <lb/>[Received July 28—8:30 a.m.]</dateline>
                </opener>
                <p>272. Canton reports Nanning and principal towns eastern Kwangsi captured. Li
                    Lu-ting [<hi rend="italic">Lu Yung-ting?</hi>]<note n="15" xml:id="d290fn15"
                        >Inspector General of Kwangtung and Kwangsi.</note> has fled. Recapture
                    Pakhoi expected daily. Kwangsi practically under control Kwangtung.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Ruddock</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
