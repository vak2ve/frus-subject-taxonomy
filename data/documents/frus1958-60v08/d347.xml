                <head>347. Memorandum of Conversation<note n="0" type="source" xml:id="d347fn0"
                        >Source: Department of State, Conference Files: Lot 64 D 560, <gloss
                            target="#t_CF1">CF</gloss> 1339. Secret. Drafted by <persName
                            corresp="#p_HMJ1">Hillenbrand</persName> and concurred in by <persName
                            corresp="#p_MLT1">Merchant</persName>. The meeting was held in the
                        French Delegation Office.</note>
                </head>
                <opener>
                    <seg rendition="#left">US/<gloss target="#t_MC1">MC</gloss>/68</seg>
                    <dateline rendition="#right">
                        <placeName>Geneva</placeName>, <date calendar="gregorian"
                            type="conversation-or-meeting-date" when="1959-06-01T10:30:00+01:00"
                            >June 1, 1959, 10:30 a.m.</date>
                    </dateline>
                </opener>
                <p rend="center">MEETING OF FOREIGN MINISTERS PALAIS DES NATIONS, GENEVA, 1959</p>
                <list type="participants">
                    <head>PARTICIPANTS</head>
                    <item>
                        <hi rend="italic">United States</hi>
                        <list>
                            <item>Mr. <persName corresp="#p_MLT1">Merchant</persName>
                            </item>
                            <item>Mr. <persName corresp="#p_RGF1">Reinhardt</persName>
                            </item>
                            <item>Mr. <persName corresp="#p_BAH1">Berding</persName>
                            </item>
                            <item>Mr. <persName corresp="#p_IJN1">Irwin</persName>
                            </item>
                            <item>Mr. <persName corresp="#p_BLE1">Becker</persName>
                            </item>
