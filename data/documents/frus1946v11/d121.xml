            <div frus:doc-dateTime-max="1946-10-04T19:00:00-05:00" frus:doc-dateTime-min="1946-10-04T19:00:00-05:00" n="121" subtype="historical-document" type="document" xml:id="d121">
                <note rend="inline" type="source">832.61311/10–446: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Brazil</hi> (<persName type="to">
                        <hi rend="italic">Darnels</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1946-10-04T19:00:00-05:00">October 4, 1946—7 p.m.</date>
                    </dateline>
                </opener>
                <p>1296. Arrangements made for fourth quarter allocation 120,000 long tons wheat and
                    wheat equivalent for Brazil in addition to 8,000 long tons wheat and 52,000 tons
                    flour (wheat equivalent) previously allocated for Sep–Oct. Arrange suitable
                    publicity.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Acheson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
