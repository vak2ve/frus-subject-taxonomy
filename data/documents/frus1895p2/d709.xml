    <text>
        <body>
            <div frus:doc-dateTime-max="1895-12-30T23:59:59-05:00"
                frus:doc-dateTime-min="1895-12-30T00:00:00-05:00" n="709"
                subtype="historical-document" type="document" xml:id="d709">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr. <persName
                            type="to">Terrell</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-12-30">
                            <hi rend="italic">December 30, 1895</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 749.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your No.
                    719, of the 12th instant, and to approve your course in addressing to the
                    minister for foreign affairs your appreciation of the gratifying conduct of the
                    Turkish officers and soldiers in protecting American citizens and their property
                    during the disturbances at Aintab on the 16th ultimo.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Richard Olney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
