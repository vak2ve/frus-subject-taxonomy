    <text>
        <body>
            <div frus:doc-dateTime-max="1895-11-17T23:59:59-05:00" frus:doc-dateTime-min="1895-11-17T00:00:00-05:00" n="630" subtype="historical-document" type="document" xml:id="d630">
                <head>
                    <hi rend="italic">
                        <persName type="from">Mavroyeni Bey</persName> to Mr.
                                    <persName type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Imperial Legation of Turkey</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-11-17">
                            <hi rend="italic">November 17,
                                    1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Mr. <hi rend="smallcaps">Secretary of State</hi>: I hasten to send to
                            your excellency the following copy of a telegram which I have received
                            this very instant from the Sublime Porte.</p>
                <quote rend="blockquote">
                    <p>Security missionaries completely assured. Please deny contrary
                                publications.</p>
                </quote>
                <p>Be pleased to accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Mavroyeni.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
