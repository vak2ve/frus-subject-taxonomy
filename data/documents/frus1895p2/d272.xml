    <text>
        <body>
            <div frus:doc-dateTime-max="1895-09-26T23:59:59-05:00" frus:doc-dateTime-min="1895-09-26T00:00:00-05:00" n="272" subtype="historical-document" type="document" xml:id="d272">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Neill</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-09-26">
                            <hi rend="italic">September 26,
                                    1895</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 131.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have received your No. 237, of August
                            29, 1895, inclosing copy of your note to the Peruvian foreign office
                            urging that the claim of the <pb facs="0321" n="1055" xml:id="pg_1055"/>
                            Hydrographic Commission of the Amazon should be brought before the
                            Peruvian Congress at its present session.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Richard Olney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
