                subtype="historical-document" type="document" xml:id="d91">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Mr. <persName
                            type="to">Young</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-03-19">
                            <hi rend="italic">March 19, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Naval investigation establishes Renton’s murder. Urge Honduras Government to take
                    prompt action lest delay enable guilty parties to escape punishment.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Uhl</hi>, <hi rend="italic">Acting.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
