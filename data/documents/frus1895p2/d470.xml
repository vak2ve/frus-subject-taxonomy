    <text>
        <body>
            <div frus:doc-dateTime-max="1896-01-07T23:59:59-05:00"
                frus:doc-dateTime-min="1896-01-07T00:00:00-05:00" n="470"
                subtype="historical-document" type="document" xml:id="d470">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr. <persName
                            type="to">Dupuy de Lôme</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-01-07">
                            <hi rend="italic">January 7, 1896</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 65.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 31st ultimo, and beg to thank you for your courtesy in
                    telegraphing to the Captain-General of Cuba, urging him to endeavor, as far as
                    possible, to protect the property of Messrs. E. Atkins &amp; Co., of Boston,
                    from devastation.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Richard Olney</hi>.</signed>
                </closer>
            </div>
        </body>
