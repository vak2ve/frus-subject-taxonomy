                subtype="historical-document" type="document" xml:id="d2">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Alexander</persName> to Mr.
                            <persName type="to">Gresham</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Athens</hi>
                        </placeName>, <date calendar="gregorian" when="1895-03-16">
                            <hi rend="italic">March 16, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Trade-mark declaration considered valid here. Can reopen question, but we and
                    other nations probably lose present advantages. Shall I reopen?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alexander.</hi>
                    </signed>
                </closer>
            </div>
        </body>
