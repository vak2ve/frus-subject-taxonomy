<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1895-05-02T23:59:59-05:00" frus:doc-dateTime-min="1895-05-02T00:00:00-05:00" n="491" subtype="historical-document" type="document" xml:id="d491">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Terrell</persName> to Mr.
                                    <persName type="to">Gresham</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Pera</hi></placeName>, <date calendar="gregorian" when="1895-05-02"><hi rend="italic">May 2,
                                1895</hi></date>.</dateline></opener>
                        <p>Have received information from the Sublime Porte that the Sultan has
                            issued irade for Marsovan College.</p>
                        <closer>
                            <signed><hi rend="smallcaps">Terrell</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>