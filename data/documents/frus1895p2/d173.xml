                subtype="historical-document" type="document" xml:id="d173">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Butler</persName> to Mr. <persName
                            type="to">Gresham</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1895-04-01">
                            <hi rend="italic">April 1, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Congress has just opened. President’s message declared. Convention signed with
                    Guatemala.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Butler.</hi>
                    </signed>
                </closer>
            </div>
        </body>
