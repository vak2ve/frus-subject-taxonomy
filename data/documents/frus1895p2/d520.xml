    <text>
        <body>
            <div frus:doc-dateTime-max="1895-01-26T23:59:59-05:00" frus:doc-dateTime-min="1895-01-26T00:00:00-05:00" n="520" subtype="historical-document" type="document" xml:id="d520">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Mr.
                                    <persName type="to">Terrell</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-01-26">
                            <hi rend="italic">January 26,
                                    1895</hi>.</date>
                    </dateline>
                    <seg rendition="#left">No. 328.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                            Nos. 376 and 386, of the respective dates of December 20, 1894, and
                            January 7, 1895, relating to the unauthorized search of Bev. Mr. Lee’s
                            house in Marash, and to commend the promptness and firmness of your
                            actions therein reported.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edwin F. Uhl</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
