    <text>
        <body>
            <div frus:doc-dateTime-max="1895-07-17T23:59:59-05:00" frus:doc-dateTime-min="1895-07-17T00:00:00-05:00" n="376" subtype="historical-document" type="document" xml:id="d376">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Taylor</persName> to Mr.
                                    <persName type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1895-07-17">
                            <hi rend="italic">July 17,
                                1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Council, Queen presiding, authorized immediate settlement Mora matter as
                            liquidated yesterday.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Taylor.</hi>
                    </signed>
                </closer>
            </div>
        </body>
