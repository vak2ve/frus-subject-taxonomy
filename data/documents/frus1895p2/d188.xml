    <text>
        <body>
            <div frus:doc-dateTime-max="1895-07-18T23:59:59-05:00" frus:doc-dateTime-min="1895-07-18T00:00:00-05:00" n="188" subtype="historical-document" type="document" xml:id="d188">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr.
                                    <persName type="to">Butler</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-07-18">
                            <hi rend="italic">July 18,
                                1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Request provisional arrest and detention Richard Rowe, charged as
                            accomplice in embezzlement public moneys Iowa. Accused has assumed named
                            Richard Rose, of Rose Brothers, Second Plateros, Number 2, Mexico.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Adee</hi>, <hi rend="italic">Acting.</hi>
                    </signed>
                </closer>
            </div>
        </body>
