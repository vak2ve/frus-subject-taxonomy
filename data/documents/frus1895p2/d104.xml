    <text>
        <body>
            <div frus:doc-dateTime-max="1896-02-06T23:59:59-05:00" frus:doc-dateTime-min="1896-02-06T00:00:00-05:00" n="104" subtype="historical-document" type="document" xml:id="d104">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Young</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-02-06">
                            <hi rend="italic">February 6,
                                1896</hi>
                        </date>.</dateline>
                </opener>
                <p>Renton claim held in abeyance reasonable time to await result criminal
                            prosecution.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Olney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
