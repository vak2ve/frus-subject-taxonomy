    <text>
        <body>
            <div frus:doc-dateTime-max="1895-12-27T23:59:59-05:00" frus:doc-dateTime-min="1895-12-27T00:00:00-05:00" n="286" subtype="historical-document" type="document" xml:id="d286">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Breckinridge</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-12-27">
                            <hi rend="italic">December 27,
                                    1895</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 156.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have received your No. 181, of the 6th
                            instant, and have to approve your note to Prince Lobanow of that date,
                            in regard to the visé of American passports.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Richard Olney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
