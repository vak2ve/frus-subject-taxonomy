    <text>
        <body>
            <div frus:doc-dateTime-max="1895-10-08T23:59:59-05:00" frus:doc-dateTime-min="1895-10-08T00:00:00-05:00" n="448" subtype="historical-document" type="document" xml:id="d448">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Dupuy de Lôme</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-10-08">
                            <hi rend="italic">October 8,
                                1895</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 43.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your telegram of the 7th instant, and to say that I have
                            transmitted a copy of the same to the Attorney-General, that through him
                            the district attorney at Wilmington, N. C., may be put in possession of
                            the significant facts stated in your dispatch.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Richard Olney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
