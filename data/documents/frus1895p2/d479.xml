    <text>
        <body>
            <div frus:doc-dateTime-max="1894-12-29T23:59:59-05:00" frus:doc-dateTime-min="1894-12-29T00:00:00-05:00" n="479" subtype="historical-document" type="document" xml:id="d479">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Mr.
                                    <persName type="to">Terrell</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-12-29">
                            <hi rend="italic">December 29,
                                    1894</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 296.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I inclose herewith, for report and such
                            action as may be proper, copy of a letter<note n="1" xml:id="d479fn1">Not printed.</note> from the foreign secretary of the American
                            Board of Commissioners for Foreign Missions requesting your aid to
                            secure an Imperial firman for the American College for Girls at
                            Constantinople.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edwin F. Uhl</hi>, <hi rend="italic">Acting
                                    Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
