    <text>
        <body>
            <div frus:doc-dateTime-max="1895-04-01T23:59:59-05:00"
                frus:doc-dateTime-min="1895-04-01T00:00:00-05:00" n="419"
                subtype="historical-document" type="document" xml:id="d419">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Mr. <persName
                            type="to">Muruaga</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-04-01">
                            <hi rend="italic">April 1, 1895</hi>.</date>
                    </dateline>
                    <seg rendition="#left">No. 11.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge receipt of your
                    note of the 30th ultimo, in which you state that you are in possession of
                    official information to the effect that volunteers for the Island of Cuba are
                        <pb facs="0459" n="1193" xml:id="pg_1193"/> being publicly recruited at New
                    Orleans in violation of the neutrality laws.</p>
                <p>A copy of your note has been sent to the Attorney-General.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. Q. Gresham.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
