    <text>
        <body>
            <div frus:doc-dateTime-max="1892-10-27T23:59:59-05:00"
                frus:doc-dateTime-min="1892-10-27T00:00:00-05:00" n="267"
                subtype="historical-document" type="document" xml:id="d267">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Wharton</persName> to Mr. <persName
                            type="to">Hicks</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-10-27">
                            <hi rend="italic">October 27, 1892</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 235.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have been gratified to receive your No. 425 of
                    the 16th ultimo, informing me that you are advised by the Peruvian foreign
                    office that the claim of the Hydrographic Commission of the Amazon will be
                    presented to Congress.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William F. Wharton</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
