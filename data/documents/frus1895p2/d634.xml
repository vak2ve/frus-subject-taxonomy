    <text>
        <body>
            <div frus:doc-dateTime-max="1895-11-19T23:59:59-05:00"
                frus:doc-dateTime-min="1895-11-19T00:00:00-05:00" n="634"
                subtype="historical-document" type="document" xml:id="d634">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr. <persName
                            type="to">Terrell</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-11-19">
                            <hi rend="italic">November 19, 1895</hi>.</date>
                    </dateline>
                    <seg rendition="#left">No. 667.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I append on the overleaf a copy of your telegram
                    of the 18th instant, and of mine of the same date, in regard to the destruction
                    of American property at Harpoot.</p>
                <pb facs="0610" n="1344" xml:id="pg_1344"/>
                <p>I approve your notification to the Porte that your Government would expect prompt
                    payment for all ascertained damages.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Richard Olney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
