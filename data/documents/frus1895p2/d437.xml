    <text>
        <body>
            <div frus:doc-dateTime-max="1895-09-18T23:59:59-05:00"
                frus:doc-dateTime-min="1895-09-18T00:00:00-05:00" n="437"
                subtype="historical-document" type="document" xml:id="d437">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr. <persName
                            type="to">Dupuy de Lôme</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-09-18">
                            <hi rend="italic">September 18, 1895</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 31.</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your telegram of this date [17], and to say in reply that I have communicated
                    with the Attorney-General, the Secretary of the Treasury, and the Secretary of
                        <pb facs="0466" n="1200" xml:id="pg_1200"/> the Navy, and asked their
                    earnest cooperation in the most diligent efforts to prevent any violations of
                    the neutrality laws of the United States, and for the arrest and punishment of
                    any persons found to he engaged therein.</p>
                <p>Faithfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Richard Olney</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
