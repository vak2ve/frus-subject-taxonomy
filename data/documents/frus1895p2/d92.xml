            <div frus:doc-dateTime-max="1895-03-23T23:59:59-05:00" frus:doc-dateTime-min="1895-03-23T00:00:00-05:00" n="92" subtype="historical-document" type="document" xml:id="d92">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Young</persName> to Mr.
                                    <persName type="to">Uhl</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Guatemala</hi>
                        </placeName>, <date calendar="gregorian" when="1895-03-23">
                            <hi rend="italic">March 23,
                                1895</hi>.</date>
                    </dateline>
                </opener>
                <p>Honduras promises to act promptly.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Young.</hi>
                    </signed>
                </closer>
            </div>
        </body>
