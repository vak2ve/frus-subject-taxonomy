<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1895-05-06T23:59:59-05:00" frus:doc-dateTime-min="1895-05-06T00:00:00-05:00" n="225" subtype="historical-document" type="document" xml:id="d225">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Baker</persName> to Mr.
                                    <persName type="to">Gresham</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Cuesta
                                        Mara</hi></placeName> [, <date ana="#date_undated-inferred-from-document-content" calendar="gregorian" type="received-date" when="1895-05-06">undated</date>.] (Received <hi rend="italic">May 6,
                                1895</hi>).</dateline></opener>
                        <p>English Nicaraguan differences adjusted. British vessels will leave
                            Corinto May 5.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Baker.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>