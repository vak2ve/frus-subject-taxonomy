                subtype="historical-document" type="document" xml:id="d42">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Peterson</persName> to Mr. <persName
                            type="to">Uhl</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vancouver, British Columbia</hi>
                        </placeName>,<lb/>
                        <date calendar="gregorian" when="1895-02-10">
                            <hi rend="italic">February 10, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>British steamship <hi rend="italic">Warrimoo</hi> arrived to-day, having on board
                    J. Cranstoun, destitute citizen of the United States, banished from Honolulu
                    without trial. Will take and forward deposition.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. F. Peterson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
