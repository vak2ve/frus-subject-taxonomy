                <head>
                    <hi rend="italic">Mr. <persName type="from">Breckinridge</persName> to
                                Mr. <persName type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">St.
                                        Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1895-09-17">
                            <hi rend="italic">September 17,
                                    1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Missionaries enter Siberia without previous condition.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Breckinridge.</hi>
                    </signed>
                </closer>
            </div>
