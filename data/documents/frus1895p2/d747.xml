    <text>
        <body>
            <div frus:doc-dateTime-max="1895-03-12T23:59:59-05:00" frus:doc-dateTime-min="1895-03-12T00:00:00-05:00" n="747" subtype="historical-document" type="document" xml:id="d747">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Andrade</persName> to Mr.
                                    <persName type="to">Gresham</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Venezuela</hi>,<lb/>
                            <hi rend="italic">Washington, D. C.</hi>
                        </placeName>, <date calendar="gregorian" when="1895-03-12">
                            <hi rend="italic">March
                                        12, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to request, in the name
                            of my Government and under the head of friendly service, that your
                            excellency may be pleased to authorize by cable the ambassador of the
                            United States at Paris to assume charge of the protection of Venezuelan
                            interests in France in the event of the minister of Venezuela making
                            such a proposition by reason of his having to leave that country.</p>
                <p>I avail myself, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">José Andrade.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
