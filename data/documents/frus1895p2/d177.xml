    <text>
        <body>
            <div frus:doc-dateTime-max="1895-10-04T23:59:59-05:00"
                frus:doc-dateTime-min="1895-10-04T00:00:00-05:00" n="177"
                subtype="historical-document" type="document" xml:id="d177">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr. <persName
                            type="to">Ransom</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-10-04">
                            <hi rend="italic">October 4, 1895</hi>.</date>
                    </dateline>
                </opener>
                <p>Department sees no objection your acting as arbitrator as desired by Mexico and
                    Guatemala.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Olney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
