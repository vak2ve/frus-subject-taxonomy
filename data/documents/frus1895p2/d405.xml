<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1895-05-04T23:59:59-05:00" frus:doc-dateTime-min="1895-05-04T00:00:00-05:00" n="405" subtype="historical-document" type="document" xml:id="d405">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Mr.
                                    <persName type="to">Taylor</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1895-05-04"><hi rend="italic">May 4,
                                1895</hi></date>.</dateline></opener>
                        <p>Your No. 344 received, and we await promised further action.</p>
                        <closer>
                            <signed><hi rend="smallcaps">Uhl</hi>, <hi rend="italic">Acting
                                    Secretary.</hi></signed>
                        </closer>
                    </div>
