<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1895-08-26T23:59:59-05:00" frus:doc-dateTime-min="1895-08-26T00:00:00-05:00" n="536" subtype="historical-document" type="document" xml:id="d536">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Terrell</persName> to Mr.
                                    <persName type="to">Olney</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Pera</hi></placeName>, <date calendar="gregorian" when="1895-08-26"><hi rend="italic">August 26,
                                1895</hi></date>.</dateline></opener>
                        <p>The Porte gives emphatic assurances of security for American citizens at
                            Tarsus.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Terrell.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>