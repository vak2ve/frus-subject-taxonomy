    <text>
        <body>
            <div frus:doc-dateTime-max="1878-05-31T23:59:59-05:00" frus:doc-dateTime-min="1878-05-31T00:00:00-05:00" n="233" subtype="historical-document" type="document" xml:id="d233">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Seward</persName> to Mr.
                                    <persName type="to">Gibbs</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1878-05-31">
                            <hi rend="italic">May 31,
                                1878</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 108.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to your dispatch No. 245, of the
                            27th ultimo, I transmit herewith a copy of a letter<note n="1" xml:id="d233fn1">Not printed.</note> addressed to the Hon. Eppa
                            Hunton, Member of Congress, in relation to the Noland claim on Peru.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">F. W. Sewärd</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
