                <head>
                    <hi rend="italic">Mr. <persName type="from">Butler</persName> to Mr. <persName
                            type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1895-07-20">
                            <hi rend="italic">July 20, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Parties arrested, and stolen funds embargoed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Butler.</hi>
                    </signed>
                </closer>
            </div>
