                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr. <persName
                            type="to">Butler</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-07-27">
                            <hi rend="italic">July 27, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Take no further action at present concerning extradition Chester Rowe.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Adee</hi>, <hi rend="italic">Acting.</hi>
                    </signed>
                </closer>
            </div>
        </body>
