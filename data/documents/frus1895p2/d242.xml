    <text>
        <body>
            <div frus:doc-dateTime-max="1885-10-19T23:59:59-05:00"
                frus:doc-dateTime-min="1885-10-19T00:00:00-05:00" n="242"
                subtype="historical-document" type="document" xml:id="d242">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName> to Mr. <persName
                            type="to">Buck</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1885-10-19">
                            <hi rend="italic">October 19, 1885</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 30.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to approve the tenor of your note in the
                    matter of the claim of members of the Hydrographic Commission of the River
                    Amazon, a copy of which you forwarded with your No. 31.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">T. F. Bayard.</hi>
                    </signed>
                </closer>
            </div>
        </body>
