    <text>
        <body>
            <div frus:doc-dateTime-max="1896-01-15T23:59:59-05:00" frus:doc-dateTime-min="1896-01-15T00:00:00-05:00" n="730" subtype="historical-document" type="document" xml:id="d730">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Terrell</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-01-15">
                            <hi rend="italic">January 15,
                                1896</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 790.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                            No. 740, of the 29th ultimo, reporting apprehensions of further
                            disorders at Marsovan, Marash, and Sivas, and to approve your urgent
                            representations at the palace.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Richard Olney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
