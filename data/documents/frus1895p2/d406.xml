    <text>
        <body>
            <div frus:doc-dateTime-max="1895-05-18T23:59:59-05:00" frus:doc-dateTime-min="1895-05-18T00:00:00-05:00" n="406" subtype="historical-document" type="document" xml:id="d406">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Mr.
                                    <persName type="to">Taylor</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-05-18">
                            <hi rend="italic">May 18,
                                1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Postpone formal acknowledgment of Spain’s last reply in <hi rend="italic">Alliança</hi> affair until instructed by the Department after
                            examination.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Uhl</hi>, <hi rend="italic">Acting.</hi>
                    </signed>
                </closer>
            </div>
        </body>
