                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr. <persName
                            type="to">Terrell</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-11-27">
                            <hi rend="italic">November 27, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Press for delivery of Guedjian to you for trial by you.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Olney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
