    <text>
        <body>
            <div frus:doc-dateTime-max="1895-10-12T23:59:59-05:00" frus:doc-dateTime-min="1895-10-12T00:00:00-05:00" n="451" subtype="historical-document" type="document" xml:id="d451">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Dupuy de Lôme</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-10-12">
                            <hi rend="italic">October 12,
                                1895</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 47.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I am requested by the honorable Secretary
                            of the Treasury to suggest the advisability of your requesting the
                            Spanish consul at Tampa to make applications or to give information
                            relative to alleged infractions of the neutrality laws of the United
                            States to the collector of customs at the port at which the revenue
                            cutter may be stationed, in all cases where the services of such vessel
                            are required.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Richard Olney</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
