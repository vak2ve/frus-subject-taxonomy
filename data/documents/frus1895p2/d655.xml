<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1895-12-03T23:59:59-05:00" frus:doc-dateTime-min="1895-12-03T00:00:00-05:00" n="655" subtype="historical-document" type="document" xml:id="d655">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Olney</persName> to
                                    <persName type="to">Mavroyeni Bey</persName>.</hi>
                        </head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1895-12-03"><hi rend="italic">December 3,
                                1895</hi></date>.</dateline>
                            <seg rendition="#left">No. 55.]</seg></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your note of the 2d instant, in which you cite a telegram
                            from your Government stating that the American missionaries in Turkey
                            are receiving proper protection.</p>
                        <p>Accept, etc.,</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Richard Olney.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>