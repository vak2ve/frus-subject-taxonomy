                <note rend="inline" type="source">836.48 1930 Hurricane/16: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in the Dominican Republic</hi> (<persName
                        type="from">
                        <hi rend="italic">Curtis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1930-09-06T18:00:00-04:40"
                            >September 6, 1930—6 p.m.</date>
                        <lb/>[Received 6:50 p.m.]</dateline>
                </opener>
                <p>99. My September 6, 5 p.m. Add name Barney Morgan to committee.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Curtis</hi>
                    </signed>
                </closer>
            </div>
        </body>
