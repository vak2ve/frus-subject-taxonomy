                subtype="historical-document" type="document" xml:id="d129">
                <note rend="inline" type="source">393.11/1180: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1930-07-01T11:00:00+08:00"
                            >July 1, 1930—11 a.m.</date>
                        <lb/>[Received July 1—10:20 a.m.]</dateline>
                </opener>
                <p>523. Legation’s 510, June 27, 10 p.m. Commander in Chief on June 29th directed U.
                    S. S. <hi rend="italic">Barker</hi> to proceed to Foochow and to report on
                    conditions there.</p>
                <closer>For the Minister:<lb/>
                    <signed>
                        <hi rend="smallcaps">Perkins</hi>
                    </signed>
                </closer>
            </div>
        </body>
