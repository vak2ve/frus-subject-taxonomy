    <text>
        <body>
            <div frus:doc-dateTime-max="1930-08-26T23:59:59-05:00"
                frus:doc-dateTime-min="1930-08-26T00:00:00-05:00" n="197"
                subtype="historical-document" type="document" xml:id="d197">
                <note rend="inline" type="source">893.00/11218</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1930-08-26">August 26,
                            1930</date>.<lb/>[Received September 24.]</dateline>
                    <seg rendition="#left">No. 425</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I beg leave to transmit herewith a copy of a
                    letter dated August 19, 1930, from the German Minister,<note n="87"
                        xml:id="d197fn87">Not printed.</note> in which Dr. von Borch expresses
                    appreciation for the services rendered by American naval ships, particularly the
                        <hi rend="italic">Palos</hi>, during the recent communist occupation of
                    Changsha. A copy of this letter has been forwarded to Admiral McVay with the
                    suggestion that the Commander of the <hi rend="italic">Palos</hi> be informed of
                    the German Minister’s sentiments.</p>
                <p>Respectfully yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Nelson Trusler Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
