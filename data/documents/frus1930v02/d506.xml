<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-08-14T04:00:00-05:00" frus:doc-dateTime-min="1930-08-14T04:00:00-05:00" n="506" subtype="historical-document" type="document" xml:id="d506">
                        <note rend="inline" type="source">793.003/391: Telegram</note>
                        <head><hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">Johnson</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><seg rendition="#center">[Extract]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peiping</hi></placeName>, <date calendar="gregorian" when="1930-08-14T17:00:00+08:00">August 14, 1930—5
                                p.m.</date><lb/>[Received August 15—4:30 a.m.<note n="53" xml:id="d506fn53">Telegram in three
                            sections.</note>]</dateline></opener>
                        <p>698. [Paraphrase.] Your 269, August 9, 2 p.m., last paragraph. I approve
                            the Department’s proposal to postpone the formal initiating of
                            negotiations respecting extraterritoriality. [End paraphrase.]</p>
                        <p rend="center">. . . . . . . . . . . . . .</p>
                        <closer><signed><hi rend="smallcaps">Johnson</hi></signed></closer>
                    </div>
                    </body></text></TEI>