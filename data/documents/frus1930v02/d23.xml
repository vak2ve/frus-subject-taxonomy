<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-09-17T11:00:00-05:00" frus:doc-dateTime-min="1930-09-17T11:00:00-05:00" n="23" subtype="historical-document" type="document" xml:id="d23">
                        <note rend="inline" type="source">893.00/11195: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in China</hi> (<persName type="to"><hi rend="italic">Johnson</hi></persName>)</head>
                        <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1930-09-17T12:00:00-04:00">September 17,
                                1930—noon</date>.</dateline></opener>
                        <p>323. Your 818, September 16, 10 p.m. The Department does not desire the
                            Consul General at Shanghai to transmit the suggested message if it is of
                            a political character.</p>
                        <closer><signed><hi rend="smallcaps">Stimson</hi></signed></closer>
                    </div>
                    </body></text></TEI>