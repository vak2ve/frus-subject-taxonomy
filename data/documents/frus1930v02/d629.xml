                subtype="historical-document" type="document" xml:id="d629">
                <note rend="inline" type="source">893.711/67: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from">
                        <hi rend="italic">Cunningham</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1930-03-26T13:00:00+08:00"
                            >March 26, 1930—1 p.m.</date>
                        <lb/>[Received March 26—9:40 a.m.]</dateline>
                </opener>
                <p>Referring to this Consulate General’s telegram of February 20, 2 p.m.<note n="77"
                        xml:id="d629fn77">Not printed.</note> The postal ban on the <hi
                        rend="italic">Shanghai Evening Post</hi> was removed on March 23. (Repeated
                    to the Legation.)</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cunningham</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
