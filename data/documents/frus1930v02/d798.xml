                subtype="historical-document" type="document" xml:id="d798">
                <note rend="inline" type="source">839.00 Revolutions/12: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in the Dominican Republic</hi> (<persName
                        type="from">
                        <hi rend="italic">Curtis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1930-02-25T15:00:00-04:40"
                            >February 25, 1930—3 p.m.</date>
                        <lb/>[Received 4:41 p.m.]</dateline>
                </opener>
                <p>17. Add to leaders named in my February 24, 4 p.m., Elias Brache, Desiderio Arias
                    and a General Perez, presumably Fermin.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Curtis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
