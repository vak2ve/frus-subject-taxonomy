                subtype="historical-document" type="document" xml:id="d531">
                <note rend="inline" type="source">793.003/451: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1930-11-09T11:00:00+08:00"
                            >November 9, 1930—11 a.m.</date>
                        <lb/>[Received November 9—1:52 a.m.]</dateline>
                </opener>
                <p>972. Following from Minister Johnson, Shanghai: <quote rend="blockquote">
                        <p>“November 8, 5 p.m. Arrived 7th, gave Japanese Chargé d’Affaires copy
                            October 28th proposals this morning and will give copy to Wang either
                            here Sunday or in Nanking on Monday.…”</p>
                    </quote>
                </p>
                <closer>For the Minister:<lb/>
                    <signed>
                        <hi rend="smallcaps">Perkins</hi>
                    </signed>
                </closer>
            </div>
        </body>
