                subtype="historical-document" type="document" xml:id="d776">
                <note rend="inline" type="source">837.00/2929: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Cuba</hi> (<persName type="from">
                        <hi rend="italic">Guggenheim</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1930-12-16T14:00:00-05:00"
                            >December 16, 1930—2 p.m.</date>
                        <lb/>[Received 4:23 p.m.]</dateline>
                </opener>
                <p>171. Only very minor disturbances of peace in last two days, but several hundred
                    arrests have been made of alleged agitators.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Guggenheim</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
