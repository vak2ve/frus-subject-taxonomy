                subtype="historical-document" type="document" xml:id="d516">
                <note rend="inline" type="source">793.003/415: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1930-09-12T21:00:00+08:00"
                            >September 12, 1930—9 p.m.</date>
                        <lb/>[Received September 12—10:40 a.m.]</dateline>
                </opener>
                <p>809. Legation’s 808, September 12, 11 a.m.<note n="64" xml:id="d516fn64">Not
                        printed.</note> I am informed by the British Legation that British Minister
                    presented draft to the Minister for Foreign Affairs on the 11th and that it was
                    received without comment.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
