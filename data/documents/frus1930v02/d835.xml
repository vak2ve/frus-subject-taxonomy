<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-09-04T16:00:00-05:00" frus:doc-dateTime-min="1930-09-04T16:00:00-05:00" n="835" subtype="historical-document" type="document" xml:id="d835">
                        <note rend="inline" type="source">836.48 1930 Hurricane/7: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Chargé in Haiti</hi> (<persName type="to"><hi rend="italic">Grummon</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1930-09-04T17:00:00-04:00">September 4, 1930—5
                                p.m.</date></dateline></opener>
                        <p>100. Please report whether the hurricane has hit any portion of Haiti and
                            if so the extent of the damage.</p>
                        <closer><signed><hi rend="smallcaps">Cotton</hi></signed></closer>
                    </div>
                    </body></text></TEI>