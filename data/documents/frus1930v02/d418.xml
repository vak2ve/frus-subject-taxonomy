                subtype="historical-document" type="document" xml:id="d418">
                <note rend="inline" type="source">893.102 S/217: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in China</hi> (<persName type="to">
                        <hi rend="italic">Perkins</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1930-01-16T15:00:00-05:00"
                            >January 16, 1930—3 p.m.</date>
                    </dateline>
                </opener>
                <p>18. Your 42, January 13, 3 p.m. Department concurs in your views expressed in
                    paragraph 2. Legation should insist upon observance of procedure laid down in
                    Article 3 of Shanghai Land Regulations.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cotton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
