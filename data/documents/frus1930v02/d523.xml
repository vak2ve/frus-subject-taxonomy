                <note rend="inline" type="source">793.003/425: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in China</hi> (<persName type="to">
                        <hi rend="italic">Johnson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1930-09-23T12:00:00-04:00"
                            >September 23, 1930—noon</date>.</dateline>
                </opener>
                <p>328. Your 834, September 20, 9 p.m. Please telegraph text or substance of any
                    changes of importance.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cotton</hi>
                    </signed>
                </closer>
            </div>
        </body>
