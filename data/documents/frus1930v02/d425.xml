<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-05-10T10:00:00-05:00" frus:doc-dateTime-min="1930-05-10T10:00:00-05:00" n="425" subtype="historical-document" type="document" xml:id="d425">
                        <note rend="inline" type="source">893.102S/239: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in China</hi> (<persName type="to"><hi rend="italic">Johnson</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1930-05-10T11:00:00-04:00">May 10, 1930—11
                                a.m.</date></dateline></opener>
                        <p>162. Your 312, May 8, 10 a.m. Department is gratified that American
                            Minister associated himself with his colleagues in approving resolution
                            of Shanghai rate-payers.</p>
                        <closer><signed><hi rend="smallcaps">Stimson</hi></signed></closer>
                    </div>
                    </body></text></TEI>