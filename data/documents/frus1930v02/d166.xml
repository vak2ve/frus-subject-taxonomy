    <text>
        <body>
            <div frus:doc-dateTime-max="1930-08-02T12:00:00-05:00"
                frus:doc-dateTime-min="1930-08-02T12:00:00-05:00" n="166"
                subtype="historical-document" type="document" xml:id="d166">
                <note rend="inline" type="source">893.00/11032: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in China</hi> (<persName type="to">
                        <hi rend="italic">Johnson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1930-08-02T13:00:00-04:00"
                            >August 2, 1930—1 p.m.</date>
                    </dateline>
                </opener>
                <p>259. Your 640 of July 31, 4 p.m.</p>
                <list>
                    <label>1.</label>
                    <item>Department approves action taken.</item>
                    <label>2.</label>
                    <item>Japanese Embassy has inquired regarding action taken by this Government,
                        and Department has read to Counselor most of text, <pb facs="0258" n="160"
                            xml:id="pg_160"/> with explanation that Department has issued no special
                        instruction and action so far taken is under authority of general
                        instructions.</item>
                </list>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Carr</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
