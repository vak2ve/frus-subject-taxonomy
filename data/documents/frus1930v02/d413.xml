<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-03-12T10:00:00-05:00" frus:doc-dateTime-min="1930-03-12T10:00:00-05:00" n="413" subtype="historical-document" type="document" xml:id="d413">
                        <note rend="inline" type="source">893.05/276: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Minister in China</hi> (<persName type="to"><hi rend="italic">Johnson</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1930-03-12T10:00:00-05:00">March 12, 1930—10
                                a.m.</date></dateline></opener>
                        <p>90. Your 181, March 7, noon. Department approves, provided the Chinese
                            representatives are of correspondingly high position.</p>
                        <closer><signed><hi rend="smallcaps">Cotton</hi></signed></closer>
                    </div>
                    </body></text></TEI>