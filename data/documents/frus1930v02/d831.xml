    <text>
        <body>
            <div frus:doc-dateTime-max="1930-08-17T09:40:00-05:00"
                frus:doc-dateTime-min="1930-08-17T09:40:00-05:00" n="831"
                subtype="historical-document" type="document" xml:id="d831">
                <note rend="inline" type="source">839.002/133: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in the Dominican Republic</hi> (<persName
                        type="from">
                        <hi rend="italic">Curtis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1930-08-17T10:00:00-04:40"
                            >August 17, 1930—10 a.m.</date>
                        <lb/>[Received August 18—1:55 p.m.]</dateline>
                </opener>
                <p>93. Rafael Trujillo inaugurated President and Rafael Estrella Ureña Vice
                    President yesterday morning. Following Cabinet appointed:</p>
                <p rend="center">. . . . . . . . . . . . . .</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Curtis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
