<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-04-26T18:00:00-05:00" frus:doc-dateTime-min="1930-04-26T18:00:00-05:00" n="344" subtype="historical-document" type="document" xml:id="d344">
                        <note rend="inline" type="source">693.9431/42: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Minister in China</hi> (<persName type="to"><hi rend="italic">Johnson</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1930-04-26T18:00:00-05:00">April 26, 1930—6
                                p.m.</date></dateline></opener>
                        <p>146. Your 265, April 12, 4 p.m.<note n="4" xml:id="d344fn4">Not
                                printed.</note> In the opinion of this Department and of the
                            Department of Commerce, the favored nation provisions of our tariff
                            agreement with China entitle our trade to the benefit of any reduction
                            in rates which may be made in treaties with or which may be accorded to
                            any other country.</p>
                        <closer><signed><hi rend="smallcaps">Cotton</hi></signed></closer>
                    </div>
                    </body></text></TEI>