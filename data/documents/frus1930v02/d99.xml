                subtype="historical-document" type="document" xml:id="d99">
                <note rend="inline" type="source">893.00/10855: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1930-05-23T13:00:00+08:00"
                            >May 23, 1930—1 p.m.</date>
                        <lb/>[Received May 23—3:30 a.m.]</dateline>
                </opener>
                <p>360. Following from Hankow: <quote rend="blockquote">
                        <p>“May 22, noon. Steamship <hi rend="italic">Chi Ta</hi> of Yangtze Rapid
                            Steamship Company fired on 3 miles above Chenglingki May 20, presumably
                            by bandits. About 100 shots fired, of which several struck the vessel
                            wounding 1 Chinese member of the crew. Have lodged customary protest
                            with Chinese authorities.”</p>
                    </quote>
                </p>
                <closer>For the Minister:<lb/>
                    <signed>
                        <hi rend="smallcaps">Perkins</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
