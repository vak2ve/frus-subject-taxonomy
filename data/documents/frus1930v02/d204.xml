                subtype="historical-document" type="document" xml:id="d204">
                <note rend="inline" type="source">393.11/1269: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1930-08-29T17:00:00+08:00"
                            >August 29, 1930—5 p.m.</date>
                        <lb/>[Received August 29—1:40 p.m.]</dateline>
                </opener>
                <p>765. Canton’s August 28, noon. The Legation has telegraphically requested the
                    Ministry of Foreign Affairs to take steps to bring Yunnanese troops under
                    control and fully protect American life and property at Nanning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
