                subtype="historical-document" type="document" xml:id="d857">
                <note rend="inline" type="source">836.48 1930 Hurricane/61: Telegram</note>
                <head>
                    <hi rend="italic">President <persName type="from">Trujillo</persName> to
                        President <persName type="to">Hoover</persName>
                    </hi>
                    <note n="22" xml:id="d857fn22">Received in the Department of State September 29,
                        1930.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Translation]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1930-09-26">September 26,
                            1930</date>.</dateline>
                </opener>
                <p>I am very grateful to Your Excellency for the encouraging message of sympathy
                    which you sent me on the occasion of the terrible hurricane that scourged this
                    city the third day of this month.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Rafael L. Trujillo</hi>
                    </signed>
                </closer>
            </div>
        </body>
