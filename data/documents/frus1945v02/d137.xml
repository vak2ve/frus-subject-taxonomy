                <dateline>
                    <placeName>London</placeName>, <date ana="#date_undated-inferred-from-document-head" calendar="gregorian" when="1945-09-24T16:00:00+00:00">September 24, 1945, 4 p.m.</date>
                </dateline>
                <opener>
