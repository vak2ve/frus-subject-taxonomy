                            </cell>
                            <cell>
                                <hi rend="italic">Authorized or in process</hi>
                            </cell>
                            <cell>
                                <hi rend="italic">Paid or available</hi>
                            </cell>
                            <cell>
                                <hi rend="italic">Balance due in 1945</hi>
                            </cell>
                        </row>
                        <row>
                            <cell>Colombia</cell>
                            <cell role="num">$2,356</cell>
                            <cell role="num">$52</cell>
                            <cell role="num">$2,304</cell>
                        </row>
                        <row>
                            <cell>Costa Rica</cell>
                            <cell role="num">400</cell>
                            <cell role="num">0</cell>
                            <cell role="num">400</cell>
                        </row>
                        <row>
                            <cell>Dominican Republic</cell>
                            <cell role="num">350</cell>
                            <cell role="num">245</cell>
                            <cell role="num">105</cell>
                        </row>
                        <row>
                            <cell>Mexico</cell>
                            <cell role="num">3,602</cell>
                            <cell role="num">1,148</cell>
                            <cell role="num">2,454</cell>
                        </row>
                        <row>
