                            <cell role="num">35</cell>
                        </row>
                        <row>
                            <cell>Venezuela</cell>
                            <cell role="num">1,017</cell>
                            <cell role="num">17</cell>
                            <cell role="num">1,000</cell>
                        </row>
                        <row>
