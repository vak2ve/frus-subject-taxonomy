                <head>
                    <hi rend="italic">Record of Decisions of the Twenty-Sixth Meeting of the Council
                        of Foreign Ministers, Lancaster House, London, September 28, 1945, 5
                        p.m.</hi>
                    <note n="77" xml:id="d162fn77">As the discussion at this brief meeting was
                        confined to procedural matters, the United States delegation minutes of the
                        meeting are not printed.</note>
                </head>
                <dateline>
                    <placeName>London</placeName>, <date ana="#date_undated-inferred-from-document-head" calendar="gregorian" when="1945-09-28T17:00:00+00:00">September 28, 1945, 5 p.m.</date>
