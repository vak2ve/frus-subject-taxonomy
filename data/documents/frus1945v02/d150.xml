                        <cell>M. Bidault</cell>
                        <cell>Dr. Wang Shih Chieh (Chairman)</cell>
                    </row>
                    <row>
                        <cell>M. Couve de Murville</cell>
                        <cell>Dr. Wellington Koo</cell>
                    </row>
                    <row>
                        <cell>General Catroux</cell>
                        <cell>Dr. Victor Hoo</cell>
                    </row>
                    <row>
                        <cell>M. Alphand</cell>
                        <cell>Dr. Hollington Tong</cell>
                    </row>
                    <row>
