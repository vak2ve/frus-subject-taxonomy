                    </row>
                    <row>
                        <cell/>
                        <cell>Mr. C. E. Bohlen</cell>
                        <cell>M. V. N. Pavlov</cell>
                    </row>
                </table>
                <table rend="width: 80%" rendition="#center-block">
                    <row>
                        <cell rend="padding-left: 4em">
