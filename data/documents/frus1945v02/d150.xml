            <div frus:doc-dateTime-max="1945-09-26T06:00:00-05:00" frus:doc-dateTime-min="1945-09-26T06:00:00-05:00" n="150" subtype="historical-document" type="document" xml:id="d150">
                <note rend="inline" type="source">Council of Foreign Ministers Files: Lot M–88: CFM
                    London Decisions</note>
                <head>
                    <hi rend="italic">Record of Decisions of the Twenty-Third Meeting of the Council
                        of Foreign Ministers, Lancaster House, London, September 26, 1945, 11
                        a.m.</hi>
                </head>
                <dateline>
                    <placeName>London</placeName>, <date ana="#date_undated-inferred-from-document-head" calendar="gregorian" when="1945-09-26T11:00:00+00:00">September 26, 1945, 11 a.m.</date>
                </dateline>
                <opener>
                    <seg rendition="#left">C.F.M.(P)(45) 23rd Meeting</seg>
                </opener>
                <p rend="center">
                    <hi rend="smallcaps">Present</hi>
                </p>
                <table rend="width: 98%" rendition="#center-block">
                    <row>
                        <cell rend="padding-left: 4em">U.K.</cell>
                        <cell rend="padding-left: 4em">U.S.A</cell>
                        <cell rend="padding-left: 4em">U.S.S.R</cell>
                    </row>
                    <row>
                        <cell>Mr. Bevin</cell>
                        <cell>Mr. Byrnes</cell>
                        <cell>M. Molotov (Chairman)</cell>
                    </row>
                    <row>
                        <cell>Sir R. I. Campbell</cell>
                        <cell>Mr. J. Dunn</cell>
                        <cell>M. F. T. Gousev</cell>
                    </row>
                    <row>
                        <cell>Sir A. Clark Kerr</cell>
                        <cell>Mr. B. V. Cohen</cell>
                        <cell>M. K. V. Novikov</cell>
                    </row>
                    <row>
                        <cell>Mr. A. Duff Cooper</cell>
                        <cell>Mr. J. F. Dulles</cell>
