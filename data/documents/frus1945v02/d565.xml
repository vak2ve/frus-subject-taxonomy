<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-12-01T13:00:00-05:00" frus:doc-dateTime-min="1945-12-01T13:00:00-05:00" n="565" subtype="historical-document" type="document" xml:id="d565">
                    <note rend="inline" type="source">800.4016 D.P./11–1745: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            United States Political Adviser for Germany</hi> (<persName type="to"><hi rend="italic">Murphy</hi></persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1945-12-01T13:00:00-05:00">December 1,
                                1945—1 p.m.</date>
                        </dateline>
                    </opener>
                    <p>987. Suggestion re segregation Jewish displaced persons contained urtel 1041
                        Nov 17 viewed favorably by Dept. Please inform Dept re ultimate action
                        taken.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Byrnes</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>