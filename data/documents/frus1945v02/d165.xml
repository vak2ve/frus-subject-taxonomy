                <note rend="inline" type="source">Council of Foreign Ministers Files: Lot M–88: CFM
                    London Decisions</note>
                <head>
                    <hi rend="italic">Record of Decisions of the Twenty-Eighth Meeting of the
                        Council of Foreign Ministers, Lancaster House, London, September 29, 1945, 3
                        p.m.</hi>
                </head>
                <dateline>
                    <placeName>London</placeName>, <date
                        ana="#date_undated-inferred-from-document-head" calendar="gregorian"
                        when="1945-09-29T15:00:00+00:00">September 29, 1945, 3 p.m.</date>
                </dateline>
                <opener>
                    <seg rendition="#left">C.F.M.(P) (45) 28th Meeting</seg>
                </opener>
                <p rend="center">
                    <hi rend="smallcaps">Present</hi>
                </p>
