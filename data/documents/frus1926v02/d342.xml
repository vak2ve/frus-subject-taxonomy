    <text>
        <body>
            <div frus:doc-dateTime-max="1926-03-06T08:44:00-05:00"
                frus:doc-dateTime-min="1926-03-06T08:44:00-05:00" n="342"
                subtype="historical-document" type="document" xml:id="d342">
                <note rend="inline" type="source">882.6176 F 51/197: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Liberia</hi> (<persName type="from">
                        <hi rend="italic">Wharton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1926-03-06T13:00:00-00:44">
                            <hi rend="italic">March 6, 1926—1 p.m.</hi>
                        </date>
                        <lb/>[Received 2:38 p.m.]</dateline>
                </opener>
                <p>19. Department’s 12.<note n="38" xml:id="d342fn38">Not printed.</note> Liberian
                    Government desiring to clear up misunderstandings and consummate negotiations
                    despatched De la Rue today with complete certified texts, documents, and
                    official explanations. Available copies will be mailed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wharton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
