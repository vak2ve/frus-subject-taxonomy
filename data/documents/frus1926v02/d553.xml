<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1924-10-17T05:00:00-05:00" frus:doc-dateTime-min="1924-10-17T05:00:00-05:00" n="553" subtype="historical-document" type="document" xml:id="d553">
                        <note rend="inline" type="source">853.51/247: Telegram</note>
                        <head><hi rend="italic">The Chargé in Portugal</hi> (<persName type="from"><hi rend="italic">Carroll</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Lisbon</hi></placeName>, <date calendar="gregorian" when="1924-10-17T10:00:00+00:00"><hi rend="italic">October 17,
                                        1924—10 a.m.</hi></date><lb/>[Received 5:38
                            p.m.]</dateline></opener>
                        <p>51. Department’s 37, October 14, 2 p.m. British bondholders will receive
                            the actual amount of sterling specified on the coupon.</p>
                        <closer><signed><hi rend="smallcaps">Carroll</hi></signed></closer>
                    </div>
