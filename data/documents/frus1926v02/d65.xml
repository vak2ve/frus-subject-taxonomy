                subtype="historical-document" type="document" xml:id="d65">
                <note rend="inline" type="source">800.51 W 89France/319: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName type="to">
                        <hi rend="italic">Herrick</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1926-06-09T13:00:00-04:00">
                            <hi rend="italic">June 9, 1926—1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>166. Your 232, June 8, 4 p.m.</p>
                <list>
                    <label>1.</label>
                    <item>Department entirely approves your action in warning the French that no
                        reservations would be accepted.</item>
                    <pb facs="0193" n="97" xml:id="pg_97"/>
                    <label>2.</label>
                    <item>Should you be asked to forward any reservations, I suggest that you might
                        refuse on ground that to comply with request would, in your opinion, result
                        only in rebuff.</item>
                </list>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
