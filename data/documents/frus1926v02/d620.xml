                <note rend="inline" type="source">711.162/74: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Salvador</hi> (<persName type="to">
                        <hi rend="italic">Engert</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1926-05-29">
                            <hi rend="italic">May 29, 1926</hi>
                        </date>.</dateline>
                </opener>
                <p>50. Your 68, May 24, 1 p.m. Senate ratified treaty yesterday.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
