<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1926-11-14T18:45:00-05:00" frus:doc-dateTime-min="1926-11-14T18:45:00-05:00" n="512" subtype="historical-document" type="document" xml:id="d512">
                        <note rend="inline" type="source">817.00/4059: Telegram</note>
                        <head><hi rend="italic">The Chargé in Nicaragua</hi> (<persName type="from"><hi rend="italic">Dennis</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Managua</hi></placeName>, <date calendar="gregorian" when="1926-11-14T18:00:00-05:45"><hi rend="italic">November 14,
                                        1926—6 p.m.</hi></date><lb/>[Received 9:23
                            p.m.]</dateline></opener>
                        <p>200. Adolfo Diaz took oath of office at 4:30 this afternoon.</p>
                        <closer><signed><hi rend="smallcaps">Dennis</hi></signed></closer>
                    </div>
