                <note rend="inline" type="source">667.113/1: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the High
                        Commissioner in Turkey</hi> (<persName type="to">
                        <hi rend="italic">Bristol</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1926-01-09T00:00:00-05:00">
                            <hi rend="italic">January 9, 1926—12 midnight</hi>
                        </date>.</dateline>
                </opener>
                <p>1. Your 1, January 5, 6 p.m. Your action in making representations is fully
                    approved. Keep Department informed of developments by telegraph.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
