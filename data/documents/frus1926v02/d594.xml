                subtype="historical-document" type="document" xml:id="d594">
                <note rend="inline" type="source">711.162/–: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Salvador</hi> (<persName type="to">
                        <hi rend="italic">Schuyler</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1923-09-20T18:00:00-04:00">
                            <hi rend="italic">September 20, 1923—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>26. Ascertain and cable whether it would be agreeable to the Government of
                    Salvador to enter into negotiations with this Government for a general treaty of
                    amity, commerce, and consular rights. If so, the text of a proposed treaty with
                    appropriate instructions will be mailed to you. You may state that this
                    Government is already negotiating with several European Governments treaties
                    similar to that contemplated with Salvador.<note n="1" xml:id="d594fn1">See <ref
                            target="frus1923v01#pg_121">
                            <hi rend="italic">Foreign Relations</hi>, 1923, vol. <hi
                                rend="smallcaps">i</hi>, pp. 121</ref> ff.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
