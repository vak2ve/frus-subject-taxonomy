    <text>
        <body>
            <div frus:doc-dateTime-max="1926-02-16T07:44:00-05:00"
                frus:doc-dateTime-min="1926-02-16T07:44:00-05:00" n="333"
                subtype="historical-document" type="document" xml:id="d333">
                <note rend="inline" type="source">882.51/1864: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Liberia</hi> (<persName type="from">
                        <hi rend="italic">Wharton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1926-02-16T12:00:00-00:44">
                            <hi rend="italic">February 16, 1926—noon</hi>
                        </date>.<lb/>[Received 7:47 p.m.]</dateline>
                </opener>
                <p>12. Cannot hold Legislature longer. Loan reconsidered and passed in accordance
                    with Legation’s cable number 11. Arbitration convention ratified.<note n="21"
                        xml:id="d333fn21">See <ref target="#pg_597">pp. 597</ref> ff.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wharton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
