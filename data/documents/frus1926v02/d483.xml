<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1926-08-26T17:00:00-05:00" frus:doc-dateTime-min="1926-08-26T17:00:00-05:00" n="483" subtype="historical-document" type="document" xml:id="d483">
                        <note rend="inline" type="source">817.00/3729: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in Nicaragua</hi> (<persName type="to"><hi rend="italic">Dennis</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1926-08-26T18:00:00-04:00"><hi rend="italic">August 26,
                                        1926—6 p.m.</hi></date></dateline></opener>
                        <p>61. U.S.S. <hi rend="italic">Tulsa</hi> has been ordered to Corinto, and
                            U.S.S. <hi rend="italic">Galveston</hi> to Bluefields.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
