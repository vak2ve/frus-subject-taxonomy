                subtype="historical-document" type="document" xml:id="d491">
                <note rend="inline" type="source">817.00/3803: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Dennis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1926-09-17T14:00:00-05:45">
                            <hi rend="italic">September 17, 1926—2 p.m.</hi>
                        </date>
                        <lb/>[Received 10:23 p.m.]</dateline>
                </opener>
                <p>137. Please advise immediately whether United States will, as requested in
                    writing by Chamorro, have neutral zone around wharf and hotel maintained by
                    marines at Corinto for conference. This is necessary as lodging and meeting
                    facilities of warship not adequate.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dennis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
