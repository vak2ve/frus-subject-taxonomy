<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1926-11-02T17:00:00-05:00" frus:doc-dateTime-min="1926-11-02T17:00:00-05:00" n="592" subtype="historical-document" type="document" xml:id="d592">
                        <note rend="inline" type="source">811.111Kollontay,Madame Alexandra:
                            Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Consul General at Berlin</hi> (<persName type="to"><hi rend="italic">Coffin</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1926-11-02T17:00:00-05:00"><hi rend="italic">November 2,
                                        1926—5 p.m.</hi></date></dateline></opener>
                        <p>Your October 20, 5 p.m. Since Madame Kollontay is inadmissible to the
                            United States under the law, no visa or transit certificate may be
                            issued to her.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>