                <note rend="inline" type="source">853.51/259: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Portugal</hi> (<persName type="from">
                        <hi rend="italic">Dearing</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lisbon</hi>
                        </placeName>, <date calendar="gregorian" when="1925-02-03T18:00:00+00:00">
                            <hi rend="italic">February 3, 1925—6 p.m.</hi>
                        </date>
                        <lb/>[Received 6:45 p.m.]</dateline>
                </opener>
                <p>5. Foreign Minister requests [on] behalf of Portuguese Treasury statement
                    supposed number bonds tobacco loan 1891 to 1896 held by American citizens.
                    Please reply by telegraph.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dearing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
