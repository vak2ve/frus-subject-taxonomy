    <text>
        <body>
            <div frus:doc-dateTime-max="1925-11-05T23:59:59-05:00"
                frus:doc-dateTime-min="1925-11-05T00:00:00-05:00" n="88"
                subtype="historical-document" type="document" xml:id="d88">
                <note rend="inline" type="source">195/874</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Herrick</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1925-11-05">
                            <hi rend="italic">November 5, 1925</hi>
                        </date>.<lb/>[Received November 16.]</dateline>
                    <seg rendition="#left">No. 5682</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: With reference to my telegram No. 540 of November
                    3rd, 5 p.m.,<note n="51" xml:id="d88fn51">Not printed.</note> I have the honor
                    to enclose herewith a copy and translation of a note from the Foreign Office
                    dated November 3rd,<note n="51" xml:id="d88fn52">Not printed.</note> in which it
                    is stated that American ships touching at French ports will experience no
                    difficulties until such a time as an agreement has been made between France and
                    the United States concerning the equivalence of navigation certificates.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Myron T. Herrick</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
