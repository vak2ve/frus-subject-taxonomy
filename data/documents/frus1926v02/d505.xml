                <note rend="inline" type="source">817.00/3970: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Nicaragua</hi> (<persName type="to">
                        <hi rend="italic">Dennis</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1926-10-28T16:00:00-05:00">
                            <hi rend="italic">October 28, 1926—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>101. Your 178, October 25, 10 a.m. Your understanding correct.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
