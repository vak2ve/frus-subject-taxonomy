<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-05-29T19:30:00-05:00" frus:doc-dateTime-min="1929-05-29T19:30:00-05:00" n="472" subtype="historical-document" type="document" xml:id="d472">
                            <note rend="inline" type="source">810.79611 Tri-Motors Safety
                                Airways/36: Telegram</note>
                            <head><hi rend="italic">The Chargé in Venezuela</hi> (<persName type="from"><hi rend="italic">Engert</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Caracas</hi></placeName>, <date calendar="gregorian" when="1929-05-29T20:00:00-04:30">May 29, 1929—8
                                    p.m.</date><lb/>[Received May 30—5:10 p.m.]</dateline></opener>
                            <p>48. Department’s 13, April 30, 2 p.m.<note n="66" xml:id="d472fn66">See footnote 55, <ref target="#pg_613">p. 613</ref>.</note> The
                                Venezuelan Government will permit survey flight by one Sikorsky
                                plane between Trinidad and Maracay.</p>
                            <closer><signed><hi rend="smallcaps">Engert</hi></signed></closer>
                        </div>
                        </body></text></TEI>