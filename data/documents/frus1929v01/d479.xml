                <note rend="inline" type="source">810.79611 Tri-Motors Safety Airways/67:
                    Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in France</hi> (<persName type="to">
                        <hi rend="italic">Armour</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1929-07-10T18:00:00-04:00"
                            >July 10, 1929—6 p.m.</date>
                    </dateline>
                </opener>
                <p>227. Your 324, July 8, 9 a.m. Flights referred to are for survey of proposed
                    airmail route.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
