                subtype="historical-document" type="document" xml:id="d450">
                <note rend="inline" type="source">810.79611 Pan American Airways, Inc./737:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Guatemala</hi> (<persName type="from">
                        <hi rend="italic">Geissler</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guatemala</hi>
                        </placeName>, <date calendar="gregorian" when="1929-12-04T17:00:00-06:00"
                            >December 4, 1929—5 p.m.</date>
                        <lb/>[Received 11:20 p.m.]</dateline>
                </opener>
                <p>156. Morrison has informed the Legation that the Minister of Fomento today signed
                    a contract granting the Pan American an air transport contract subject to
                    approval by the Assembly and a provisional permit.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Geissler</hi>
                    </signed>
                </closer>
            </div>
        </body>
