<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-02-28T13:00:00-05:00" frus:doc-dateTime-min="1929-02-28T13:00:00-05:00" n="545" subtype="historical-document" type="document" xml:id="d545">
                        <note rend="inline" type="source">723.2515/3270: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Peru</hi> (<persName type="from"><hi rend="italic">Moore</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Lima</hi></placeName>, <date calendar="gregorian" when="1929-02-28T13:00:00-05:00">February 28, 1929—1
                                p.m.</date><lb/>[Received 3 p.m.]</dateline></opener>
                        <p>23. My 22, February 27, 8 p.m. President Leguia will deliver report to
                            Ambassador Figueroa at the Government Palace at 5 p.m. today.</p>
                        <closer><signed><hi rend="smallcaps">Moore</hi></signed></closer>
                    </div>
