                subtype="historical-document" type="document" xml:id="d365">
                <note rend="inline" type="source">810.79611 Pan American Airways, Inc./456:
                    Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Brazil</hi> (<persName type="to">
                        <hi rend="italic">Morgan</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1929-06-01T13:00:00-04:00"
                            >June 1, 1929—1 p.m.</date>
                    </dateline>
                </opener>
                <p>21. Please request free entry contingent upon reexportation for one Fokker super
                    universal monoplane with wasp engine, shipped May 31 on <hi rend="italic"
                        >Western World</hi> by Pan American Airways, also permission for air mail
                    survey flights along the coast of Brazil.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Clark</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
