<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-10-30T19:00:00-05:00" frus:doc-dateTime-min="1929-10-30T19:00:00-05:00" n="809" subtype="historical-document" type="document" xml:id="d809">
                            <note rend="inline" type="source">714.1515/962: Telegram</note>
                            <head><hi rend="italic">The Minister in Honduras</hi> (<persName type="from"><hi rend="italic">Summerlin</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Tegucigalpa</hi></placeName>, <date calendar="gregorian" when="1929-10-30T18:00:00-06:00">October 30, 1929—6 p.m.</date><lb/>[Received October
                                    31—1:43 a.m.]</dateline></opener>
                            <p>105. The Minister for Foreign Affairs stated to me today that
                                Honduras will accept the proposal contained in your telegram No. 78,
                                October 25, 5 p.m., but that the acceptance may not be forwarded
                                until next week.</p>
                            <p>Repeated to Guatemala.</p>
                            <closer><signed><hi rend="smallcaps">Summerlin</hi></signed></closer>
                        </div>
                        </body></text></TEI>