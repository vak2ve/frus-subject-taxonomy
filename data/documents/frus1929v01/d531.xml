<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-01-04T15:00:00-05:00" frus:doc-dateTime-min="1929-01-04T15:00:00-05:00" n="531" subtype="historical-document" type="document" xml:id="d531">
                        <note rend="inline" type="source">723.2515/3251: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Peru</hi> (<persName type="from"><hi rend="italic">Moore</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Lima</hi></placeName>, <date calendar="gregorian" when="1929-01-04T15:00:00-05:00">January 4, 1929—3
                                p.m.</date><lb/>[Received 5:55 p.m.]</dateline></opener>
                        <p>2. Your 1, January 3, 8 p.m. On January 9, Ralph Cady and assistant,
                            Julio del Pino, will sail from Callao for Arica. Señor del Pino is a
                            Peruvian citizen.</p>
                        <closer><signed><hi rend="smallcaps">Moore</hi></signed></closer>
                    </div>
                    </body></text></TEI>