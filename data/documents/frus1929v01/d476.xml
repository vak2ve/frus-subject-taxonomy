                subtype="historical-document" type="document" xml:id="d476">
                <note rend="inline" type="source">810.79611 Tri-Motors Safety Airways/47:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Uruguay</hi> (<persName type="from">
                        <hi rend="italic">Gade</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Montevideo</hi>
                        </placeName>, <date calendar="gregorian" when="1929-06-19T10:00:00-03:30"
                            >June 19, 1929—10 a.m.</date>
                        <lb/>[Received 10:40 a.m.]</dateline>
                </opener>
                <p>30. Department’s telegram 8, April 30, 2 p.m.<note n="70" xml:id="d476fn70">See
                        footnote 55, <ref target="#pg_613">p. 613</ref>.</note> Permission for free
                    entry and flights granted.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gade</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
