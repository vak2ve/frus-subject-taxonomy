                subtype="historical-document" type="document" xml:id="d445">
                <note rend="inline" type="source">810.79611 Pan American Airways, Inc./719:
                    Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Guatemala</hi> (<persName type="to">
                        <hi rend="italic">Hawks</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1929-11-18T15:00:00-05:00"
                            >November 18, 1929—3 p.m.</date>
                    </dateline>
                </opener>
                <p>71. Your 148, November 14, 3 p.m. Provided that it will not conflict with any
                    existing contracts or pending application of other American countries [<hi
                        rend="italic">companies?</hi>] you are authorized to do as requested on
                    behalf of the Pan American Airways, Incorporated, but not of its non-American
                    subsidiary.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
