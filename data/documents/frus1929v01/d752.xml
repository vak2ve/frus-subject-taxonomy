<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-09-30T10:00:00-05:00" frus:doc-dateTime-min="1929-09-30T10:00:00-05:00" n="752" subtype="historical-document" type="document" xml:id="d752">
                            <note rend="inline" type="source">724.3415/739f: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Chargé in Bolivia</hi> (<persName type="to"><hi rend="italic">Hibbard</hi></persName>)<note n="72" xml:id="d752fn72">The same, <hi rend="italic">mutatis
                                        mutandis</hi>, on the same date to the Minister in Paraguay
                                    as telegram No. 51.</note></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1929-09-30T10:00:00-05:00">September 30, 1929—10
                                        a.m.</date></dateline></opener>
                            <p>57. Department’s circular September 23, 6 p.m. Please transmit
                                communication quoted therein to Bolivian Government on Tuesday
                                morning, October first.</p>
                            <closer><signed><hi rend="smallcaps">Stimson</hi></signed></closer>
                        </div>
                        </body></text></TEI>