                subtype="historical-document" type="document" xml:id="d330">
                <note rend="inline" type="source">810.79611 Pan American Airways, Inc./239:
                    Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Panama</hi> (<persName type="to">
                        <hi rend="italic">South</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1929-02-07T11:00:00-05:00"
                            >February 7, 1929—11 a.m.</date>
                    </dateline>
                </opener>
                <p>7. Please show the following to Colonel Lindbergh.</p>
                <p>[Here follows text of telegram No. 15, February- 6, 11 a.m., from the Minister in
                    Colombia, printed <hi rend="italic">supra.</hi>]</p>
                <p>Legation Bogotá will advise you as soon as permission granted.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
