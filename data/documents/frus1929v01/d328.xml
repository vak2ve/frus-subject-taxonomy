<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-02-02T11:14:00-05:00" frus:doc-dateTime-min="1929-02-02T11:14:00-05:00" n="328" subtype="historical-document" type="document" xml:id="d328">
                            <note rend="inline" type="source">810.79611 Pan American Airways,
                                Inc./234: Telegram</note>
                            <head><hi rend="italic">The Minister in Ecuador</hi> (<persName type="from"><hi rend="italic">Bading</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Quito</hi></placeName>, <date calendar="gregorian" when="1929-02-02T11:00:00-05:14">February 2, 1929—11
                                        a.m.</date><lb/>[Received 5:15 p.m.]</dateline></opener>
                            <p>8. Department’s 2, January 18, noon.<note n="6" xml:id="d328fn6">See
                                    footnote 2, <ref target="#pg_546">p. 546</ref>.</note>
                                Permission granted, but Government requests that official Ecuadorian
                                pilot be taken on survey flights to be picked up at first Ecuadorian
                                port.</p>
                            <closer><signed><hi rend="smallcaps">Bading</hi></signed></closer>
                        </div>
                        </body></text></TEI>