    <text>
        <body>
            <div frus:doc-dateTime-max="1929-02-26T23:59:59-05:00"
                frus:doc-dateTime-min="1929-02-26T00:00:00-05:00" n="518"
                subtype="historical-document" type="document" xml:id="d518">
                <note rend="inline" type="source">574.H1/103</note>
                <head>
                    <hi rend="italic">The American Minister in Canada</hi> (<persName type="from">
                        <hi rend="italic">Phillips</hi>
                    </persName>) <hi rend="italic">to the Canadian Secretary of State for External
                        Affairs</hi> (<persName type="to">
                        <hi rend="italic">Mackenzie King</hi>
                    </persName>)<note n="7" xml:id="d518fn7">Copy transmitted to the Department by
                        the Minister in Canada as an enclosure to his despatch No. 1033, June 13;
                        received June 17.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Ottawa</hi>
                        </placeName>, <date calendar="gregorian" when="1929-02-26">February 26,
                            1929</date>.</dateline>
                    <seg rendition="#left">No. 314</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: With regard to the recent short length radio
                    conference at Ottawa, I am instructed by my Government to inform you that it
                    approves the recommendations of the delegates at the conference and will
                    announce the agreement effective March 1, 1929.</p>
                <p>I avail myself [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
