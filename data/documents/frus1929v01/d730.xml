                subtype="historical-document" type="document" xml:id="d730">
                <note rend="inline" type="source">724.3415/667b: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Bolivia</hi> (<persName type="to">
                        <hi rend="italic">Hibbard</hi>
                    </persName>)<note n="46" xml:id="d730fn46">The same on the same date to the
                        Minister in Paraguay as telegram No. 32, mentioning Department’s telegram
                        No. 31. August 24, 11 a.m.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1929-08-24T13:00:00-04:00"
                            >August 24, 1929—1 p.m.</date>
                    </dateline>
                </opener>
                <p>44. American Embassy in Brazil reports that the Government of Brazil will be
                    disposed to cooperate in counseling moderation at Asunción and La Paz in the
                    circumstances set forth in the Department’s telegram 43, August 24, 11 a.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Carr</hi>
                    </signed>
                </closer>
            </div>
        </body>
