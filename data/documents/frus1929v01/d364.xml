                subtype="historical-document" type="document" xml:id="d364">
                <note rend="inline" type="source">810.79611 Pan American Airways, Inc./455:
                    Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Argentina</hi> (<persName type="to">
                        <hi rend="italic">Bliss</hi>
                    </persName>)<note n="17" xml:id="d364fn17">The same, <hi rend="italic">mutatis
                            mutandis</hi>, on the same date to the Minister in Uruguay as telegram
                        No. 9.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1929-06-01T13:00:00-04:00"
                            >June 1, 1929—1 p.m.</date>
                    </dateline>
                </opener>
                <p>46. Please request on behalf of Pan American Airways free entry contingent upon
                    reexportation for one Fokker super universal monoplane, also permission to fly
                    over and land in Argentina in making air mail survey flights.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Clark</hi>
                    </signed>
                </closer>
            </div>
        </body>
