<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-02-09T19:00:00-05:00" frus:doc-dateTime-min="1929-02-09T19:00:00-05:00" n="335" subtype="historical-document" type="document" xml:id="d335">
                            <note rend="inline" type="source">810.79611 Pan American Airways,
                                Inc./249: Telegram</note>
                            <head><hi rend="italic">The Minister in Colombia</hi> (<persName type="from"><hi rend="italic">Caffery</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1929-02-09T19:00:00-05:00">February 9, 1929—7
                                        p.m.</date><lb/>[Received 10:15 p.m.]</dateline></opener>
                            <p>22. My 21 February 8, 9 p.m.<note n="7" xml:id="d335fn7">Not
                                    printed.</note> Colombian Government today granted request of
                                Pan American, as set forth in the Department’s 5, January 18, 12
                                noon, under the following conditions: <list>
                                    <label>1.</label>
                                    <item>Notification day and approximate hour arrival Colombian
                                        territory.</item>
                                    <label>2.</label>
                                    <item>Type of plane and power of motor.</item>
                                    <pb facs="0686" n="550" xml:id="pg_550"/>
                                    <label>3.</label>
                                    <item>Not to be considered inauguration commercial service
                                        between United States and Colombia pending termination
                                        negotiations between the two countries.<note n="8" xml:id="d335fn8">See <ref target="frus1929v02#pg_879">vol. <hi rend="smallcaps">ii</hi>, pp. 879</ref>
                                            ff.</note></item>
                                </list>
                            </p>
                            <p>Repeated to Panama.</p>
                            <closer><signed><hi rend="smallcaps">Caffery</hi></signed></closer>
                        </div>
                        </body></text></TEI>