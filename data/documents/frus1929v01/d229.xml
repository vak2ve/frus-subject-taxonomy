    <text>
        <body>
            <div frus:doc-dateTime-max="1928-11-05T23:59:59-05:00"
                frus:doc-dateTime-min="1928-11-05T00:00:00-05:00" n="229"
                subtype="historical-document" type="document" xml:id="d229">
                <note rend="inline" type="source">551.58B1/21</note>
                <head>
                    <hi rend="italic">The Minister in Switzerland</hi> (<persName type="from">
                        <hi rend="italic">Wilson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berne</hi>
                        </placeName>, <date calendar="gregorian" when="1928-11-05">November 5,
                            1928</date>.<lb/>[Received November 30.]</dateline>
                    <seg rendition="#left">No. 645</seg>
                    <lb/>
                    <seg rendition="#left">L. of N. No. 1232</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to my despatch No. 619, L. of N. No.
                    1219, of October 11, 1928, and to my telegram No. 106 [<hi rend="italic"
                        >100</hi>], of today’s date,<note n="4" xml:id="d229fn4">Latter not
                        printed.</note> I have the honor to transmit herewith a communication
                    addressed to you by the Secretary General of the League of Nations, dated
                    November 3,<note n="1" xml:id="d229fn1">Not printed.</note> inviting the
                    American Government to send duly authorized representatives to take part in an
                    international conference for the final adoption of an international convention
                    for the suppression of counterfeiting currency. The Conference is to meet at
                    Geneva on April 9, 1929.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hugh R. Wilson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
