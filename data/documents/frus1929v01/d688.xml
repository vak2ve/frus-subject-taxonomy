<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-01-04T16:00:00-05:00" frus:doc-dateTime-min="1929-01-04T16:00:00-05:00" n="688" subtype="historical-document" type="document" xml:id="d688">
                            <note rend="inline" type="source">724.3415/338: Telegram</note>
                            <head><hi rend="italic">The Minister in Colombia</hi> (<persName type="from"><hi rend="italic">Caffery</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1929-01-04T16:00:00-05:00">January 4, 1929—4
                                        p.m.</date><lb/>[Received 5:55 p.m.]</dateline></opener>
                            <p>2. My telegram number 1, January 4, noon.<note n="15" xml:id="d688fn15">Not printed.</note> Minister for Foreign
                                Affairs telephones me Colombian Government accepts the
                                invitation.</p>
                            <closer><signed><hi rend="smallcaps">Caffery</hi></signed></closer>
                        </div>
