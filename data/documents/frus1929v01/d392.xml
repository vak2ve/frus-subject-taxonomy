                <note rend="inline" type="source">823.79625/2: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Peru</hi> (<persName type="to">
                        <hi rend="italic">Mayer</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1929-07-31T18:00:00-04:00"
                            >July 31, 1929—6 p.m.</date>
                    </dateline>
                </opener>
                <p>79. Your 143 July 30, 9 p.m., paragraph 4. Take action suggested.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
