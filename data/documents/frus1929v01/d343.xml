<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-02-28T18:00:00-05:00" frus:doc-dateTime-min="1929-02-28T18:00:00-05:00" n="343" subtype="historical-document" type="document" xml:id="d343">
                            <note rend="inline" type="source">810.79611 Pan American Airways,
                                Inc./289: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Minister in Panama</hi> (<persName type="to"><hi rend="italic">South</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1929-02-28T18:00:00-05:00">February 28, 1929—6
                                        p.m.</date></dateline></opener>
                            <p>14. Your 12, February 27, 6 p.m. Department not disposed to object to
                                contract providing that it shall be subject to the Joint Regulations
                                to Govern Commercial Aviation in the Republic of Panama.</p>
                            <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                        </div>
                        </body></text></TEI>