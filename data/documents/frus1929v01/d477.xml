                subtype="historical-document" type="document" xml:id="d477">
                <note rend="inline" type="source">810.79611 Tri-Motors Safety Airways/55:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in the Netherlands</hi> (<persName type="from">
                        <hi rend="italic">Norweb</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Hague</hi>
                        </placeName>, <date calendar="gregorian" when="1929-06-22T11:00:00+01:19"
                            >June 22, 1929—11 a.m.</date>
                        <lb/>[Received June 22—7:50 a.m.]</dateline>
                </opener>
                <p>35. Department’s telegram 16, June 17, 11 a.m.<note n="71" xml:id="d477fn71">Not
                        printed.</note> Permission to land and free entry accorded.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Norweb</hi>
                    </signed>
                </closer>
            </div>
        </body>
