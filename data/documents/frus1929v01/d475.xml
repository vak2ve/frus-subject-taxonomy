                subtype="historical-document" type="document" xml:id="d475">
                <note rend="inline" type="source">810.79611 Tri-Motors Safety Airways/40:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Argentina</hi> (<persName type="from">
                        <hi rend="italic">White</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1929-06-05T12:00:00-04:00"
                            >June 5, 1929—noon</date>.<lb/>[Received June 5—11:55 a.m.]</dateline>
                </opener>
                <p>48. Your 35, April 30, 2 p.m.<note n="67" xml:id="d475fn67">See footnote 55, <ref
                            target="#pg_613">p. 613</ref>.</note> Permission Sikorsky planes
                    granted.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">White</hi>
                    </signed>
                </closer>
            </div>
        </body>
