                            <note rend="inline" type="source">810.79611 Pan American Airways,
                                Inc./690: Telegram</note>
                            <head><hi rend="italic">The Minister in El Salvador</hi> (<persName type="from"><hi rend="italic">Robbins</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">San
                                            Salvador</hi></placeName>, <date calendar="gregorian" when="1929-10-22T11:00:00-06:00">October 22, 1929—11
