                <note rend="inline" type="source">723.2515/3313b: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Chile</hi> (<persName type="to">
                        <hi rend="italic">Culbertson</hi>
                    </persName>)<note n="16" xml:id="d591fn16">The same, <hi rend="italic">mutatis
                            mutandis</hi>, on the same date to the Ambassador in Peru as telegram
                        No. 32.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1929-03-25T11:00:00-05:00"
                            >March 25, 1929—11 a.m.</date>
                    </dateline>
                </opener>
                <p>34. I shall remain in office until Friday.<note n="17" xml:id="d591fn17">March
                        29.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
