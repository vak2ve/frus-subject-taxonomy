<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-04-27T23:59:59-05:00" frus:doc-dateTime-min="1929-04-27T00:00:00-05:00" n="294" subtype="historical-document" type="document" xml:id="d294">
                        <note rend="inline" type="source">579.6D1/292</note>
                        <head><hi rend="italic">President <persName type="from">Hoover</persName> to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">The
                                        White House</hi></placeName>, <date calendar="gregorian" when="1929-04-27">April 27, 1929</date>.</dateline></opener>
                        <p><hi rend="smallcaps">My Dear Mr. Secretary</hi>: I have your letter of
                            April 25th on the subject of the International Commission for Air
                            Navigation in Paris. I approve of the arrangements you have made and of
                            the appointment of Messrs. MacCracken and Baker with their technical
                            advisors, to attend this conference.</p>
                        <p>Yours faithfully,</p>
                        <closer><signed><hi rend="smallcaps">Herbert Hoover</hi></signed></closer>
                    </div>
                    </body></text></TEI>