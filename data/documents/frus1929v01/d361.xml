                <note rend="inline" type="source">810.79611 Pan American Airways, Inc./449:
                    Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Cuba</hi> (<persName type="to">
                        <hi rend="italic">Judah</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1929-05-27T18:00:00-04:00"
                            >May 27, 1929—6 p.m.</date>
                    </dateline>
                </opener>
                <p>57. Upon request please render all proper assistance to Cyrus F. Wicker
                    representing Pan American Airways Incorporated.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
