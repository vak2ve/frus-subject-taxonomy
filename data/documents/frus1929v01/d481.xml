                subtype="historical-document" type="document" xml:id="d481">
                <note rend="inline" type="source">810.79611 Tri-Motors Safety Airways/85:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Venezuela</hi> (<persName type="from">
                        <hi rend="italic">Engert</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Caracas</hi>
                        </placeName>, <date calendar="gregorian" when="1929-08-03T14:00:00-04:30"
                            >August 3, 1929—2 p.m.</date>
                        <lb/>[Received 6 p.m.]</dateline>
                </opener>
                <p>113. Confidentially informed that the Government of Venezuela has approved the
                    contract with the New York, Rio, and Buenos Aires Line on essentially the same
                    terms as the French contract. See Legation’s despatch No. 1918, July 13.<note
                        n="72" xml:id="d481fn72">Not printed.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Engert</hi>
                    </signed>
                </closer>
            </div>
        </body>
