<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-06-22T12:00:00-05:00" frus:doc-dateTime-min="1929-06-22T12:00:00-05:00" n="373" subtype="historical-document" type="document" xml:id="d373">
                            <note rend="inline" type="source">810.79611 Pan American Airways,
                                Inc./498: Telegram</note>
                            <head><hi rend="italic">The Ambassador in Chile</hi> (<persName type="from"><hi rend="italic">Culbertson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Santiago</hi></placeName>, <date calendar="gregorian" when="1929-06-22T12:00:00-05:00">June 22,
                                    1929—noon</date>.<lb/>[Received 12:50 p.m.]</dateline></opener>
                            <p>96. Your 65, June 19, 7 p.m. Decree signed granting concession to Pan
                                American-Grace Airways.</p>
                            <closer><signed><hi rend="smallcaps">Clubertson</hi></signed></closer>
