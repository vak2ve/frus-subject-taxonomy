<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-05-02T17:00:00-05:00" frus:doc-dateTime-min="1929-05-02T17:00:00-05:00" n="497" subtype="historical-document" type="document" xml:id="d497">
                            <note rend="inline" type="source">814.796 Latin American Airways/2:
                                Telegram</note>
                            <head><hi rend="italic">The Minister in Guatemala</hi> (<persName type="from"><hi rend="italic">Geissler</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Guatemala</hi></placeName>, <date calendar="gregorian" when="1929-05-02T16:00:00-06:00">May 2, 1929—4
                                    p.m.</date><lb/>[Received 11:20 p.m.]</dateline></opener>
                            <p>54. Despatch 2371, April 24.<note n="90" xml:id="d497fn90">Not
                                    printed.</note> A note has been received from the Foreign Office
                                requesting information regarding the financial backing and
                                capacities of the Latin American Air Transport Company <pb facs="0773" n="637" xml:id="pg_637"/> represented by Lee Balch
                                and “all such other data regarding the matter as may be deemed of
                                interest to the Government of Guatemala.” Please answer by
                                telegraph.</p>
                            <closer><signed><hi rend="smallcaps">Geissler</hi></signed></closer>
                        </div>
                        </body></text></TEI>