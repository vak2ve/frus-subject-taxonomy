<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Acting Secretary of State to
                        the Minister in Austria (
                        Erhardt
                    )</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1946v05</bibl><bibl type="frus-document-id">d183</bibl><bibl type="frus-document-number">183</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1946-11-21T19:00:00-05:00" notAfter="1946-11-21T19:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1946-11-21T19:00:00-05:00" frus:doc-dateTime-min="1946-11-21T19:00:00-05:00" n="183" subtype="historical-document" type="document" xml:id="d183">
                <note rend="inline" type="source">840.811/11–2146: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Austria</hi> (<persName type="to">
                        <hi rend="italic">Erhardt</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1946-11-21T19:00:00-05:00">November 21, 1946—7 p.m.</date>
                    </dateline>
                </opener>
                <p>1026. ReDeptel cir 1610 Nov 7,<note n="91" xml:id="d183fn91">See footnote 87,
                            <ref target="#pg_280">p. 280</ref>.</note> WX 85902 Nov 20 to <gloss target="#t_OMGUS1">OMGUS</gloss> and <gloss target="#t_USFA1">USFA</gloss>
                    <note n="92" xml:id="d183fn92">Not found in Department files.</note> requests US
                    military authorities to discuss with proper <pb facs="0300" n="282" xml:id="pg_282"/> Austrian authorities means of returning Austrian Danube
                    vessels to Austrian Govt under circumstances permitting utilization by Austrians
                    in international traffic. Suggestion has been made that formation new Austrian
                    shipping company might safeguard vessels now in US zones from Soviet seizure in
                    operations below Linz.</p>
                <p>Sent Vienna, repeated 2324 to Berlin.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Acheson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
