    <text>
        <body>
            <div frus:doc-dateTime-max="1937-04-08T10:00:00-05:00"
                frus:doc-dateTime-min="1937-04-08T10:00:00-05:00" n="538"
                subtype="historical-document" type="document" xml:id="d538">
                <note rend="inline" type="source">123H875/245: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Ethiopia</hi> (<persName type="from">
                        <hi rend="italic">Hughes</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                    <note n="9" xml:id="d538fn9">This is the last message from the Legation at Addis
                        Ababa. The Legation and Consulate were closed and all official American
                        representatives were withdrawn.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Addis Ababa</hi>
                        </placeName>, <date calendar="gregorian" when="1937-04-08T18:00:00+03:00"
                            >April 8, 1937—6 p.m.</date>
                        <lb/>[Received April 10—6:05 a.m.]</dateline>
                </opener>
                <p>90. Departing for Djibouti tomorrow early with Hunter and Colquitt.<note n="10"
                        xml:id="d538fn10">Robert L. Hunter and Adrian B. Colquitt, Vice
                        Consuls.</note>…</p>
                <p rend="center">. . . . . . . . . . . . . .</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
