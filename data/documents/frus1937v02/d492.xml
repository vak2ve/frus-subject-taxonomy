                subtype="historical-document" type="document" xml:id="d492">
                <note rend="inline" type="source">783.003/272: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Egypt</hi> (<persName type="from">
                        <hi rend="italic">Fish</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Alexandria</hi>
                        </placeName>, <date calendar="gregorian" when="1937-07-21T19:00:00+02:00"
                            >July 21, 1937—7 p.m.</date>
                        <lb/>[Received July 22—5:39 a.m.]</dateline>
                </opener>
                <p>59. Egyptian Parliament approved ratifications of the Montreux Convention last
                    night.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Fish</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
