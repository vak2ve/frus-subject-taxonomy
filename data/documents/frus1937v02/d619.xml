                subtype="historical-document" type="document" xml:id="d619">
                <note rend="inline" type="source">682.00241/3: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Liberia</hi> (<persName type="from">
                        <hi rend="italic">Walton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1937-12-10T15:00:00-00:44"
                            >December 10, 1937—3 p.m.</date>
                        <lb/>[Received December 10—12:55 p.m.]</dateline>
                </opener>
                <p>69. Legislature passed bill allowing missionaries free entry on personal effects
                    up to $150 yearly.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Walton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
