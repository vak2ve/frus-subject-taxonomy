                subtype="historical-document" type="document" xml:id="d139">
                <note rend="inline" type="source">711.428/2051a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in the United Kingdom</hi> (<persName type="to">
                        <hi rend="italic">Bingham</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1937-01-13T19:00:00-05:00"
                            >January 13, 1937—7 p.m.</date>
                    </dateline>
                </opener>
                <p>9. My 406, November 16. Department is informed that the S. S. <hi rend="italic"
                        >Thorland</hi> is preparing to leave England within a few days, possibly by
                    January 15th. Please again endeavor to secure a reply from the British
                    Government to representations made in November.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Moore</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
