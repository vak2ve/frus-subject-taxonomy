<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1937-02-15T18:00:00-05:00" frus:doc-dateTime-min="1937-02-15T18:00:00-05:00" n="403" subtype="historical-document" type="document" xml:id="d403">
                            <note rend="inline" type="source">611.60C31/159: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in Poland</hi> (<persName type="to"><hi rend="italic">Cudahy</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1937-02-15T18:00:00-05:00">February 15, 1937—6
                                        p.m.</date></dateline>
                            </opener>
                            <p>11. Your 13, February 10, 6 p.m.<note n="5" xml:id="d403fn5">Not
                                    printed.</note> Informal discussions have taken place at the
                                initiative of the Polish Embassy between the Embassy and the
                                Department with a view to ascertaining whether there is any basis
                                for entering into negotiations for the conclusion of a trade
                                agreement with Poland. No decision has yet been reached by the
                                Department with regard to the opening of negotiations.</p>
                            <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                        </div>
                        </body></text></TEI>