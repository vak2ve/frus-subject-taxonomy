<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1937-07-30T07:00:00-05:00" frus:doc-dateTime-min="1937-07-30T07:00:00-05:00" n="654" subtype="historical-document" type="document" xml:id="d654">
                            <note rend="inline" type="source">781.003/26: Telegram</note>
                            <head><hi rend="italic">The Ambassador in the United Kingdom</hi>
                                    (<persName type="from"><hi rend="italic">Bingham</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1937-07-30T13:00:00+01:00">July 30, 1937—1
                                    p.m.</date><lb/>[Received July 30—9:15 a.m.]</dateline>
                            </opener>
                            <p>512. My 506, July 27, 6 p.m.<note n="8" xml:id="d654fn8">Not
                                    printed.</note> Foreign Office informs me that Anglo-French
                                Convention for the Abolition of British capitulations in French
                                Morocco was signed in London yesterday.<note n="9" xml:id="d654fn9">For text, see British Treaty Series No. 8 (1938), or British
                                    Cmd. 5538, Miscellaneous No. 7 (1937): <hi rend="italic">Convention for the Abolition of Capitulations in Morocco
                                        and Zanzibar.</hi></note></p>
                            <closer><signed><hi rend="smallcaps">Bingham</hi></signed></closer>
                        </div>
                        </body></text></TEI>