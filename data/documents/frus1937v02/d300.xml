                subtype="historical-document" type="document" xml:id="d300">
                <note rend="inline" type="source">362.1121 Hirsch, Helmut/48: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Germany</hi> (<persName type="to">
                        <hi rend="italic">Dodd</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1937-06-01T17:00:00-04:00"
                            >June 1, 1937—5 p.m.</date>
                    </dateline>
                </opener>
                <p>52. Your telegrams 120, 121<note n="11" xml:id="d300fn11">Neither printed.</note>
                    and 123. We fully approve your actions and trust that you will continue to exert
                    every effort to secure commutation of sentence. The matter is being kept
                    confidential here.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
