<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1937-03-25T18:00:00-05:00" frus:doc-dateTime-min="1937-03-25T18:00:00-05:00" n="536" subtype="historical-document" type="document" xml:id="d536">
                            <note rend="inline" type="source">765.84/5197: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Chargé in Ethiopia</hi> (<persName type="to"><hi rend="italic">Hughes</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1937-03-25T18:00:00-05:00">March 25, 1937—6
                                        p.m.</date></dateline>
                            </opener>
                            <p>40. Your 61, February 25, 4 p.m. Please comment on press reports that
                                refugees were attacked and otherwise mistreated after leaving the
                                Legation.</p>
                            <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                        </div>
                        </body></text></TEI>