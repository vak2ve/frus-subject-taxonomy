                subtype="historical-document" type="document" xml:id="d785">
                <note rend="inline" type="source">890F.24/7–1744: Telegram</note>
                <head>
                    <hi rend="italic">The Minister Resident in Saudi Arabia</hi> (<persName
                        type="from">
                        <hi rend="italic">Moose</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Jidda</hi>
                        </placeName>, <date calendar="gregorian" when="1944-07-17T13:00:00+03:06"
                            >July 17, 1944—1 p.m.</date>
                        <lb/> [Received 1:42 p.m.]</dateline>
                </opener>
                <p>214. Reference my July 7, 8 p.m. to Cairo repeated to Department.<note n="21"
                        xml:id="d785fn21">Not printed.</note> Acting Minister of Foreign Affairs
                    informs me that Saudi Government stocks of wheat and flour will be exhausted in
                    about 3 days.</p>
                <p>Repeated by airmail to Cairo.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Moose</hi>
                    </signed>
                </closer>
            </div>
        </body>
