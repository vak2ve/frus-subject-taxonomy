<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1944-05-02T11:00:00-05:00" frus:doc-dateTime-min="1944-05-02T11:00:00-05:00" n="1114" subtype="historical-document" type="document" xml:id="d1114">
                            <note rend="inline" type="source">711.94115 Exchange/353:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The Minister in Switzerland</hi> (<persName type="from"><hi rend="italic">Harrison</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Bern</hi></placeName>, <date calendar="gregorian" when="1944-05-02T17:00:00+01:00">May 2,
                                        1944—5 p.m.</date>
                                    <lb/> [Received May 2—3:05 p.m.]</dateline>
                            </opener>
                            <p>2773. American Interests—Japan. Legation’s 2641, April 25. Foreign
                                Office note April 27 states Japanese Foreign Office notified Swiss
                                Legation, Tokyo, April 22, that study of Department’s proposals
                                regarding third exchange will require some time.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Harrison</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>