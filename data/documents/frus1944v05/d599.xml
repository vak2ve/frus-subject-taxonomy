                subtype="historical-document" type="document" xml:id="d599">
                <note rend="inline" type="source">862.20252/11–1744: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Spain</hi> (<persName type="to">
                        <hi rend="italic">Hayes</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1944-11-17T19:00:00-04:00"
                            >November 17, 1944—7 p.m.</date>
                    </dateline>
                </opener>
                <p>3052. Please furnish by cable a recapitulation of present status of situation
                    arising from our demands for expulsion or internment of Axis agents. Department
                    desires to know exactly to what extent our demands have been satisfied.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stettinius</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
