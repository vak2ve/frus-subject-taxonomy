                subtype="historical-document" type="document" xml:id="d597">
                <note rend="inline" type="source">800.20281/55: Airgram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé at Tangier</hi> (<persName type="to">
                        <hi rend="italic">Childs</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1944-06-28T16:00:00-04:00"
                            >June 28, 1944—4 p.m.</date>
                    </dateline>
                </opener>
                <p>A–73. The Department concurs with the view expressed in you’re A–112, June 16,
                    1944, 6 p.m., that no action should be taken with regard to the expulsion of
                    Vichy representatives at this time.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
