<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1944-02-29T16:00:00-05:00" frus:doc-dateTime-min="1944-02-29T16:00:00-05:00" n="57" subtype="historical-document" type="document" xml:id="d57">
                            <note rend="inline" type="source">883.6363/93: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Minister in Egypt</hi> (<persName type="to"><hi rend="italic">Kirk</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1944-02-29T17:00:00-04:00">February 29, 1944—5 p.m.</date>
                                </dateline>
                            </opener>
                            <p>413. Your 232 of February 2, 1944 and 306 of February 10, 1944.
                                Please keep the Department fully informed with respect to the
                                reasons for the new 15 percent export duty, the nature of the
                                application envisaged and particularly the effects it may have upon
                                the development of American petroleum interests in Egypt.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Stettinius</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>