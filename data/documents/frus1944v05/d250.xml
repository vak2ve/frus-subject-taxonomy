<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1944-07-28T18:00:00-05:00" frus:doc-dateTime-min="1944-07-28T18:00:00-05:00" n="250" subtype="historical-document" type="document" xml:id="d250">
                            <note rend="inline" type="source">845.00/7–2244: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Ambassador in the United Kingdom</hi>
                                    (<persName type="to"><hi rend="italic">Winant</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1944-07-28T19:00:00-04:00">July
                                        28, 1944—7 p.m.</date>
                                </dateline>
                            </opener>
                            <p>5932. For the Ambassador. Your attention is invited to Deptel 5931
                                for Phillips on the subject of possible conversations with the
                                British Government regarding the Indian situation.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Stettinius</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>