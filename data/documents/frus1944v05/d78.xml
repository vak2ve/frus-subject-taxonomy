                subtype="historical-document" type="document" xml:id="d78">
                <note rend="inline" type="source">884.77/10–1244: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Ethiopia</hi> (<persName type="to">
                        <hi rend="italic">Caldwell</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1944-12-27T20:00:00-04:00"
                            >December 27, 1944—8 p.m.</date>
                    </dateline>
                </opener>
                <p>197. Please advise whether new agreement contained provision anticipated in your
                    telegram 206, October 12,<note n="34" xml:id="d78fn34">Telegram not
                        printed.</note> that operation of railway by Ethiopians requires clearance
                    with French. If so please report what if any steps the Ethiopian Government has
                    taken to secure agreement with the French.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stettinius</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
