<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-08-19T13:00:00-05:00" frus:doc-dateTime-min="1939-08-19T13:00:00-05:00" n="592" subtype="historical-document" type="document" xml:id="d592">
                            <note rend="inline" type="source">391.1164/90a: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Chargé in Iran</hi> (<persName type="to"><hi rend="italic">Engert</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1939-08-19T14:00:00-04:00">August 19, 1939—2
                                        p.m.</date></dateline>
                            </opener>
                            <p>37. Following from Presbyterian Board for Muller:<note n="2" xml:id="d592fn2">Rev. Hugo A. Muller, member of the Presbyterian
                                    Mission at Tehran.</note>
                                <quote rend="blockquote">
                                    <p>“We have consulted State Department and for the time being
                                        formal representations on behalf of mission will be handled
                                        by Legation at Tehran. Please keep in close touch with
                                        Engert and communicate with us through the Legation as
                                        circumstances may require.”</p>
                                </quote></p>
                            <closer><signed><hi rend="smallcaps">Moore</hi></signed></closer>
                        </div>
                        </body></text></TEI>