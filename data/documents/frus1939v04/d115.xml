<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-12-07T19:00:00-05:00" frus:doc-dateTime-min="1939-12-07T19:00:00-05:00" n="115" subtype="historical-document" type="document" xml:id="d115">
                            <note rend="inline" type="source">893.102S/1960: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Counselor of Embassy in China</hi>
                                    (<persName type="to"><hi rend="italic">Peck</hi></persName>),
                                    <hi rend="italic">at Chungking</hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1939-12-07T19:00:00-05:00">December 7, 1939—7
                                        p.m.</date></dateline>
                            </opener>
                            <p>231. Your 626, December 4, 5 p.m.</p>
                            <list>
                                <label>1.</label>
                                <item>Department desires that the American Consul General at
                                    Shanghai transmit informally and without comment the text of the
                                    Chinese <pb facs="0112" n="106" xml:id="pg_106"/> Foreign
                                    Office’s note to the appropriate authorities of the Shanghai
                                    International Settlement.</item>
                                <label>2.</label>
                                <item>Please make suitable acknowledgment to the Chinese Foreign
                                    Office of its note and say that the note is being communicated
                                    to the appropriate authorities of the Shanghai International
                                    Settlement.</item>
                            </list>
                            <p>Sent to Chungking. Repeated to Peiping and Shanghai.</p>
                            <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                        </div>
                        </body></text></TEI>