<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-09-29T18:00:00-05:00" frus:doc-dateTime-min="1939-09-29T18:00:00-05:00" n="89" subtype="historical-document" type="document" xml:id="d89">
                            <note rend="inline" type="source">893.0146/705: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Consul General at Shanghai</hi>
                                    (<persName type="to"><hi rend="italic">Gauss</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1939-09-29T18:00:00-05:00">September 29, 1939—6
                                        p.m.</date></dateline>
                            </opener>
                            <p>378. Your 869, September 29, 11 a.m. Department approves statement
                                made by you to the Mayor of the Japanese-sponsored Chinese Municipal
                                regime as reported in your telegram under reference.</p>
                            <p>Sent to Shanghai. Repeated to Chungking and Peiping. Shanghai please
                                air mail to Tokyo.</p>
                            <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                        </div>
                        </body></text></TEI>