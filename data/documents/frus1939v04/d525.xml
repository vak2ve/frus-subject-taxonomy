<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-01-03T22:00:00-05:00" frus:doc-dateTime-min="1939-01-03T22:00:00-05:00" n="525" subtype="historical-document" type="document" xml:id="d525">
                            <note rend="inline" type="source">894.00/828: Telegram</note>
                            <head><hi rend="italic">The Ambassador in Japan</hi> (<persName type="from"><hi rend="italic">Grew</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Tokyo</hi></placeName>, <date calendar="gregorian" when="1939-01-04T12:00:00+09:00">January 4,
                                    1939—noon</date>.<lb/>[Received January 4—5:10 a.m.]</dateline>
                            </opener>
                            <p>4. Embassy’s 813, December 29, 7 p.m.<note n="2" xml:id="d525fn2"><ref target="frus1938v04#pg_610"><hi rend="italic">Ibid.</hi>, p. 610</ref>.</note> The entire Cabinet
                                resigned this morning.</p>
                            <closer><signed><hi rend="smallcaps">Grew</hi></signed></closer>
