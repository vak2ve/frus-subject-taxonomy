    <text>
        <body>
            <div frus:doc-dateTime-max="1939-05-22T23:59:59-05:00"
                frus:doc-dateTime-min="1939-05-22T00:00:00-05:00" n="388"
                subtype="historical-document" type="document" xml:id="d388">
                <note rend="inline" type="source">393.1115/4317</note>
                <head>
                    <hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from">
                        <hi rend="italic">Gauss</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 2219</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1939-05-22">May 22,
                            1939</date>.<lb/>[Received June 28.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to submit with this despatch a
                    copy of a self-explanatory communication that the Acting Consul General for
                    Japan in Shanghai addressed to me on May 19, 1939,<note n="72" xml:id="d388fn72"
                        >Not printed.</note> offering on behalf of the Japanese military authorities
                    the limited facilities of Japanese transports to Americans who evacuated Kuling
                    prior to the Japanese military operations against that place and who now desire
                    to return there.</p>
                <p>Respectfully yours,</p>
                <closer>
                    <signed>C. E. <hi rend="smallcaps">Gauss</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
