<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-04-22T12:00:00-05:00" frus:doc-dateTime-min="1939-04-22T12:00:00-05:00" n="578" subtype="historical-document" type="document" xml:id="d578">
                            <note rend="inline" type="source">365D.1163/139: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in Italy</hi> (<persName type="to"><hi rend="italic">Phillips</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1939-04-22T12:00:00-05:00">April 22,
                                    1939—noon</date>.</dateline>
                            </opener>
                            <p>30. Your 108, March 29, 5 p.m. Please inform the Italian authorities
                                that Mr. Duncan Henry at Addis Ababa is now authorized to represent
                                the Presbyterian Board of Foreign Missions in negotiations relating
                                to the appraisal of mission properties at Sayo and Gore.</p>
                            <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                        </div>
                        </body></text></TEI>