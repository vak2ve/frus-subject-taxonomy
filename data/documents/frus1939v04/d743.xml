<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-06-15T16:00:00-05:00" frus:doc-dateTime-min="1939-06-15T16:00:00-05:00" n="743" subtype="historical-document" type="document" xml:id="d743">
                            <note rend="inline" type="source">481.11/137: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Chargé in France</hi> (<persName type="to"><hi rend="italic">Wilson</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1939-06-15T17:00:00-04:00">June 15, 1939—5
                                    p.m.</date></dateline>
                            </opener>
                            <p>433. Your 1117, June 13, 3 p.m. The Department fully approves the
                                action proposed by you.</p>
                            <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                        </div>
                        </body></text></TEI>