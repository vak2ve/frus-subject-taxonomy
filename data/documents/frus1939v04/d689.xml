<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-03-31T07:44:00-05:00" frus:doc-dateTime-min="1939-03-31T07:44:00-05:00" n="689" subtype="historical-document" type="document" xml:id="d689">
                            <note rend="inline" type="source">711.8227/2: Telegram</note>
                            <head><hi rend="italic">The Minister in Liberia</hi> (<persName type="from"><hi rend="italic">Walton</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Monrovia</hi></placeName>, <date calendar="gregorian" when="1939-03-31T12:00:00-00:44">March 31,
                                    1939—noon</date>.<lb/>[Received March 31—11:18 a.m.]</dateline>
                            </opener>
                            <p>18. Department’s No. 9, March 25, 2 p.m. The Liberian Government
                                would welcome the initiation of negotiations with the United States
                                Government for the conclusion of a civil aviation agreement.</p>
                            <closer><signed><hi rend="smallcaps">Walton</hi></signed></closer>
                        </div>
                        </body></text></TEI>