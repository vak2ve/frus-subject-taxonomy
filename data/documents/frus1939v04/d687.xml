    <text>
        <body>
            <div frus:doc-dateTime-max="1939-12-04T23:59:59-05:00"
                frus:doc-dateTime-min="1939-12-04T00:00:00-05:00" n="687"
                subtype="historical-document" type="document" xml:id="d687">
                <note rend="inline" type="source">882.20/515</note>
                <head>
                    <hi rend="italic">The Liberian Consul General at New York</hi> (<persName
                        type="from">
                        <hi rend="italic">Walker</hi>
                    </persName>) <hi rend="italic">to the Chief of the Division of Near Eastern
                        Affairs</hi> (<persName type="to">
                        <hi rend="italic">Murray</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">New York</hi>
                        </placeName>, <date calendar="gregorian" when="1939-12-04">December 4,
                            1939</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Murray</hi>: I have just received a cable from the
                    Secretary of the Treasury at Monrovia, stating that the Government feels that
                    additional guns are not necessary for the present time.</p>
                <p>Again I want to thank you for your interest and courtesies in this matter.</p>
                <p>Very sincerely yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Walter F. Walker</hi>
                    </signed>
                </closer>
            </div>
        </body>
