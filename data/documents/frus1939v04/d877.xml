                subtype="historical-document" type="document" xml:id="d877">
                <note rend="inline" type="source">123 Fish, Bert/217: Telegram</note>
                <head>
                    <hi rend="italic">The Minister to Saudi Arabia</hi> (<persName type="from">
                        <hi rend="italic">Fish</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Djedda</hi>
                        </placeName>, <date ana="#date_undated-inferred-from-outside-research"
                            calendar="gregorian" when="1940-02-04">undated</date>.<lb/>[Received
                        February 5, 1940—10:10 a.m.]</dateline>
                </opener>
                <p>Presented credentials to King here yesterday and had informal audience today.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Fish</hi>
                    </signed>
                </closer>
            </div>
        </body>
