    <text>
        <body>
            <div frus:doc-dateTime-max="1940-01-24T12:44:00-05:00"
                frus:doc-dateTime-min="1940-01-24T12:44:00-05:00" n="696"
                subtype="historical-document" type="document" xml:id="d696">
                <note rend="inline" type="source">711.8227/12: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Liberia</hi> (<persName type="from">
                        <hi rend="italic">Walton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1940-01-24T17:00:00-00:44"
                            >January 24, 1940—5 p.m.</date>
                        <lb/>[Received January 24—12:40 p.m.]</dateline>
                </opener>
                <p>4. Aviation agreement<note n="55" xml:id="d696fn55">For text, see Department of
                        State Executive Agreement Series No. 166, or 54 Stat. 2018.</note> effected
                    by exchange of notes in accordance with Department’s instruction No. 152,
                    September 12, 1939.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Walton</hi>
                    </signed>
                </closer>
            </div>
        </body>
