                subtype="historical-document" type="document" xml:id="d883">
                <note rend="inline" type="source">890D.927/92: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Bullitt</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1939-02-08T17:00:00+00:00"
                            >February 8, 1939—5 p.m.</date>
                        <lb/>[Received February 8—2:30 p.m.]</dateline>
                </opener>
                <p>240. Embassy’s telegram 55, January 10, 8 p.m. The Foreign Office has just
                    advised us informally of the receipt of a telegram from the French Embassy at
                    Ankara reporting that the Turkish Government has raised no objection to the
                    continuing of the excavation contract and that the Turkish Government has sent
                    appropriate instructions to the authorities at Antioch.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bullitt</hi>
                    </signed>
                </closer>
            </div>
        </body>
