    <text>
        <body>
            <div frus:doc-dateTime-max="1939-08-21T23:59:59-05:00"
                frus:doc-dateTime-min="1939-08-21T00:00:00-05:00" n="703"
                subtype="historical-document" type="document" xml:id="d703">
                <note rend="inline" type="source">711.8212a/12</note>
                <head>
                    <hi rend="italic">The Minister in Liberia</hi> (<persName type="from">
                        <hi rend="italic">Walton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 329</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1939-08-21">August 21,
                            1939</date>.<lb/>[Received September 19.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Adverting to Department’s instruction No. 137,
                    July 6, 1939, I have the honor to transmit herewith Conciliation Treaty between
                        <pb facs="0629" n="623" xml:id="pg_623"/> the United States of America and
                    Liberia, signed at Monrovia August 21, 1939, at 1:30 p.m.<note n="62"
                        xml:id="d703fn62">For text, see Department of State Treaty Series No. 968,
                        or 55 Stat. 1137.</note>
                </p>
                <p>Respectfully yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lester A. Walton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
