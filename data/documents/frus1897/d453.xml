                subtype="historical-document" type="document" xml:id="d453">
                <head>
                    <hi rend="italic">Sir <persName type="from">Julian Pauncefote</persName> to Mr.
                            <persName type="to">Sherman</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1897-04-05">
                            <hi rend="italic">April 5, 1897</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note No. 630, of the 3d instant, respecting the proposed ordinance for the
                    disposal of men-of-war’s men who offend against the municipal regulations in
                    Samoa and the course which you propose to follow with reference thereto.</p>
                <p>I have forwarded a copy of your note to the Marquis of Salisbury.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Julian Pauncefote.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
