    <text>
        <body>
            <div frus:doc-dateTime-max="1897-09-21T23:59:59-05:00"
                frus:doc-dateTime-min="1897-09-21T00:00:00-05:00" n="559"
                subtype="historical-document" type="document" xml:id="d559">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Woodford</persName> to Mr. <persName
                            type="to">Sherman</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Sebastian, Spain</hi>
                        </placeName>,<lb/>
                        <date calendar="gregorian" when="1897-09-21">
                            <hi rend="italic">September 21, 1897</hi>
                        </date>. (Received Oct. 4.)</dateline>
                    <seg rendition="#left">No. 30.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your No. 23, of August 28, 1897, inclosing for my information the correspondence
                    had by your Department touching the request of the military governor of Santiago
                    for list of American property. I note the Department’s reply through the
                    consul-general at Havana, and shall maintain with earnestness the position
                    therein taken.</p>
                <p>I have the honor, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stewart L. Woodford.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
