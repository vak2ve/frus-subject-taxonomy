    <text>
        <body>
            <div frus:doc-dateTime-max="1897-11-18T23:59:59-05:00"
                frus:doc-dateTime-min="1897-11-18T00:00:00-05:00" n="533"
                subtype="historical-document" type="document" xml:id="d533">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Sherman</persName> to Mr. <persName
                            type="to">Dupuy de Lôme</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1897-11-18">
                            <hi rend="italic">November 18, 1897</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 313.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 10th instant and to assure you of the pleasure it has afforded
                    this Government to learn from your statements therein of the initial measures
                    adopted by the Spanish authorities for the relief of the reconcentrados in
                    Cuba.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Sherman.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
