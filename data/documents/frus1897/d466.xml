                <head>
                    <hi rend="italic">Mr. <persName type="from">Barrett</persName> to Mr. <persName
                            type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bangkok</hi>
                        </placeName>, <date calendar="gregorian" when="1897-02-27">
                            <hi rend="italic">February 27, 1897</hi>
                        </date>.</dateline>
                </opener>
                <p>Negotiations on selection arbitrator Cheek Case proceeding favorably. It will be
                    agreed to shortly. * * *</p>
                <p>[Rest of telegram relates to other matters.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Barrett.</hi>
                    </signed>
                </closer>
            </div>
        </body>
