    <text>
        <body>
            <div frus:doc-dateTime-max="1897-03-09T23:59:59-05:00"
                frus:doc-dateTime-min="1897-03-09T00:00:00-05:00" n="604"
                subtype="historical-document" type="document" xml:id="d604">
                <head>
                    <hi rend="italic">
                        <persName type="from">Moustapha Bey</persName> to Mr. <persName type="to"
                            >Sherman</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Imperial Legation of Turkey</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1897-03-09">
                            <hi rend="italic">March 9, 1897</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: I hereby apprise your
                    excellency, in pursuance of instructions received, that Mr. Iasigi has been
                    relieved of his functions as consul-general at Boston, and is consequently in no
                    sense an agent of the Imperial Government.</p>
                <p>Be pleased to accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Moustapha.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
