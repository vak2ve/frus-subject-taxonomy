    <text>
        <body>
            <div frus:doc-dateTime-max="1897-02-16T23:59:59-05:00"
                frus:doc-dateTime-min="1897-02-16T00:00:00-05:00" n="464"
                subtype="historical-document" type="document" xml:id="d464">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Barrett</persName> to Mr. <persName
                            type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bangkok</hi>
                        </placeName>, <date calendar="gregorian" when="1897-02-16">
                            <hi rend="italic">February 16, 1897</hi>
                        </date>.</dateline>
                </opener>
                <p>Cheek arbitration satisfactorily settled. I await your instructions constitution
                    of the tribunal of arbitration.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Barrett.</hi>
                    </signed>
                </closer>
            </div>
        </body>
