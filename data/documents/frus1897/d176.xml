    <text>
        <body>
            <div frus:doc-dateTime-max="1897-12-13T23:59:59-05:00"
                frus:doc-dateTime-min="1897-12-13T00:00:00-05:00" n="176"
                subtype="historical-document" type="document" xml:id="d176">
                <head>
                    <hi rend="italic">Mr. <persName type="from">von Holleben</persName> to Mr.
                            <persName type="to">Sherman</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Imperial German Embassy</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1897-12-13">
                            <hi rend="italic">December 13, 1897</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: Referring to Mr. von
                    Reichenau’s note of August 24, 1897, I have the honor, in pursuance of
                    instructions received, to express to your excellency the warmest thanks of the
                    Imperial Government for the assistance so kindly rendered to the captain of the
                    German bark <hi rend="italic">Elisabeth Ahrens</hi> by Mr. Julius G. Tucker,
                    United States consul in Martinique.</p>
                <p>I have the honor at the same time to inclose a check for $26.47, in payment of
                    the amount advanced to Captain Aim by Mr. Tucker.</p>
                <p>
                    <hi rend="smallcaps">Accept, etc.</hi>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Holleben.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
