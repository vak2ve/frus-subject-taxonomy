                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr. <persName
                            type="to">Barrett</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>
                        </placeName>,<lb/>
                        <date calendar="gregorian" when="1897-02-17">
                            <hi rend="italic">February 17, 1897</hi>
                        </date>.</dateline>
                </opener>
                <p>Will Cheek estate and Siam consent one arbitrator, say governor Straits
                    Settlements, or other suitable person near by.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Olney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
