<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1897-02-17T23:59:59-05:00" frus:doc-dateTime-min="1897-02-17T00:00:00-05:00" n="465" subtype="historical-document" type="document" xml:id="d465">
                        <head><hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Barrett</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi></placeName>,<lb/><date calendar="gregorian" when="1897-02-17"><hi rend="italic">February 17, 1897</hi></date>.</dateline></opener>
                        <p>Will Cheek estate and Siam consent one arbitrator, say governor Straits
                            Settlements, or other suitable person near by.</p>
                        <closer><signed><hi rend="smallcaps">Olney.</hi></signed></closer>
                    </div>
                    </body></text></TEI>