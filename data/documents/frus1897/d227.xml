<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1897-05-24T23:59:59-05:00" frus:doc-dateTime-min="1897-05-24T00:00:00-05:00" n="227" subtype="historical-document" type="document" xml:id="d227">
                        <head><hi rend="italic">Mr. <persName type="from">Sherman</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1897-05-24"><hi rend="italic">May 24,
                                1897</hi></date>.</dateline></opener>
                        <p>The President desires you to convey to Her Majesty the sincere
                            congratulations of himself and the American people upon the anniversary
                            of Her Majesty’s birthday.</p>
                        <closer><signed><hi rend="smallcaps">Sherman.</hi></signed></closer>
                    </div>
                    </body></text></TEI>