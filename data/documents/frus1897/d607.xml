<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1897-04-24T23:59:59-05:00" frus:doc-dateTime-min="1897-04-24T00:00:00-05:00" n="607" subtype="historical-document" type="document" xml:id="d607">
                        <head><hi rend="italic">Mr. <persName type="from">Terrell</persName> to Mr.
                                    <persName type="to">Sherman</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Constantinople</hi></placeName>, <date calendar="gregorian" when="1897-04-24"><hi rend="italic">April 24,
                                1897</hi></date>.</dateline></opener>
                        <p>I have protested against the sudden expulsion of peaceful Greeks who are
                            in the employ and who protect American interests here.</p>
                        <closer><signed><hi rend="smallcaps">Terrell.</hi></signed></closer>
                    </div>
                    </body></text></TEI>