    <text>
        <body>
            <div frus:doc-dateTime-max="1897-12-06T23:59:59-05:00"
                frus:doc-dateTime-min="1897-12-06T00:00:00-05:00" n="518"
                subtype="historical-document" type="document" xml:id="d518">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Sherman</persName> to Mr. <persName
                            type="to">Woodford</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1897-12-06">
                            <hi rend="italic">December 6, 1897</hi>
                        </date>.</dateline>
                </opener>
                <p>Is it not possible to hasten expediente Salomon tobacco case?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sherman.</hi>
                    </signed>
                </closer>
            </div>
        </body>
