                subtype="historical-document" type="document" xml:id="d474">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Sherman</persName> to Mr. <persName
                            type="to">Barrett</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1897-09-17">
                            <hi rend="italic">September 17, 1897</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 138.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                    dispatches Nos. 221 and 222, both dated the 22dof July last, and relating to the
                    arbitration of the Cheek case.</p>
                <p>In reply I have to inform you that the postponement of the date of the
                    arbitration of said case to February 1 next is acceptable to the Department.</p>
                <p>Respectfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Sherman.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
