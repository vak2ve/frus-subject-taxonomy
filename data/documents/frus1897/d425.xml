                subtype="historical-document" type="document" xml:id="d425">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Sherman</persName> to <persName
                            type="to">Senhor da Costa Duarte</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1897-08-16">
                            <hi rend="italic">August 16, 1897</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 26.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    Viscount de Santo-Thyrso’s note of the 9th instant, explaining further his
                    position in regard to the flag incident at Monterey, Cal.</p>
                <p>The Department has forwarded a copy of this note to the governor of California
                    for his information, thus closing the incident.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Sherman.</hi>
                    </signed>
                </closer>
            </div>
        </body>
