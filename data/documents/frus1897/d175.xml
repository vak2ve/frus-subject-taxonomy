    <text>
        <body>
            <div frus:doc-dateTime-max="1897-08-24T23:59:59-05:00"
                frus:doc-dateTime-min="1897-08-24T00:00:00-05:00" n="175"
                subtype="historical-document" type="document" xml:id="d175">
                <head>
                    <hi rend="italic">Mr. <persName type="from">von Reichenau</persName> to Mr.
                            <persName type="to">Sherman</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Imperial German Embassy</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1897-08-24">
                            <hi rend="italic">August 24, 1897</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. ‘Secretary of State</hi>: I have the honor to
                    acknowledge the receipt of your polite note of the 13th instant relative to the
                    German bark <hi rend="italic">Elisabeth Ahrens.</hi>
                </p>
                <p>I have not failed to bring the matter to the notice of the Imperial Government,
                    and a subsequent communication may be expected from me on this subject.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Reichenau.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
