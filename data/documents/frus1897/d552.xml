<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1897-07-28T23:59:59-05:00" frus:doc-dateTime-min="1897-07-28T00:00:00-05:00" n="552" subtype="historical-document" type="document" xml:id="d552">
                        <head><hi rend="italic">Mr. <persName type="from">Taylor</persName> to Mr.
                                    <persName type="to">Sherman</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">San
                                        Sebastian</hi></placeName>, <date calendar="gregorian" when="1897-07-28"><hi rend="italic">July 28,
                                1897</hi></date>.</dateline></opener>
                        <p>Minister for foreign affairs has promised to further investigate
                            Chaqueilo case; knows nothing of death sentence.</p>
                        <closer><signed><hi rend="smallcaps">Taylor.</hi></signed></closer>
                    </div>
                    </body></text></TEI>