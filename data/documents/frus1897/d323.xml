<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1897-01-27T23:59:59-05:00" frus:doc-dateTime-min="1897-01-27T00:00:00-05:00" n="323" subtype="historical-document" type="document" xml:id="d323">
                        <head><hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Lazo Arriaga</persName>.</hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1897-01-27"><hi rend="italic">January 27,
                                1897</hi></date>.</dateline>
                            <seg rendition="#left">No. 25.]</seg></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your note of the 15th instant, and to inform you in reply
                            that Mr. D. Lynch Pringle, consul-general of the United States at
                            Guatemala City, has been appointed honorary commissioner of this
                            Government at the Central American Exposition, to be opened on March 15
                            next.</p>
                        <p>Accept, sir, etc.,</p>
                        <closer><signed><hi rend="smallcaps">Richard Olney.</hi></signed></closer>
                    </div>
                    </body></text></TEI>