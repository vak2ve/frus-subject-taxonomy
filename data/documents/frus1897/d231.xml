                <head>
                    <hi rend="italic">Mr. <persName type="from">Carter</persName> to Mr. <persName
                            type="to">Sherman</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Embassy of the United States</hi>,<lb/>
                            <hi rend="italic">London</hi>
                        </placeName>, <date calendar="gregorian" when="1897-03-21">
                            <hi rend="italic">March 21</hi>, (<hi rend="italic">?</hi>) <hi
                                rend="italic">1897</hi>
                        </date>.</dateline>
                </opener>
                <p>Officially notified blockade of Crete by powers, March 21.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Carter.</hi>
                    </signed>
                </closer>
            </div>
        </body>
