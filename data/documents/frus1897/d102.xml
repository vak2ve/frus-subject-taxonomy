    <text>
        <body>
            <div frus:doc-dateTime-max="1897-08-17T23:59:59-05:00"
                frus:doc-dateTime-min="1897-08-17T00:00:00-05:00" n="102"
                subtype="historical-document" type="document" xml:id="d102">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Sherman</persName> to Mr. <persName
                            type="to">Denby</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1897-08-17">
                            <hi rend="italic">August 17, 1897</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                    dispatch No. 2775, of the 12th ultimo, inclosing a copy of the correspondence
                    between yourself and the Chinese Government in relation to the exhibition of
                    passports by travelers in China, and matters connected therewith.</p>
                <p>Your reply to the Tsung-li Yamên is approved by the Department.</p>
                <p>Respectfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Sherman.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
