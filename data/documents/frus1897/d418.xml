                subtype="historical-document" type="document" xml:id="d418">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Sherman</persName> to Mr. <persName
                            type="to">McDonald</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1897-04-06">
                            <hi rend="italic">April 6, 1897</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 194.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your No.
                    282, diplomatic series, of February 28 last, concerning certain restrictions
                    placed on the introduction of books into Persia.</p>
                <p>The Department reserves instructions should well-grounded complaint of
                    interference with any just right of citizens of the United States be brought to
                    its knowledge with due averment of all necessary facts upon which to reach a
                    decision.</p>
                <p>Respectfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Sherman.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
