    <text>
        <body>
            <div frus:doc-dateTime-max="1966-04-01T23:59:59-05:00"
                frus:doc-dateTime-min="1966-04-01T00:00:00-05:00" n="127"
                subtype="historical-document" type="document" xml:id="d127">
                <head>127. National Security Action Memorandum No. 344<note n="1" type="source"
                        xml:id="d127fn1">Source: National Archives and Records Administration, RG
                        59, Records of the Department of State, Central Files, 1964–66, AV 3. No
                        classification marking.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1966-04-01">April 1, 1966</date>.</dateline>
                </opener>
                <list type="to">
                    <head>TO</head>
                    <item>The Vice President</item>
                    <item>The Secretary of Defense</item>
                    <item>The Secretary of Commerce</item>
                    <item>Administrator, Federal Aviation Agency</item>
                    <item>Director, Bureau of the Budget</item>
                    <item>Director, Office of Emergency Planning</item>
                </list>
                <list type="subject">
                    <head>SUBJECT</head>
                    <item>Assignment of Highest National Priority to the Civil Supersonic
                        Development Program</item>
                </list>
                <p>Under the authority vested in me by the Defense Production Act of 1950, I hereby
                    assign the highest national priority to the Civil Supersonic Transport
                    Development Program for research and development <pb facs="0261" n="231"
                        xml:id="pg_231"/> and for construction of two prototype aircraft, in
                    accordance with the unanimous recommendation of the Members of the National
                    Aeronautics and Space Council.</p>
                <closer>
                    <signed>
                        <hi rend="strong">
                            <persName corresp="#p_JLB1">Lyndon B. Johnson</persName>
                        </hi>
                    </signed>
                </closer>
            </div>
