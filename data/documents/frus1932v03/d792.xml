                subtype="historical-document" type="document" xml:id="d792">
                <note rend="inline" type="source">793.94/5144: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China (<persName corresp="#p_JNT1" type="from"
                            >Johnson</persName>) to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1932-05-03T12:00:00+08:00"
                            >May 3, 1932—noon</date>.<lb/>[Received May 3—3 a.m.]</dateline>
                </opener>
                <p>
                    <persName corresp="#p_QT1">Quo Tai-chi</persName>, chief delegate on Chinese
                    side assaulted by Chinese student at his house at about 9:30 this morning.
                    Slightly wounded on forehead. It is not believed that his condition is such as
                    to delay proceedings.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_JNT1">
                            <hi rend="smallcaps">Johnson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
