                subtype="historical-document" type="document" xml:id="d699">
                <note rend="inline" type="source">693.002 Manchuria/33: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Great Britain (<persName corresp="#p_AR1"
                            type="from">Atherton</persName>) to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1932-04-02T12:00:00+00:00"
                            >April 2, 1932—noon</date>.<lb/>[Received April 2—8 a.m.]</dateline>
                </opener>
                <p>127. In view of British Government’s opinion expressed in my telegram 126, April
                    1, 5 p.m., I shall take no action on Department’s 105, April 1, 4 p.m., without
                    further instructions.<note n="38" xml:id="d699fn38">The Department replied in
                        telegram No. 107, April 3, 2 p.m.: “Withhold action until further
                        instructed.” (693.002 Manchuria/39)</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_AR1">
                            <hi rend="smallcaps">Atherton</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
