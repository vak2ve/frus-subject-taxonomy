                subtype="historical-document" type="document" xml:id="d536">
                <note rend="inline" type="source">793.94/4534: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan (<persName corresp="#p_FWC1"
                            type="from">Forbes</persName>) to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1932-03-03T17:00:00+09:00"
                            >March 3, 1932—5 p.m.</date>
                        <lb/>[Received March 3—6:10 a.m.]</dateline>
                </opener>
                <p>88. Japanese General Staff announces that further forward advance of Japanese
                    Army at Shanghai will in general cease after today’s movements are
                    completed.</p>
                <p>The papers announce complete general withdrawal of 19th Chinese Route Army.</p>
                <p>Repeated to Shanghai.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_FWC1">
                            <hi rend="smallcaps">Forbes</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
