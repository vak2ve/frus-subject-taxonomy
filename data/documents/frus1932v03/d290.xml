                subtype="historical-document" type="document" xml:id="d290">
                <note rend="inline" type="source">793.94/4086: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Nanking (<persName type="from"
                            >Peck</persName>) to the <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1932-02-10T15:00:00+08:00"
                            >February 10, 1932—3 p.m.</date>
                        <lb/>[Received February 10—9:20 a.m.]</dateline>
                </opener>
                <p>40. Your 26, February 9, 1 p.m.<note n="93" xml:id="d290fn93">Not printed.</note>
                    Three Japanese cruisers and three Japanese destroyers are now at Nanking.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Peck</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
