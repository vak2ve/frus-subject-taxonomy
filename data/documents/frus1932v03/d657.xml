    <text>
        <body>
            <div frus:doc-dateTime-max="1932-03-21T19:00:00-05:00"
                frus:doc-dateTime-min="1932-03-21T19:00:00-05:00" n="657"
                subtype="historical-document" type="document" xml:id="d657">
                <note rend="inline" type="source">793.94/4844: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China (<persName corresp="#p_JNT1" type="from"
                            >Johnson</persName>) to the <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1932-03-22T08:00:00+08:00"
                            >March 22, 1932—8 a.m.</date>
                        <lb/>[Received March 22—3:05 a.m.]</dateline>
                </opener>
                <p>Situation report No. 12, March 21st: <quote rend="blockquote">
                        <list>
                            <item>“1. Embarkation of 11th Division for Japan begins today. Movement
                                is expected to be completed by 22nd.</item>
                            <item>2. On completed departure of this Division there will still be
                                approximately 37, 000 Japanese troops remaining.”</item>
                        </list>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_JNT1">
                            <hi rend="smallcaps">Johnson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
