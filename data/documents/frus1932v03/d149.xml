                subtype="historical-document" type="document" xml:id="d149">
                <note rend="inline" type="source">793.94/3709: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Shanghai (<persName corresp="#p_CES1"
                            type="from">Cunningham</persName>) to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1932-01-30T20:00:00+08:00"
                            >January 30, 1932—8 p.m.</date>
                        <lb/>[Received January 30—6:49 a.m.]</dateline>
                </opener>
                <p>Referring to my telegram of January 27, I have now decided that the exigencies
                    justify my requesting that the landing forces from American vessels be increased
                    at the earliest moment possible.</p>
                <p>Repeated to the Legation.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_CES1">
                            <hi rend="smallcaps">Cunningham</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
