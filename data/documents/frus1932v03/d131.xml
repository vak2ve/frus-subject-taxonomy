                subtype="historical-document" type="document" xml:id="d131">
                <note rend="inline" type="source">793.94/3723: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy (<persName type="from"
                            >Garrett</persName>) to the <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1932-01-30T13:00:00+01:00"
                            >January 30, 1932—1 p.m.</date>
                        <lb/>[Received January 30—9:30 a.m.]</dateline>
                </opener>
                <p>19. Foreign Office informs me that it is understood that British Government last
                    night made representations in regard to Shanghai <pb facs="0220" n="116"
                        xml:id="pg_116"/> through Japanese Ambassador in London and that the Italian
                    Government is disposed to follow the British lead.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Garrett</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
