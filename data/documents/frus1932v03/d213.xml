                subtype="historical-document" type="document" xml:id="d213">
                <note rend="inline" type="source">793.94/3892: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Japan (<persName corresp="#p_FWC1" type="to"
                        >Forbes</persName>)</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-02-03T12:00:00-05:00"
                            >February 3, 1932—noon</date>.</dateline>
                </opener>
                <p>35. Your 37, February 3, 5 p.m., last paragraph. The Consul General at Shanghai
                    has been instructed in accordance with your request.</p>
                <p>The Department requests from you fuller and more frequent reports, if possible,
                    of events and opinion in Tokyo.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
