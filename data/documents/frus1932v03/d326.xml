                subtype="historical-document" type="document" xml:id="d326">
                <note rend="inline" type="source">793.94/4178a:Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at Shanghai (<persName corresp="#p_CES1" type="to"
                            >Cunningham</persName>)</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-02-12T17:00:00-05:00"
                            >February 12, 1932—5 p.m.</date>
                    </dateline>
                </opener>
                <p>17. For the Minister. I desire that you keep in close touch with the British
                    Minister and that you keep me promptly and fully informed of your views in
                    reference to current developments and estimated possibilities.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
