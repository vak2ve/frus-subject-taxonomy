<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-03-08T12:00:00-05:00" frus:doc-dateTime-min="1932-03-08T12:00:00-05:00" n="569" subtype="historical-document" type="document" xml:id="d569">
                        <note rend="inline" type="source">893.01 Manchuria/25: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in China (<persName corresp="#p_JNT1" type="to">Johnson</persName>)</hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1932-03-08T12:00:00-05:00">March 8,
                                1932—noon</date>.</dateline>
                        </opener>
                        <p>80. Your 312, March 8, 11 a.m.</p>
                        <list>
                            <label>1.</label>
                            <item>Department has telegraphed the Consul General at Harbin<note n="64" xml:id="d569fn64">Telegram not printed.</note> directly
                                that he should not attend congratulatory celebration and should file
                                without acknowledgment any official invitation received from the new
                                regime.</item>
                            <pb facs="0634" n="530" xml:id="pg_530"/>
                            <label>2.</label>
                            <item>Please inform Consul General at Mukden that Department approves
                                his attitude toward invitation to attend inauguration of the
                                executive at Changchun and that he should file invitation without
                                acknowledgment.</item>
                            <label>3.</label>
                            <item>Inform Minister.</item>
                        </list>
                        <closer><signed><persName corresp="#p_SHL1"><hi rend="smallcaps">Stimson</hi></persName></signed></closer>
                    </div>
                    </body></text></TEI>