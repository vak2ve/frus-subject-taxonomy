                subtype="historical-document" type="document" xml:id="d162">
                <note rend="inline" type="source">793.94/3775: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Shanghai (<persName corresp="#p_CES1"
                            type="from">Cunningham</persName>) to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1932-01-31T22:00:00+08:00"
                            >January 31, 1932—10 p.m.</date>
                        <lb/>[Received January 31—9:25 a.m.]</dateline>
                </opener>
                <p>My telegram January 30, 4 p.m. and Department’s January 30, 2 p.m.</p>
                <p>2. The Secretary General of the Council informed me this afternoon that the
                    Council had decided not to file a formal protest against the violation of the
                    neutrality of the Settlement.</p>
                <p>Repeated to the Legation and Nanking.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_CES1">
                            <hi rend="smallcaps">Cunningham</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
