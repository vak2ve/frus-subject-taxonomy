                subtype="historical-document" type="document" xml:id="d86">
                <note rend="inline" type="source">893.00/11747: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China (<persName corresp="#p_JNT1" type="from"
                            >Johnson</persName>) to the <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1932-01-27T17:00:00+08:00"
                            >January 27, 1932—5 p.m.</date>
                        <lb/>[Received January 27—8:45 a.m.]</dateline>
                </opener>
                <p>132. Following from Reuter, Nanking: <quote rend="blockquote">
                        <p>January 26. “General <persName corresp="#p_CM1">Chen Ming-shu</persName>
                            has been appointed Foreign Minister in succession to Mr. <persName
                                corresp="#p_CEY1">Eugene Chen</persName>, who resigned owing to the
                            Government not agreeing to his proposal to break off relations with
                            Japan.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_JNT1">
                            <hi rend="smallcaps">Johnson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
