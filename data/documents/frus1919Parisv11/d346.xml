<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-10-05T05:00:00-05:00" frus:doc-dateTime-min="1919-10-05T05:00:00-05:00" n="346" subtype="historical-document" type="document" xml:id="d346">
                    <note rend="inline" type="source">763.72119P43/715: Telegram</note>
                    <head><hi rend="italic">Colonel <persName type="from">E. M. House</persName> to
                            the <gloss type="to">Secretary of State</gloss></hi></head>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1919-10-05T11:00:00+01:00">October 5, 1919—11
                            a.m.</date><lb/>[Received October 5—9:35 a.m.]</dateline></opener>
                    <p>4532. For the President and Secretary of State. I am leaving Paris today for
                        Brest and am sailing for home tomorrow morning on the <hi rend="italic">Northern Pacific</hi>.</p>
                    <closer><signed><hi rend="smallcaps">Edward House</hi></signed></closer>
                </div>
                </body></text></TEI>