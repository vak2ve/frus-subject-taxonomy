                subtype="historical-document" type="document" xml:id="d264">
                <note rend="inline" type="source">Paris Peace Conf. 184.1 Morison, Samuel E.</note>
                <head>
                    <hi rend="italic">The Secretary General of the Commission to Negotiate
                        Peace</hi> (<persName type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to Mr. <persName type="to">S. E.
                            Morison</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1919-06-16">June 16,
                            1919</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Dr. Morison</hi>: I beg to acknowledge the receipt
                    of your letter of June 15th and to advise you that the Commissioners have
                    accepted your resignation from the Commission.</p>
                <p>Yours very truly,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">J. C. Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
