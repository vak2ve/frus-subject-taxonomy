    <text>
        <body>
            <div frus:doc-dateTime-max="1919-04-21T23:59:59-05:00"
                frus:doc-dateTime-min="1919-04-21T00:00:00-05:00" n="243"
                subtype="historical-document" type="document" xml:id="d243">
                <note rend="inline" type="source">Paris Peace Conf. 184/148</note>
                <head>
                    <hi rend="italic">The Secretary General of the Commission to Negotiate
                        Peace</hi> (<persName type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1919-04-21">April 21,
                            1919</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to enclose, for the information
                    of the Department, two copies of a chart showing in detail the organization</p>
                <pb facs="0587" n="[Chart 1]" xml:id="pg-seq-0587-chart-1"/>
                <figure>
                    <graphic url="figure_0587"/>
                </figure>
                <pb facs="0588" n="[]" xml:id="pg-seq-0588"/>
                <pb facs="0589" n="551" xml:id="pg_551"/>
                <p rend="flushleft">of the American Commission to Negotiate Peace.<note n="39"
                        xml:id="d243fn39">See diagram facing <ref target="#pg_550">p.
                        550</ref>.</note> These charts are revised to April 1, 1919.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">J. C. Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
