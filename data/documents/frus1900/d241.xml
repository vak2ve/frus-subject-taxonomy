                subtype="historical-document" type="document" xml:id="d241">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Conger</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>.<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1900-12-21">
                            <hi rend="italic">December 21, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>(As Mr. Conger has felt obliged to acquiesce in the note retaining the word
                    “irrevocable,” and considering his statement that if he does not sign it will
                    probably result in failure of negotiations, Mr. Hay authorizes him to sign after
                    again stating the views of this Government.)</p>
            </div>
        </body>
