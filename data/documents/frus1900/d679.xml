    <text>
        <body>
            <div frus:doc-dateTime-max="1900-01-12T23:59:59-05:00"
                frus:doc-dateTime-min="1900-01-12T00:00:00-05:00" n="679"
                subtype="historical-document" type="document" xml:id="d679">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Choate</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram in cipher—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1900-01-12">
                            <hi rend="italic">January 12, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>[Mr. Choate states that in answer to his pressing inquiries foreign office states
                    that it has no information regarding seizures not already possessed by the
                    United States Government, and that it would furnish facts as soon as it received
                    them.]</p>
            </div>
        </body>
