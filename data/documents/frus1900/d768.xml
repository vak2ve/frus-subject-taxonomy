                subtype="historical-document" type="document" xml:id="d768">
                <head>
                    <hi rend="italic">Lord <persName type="from">Pauncefote</persName> to Mr.
                            <persName type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">British Embassy</hi>,<lb/>
                            <hi rend="italic">Newport R. I.</hi>
                        </placeName>, <date calendar="gregorian" when="1900-10-01">
                            <hi rend="italic">October 1, 1900</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 285.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you by direction of
                    the Marquis of Salisbury that His Majesty the King of Sweden and Norway has
                    signified his willingness to consider the claims of all foreigners in connection
                        <pb facs="0725" n="627" xml:id="pg_627"/> with the military operations in
                    Samoa, if the three signatory powers of the convention of November 7, 1899, will
                    consent to their being submitted to His Majesty’s arbitration.</p>
                <p>I am instructed by Lord Salisbury to ascertain the views of your Government on
                    this point and to inform you that Her Majesty’s Government on their part are
                    prepared to agree to the proposal.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Pauncefote.</hi>
                    </signed>
                </closer>
            </div>
        </body>
