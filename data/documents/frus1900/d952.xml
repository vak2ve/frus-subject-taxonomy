<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1900-08-08T23:59:59-05:00" frus:doc-dateTime-min="1900-08-08T00:00:00-05:00" n="952" subtype="historical-document" type="document" xml:id="d952">
                        <head><hi rend="italic">Señor <persName type="from">Corea</persName> to the
                                    <gloss type="to">Department of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Managua, Nicaragua</hi></placeName>, <date calendar="gregorian" when="1900-08-08"><hi rend="italic">August
                                        8, 1900</hi></date>.</dateline></opener>
                        <p>Government resolved definitively July 30 devolution duties American
                            merchants regards.</p>
                        <closer><signed><hi rend="smallcaps">Corea.</hi></signed></closer>
                    </div>
