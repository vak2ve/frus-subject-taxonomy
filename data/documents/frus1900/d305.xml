<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1900-07-24T23:59:59-05:00" frus:doc-dateTime-min="1900-07-24T00:00:00-05:00" n="305" subtype="historical-document" type="document" xml:id="d305">
                            <head><hi rend="italic">Mr. <persName type="from">Wu
                                        Ting-fang</persName> to Mr. <persName type="to">Hay</persName>.</hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Chinese Legation</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1900-07-24"><hi rend="italic">July 24,
                                        1900</hi></date>.</dateline></opener>
                            <p><hi rend="smallcaps">My Dear Mr. Secretary</hi>: I have the honor to
                                acknowledge receipt of your note of yesterday, inclosing a copy of a
                                letter from the President of the United States to the Emperor of
                                China, which I have transmitted by telegraph to its high destination
                                as requested.</p>
                            <p>With renewed assurances, etc.,</p>
                            <closer><signed><hi rend="smallcaps">Wu
                                Ting-fang.</hi></signed></closer>
                        </div>
                        </body></text></TEI>