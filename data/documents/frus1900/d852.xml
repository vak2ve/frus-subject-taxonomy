                <head>
                    <hi rend="italic">Mr. <persName type="from">Draper</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Embassy of the United States</hi>,<lb/>
                            <hi rend="italic">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1900-03-18">
                            <hi rend="italic">March 18, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Draper acknowledges receipt of telegraphic instructions of the 16th instant,
                    and reports that arrangements will be made as directed.)</p>
