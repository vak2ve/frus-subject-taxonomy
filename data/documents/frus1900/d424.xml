<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1900-10-20T23:59:59-05:00" frus:doc-dateTime-min="1900-10-20T00:00:00-05:00" n="424" subtype="historical-document" type="document" xml:id="d424">
                            <head><hi rend="italic">Count <persName type="from">Quadt</persName> to
                                    Mr. <persName type="to">Hay</persName>.</hi></head>
                            <opener><seg rendition="#center">[Translation.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Imperial German Embassy</hi>,<lb/><hi rend="italic">Washington, D. C.</hi></placeName>, <date calendar="gregorian" when="1900-10-20"><hi rend="italic">October 20, 1900</hi></date>.</dateline></opener>
                            <p>Mr. <hi rend="smallcaps">Secretary of State</hi>: In compliance with
                                instructions, I have the honor respectfully to bring to the
                                knowledge of your excellency the following agreement, arrived at by
                                the Imperial Ambassador Count von Hatzfeldt and Lord Salisbury on
                                the 16th instant, by means of an exchange of notes.<note n="1" xml:id="d424fn1">English translation of agreement, printed under
                                    Great Britain, <ref target="#pg_354">p. 354</ref>.</note></p>
                            <p>Accept, Mr. Secretary of State, the renewed assurance of my most
                                distinguished consideration,</p>
                            <closer><signed><hi rend="smallcaps">A. Quadt.</hi></signed></closer>
                        </div>
                        </body></text></TEI>