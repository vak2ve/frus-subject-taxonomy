<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1900-07-11T23:59:59-05:00" frus:doc-dateTime-min="1900-07-11T00:00:00-05:00" n="134" subtype="historical-document" type="document" xml:id="d134">
                            <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                        <persName type="to">Conger</persName>.</hi></head>
                            <opener><seg rendition="#center">[Telegram.—Sent in cipher through the
                                    Chinese minister, who thought he might be able to get it to Mr.
                                    Conger through Sheng Tajen.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1900-07-11"><hi rend="italic">July 11,
                                        1900</hi></date>.</dateline></opener>
                            <p rend="flushleft"><hi rend="smallcaps">Conger</hi>, <hi rend="italic">American Minister, Pekin:</hi></p>
                            <p>Communicate tidings bearer.</p>
                            <closer><signed><hi rend="smallcaps">Hay.</hi></signed></closer>
                        </div>
                        </body></text></TEI>