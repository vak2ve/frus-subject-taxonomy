                subtype="historical-document" type="document" xml:id="d667">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Toomey</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington D. C.</hi>
                        </placeName>, <date calendar="gregorian" when="1900-01-09">
                            <hi rend="italic">January 9, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Pennsylvania Milling and Export Co.</hi>:</p>
                <p>Ambassador Choate telegraphs to-day inquiring if your flour was sold for future
                    delivery; also how does your present interest appear?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
