<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1900-06-20T23:59:59-05:00" frus:doc-dateTime-min="1900-06-20T00:00:00-05:00" n="750" subtype="historical-document" type="document" xml:id="d750">
                        <head><hi rend="italic">Mr. <persName type="from">Choate</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram—Paraphrase]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Embassy</hi>,<lb/><hi rend="italic">London</hi></placeName>, <date calendar="gregorian" when="1900-06-20"><hi rend="italic">June 20,
                                1900</hi></date>.</dateline></opener>
                        <p>(Mr. Choate requests that Mr. Geldart state the price that will reimburse
                            him for shipments on the <hi rend="italic">Mashona.</hi>)</p>
