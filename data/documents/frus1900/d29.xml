                subtype="historical-document" type="document" xml:id="d29">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Townsend</persName> to <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Brussels</hi>
                        </placeName>, <date calendar="gregorian" when="1900-12-22">
                            <hi rend="italic">December 22, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Townsend reports that he is informed by the minister for foreign affairs
                    that it is not too late for the United States to adhere to the Brussels
                    convention of June 8, 1899.)</p>
            </div>
