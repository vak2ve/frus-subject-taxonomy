<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1900-07-03T23:59:59-05:00" frus:doc-dateTime-min="1900-07-03T00:00:00-05:00" n="254" subtype="historical-document" type="document" xml:id="d254">
                            <head><hi rend="italic">Mr. <persName type="from">Goodnow</persName> to
                                    Mr. <persName type="to">Cridler</persName>.</hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Consulate-General of the United States</hi>,<lb/><hi rend="italic">Shanghai</hi></placeName>, <date calendar="gregorian" when="1900-07-03"><hi rend="italic">July 3, 1900</hi></date>.</dateline></opener>
                            <p><hi rend="smallcaps">Sir</hi>: I beg to hand you herewith (in
                                duplicate) proclamation issued here at request of the admirals
                                allied fleet.</p>
                            <p>I have the honor to be, etc.,</p>
                            <closer><signed><hi rend="smallcaps">John Goodnow</hi>, <hi rend="italic">Consul-General.</hi></signed></closer>
                            <frus:attachment>
                                <opener><seg rendition="#center">[Inclosure.]</seg></opener>
                                <head><hi rend="italic">Proclamation.</hi></head>
                                <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Taku</hi></placeName>, <date calendar="gregorian" when="1900-06-20"><hi rend="italic">June 20,
                                            1900</hi></date>.</dateline></opener>
                                <p>The admirals and senior officers of the allied powers in China
                                    desire to let it be known to all viceroys and authorities on*
                                    coast, river provinces, and cities in China <pb facs="0350" n="252" xml:id="pg_252"/> that they intend use of their arms
                                    only against the Boxers and those people who oppose them in
                                    their march to Pekin for the rescue of their fellow
                                    countrymen.</p>
                                <p>Published by request of the senior admiral at Taku.</p>
                                <closer><signed><hi rend="smallcaps">Joaquim Maria Travassos
                                            Valdez</hi>,<lb/><hi rend="italic">Consul-General for
                                            Portugal and Senior Consul.</hi></signed>
                                    <lb/>
                                    <dateline rendition="#left"><hi rend="smallcaps">Senior
                                            Consulate</hi>, <placeName><hi rend="italic">Shanghai</hi></placeName>, <date calendar="gregorian" when="1900-06-23"><hi rend="italic">June 23, 1900</hi></date>.</dateline></closer>
                                <postscript>
                                    <p><hi rend="smallcaps">United States
                                            Consulate-General</hi>,<lb/><hi rend="italic">Shanghai,
                                            China, July 3, 1900.</hi></p>
                                </postscript>
                            </frus:attachment>
                        </div>
                        </body></text></TEI>