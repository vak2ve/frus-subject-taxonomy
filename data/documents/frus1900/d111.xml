    <text>
        <body>
            <div frus:doc-dateTime-max="1900-05-26T23:59:59-05:00"
                frus:doc-dateTime-min="1900-05-26T00:00:00-05:00" n="111"
                subtype="historical-document" type="document" xml:id="d111">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hill</persName> to Mr. <persName
                            type="to">Conger</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1900-05-26">
                            <hi rend="italic">May 26, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>If required for safety of legation, confer with admiral about sending guards for
                    your protection.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hill</hi>, <hi rend="italic">Acting.</hi>
                    </signed>
                </closer>
            </div>
        </body>
