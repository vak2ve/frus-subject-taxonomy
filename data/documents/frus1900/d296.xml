    <text>
        <body>
            <div frus:doc-dateTime-max="1900-07-11T23:59:59-05:00"
                frus:doc-dateTime-min="1900-07-11T00:00:00-05:00" n="296"
                subtype="historical-document" type="document" xml:id="d296">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Wu Ting-fang</persName> to Mr.
                            <persName type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chinese Legation</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1900-07-11">
                            <hi rend="italic">July 11, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: I have the pleasure to
                    acknowledge receipt of your letter of the 5th instant inclosing copies of
                    telegrams sent to the American consul-general at Shanghai on the 27th of June
                    and the 1st of July, respectively, for which please accept my sincere
                    thanks.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wu Ting-fang.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
