<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1900-07-05T23:59:59-05:00" frus:doc-dateTime-min="1900-07-05T00:00:00-05:00" n="295" subtype="historical-document" type="document" xml:id="d295">
                            <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                        <persName type="to">Wu Ting-fang</persName>.</hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1900-07-05"><hi rend="italic">July 5,
                                    1900</hi></date>.</dateline></opener>
                            <p><hi rend="smallcaps">Dear Mr. Minister</hi>: I inclose copies of
                                telegrams sent to the American consul-general at Shanghai on the
                                27th of June and the 1st of July.<note n="1" xml:id="d295fn1">Printed <ref target="#pg_248">pp. 248</ref> and <ref target="#pg_252">252</ref>.</note></p>
                            <closer><signed><hi rend="smallcaps">John Hay.</hi></signed></closer>
                        </div>
                        </body></text></TEI>