    <text>
        <body>
            <div frus:doc-dateTime-max="1900-07-30T23:59:59-05:00"
                frus:doc-dateTime-min="1900-07-30T00:00:00-05:00" n="859"
                subtype="historical-document" type="document" xml:id="d859">
                <head>
                    <hi rend="italic">Baron <persName type="from">Fava</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Seabright, N. J.</hi>
                        </placeName>, <date calendar="gregorian" when="1900-07-30">
                            <hi rend="italic">July 30, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>Your telegram received and transmitted to my Government. I am deeply grateful for
                    the part the President, your excellency, and American people take in our great
                    sorrow.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Fava.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
