<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1900-10-23T23:59:59-05:00" frus:doc-dateTime-min="1900-10-23T00:00:00-05:00" n="410" subtype="historical-document" type="document" xml:id="d410">
                            <head><hi rend="italic">Mr. <persName type="from">Jackson</persName> to
                                    Mr. <persName type="to">Hay</persName>.</hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Embassy of the United States</hi>,<lb/><hi rend="italic">Berlin</hi></placeName>, <date calendar="gregorian" when="1900-10-23"><hi rend="italic">October 23, 1900</hi></date>.</dateline>
                                <seg rendition="#left">No. 1434.]</seg></opener>
                            <p><hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                                receipt this morning of your telegram<note n="1" xml:id="d410fn1">Printed <ref target="#pg_307">p. 307</ref>.</note> containing
                                the American answer to certain French proposals with regard to the
                                peace negotiations with China, and to inform you that I at once
                                communicated the same to Baron von Richthofen, at the foreign
                                office. * * *</p>
                            <p>I have the honor to be, etc.,</p>
                            <closer><signed><hi rend="smallcaps">John B.
                                Jackson.</hi></signed></closer>
                        </div>
                        </body></text></TEI>