<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1900-11-16T23:59:59-05:00" frus:doc-dateTime-min="1900-11-16T00:00:00-05:00" n="218" subtype="historical-document" type="document" xml:id="d218">
                            <head><hi rend="italic">Mr. <persName type="from">Conger</persName> to
                                    Mr. <persName type="to">Hay</persName>.</hi></head>
                            <opener><seg rendition="#center">[Telegram—Paraphrase.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Pekin</hi></placeName>, <date calendar="gregorian" when="1900-11-16"><hi rend="italic">November 16,
                                        1900</hi></date>.</dateline></opener>
                            <p>(Mr. Conger reports the decapitation at Paotingfu of the provincial
                                treasurer, a Tartar general, and a lieutenant-colonel, under
                                sentence of military court, approved by field marshal.)</p>
                        </div>
                        </body></text></TEI>