                subtype="historical-document" type="document" xml:id="d1016">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Peirce</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraph rase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Embassy of the United States</hi>,<lb/>
                            <hi rend="italic">St. Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1900-09-08">
                            <hi rend="italic">September 8, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>[Mr. Peirce reports the signature at noon this day of the protocol of the
                    arbitration of the claims of United States citizens for the seizure by Russia of
                    vessels in the North Pacific]</p>
            </div>
