    <text>
        <body>
            <div frus:doc-dateTime-max="1900-07-19T23:59:59-05:00"
                frus:doc-dateTime-min="1900-07-19T00:00:00-05:00" n="136"
                subtype="historical-document" type="document" xml:id="d136">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Rockhill</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1900-07-19">
                            <hi rend="italic">July 19, 1900</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 1.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I inclose herewith the commission of the
                        President,<note n="2" xml:id="d136fn2">Not printed.</note> dated to-day,
                    appointing you Commissioner of the United States of America to China.</p>
                <p>You will proceed to that country and act in compliance with the instructions
                    which have been given to you orally.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
