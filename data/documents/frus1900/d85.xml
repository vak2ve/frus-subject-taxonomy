                <head>
                    <hi rend="italic">Mr. <persName type="from">Conger</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Pekin</hi>
                        </placeName>, <date calendar="gregorian" when="1900-01-25">
                            <hi rend="italic">January 25, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>Imperial decree appoints P’u Ch’un, aged 14, heir apparent.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Conger.</hi>
                    </signed>
                </closer>
