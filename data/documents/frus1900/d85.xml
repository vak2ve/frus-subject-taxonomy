                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Pekin</hi></placeName>, <date calendar="gregorian" when="1900-01-25"><hi rend="italic">January 25,
