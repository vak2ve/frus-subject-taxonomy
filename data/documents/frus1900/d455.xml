                subtype="historical-document" type="document" xml:id="d455">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Iddings</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">United States Embassy</hi>,<lb/>
                            <hi rend="italic">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1900-07-04">
                            <hi rend="italic">July 4, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Iddings acknowledges the Department’s circular telegram of July 3<note n="1"
                        xml:id="d455fn1">Printed, <ref target="#pg_299">p. 299</ref>.</note> and
                    reports compliance with instructions. The minister for foreign affairs says
                    course of Italy depends largely upon that of other powers.)</p>
            </div>
        </body>
