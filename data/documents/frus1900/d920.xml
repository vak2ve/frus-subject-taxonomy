                subtype="historical-document" type="document" xml:id="d920">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Mill</persName> to Mr. <persName
                            type="to">Newel</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1900-11-24">
                            <hi rend="italic">November 24, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>[Mr. Hill directs that the Government of the Netherlands and the international
                    bureau of The Hague be notified that, in conformity with article 23 of Hague
                    convention for the pacific settlement of international <pb facs="0891" n="793"
                        xml:id="pg_793"/> disputes, the President designates as members of the court
                    of arbitration ex-President Benjamin Harrison, Chief Justice Melville W. Fuller,
                    Attorney-General John W. Griggs, and Judge George Gray.]</p>
            </div>
        </body>
