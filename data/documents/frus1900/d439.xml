                subtype="historical-document" type="document" xml:id="d439">
                <head>
                    <hi rend="italic">Lord <persName type="from">Pauncefote</persName> to Mr.
                            <persName type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Newport</hi>
                        </placeName>, <date calendar="gregorian" when="1900-07-06">
                            <hi rend="italic">July 6, 1900</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 195.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor, by direction of Her Majesty’s
                    principal secretary of state for foreign affairs, to inform you that his
                    lordship communicated a memorandum to the Chinese minister yesterday in the
                    following words: <quote rend="blockquote">
                        <p>The Chinese minister is requested by Her Majesty’s Government to transmit
                            by telegraph, in such a manner as will insure the message reaching the
                            Government at Pekin, notice that they will be held to be personally
                            guilty if the members of the European legations and others in Pekin
                            surfer injury.</p>
                    </quote>
                </p>
                <p>I have the honor to be, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Pauncefote.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
