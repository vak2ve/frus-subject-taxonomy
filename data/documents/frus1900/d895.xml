                subtype="historical-document" type="document" xml:id="d895">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hill</persName> to Mr. <persName
                            type="to">Takahira</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1900-09-26">
                            <hi rend="italic">September 26, 1900</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 9]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 21st instant expressing, by direction of His Imperial Majesty’s
                    Government, their profound sympathy and sincere condolence on account of the
                    disaster at Galveston.</p>
                <p>I beg you to assure your Government that this sympathetic message is highly
                    appreciated by the Government of the United States.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">David J. Hill</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
