    <text>
        <body>
            <div frus:doc-dateTime-max="1900-01-17T23:59:59-05:00"
                frus:doc-dateTime-min="1900-01-17T00:00:00-05:00" n="691"
                subtype="historical-document" type="document" xml:id="d691">
                <head>
                    <hi rend="italic">Messrs. <gloss type="from">C. C. Abel &amp; Co.</gloss> to Mr.
                            <persName type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">New York</hi>
                        </placeName>, <date calendar="gregorian" when="1900-01-17">
                            <hi rend="italic">January 17, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: We are in receipt of your communication of the
                    16th instant, and thank you for your courteous and prompt reply to our letter of
                    the 12th instant.</p>
                <p>It will be necessary for us to put ourselves in further correspondence with the
                    consignees of the petroleum to enable us to give you the required
                    particulars.</p>
                <p>We are, sir, your obedient servants,</p>
                <closer>
                    <hi rend="smallcaps">C. C. Abel</hi> &amp; Co.</closer>
            </div>
        </body>
    </text>
