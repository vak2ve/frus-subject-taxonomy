<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1900-09-21T23:59:59-05:00" frus:doc-dateTime-min="1900-09-21T00:00:00-05:00" n="160" subtype="historical-document" type="document" xml:id="d160">
                            <head><hi rend="italic">Mr. <persName type="from">Hill</persName> to Mr.
                                        <persName type="to">Conger</persName>.</hi></head>
                            <opener><seg rendition="#center">[Telegram—Paraphrase.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1900-09-21"><hi rend="italic">September 21,
                                        1900</hi></date>.</dateline></opener>
                            <p>(Mr. Hill directs that Mr. Conger extend to Swedish and Norwegian
                                missionaries attached to American missions at Kweihua-Che’eng, or
                                elsewhere in China, all possible proper protection.)</p>
                        </div>
                        </body></text></TEI>