    <text>
        <body>
            <div frus:doc-dateTime-max="1900-08-11T23:59:59-05:00"
                frus:doc-dateTime-min="1900-08-11T00:00:00-05:00" n="431"
                subtype="historical-document" type="document" xml:id="d431">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Choate</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">London</hi>
                        </placeName>, <date calendar="gregorian" when="1900-08-11">
                            <hi rend="italic">August 11, 1900</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 381.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to report that upon the receipt
                    of your instruction by cable, of August 8,<note n="1" xml:id="d431fn1">Circular
                        telegram printed ante, <ref target="#pg_300">p. 300</ref>.</note> I
                    communicated the contents thereof to Her Majesty’s minister for foreign affairs
                    by a note of August 9.</p>
                <p>I have the honor to be, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Joseph H. Choate.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
