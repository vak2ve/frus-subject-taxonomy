    <text>
        <body>
            <div frus:doc-dateTime-max="1900-01-06T23:59:59-05:00"
                frus:doc-dateTime-min="1900-01-06T00:00:00-05:00" n="665"
                subtype="historical-document" type="document" xml:id="d665">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Toomey</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">New York</hi>
                        </placeName>, <date calendar="gregorian" when="1900-01-06">
                            <hi rend="italic">January 6, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The 2,000 bags branded Speria, on steamer <hi
                        rend="italic">Maria</hi>, marked O &amp; Co., Delagoa Bay; the 1,500
                    Goldfields, same steamer, marked diamond T with letter S outside diamond, also
                    Delagoa Bay; the 4,300 branded Johannesburg, on <hi rend="italic">Beatrice</hi>,
                    marked diamond B, letter M outside, Delagoa Bay; the 1,300 Goldfields, same
                    steamer, diamond T, S outside, Delagoa Bay; the 3,100 branded Johannesburg, on
                    steamer <hi rend="italic">Mashona</hi>, marked diamond B, letter M outside
                    diamond, Delagoa Bay.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">A. J. Toomey</hi>,<lb/>
                        <hi rend="italic">President Pennsylvania Milling and Export Co.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
