<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1900-07-18T23:59:59-05:00" frus:doc-dateTime-min="1900-07-18T00:00:00-05:00" n="259" subtype="historical-document" type="document" xml:id="d259">
                            <head><hi rend="italic">Mr. <persName type="from">Goodnow</persName> to
                                    Mr. <persName type="to">Hay</persName>.</hi></head>
                            <opener><seg rendition="#center">[Telegram.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Shanghai</hi></placeName>, <date calendar="gregorian" when="1900-07-18"><hi rend="italic">July 18,
                                        1900</hi></date>.</dateline></opener>
                            <p>Bombarding legations 30th June with Krupp cannon. Reliable. Sixty
                                foreigners, 100 Chinese massacred Tai-yuan Shansi.</p>
                            <closer><signed><hi rend="smallcaps">Goodnow.</hi></signed></closer>
                        </div>
                        </body></text></TEI>