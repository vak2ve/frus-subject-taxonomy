<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1900-11-06T23:59:59-05:00" frus:doc-dateTime-min="1900-11-06T00:00:00-05:00" n="1028" subtype="historical-document" type="document" xml:id="d1028">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Storer</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1900-11-06"><hi rend="italic">November 6,
                                1900</hi></date>.</dateline></opener>
                        <p>[Mr. Hay directs that all passports or cedulas presented by citizens of
                            Porto Rico and Cuba, and all passports or cedulas presented by natives
                            of the Philippines, when issued or countersigned by the military
                            authorities of the United States in these islands, shall be registered
                            and viséed.]</p>
                    </div>
                    </body></text></TEI>