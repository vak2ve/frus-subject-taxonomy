<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1900-07-18T23:59:59-05:00" frus:doc-dateTime-min="1900-07-18T00:00:00-05:00" n="299" subtype="historical-document" type="document" xml:id="d299">
                            <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                        <persName type="to">Wu Ting-fang</persName>.</hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1900-07-18"><hi rend="italic">July 18,
                                        1900</hi></date>.</dateline></opener>
                            <p><hi rend="smallcaps">Dear Mr. Wu</hi>: The President has transmitted
                                to our officers in Tientsin the request of the viceroys and his hope
                                that it may be complied with.</p>
                            <closer><signed><hi rend="smallcaps">John Hay.</hi></signed></closer>
                        </div>
                        </body></text></TEI>