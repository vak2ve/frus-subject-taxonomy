                subtype="historical-document" type="document" xml:id="d28">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Townsend</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1900-12-21">
                            <hi rend="italic">December 21, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Hay states that Senate has just given its consent to adhesion of the United
                    States to Brussels convention of June 8, 1899, and directs Mr. Townsend to
                    ascertain whether it is too late to adhere.)</p>
            </div>
