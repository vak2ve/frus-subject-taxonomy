    <text>
        <body>
            <div frus:doc-dateTime-max="1900-01-30T23:59:59-05:00"
                frus:doc-dateTime-min="1900-01-30T00:00:00-05:00" n="710"
                subtype="historical-document" type="document" xml:id="d710">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Choate</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <date calendar="gregorian" when="1900-01-30">
                            <hi rend="smallcaps">January</hi> 30, 1900</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I herewith transmit to you the manifest of the
                    ship <hi rend="italic">Mashona</hi>, certified by the collector of the port of
                    New York, as suggested by you in your cablegram of the 21th instant. A copy has
                    been forwarded to our consul at Cape Town.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
