                subtype="historical-document" type="document" xml:id="d857">
                <head>
                    <hi rend="italic">The <gloss type="from">President</gloss> to the <gloss
                            type="to">King of Italy</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Executive Mansion</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1900-07-30">
                            <hi rend="italic">July 30, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>In my name, and on behalf of the American people, I offer Your Majesty and the
                    Italian nation sincere condolences in this hour of deep bereavement.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William McKinley.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
