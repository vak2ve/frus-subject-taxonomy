    <text>
        <body>
            <div frus:doc-dateTime-max="1900-12-29T23:59:59-05:00"
                frus:doc-dateTime-min="1900-12-29T00:00:00-05:00" n="765"
                subtype="historical-document" type="document" xml:id="d765">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Choate</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1900-12-29">
                            <hi rend="italic">December 29, 1900</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 522.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your No. 459
                    of the 19th instant transmitting an order upon Her Majesty’s paymaster-general
                    for £1,000, which the British secretary of war has awarded to Mrs. George F.
                    Labram in recognition of the assistance afforded by her late husband to Her
                    Majesty’s troops at Kimberly.</p>
                <p>The order has this day been forwarded to Mrs. Labram.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
