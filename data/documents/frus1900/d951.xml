                subtype="historical-document" type="document" xml:id="d951">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr. <persName
                            type="to">Merry</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1900-08-08">
                            <hi rend="italic">August 8, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>[Mr. Adee states that a report has been received that repayment of duties to
                    merchants has been ordered by the Nicaraguan Government, and directs Mr. Merry,
                    in that case, to ignore the last instruction of the Department.]</p>
            </div>
