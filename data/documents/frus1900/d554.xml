    <text>
        <body>
            <div frus:doc-dateTime-max="1900-07-06T23:59:59-05:00"
                frus:doc-dateTime-min="1900-07-06T00:00:00-05:00" n="554"
                subtype="historical-document" type="document" xml:id="d554">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to <persName
                            type="to">Thiebaut</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1900-07-06">
                            <hi rend="italic">July 6, 1900</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 334.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to receive with great
                    appreciation the expression of the thanks of the Government of the French
                    Republic, as conveyed in your note of the 2d instant, on the occasion of the
                    dedication of the statue erected to Lafayette in Paris by the Congress and the
                    school children of the United States.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
