    <text>
        <body>
            <div frus:doc-dateTime-max="1901-02-05T23:59:59-05:00"
                frus:doc-dateTime-min="1901-02-05T00:00:00-05:00" n="33"
                subtype="historical-document" type="document" xml:id="d33">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Townsend</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-02-05">
                            <hi rend="italic">February 5, 1901</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 68.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I beg to inform you that the formal instrument of
                    adhesion of the United States to the Brussels convention of June 8, 1899, for
                    the regulation of the importation of spirituous liquors into certain regions of
                    Africa, is sent to you to-day through the dispatch agent at London.</p>
                <p>Upon its receipt you will deposit the instrument of adhesion with the Belgian
                    Government.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
