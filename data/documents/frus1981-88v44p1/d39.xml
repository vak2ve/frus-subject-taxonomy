                        <head>
                            <gloss target="#t_SALT_1">SALT</gloss> Dismantlements Since 1972</head>
                        <row>
                            <cell/>
                            <cell>
                                <gloss target="#t_US_1">U.S.</gloss> Launchers</cell>
