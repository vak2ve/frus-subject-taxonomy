<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1869-08-18T23:59:59-05:00" frus:doc-dateTime-min="1869-08-18T00:00:00-05:00" n="467" subtype="historical-document" type="document" xml:id="d467">
                            <head><seg type="margin">[146]</seg> *<hi rend="italic">Mr. <persName type="from">Field</persName>, Acting Attorney-General, to
                                    Mr. <persName type="to">Barlow</persName>, United States
                                    marshal.</hi></head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <dateline><placeName><hi rend="smallcaps">Washington</hi></placeName>,
                                    <date calendar="gregorian" when="1869-08-18"><hi rend="italic">August</hi> 18, 1869</date>.</dateline>
                            <p rend="flushleft"><hi rend="smallcaps">F. C. Barlow</hi>, Esq., <hi rend="italic">United States Marshal, New York City:</hi></p>
                            <p>Have you any important facts about the steamer Hornet?</p>
                            <closer>
                                <signed>W. A. FIELD,<lb/><hi rend="italic">Acting
                                        Attorney-General.</hi></signed>
                            </closer>
                        </div>
                        </body></text></TEI>