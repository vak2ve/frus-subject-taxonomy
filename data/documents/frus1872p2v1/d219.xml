    <text>
        <body>
            <div frus:doc-dateTime-max="1850-05-25T23:59:59-05:00" frus:doc-dateTime-min="1850-05-25T00:00:00-05:00" n="219" subtype="historical-document" type="document" xml:id="d219">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Clayton</persName>,
                                    Secretary of State, to Mr. <persName type="to">Williams</persName>, district attorney.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Per telegraph.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Department of
                                    State</hi>
                    </placeName>,<lb/>
                    <date calendar="gregorian" when="1850-05-25">
                        <hi rend="italic">May</hi> 25,
                                1850</date>.</dateline>
                <p rend="flushleft">
                    <hi rend="smallcaps">Henry Williams</hi>,
                                    Esq.,<lb/>
                    <hi rend="italic">United States District Attorney,
                                    Savannah, Georgia:</hi>
                </p>
                <p>Proceed according to law to have General Lopez arrested for a
                                violation of the act of Congress of the 20th of April, 1818, and
                                held in custody until he can be transferred to the proper district
                                for trial.</p>
                <closer>
                    <signed>JOHN M. CLAYTON,<lb/>
                        <hi rend="italic">Secretary of
                                        State</hi>.</signed>
                </closer>
            </div>
        </body>
