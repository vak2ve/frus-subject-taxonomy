    <text>
        <body>
            <div frus:doc-dateTime-max="1869-09-03T23:59:59-05:00" frus:doc-dateTime-min="1869-09-03T00:00:00-05:00" n="433" subtype="historical-document" type="document" xml:id="d433">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Milledge</persName>,
                                    district attorney, to Mr. <persName type="to">Hoar</persName>,
                                    Attorney-General.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Macon,
                                    Georgia</hi>
                    </placeName>, <date calendar="gregorian" when="1869-09-03">
                        <hi rend="italic">September</hi> 3,
                                    1869</date>.</dateline>
                <p rend="flushleft">To <hi rend="smallcaps">Attorney-General</hi>:</p>
                <p>Can I have authority to employ troops if necessary; also to authorize
                                collector at Savannah to employ light-draught boat to cruise inland?
                                Cutter draws too much water. Answer.</p>
                <closer>
                    <signed>JOHN MILLEDGE,<lb/>
                        <hi rend="italic">United States District
                                        Attorney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
