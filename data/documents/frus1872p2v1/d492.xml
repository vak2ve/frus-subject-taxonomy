    <text>
        <body>
            <div frus:doc-dateTime-max="1869-10-07T23:59:59-05:00" frus:doc-dateTime-min="1869-10-07T00:00:00-05:00" n="492" subtype="historical-document" type="document" xml:id="d492">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Boutwell</persName>,
                                    Secretary of the Treasury, to Mr. <persName type="to">Rumley</persName>, collector.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Treasury
                                        Department</hi>,<lb/>
                        <hi rend="italic">Washington, D.
                                        C.</hi>
                    </placeName>, <date calendar="gregorian" when="1869-10-07">
                        <hi rend="italic">October</hi> 7,
                                1869</date>.</dateline>
                <p rend="flushleft">
                    <hi rend="smallcaps">D. Rumley</hi>, <hi rend="italic">Collector of Customs, Wilmington, North
                                    Carolina:</hi>
                </p>
                <p>
                    <seg type="margin">[173]</seg> I have ordered the steam
                                revenue-cutter McCulloch, at *Savannah, to proceed to Wilmington,
                                and report to you for orders.</p>
                <closer>
                    <signed>GEO. S. BOUTWELL,<lb/>
                        <hi rend="italic">Secretary of
                                        Treasury.</hi>
                    </signed>
                </closer>
            </div>
        </body>
