<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1869-06-18T23:59:59-05:00" frus:doc-dateTime-min="1869-06-18T00:00:00-05:00" n="377" subtype="historical-document" type="document" xml:id="d377">
                            <head>
                                <seg type="margin">[63]</seg>
                                <hi rend="italic">*Mr. <persName type="from">Pierrepont</persName>,
                                    district attorney, to Mr. <persName type="to">Hoar</persName>,
                                    Attorney-General.</hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <dateline><placeName><hi rend="smallcaps">New York</hi></placeName>,
                                    <date calendar="gregorian" when="1869-06-18"><hi rend="italic">June</hi> 18, 1869</date>.</dateline>
                            <p><hi rend="smallcaps">Sir</hi>: Yours of the seventeenth in relation
                                to the Cuban expedition is received. Action had already been taken
                                by me.</p>
                            <closer>
                                <signed>EDWARDS PIERREPONT,<lb/><hi rend="italic">United States
                                        Attorney.</hi></signed>
                            </closer>
                            <postscript>
                                <p>Hon. <hi rend="smallcaps">E. R. Hoar</hi>,<lb/><hi rend="italic">Attorney-General, Washington.</hi></p>
                            </postscript>
                        </div>
                        </body></text></TEI>