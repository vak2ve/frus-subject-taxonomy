                subtype="historical-document" type="document" xml:id="d399">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Field</persName>, Assistant
                        Attorney-General, to <gloss type="to">United States marshal, New Haven,
                            Connecticut</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1869-07-01">
                        <hi rend="italic">July</hi> 1, 1869</date>.</dateline>
                <p rend="flushleft">
                    <hi rend="smallcaps">United States Marshal</hi>,<lb/>
                    <hi rend="italic">New Haven, Connecticut:</hi>
                </p>
                <p>The schooners Fancy and Winona are at Milford, alleged to have violated the
                    neutrality laws. See district attorney, and take care of them and the men found
                    on board.</p>
                <closer>
                    <signed>W. A. FIELD.</signed>
                </closer>
            </div>
        </body>
    </text>
