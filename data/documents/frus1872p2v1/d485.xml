                subtype="historical-document" type="document" xml:id="d485">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Boutwell</persName>, Secretary of
                        the Treasury, to Mr. <persName type="to">Rumley</persName>,
                    collector</hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Treasury Department</hi>,<lb/>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1869-10-05">
                        <hi rend="italic">October</hi> 5, 1869</date>.</dateline>
                <p rend="flushleft">
                    <hi rend="smallcaps">D. Rumley</hi>, <hi rend="italic">Collector of Customs,
                        Wilmington, North Carolina:</hi>
                </p>
                <p>Your course in the case of the Hornet is approved. Who is retained as counsel?
                    You will hold the Hornet, under the eleventh section of the act of 1818, until
                    directed by the President to release her.</p>
                <closer>
                    <signed>GEO. S. BOUTWELL,<lb/>
                        <hi rend="italic">Secretary, &amp;c.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
