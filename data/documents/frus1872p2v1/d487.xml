                <head>
                    <seg type="margin">[170]</seg> *<hi rend="italic">Mr. <persName type="from"
                            >Barlow</persName>, United States marshal, to Mr. <persName type="to"
                            >Fish</persName>, Secretary of State.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">New York</hi>
                    </placeName>, <date calendar="gregorian" when="1869-10-07">
                        <hi rend="italic">October</hi> 7, 1869</date>.</dateline>
                <p rend="flushleft">
                    <hi rend="smallcaps">Secretary of State</hi>:</p>
                <p>I get rumor that Hornet will run out of Wilmington, in defiance of the United
                    States authorities.</p>
                <closer>
                    <signed>FRANCIS C. BARLOW.</signed>
                </closer>
            </div>
        </body>
