<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1869-10-07T23:59:59-05:00" frus:doc-dateTime-min="1869-10-07T00:00:00-05:00" n="487" subtype="historical-document" type="document" xml:id="d487">
                            <head><seg type="margin">[170]</seg> *<hi rend="italic">Mr. <persName type="from">Barlow</persName>, United States marshal, to Mr.
                                        <persName type="to">Fish</persName>, Secretary of
                                    State.</hi></head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <dateline><placeName><hi rend="smallcaps">New York</hi></placeName>,
                                    <date calendar="gregorian" when="1869-10-07"><hi rend="italic">October</hi> 7, 1869</date>.</dateline>
                            <p rend="flushleft"><hi rend="smallcaps">Secretary of State</hi>:</p>
                            <p>I get rumor that Hornet will run out of Wilmington, in defiance of
                                the United States authorities.</p>
                            <closer>
                                <signed>FRANCIS C. BARLOW.</signed>
                            </closer>
                        </div>
                        </body></text></TEI>