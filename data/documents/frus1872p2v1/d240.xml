<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1849-08-17T23:59:59-05:00" frus:doc-dateTime-min="1849-08-17T00:00:00-05:00" n="240" subtype="historical-document" type="document" xml:id="d240">
                            <head><seg type="margin">[692]</seg> *<hi rend="italic">Commandant
                                        <persName type="from">Newton</persName>, United States Navy,
                                    to Commander <persName type="to">Randolph</persName>, United
                                    States Navy.</hi></head>
                            <dateline><placeName><hi rend="smallcaps">Commandant’s
                                        Office</hi>,<lb/><hi rend="italic">Navy-Yard,
                                    Pensacola</hi></placeName>, <date calendar="gregorian" when="1849-08-17"><hi rend="italic">August</hi> 17,
                                1849</date>.</dateline>
                            <p><hi rend="smallcaps">Sir</hi>: You will prepare the United States
                                sloop-of-war Albany, under your command, for sea with all possible
                                dispatch.</p>
                            <p>I am, very respectfully, your obedient servant,</p>
                            <closer>
                                <signed>
                                    <list>
                                        <item>JOHN THOMAS NEWTON,<lb/><hi rend="italic">Commandant.</hi></item>
                                        <item>Commodore <hi rend="smallcaps">V. M.
                                                Randolph</hi>,<lb/><hi rend="italic">Commanding
                                                United States Ship Albany,<lb/>Off Navy-Yard,
                                                Pensacola.</hi></item>
                                    </list>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>