            <div frus:doc-dateTime-max="1869-09-01T23:59:59-05:00" frus:doc-dateTime-min="1869-09-01T00:00:00-05:00" n="431" subtype="historical-document" type="document" xml:id="d431">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Field</persName>, Acting
                                    Attorney-General, to Mr. <persName type="to">Milledge</persName>, district attorney.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Washington</hi>
                    </placeName>,
                                    <date calendar="gregorian" when="1869-09-01">
                        <hi rend="italic">September</hi> 1, 1869</date>.</dateline>
                <p rend="flushleft">
                    <hi rend="smallcaps">John Milledge</hi>,
                                    Esq.,<lb/>
                    <hi rend="italic">United States Attorney, Savannah,
                                    Georgia:</hi>
                </p>
                <p>If any illegal hostile expedition attempts to leave Savannah for Cuba
                                or elsewhere, stop it and indict the parties.</p>
                <closer>
                    <signed>W. A. FIELD,<lb/>
                        <hi rend="italic">Acting
                                        Attorney-General.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
