                subtype="historical-document" type="document" xml:id="d464">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Valentine</persName>, assistant
                        district attorney, to Mr. <persName type="to">Field</persName>, Acting
                        Attorney-General.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Philadelphia</hi>
                    </placeName>, <date calendar="gregorian" when="1869-08-16">
                        <hi rend="italic">August</hi> 16, 1869</date>.</dateline>
                <p rend="flushleft">Hon. <hi rend="smallcaps">W. A. Field</hi>, <hi rend="italic"
                        >Acting Attorney-General:</hi>
                </p>
                <p>The Hornet sailed Sunday morning, and was detained.</p>
                <p>An examination will be made to-day, and the facts reported.</p>
                <closer>
                    <signed>JOHN K. VALENTINE,<lb/>
                        <hi rend="italic">Assistant United States Attorney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
