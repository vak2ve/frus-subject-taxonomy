                subtype="historical-document" type="document" xml:id="d280">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Soar</persName>, Attorney-General,
                        to Mr. <persName type="to">Smith</persName>, district attorney</hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1869-05-18">
                        <hi rend="italic">May</hi> 18, 1869</date>.</dateline>
                <p rend="flushleft">
                    <hi rend="smallcaps">Aubrey H. Smith</hi>, Esq., <hi rend="italic">United States
                        Attorney, Philadelphia:</hi>
                </p>
                <p>Look out for the Florida. On proof of probable cause, libel and arrest her.</p>
                <closer>
                    <signed>E. R. HOAR.<lb/>
                        <hi rend="italic">Attorney-General.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
