<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1869-05-21T23:59:59-05:00" frus:doc-dateTime-min="1869-05-21T00:00:00-05:00" n="373" subtype="historical-document" type="document" xml:id="d373">
                            <head><seg type="margin">[61]</seg> *<hi rend="italic">Mr. <persName type="from">Fish</persName>, Secretary of State, to Mr.
                                        <persName type="to">Boutwell</persName>, Secretary of
                                    Treasury</hi>.</head>
                            <dateline><placeName><hi rend="smallcaps">Department of
                                        State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1869-05-21"><hi rend="italic">May</hi> 21,
                                1869</date>.</dateline>
                            <p><hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                                receipt of your letter of the 18th instant, with its accompaniment,
                                in relation to the refusal of a clearance to the steamer Columbia
                                [Quaker City,] and to inform you that I have transmitted a copy of
                                the same to Mr. Roberts, the Spanish minister, for his
                                information.</p>
                            <p>I have the honor to be, &amp;c.,</p>
                            <closer>
                                <signed>HAMILTON FISH.</signed>
                            </closer>
                            <postscript>
                                <p>Hon. <hi rend="smallcaps">George S. Boutwell</hi>,<lb/><hi rend="italic">Secretary of the Treasury.</hi></p>
                            </postscript>
                        </div>
                        </body></text></TEI>