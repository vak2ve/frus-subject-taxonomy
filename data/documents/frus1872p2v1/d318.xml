    <text>
        <body>
            <div frus:doc-dateTime-max="1865-03-31T23:59:59-05:00" frus:doc-dateTime-min="1865-03-31T00:00:00-05:00" n="318" subtype="historical-document" type="document" xml:id="d318">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Seward</persName>,
                                    Secretary of State, to Mr. <persName type="to">Dickinson</persName>, district attorney.</hi>
                </head>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Department of
                                        State</hi>,<lb/>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1865-03-31">
                        <hi rend="italic">March</hi> 31,
                                1865</date>.</dateline>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Pursuant to the request contained in
                                your letter of yesterday’s date, I herewith transmit a certified
                                copy of an official paper on file in this Department relative to the
                                existence of a state of war between Spain and Chili.</p>
                <p>I am, sir, yours, &amp;c.,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">D. S. Dickinson</hi>, Esq.,<lb/>
                        <hi rend="italic">United States District Attorney, New
                                        York.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
