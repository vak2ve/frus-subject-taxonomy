            <div frus:doc-dateTime-max="1869-08-31T23:59:59-05:00" frus:doc-dateTime-min="1869-08-31T00:00:00-05:00" n="430" subtype="historical-document" type="document" xml:id="d430">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Morrill</persName>,
                                    United States commissioner, to Mr. <persName type="to">Hoar</persName>, Attorney-General.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Macon,
                                    Georgia</hi>
                    </placeName>, <date calendar="gregorian" when="1869-08-31">
                        <hi rend="italic">August</hi> 31,
                                1869</date>.</dateline>
                <p rend="flushleft">Attorney-General <hi rend="smallcaps">Hoar</hi>:</p>
                <p>Eighty-three persons enlisted for Cuban army will try to leave for
                                Florida to-night. Have telegraphed to marshal at Savannah, and
                                district attorney.</p>
                <closer>
                    <signed>W. C. MORRILL.</signed>
                </closer>
            </div>
        </body>
    </text>
