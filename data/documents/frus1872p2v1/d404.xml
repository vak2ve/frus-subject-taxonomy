<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1869-07-02T23:59:59-05:00" frus:doc-dateTime-min="1869-07-02T00:00:00-05:00" n="404" subtype="historical-document" type="document" xml:id="d404">
                            <head><seg type="margin">[86]</seg> *<hi rend="italic">Mr. <persName type="from">Field</persName>, Assistant Attorney-General, to
                                    Mr. <persName type="to">Willey</persName>, district
                                    attorney.</hi></head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <dateline><placeName><hi rend="smallcaps">Washington</hi></placeName>,
                                    <date calendar="gregorian" when="1869-07-02"><hi rend="italic">July</hi> 2, 1869</date>.</dateline>
                            <p rend="flushleft"><hi rend="smallcaps">Hiram Willey</hi>,<lb/><hi rend="italic">United States Attorney, New London,
                                    Connecticut:</hi></p>
                            <p>Libel vessels and cargo, if you think they are forfeitable; otherwise
                                detain them, and report facts to this office.</p>
                            <closer>
                                <signed>W. A. FIELD,<lb/><hi rend="italic">Assistant
                                        Attorney-General.</hi></signed>
                            </closer>
                        </div>
                        </body></text></TEI>