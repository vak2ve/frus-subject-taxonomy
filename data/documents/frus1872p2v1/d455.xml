                subtype="historical-document" type="document" xml:id="d455">
                <head>
                    <seg type="margin">[125]</seg> *<hi rend="italic">Mr. <persName type="from"
                            >Robeson</persName>, Secretary of the Navy, to Mr. <persName type="to"
                            >Fish</persName>, Secretary of State.</hi>
                </head>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Navy Department</hi>,<lb/>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1869-11-13">
                        <hi rend="italic">November</hi> 13, 1869</date>.</dateline>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your communication of the 11th instant, inclosing a transcript of a
                    communication from the United States marshal for the southern district of New
                    York.</p>
                <p>Copies of said communication have been transmitted to Rear-Admiral Stringham,
                    port-admiral at New York, and he has been directed to render the marshal every
                    assistance in his power in preventing the departure from New York, or that
                    vicinity, of any unlawful expeditions in aid of the Cuban insurgents.</p>
                <p>Very respectfully,</p>
                <closer>
                    <signed>GEO. M. ROBESON,<lb/>
                        <hi rend="italic">Secretary of the Navy.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">Hamilton Fish</hi>,<lb/>
                        <hi rend="italic">Secretary of State.</hi>
                    </p>
                </postscript>
            </div>
        </body>
