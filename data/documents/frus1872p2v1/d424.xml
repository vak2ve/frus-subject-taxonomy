    <text>
        <body>
            <div frus:doc-dateTime-max="1869-07-16T23:59:59-05:00" frus:doc-dateTime-min="1869-07-16T00:00:00-05:00" n="424" subtype="historical-document" type="document" xml:id="d424">
                <head>
                    <seg type="margin">[105]</seg> *<hi rend="italic">Mr. <persName type="from">Fish</persName>, Secretary of State, to Mr.
                                        <persName type="to">Hoar</persName>,
                                Attorney-General</hi>.</head>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Department of
                                        State</hi>,<lb/>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1869-07-16">
                        <hi rend="italic">July</hi> 16,
                                1869</date>.</dateline>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Inclosed I send you a copy of a
                                telegram just received from the marshal of New York, and will thank
                                you either to instruct him on the subject, or to advise me what
                                answer I shall give.</p>
                <p>I have the honor to be, &amp;c.,</p>
                <closer>
                    <signed>HAMILTON FISH.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">E. R. Hoar</hi>,<lb/>
                        <hi rend="italic">Attorney-General.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
