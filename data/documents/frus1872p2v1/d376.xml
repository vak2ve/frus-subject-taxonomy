                subtype="historical-document" type="document" xml:id="d376">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hoar</persName>, Attorney-General,
                        to Mr. <persName type="to">Pierrepont</persName>, district attorney.</hi>
                </head>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1869-06-17">
                        <hi rend="italic">June</hi> 17, 1869</date>.</dateline>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Spanish minister writes to the State
                    Department that an armed expedition for Cuba is fitting out in New York, to sail
                    in a day or two. You will please to use all efforts to prevent it, and instruct
                    the marshal to do the same.</p>
                <p>Respectfully, yours, &amp;c.,</p>
                <closer>
                    <signed>E. R. HOAR,<lb/>
                        <hi rend="italic">Attorney-General.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">E. Pierrepont</hi>,<lb/>
                        <hi rend="italic">United States Attorney, New York.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
