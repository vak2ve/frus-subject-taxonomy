    <text>
        <body>
            <div frus:doc-dateTime-max="1869-09-04T23:59:59-05:00"
                frus:doc-dateTime-min="1869-09-04T00:00:00-05:00" n="440"
                subtype="historical-document" type="document" xml:id="d440">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Richardson</persName>, Acting
                        Secretary of the Treasury, to Mr. <persName type="to">Casey</persName>,
                        collector.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Treasury Department</hi>,<lb/>
                        <seg type="margin">[114]</seg> *<hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1869-09-04">
                        <hi rend="italic">September</hi> 4, 1869</date>.</dateline>
                <p rend="flushleft">
                    <hi rend="smallcaps">James F. Casey</hi>,<lb/>
                    <hi rend="italic">Collector of Customs, New Orleans, Louisiana:</hi>
                </p>
                <p>Whenever called upon by the proper authority, you are permitted to place
                    Wilderness at command to prevent filibustering expedition to Cuba.</p>
                <closer>
                    <signed>WM. A. RICHARDSON,<lb/>
                        <hi rend="italic">Acting Secretary of the Treasury.</hi>
                    </signed>
                </closer>
            </div>
        </body>
