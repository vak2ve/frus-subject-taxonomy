<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1869-05-07T23:59:59-05:00" frus:doc-dateTime-min="1869-05-07T00:00:00-05:00" n="352" subtype="historical-document" type="document" xml:id="d352">
                            <head>
                                <hi rend="italic">Mr. <persName type="from">Barlow</persName>,
                                    United States marshal, to Mr. <persName type="to">Fishy</persName> Secretary of State.</hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <dateline><placeName><hi rend="smallcaps">New York</hi></placeName>,
                                    <date calendar="gregorian" when="1869-05-07"><hi rend="italic">May</hi> 7, 1869</date>.</dateline>
                            <p rend="flushleft">Hon. <hi rend="smallcaps">Hamilton Fish</hi>, <hi rend="italic">Secretary of State:</hi></p>
                            <p>Telegram just received. I will at once inquire.</p>
                            <closer>
                                <signed>FRANCIS C. BARLOW,<lb/><hi rend="italic">United States
                                        Marshal.</hi></signed>
                            </closer>
                        </div>
                        </body></text></TEI>