<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1869-10-07T23:59:59-05:00" frus:doc-dateTime-min="1869-10-07T00:00:00-05:00" n="491" subtype="historical-document" type="document" xml:id="d491">
                            <head>
                                <hi rend="italic">Mr. <persName type="from">Boutwell</persName>,
                                    Secretary of the Treasury, to Mr. <persName type="to">Robb</persName>, collector.</hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <dateline><placeName><hi rend="smallcaps">Treasury
                                        Department</hi>,<lb/><hi rend="italic">Washington, D.
                                        C.</hi></placeName>, <date calendar="gregorian" when="1869-10-07"><hi rend="italic">October</hi> 7,
                                1869</date>.</dateline>
                            <p rend="flushleft"><hi rend="smallcaps">Thomas P. Robb</hi>, <hi rend="italic">Collector of Customs, Savannah, Georgia:</hi></p>
                            <p>Send McCulloch to Wilmington, North Carolina, immediately. Let
                                Captain Merry man go.</p>
                            <p>Report to Collector Rumley. Nansemond left yesterday.</p>
                            <closer>
                                <signed>GEO. S. BOUT WELL,<lb/><hi rend="italic">Secretary of
                                        Treasury.</hi></signed>
                            </closer>
                        </div>
                        </body></text></TEI>