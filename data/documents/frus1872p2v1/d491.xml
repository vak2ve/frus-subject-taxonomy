                subtype="historical-document" type="document" xml:id="d491">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Boutwell</persName>, Secretary of
                        the Treasury, to Mr. <persName type="to">Robb</persName>, collector.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Treasury Department</hi>,<lb/>
                        <hi rend="italic">Washington, D. C.</hi>
                    </placeName>, <date calendar="gregorian" when="1869-10-07">
                        <hi rend="italic">October</hi> 7, 1869</date>.</dateline>
                <p rend="flushleft">
                    <hi rend="smallcaps">Thomas P. Robb</hi>, <hi rend="italic">Collector of
                        Customs, Savannah, Georgia:</hi>
                </p>
                <p>Send McCulloch to Wilmington, North Carolina, immediately. Let Captain Merry man
                    go.</p>
                <p>Report to Collector Rumley. Nansemond left yesterday.</p>
                <closer>
                    <signed>GEO. S. BOUT WELL,<lb/>
                        <hi rend="italic">Secretary of Treasury.</hi>
                    </signed>
                </closer>
            </div>
        </body>
