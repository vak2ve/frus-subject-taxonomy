    <text>
        <body>
            <div frus:doc-dateTime-max="1869-07-02T23:59:59-05:00"
                frus:doc-dateTime-min="1869-07-02T00:00:00-05:00" n="403"
                subtype="historical-document" type="document" xml:id="d403">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Carll</persName>, United States
                        marshal, to Mr. <persName type="to">Field</persName>, Assistant
                        Attorney-General</hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">New Haven, Connecticut</hi>
                    </placeName>, <date calendar="gregorian" when="1869-07-02">
                        <hi rend="italic">July</hi> 2, 1869</date>.</dateline>
                <p rend="flushleft">Hon. <hi rend="smallcaps">W. A. Field</hi>,<lb/>
                    <hi rend="italic">Assistant United States Attorney-General:</hi>
                </p>
                <p>The schooners Fancy and Winona both at the dock in New Haven, with a portion of
                    cargo; balance of cargo in Milford; all in my custody, awaiting further
                    orders.</p>
                <closer>
                    <signed>P. R. CARLL,<lb/>
                        <hi rend="italic">United States Marshal.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
