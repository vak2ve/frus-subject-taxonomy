<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1869-06-28T23:59:59-05:00" frus:doc-dateTime-min="1869-06-28T00:00:00-05:00" n="389" subtype="historical-document" type="document" xml:id="d389">
                            <head><seg type="margin">[71]</seg> *<hi rend="italic">Mr. <persName type="from">Barlow</persName>, United States marshal, to Mr.
                                        <persName type="to">Hoar</persName>,
                                Attorney-General.</hi></head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <dateline><placeName><hi rend="smallcaps">New York</hi></placeName>,
                                    <date calendar="gregorian" when="1869-06-28"><hi rend="italic">June</hi> 28, 1869</date>.</dateline>
                            <p rend="flushleft"><hi rend="smallcaps">Attorney-General</hi>, <hi rend="italic">Washington:</hi></p>
                            <p>I have arrested General Goicuria, said to be the leader of the
                                expedition on board the Whiting, under an assumed name, and the
                                vessel has been libeled.</p>
                            <closer>
                                <signed>FRANCIS C. BARLOW, <lb/>
                                    <hi rend="italic">United States-Marshal.</hi></signed>
                            </closer>
                        </div>
                        </body></text></TEI>