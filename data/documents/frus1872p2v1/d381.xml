        <body>
            <div frus:doc-dateTime-max="1869-06-19T23:59:59-05:00" frus:doc-dateTime-min="1869-06-19T00:00:00-05:00" n="381" subtype="historical-document" type="document" xml:id="d381">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hoar</persName>,
                                    Attorney-General, to Mr. <persName type="to">Barlow</persName>,
                                    United States marshal.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Washington</hi>
                    </placeName>,
                                    <date calendar="gregorian" when="1869-06-19">
                        <hi rend="italic">June</hi> 19, 1869</date>.</dateline>
                <p rend="flushleft">
                    <hi rend="smallcaps">Francis C. Barlow</hi>, <hi rend="italic">United States Marshal, New York City:</hi>
                </p>
                <p>Military expedition, to sail within two days, reported as organizing
                                at 71 Broadway, room 36 at 636 Broadway, at 12 East Houston street,
                                and in New York Casino, same street. Look out for them.</p>
                <closer>
                    <signed>E. R. HOAR,<lb/>
                        <hi rend="italic">Attorney-General.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
