            <div frus:doc-dateTime-max="1869-10-04T23:59:59-05:00" frus:doc-dateTime-min="1869-10-04T00:00:00-05:00" n="483" subtype="historical-document" type="document" xml:id="d483">
                <head>
                    <hi rend="italic">General <persName type="from">Sherman</persName>,
                                    Acting Secretary of War, to Mr. <persName type="to">Rumley</persName>, collector.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Washington</hi>
                    </placeName>,
                                    <date calendar="gregorian" when="1869-10-04">
                        <hi rend="italic">October</hi> 4, 1869</date>.</dateline>
                <p rend="flushleft">
                    <hi rend="smallcaps">D. Rumley</hi>, <hi rend="italic">Collector, Wilmington, North Carolina:</hi>
                </p>
                <p>Notify commanding officer at Fort Johnson that he is ordered, by
                                telegraph, to detain the Hornet till she receives from you a regular
                                clearance.</p>
                <closer>
                    <signed>W. T. SHERMAN,<lb/>
                        <hi rend="italic">General, and Acting
                                        Secretary of War.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
