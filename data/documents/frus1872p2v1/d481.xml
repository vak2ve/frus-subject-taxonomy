    <text>
        <body>
            <div frus:doc-dateTime-max="1869-10-04T23:59:59-05:00" frus:doc-dateTime-min="1869-10-04T00:00:00-05:00" n="481" subtype="historical-document" type="document" xml:id="d481">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Boutwell</persName>,
                                    Secretary of the Treasury, to General <persName type="to">Sherman</persName>, Acting Secretary of War.</hi>
                </head>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Treasury
                                        Department</hi>,<lb/>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1869-10-04">
                        <hi rend="italic">October</hi> 4,
                                1869</date>.</dateline>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I get information from the collector
                                of customs at Wilmington, North Carolina, that there is danger that
                                the Hornet may go to sea in defiance of our authority.</p>
                <p>I have directed the collector to take precautions to prevent this,
                                and I have the honor to request you to issue further orders, if you
                                deem it necessary, to the military officers, to assist in preventing
                                her escape.</p>
                <p>
                    <seg type="margin">[167]</seg> *Very respectfully,</p>
                <closer>
                    <signed>
                        <list>
                            <item>GEO. S. BOUTWELL,<lb/>
                                <hi rend="italic">Secretary.</hi>
                            </item>
                            <item>General <hi rend="smallcaps">W. T.
                                                Sherman</hi>,<lb/>
                                <hi rend="italic">Acting Secretary
                                                of War.</hi>
                            </item>
                        </list>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
