    <text>
        <body>
            <div frus:doc-dateTime-max="1869-12-10T23:59:59-05:00" frus:doc-dateTime-min="1869-12-10T00:00:00-05:00" n="313" subtype="historical-document" type="document" xml:id="d313">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Pierrepont</persName>,
                                    district attorney, to Mr. <persName type="to">Fish</persName>,
                                    Secretary of State.</hi>
                </head>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Office of the Attorney of the
                                        United States for the Southern District of New
                                    York</hi>,<lb/>41 <hi rend="italic">Chambers
                                    street</hi>
                    </placeName>, <date calendar="gregorian" when="1869-12-10">
                        <hi rend="italic">December</hi> 10,
                                    1869</date>.</dateline>
                <p>
                    <hi rend="smallcaps">Sir</hi>: By order of the court, this day made,
                                the Spanish Cuban gunboats are released. I have directed the marshal
                                to keep them no longer in custody; he will surrender them
                                forthwith.</p>
                <p>Yours, very respectfully,</p>
                <closer>
                    <signed>EDWARDS PIERREPONT,<lb/>
                        <hi rend="italic">United States
                                        Attorney.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">Hamilton Fish</hi>,<lb/>
                        <hi rend="italic">Secretary of State, Washington, D. C.</hi>
                    </p>
                </postscript>
            </div>
        </body>
