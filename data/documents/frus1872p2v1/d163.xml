<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1856-01-09T23:59:59-05:00" frus:doc-dateTime-min="1856-01-09T00:00:00-05:00" n="163" subtype="historical-document" type="document" xml:id="d163">
                            <head>
                                <hi rend="italic">Mr. <persName type="from">Pierce</persName>,
                                    President, to Captain <persName type="to">Bigelow</persName>,
                                    United States navy-yard.</hi>
                            </head>
                            <dateline><placeName><hi rend="smallcaps">Executive
                                    Mansion</hi></placeName>, <date calendar="gregorian" when="1856-01-09"><hi rend="italic">January</hi> 9,
                                1856</date>.</dateline>
                            <p rend="flushleft">Captain <hi rend="smallcaps">Abram Bigelow</hi>,</p>
                            <p rend="center">
                                <hi rend="italic">United States Navy-Yard, Brooklyn, New York:</hi>
                            </p>
                            <p>Arrest and detain any vessel in the port of New York charged with
                                violation of neutrality laws, upon advice of the district attorney,
                                Hon. John McKeon.</p>
                            <closer>
                                <signed>FRANKLIN PIERCE.</signed>
                            </closer>
                            <postscript>
                                <p>The original received, of which the above is a copy.</p>
                            </postscript>
                        </div>
                        </body></text></TEI>