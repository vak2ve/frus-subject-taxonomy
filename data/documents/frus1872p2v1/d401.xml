                subtype="historical-document" type="document" xml:id="d401">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Field</persName>, Assistant
                        Attorney-General to Mr. <persName type="to">Barlow</persName>, United States
                        marshal.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1869-07-01">
                        <hi rend="italic">July</hi> 1, 1869</date>.</dateline>
                <p rend="flushleft">
                    <hi rend="smallcaps">F. C. Barlow</hi>,<lb/>
                    <hi rend="italic">United States Marshal, New York City:</hi>
                </p>
                <p>Have sent telegrams to marshal and district attorney of Connecticut, to take care
                    of the Fancy and Winona.</p>
                <closer>
                    <signed>W. A. FIELD.</signed>
                </closer>
            </div>
        </body>
    </text>
