                subtype="historical-document" type="document" xml:id="d498">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Starbuck</persName>, district
                        attorney, to Mr. <persName type="to">Soar</persName>, Attorney-General.</hi>
                </head>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Office of United States Attorney</hi>,<lb/>
                        <hi rend="italic">Salem, North Carolina</hi>
                    </placeName>, <date calendar="gregorian" when="1869-10-11">
                        <hi rend="italic">October</hi> 11, 1869</date>.</dateline>
                <p>
                    <seg type="margin">[179]</seg>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your letter concerning the steamer Hornet, detained in the port of Wilmington,
                    *and the case will soon undergo an investigation before the United States
                    commissioner, which I trust will develop the true character of the vessel; then
                    such proceedings will be instituted as the facts may warrant.</p>
                <p>I am, sir, very respectfully,</p>
                <closer>
                    <signed>D. H. STARBUCK,<lb/>
                        <hi rend="italic">United States Attorney.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">E. R. Hoar</hi>,<lb/>
                        <hi rend="italic">Attorney-General.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
