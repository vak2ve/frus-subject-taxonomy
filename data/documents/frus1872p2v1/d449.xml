                subtype="historical-document" type="document" xml:id="d449">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Harlow</persName>, United States
                        marshal, to Mr. <persName type="to">Fish</persName>, Secretary of
                        State.</hi>
                </head>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">United States Marshal’s Office, Southern District of
                            New York</hi>,<lb/>
                        <hi rend="italic">New York</hi>
                    </placeName>, <date calendar="gregorian" when="1869-11-08">
                        <hi rend="italic">November</hi> 8, 1869</date>.</dateline>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that I am
                    employing, the same as my predecessor, General Barlow, one superintendent and
                    two or three detectives, (as circumstances require,) to learn of any
                    infringements of the neutrality law.</p>
                <p>Very respectfully,</p>
                <closer>
                    <signed>S. R. HARLOW,<lb/>
                        <hi rend="italic">United States Marshal.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">Hamilton Fish</hi>,<lb/>
                        <hi rend="italic">Secretary of State.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
