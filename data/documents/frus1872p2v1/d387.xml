<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1869-06-26T23:59:59-05:00" frus:doc-dateTime-min="1869-06-26T00:00:00-05:00" n="387" subtype="historical-document" type="document" xml:id="d387">
                            <head>
                                <hi rend="italic">Mr. <persName type="from">Fish</persName>,
                                    Secretary of State, to Mr. <persName type="to">Pierrepont</persName>, district attorney.</hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <dateline><placeName><hi rend="smallcaps">Department of
                                        State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1869-06-26"><hi rend="italic">June</hi> 26,
                                1869</date>.</dateline>
                            <p rend="flushleft">Hon. <hi rend="smallcaps">Edwards Pierrepont</hi>,
                                    <hi rend="italic">District Attorney, New York:</hi></p>
                            <p><seg type="margin">[70]</seg> The marshal and his officers will be
                                sustained *in their duties at all hazards. Instructions by mail this
                                afternoon. Get the letter.</p>
                            <closer>
                                <signed>HAMILTON FISH.</signed>
                            </closer>
                        </div>
                        </body></text></TEI>