<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1869-05-08T23:59:59-05:00" frus:doc-dateTime-min="1869-05-08T00:00:00-05:00" n="356" subtype="historical-document" type="document" xml:id="d356">
                            <head>
                                <hi rend="italic">Mr. <persName type="from">Fish</persName>,
                                    Secretary of State, to Mr. <persName type="to">Barlow</persName>, United States marshal, New York.</hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <dateline><placeName><hi rend="smallcaps">Department of
                                        State,.</hi><lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1869-05-08"><hi rend="italic">May</hi> 8,
                                1869</date>.</dateline>
                            <p rend="flushleft">General <hi rend="smallcaps">Frances C. Barlow</hi>,
                                    <hi rend="italic">United States Marshal, New York:</hi></p>
                            <p>Dispatch received. Spanish minister been requested to communicate
                                with you. Confer with him or Spanish consul. Watch the ship, and
                                seize whenever sufficient proof.</p>
                            <closer>
                                <signed>HAMILTON FISH.</signed>
                            </closer>
                        </div>
                        </body></text></TEI>