<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1869-05-21T23:59:59-05:00" frus:doc-dateTime-min="1869-05-21T00:00:00-05:00" n="374" subtype="historical-document" type="document" xml:id="d374">
                            <head>
                                <hi rend="italic">Mr. <persName type="from">Boutwell</persName>,
                                    Secretary of the Treasury, to Mr. <persName type="to">Grinnell</persName>, collector.</hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <dateline><placeName><hi rend="smallcaps">Washington</hi></placeName>,
                                    <date calendar="gregorian" when="1869-05-21"><hi rend="italic">May</hi> 21, 1869</date>.</dateline>
                            <p rend="flushleft"><hi rend="smallcaps">Moses H. Grinnell</hi>, <hi rend="italic">Collector of Customs, New York:</hi></p>
                            <p>If the Columbia has not cleared, withhold papers till further
                                orders.</p>
                            <closer>
                                <signed>GEORGE S. BOUTWELL.<lb/><hi rend="italic">Secretary of the
                                        Treasury.</hi></signed>
                            </closer>
                        </div>
                        </body></text></TEI>