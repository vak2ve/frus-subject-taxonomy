<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1869-10-08T23:59:59-05:00" frus:doc-dateTime-min="1869-10-08T00:00:00-05:00" n="495" subtype="historical-document" type="document" xml:id="d495">
                            <head><seg type="margin">[176]</seg> *<hi rend="italic">Vice-Admiral
                                        <persName type="from">Porter</persName> to the <gloss type="to">President</gloss></hi></head>
                            <dateline><placeName><hi rend="smallcaps">Navy Department</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1869-10-08"><hi rend="italic">October</hi> 8, 1869</date>.</dateline>
                            <p><hi rend="smallcaps">Sir</hi>: I have the honor to send herewith a
                                copy of a telegram received this a.m. from Rear-Admiral Godon,
                                commandant of navy-yard, New York, dated 7th instant, and copies of
                                two telegrams from Commander Queen, senior officer at Key West.</p>
                            <p>Very respectfully, your obedient servant,</p>
                            <closer>
                                <signed>DAVID D. PORTER,<lb/><hi rend="italic">Vice-Admiral.</hi></signed>
                            </closer>
                            <postscript>
                                <p>The <hi rend="smallcaps">President.</hi></p>
                            </postscript>
                            <pb facs="0862" n="848" xml:id="pg_848"/>
                            <frus:attachment>
                                <opener>
                                    <seg rendition="#center">[Inclosure No. 1.]</seg>
                                </opener>
                                <head>
                                    <hi rend="italic">Rear-Admiral <persName type="from">Godon</persName> to Vice-Admiral <persName type="to">Porter</persName>, Acting Secretary of Navy</hi>
                                </head>
                                <opener>
                                    <seg rendition="#center">[Telegram.]</seg>
                                </opener>
                                <dateline><placeName><hi rend="smallcaps">Brooklyn, New
                                        York</hi></placeName>, <date calendar="gregorian" when="1869-10-07"><hi rend="italic">October</hi> 7,
                                        1869</date>.</dateline>
                                <p rend="flushleft">To <hi rend="smallcaps">Secretary of the
                                        Navy</hi>:</p>
                                <p>Telegram received. The Frolic will sail by 8 o’clock.</p>
                                <closer>
                                    <signed>S. W. GODON,<lb/><hi rend="italic">Rear
                                        Admiral.</hi></signed>
                                </closer>
                            </frus:attachment>
                            <frus:attachment>
                                <opener>
                                    <seg rendition="#center">[Inclosure No. 2.]</seg>
                                </opener>
                                <head><hi rend="italic">Commander <persName type="from">Queen</persName> to Mr. <persName type="to">Robeson</persName>, Secretary of the Navy</hi>.</head>
                                <opener>
                                    <seg rendition="#center">[Telegram.]</seg>
                                </opener>
                                <dateline><placeName><hi rend="smallcaps">United States Steamer
                                            Tuscarora</hi>,<lb/><hi rend="italic">Key West,
                                            Florida</hi></placeName>, <date calendar="gregorian" when="1869-10-07"><hi rend="italic">October</hi> 7,
                                        1869</date>.</dateline>
                                <p rend="flushleft"><seg type="margin">[177]</seg> *<hi rend="smallcaps">Hon. Geo. M. Robeson</hi>:</p>
                                <p>Telegram received. No vessel to send. Tuscarora and Saugus only
                                    vessels here. Tuscarora cannot move before Monday on account of
                                    bursting of main steam-pipe.</p>
                                <closer>
                                    <signed>W. W. QUEEN,<lb/><hi rend="italic">Commander and Senior
                                            Officer.</hi></signed>
                                </closer>
                            </frus:attachment>
                        </div>
                        </body></text></TEI>