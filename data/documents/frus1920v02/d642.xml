                subtype="historical-document" type="document" xml:id="d642">
                <note rend="inline" type="source">814.00/388: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Guatemala</hi> (<persName type="from">
                        <hi rend="italic">McMillin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guatemala</hi>
                        </placeName>, [<date calendar="gregorian" when="1920-04-08">
                            <hi rend="italic">April 8, 1920?</hi>
                        </date>].<lb/>[Received April 9—12:30 a.m.]</dateline>
                </opener>
                <p>64. Department’s 21 [<hi rend="italic">29</hi>], April 1, 5 p.m. The two
                    designados of Guatemala are, first, General Mariano Serrano Muñoz and, second,
                    General Duarte.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">McMillin</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
