                subtype="historical-document" type="document" xml:id="d115">
                <note rend="inline" type="source">839.918/1: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in the Dominican Republic</hi> (<persName type="to">
                        <hi rend="italic">Russell</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-12-23T13:00:00-05:00">
                            <hi rend="italic">December 23, 1919—1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Information has reached the Department that regulations as to censorship have
                    been modified. Inform Department extent of changes and when made.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
