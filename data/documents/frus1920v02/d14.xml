<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-05-27T15:29:00-05:00" frus:doc-dateTime-min="1920-05-27T15:29:00-05:00" n="14" subtype="historical-document" type="document" xml:id="d14">
                            <note rend="inline" type="source">837.00/1673: Telegram</note>
                            <head><hi rend="italic">The Chargé in Cuba</hi> (<persName type="from"><hi rend="italic">White</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Habana</hi></placeName>, <date calendar="gregorian" when="1920-05-27T15:00:00-05:29"><hi rend="italic">May 27,
                                            1920—3 p.m.</hi></date><lb/>[Received 6:30
                                    p.m.]</dateline></opener>
                            <p>119. General Electoral Board yesterday recognized Partido Popular
                                Cubano of Doctor Alfredo Zayas as a national party.</p>
                            <closer><signed><hi rend="smallcaps">White</hi></signed></closer>
                        </div>
