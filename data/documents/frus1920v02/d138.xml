<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-11-05T17:14:00-05:00" frus:doc-dateTime-min="1919-11-05T17:14:00-05:00" n="138" subtype="historical-document" type="document" xml:id="d138">
                            <note rend="inline" type="source">722.65/3: Telegram</note>
                            <head><hi rend="italic">The Minister in Ecuador</hi> (<persName type="from"><hi rend="italic">Hartman</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Quito</hi></placeName>, <date calendar="gregorian" when="1919-11-05T17:00:00-05:14"><hi rend="italic">November
                                            5, 1919—5 p.m.</hi></date><lb/>[Received November 6—8:20
                                    p.m.]</dateline></opener>
                            <p>My October 2 noon. Bill based on amended memorandum authorizing
                                President to make contract <hi rend="italic">ad referendum</hi> for
                                loan of 40,000,000 sucres and including other provisions reported in
                                my said telegram of October 2 noon, passed by Congress.</p>
                            <closer><signed><hi rend="smallcaps">Hartman</hi></signed></closer>
                        </div>
                        </body></text></TEI>