                subtype="historical-document" type="document" xml:id="d57">
                <note rend="inline" type="source">837.73/2a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Cuba</hi> (<persName type="to">
                        <hi rend="italic">White</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-06-03T13:00:00-04:00">
                            <hi rend="italic">June 3, 1920—1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>89. Thomas R. Strahan, of Root, Clark, Buckner and Howland, is at Hotel Sevilla
                    to further interests of All America Cables. Please lend him all proper
                    assistance.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
