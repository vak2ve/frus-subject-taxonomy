                <note rend="inline" type="source">763.72119/10074b: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Belgium</hi> (<persName type="to">
                        <hi rend="italic">Whitlock</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-06-26T15:00:00-04:00">
                            <hi rend="italic">June 26, 1920—3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>56. Please cable brief summary of all available information concerning results
                    reached at recent Hythe and Boulogne conferences. Send full report by pouch.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
