                subtype="historical-document" type="document" xml:id="d130">
                <note rend="inline" type="source">339.3921L96/33: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in the Dominican Republic</hi> (<persName
                        type="from">
                        <hi rend="italic">Russell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1920-10-23T17:00:00-04:40">
                            <hi rend="italic">October 23, 1920—5 p.m.</hi>
                        </date>
                        <lb/>[Received October 25—4:10 p.m.]</dateline>
                </opener>
                <p>49. Journalists Sanabia and Castillo placed at liberty under surveillance. There
                    are now no journalists imprisoned.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Russell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
