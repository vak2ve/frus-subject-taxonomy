                <note rend="inline" type="source">838.51/997: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Haiti</hi> (<persName type="to">
                        <hi rend="italic">Bailly-Blanchard</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-10-19T19:00:00-04:00">
                            <hi rend="italic">October 19, 1920—7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>95. Your 78, October 16, 10 a.m.</p>
                <p>Department approves and desires that plan be put in operation at once.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
