<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-12-15T13:00:00-05:00" frus:doc-dateTime-min="1920-12-15T13:00:00-05:00" n="378" subtype="historical-document" type="document" xml:id="d378">
                            <note rend="inline" type="source">462.00 R 29/412: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Ambassador in France</hi> (<persName type="to"><hi rend="italic">Wallace</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1920-12-15T13:00:00-05:00"><hi rend="italic">December
                                            15, 1920—1 p.m.</hi></date></dateline></opener>
                            <p>1700. Your 2006, December 13, 5 p.m.</p>
                            <p>See Department’s 1684, B–168 for Boyden.</p>
                            <p>You are requested to inform the French Foreign Office that this
                                Government does not deem it practicable to be represented at the
                                conference at Brussels on December 15.</p>
                            <closer><signed><hi rend="smallcaps">Davis</hi></signed></closer>
                        </div>
                    </body></text></TEI>