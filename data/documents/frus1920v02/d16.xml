<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-07-12T12:29:00-05:00" frus:doc-dateTime-min="1920-07-12T12:29:00-05:00" n="16" subtype="historical-document" type="document" xml:id="d16">
                            <note rend="inline" type="source">837.00/1695: Telegram</note>
                            <head><hi rend="italic">The Chargé in Cuba</hi> (<persName type="from"><hi rend="italic">White</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Habana</hi></placeName>, <date calendar="gregorian" when="1920-07-12T12:00:00-05:29"><hi rend="italic">July 12,
                                            1920—noon</hi></date>.<lb/>[Received 4:13
                                    p.m.]</dateline></opener>
                            <p>147. Liberal National Committee yesterday met and nominated José
                                Miguel Gomez for President. Meeting adjourned without naming
                                vice-presidential candidate.</p>
                            <closer><signed><hi rend="smallcaps">White</hi></signed></closer>
                        </div>
                        </body></text></TEI>