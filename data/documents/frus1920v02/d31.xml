<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-09-27T17:29:00-05:00" frus:doc-dateTime-min="1920-09-27T17:29:00-05:00" n="31" subtype="historical-document" type="document" xml:id="d31">
                            <note rend="inline" type="source">837.00/1772: Telegram</note>
                            <head><hi rend="italic">The Minister in Cuba</hi> (<persName type="from"><hi rend="italic">Long</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Habana</hi></placeName>, <date calendar="gregorian" when="1920-09-27T17:00:00-05:29"><hi rend="italic">September
                                            27, 1920—5 p.m.</hi></date><lb/>[Received 11:09
                                    p.m.]</dateline></opener>
                            <p>228. Supreme Court September 25 upheld Zayas against Montalvo as
                                legal candidate of the Conservative Party for President in the
                                elections. This decision clears the way for the National League.
                                Details by mail.<note n="36" xml:id="d31fn36">Not
                                printed.</note></p>
                            <closer><signed><hi rend="smallcaps">Long</hi></signed></closer>
                        </div>
                        </body></text></TEI>