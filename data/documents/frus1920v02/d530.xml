<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-02-02T18:00:00-05:00" frus:doc-dateTime-min="1920-02-02T18:00:00-05:00" n="530" subtype="historical-document" type="document" xml:id="d530">
                            <note rend="inline" type="source">341.115L89/10: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Consul General at London</hi>
                                    (<persName type="to"><hi rend="italic">Skinner</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1920-02-02T18:00:00-05:00"><hi rend="italic">February
                                            2, 1920—6 p.m.</hi></date></dateline></opener>
                            <p>Your January 17, 1 p.m.</p>
                            <p>Telegraph whether Procurator General has obtained instructions from
                                President Prize Court applicable to all similar claims.</p>
                            <closer><signed><hi rend="smallcaps">Lansing</hi></signed></closer>
                        </div>
                        </body></text></TEI>