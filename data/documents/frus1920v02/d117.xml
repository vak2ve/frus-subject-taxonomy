<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-12-27T18:00:00-05:00" frus:doc-dateTime-min="1919-12-27T18:00:00-05:00" n="117" subtype="historical-document" type="document" xml:id="d117">
                            <note rend="inline" type="source">839.918/2: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Minister in the Dominican Republic</hi>
                                    (<persName type="to"><hi rend="italic">Russell</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-12-27T18:00:00-05:00"><hi rend="italic">December
                                            27, 1919—6 p.m.</hi></date></dateline></opener>
                            <p>Your December 25, 5 p.m.</p>
                            <p>Please bring with you full text of regulations forbidding publication
                                of false statements against Military and United States Government
                                and articles attempting to disturb order and labor agitation.</p>
                            <closer><signed><hi rend="smallcaps">Polk</hi></signed></closer>
                        </div>
                        </body></text></TEI>