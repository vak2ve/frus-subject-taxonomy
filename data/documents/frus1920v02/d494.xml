<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-05-29T17:00:00-05:00" frus:doc-dateTime-min="1917-05-29T17:00:00-05:00" n="494" subtype="historical-document" type="document" xml:id="d494">
                            <note rend="inline" type="source">763.72112/3729a: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Consul General at London</hi>
                                    (<persName type="to"><hi rend="italic">Skinner</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-05-29T17:00:00-05:00"><hi rend="italic">May 29,
                                            1917—5 p.m.</hi></date></dateline></opener>
                            <p>Please compile and cable list of cases pending in Prize Court
                                involving American interests and add your opinion as to how they may
                                now be equitably disposed of in view of the fact that the United
                                States has entered the war.</p>
                            <closer><signed><hi rend="smallcaps">Lansing</hi></signed></closer>
                        </div>
                        </body></text></TEI>