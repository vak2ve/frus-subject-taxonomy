<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-03-22T09:14:00-05:00" frus:doc-dateTime-min="1920-03-22T09:14:00-05:00" n="158" subtype="historical-document" type="document" xml:id="d158">
                            <note rend="inline" type="source">422.11G93/1087: Telegram</note>
                            <head><hi rend="italic">The Minister in Ecuador</hi> (<persName type="from"><hi rend="italic">Hartman</hi></persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                                        State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Quito</hi></placeName>, <date calendar="gregorian" when="1920-03-22T09:00:00-05:14"><hi rend="italic">March 22,
                                            1920—9 a.m.</hi></date><lb/>[Received 2:55
                                    p.m.]</dateline></opener>
                            <p>18. Department’s March 19, 6 p.m. Daily deposits do not amount to one
                                three hundred sixty fifth of total annual amount due on railroad
                                bonds. See my telegram number 17 March 20th, 3 p.m., for amount
                                deposited and full report.<note n="20" xml:id="d158fn20">Not
                                    printed.</note></p>
                            <closer><signed><hi rend="smallcaps">Hartman</hi></signed></closer>
                        </div>
                        </body></text></TEI>