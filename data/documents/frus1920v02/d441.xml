    <text>
        <body>
            <div frus:doc-dateTime-max="1920-04-23T15:00:00-05:00"
                frus:doc-dateTime-min="1920-04-23T15:00:00-05:00" n="441"
                subtype="historical-document" type="document" xml:id="d441">
                <note rend="inline" type="source">862.85/1127: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Wallace</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1920-04-23T21:00:00+01:00">
                            <hi rend="italic">April 23, 1920—9 p.m.</hi>
                        </date>
                        <lb/>[Received April 23—4:38 p.m.]</dateline>
                </opener>
                <p>1046. B–39 for Department and Davis.</p>
                <p>1st. Information received that French Government has agreed to full acceptance of
                    Wilson–Lloyd George Agreement. This acceptance was embodied in recent
                    Anglo-French shipping agreement signed in London April 22. Boyden.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wallace</hi>
                    </signed>
                </closer>
            </div>
        </body>
