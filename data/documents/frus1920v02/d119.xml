<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-01-16T13:40:00-05:00" frus:doc-dateTime-min="1920-01-16T13:40:00-05:00" n="119" subtype="historical-document" type="document" xml:id="d119">
                            <note rend="inline" type="source">839.918/4: Telegram</note>
                            <head><hi rend="italic">The Chargé des Affaires in the Dominican
                                    Republic</hi> (<persName type="from"><hi rend="italic">Brewer</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Santo Domingo</hi></placeName>, <date calendar="gregorian" when="1920-01-16T14:00:00-04:40"><hi rend="italic">January 16, 1920—2
                                    p.m.</hi></date><lb/>[Received January 17—9:07
                                a.m.]</dateline></opener>
                            <p>3. Your telegram received today. Military Government issuing
                                Executive order abolishing censorship, and embodying provisions
                                suggested.</p>
                            <closer><signed><hi rend="smallcaps">Brewer</hi></signed></closer>
                        </div>
                        </body></text></TEI>