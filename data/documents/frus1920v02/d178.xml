                subtype="historical-document" type="document" xml:id="d178">
                <note rend="inline" type="source">833.05/159a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Egypt</hi> (<persName type="to">
                        <hi rend="italic">De Billier</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-05-07T17:00:00-04:00">
                            <hi rend="italic">May 7, 1920—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>25. Department understands Judge Tuck has resigned.</p>
                <p>This Government desires appoint Judge Crabitès to Court of Appeals. Take up
                    matter orally immediately with proper authority and report.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
