                <note rend="inline" type="source">811.918/248</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Italian Ambassador</hi> (<persName type="to">
                        <hi rend="italic">De Martino</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1931-07-02">July 2,
                            1931</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Ambassador</hi>: I am in receipt of your letter
                    of June 16, 1931, in regard to <hi rend="italic">Il Martello</hi>. As you are
                    aware under our regime of freedom for the press, it is extremely difficult to
                    initiate judicial proceedings in respect to published utterances of the nature
                    of those which you quote in your letter.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. R. Castle, Jr.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
