                subtype="historical-document" type="document" xml:id="d131">
                <note rend="inline" type="source">839.51/3525: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in the Dominican Republic</hi> (<persName
                        type="from">
                        <hi rend="italic">Schoenfeld</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1931-10-11T12:00:00-04:40"
                            >October 11, 1931—noon</date>.<lb/>[Received 10:11 p.m.]</dateline>
                </opener>
                <p>70. Legation’s telegram No. 67, October 7, 6 p.m. It is announced that the
                    Enabling Act was promulgated yesterday.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schoenfeld</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
