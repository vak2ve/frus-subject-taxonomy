<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1931-09-26T10:00:00-05:00" frus:doc-dateTime-min="1931-09-26T10:00:00-05:00" n="507" subtype="historical-document" type="document" xml:id="d507">
                        <note rend="inline" type="source">838.51/2331: Telegram</note>
                        <head><hi rend="italic">The Chargé in Haiti</hi> (<persName type="from"><hi rend="italic">McGurk</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Port-au-Prince</hi></placeName>, <date calendar="gregorian" when="1931-09-26T10:00:00-05:00">September 26, 1931—10
                                    a.m.</date><lb/>[Received 11:37 a.m.]</dateline></opener>
                        <p>114. For de la Rue from Pixley. Budget as enacted by the Legislature has
                            been submitted to our office.</p>
                        <closer><signed><hi rend="smallcaps">McGurk</hi></signed></closer>
                    </div>
                    </body></text></TEI>