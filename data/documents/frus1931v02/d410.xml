                subtype="historical-document" type="document" xml:id="d410">
                <note rend="inline" type="source">814.01/27: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Guatemala</hi> (<persName type="from">
                        <hi rend="italic">Whitehouse</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guatemala</hi>
                        </placeName>, <date calendar="gregorian" when="1931-01-03T11:00:00-07:00"
                            >January 3, 1931—11 a.m.</date>
                        <lb/>[Received 2:55 p.m.]</dateline>
                </opener>
                <p>5. German Minister authorized to recognize Reina Andrade but believe he will take
                    no action until I have received your instructions.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Whitehouse</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
