<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1931-05-04T19:00:00-05:00" frus:doc-dateTime-min="1931-05-04T19:00:00-05:00" n="610" subtype="historical-document" type="document" xml:id="d610">
                        <note rend="inline" type="source">815.24/143: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Honduras</hi> (<persName type="to"><hi rend="italic">Lay</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1931-05-04T20:00:00-04:00">May 4, 1931—8
                                p.m.</date></dateline></opener>
                        <p>36. Please report by telegraph results of any representations made by you
                            in compliance with the Department’s instruction No. 90, dated January
                            22.</p>
                        <closer><signed><hi rend="smallcaps">Stimson</hi></signed></closer>
                    </div>
                    </body></text></TEI>