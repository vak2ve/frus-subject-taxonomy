                subtype="historical-document" type="document" xml:id="d833">
                <note rend="inline" type="source">817.48 Earthquake of 1931/7: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Beaulac</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName> [<date
                            ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                            calendar="gregorian" notAfter="1931-04-01T02:42:00-05:00"
                            notBefore="1931-03-31T22:41:00-05:45">undated</date>].<lb/>[Received
                        April 1, 1931—2:42 a.m.]</dateline>
                </opener>
                <p>Legation in flames. All archives etc. lost. Tremors of considerable intensity
                    continue.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Beaulac</hi>
                    </signed>
                </closer>
            </div>
        </body>
