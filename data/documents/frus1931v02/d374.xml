                subtype="historical-document" type="document" xml:id="d374">
                <note rend="inline" type="source">211.41/159: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Dawes</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1931-12-22T12:00:00+00:00"
                            >December 22, 1931—noon</date>.<lb/>[Received December 22—8:35
                        a.m.]</dateline>
                </opener>
                <p>468. Department’s instruction 949, October 1. Extradition treaty signed and notes
                    regarding its application to Palestine and Trans-Jordan exchanged today.
                    Documents in next pouch.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dawes</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
