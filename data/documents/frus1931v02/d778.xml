                subtype="historical-document" type="document" xml:id="d778">
                <note rend="inline" type="source">702.1211/2128: Telegram</note>
                <head>
                    <hi rend="italic">The Governor of Illinois</hi> (<persName type="from">
                        <hi rend="italic">Emmerson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Springfield</hi>
                        </placeName>, <date calendar="gregorian" when="1931-07-07">July 7,
                            1931</date>.<lb/>[Received 8:52 p.m.]</dateline>
                </opener>
                <p>For Castle. Your telegram relative to arrest of Mexican Consul at Chicago on
                    chargé of contempt of court of Judge Thomas Green received. We are making an
                    immediate investigation to see what can be done and will advise you.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Louis L. Emmerson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
