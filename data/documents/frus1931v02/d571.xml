                subtype="historical-document" type="document" xml:id="d571">
                <note rend="inline" type="source">815.00 Revolutions/85: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Honduras</hi> (<persName type="from">
                        <hi rend="italic">Lay</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1931-05-14T12:00:00-06:00"
                            >May 14, 1931—noon</date>.<lb/>[Received 2:55 p.m.]</dateline>
                </opener>
                <p>95. Read the Department’s telegram No. 40, May 13, 3 p.m., to President Mejia
                    Colindres who has asked me if he can give immediately the substance thereof to
                    the Honduran press.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lay</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
