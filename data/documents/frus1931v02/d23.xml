    <text>
        <body>
            <div frus:doc-dateTime-max="1931-02-26T10:00:00-05:00"
                frus:doc-dateTime-min="1931-02-26T10:00:00-05:00" n="23"
                subtype="historical-document" type="document" xml:id="d23">
                <note rend="inline" type="source">821.6363/1067: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Colombia</hi> (<persName type="from">
                        <hi rend="italic">Caffery</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bogotá</hi>
                        </placeName>, <date calendar="gregorian" when="1931-02-26T10:00:00-05:00"
                            >February 26, 1931—10 a.m.</date>
                        <lb/>[Received 1:30 p.m.]</dateline>
                </opener>
                <p>23. My 16, February 14, 11 a.m.<note n="18" xml:id="d23fn18">Not printed.</note>
                    Upon the request of President Olaya, Rublee has decided to remain in Colombia
                    until March 26 in order to assist in drawing up regulating decrees under the new
                    petroleum law.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caffery</hi>
                    </signed>
                </closer>
            </div>
        </body>
