                <note rend="inline" type="source">815.00 Revolutions/103: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Honduras</hi> (<persName type="to">
                        <hi rend="italic">Lay</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1931-05-17T18:00:00-04:00"
                            >May 17, 1931—6 p.m.</date>
                    </dateline>
                </opener>
                <p>42. Referring your telegram number 100 May 17 1 p.m. approved.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Castle</hi>
                    </signed>
                </closer>
