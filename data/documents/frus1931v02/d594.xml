                subtype="historical-document" type="document" xml:id="d594">
                <note rend="inline" type="source">815.00 Revolutions/194: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Honduras</hi> (<persName type="from">
                        <hi rend="italic">Lay</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1931-06-27T11:00:00-06:00"
                            >June 27, 1931—11 a.m.</date>
                        <lb/>[Received 2:20 p.m.]</dateline>
                </opener>
                <p>135. I have been informed officially that Ferrera was killed yesterday by
                    Government troops near San Pedro Sula.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lay</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
