                <note rend="inline" type="source">651.116 Nitrate/41: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in France</hi> (<persName type="to">
                        <hi rend="italic">Shaw</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1931-11-23T21:00:00-05:00"
                            >November 23, 1931—9 p.m.</date>
                    </dateline>
                </opener>
                <p>590. Your 785, November 23, 5 p.m. Do not make formal protest.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
