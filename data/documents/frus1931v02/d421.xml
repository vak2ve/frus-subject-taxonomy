                subtype="historical-document" type="document" xml:id="d421">
                <note rend="inline" type="source">814.01/35a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Guatemala</hi> (<persName type="to">
                        <hi rend="italic">Whitehouse</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1931-01-06T18:00:00-05:00"
                            >January 6, 1931—6 p.m.</date>
                    </dateline>
                </opener>
                <p>3. You may extend the recognition of the Government of the United States to the
                    Government of Señor Andrade on the afternoon of January 8. Please inform your
                    Central American colleagues of the action you are taking in order that they may
                    join with you if they desire to do so.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
