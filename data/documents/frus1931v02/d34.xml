<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1931-07-30T17:00:00-05:00" frus:doc-dateTime-min="1931-07-30T17:00:00-05:00" n="34" subtype="historical-document" type="document" xml:id="d34">
                        <note rend="inline" type="source">821.6363/1152: Telegram</note>
                        <head><hi rend="italic">The Minister in Colombia</hi> (<persName type="from"><hi rend="italic">Caffery</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Acting Secretary of State</gloss></hi></head>
                        <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1931-07-30T17:00:00-05:00">July 30, 1931—5
                                p.m.</date><lb/>[Received 7:10 p.m.]</dateline></opener>
                        <p>103. My 102, July 29, 2 p.m. Petroleum regulating decree was published
                            yesterday. It is highly satisfactory. Please inform Mr. Rublee.</p>
                        <closer><signed><hi rend="smallcaps">Caffery</hi></signed></closer>
                    </div>
                </body></text></TEI>