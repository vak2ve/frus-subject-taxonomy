    <text>
        <body>
            <div frus:doc-dateTime-max="1931-12-11T23:59:59-05:00"
                frus:doc-dateTime-min="1931-12-11T00:00:00-05:00" n="1034"
                subtype="historical-document" type="document" xml:id="d1034">
                <note rend="inline" type="source">360c.1121 Fedoryszyn, Justyn/111</note>
                <head>
                    <hi rend="italic">The Polish Ambassador</hi> (<persName type="from">
                        <hi rend="italic">Filipowicz</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1931-12-11">December 11,
                            1931</date>.</dateline>
                    <seg rendition="#left">No. 327/T/31</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In compliance with instructions received from my
                    Government, I have the honor to enclose herewith a check for $4000 (Four
                    thousand <pb facs="1083" n="963" xml:id="pg_963"/> Dollars), this sum
                    constituting the indemnity with respect to the claim of Mr. Justyn Fedoryszyn,
                    paid on his behalf to the United States Government in full settlement of this
                    case.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">T. Filipowicz</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
