                subtype="historical-document" type="document" xml:id="d525">
                <note rend="inline" type="source">838.51/2363: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Haiti</hi> (<persName type="from">
                        <hi rend="italic">Munro</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port-au-Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1931-11-27T13:00:00-05:00"
                            >November 27, 1931—1 p.m.</date>
                        <lb/>[Received 2:26 p.m.]</dateline>
                </opener>
                <p>138. The Financial Adviser yesterday gave his accord to the budget and the latter
                    is now being published.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Munro</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
