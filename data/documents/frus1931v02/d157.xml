                subtype="historical-document" type="document" xml:id="d157">
                <note rend="inline" type="source">822.00/815: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Ecuador</hi> (<persName type="from">
                        <hi rend="italic">Dawson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Quito</hi>
                        </placeName>, <date calendar="gregorian" when="1931-10-16T16:00:00-05:00"
                            >October 16, 1931—4 p.m.</date>
                        <lb/>[Received 10:08 p.m.]</dateline>
                </opener>
                <p>57. City is quiet and assumption of Executive power by Baquerizo Moreno has been
                    received with satisfaction on all sides.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dawson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
