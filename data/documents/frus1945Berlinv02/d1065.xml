    <text>
        <body>
            <div frus:doc-dateTime-max="1945-07-21T09:00:00-05:00"
                frus:doc-dateTime-min="1945-07-21T09:00:00-05:00" n="1065"
                subtype="historical-document" type="document" xml:id="d1065">
                <note rend="inline" type="source">868.00/7–2145: Telegram</note>
                <head>No. 1065<lb/>
                    <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_CJ1"
                        type="from">
                        <hi rend="italic">Caffery</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">United States
                            Delegation</gloss>
                    </hi>
                    <note n="1" xml:id="d1065fn1">Printed from the text received in the Department
                        of State.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-21T16:00:00+02:00"
                            >July 21, 1945—4 p.m.</date>
                    </dateline>
                </opener>
                <p>[46.] <persName corresp="#p_BG1">Bidault</persName> accepted at once on behalf of
                    the French Govt the proposal regarding Greek elections as set out in your <gloss
                        target="#t_Victory1">
                        <hi rend="smallcaps">Victory</hi>
                    </gloss> 116 telegram.<note n="2" xml:id="d1065fn2">
                        <ref target="#d1062">Document No. 1062</ref>.</note>
                </p>
                <p>Sent Frankfurt for Berlin as 46, repeated Washington 4395 and Athens 9.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_CJ1">
                            <hi rend="smallcaps">Caffery</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
