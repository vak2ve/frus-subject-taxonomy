<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-07-25T23:59:59-05:00" frus:doc-dateTime-min="1945-07-25T00:00:00-05:00" n="816" subtype="historical-document" type="document" xml:id="d816">
                                <note rend="inline" type="source">Department of the Army Files:
                                    Telegram</note>
                                <head>No. 816<lb/><hi rend="italic">The <gloss type="from">Secretary
                                            of State</gloss> to the Acting Representative in
                                        Rumania</hi> (<persName corresp="#p_MRM1" type="to"><hi rend="italic">Melbourne</hi></persName>)<note n="1" xml:id="d816fn1">Messages identical with this telegram,
                                        except that they refer respectively to <persName corresp="#p_KMGWS1">Key</persName> and <persName corresp="#p_CMGJA1">Crane</persName> instead of
                                            <persName corresp="#p_SBGCTVR1">Schuyler</persName>,
                                        were dispatched at the same time to the American Missions at
                                        Budapest and Sofia as telegrams Nos. <gloss target="#t_Victory1"><hi rend="smallcaps">Victory</hi></gloss> 324 and 325.</note></head>
                                <opener>
                                    <seg rendition="#left"><hi rend="smallcaps">secret</hi>
                                        <lb/>
                                        <hi rend="smallcaps">urgent</hi></seg>
                                    <dateline rendition="#right">[<placeName><hi rend="smallcaps">Babelsberg</hi></placeName>,] <date calendar="gregorian" when="1945-07-25">July 25,
                                            1945</date>.</dateline>
                                </opener>
                                <p><gloss target="#t_Victory1"><hi rend="smallcaps">Victory</hi></gloss> 323. The question of the revision of
                                    the Control Commission procedures in Rumania, Bulgaria and
                                    Hungary is under discussion at the Berlin Conference. Please
                                    inform <persName corresp="#p_SBGCTVR1">General
                                        Schuyler</persName> requesting him to keep matter open but
                                    not to indicate our acceptance of the Soviet proposal pending
                                    receipt of further instructions.</p>
                                <closer><signed><persName corresp="#p_BJF1"><hi rend="smallcaps">Byrnes</hi></persName></signed></closer>
                            </div>
                            </body></text></TEI>