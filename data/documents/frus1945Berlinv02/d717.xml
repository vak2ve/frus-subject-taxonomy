<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>No. 717
                    The Secretary of State to the
                        Ambassador in China (
                        Hurley
                    )</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv02</bibl><bibl type="frus-document-id">d717</bibl><bibl type="frus-document-number">717</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-07-30T00:00:00-05:00" notAfter="1945-07-30T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-07-30T23:59:59-05:00" frus:doc-dateTime-min="1945-07-30T00:00:00-05:00" n="717" subtype="historical-document" type="document" xml:id="d717">
                <note rend="inline" type="source">Department of the Army Files: Telegram</note>
                <head>No. 717<lb/>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in China</hi> (<persName corresp="#p_HMGPJ1" type="to">
                        <hi rend="italic">Hurley</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                        <lb/>
                        <hi rend="smallcaps">urgent</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Babelsberg</hi>
                        </placeName>,] <date calendar="gregorian" when="1945-07-30">July 30,
                            1945</date>.</dateline>
                </opener>
                <p>
                    <gloss target="#t_Victory1">
                        <hi rend="smallcaps">Victory</hi>
                    </gloss> 439. Please proceed at once in accordance with the instruction in our
                    telegram Number 375 of July 27<note n="1" xml:id="d717fn1">
                        <ref target="#d715">Document No. 715</ref>.</note> inasmuch as we wish to
                    have President <persName corresp="#p_CK1">Chiang</persName>’s reply within the
                    next 48 hours.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BJF1">
                            <hi rend="smallcaps">Byrnes</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
