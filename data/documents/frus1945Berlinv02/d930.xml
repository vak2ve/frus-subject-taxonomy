<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-07-25T23:59:59-05:00" frus:doc-dateTime-min="1945-07-25T00:00:00-05:00" n="930" subtype="historical-document" type="document" xml:id="d930">
                            <note rend="inline" type="source">740.00119 E. W./7–2545</note>
                            <head>No. 930<lb/><hi rend="italic">The Representative on the Allied
                                    Commission on Reparations</hi> (<persName corresp="#p_PEW1" type="from"><hi rend="italic">Pauley</hi></persName>) <hi rend="italic">to the Assistant Secretary of State</hi>
                                    (<persName corresp="#p_CWL1" type="to"><hi rend="italic">Clayton</hi></persName>)<note n="1" xml:id="d930fn1">Printed from the ribbon copy, which bears only a typed
                                    signature.</note></head>
                            <opener>
                                <dateline rendition="#right">[<placeName><hi rend="smallcaps">Babelsberg</hi></placeName>,] <date calendar="gregorian" when="1945-07-25">July 25,
                                    1945</date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Dear Mr. <persName corresp="#p_CWL1">Clayton</persName></hi>: Attached are estimates of both
                                ourselves and the Soviet Union on the comparative percentage of
                                wealth in the Soviet occupied zone. In view of our present
                                discussions I am sure they will be of interest to you.</p>
                            <p>Very truly yours,</p>
                            <closer><signed><persName corresp="#p_PEW1"><hi rend="smallcaps">Edwin
                                            W. Pauley</hi></persName></signed></closer>
                            <frus:attachment>
                                <opener>
                                    <seg rendition="#center">[Attachment 1]</seg>
                                </opener>
                                <opener>
                                    <dateline rendition="#right">[<placeName><hi rend="smallcaps">Babelsberg</hi></placeName>,] <date calendar="gregorian" when="1945-07-25">July 25,
                                            1945</date>.</dateline>
                                </opener>
                                <p rend="center"><hi rend="smallcaps">Estimated Wealth in</hi> U. S.
                                    S. R. <hi rend="smallcaps">Zone of Occupation</hi></p>
                                <p rend="center">1937 Boundaries</p>
                                <table cols="3" rows="10">
                                    <row>
                                        <cell/>
                                        <cell><hi rend="italic">U.S.Estimate</hi></cell>
                                        <cell><hi rend="italic">U.S.S.R.Estimate</hi></cell>
                                    </row>
                                    <row>
                                        <cell/>
                                        <cell><hi rend="italic">Percent</hi></cell>
                                        <cell><hi rend="italic">Percent</hi></cell>
                                    </row>
                                    <row>
                                        <cell>Industry &amp; Mining</cell>
                                        <cell role="num">39.3</cell>
                                        <cell role="num">35.3</cell>
                                    </row>
                                    <row>
                                        <cell>Agriculture</cell>
                                        <cell role="num">48.0</cell>
                                        <cell role="num">48.0</cell>
                                    </row>
                                    <row>
                                        <cell/>
                                        <cell role="num">87.3</cell>
                                        <cell role="num">83.3</cell>
                                    </row>
                                    <row>
                                        <cell>Increase in industry due to removals into Eastern
                                            areas during war</cell>
                                        <cell role="num">5.0</cell>
                                        <cell role="num">3.0</cell>
                                    </row>
                                    <row>
                                        <cell/>
                                        <cell role="num">92.3</cell>
                                        <cell role="num">86.3</cell>
                                    </row>
                                    <row>
                                        <cell><note n="*" xml:id="d930fn2">U.S.weights agriculture
                                                and industry as equal in importance.U.S.S.R. weights
                                                industry as three times as important as
                                                agriculture.[Footnote in the
                                            original.]</note>Average</cell>
                                        <cell role="num">46.1</cell>
                                        <cell role="num">40.9</cell>
                                    </row>
                                    <row>
                                        <cell>Add 3 percent as value of land ceded to USSR</cell>
                                        <cell role="num">3.0</cell>
                                        <cell role="num">0.0</cell>
                                    </row>
                                    <row>
                                        <cell/>
                                        <cell role="num">49.1</cell>
                                        <cell role="num">40.9</cell>
                                    </row>
                                </table>
                            </frus:attachment>
                            <pb facs="1072" n="878" xml:id="pg_878"/>
