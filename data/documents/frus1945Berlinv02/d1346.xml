    <teiHeader><fileDesc><titleStmt><title>No. 1346
                    Prime Minister Attlee to President Truman</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv02</bibl><bibl type="frus-document-id">d1346</bibl><bibl type="frus-document-number">1346</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-07-31T00:00:00-05:00" notAfter="1945-07-31T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-07-31T23:59:59-05:00" frus:doc-dateTime-min="1945-07-31T00:00:00-05:00" n="1346" subtype="historical-document" type="document" xml:id="d1346">
                <note rend="inline" type="source">
                    <persName corresp="#p_TSH1">Truman</persName> Papers</note>
                <head>No. 1346<lb/>
                    <hi rend="italic">Prime Minister <persName corresp="#p_ACR1" type="from">Attlee</persName> to President <persName corresp="#p_THS1" type="to">Truman</persName>
                    </hi>
                </head>
                <p rend="center">
                    <hi rend="smallcaps">Memorandum to the President From the Prime Minister</hi>
                </p>
                <p>I have read your memorandum of July 24 about Palestine.<note n="1" xml:id="d1346fn1">
                        <ref target="#d1344">Document No. 1344</ref>.</note> You will I am sure
                    understand that I cannot give you any statement on policy until we have had time
                    to consider the matter, and this is simply to inform you that we will give early
                    and careful consideration to your memorandum.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_ACR1">
                            <hi rend="smallcaps">C R Attlee</hi>
                        </persName>
                    </signed>
                    <dateline rendition="#left">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-31">31st July,
                            1945</date>.</dateline>
                </closer>
            </div>
        </body>
    </text>
</TEI>
