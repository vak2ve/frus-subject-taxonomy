    <teiHeader><fileDesc><titleStmt><title>No. 1050
                    The Third Secretary of the British Embassy (
                        Miles
                    ) to the Assistant Adviser on German Economic
                        Affairs (
                        deWilde
                    )</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv02</bibl><bibl type="frus-document-id">d1050</bibl><bibl type="frus-document-number">1050</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-07-30T00:00:00-05:00" notAfter="1945-07-30T23:59:59-05:00"/></setting></settingDesc>            <textClass>
