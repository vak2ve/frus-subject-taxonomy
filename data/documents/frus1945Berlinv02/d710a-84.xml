<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Secretary of State to the
                        Ambassador in the United Kingdom (
                        Winant
                    )</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv02</bibl><bibl type="frus-document-id">d710a-84</bibl><bibl type="frus-document-number">710a-84</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-07-23T00:00:00-05:00" notAfter="1945-07-23T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-07-23T23:59:59-05:00" frus:doc-dateTime-min="1945-07-23T00:00:00-05:00" n="[Unnumbered document following Document 710 (#84)]" subtype="historical-document" type="document" xml:id="d710a-84">
                <note rend="inline" type="source">740.00119 <gloss target="#t_EAC1">EAC</gloss>/7–2345: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the United Kingdom</hi> (<persName corresp="#p_WJG2" type="to">
                        <hi rend="italic">Winant</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Babelsberg</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-23">July 23,
                            1945</date>.</dateline>
                </opener>
                <p>
                    <gloss target="#t_Victory1">
                        <hi rend="smallcaps">Victory</hi>
                    </gloss> 241. To <gloss target="#t_AmEmbassy1">AmEmbassy</gloss> London for
                        <persName corresp="#p_WJG2">Winant</persName>. <gloss target="#t_info1">Info</gloss> [Acting] <gloss target="#t_SecState1">SecState</gloss>
                    Washington.</p>
                <p>(Message has been sent to <gloss target="#t_MA1">MA</gloss>, London.)</p>
                <p>
                    <persName corresp="#p_G10">Gousev</persName> informed <persName corresp="#p_MPE1">Mosely</persName> tonight instructions sent <persName corresp="#p_SGF1">Saksin</persName> last night or this morning to sign
                        <gloss target="#t_EAC1">EAC</gloss> agreement on additional
                        requirements.<note n="1" xml:id="d710a-84fn1">See <hi rend="italic">ante</hi>, <ref target="#pg_138">p. 138</ref>, and <hi rend="italic">post</hi>, <ref target="#pg_1006">pp. 1006</ref>–<ref target="#pg_1023">1023</ref>.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_BJF1">
                            <hi rend="smallcaps">Byrnes</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
