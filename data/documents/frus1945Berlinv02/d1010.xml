<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>No. 1010
                    The Commander in Chief, United States Fleet, and Chief of
                        Naval Operations (
                        King
                    ) to the Navy Department
                    
                    This message resulted from an agreement reached in
                        Anglo-American conversations at Babelsberg. See ante,
                            p. 299.</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv02</bibl><bibl type="frus-document-id">d1010</bibl><bibl type="frus-document-number">1010</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-07-26T00:00:00-05:00" notAfter="1945-07-26T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-07-26T23:59:59-05:00" frus:doc-dateTime-min="1945-07-26T00:00:00-05:00" n="1010" subtype="historical-document" type="document" xml:id="d1010">
                <note rend="inline" type="source">Department of the Army Files: Telegram</note>
                <head>No. 1010<lb/>
                    <hi rend="italic">The Commander in Chief, United States Fleet, and Chief of
                        Naval Operations</hi> (<persName corresp="#p_KFAEJ1" type="from">
                        <hi rend="italic">King</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Navy Department</gloss>
                    </hi>
                    <note n="1" xml:id="d1010fn1">This message resulted from an agreement reached in
                        Anglo-American conversations at Babelsberg. See <hi rend="italic">ante</hi>,
                            <ref target="#pg_299">p. 299</ref>.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">confidential</hi>
                        <lb/>
                        <hi rend="smallcaps">routine</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Babelsberg</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-26">26 July
                            1945</date>.</dateline>
                </opener>
                <p>
                    <gloss target="#t_Victory1">
                        <hi rend="smallcaps">Victory</hi>
                    </gloss> 358. <gloss target="#t_CominCh1">CominCh</gloss> sends serial 25 to
                        <gloss target="#t_CominCh1">CominCh</gloss> and <gloss target="#t_CNO1">CNO</gloss>
                    <gloss target="#t_admin1">Admin</gloss> for action. Action ad[dress]ee pass for
                        <gloss target="#t_info1">info</gloss> to <gloss target="#t_ComNavEu1">ComNavEu</gloss> and <gloss target="#t_ComNavForGermany1">ComNavForGermany</gloss>.</p>
                <pb facs="1171" n="975" xml:id="pg_975"/>
                <p>In consultation with Commodore <persName corresp="#p_MCEJ1">Moran</persName>
                    select officer qualified to sit on <gloss target="#t_Capcraft1">
                        <hi rend="smallcaps">Capcraft</hi>
                    </gloss> Commission to select tugs suitable for United States purposes. Have
                    selected officer report to <gloss target="#t_ComNavEu1">ComNavEu</gloss> for
                    temporary duty on <gloss target="#t_Capcraft1">
                        <hi rend="smallcaps">Capcraft</hi>
                    </gloss> Commission.</p>
            </div>
        </body>
    </text>
</TEI>
