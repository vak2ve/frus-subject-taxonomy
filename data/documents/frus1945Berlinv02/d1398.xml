<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>No. 1398
                    The Ambassador in France (
                        Caffery
                    ) to the French Minister of Foreign Affairs
                        (
                        Bidault
                    )</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv02</bibl><bibl type="frus-document-id">d1398</bibl><bibl type="frus-document-number">1398</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-08-01T00:00:00-05:00" notAfter="1945-08-01T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-08-01T23:59:59-05:00" frus:doc-dateTime-min="1945-08-01T00:00:00-05:00" n="1398" subtype="historical-document" type="document" xml:id="d1398">
                <note rend="inline" type="source">740.00119 (Potsdam)/8–145</note>
                <head>No. 1398<lb/>
                    <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_CJ1" type="from">
                        <hi rend="italic">Caffery</hi>
                    </persName>) <hi rend="italic">to the French Minister of Foreign Affairs</hi>
                        (<persName corresp="#p_BG1" type="to">
                        <hi rend="italic">Bidault</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                        <lb/> No. 675</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1945-08-01">August 1,
                            1945</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: Acting under instructions from my
                    Government, I have the honor to transmit herewith the text of the document
                    “Western Frontier of Poland” approved on July 31, 1945.<note n="1" xml:id="d1398fn1">The enclosure consists of the text, without date or
                        heading, of <ref target="#d1152">document No. 1152</ref>.</note>
                </p>
                <p>I avail myself [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_CJ1">
                            <hi rend="smallcaps">Jefferson Caffery</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
