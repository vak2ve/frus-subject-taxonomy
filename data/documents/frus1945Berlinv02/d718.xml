<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>No. 718
                    The Ambassador in China (
                        Hurley
                    ) to the Secretary of
                            State
                    
                    Sent by the Commanding General, United States
                        Forces, China, via Army channels.</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv02</bibl><bibl type="frus-document-id">d718</bibl><bibl type="frus-document-number">718</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-07-31T00:00:00-05:00" notAfter="1945-07-31T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-07-31T23:59:59-05:00" frus:doc-dateTime-min="1945-07-31T00:00:00-05:00" n="718" subtype="historical-document" type="document" xml:id="d718">
                <note rend="inline" type="source">Department of the Army Files: Telegram</note>
                <head>No. 718<lb/>
                    <hi rend="italic">The Ambassador in China</hi> (<persName corresp="#p_HMGPJ1" type="from">
                        <hi rend="italic">Hurley</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                    <note n="1" xml:id="d718fn1">Sent by the Commanding General, United States
                        Forces, China, via Army channels.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                        <lb/>
                        <hi rend="smallcaps">urgent</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chungking</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-31">31 July
                            1945</date>.</dateline>
                </opener>
                <p>
                    <gloss target="#t_topsec1">TopSec</gloss> and Urgent Personal for <persName corresp="#p_BJF1">Byrnes</persName>, Secretary of State, Potsdam, Germany
                        <gloss target="#t_Cfb1">
                        <hi rend="smallcaps">Cfb</hi>
                    </gloss> 2223 from <persName corresp="#p_HMGPJ1">Hurley</persName> signed <gloss target="#t_ComGenChina1">ComGenChina</gloss>.</p>
                <p>Received your unnumbered message July 30,<note n="2" xml:id="d718fn2">
                        <ref target="#d717">Document No. 717</ref>.</note> 1040 hours,<note n="3" xml:id="d718fn3">i. e., 10:40 a.m.</note> Chungking time, July 31.</p>
                <p>Proceeding immediately on instructions contained in your <gloss target="#t_Victory1">
                        <hi rend="smallcaps">Victory</hi>
                    </gloss> number 375.<note n="4" xml:id="d718fn4">
                        <ref target="#d715">Document No. 715</ref>.</note>
                </p>
            </div>
        </body>
    </text>
</TEI>
