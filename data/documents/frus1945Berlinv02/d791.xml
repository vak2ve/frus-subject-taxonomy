        <body>
            <div frus:doc-dateTime-max="1945-07-27T23:59:59-05:00" frus:doc-dateTime-min="1945-07-27T00:00:00-05:00" n="791" subtype="historical-document" type="document" xml:id="d791">
                <note rend="inline" type="source">740.00119 Control (Germany)/7–2545</note>
                <head>No. 791<lb/>
                    <hi rend="italic">The Information Officer in the Office of the Secretary of
                        State</hi> (<persName corresp="#p_RRB1" type="from">
                        <hi rend="italic">Reams</hi>
                    </persName>) <hi rend="italic">to the Assistant Secretary of State</hi>
                        (<persName corresp="#p_DJC1" type="to">
                        <hi rend="italic">Dunn</hi>
                    </persName>)<note n="1" xml:id="d791fn1">Printed from a ribbon copy on which
                        there is a typed signature.</note>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Babelsberg</hi>
                        </placeName>,] <date calendar="gregorian" when="1945-07-27">July 27,
                            1945</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. <persName corresp="#p_DJC1">Dunn</persName>
                    </hi>: <persName corresp="#p_HLGJE1">General Hull</persName> prefers that this
                    matter be presented to the <gloss target="#t_War1">War</gloss> Department in
                    Washington. However, if you feel that there is some special need for haste, he
                    is prepared to take it up with <persName corresp="#p_EGADD1">General
                        Eisenhower</persName> and the <gloss target="#t_War1">War</gloss> Department
                    from Potsdam.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_RRB1">R. <hi rend="smallcaps">Borden Reams</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
