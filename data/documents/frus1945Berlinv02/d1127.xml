<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>No. 1127
                    The Assistant Secretary of State (
                        Clayton
                    ) to the Acting Secretary of
                            State
                    
                    Sent over the signature of Byrnes.</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv02</bibl><bibl type="frus-document-id">d1127</bibl><bibl type="frus-document-number">1127</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-07-21T00:00:00-05:00" notAfter="1945-07-21T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-07-21T23:59:59-05:00" frus:doc-dateTime-min="1945-07-21T00:00:00-05:00" n="1127" subtype="historical-document" type="document" xml:id="d1127">
                <note rend="inline" type="source">860c.85/7–2145: Telegram</note>
                <head>No. 1127<lb/>
                    <hi rend="italic">The Assistant Secretary of State</hi> (<persName corresp="#p_CWL1" type="from">
                        <hi rend="italic">Clayton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                    <note n="1" xml:id="d1127fn1">Sent over the signature of <persName corresp="#p_BJF1">Byrnes</persName>.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Babelsberg</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-21">July 21,
                            1945</date>.</dateline>
                </opener>
                <p>
                    <gloss target="#t_Victory1">
                        <hi rend="smallcaps">Victory</hi>
                    </gloss>–185. From <persName corresp="#p_CWL1">Clayton</persName>.</p>
                <p>
                    <persName corresp="#p_LVAES1">Admiral Land</persName>, Mr. <persName corresp="#p_DJC1">Dunn</persName>, and I have discussed Polish seamen’s
                        strike<note n="2" xml:id="d1127fn2">See <hi rend="italic">ante</hi>, <ref target="#pg_163">p. 163</ref>.</note> (<gloss target="#t_reurtel1">reurtel</gloss>s Nos. 73 and 74<note n="3" xml:id="d1127fn3">
                        <ref target="#d1124">Documents Nos. 1124</ref> and <ref target="#d1125">1125</ref>, respectively.</note>) and decided that <gloss target="#t_WSA1">WSA</gloss> should take action parallel to British; that
                    is, haul down Polish flag, run up United States flag, offer to sign on same
                    seamen, and indicate that the action is temporary for the emergency
                    situation.</p>
            </div>
        </body>
    </text>
</TEI>
