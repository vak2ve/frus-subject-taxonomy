    <text>
        <body>
            <div frus:doc-dateTime-max="1945-07-28T23:59:59-05:00"
                frus:doc-dateTime-min="1945-07-28T00:00:00-05:00" n="716"
                subtype="historical-document" type="document" xml:id="d716">
                <note rend="inline" type="source">Department of the Army Files: Telegram</note>
                <head>No. 716<lb/>
                    <hi rend="italic">The Ambassador in China</hi> (<persName corresp="#p_HMGPJ1"
                        type="from">
                        <hi rend="italic">Hurley</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                    <note n="1" xml:id="d716fn1">Sent by the Commanding General, United States
                        Forces, China, via Army channels.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                        <lb/>
                        <hi rend="smallcaps">urgent</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chungking</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-28">28 July
                            1945</date>.</dateline>
                </opener>
                <p>
                    <gloss target="#t_Cfb1">
                        <hi rend="smallcaps">Cfb</hi>
                    </gloss> 2015. For the Eyes alone of <persName corresp="#p_BJF1"
                        >Byrnes</persName>, Secretary of State, Potsdam, Germany from <persName
                        corresp="#p_HMGPJ1">Hurley</persName>, signed <gloss
                        target="#t_ComGenChina1">ComGenChina</gloss>.</p>
                <p>Received your <gloss target="#t_Victory1">
                        <hi rend="smallcaps">Victory</hi>
                    </gloss> 375, July 27.<note n="2" xml:id="d716fn2">
                        <ref target="#d715">Document No. 715</ref>.</note> Will be prepared to
                    obtain acceptance by <persName corresp="#p_CK1">Chiang Kai-Shek</persName>
                    quickly and in the method suggested on receipt of authorization.</p>
            </div>
        </body>
    </text>
