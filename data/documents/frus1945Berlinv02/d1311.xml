<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-07-23T23:59:59-05:00" frus:doc-dateTime-min="1945-07-23T00:00:00-05:00" n="1311" subtype="historical-document" type="document" xml:id="d1311">
                                <note rend="inline" type="source">Department of the Army Files:
                                    Telegram</note>
                                <head>No. 1311<lb/><hi rend="italic">The Acting Chairman of the
                                        Interim Committee</hi> (<persName corresp="#p_HGL1" type="from"><hi rend="italic">Harrison</hi></persName>) <hi rend="italic">to the Secretary of War</hi> (<persName corresp="#p_SHL2" type="to"><hi rend="italic">Stimson</hi></persName>)</head>
                                <opener>
                                    <seg rendition="#left"><hi rend="smallcaps">top secret</hi>
                                        <lb/>
                                        <hi rend="smallcaps">urgent</hi></seg>
                                    <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1945-07-23">23 July
                                            1945</date>.</dateline>
                                </opener>
                                <p><gloss target="#t_War1"><hi rend="smallcaps">War</hi></gloss>
                                    36791. Top secret Secretary of <gloss target="#t_War1">War</gloss>
                                    <gloss target="#t_EyesOnly1"><hi rend="smallcaps">Eyes
                                        Only</hi></gloss> from <persName corresp="#p_HGL1">Harrison</persName>.</p>
                                <p>Reference my <gloss target="#t_War1"><hi rend="smallcaps">War</hi></gloss> 35987<note n="1" xml:id="d1311fn1"><ref target="#d1307">Document No. 1307</ref>.</note>
                                    and your <gloss target="#t_Victory1"><hi rend="smallcaps">Victory</hi></gloss> 218<note n="2" xml:id="d1311fn2"><ref target="#d1310">Document No. 1310</ref>.</note>
                                    Hiroshima, Kokura, Niigata in [<hi rend="italic">is?</hi>] order
                                    of choice here.</p>
                            </div>
