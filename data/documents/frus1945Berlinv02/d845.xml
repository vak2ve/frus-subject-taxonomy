<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>No. 845
                    The Acting Secretary of State to
                        the Chargé in the Soviet Union (
                        Kennan
                    )</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv02</bibl><bibl type="frus-document-id">d845</bibl><bibl type="frus-document-number">845</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-07-19T16:00:00-05:00" notAfter="1945-07-19T16:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-07-19T16:00:00-05:00" frus:doc-dateTime-min="1945-07-19T16:00:00-05:00" n="845" subtype="historical-document" type="document" xml:id="d845">
                <note rend="inline" type="source">800.515/7–1445: Telegram</note>
                <head>No. 845<lb/>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in the Soviet Union</hi> (<persName corresp="#p_KGF1" type="to">
                        <hi rend="italic">Kennan</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                        <lb/>
                        <hi rend="smallcaps">priority</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-19T17:00:00-04:00">July 19, 1945—5 p.m.</date>
                    </dateline>
                </opener>
                <p>1641. <gloss target="#t_Dept1">Dept</gloss> forwarding memo<note n="1" xml:id="d845fn1">Not found.</note> to <persName corresp="#p_CEG1">Collado</persName>, Potsdam, discussing entire problem freezing satellites
                        (<gloss target="#t_reurtel1">reurtel</gloss> 2570 Jul 14, repeated to London
                    as 360,<note n="2" xml:id="d845fn2">
                        <ref target="frus1945Berlinv01#d326">Document No. 326, printed in vol. <hi rend="smallcaps">i</hi>
                        </ref>.</note> and related cables) and suggesting desirability discussion
                    Russian authorities. <gloss target="#t_Dept1">Dept</gloss> continues to feel
                    total freeze desirable in view administrative difficulties which will
                    undoubtedly be encountered if neutrals are requested to freeze on partial basis.
                    Matter will be held in abeyance pending reply.</p>
                <p>Sent to Moscow, repeated to London and Stockholm.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJC1">
                            <hi rend="smallcaps">Grew</hi>
                        </persName>
                        <lb/>
                        <persName corresp="#p_OCT1">C[ovey] T. O[liver]</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
