<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-07-19T15:00:00-05:00" frus:doc-dateTime-min="1945-07-19T15:00:00-05:00" n="1112" subtype="historical-document" type="document" xml:id="d1112">
                                <note rend="inline" type="source">740.00119 Control (Italy)/7–1745:
                                    Telegram</note>
                                <head>No. 1112<lb/><hi rend="italic">The <gloss type="from">Acting
                                            Secretary of State</gloss> to the Ambassador in
                                        Italy</hi> (<persName corresp="#p_KA1" type="to"><hi rend="italic">Kirk</hi></persName>)</head>
                                <opener>
                                    <seg rendition="#left"><hi rend="smallcaps">secret</hi></seg>
                                    <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1945-07-19T16:00:00-04:00">July 19, 1945—4 p.m.</date></dateline>
                                </opener>
                                <p>1205. <gloss target="#t_Dept1">Dept</gloss> has not yet received
                                    British concurrence (<gloss target="#t_urtel1">urtel</gloss>
                                    2010, July 17<note n="1" xml:id="d1112fn1"><ref target="#d1111">Document No. 1111</ref>.</note>) in appointment of
                                        <persName corresp="#p_DCJHJ1">Douglas</persName> as Chief
                                    Commissioner of <gloss target="#t_AC1">AC</gloss>.</p>
                                <closer><signed>
                                        <persName corresp="#p_GJC1"><hi rend="smallcaps">Grew</hi></persName>
                                        <lb/>
                                        <persName corresp="#p_RS1">S[amuel] R[eber]</persName>
                                    </signed></closer>
                            </div>
                            </body></text></TEI>