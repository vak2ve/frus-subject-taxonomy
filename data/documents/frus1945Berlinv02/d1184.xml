<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-07-25T23:59:59-05:00" frus:doc-dateTime-min="1945-07-25T00:00:00-05:00" n="1184" subtype="historical-document" type="document" xml:id="d1184">
                                <note rend="inline" type="source">740.00119 <gloss target="#t_PW1">PW</gloss>/7–2545</note>
                                <head>No. 1184<lb/><hi rend="italic">Prime Minister <persName corresp="#p_CWS1" type="from">Churchill</persName> to
                                        President <persName corresp="#p_THS1" type="to">Truman</persName></hi></head>
                                <opener>
                                    <seg rendition="#center">[Extract<note n="1" xml:id="d1184fn1">For the main body of this letter, see <ref target="#d1249">document No.
                                        1249</ref>.</note>]</seg>
                                </opener>
                                <opener>
                                    <seg rendition="#left"><hi rend="smallcaps">most
                                        secret</hi></seg>
                                    <dateline rendition="#right"><placeName><hi rend="smallcaps">Whitehall</hi> [<hi rend="italic">Babelsberg</hi>]</placeName>, <date calendar="gregorian" when="1945-07-25">July 25,
                                            1945</date>.</dateline>
                                </opener>
                                <p><hi rend="smallcaps">My Dear Mr. President</hi>, I thank you for
                                    your letter of July 25,<note n="2" xml:id="d1184fn2"><ref target="#d1183">Document No. 1183</ref>.</note> and I
                                    await the Memorandum on Lend-Lease which you are kindly having
                                    prepared.</p>
                                <p rend="center">. . . . . . . . . . . . . .</p>
                                <p>Yours very sincerely,</p>
                                <closer><signed><persName corresp="#p_CWS1"><hi rend="smallcaps">Winston</hi> S. <hi rend="smallcaps">Churchill</hi></persName></signed></closer>
                            </div>
                            </body></text></TEI>