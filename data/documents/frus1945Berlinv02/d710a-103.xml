    <text>
        <body>
            <div frus:doc-dateTime-max="1945-07-25T03:00:00-05:00"
                frus:doc-dateTime-min="1945-07-25T03:00:00-05:00"
                n="[Unnumbered document following Document 710 (#103)]"
                subtype="historical-document" type="document" xml:id="d710a-103">
                <note rend="inline" type="source">
                    <persName corresp="#p_TSH1">Truman</persName> Papers</note>
                <head>
                    <hi rend="italic">United States Delegation Working Paper</hi>
                </head>
                <dateline>
                    <placeName>Potsdam</placeName>, <date
                        ana="#date_undated-inferred-from-chapter-heading" calendar="gregorian"
                        when="1945-07-25T11:00:00+03:00">July 25, 1945, 11 a.m.</date>
                </dateline>
                <p rend="center">
                    <hi rend="smallcaps">Agenda for the Meeting of Heads of Governments, July</hi>
                    25, 1945</p>
                <list>
                    <label>1.</label>
                    <item>Polish Western Frontier<note n="3" xml:id="d710a-103fn3">Opposite this
                            item is the following marginal manuscript notation by <persName
                                corresp="#p_DJC1">Dunn</persName>: “<persName corresp="#p_EA1"
                                >Eden</persName> opposed to discussing this morning”.</note>
                    </item>
                    <label>2.</label>
                    <item>Disposition of German Fleet and Merchant Marine<note n="4"
                            xml:id="d710a-103fn4">Items 2 and 3 are bracketed together with the
                            following marginal manuscript notation by <persName corresp="#p_DJC1"
                                >Dunn</persName>: “Br[itish] ask to postpone”.</note>
                    </item>
                    <label>3.</label>
                    <item>German Reparations</item>
                    <label>4.</label>
                    <item>Transfer of populations from Poland &amp; Czechoslovakia<note n="5"
                            xml:id="d710a-103fn5">Item 4 was added in manuscript by <persName
                                corresp="#p_DJC1">Dunn</persName> with the following marginal
                            notation: “British will ask to add to agenda.”</note>
                    </item>
                    <label>[5.]</label>
                    <item>Waterways<note n="6" xml:id="d710a-103fn6">The last item was added in
                            manuscript by <persName corresp="#p_TJV1">Truman</persName>.</note>
                    </item>
                </list>
            </div>
        </body>
    </text>
