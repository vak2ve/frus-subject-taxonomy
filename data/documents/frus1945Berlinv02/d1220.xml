<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>No. 1220
                    The Ambassador in China (
                        Hurley
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv02</bibl><bibl type="frus-document-id">d1220</bibl><bibl type="frus-document-number">1220</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-07-29T00:00:00-05:00" notAfter="1945-07-29T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-07-29T23:59:59-05:00" frus:doc-dateTime-min="1945-07-29T00:00:00-05:00" n="1220" subtype="historical-document" type="document" xml:id="d1220">
                <note rend="inline" type="source">761.93/7–2945: Telegram</note>
                <head>No. 1220<lb/>
                    <hi rend="italic">The Ambassador in China</hi> (<persName corresp="#p_HMGPJ1" type="from">
                        <hi rend="italic">Hurley</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chungking</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-29">29 July
                            1945</date>.</dateline>
                </opener>
                <p>
                    <gloss target="#t_Cfb1">
                        <hi rend="smallcaps">Cfb</hi>
                    </gloss> 2087. Reference to your message of 28 July for Doctor <persName corresp="#p_STV1">T. V. Soong</persName>
                    <note n="1" xml:id="d1220fn1">
                        <ref target="#d1219">Document No. 1219</ref>.</note> the following is
                        <persName corresp="#p_STV1">Soong</persName>’s reply to you: <quote rend="blockquote">
                        <p>“When I left Moscow I had distinct understanding with <persName corresp="#p_MVM1">M. Molotov</persName> that he will keep me
                            informed of Marshal <persName corresp="#p_SGIV1">Stalin</persName>’s
                            movements so that I could reach Moscow soon after he returns.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_HMGPJ1">
                            <hi rend="smallcaps">Hurley</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
