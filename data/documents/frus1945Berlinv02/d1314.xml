                    <term ref="rec00812a40defabcb" type="topic" category="global-issues" subcategory="peace" subject="peace" lcsh-uri="http://id.loc.gov/authorities/subjects/sh00005610" lcsh-match="exact">Peace</term>
                </keywords>
