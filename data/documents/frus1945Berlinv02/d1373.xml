    <text>
        <body>
            <div frus:doc-dateTime-max="1945-07-25T23:59:59-05:00"
                frus:doc-dateTime-min="1945-07-25T00:00:00-05:00" n="1373"
                subtype="historical-document" type="document" xml:id="d1373">
                <note rend="inline" type="source">840.811/7–2545</note>
                <head>No. 1373<lb/>
                    <hi rend="italic">Proposal by the United States Delegation</hi>
                    <note n="1" xml:id="d1373fn1">Submitted at a meeting of the Subcommittee on
                        Inland Waterways, July 27. See <hi rend="italic">ante</hi>, <ref
                            target="#pg_453">p. 453</ref>.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Extract<note n="2" xml:id="d1373fn2">For the other
                            paragraphs of this proposal, see <ref target="#d758">document No.
                                758</ref>.</note>]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin Conference</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-25">July 25,
                            1945</date>.</dateline>
                </opener>
                <p rend="center">
                    <hi rend="smallcaps">Draft Proposal by American Delegation</hi>
                </p>
                <p rend="center">. . . . . . . . . . . . . .</p>
                <p>The three states will support the policy of free and unrestricted navigation in
                    any revision of the Montreux Convention of 1936.</p>
            </div>
        </body>
