    <text>
        <body>
            <div frus:doc-dateTime-max="1945-07-30T23:59:59-05:00"
                frus:doc-dateTime-min="1945-07-30T00:00:00-05:00"
                n="[Unnumbered document following Document 710 (#145)]"
                subtype="historical-document" type="document" xml:id="d710a-145">
                <note rend="inline" type="source">740.00119 Control (Germany)/7–2945</note>
                <head>
                    <hi rend="italic">Memorandum by the <gloss type="from">Political Adviser</gloss>
                        to the Representative on the European Advisory Commission</hi> (<persName
                        corresp="#p_MPE1" type="to">
                        <hi rend="italic">Mosely</hi>
                    </persName>)<note n="2" xml:id="d710a-145fn2">This memorandum is in the form of
                        a manuscript endorsement to <ref target="#d788">document No. 788</ref>, <hi
                            rend="italic">post</hi>.</note>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Babelsberg</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-30">July 30,
                            1945</date>.]</dateline>
                </opener>
                <p>Informed <persName corresp="#p_WJG1">J. G. Ward</persName> (<gloss
                        target="#t_UK1">UK</gloss>) and <persName corresp="#p_G10">Gousev</persName>
                    (U. S. S. R.) July 30, of U. S. approval<note n="3" xml:id="d710a-145fn3">Of
                        three quadripartite statements relating to Austria. See <ref target="#d788"
                            >document No. 788</ref>, <hi rend="italic">post</hi>.</note> and timing
                    arrangement. Telegram to Mr. <persName corresp="#p_WJG2">Winant</persName>, July
                        30.<note n="4" xml:id="d710a-145fn4">
                        <ref target="#d789">Document No. 789</ref>, <hi rend="italic"
                        >post</hi>.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_MPE1">P[<hi rend="smallcaps">hilip</hi>] E. M[<hi
                                rend="smallcaps">osely</hi>]</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
