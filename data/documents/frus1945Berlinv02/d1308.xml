    <text>
        <body>
            <div frus:doc-dateTime-max="1945-07-21T23:59:59-05:00"
                frus:doc-dateTime-min="1945-07-21T00:00:00-05:00" n="1308"
                subtype="historical-document" type="document" xml:id="d1308">
                <note rend="inline" type="source">Department of the Army Files: Telegram</note>
                <head>No. 1308<lb/>
                    <hi rend="italic">The Secretary of War</hi> (<persName corresp="#p_SHL2"
                        type="from">
                        <hi rend="italic">Stimson</hi>
                    </persName>) <hi rend="italic">to the Acting Chairman of the Interim
                        Committee</hi> (<persName corresp="#p_HGL1" type="to">
                        <hi rend="italic">Harrison</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                        <lb/>
                        <hi rend="smallcaps">urgent</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Babelsberg</hi>
                        </placeName>,] <date calendar="gregorian" when="1945-07-21">21 July,
                            1945</date>.</dateline>
                </opener>
                <p>
                    <gloss target="#t_Victory1">
                        <hi rend="smallcaps">Victory</hi>
                    </gloss> 189. Reference <hi rend="smallcaps">War</hi> 35987<note n="1"
                        xml:id="d1308fn1">
                        <ref target="#d1307">Document No. 1307</ref>.</note> from <persName
                        corresp="#p_SHL2">Stimson</persName> to <persName corresp="#p_PLCHM1"
                        >Pasco</persName> for <persName corresp="#p_HGL1">Harrison</persName>’s
                        <gloss target="#t_EyesOnly1">
                        <hi rend="smallcaps">Eyes Only</hi>
                    </gloss>. Message begins: Aware of no factors to change my decision. On the
                    contrary new factors here tend to confirm it. End.</p>
            </div>
        </body>
    </text>
