                            </row>
                        </table>
                        <closer>
                            <signed>
                                <persName corresp="#p_REL1">Elliot L. Richardson</persName><note n="5" xml:id="d308fn5">Printed from a copy that bears this typed
                                    signature.</note>
                            </signed>
                        </closer>
