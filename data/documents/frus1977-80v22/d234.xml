                subtype="historical-document" type="document" xml:id="d234">
                <head>234. Note From President <persName corresp="#p_CJE_1">Carter</persName> to
                    Secretary of State <persName corresp="#p_VC_1">Vance</persName>
                    <note n="1" type="source" xml:id="d234fn1">Source: Carter Library, National
                        Security Affairs, Staff Material, Far East, Armacost Chron File, Box 3,
                        6/11–27/77. No classification marking. <persName corresp="#p_CJE_1"
                            >Carter</persName> handwrote the note.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1977-06-14">June 14, 1977</date>
                    </dateline>
                    <salute>To <persName corresp="#p_VC_1">Cy Vance</persName>
                    </salute>
                </opener>
                <p>Please delay the visit to U.S. of Prime Minister of New Zealand.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="strong">J.C.</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
