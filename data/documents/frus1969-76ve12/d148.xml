                <head>148. Minutes of the Secretary of State’s Staff Meeting, Washington, January
                    12, 1976, 8:11 a.m.<note n="1" type="source" xml:id="d148fn1">Source: National
                        Archives, <gloss target="#t_rg">RG</gloss> 59, Transcripts of Secretary of
                        State <persName corresp="#p_kissinger-henry-a">Kissinger</persName>’s Staff
                        Meetings, 1973–1977, E5177, Box 9. Secret. The minutes are incorrectly dated
                        January 12, 1975.</note>
                    <note n="2" type="summary" xml:id="d148fn2">
                        <persName corresp="#p_kissinger-henry-a">Kissinger</persName> and his aides
                        discussed the situation in East Timor.</note>
                </head>
                <opener>
                    <dateline>
                        <placeName>Washington</placeName>, <date
                            ana="#date_undated-inferred-from-document-head" calendar="gregorian"
                            when="1976-01-12T08:11:00-05:00">January 12, 1976, 8:11 a.m.</date>
                    </dateline>
                </opener>
                <list type="participants">
                    <head>In Attendance - Monday, 1/12/1975</head>
                    <item>Secretary of State <persName corresp="#p_kissinger-henry-a"
                            >Kissinger</persName> - Chairman</item>
                    <item>D Mr. <persName corresp="#p_ingersoll-robert-stephen">Ingersoll</persName>
                    </item>
                    <item>
                        <gloss target="#t_p">P</gloss> Mr. <persName corresp="#p_sisco-joseph-j"
                            >Sisco</persName>
                    </item>
                    <item>E Mr. <persName corresp="#p_robinson-charles-w">Robinson</persName>
                    </item>
                    <item>
                        <gloss target="#t_t">T</gloss> Mr. <persName corresp="#p_maw-carlyle-e"
                            >Maw</persName>
                    </item>
                    <item>C Mr. <persName corresp="#p_sonnenfeldt-helmut-c">Sonnenfeldt</persName>
                    </item>
                    <item>
                        <gloss target="#t_af">AF</gloss> Mr. Schaufele</item>
                    <item>
                        <gloss target="#t_ara">ARA</gloss> Mr. Rogers</item>
                    <item>
                        <gloss target="#t_ea">EA</gloss> Mr. <persName corresp="#p_habib-philip-c"
                            >Habib</persName>
                    </item>
                    <item>
                        <gloss target="#t_eur">EUR</gloss> Mr. Lowenstein (Acting)</item>
                    <item>
                        <gloss target="#t_nea">NEA</gloss> Mr. Atherton</item>
                    <item>
                        <gloss target="#t_inr">INR</gloss> Mr. Saunders</item>
                    <item>
                        <gloss target="#t_s-p">S/P</gloss> Mr. <persName corresp="#p_lord-winston"
                            >Lord</persName>
                    </item>
                    <item>
                        <gloss target="#t_eb">EB</gloss> Mr. Enders</item>
                    <item>
                        <gloss target="#t_s-prs">S/PRS</gloss> Mr. Funseth (Acting)</item>
                    <item>
                        <gloss target="#t_pm">PM</gloss> Mr. Vest</item>
                    <item>
                        <gloss target="#t_io">IO</gloss> Mr. <persName corresp="#p_lewis-samuel-w"
                            >Lewis</persName>
                    </item>
                    <item>
                        <gloss target="#t_h">H</gloss> Mr. <persName corresp="#p_mccloskey-robert-j"
                            >McCloskey</persName>
                    </item>
                    <item>
                        <gloss target="#t_l">L</gloss> Mr. Leigh</item>
                    <item>
                        <gloss target="#t_s-s">S/S</gloss> Mr. SpringsteenMr</item>
                    <item>
                        <gloss target="#t_s">S</gloss> Mr. <persName corresp="#p_barbian-paul-e"
                            >Barbian</persName>
                    </item>
