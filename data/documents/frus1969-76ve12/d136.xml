                            <item>
                                <gloss target="#t_s-prs">S/PRS</gloss> Mr. Anderson</item>
                            <item>
                                <gloss target="#t_pm">PM</gloss> Mr. Vest</item>
                            <item>
                                <gloss target="#t_io">IO</gloss> Mr. Buffum</item>
                            <item>
                                <gloss target="#t_h">H</gloss> Mr. <persName corresp="#p_mccloskey-robert-j">McCloskey</persName>
                            </item>
                            <item>
                                <gloss target="#t_l">L</gloss> Mr. Leigh</item>
                            <item>
                                <gloss target="#t_s-s">S/S</gloss> Mr. <persName corresp="#p_springsteen-george-s">Springsteen</persName>
