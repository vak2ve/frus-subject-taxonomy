<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1867-12-24T23:59:59-05:00" frus:doc-dateTime-min="1867-12-24T00:00:00-05:00" n="13" subtype="historical-document" type="document" xml:id="d13">
                        <opener><seg rendition="#center">[Telegram per cable.]</seg></opener>
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName></head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                                <date calendar="gregorian" when="1867-12-24"><hi rend="italic">December</hi> 24, 1867.</date></dateline></opener>
                        <p>Employ counsel for Burke, at reasonable cost.</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
