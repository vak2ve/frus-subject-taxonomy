<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1869-01-12T23:59:59-05:00" frus:doc-dateTime-min="1869-01-12T00:00:00-05:00" n="163" subtype="historical-document" type="document" xml:id="d163">
                        <opener><seg rendition="#center">[Telegram per
                            cable.—Extract.]</seg></opener>
                        <head><persName type="from">Mr. Johnson</persName> to <persName type="to">Mr. Seward</persName></head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Legation of the United States</hi>,
                                        <hi rend="italic">London</hi></placeName>, <date calendar="gregorian" when="1869-01-12"><hi rend="italic">January</hi> 12, 1869.</date></dateline></opener>
                        <p>Telegram received. Have since intelligence from Clarendon, and think all
                            will be right. * * * *</p>
                        <closer>
                            <signed>REVERDY JOHNSON.</signed></closer>
                        <postscript>
                            <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">Secretary of State, Washington, D. C.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>