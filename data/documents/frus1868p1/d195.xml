    <text>
        <body>
            <div frus:doc-dateTime-max="1868-07-23T23:59:59-05:00" frus:doc-dateTime-min="1868-07-23T00:00:00-05:00" n="195" subtype="historical-document" type="document" xml:id="d195">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Thornton</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1868-07-23">
                            <hi rend="italic">July</hi> 23, 1868.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have the honor to transmit herewith, for
                            your information and that of the government which you represent, a copy
                            of an instruction<note n="*" xml:id="d195fn1">For this inclosure see
                                correspondence with. United States minister to Japan.</note> which,
                            on the 14th instant, was addressed by this department to the United
                            States minister at Yeddo.</p>
                <p>I have the honor to be, sir, with the highest consideration, your
                            obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Edward Thornton,</hi> Esq., <hi rend="italic">&amp;c</hi>, <hi rend="italic">&amp;c.</hi>, <hi rend="italic">&amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
