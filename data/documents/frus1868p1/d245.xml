<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1868-01-24T23:59:59-05:00" frus:doc-dateTime-min="1868-01-24T00:00:00-05:00" n="245" subtype="historical-document" type="document" xml:id="d245">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                de Stoeckl</persName></head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                                <date calendar="gregorian" when="1868-01-24"><hi rend="italic">January</hi> 24, 1868.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> I have the honor to communicate, for the
                            information of the Russian government, a copy of a report of General
                            Lovell H. Rousseau, United States agent to receive the transfer of
                            Alaska.</p>
                        <p>Accept, sir, a renewed assurance of my highest consideration,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p>Mr. <hi rend="smallcaps">Edward de Stoeckl, &amp;c</hi>., <hi rend="italic">&amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>