<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1868-02-18T23:59:59-05:00" frus:doc-dateTime-min="1868-02-18T00:00:00-05:00" n="36" subtype="historical-document" type="document" xml:id="d36">
                        <opener><seg rendition="#center">[Telegram per cable.]</seg></opener>
                        <head><persName type="from">Mr. Adams</persName> to <persName type="to">Mr.
                                Seward</persName></head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Legation of the United States</hi>,
                                        <hi rend="italic">London,</hi></placeName>
                                <date calendar="gregorian" when="1868-02-18"><hi rend="italic">February</hi> 18, 1868.</date></dateline></opener>
                        <p>Usual counsel engaged. No reply yet to dispatch 14th December.</p>
                        <closer>
                            <signed>CHARLES FRANCIS ADAMS.</signed></closer>
                        <postscript>
                            <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">Secretary of State, Washington, D. C.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>