                <opener>
                    <seg rendition="#center">[Telegram per cable.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Johnson</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1868-10-25">
                            <hi rend="italic">October</hi> 25, 1868.</date>
                    </dateline>
                </opener>
                <p>Naturalization protocol approved. Can you hasten claims convention?</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Reverdy Johnson,</hi> Esq<hi rend="italic">.,
                            &amp;c</hi>., <hi rend="italic">&amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
