    <text>
        <body>
            <div frus:doc-dateTime-max="1868-10-20T23:59:59-05:00"
                frus:doc-dateTime-min="1868-10-20T00:00:00-05:00" n="122"
                subtype="historical-document" type="document" xml:id="d122">
                <opener>
                    <seg rendition="#center">[Telegram per cable.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Johnson</persName> to <persName type="to">Mr.
                        Seward</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>, <hi
                                rend="italic">London,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1868-10-20">
                            <hi rend="italic">October</hi> 20, 1868.</date>
                    </dateline>
                </opener>
                <p>Can I consent to leave all questions as to Alabama claims to arbitration of King
                    of Prussia?</p>
                <closer>
                    <signed>REVERDY JOHNSON.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">Secretary
                            of State</hi>, <hi rend="italic">Washington, D. C.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
