<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1868-04-10T23:59:59-05:00" frus:doc-dateTime-min="1868-04-10T00:00:00-05:00" n="63" subtype="historical-document" type="document" xml:id="d63">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName></head>
                        <opener>
                            <seg rendition="#left">No. 2154.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1868-04-10"><hi rend="italic">April</hi> 10, 1868.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> Your dispatches numbered 1553 to 1560 have
                            been received and are approved.</p>
                        <pb facs="0237" n="189" xml:id="pg_189"/>
                        <p>The delay of the British government on the naturalization question, to
                            which reference is made in your No. 1558, is regretted.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>