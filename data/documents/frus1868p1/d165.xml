    <text>
        <body>
            <div frus:doc-dateTime-max="1869-01-14T23:59:59-05:00" frus:doc-dateTime-min="1869-01-14T00:00:00-05:00" n="165" subtype="historical-document" type="document" xml:id="d165">
                <opener>
                    <seg rendition="#center">[Telegram per cable.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Johnson</persName> to <persName type="to">Mr. Seward</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,
                                        <hi rend="italic">London</hi>
                        </placeName>
                        <date calendar="gregorian" when="1869-01-14">
                            <hi rend="italic">January</hi> 14, 1869.</date>
                    </dateline>
                </opener>
                <p>Conventions signed as instructed. Go Saturday.</p>
                <closer>
                    <signed>REVERDY JOHNSON.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">Secretary of State, Washington, D</hi>. <hi rend="italic">C.</hi>
                    </p>
                </postscript>
            </div>
        </body>
