    <text>
        <body>
            <div frus:doc-dateTime-max="1868-10-07T23:59:59-05:00" frus:doc-dateTime-min="1868-10-07T00:00:00-05:00" n="115" subtype="historical-document" type="document" xml:id="d115">
                <opener>
                    <seg rendition="#center">[Telegram per cable.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Johnson</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1868-10-07">
                            <hi rend="italic">October</hi> 7, 1868.</date>
                    </dateline>
                </opener>
                <p>Your 20 received. See and adhere to my 20. Send protocol by cable, in
                            cipher.</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Revedy Johnson,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
