    <text>
        <body>
            <div frus:doc-dateTime-max="1868-10-09T23:59:59-05:00" frus:doc-dateTime-min="1868-10-09T00:00:00-05:00" n="116" subtype="historical-document" type="document" xml:id="d116">
                <opener>
                    <seg rendition="#center">[Telegram per cable.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Johnson</persName> to <persName type="to">Mr. Seward</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,
                                        <hi rend="italic">London,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1868-10-09">
                            <hi rend="italic">October</hi> 9, 1868.</date>
                    </dateline>
                </opener>
                <p>Protocol on naturalization signed. Copy by bag.</p>
                <closer>
                    <signed>REVERDY JOHNSON.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">Secretary of State, Washington, D. C.</hi>
                    </p>
                </postscript>
            </div>
        </body>
