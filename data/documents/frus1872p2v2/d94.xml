    <text>
        <body>
            <div frus:doc-dateTime-max="1866-03-31T23:59:59-05:00"
                frus:doc-dateTime-min="1866-03-31T00:00:00-05:00" n="94"
                subtype="historical-document" type="document" xml:id="d94">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Seward</persName>, Secretary of
                        State, to Mr. <persName type="to">BicMnson</persName>, district
                        attorney.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1866-03-31">
                            <hi rend="italic">March</hi> 31, 1866</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Pursuant to the request contained in your letter
                    of yesterday’s date, I herewith transmit a certified copy of an official paper
                    on file in this Department, relative, to the existence of a state of war between
                    Spain and Chili.</p>
                <p>I am, sir, yours, &amp;c.,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">D. S. Dickinson</hi>, Esq.,<lb/>
                        <hi rend="italic">United States District Attorney, New York.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
