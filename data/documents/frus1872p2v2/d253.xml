                <head>No. 118.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Davis</persName> to Mr. <persName
                            type="to">Fish</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Geneva</hi>
                        </placeName>, <date calendar="gregorian" when="1872-06-27">
                            <hi rend="italic">June</hi> 27, 1872</date>. (Received at 3.45
                        p.m.)</dateline>
                </opener>
                <p>British argument tiled. Arbitration goes on.</p>
                <closer>
                    <signed>DAVIS.</signed>
                </closer>
            </div>
