    <text>
        <body>
            <div frus:doc-dateTime-max="1872-02-27T23:59:59-05:00" frus:doc-dateTime-min="1872-02-27T00:00:00-05:00" n="142" subtype="historical-document" type="document" xml:id="d142">
                <head>No. 7.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Fish</persName>
                                to General <persName type="to">Schenck</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1872-02-27">
                            <hi rend="italic">February</hi> 27,
                                    1872</date>.</dateline>
                </opener>
                <p>Reported rejection untrue. Entire unanimity. Answer now being copied.
                            Granville’s suggestion inadmissible.</p>
                <closer>
                    <signed>FISH.</signed>
                </closer>
            </div>
        </body>
    </text>
