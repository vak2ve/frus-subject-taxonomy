    <text>
        <body>
            <div frus:doc-dateTime-max="1915-11-30T23:59:59-05:00"
                frus:doc-dateTime-min="1915-11-30T00:00:00-05:00" n="285"
                subtype="historical-document" type="document" xml:id="d285">
                <note rend="inline" type="source">File No. 763.72112/1952</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1915-11-30">
                            <hi rend="italic">November 30, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 5 p. m.</hi>]</dateline>
                </opener>
                <p>3317. Your 2504, 27th, 9 p. m. Your understanding of matter correct. Foreign
                    Office state extract included.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">American Embassy</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
