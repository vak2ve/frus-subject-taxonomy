                subtype="historical-document" type="document" xml:id="d151">
                <note rend="inline" type="source">File No. 763.72/1461</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Italy</hi> (<persName corresp="#p_PTN1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-02-17">
                            <hi rend="italic">February 17, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>164. Your 190, February 16, 9 a. m. Please keep Department promptly advised as to
                    situation.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
