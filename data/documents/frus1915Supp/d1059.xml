<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-12-24T23:59:59-05:00" frus:doc-dateTime-min="1915-12-24T00:00:00-05:00" n="1059" subtype="historical-document" type="document" xml:id="d1059">
                            <note rend="inline" type="source">File No. 841.711/145</note>
                            <head>
                                <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="from"><hi rend="italic">Gerard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName><hi rend="smallcaps">Berlin</hi></placeName>, <date calendar="gregorian" when="1915-12-24">
                                        <hi rend="italic">December 24, 1915</hi>.</date>
                                    <lb/> [<hi rend="italic">Received December 25, 4.50 p.
                                    m.</hi>]</dateline>
                            </opener>
                            <p>3263. American Association of Commerce and Trade here request me to
                                inform you that 5,000 packages of merchandise, American property,
                                have been seized by British Government from Danish steamer <hi rend="italic">United States</hi> on her last trip to United
                                States.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_GJW1">
                                        <hi rend="smallcaps">Gerard</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>