<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-10-07T23:59:59-05:00" frus:doc-dateTime-min="1915-10-07T00:00:00-05:00" n="1156" subtype="historical-document" type="document" xml:id="d1156">
                        <note rend="inline" type="source">File No. 763.72111/2941</note>
                        <head>
                            <hi rend="italic">The Attorney General</hi> (<persName corresp="#p_GTW1" type="from"><hi rend="italic">Gregory</hi></persName>) <hi rend="italic">to the</hi>
                            <gloss type="to">
                                <hi rend="italic">Secretary of State</hi>
                            </gloss>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-10-07">
                                    <hi rend="italic">October 7, 1915</hi>.</date>
                            </dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: The Department is in receipt of your
                            letter of September 27, 1915, enclosing photographic copies and
                            translations of letter relative to Austro-Hungarian subjects.</p>
                        <pb facs="1067" n="809" xml:id="pg_809"/>
                        <p>In reply, I desire to say that the facts contained do not seem to
                            constitute any violation of the Federal criminal laws.</p>
                        <p>Respectfully,</p>
                        <closer>For the Attorney General: <lb/>
                            <signed>
                                <persName corresp="#p_WC1">
                                    <hi rend="smallcaps">Charles Warren</hi>
                                </persName>
                            </signed>
                            <lb/>
                            <hi rend="italic">Assistant Attorney General</hi>
                        </closer>
                    </div>
                    </body></text></TEI>