    <text>
        <body>
            <div frus:doc-dateTime-max="1915-08-09T23:59:59-05:00"
                frus:doc-dateTime-min="1915-08-09T00:00:00-05:00" n="1464"
                subtype="historical-document" type="document" xml:id="d1464">
                <note rend="inline" type="source">File No. 763.72114/684</note>
                <head>
                    <hi rend="italic">The Ambassador in Russia</hi> (<persName corresp="#p_MGT1"
                        type="from">
                        <hi rend="italic">Marye</hi>
                    </persName>) <hi rend="italic">to the</hi>
                    <gloss type="to">
                        <hi rend="italic">Secretary of State</hi>
                    </gloss>
                    <note n="1" xml:id="d1464fn1">Communicated to the Ambassador in Germany, August
                        10, No. 2058.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Petrograd</hi>
                        </placeName>, <date calendar="gregorian" when="1915-08-09">
                            <hi rend="italic">August 9, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 12.45 p. m.</hi>]</dateline>
                </opener>
                <p>253. Russian Government has given its consent that American Red Cross operate in
                    Siberia and throughout Russia in manner to it most convenient. Additional
                    secretaries of Embassy sent to us can take charge of visiting the camps in
                    Russia and are now engaged in such work.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MGT1">
                            <hi rend="smallcaps">Marye</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
