    <text>
        <body>
            <div frus:doc-dateTime-max="1915-02-28T23:59:59-05:00"
                frus:doc-dateTime-min="1915-02-28T00:00:00-05:00" n="487"
                subtype="historical-document" type="document" xml:id="d487">
                <note rend="inline" type="source">File No. 451.11B74</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_SWG1"
                        type="from">
                        <hi rend="italic">Sharp</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1915-02-28">
                            <hi rend="italic">February 28, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 5.10 p. m.</hi>]</dateline>
                </opener>
                <p>574. Morning papers publish announcement by Ministry of Marine to effect that <hi
                        rend="italic">Dacia</hi> was captured in western part of English Channel by
                    French cruiser and taken to Brest.<note n="1" xml:id="d487fn1">For previous
                        correspondence concerning the <hi rend="italic">Dacia</hi> case, see the
                        section dealing with transfer of ships, <hi rend="italic">post</hi>, <ref
                            target="#pg_674">p. 674</ref>.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_SWG1">
                            <hi rend="smallcaps">Sharp</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
