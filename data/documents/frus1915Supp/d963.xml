    <text>
        <body>
            <div frus:doc-dateTime-max="1915-06-12T23:59:59-05:00"
                frus:doc-dateTime-min="1915-06-12T00:00:00-05:00" n="963"
                subtype="historical-document" type="document" xml:id="d963">
                <note rend="inline" type="source">File No. 195.1/443</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> ad interim
                        to the Consul General at Copenhagen</hi> (<persName corresp="#p_WED1"
                        type="to">
                        <hi rend="italic">Winslow</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-06-12">
                            <hi rend="italic">June 12, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>Your telegram June 4, 6 p. m.<note n="1" xml:id="d963fn1">Not printed.</note>
                    Department of Commerce requests you be informed you should issue no more
                    certificates to ships involved in transactions of Jensen and American
                    Transatlantic Company.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
