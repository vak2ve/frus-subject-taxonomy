<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-10-05T17:00:00-05:00" frus:doc-dateTime-min="1915-10-05T17:00:00-05:00" n="81" subtype="historical-document" type="document" xml:id="d81">
                        <note rend="inline" type="source">File No. 763.72/2184h</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Roumania, Servia, and Bulgaria</hi> (<persName corresp="#p_VCJ1" type="to"><hi rend="italic">Vopicka</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-10-05T17:00:00-05:00">
                                    <hi rend="italic">October 5, 1915, 5 p. m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>160. Department desires your opinion on Balkan situation and frequent
                            confidential cable reports.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>