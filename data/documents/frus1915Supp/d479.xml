                subtype="historical-document" type="document" xml:id="d479">
                <note rend="inline" type="source">File No. 763.72112/739</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1915-02-17">
                            <hi rend="italic">February 17, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 5 p. m.</hi>]</dateline>
                </opener>
                <p>1662. Your 1138, February 16. Although rescinding of order forbidding publication
                    for thirty days of ships’ manifests comes at a time when the public mind and
                    press are occupied with more exciting subjects, it is appreciatively received
                    and will have excellent effect. The <hi rend="italic">Times</hi> this morning
                    has thankful comment.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">American Ambassador</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
