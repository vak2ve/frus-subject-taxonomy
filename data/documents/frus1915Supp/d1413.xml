<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-10-06T23:59:59-05:00" frus:doc-dateTime-min="1915-10-06T00:00:00-05:00" n="1413" subtype="historical-document" type="document" xml:id="d1413">
                        <note rend="inline" type="source">File No. 367.11/772</note>
                        <head>
                            <hi rend="italic">The</hi>
                            <gloss type="from">
                                <hi rend="italic">Secretary of State</hi>
                            </gloss>
                            <hi rend="italic">to the Ambassador in Turkey</hi> (<persName corresp="#p_MH1" type="to"><hi rend="italic">Morgenthau</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-10-06">
                                    <hi rend="italic">October 6, 1915</hi>.</date>
                            </dateline>
                        </opener>
                        <p>1165. Can you secure permission to leave Turkey for Armenians whose
                            relatives in America will pay expenses passage? Also please answer
                            Department’s 1028, September 8.<note n="1" xml:id="d1413fn1">Not
                                printed.</note>
                        </p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>