    <text>
        <body>
            <div frus:doc-dateTime-max="1915-09-14T11:00:00-05:00"
                frus:doc-dateTime-min="1915-09-14T11:00:00-05:00" n="1322"
                subtype="historical-document" type="document" xml:id="d1322">
                <note rend="inline" type="source">File No. 701.6311/149</note>
                <head>
                    <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="from">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the</hi>
                    <gloss type="to">
                        <hi rend="italic">Secretary of State</hi>
                    </gloss>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1915-09-14T17:00:00+01:00">
                            <hi rend="italic">September 14, 1915, 5 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received September 16, 9 p. m.</hi>]</dateline>
                </opener>
                <p>897. Austro-Hungarian Government desires to know whether American Government
                    would consent to procure safe-conduct from British and French Governments for
                    Austro-Hungarian Ambassador at Washington in case he should be directed to come
                    to Vienna to give verbal explanation of the subject your telegram 887, September
                    8, 4 p. m.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
