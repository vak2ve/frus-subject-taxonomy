<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-04-30T23:59:59-05:00" frus:doc-dateTime-min="1915-04-30T00:00:00-05:00" n="547" subtype="historical-document" type="document" xml:id="d547">
                            <note rend="inline" type="source">File No. 362.115St21</note>
                            <head>
                                <hi rend="italic">The Minister in the Netherlands</hi> (<persName corresp="#p_VDH1" type="from"><hi rend="italic">Van
                                    Dyke</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">The Hague</hi></placeName>, <date calendar="gregorian" when="1915-04-30">
                                        <hi rend="italic">April 30, 1915</hi>.</date>
                                    <lb/> [<hi rend="italic">Received 9.08 p. m.</hi>]</dateline>
                            </opener>
                            <p>255. American Consul, Rotterdam, reports American steamship <hi rend="italic">Cushing</hi>, Captain
                                <persName>Herland</persName>, with petroleum from New York to
                                Rotterdam, flying American flag, was attacked by German aeroplane
                                near North Hinder Lightship, afternoon April 29. Three bombs
                                dropped, one struck ship causing damage but no life lost.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_VDH1">
                                        <hi rend="smallcaps">Van Dyke</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>