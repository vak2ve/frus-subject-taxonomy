                subtype="historical-document" type="document" xml:id="d240">
                <note rend="inline" type="source">File No. 763.72112/564</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1914-12-31T19:00:00+01:00">
                            <hi rend="italic">December 31, 1914, 7 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received January 2, 1915, 4.15 p.
                        m.</hi>]</dateline>
                </opener>
                <p>1234. Consular Agent, Lübeck, reports demand for cotton. Is it understood to be
                    considered as contraband? May it be shipped to Germany?</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
