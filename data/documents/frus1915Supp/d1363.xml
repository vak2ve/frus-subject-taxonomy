<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-03-16T04:00:00-05:00" frus:doc-dateTime-min="1915-03-16T04:00:00-05:00" n="1363" subtype="historical-document" type="document" xml:id="d1363">
                        <note rend="inline" type="source">File No. 763.72/1590</note>
                        <head>
                            <hi rend="italic">The Ambassador in Turkey</hi> (<persName corresp="#p_MH1" type="from"><hi rend="italic">Morgenthau</hi></persName>) <hi rend="italic">to the</hi>
                            <gloss type="to">
                                <hi rend="italic">Secretary of State</hi>
                            </gloss>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Constantinople</hi></placeName>, <date calendar="gregorian" when="1915-03-16T11:00:00+02:00">
                                    <hi rend="italic">March 16, 1915, 11 a. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received 9 p. m.</hi>]</dateline>
                        </opener>
                        <p>505. Your telegram 499.<note n="1" xml:id="d1363fn1">Not printed.</note>
                            Have definite assurance Turkish Government will make every endeavor to
                            protect non-combatants. Am [accompanying] Minister of War and four
                            senators to Dardanelles.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">American Ambassador</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>