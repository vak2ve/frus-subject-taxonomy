<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-10-19T23:59:59-05:00" frus:doc-dateTime-min="1915-10-19T00:00:00-05:00" n="91" subtype="historical-document" type="document" xml:id="d91">
                        <note rend="inline" type="source">File No. 763.72/2200</note>
                        <head>
                            <hi rend="italic">The Third Assistant <gloss type="from">Secretary of
                                    State</gloss> to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-10-19">
                                    <hi rend="italic">October 19, 1915</hi>.</date>
                            </dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Dear Mr. Secretary</hi>: The Counselor of the
                            Italian Embassy called this morning to say that a state of war exists
                            between Italy and Bulgaria. The Embassy will inform the Department of
                            this fact by a formal note.</p>
                        <p>Sincerely,</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_PW1">
                                    <hi rend="smallcaps">W. Phillips</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>