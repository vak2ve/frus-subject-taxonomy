<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-01-14T23:59:59-05:00" frus:doc-dateTime-min="1915-01-14T00:00:00-05:00" n="916" subtype="historical-document" type="document" xml:id="d916">
                        <note rend="inline" type="source">File No. 611.479/131</note>
                        <head>
                            <hi rend="italic">The Consul General at Sydney</hi> (<persName corresp="#p_BJP1" type="from"><hi rend="italic">Bray</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Sydney</hi></placeName>, <date calendar="gregorian" when="1915-01-14">
                                    <hi rend="italic">January 14, 1915</hi>.</date>
                                <lb/> [<hi rend="italic">Received 8 a. m.</hi>]</dateline>
                        </opener>
                        <p>Comptroller customs advises when collector satisfied <hi rend="italic">bona fides</hi> ship; shipment merino wool, hides, skins to United
                            States allowed in American ships same condition as British ships.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BJP1">
                                    <hi rend="smallcaps">Bray</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>