    <text>
        <body>
            <div frus:doc-dateTime-max="1915-05-03T23:59:59-05:00"
                frus:doc-dateTime-min="1915-05-03T00:00:00-05:00" n="549"
                subtype="historical-document" type="document" xml:id="d549">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)<note n="1" xml:id="d549fn1">The same to the Ambassador in Germany,
                        No. 1612, May 3.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-05-03">
                            <hi rend="italic">May 3, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>1500. Reported American tank steamer <hi rend="italic">Gulflight</hi> torpedoed
                    off Scilly May 1. Please obtain detailed report and forward Department
                    immediately. Cabling American Consul Plymouth to-day for detailed report.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
