<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-05-25T16:00:00-05:00" frus:doc-dateTime-min="1915-05-25T16:00:00-05:00" n="59" subtype="historical-document" type="document" xml:id="d59">
                        <note rend="inline" type="source">File No. 704.6167/3</note>
                        <head>
                            <hi rend="italic">The Ambassador in Turkey</hi> (<persName corresp="#p_MH1" type="from"><hi rend="italic">Morgenthau</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Constantinople</hi></placeName>, <date calendar="gregorian" when="1915-05-25T23:00:00+02:00">
                                    <hi rend="italic">May 25, 1915, 11 p. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received June 1, 4.10 p.
                                m.</hi>]</dateline>
                        </opener>
                        <p>694. Your 701.<note n="1" xml:id="d59fn1">
                                <hi rend="italic">Ante</hi>, p.<ref target="#pg_36">36</ref>.</note>
                            Greatly prefer to decline care of Russian interests and hope you will
                            arrange my acting for Italy alone.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">American Ambassador</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>