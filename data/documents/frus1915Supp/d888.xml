    <text>
        <body>
            <div frus:doc-dateTime-max="1915-12-17T23:59:59-05:00"
                frus:doc-dateTime-min="1915-12-17T00:00:00-05:00" n="888"
                subtype="historical-document" type="document" xml:id="d888">
                <note rend="inline" type="source">File No. 865.857An2/83a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Italy</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-12-17">
                            <hi rend="italic">December 17, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>420. Obtain names of Americans on board <hi rend="italic">Ancona;</hi> obtain
                    names of Americans lost or injured on <hi rend="italic">Ancona</hi>. Cable
                    answer to the first question immediately, and answer to the second as soon as
                    possible.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
