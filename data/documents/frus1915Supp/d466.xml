    <text>
        <body>
            <div frus:doc-dateTime-max="1915-01-27T23:59:59-05:00"
                frus:doc-dateTime-min="1915-01-27T00:00:00-05:00" n="466"
                subtype="historical-document" type="document" xml:id="d466">
                <note rend="inline" type="source">File No. 300.115/2236</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                    <note n="1" xml:id="d466fn1">Communicated to the Swiss Minister January
                        30.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1915-01-27">
                            <hi rend="italic">January 27, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 4.30 p. m.</hi>]</dateline>
                </opener>
                <p>1536. Your 1015, January 22.<note n="2" xml:id="d466fn2">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_312">p. 312</ref>.</note>
                    Swiss Minister informs me he has practically secured the result he wishes.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">American Ambassador</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
