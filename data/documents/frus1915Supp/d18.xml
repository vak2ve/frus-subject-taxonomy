<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-03-01T06:00:00-05:00" frus:doc-dateTime-min="1915-03-01T06:00:00-05:00" n="18" subtype="historical-document" type="document" xml:id="d18">
                        <note rend="inline" type="source">File No. 763.72119/120</note>
                        <head>
                            <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="from"><hi rend="italic">Gerard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi><note n="1" xml:id="d18fn1">Repeated to the Ambassador in Great
                                Britain March 3.</note>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Berlin</hi></placeName>, <date calendar="gregorian" when="1915-03-01T12:00:00+01:00">
                                    <hi rend="italic">March 1, 1915, 12 noon</hi>.</date>
                                <lb/> [<hi rend="italic">Received March 2, 7.50 p.
                                m.</hi>]</dateline>
                        </opener>
                        <p>1714. We cannot send cipher to London, so please inform Colonel House
                            that <persName corresp="#p_JGEGV1">Von Jagow</persName>, Minister of
                            Foreign Affairs, said he hoped Colonel was coming to Berlin soon.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_GJW1">
                                    <hi rend="smallcaps">Gerard</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>