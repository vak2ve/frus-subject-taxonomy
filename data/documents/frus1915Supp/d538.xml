<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-04-19T23:59:59-05:00" frus:doc-dateTime-min="1915-04-19T00:00:00-05:00" n="538" subtype="historical-document" type="document" xml:id="d538">
                            <note rend="inline" type="source">File No. 341.115P51/39</note>
                            <head>
                                <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1915-04-19">
                                        <hi rend="italic">April 19, 1915</hi>.</date>
                                    <lb/> [<hi rend="italic">Received 5.55 p. m.</hi>]</dateline>
                            </opener>
                            <p>1955. Your 1421, 14th. Foreign Office informs me British Government
                                have decided to discharge the cargo on <persName>
                                    <hi rend="italic">Joseph W. Fordney</hi>
                                </persName> on ground that it is believed to be intended for
                                Germany.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">American Ambassador</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>