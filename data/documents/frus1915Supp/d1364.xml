    <text>
        <body>
            <div frus:doc-dateTime-max="1915-03-16T12:00:00-05:00"
                frus:doc-dateTime-min="1915-03-16T12:00:00-05:00" n="1364"
                subtype="historical-document" type="document" xml:id="d1364">
                <note rend="inline" type="source">File No. 763.72/1600</note>
                <head>
                    <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="from">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the</hi>
                    <gloss type="to">
                        <hi rend="italic">Secretary of State</hi>
                    </gloss>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1915-03-16T18:00:00+01:00">
                            <hi rend="italic">March 16, 1915, 6 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received March 17, 9.25 p. m.</hi>]</dateline>
                </opener>
                <p>565. Your 569, March 12, 5 p. m.<note n="2" xml:id="d1364fn2">See footnote 2, <hi
                            rend="italic">ante</hi>, <ref target="#pg_963">p. 963</ref>.</note> Had
                    satisfactory interview with the Minister for Foreign Affairs to-day on subject
                    your cable relative to possible massacres in Turkey.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
