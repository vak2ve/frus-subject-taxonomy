    <text>
        <body>
            <div frus:doc-dateTime-max="1915-01-29T23:59:59-05:00"
                frus:doc-dateTime-min="1915-01-29T00:00:00-05:00" n="244"
                subtype="historical-document" type="document" xml:id="d244">
                <note rend="inline" type="source">File No. 763.72112/673</note>
                <head>
                    <hi rend="italic">The Minister in the Netherlands</hi> (<persName
                        corresp="#p_VDH1" type="from">
                        <hi rend="italic">Van Dyke</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Hague</hi>
                        </placeName>, <date calendar="gregorian" when="1915-01-29">
                            <hi rend="italic">January 29, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 8.36 p. m.</hi>]</dateline>
                </opener>
                <p>132. American Ambassador London telegraphs:</p>
                <quote rend="blockquote">
                    <p>Foreign Office informs me cottonseed oil not on contraband list and hopes it
                        will not be placed there. Shipments from United States to Netherlands can go
                        forward without hindrance.</p>
                </quote>
                <p>Please inform Commerce Department.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_VDH1">
                            <hi rend="smallcaps">Van Dyke</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
