<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-09-01T23:59:59-05:00" frus:doc-dateTime-min="1915-09-01T00:00:00-05:00" n="1143" subtype="historical-document" type="document" xml:id="d1143">
                        <head>
                            <hi rend="italic">The</hi>
                            <gloss type="from">
                                <hi rend="italic">Secretary of State</hi>
                            </gloss>
                            <hi rend="italic">to the Russian Ambassador</hi> (<persName corresp="#p_BG1" type="to"><hi rend="italic">Bakhméteff</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-09-01">
                                    <hi rend="italic">September 1, 1915</hi>.</date>
                            </dateline>
                        </opener>
                        <p>Your telegram to-day regarding motor-boats. The collector of customs has
                            been instructed to allow exportation.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Robert Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>