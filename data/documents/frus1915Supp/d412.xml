<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-09-20T16:30:00-05:00" frus:doc-dateTime-min="1915-09-18T00:00:00-05:00" n="412" subtype="historical-document" type="document" xml:id="d412">
                            <note rend="inline" type="source">File No. 763.72112/1600</note>
                            <head>
                                <hi rend="italic">The Minister in the Netherlands</hi> (<persName corresp="#p_VDH1" type="from"><hi rend="italic">Van
                                    Dyke</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">The Hague</hi></placeName>, <date ana="#date_undated-inferred-from-document-content-and-sibling-dates" calendar="gregorian" notAfter="1915-09-20T16:30:00-05:00" notBefore="1915-09-18T00:00:00-05:00"><hi rend="italic">undated</hi></date>.<lb/>[<hi rend="italic">Received
                                        September 20, 1915, 4.30 p. m.</hi>]</dateline>
                            </opener>
                            <p>379. Your 199, 18th. Have endeavored obtain permission for
                                    <persName>Martin</persName> consignment. Oversea Trust declines
                                because present supply of these goods sufficient for Dutch
                                consumption.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_VDH1">
                                        <hi rend="smallcaps">Van Dyke</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>