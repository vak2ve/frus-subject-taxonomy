    <text>
        <body>
            <div frus:doc-dateTime-max="1915-11-01T08:15:00-05:00"
                frus:doc-dateTime-min="1915-10-26T17:00:00-05:00" n="1295"
                subtype="historical-document" type="document" xml:id="d1295">
                <note rend="inline" type="source">File No. 123Ei6/96</note>
                <head>
                    <hi rend="italic">The Special Agent in Bulgaria</hi> (<persName corresp="#p_EL1"
                        type="from">
                        <hi rend="italic">Einstein</hi>
                    </persName>) <hi rend="italic">to the</hi>
                    <gloss type="to">
                        <hi rend="italic">Secretary of State</hi>
                    </gloss>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Sofia</hi>
                        </placeName>, <date
                            ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                            calendar="gregorian" notAfter="1915-11-01T08:15:00-05:00"
                            notBefore="1915-10-27T00:00:00+02:00">
                            <hi rend="italic">undated</hi>
                        </date>.<lb/>[<hi rend="italic">Received November 1, 1915, 8.15 a.
                        m.</hi>]</dateline>
                </opener>
                <p>Have presented letters as Chargé d’Affaires.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_EL1">
                            <hi rend="smallcaps">Einstein</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
