                subtype="historical-document" type="document" xml:id="d207">
                <note rend="inline" type="source">File No. 763.72/1659</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1915-04-07T14:00:00+00:00">
                            <hi rend="italic">April 7, 1915, 2 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 7 p. m.</hi>]</dateline>
                </opener>
                <p>1892. Practically all newspaper comment on note is friendly and shows
                    appreciation of the American position. The worst that is said <pb facs="0417"
                        n="159" xml:id="pg_159"/> is that it is a discussion in a vacuum a sort of
                    lawyer’s brief. Every indication yet at hand shows that it is well received by
                    British press and public. I have yet heard no official opinion.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">American Ambassador</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
