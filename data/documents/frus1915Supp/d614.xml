<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-05-28T23:59:59-05:00" frus:doc-dateTime-min="1915-05-28T00:00:00-05:00" n="614" subtype="historical-document" type="document" xml:id="d614">
                            <note rend="inline" type="source">File No. 763.72/1826</note>
                            <head>
                                <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="from"><hi rend="italic">Gerard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Berlin</hi></placeName>, <date calendar="gregorian" when="1915-05-28">
                                        <hi rend="italic">May 28, 1915</hi>.</date>
                                    <lb/> [<hi rend="italic">Received May 30, 9 a.
                                    m.</hi>]</dateline>
                            </opener>
                            <p>2320. Best naval sources state no change will be made in method of
                                submarine blockade even if consequences involve war between Germany
                                and United States.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_GJW1">
                                        <hi rend="smallcaps">Gerard</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                    </body></text></TEI>