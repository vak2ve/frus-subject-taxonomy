<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-09-11T17:00:00-05:00" frus:doc-dateTime-min="1915-09-11T17:00:00-05:00" n="269" subtype="historical-document" type="document" xml:id="d269">
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-09-11T17:00:00-05:00">
                                        <hi rend="italic">September 11, 1915, 5 p. m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>2102. Department’s 2072, September 4.<note n="2" xml:id="d269fn2">See
                                    footnote 1.</note> Department reliably informed Mediterranean
                                fruits freely entering Netherlands and also free for transit to
                                Germany. It appears unjust to restrict free transit of American
                                fruits.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>