    <text>
        <body>
            <div frus:doc-dateTime-max="1915-10-30T07:00:00-05:00"
                frus:doc-dateTime-min="1915-10-30T07:00:00-05:00" n="423"
                subtype="historical-document" type="document" xml:id="d423">
                <note rend="inline" type="source">File No. 763.72112/1813</note>
                <head>
                    <hi rend="italic">The Minister in Sweden</hi> (<persName corresp="#p_MIN1"
                        type="from">
                        <hi rend="italic">Morris</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Stockholm</hi>
                        </placeName>, <date calendar="gregorian" when="1915-10-30T13:00:00+01:00">
                            <hi rend="italic">October 30, 1915, 1 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 11 p. m.</hi>]</dateline>
                </opener>
                <p>68. Negotiations have been definitely broken off between Swedish and English
                    trade commissions.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MIN1">
                            <hi rend="smallcaps">Morris</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
