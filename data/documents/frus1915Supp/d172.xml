                subtype="historical-document" type="document" xml:id="d172">
                <note rend="inline" type="source">File No. 763.72/1561a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Italy</hi> (<persName corresp="#p_PTN1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-02-27T14:00:00-05:00">
                            <hi rend="italic">February 27, 1915, 2 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>170. Press carries a despatch from Rome saying that Germany’s reply to Italy’s
                    memorandum regarding the war zone decree gives assurances that Germany will
                    respect the Italian flag. Please report if this is true.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
