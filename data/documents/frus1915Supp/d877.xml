<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-12-10T15:20:00-05:00" frus:doc-dateTime-min="1915-12-10T02:00:00-05:00" n="877" subtype="historical-document" type="document" xml:id="d877">
                            <note rend="inline" type="source">File No. 300.115P44/2</note>
                            <head>
                                <hi rend="italic">The Consul at Algiers</hi> (<persName corresp="#p_MDB1" type="from"><hi rend="italic">Mason</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Algiers</hi></placeName>, <date ana="#date_undated-inferred-from-document-content" calendar="gregorian" notAfter="1915-12-10T15:20:00-05:00" notBefore="1915-12-10T07:00:00+00:00" when="1915-12-10">
                                        <hi rend="italic">undated</hi>
                                    </date>.<lb/>[<hi rend="italic">Received December 10, 1915, 3.20
                                        p. m.</hi>]</dateline>
                            </opener>
                            <p>American steamer <hi rend="italic">Petrolite</hi> arrived Algiers 7
                                a. m., December 10. Captain reports vessel attacked nineteen hours
                                from Alexandria by submarine flying Austrian flag. One seaman
                                wounded by shell. After examination papers and forcibly taking
                                provisions vessel allowed to proceed.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_MDB1">
                                        <hi rend="smallcaps">Mason</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>