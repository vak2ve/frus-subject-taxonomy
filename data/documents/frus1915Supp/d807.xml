    <text>
        <body>
            <div frus:doc-dateTime-max="1915-09-22T23:59:59-05:00"
                frus:doc-dateTime-min="1915-09-22T00:00:00-05:00" n="807"
                subtype="historical-document" type="document" xml:id="d807">
                <note rend="inline" type="source">File No. 763.72112/1574</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at London</hi> (<persName corresp="#p_SRP1" type="to">
                        <hi rend="italic">Skinner</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">No. 420]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-09-22">
                            <hi rend="italic">September 22, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has received your despatch No. 664
                    of August 17, 1915,<note n="1" xml:id="d807fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_546">p. 546</ref>.</note>
                    together with its enclosure, relative to the demand upon claimants to refrain
                    from asking for compensation, and approves of the tenor of the communication
                    addressed by you to the procurator general.</p>
                <p>I am [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Wilbur J. Carr</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
