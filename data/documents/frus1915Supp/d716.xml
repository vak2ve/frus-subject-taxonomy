<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-07-31T23:59:59-05:00" frus:doc-dateTime-min="1915-07-31T00:00:00-05:00" n="716" subtype="historical-document" type="document" xml:id="d716">
                            <note rend="inline" type="source">File No. 841.857Ib3</note>
                            <head>
                                <hi rend="italic">The Consul at Cork</hi> (<persName corresp="#p_FW1" type="from"><hi rend="italic">Frost</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Queenstown</hi></placeName>, <date ana="#date_undated-inferred-from-document-content" calendar="gregorian" when="1915-07-31"><hi rend="italic">undated</hi></date>.<lb/>[<hi rend="italic">Received
                                        July 31, 1915, 11 a. m.</hi>]</dateline>
                            </opener>
                            <p>Steamer <hi rend="italic">Iberian</hi> submarined. Wiley, American
                                muleteer, killed.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_FW1">
                                        <hi rend="smallcaps">Frost</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>