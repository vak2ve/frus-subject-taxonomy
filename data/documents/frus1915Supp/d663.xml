<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-07-03T23:59:59-05:00" frus:doc-dateTime-min="1915-07-03T00:00:00-05:00" n="663" subtype="historical-document" type="document" xml:id="d663">
                            <note rend="inline" type="source">File No. 841.115R221/5</note>
                            <head>
                                <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1915-07-03">
                                        <hi rend="italic">July 3, 1915</hi>.</date>
                                    <lb/> [<hi rend="italic">Received 11.55 a. m.</hi>]</dateline>
                            </opener>
                            <p>2499. Department’s 1681, June 8, <hi rend="italic">re
                                    Helge</hi>.<note n="2" xml:id="d663fn2">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_434">p.
                                    434</ref>.</note> Foreign Office informs me this matter
                                receiving careful attention of British Government.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">American Ambassador</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>