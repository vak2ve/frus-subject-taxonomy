    <text>
        <body>
            <div frus:doc-dateTime-max="1915-10-12T11:41:00-05:00"
                frus:doc-dateTime-min="1915-10-12T11:41:00-05:00" n="1415"
                subtype="historical-document" type="document" xml:id="d1415">
                <note rend="inline" type="source">File No. 867.4016/163</note>
                <head>
                    <hi rend="italic">The Minister in the Netherlands</hi> (<persName
                        corresp="#p_VDH1" type="from">
                        <hi rend="italic">Van Dyke</hi>
                    </persName>) <hi rend="italic">to the</hi>
                    <gloss type="to">
                        <hi rend="italic">Secretary of State</hi>
                    </gloss>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Hague</hi>
                        </placeName>, <date calendar="gregorian" when="1915-10-12T17:00:00+00:19">
                            <hi rend="italic">October 12, 1915, 5 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received October 13, 8.30 a. m.</hi>]</dateline>
                </opener>
                <p>400. The Minister of Foreign Affairs told me yesterday that he would instruct the
                    Netherlands Minister at Constantinople to confer with the United States
                    Ambassador in support of efforts to prevent reported Armenian atrocities.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_VDH1">
                            <hi rend="smallcaps">Van Dyke</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
