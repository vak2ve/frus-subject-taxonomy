<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-07-20T23:59:59-05:00" frus:doc-dateTime-min="1915-07-20T00:00:00-05:00" n="1404" subtype="historical-document" type="document" xml:id="d1404">
                        <note rend="inline" type="source">File No. 867.4016/79</note>
                        <head>
                            <hi rend="italic">The Ambassador in Turkey</hi> (<persName corresp="#p_MH1" type="from"><hi rend="italic">Morgenthau</hi></persName>) <hi rend="italic">to the</hi>
                            <gloss type="to">
                                <hi rend="italic">Secretary of State</hi>
                            </gloss>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Constantinople</hi></placeName>, <date calendar="gregorian" when="1915-07-20">
                                    <hi rend="italic">July 20, 1915, noon</hi>.</date>
                                <lb/> [<hi rend="italic">Received July 23, 8.20 a.
                                m.</hi>]</dateline>
                        </opener>
                        <p>866. Your telegram 865. Embassy has not heard of any injuries to native
                            or naturalized citizens of the United States.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">American Ambassador</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>