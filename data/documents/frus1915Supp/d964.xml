    <text>
        <body>
            <div frus:doc-dateTime-max="1915-06-12T23:59:59-05:00"
                frus:doc-dateTime-min="1915-06-12T00:00:00-05:00" n="964"
                subtype="historical-document" type="document" xml:id="d964">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> ad interim
                        to the <gloss type="to">Consuls at Liverpool and Christiania</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-06-12">
                            <hi rend="italic">June 12, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>Department of Commerce requests you be informed transfer steamer <hi
                        rend="italic">Lapland</hi>
                    <note n="2" xml:id="d964fn2">Bought by the American Transatlantic
                        Company.</note> to American flag cannot be recognized since vessel was not
                    purchased by money furnished by American citizens.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
