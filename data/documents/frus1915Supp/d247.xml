<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-02-11T23:59:59-05:00" frus:doc-dateTime-min="1915-02-11T00:00:00-05:00" n="247" subtype="historical-document" type="document" xml:id="d247">
                            <note rend="inline" type="source">File No. 763.72112/713</note>
                            <head>
                                <hi rend="italic">
                                    <persName type="from">Knauth, Nachod and Kuhne</persName> to the
                                        <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">New York</hi></placeName>, <date calendar="gregorian" when="1915-02-11">
                                        <hi rend="italic">February 11, 1915</hi>.</date>
                                </dateline>
                            </opener>
                            <p>May we safely ship cotton linters as non-contraband goods same as
                                cotton to Bremen?</p>
                            <closer>
                                <persName>
                                    <hi rend="smallcaps">Knauth, Nachod and Kuhne</hi>
                                </persName>
                            </closer>
                        </div>
                        </body></text></TEI>