                <note rend="inline" type="source">File No. 763.72112/713</note>
                <head>
                    <hi rend="italic">
                        <persName type="from">Knauth, Nachod and Kuhne</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">New York</hi>
                        </placeName>, <date calendar="gregorian" when="1915-02-11">
                            <hi rend="italic">February 11, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>May we safely ship cotton linters as non-contraband goods same as cotton to
                    Bremen?</p>
                <closer>
                    <persName>
                        <hi rend="smallcaps">Knauth, Nachod and Kuhne</hi>
                    </persName>
                </closer>
            </div>
        </body>
    </text>
