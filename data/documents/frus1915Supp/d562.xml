    <text>
        <body>
            <div frus:doc-dateTime-max="1915-05-07T23:59:59-05:00"
                frus:doc-dateTime-min="1915-05-07T00:00:00-05:00" n="562"
                subtype="historical-document" type="document" xml:id="d562">
                <note rend="inline" type="source">File No. 300.115G95/9</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1915-05-07">
                            <hi rend="italic">May 7, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 10.45 p. m.</hi>]</dateline>
                </opener>
                <p>2175. Department’s 1612, 3d.<note n="1" xml:id="d562fn1">See footnote 1, <hi
                            rend="italic">ante</hi>, <ref target="#pg_378">p. 378</ref>.</note>
                    German Admiralty has as yet no news as to <hi rend="italic">Gulflight</hi>. Will
                    report as soon as information obtained.<note n="2" xml:id="d562fn2">The
                        statement of the German Government is contained in the note of June 1,
                        transmitted by the Ambassador in Germany in his telegram No. 2346 of the
                        same date, <hi rend="italic">post,</hi>
                        <ref target="#pg_431">p. 431</ref>.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
