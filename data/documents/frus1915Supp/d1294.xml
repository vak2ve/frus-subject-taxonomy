<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-10-27T23:59:59-05:00" frus:doc-dateTime-min="1915-10-27T00:00:00-05:00" n="1294" subtype="historical-document" type="document" xml:id="d1294">
                        <note rend="inline" type="source">File No. 123Ei6/94</note>
                        <head>
                            <hi rend="italic">The</hi>
                            <gloss type="from">
                                <hi rend="italic">Secretary of State</hi>
                            </gloss>
                            <hi rend="italic">to the Minister in Roumania, Servia, and Bulgaria</hi>
                                (<persName corresp="#p_VCJ1" type="to"><hi rend="italic">Vopicka</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram—Extract]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-10-27">
                                    <hi rend="italic">October 27, 1915</hi>.</date>
                            </dateline>
                        </opener>
                        <p>176. Department’s 161 and your 157, October 22.<note n="2" xml:id="d1294fn2">Latter not printed.</note>
                            <persName corresp="#p_EL1">Einstein</persName> appointed special agent
                            to assist you in caring for British interests in Bulgaria with
                            headquarters at Sofia and not Chargé d’Affaires on special mission. So
                            inform Bulgarian Government.…</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>