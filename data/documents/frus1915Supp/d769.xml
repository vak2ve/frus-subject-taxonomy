    <text>
        <body>
            <div frus:doc-dateTime-max="1915-09-01T23:59:59-05:00"
                frus:doc-dateTime-min="1915-09-01T00:00:00-05:00" n="769"
                subtype="historical-document" type="document" xml:id="d769">
                <note rend="inline" type="source">File No. 763.72/2085</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1915-09-01">
                            <hi rend="italic">September 1, 1915, noon.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received September 2, noon.</hi>]</dateline>
                </opener>
                <p>2817. Believe German Government only working for delay until Balkan situation
                    well in hand. Suggest the sooner your demands are made the greater the
                    probability that the demands will be granted.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
