<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-10-05T12:26:00-05:00" frus:doc-dateTime-min="1915-10-05T12:26:00-05:00" n="82" subtype="historical-document" type="document" xml:id="d82">
                        <note rend="inline" type="source">File No. 868.002/18</note>
                        <head>
                            <hi rend="italic">The Minister in Greece</hi> (<persName corresp="#p_DG1" type="from"><hi rend="italic">Droppers</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Athens</hi></placeName>, <date calendar="gregorian" when="1915-10-05T19:00:00+01:34">
                                    <hi rend="italic">October 5, 1915, 7 p. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received October 6, 8.30 a.
                                m.</hi>]</dateline>
                        </opener>
                        <p>59. Prime Minister resigned. Situation critical.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_DG1">
                                    <hi rend="smallcaps">Droppers</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
