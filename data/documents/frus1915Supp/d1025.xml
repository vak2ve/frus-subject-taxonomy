<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-08-06T23:59:59-05:00" frus:doc-dateTime-min="1915-08-06T00:00:00-05:00" n="1025" subtype="historical-document" type="document" xml:id="d1025">
                        <note rend="inline" type="source">File No. 841.731/699</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-08-06">
                                    <hi rend="italic">August 6, 1915</hi>.</date>
                            </dateline>
                        </opener>
                        <p>1954. Your 2447 July 13, 4 p. m. Please continue to follow as closely as
                            possible Department’s mailed instruction 1168, June 25.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>