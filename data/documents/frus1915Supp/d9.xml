                subtype="historical-document" type="document" xml:id="d9">
                <note rend="inline" type="source">File No. 763.72119/44</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1915-02-12T12:00:00+01:00">
                            <hi rend="italic">February 12, 1915, 12 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received February 13, 7.30 p. m.</hi>]</dateline>
                </opener>
                <p>1587. Referring to my cipher telegram 1579<note n="2" xml:id="d9fn2">See
                        following telegram.</note> yesterday, suggest <persName>Colonel
                        House</persName> may be great help especially in England and if you
                    authorize me as requested will communicate with him.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
