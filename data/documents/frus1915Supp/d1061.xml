                subtype="historical-document" type="document" xml:id="d1061">
                <note rend="inline" type="source">File No. 124.0665/7</note>
                <head>
                    <hi rend="italic">The Ambassador in Turkey</hi> (<persName corresp="#p_MH1"
                        type="from">
                        <hi rend="italic">Morgenthau</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Constantinople</hi>
                        </placeName>, <date calendar="gregorian" when="1915-01-17T15:00:00+02:00">
                            <hi rend="italic">January 17, 1915, 3 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received January 18, 8.30 a. m.</hi>]</dateline>
                </opener>
                <p>306. Your 71, November 25,<note n="2" xml:id="d1061fn1">
                        <ref target="frus1914Supp#pg_542">
                            <hi rend="italic">Foreign Relations</hi>, 1914, Supplement, p.
                        542</ref>.</note> and your 262 of the 13th instant.<note n="1"
                        xml:id="d1061fn2">Not printed.</note> Note received from Foreign Office
                    stating that, owing to the extreme gravity of the present situation, decisions
                    now in force (enclosure No. 2, despatch 137, November 28<note n="1"
                        xml:id="d1061fn3">Not printed.</note>) regarding restrictions of sealed
                    official correspondence cannot be changed. By these decisions military
                    commanders of districts where military movement is taking place are empowered to
                    stop all sealed official correspondence between consulates and embassy, etc.
                    Will file protest.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">American Ambassador</hi>
                    </signed>
                </closer>
            </div>
        </body>
