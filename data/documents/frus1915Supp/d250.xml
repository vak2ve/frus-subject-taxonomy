<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-02-24T23:59:59-05:00" frus:doc-dateTime-min="1915-02-24T00:00:00-05:00" n="250" subtype="historical-document" type="document" xml:id="d250">
                            <note rend="inline" type="source">File No. 763.72112/762</note>
                            <head>
                                <hi rend="italic">The Consul General at London</hi> (<persName corresp="#p_SRP1" type="from"><hi rend="italic">Skinner</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1915-02-24">
                                        <hi rend="italic">February 24, 1915</hi>.</date>
                                    <lb/> [<hi rend="italic">Received 9.30 a. m.</hi>]</dateline>
                            </opener>
                            <p>Department’s 23d. Cotton linters are not contraband.<note n="1" xml:id="d250fn1">Letters conveying this information were
                                    dispatched to sixty interested persons and firms.</note>
                            </p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_SRP1">
                                        <hi rend="smallcaps">Skinner</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>