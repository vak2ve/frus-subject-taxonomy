<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-02-23T23:59:59-05:00" frus:doc-dateTime-min="1915-02-23T00:00:00-05:00" n="249" subtype="historical-document" type="document" xml:id="d249">
                            <note rend="inline" type="source">File No. 763.72112/762a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Consul General at London</hi> (<persName corresp="#p_SRP1" type="to"><hi rend="italic">Skinner</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-02-23">
                                        <hi rend="italic">February 23, 1915</hi>.</date>
                                </dateline>
                            </opener>
                            <p>Are cotton linters considered contraband? Answer quickly.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_BWJ1">
                                        <hi rend="smallcaps">Bryan</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>