    <text>
        <body>
            <div frus:doc-dateTime-max="1915-09-06T09:41:00-05:00"
                frus:doc-dateTime-min="1915-09-06T09:41:00-05:00" n="1286"
                subtype="historical-document" type="document" xml:id="d1286">
                <head>
                    <hi rend="italic">The Minister the Netherlands</hi> (<persName corresp="#p_VDH1"
                        type="from">
                        <hi rend="italic">Van Dyke</hi>
                    </persName>) <hi rend="italic">to the</hi>
                    <gloss type="to">
                        <hi rend="italic">Secretary of State</hi>
                    </gloss>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Hague</hi>
                        </placeName>, <date calendar="gregorian" when="1915-09-06T15:00:00+00:19">
                            <hi rend="italic">September 6, 1915, 3 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 5.40 p. m.</hi>]</dateline>
                </opener>
                <p>364. Your September 2, 11 a. m. I have complied with your instruction. <persName
                        corresp="#p_AJFJ1">Archibald</persName> expects to sail for New York on the
                    steamer <hi rend="italic">Rotterdam</hi> September 8.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_VDH1">
                            <hi rend="smallcaps">Van Dyke</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
