    <text>
        <body>
            <div frus:doc-dateTime-max="1915-09-24T23:59:59-05:00"
                frus:doc-dateTime-min="1915-09-24T00:00:00-05:00" n="78"
                subtype="historical-document" type="document" xml:id="d78">
                <note rend="inline" type="source">File No. 763.72/2148</note>
                <head>
                    <hi rend="italic">The Minister in Roumania, Servia, and Bulgaria</hi> (<persName
                        corresp="#p_VCJ1" type="from">
                        <hi rend="italic">Vopicka</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bucharest</hi>
                        </placeName>, <date calendar="gregorian" when="1915-09-24">
                            <hi rend="italic">September 24, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 6.50 p. m.</hi>]</dateline>
                </opener>
                <p>138. Bulgarian mobilization officially announced.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_VCJ1">
                            <hi rend="smallcaps">Vopicka</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
