                subtype="historical-document" type="document" xml:id="d32">
                <note rend="inline" type="source">File No. 763.72119/54</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1915-04-25T14:00:00+01:00">
                            <hi rend="italic">April 25, 1915, 2 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received April 26, 10.15 a. m.</hi>]</dateline>
                </opener>
                <p>2110. Statement stated to be half official is published to-day to the effect that
                    rumors of peace are without foundation and that there will <pb facs="0288"
                        n="30" xml:id="pg_30"/> be no peace until the object of the war as set forth
                    in Chancellor’s speeches has been attained.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
