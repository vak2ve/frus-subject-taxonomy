    <text>
        <body>
            <div frus:doc-dateTime-max="1915-02-02T23:59:59-05:00"
                frus:doc-dateTime-min="1915-02-02T00:00:00-05:00" n="1313"
                subtype="historical-document" type="document" xml:id="d1313">
                <note rend="inline" type="source">File No. 702.6211/203</note>
                <head>
                    <hi rend="italic">The German Ambassador</hi> (<persName corresp="#p_BJHACV1"
                        type="from">
                        <hi rend="italic">Bernstorff</hi>
                    </persName>) <hi rend="italic">to the</hi>
                    <gloss type="to">
                        <hi rend="italic">Secretary of State</hi>
                    </gloss>
                </head>
                <opener>
                    <seg rendition="#center">[Translation—Extract]</seg>
                </opener>
                <opener>
                    <seg rendition="#left">J. Nr. B 1448]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-02-02">
                            <hi rend="italic">February 2, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received February 4</hi>.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: I have the honor to inform
                    your excellency, in connection with your esteemed note of the 14th ultimo—No.
                    1183—that the Imperial Consul in Seattle, Washington, Herr von Loehneysen, has
                    been recalled from his post.…</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BJHACV1">
                            <hi rend="smallcaps">J. Bernstorff</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
