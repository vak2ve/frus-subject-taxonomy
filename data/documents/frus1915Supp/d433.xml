    <text>
        <body>
            <div frus:doc-dateTime-max="1915-11-23T23:59:59-05:00"
                frus:doc-dateTime-min="1915-11-23T00:00:00-05:00" n="433"
                subtype="historical-document" type="document" xml:id="d433">
                <note rend="inline" type="source">File No. 763.72112/1917</note>
                <head>
                    <hi rend="italic">The Vice Consul at London</hi> (<persName corresp="#p_WR1"
                        type="from">
                        <hi rend="italic">Westacott</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1915-11-23">
                            <hi rend="italic">November 23, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 10.50 a. m.</hi>]</dateline>
                </opener>
                <p>Foreign Office announces Swiss import trust called Société Suisse de Surveillance
                    Economique commenced operations November 16 as only authorized consignee in
                    Switzerland of contraband and prohibited exports from Allies. Articles for
                    exportation of which British licenses granted previous to 16th November may
                    proceed notwithstanding.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WR1">
                            <hi rend="smallcaps">Westacott</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
