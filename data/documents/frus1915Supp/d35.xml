<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-04-29T16:00:00-05:00" frus:doc-dateTime-min="1915-04-29T16:00:00-05:00" n="35" subtype="historical-document" type="document" xml:id="d35">
                        <note rend="inline" type="source">File No. 763.72/1714a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Italy</hi> (<persName corresp="#p_PTN1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-04-29T16:00:00-05:00">
                                    <hi rend="italic">April 29, 1915, 4 p. m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>207. Please keep Department advised as much as possible, but entirely at
                            your own discretion, regarding status of negotiations between Italy and
                            Austria.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BWJ1">
                                    <hi rend="smallcaps">Bryan</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>