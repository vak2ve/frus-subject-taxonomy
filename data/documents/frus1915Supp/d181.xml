                subtype="historical-document" type="document" xml:id="d181">
                <note rend="inline" type="source">File No. 763.72/1517</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="to">
                        <hi rend="italic">Gerard</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-03-02T17:00:00-05:00">
                            <hi rend="italic">March 2, 1915, 5 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1305. Department regrets it cannot accept suggestion contained in your 1710,
                    February 27.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
