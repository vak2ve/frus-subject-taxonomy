                subtype="historical-document" type="document" xml:id="d1455">
                <note rend="inline" type="source">File No. 763.72114/399</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the</hi>
                    <gloss type="to">
                        <hi rend="italic">Secretary of State</hi>
                    </gloss>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1915-04-16T19:00:00+01:00">
                            <hi rend="italic">April 16, 1915, 7 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received April 17, 6 p. m.</hi>]</dateline>
                </opener>
                <p>2064. Department’s 1479, April 7.<note n="2" xml:id="d1455fn1">See footnote 1,
                            <hi rend="italic">supra</hi>.</note> I have now received written
                    assurances from the Imperial Foreign Office that the assent of the British
                    Government to the German Government’s scheme regarding camp inspection
                    telegraphed to you in my 1824, March 11, is understood.<note n="3"
                        xml:id="d1455fn2">Transmitted to the Ambassador in Great Britain, April 21,
                        No. 1449.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
