<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-10-18T23:59:59-05:00" frus:doc-dateTime-min="1915-10-18T00:00:00-05:00" n="90" subtype="historical-document" type="document" xml:id="d90">
                        <note rend="inline" type="source">File No. 763.72/2194</note>
                        <head>
                            <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_SWG1" type="from"><hi rend="italic">Sharp</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1915-10-18">
                                    <hi rend="italic">October 18, 1915</hi>.</date>
                                <lb/> [<hi rend="italic">Received 5.30 p. m.</hi>]</dateline>
                        </opener>
                        <p>1051. <hi rend="italic">Journal officiel</hi> of to-day contains
                            following declaration of war:<quote rend="blockquote">
                                <p>Bulgaria having entered into action on the side of the enemies
                                    and against one of the allies of France, the Government of the
                                    Republic declares that a state of war exists between France and
                                    Bulgaria from October 16, 1915, 6 a. m., through the act of
                                    Bulgaria.</p>
                            </quote>
                        </p>
                        <closer>
                            <signed>
                                <persName corresp="#p_SWG1">
                                    <hi rend="smallcaps">Sharp</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>