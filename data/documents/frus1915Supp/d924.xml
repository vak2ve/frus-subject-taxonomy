<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-02-26T08:00:00-05:00" frus:doc-dateTime-min="1915-02-22T09:00:00-05:00" n="924" subtype="historical-document" type="document" xml:id="d924">
                        <note rend="inline" type="source">File No. 611.479/153</note>
                        <head>
                            <hi rend="italic">The Consul General at Sydney</hi> (<persName corresp="#p_BJP1" type="from"><hi rend="italic">Bray</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Sydney</hi></placeName>, <date ana="#date_undated-inferred-from-document-content-and-sibling-dates" calendar="gregorian" notAfter="1915-02-26T08:00:00-05:00" notBefore="1915-02-23T00:00:00+10:00">
                                    <hi rend="italic">undated</hi>
                                </date>.<lb/>[<hi rend="italic">Received February 26, 1915, 8 a.
                                    m.</hi>]</dateline>
                        </opener>
                        <p>Commonwealth government advises shipment merino wool United States may
                            now be made as previously provided.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BJP1">
                                    <hi rend="smallcaps">Bray</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>