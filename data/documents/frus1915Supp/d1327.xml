                subtype="historical-document" type="document" xml:id="d1327">
                <note rend="inline" type="source">File No. 701.6311/156</note>
                <head>
                    <hi rend="italic">The</hi>
                    <gloss type="from">
                        <hi rend="italic">Acting Secretary of State</hi>
                    </gloss>
                    <hi rend="italic">to the Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="to">
                        <hi rend="italic">Penfield</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-09-22T21:00:00-05:00">
                            <hi rend="italic">September 22, 1915, 9 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>910. To-day Doctor <persName corresp="#p_DCT1">Dumba</persName> informs
                    Department leave of absence granted him officially by his Government. He
                    requests safe-conduct for himself and Madame <persName corresp="#p_DCT1"
                        >Dumba</persName> on steamship <hi rend="italic">Rotterdam</hi>, sailing
                    September 28. Department has replied that it is still await a definite reply
                    from Vienna to its note of September 8, requesting his recall. Urge an immediate
                    reply.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
