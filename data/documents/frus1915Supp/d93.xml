    <text>
        <body>
            <div frus:doc-dateTime-max="1915-10-30T09:00:00-05:00"
                frus:doc-dateTime-min="1915-10-30T09:00:00-05:00" n="93"
                subtype="historical-document" type="document" xml:id="d93">
                <note rend="inline" type="source">File No. 763.72/2225</note>
                <head>
                    <hi rend="italic">The Minister in Switzerland</hi> (<persName corresp="#p_SPA1"
                        type="from">
                        <hi rend="italic">Stovall</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berne</hi>
                        </placeName>, <date calendar="gregorian" when="1915-10-30T15:00:00+01:00">
                            <hi rend="italic">October 30, 1915, 3 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 10.30 p. m.</hi>]</dateline>
                </opener>
                <p>217. Former Chancellor <persName corresp="#p_BBHKMPV1">Von Bülow</persName> this
                    week is in Switzerland. Revives rumor circulated that Germany is making offers
                    to Italy to withdraw from the war.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SPA1">Stovall</persName>
                    </signed>
                </closer>
            </div>
        </body>
