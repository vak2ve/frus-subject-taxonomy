                subtype="historical-document" type="document" xml:id="d961">
                <note rend="inline" type="source">File No. 195.1/426</note>
                <head>
                    <hi rend="italic">The Consul General at Copenhagen</hi> (<persName
                        corresp="#p_WED1" type="from">
                        <hi rend="italic">Winslow</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Copenhagen</hi>
                        </placeName>, <date
                            ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                            calendar="gregorian" notAfter="1915-05-17T23:35:00-05:00"
                            notBefore="1915-04-29T00:00:00+01:00">
                            <hi rend="italic">undated</hi>
                        </date>.<lb/>[<hi rend="italic">Received May 17, 1915, 11:35 p.
                        m.</hi>]</dateline>
                </opener>
                <p>American Transatlantic Company, incorporated laws Delaware, purchasing Danish
                    steamers different ports through authorized agent here. Unless otherwise
                    instructed shall issue Form 35.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WED1">
                            <hi rend="smallcaps">Winslow</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
