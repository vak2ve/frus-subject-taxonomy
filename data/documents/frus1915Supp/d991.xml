                subtype="historical-document" type="document" xml:id="d991">
                <note rend="inline" type="source">File No. 841.731/308</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-02-02">
                            <hi rend="italic">February 2, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>1061. Your 1570, February 1. Unless otherwise advised by you, Department will
                    continue sending copies stopped telegrams which you may in your discretion
                    submit to British authorities. Department still in receipt of many complaints,
                    but feels you have done all possible for the present.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
