    <text>
        <body>
            <div frus:doc-dateTime-max="1915-06-14T23:59:59-05:00"
                frus:doc-dateTime-min="1915-06-14T00:00:00-05:00" n="1423"
                subtype="historical-document" type="document" xml:id="d1423">
                <note rend="inline" type="source">File No. 763.72/1872</note>
                <head>
                    <hi rend="italic">The Ambassador in Russia</hi> (<persName corresp="#p_MGT1"
                        type="from">
                        <hi rend="italic">Marye</hi>
                    </persName>) <hi rend="italic">to the</hi>
                    <gloss type="to">
                        <hi rend="italic">Secretary of State</hi>
                    </gloss>
                    <note n="1" xml:id="d1423fn1">Communicated to the German Ambassador, June 18
                        (No. 1468).</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Petrograd</hi>
                        </placeName>, <date calendar="gregorian" when="1915-06-14">
                            <hi rend="italic">June 14, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received June 15, 11.25 p. m.</hi>]</dateline>
                </opener>
                <p>193. Department’s 349, May 26th. Russian Government does not find it possible to
                    liberate German subjects taken prisoner by Russian troops on Persian
                    territory.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MGT1">
                            <hi rend="smallcaps">Marye</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
