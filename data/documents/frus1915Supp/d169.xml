<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-02-25T23:59:59-05:00" frus:doc-dateTime-min="1915-02-25T00:00:00-05:00" n="169" subtype="historical-document" type="document" xml:id="d169">
                            <note rend="inline" type="source">File No. 763.72/1484</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Italy</hi> (<persName corresp="#p_PTN1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-02-25">
                                        <hi rend="italic">February 25, 1915</hi>.</date>
                                </dateline>
                            </opener>
                            <p>168. Your 191, 19th.<note n="1" xml:id="d169fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_117">p.
                                    117</ref>.</note> Department conferring daily with
                                representatives of neutrals on subject of your telegram.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_BWJ1">
                                        <hi rend="smallcaps">Bryan</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
