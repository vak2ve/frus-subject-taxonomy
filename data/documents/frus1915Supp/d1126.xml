<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-05-03T23:59:59-05:00" frus:doc-dateTime-min="1915-05-03T00:00:00-05:00" n="1126" subtype="historical-document" type="document" xml:id="d1126">
                        <note rend="inline" type="source">File No. 763.72111/2122</note>
                        <head>
                            <hi rend="italic">The German Ambassador</hi> (<persName corresp="#p_BJHACV1" type="from"><hi rend="italic">Bernstorff</hi></persName>) <hi rend="italic">to the</hi>
                            <gloss type="to">
                                <hi rend="italic">Secretary of State</hi>
                            </gloss>
                        </head>
                        <opener>
                            <seg rendition="#center">[Translation]</seg>
                        </opener>
                        <opener>
                            <seg rendition="#left">J. Nr. A 3090]</seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-05-03">
                                    <hi rend="italic">May 3, 1915</hi>.</date>
                                <lb/> [<hi rend="italic">Received May 4</hi>.]</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Mr. Secretary of State</hi>: It is reported in the
                            press that English officers are supervising the manufacture of arms and
                            ammunition ordered in this country by Great Britain in the factories
                            here, the works of the Bethlehem Steel Company among others.</p>
                        <p>I should be thankful to your excellency if you would kindly ascertain and
                            inform me whether this press report is true.</p>
                        <p>Accept [etc.]</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BJHACV1">
                                    <hi rend="smallcaps">J. Bernstorff</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>