<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-02-16T23:59:59-05:00" frus:doc-dateTime-min="1915-02-16T00:00:00-05:00" n="478" subtype="historical-document" type="document" xml:id="d478">
                            <note rend="inline" type="source">File No. 763.72112/699</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-02-16">
                                        <hi rend="italic">February 16, 1915</hi>.</date>
                                </dateline>
                            </opener>
                            <p>1138. Your 1607, 8th.<note n="1" xml:id="d478fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_322">p.
                                    322</ref>.</note> Order prohibiting publication ship manifests
                                until after thirty days has been rescinded.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_BWJ1">
                                        <hi rend="smallcaps">Bryan</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>