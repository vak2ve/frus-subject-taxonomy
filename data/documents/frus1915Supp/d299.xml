    <text>
        <body>
            <div frus:doc-dateTime-max="1915-05-17T23:59:59-05:00"
                frus:doc-dateTime-min="1915-05-17T00:00:00-05:00" n="299"
                subtype="historical-document" type="document" xml:id="d299">
                <note rend="inline" type="source">File No. 763.72112/1116</note>
                <head>
                    <hi rend="italic">The Minister in the Netherlands</hi> (<persName
                        corresp="#p_VDH1" type="from">
                        <hi rend="italic">Van Dyke</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Hague</hi>
                        </placeName>, <date calendar="gregorian" when="1915-05-17">
                            <hi rend="italic">May 17, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 3.20 p.m.</hi>]</dateline>
                </opener>
                <p>266. Oversea Trust arrangement in my 257, 30th, now limited to goods in Holland
                    before May 15, and shipped from Holland before June 1. This applies also to
                    Belgian goods.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_VDH1">
                            <hi rend="smallcaps">Van Dyke</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
