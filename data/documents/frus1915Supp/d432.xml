    <text>
        <body>
            <div frus:doc-dateTime-max="1915-10-01T23:59:59-05:00"
                frus:doc-dateTime-min="1915-10-01T00:00:00-05:00" n="432"
                subtype="historical-document" type="document" xml:id="d432">
                <note rend="inline" type="source">File No. 763.72112/1657</note>
                <head>
                    <hi rend="italic">The Minister in Switzerland</hi> (<persName corresp="#p_SPA1"
                        type="from">
                        <hi rend="italic">Stovall</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berne</hi>
                        </placeName>, <date calendar="gregorian" when="1915-10-01">
                            <hi rend="italic">October 1, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 7.45 p. m.</hi>]</dateline>
                </opener>
                <p>199. Your 157, 30th.<note n="1" xml:id="d432fn1">Not printed.</note> Details of
                    agreement not yet perfected but trust proposal approved by Federal Council and
                    organization will probably be in operation within a month. I have reported fully
                    by mail in my despatch No. 209, September 29.<note n="1" xml:id="d432fn2">Not
                        printed.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_SPA1">
                            <hi rend="smallcaps">Stovall</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
