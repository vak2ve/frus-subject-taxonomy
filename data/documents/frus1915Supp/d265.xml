    <text>
        <body>
            <div frus:doc-dateTime-max="1915-09-20T23:59:59-05:00"
                frus:doc-dateTime-min="1915-09-20T00:00:00-05:00" n="265"
                subtype="historical-document" type="document" xml:id="d265">
                <note rend="inline" type="source">File No. 763.72112/1596</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1915-09-20">
                            <hi rend="italic">September 20, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 8.50 p. m.</hi>]</dateline>
                </opener>
                <p>2830. Your 2118, September 15, 5 p. m. Foreign Office informs me that
                    arrangements referred to in your telegram have not been perfected but that
                    negotiations are at present taking place. Under arrangement with British
                    Government, Swedish Cotton Spinner Association accepts 10,000 bales of cotton a
                    month.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">American Ambassador</hi>
                    </signed>
                </closer>
            </div>
        </body>
