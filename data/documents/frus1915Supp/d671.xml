    <text>
        <body>
            <div frus:doc-dateTime-max="1915-07-10T23:59:59-05:00"
                frus:doc-dateTime-min="1915-07-10T00:00:00-05:00" n="671"
                subtype="historical-document" type="document" xml:id="d671">
                <note rend="inline" type="source">File No. 841.857Ar5/10</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1915-07-10">
                            <hi rend="italic">July 10, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 11.45 a. m.</hi>]</dateline>
                </opener>
                <p>2435. My 2395, July 3. Foreign Office inform me that <hi rend="italic"
                        >Armenian</hi> was under charter to British Government when she was sunk and
                    was carrying cargo of mules.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">American Ambassador</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
