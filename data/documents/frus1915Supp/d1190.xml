    <text>
        <body>
            <div frus:doc-dateTime-max="1915-04-26T23:59:59-05:00"
                frus:doc-dateTime-min="1915-04-26T00:00:00-05:00" n="1190"
                subtype="historical-document" type="document" xml:id="d1190">
                <note rend="inline" type="source">File No. 763.72111K92/18</note>
                <head>
                    <hi rend="italic">The Assistant Secretary of the Treasury</hi> (<persName
                        corresp="#p_PAJ1" type="from">
                        <hi rend="italic">Peters</hi>
                    </persName>) <hi rend="italic">to the</hi>
                    <gloss type="to">
                        <hi rend="italic">Counselor for the Department of State</hi>
                    </gloss>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-04-26">
                            <hi rend="italic">April 26, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Lansing</hi>: I enclose herewith copy of a letter
                    received by Collector Hamilton of Norfolk from Commander Thierfelder of <pb
                        facs="1093" n="835" xml:id="pg_835"/> the German cruiser <persName>
                        <hi rend="italic">Kronprinz Wilhelm</hi>
                    </persName>. This was telephoned by Collector Hamilton to this office.</p>
                <p>Sincerely yours,</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PAJ1">
                            <hi rend="smallcaps">A. J. Peters</hi>
                        </persName>
                    </signed>
                </closer>
                <frus:attachment>
                    <opener>
                        <seg rendition="#center">[Enclosure]</seg>
                    </opener>
                    <head>
                        <hi rend="italic">The Commander of the</hi> “<persName>
                            <hi rend="italic">Kronprinz Wilhelm</hi>
                        </persName>” (<persName type="from">
                            <hi rend="italic">Thierfelder</hi>
                        </persName>) <hi rend="italic">to the Collector of Customs at Norfolk</hi>
                            (<persName type="to">
                            <hi rend="italic">Hamilton</hi>
                        </persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <date calendar="gregorian" when="1915-04-26">
                                <hi rend="italic">April 26, 1915</hi>.</date>
                        </dateline>
                    </opener>
                    <p>
                        <hi rend="smallcaps">Sir</hi>: Herewith I have to officially inform you that
                        I intern. Awaiting your further orders, I am</p>
                    <p>Yours respectfully,</p>
                    <closer>
                        <signed>
                            <persName>
                                <hi rend="smallcaps">Thierfelder</hi>
                            </persName>
                        </signed>
                    </closer>
                </frus:attachment>
            </div>
        </body>
    </text>
