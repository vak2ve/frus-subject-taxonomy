<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-01-15T23:59:59-05:00" frus:doc-dateTime-min="1915-01-15T00:00:00-05:00" n="455" subtype="historical-document" type="document" xml:id="d455">
                            <note rend="inline" type="source">File No. 300.115/2101</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-01-15">
                                        <hi rend="italic">January 15, 1915</hi>.</date>
                                </dateline>
                            </opener>
                            <p>964. Department advised by Swiss Legation Department Foreign Affairs
                                Swiss Government requests good offices of United States with British
                                Government for release of 800 tons copper steamers <hi rend="italic">Ascot, Palermo</hi> and <hi rend="italic">Regina d’ltalia</hi>,
                                detained at Gibraltar, shipped by American Metal Company, destined
                                for Brown Boveri, Baden, Aargau, Switzerland. Appropriately present
                                matter British Foreign Office, requesting release copper for
                                forwarding to Swiss consignees.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_BWJ1">
                                        <hi rend="smallcaps">Bryan</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>