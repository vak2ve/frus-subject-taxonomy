<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-04-08T23:59:59-05:00" frus:doc-dateTime-min="1915-04-08T00:00:00-05:00" n="30" subtype="historical-document" type="document" xml:id="d30">
                        <note rend="inline" type="source">File No. 763.72119/53a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="to"><hi rend="italic">Gerard</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-04-08">
                                    <hi rend="italic">April 8, 1915</hi>.</date>
                            </dateline>
                        </opener>
                        <p>1484. Inform Foreign Office for information Admiralty that delegation
                            eight American ladies and gentlemen sailed April 7 by steamer <hi rend="italic">Frederik VIII</hi> of Scandinavian-American Line <hi rend="italic">en route</hi> to peace conference at The Hague.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BWJ1">
                                    <hi rend="smallcaps">Bryan</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>