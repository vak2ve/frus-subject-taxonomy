<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-05-22T23:59:59-05:00" frus:doc-dateTime-min="1915-05-22T00:00:00-05:00" n="52" subtype="historical-document" type="document" xml:id="d52">
                        <note rend="inline" type="source">File No. 763.72/1793</note>
                        <head>
                            <hi rend="italic">The Ambassador in Italy</hi> (<persName corresp="#p_PTN1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Rome</hi></placeName>, <date calendar="gregorian" when="1915-05-22">
                                    <hi rend="italic">May 22, 1915</hi>.</date>
                                <lb/> [<hi rend="italic">Received May 23, 3.10 p.
                                m.</hi>]</dateline>
                        </opener>
                        <p>293. General mobilization called for to-morrow. State of war declared in
                            provinces along Austrian border and confines of Adriatic.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_PTN1">
                                    <hi rend="smallcaps">Nelson Page</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>