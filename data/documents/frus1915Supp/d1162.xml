    <text>
        <body>
            <div frus:doc-dateTime-max="1915-11-03T23:59:59-05:00"
                frus:doc-dateTime-min="1915-11-03T00:00:00-05:00" n="1162"
                subtype="historical-document" type="document" xml:id="d1162">
                <note rend="inline" type="source">File No. 763.72111E1 1/29</note>
                <head>
                    <hi rend="italic">The</hi>
                    <gloss type="from">
                        <hi rend="italic">Secretary of State</hi>
                    </gloss>
                    <hi rend="italic">to the Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="to">
                        <hi rend="italic">Penfield</hi>
                    </persName>)<note n="2" xml:id="d1162fn1">The same to the Ambassador in Germany,
                        No. 2360, November 1, 1915 (File No. 763.72111E1 1/54).</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-11-03">
                            <hi rend="italic">November 3, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>967. Your 942, October 15.<note n="3" xml:id="d1162fn2">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_809">p. 809</ref>.</note>
                    After investigation Department finds no evidence that any submarines have been
                    built in the United States for delivery during the present war, or that any
                    submarines have left American jurisdiction under their own power.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
