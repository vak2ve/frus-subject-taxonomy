<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-09-27T23:59:59-05:00" frus:doc-dateTime-min="1915-09-27T00:00:00-05:00" n="815" subtype="historical-document" type="document" xml:id="d815">
                            <note rend="inline" type="source">File No. 763.72112/1531</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Ambassador in Great Britain</hi>
                                    (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-09-27">
                                        <hi rend="italic">September 27, 1915</hi>.</date>
                                </dateline>
                            </opener>
                            <p>2178. Your 2851, September 23.<note n="1" xml:id="d815fn1">Not
                                    printed.</note> Department agreeable to simultaneous publication
                                of Embassy’s memorandum of June 3, and Foreign Office note August
                                    13,<note n="2" xml:id="d815fn2">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_511">pp.
                                        511</ref>–<ref target="#pg_515">15</ref>.</note> morning
                                press Saturday, October 2. Cable if this date satisfactory.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_PFL1">
                                        <hi rend="smallcaps">Polk</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>