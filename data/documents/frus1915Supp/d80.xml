                subtype="historical-document" type="document" xml:id="d80">
                <note rend="inline" type="source">File No. 763.72/2174</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName corresp="#p_PTN1"
                        type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1915-10-04T15:00:00+01:00">
                            <hi rend="italic">October 4, 1915, 3 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 6.15 p. m.</hi>]</dateline>
                </opener>
                <p>404. Russian twenty-four hour limit to Bulgaria probably means immediate outbreak
                    of hostilities. Roumania for the present remains <pb facs="0320" n="62"
                        xml:id="pg_62"/> neutral, Greece likewise, though probably not for long.
                    Allied forces expected to land at Saloniki to-morrow, if not already done,
                    notwithstanding Greece’s <hi rend="italic">pro forma</hi> prohibition.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">American Embassy</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
