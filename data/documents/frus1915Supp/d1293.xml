    <text>
        <body>
            <div frus:doc-dateTime-max="1915-10-21T23:59:59-05:00"
                frus:doc-dateTime-min="1915-10-21T00:00:00-05:00" n="1293"
                subtype="historical-document" type="document" xml:id="d1293">
                <note rend="inline" type="source">File No. 124.74/2</note>
                <head>
                    <hi rend="italic">The Minister in Roumania, Servia, and Bulgaria</hi> (<persName
                        corresp="#p_VCJ1" type="from">
                        <hi rend="italic">Vopicka</hi>
                    </persName>) <hi rend="italic">to the</hi>
                    <gloss type="to">
                        <hi rend="italic">Secretary of State</hi>
                    </gloss>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bucharest</hi>
                        </placeName>, <date calendar="gregorian" when="1915-10-21">
                            <hi rend="italic">October 21, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received October 22, 8 p. m.</hi>]</dateline>
                </opener>
                <p>156. Bulgarian Government has consented to your telegrams 161 and 165.<note n="2"
                        xml:id="d1293fn2">Latter not printed.</note>
                    <persName corresp="#p_EL1">Einstein</persName> expected here to-day. Received
                    telegram from Ambassador <persName corresp="#p_SWG1">Sharp</persName> stating
                    Wadsworth started for England same day my telegram reached Paris; he repeated
                    same to American Embassy, London.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_VCJ1">
                            <hi rend="smallcaps">Vopicka</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
