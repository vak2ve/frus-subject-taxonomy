                subtype="historical-document" type="document" xml:id="d634">
                <note rend="inline" type="source">File No. 763.72/1861</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1915-06-11T15:00:00+01:00">
                            <hi rend="italic">June 11, 1915, 3 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received June 12, 2 p. m.</hi>]</dateline>
                </opener>
                <p>2416. Presented <hi rend="italic">Lusitania</hi> note personally to <persName
                        corresp="#p_JGEGV1">Von Jagow</persName> one o’clock to-day. He read it and
                    said he could not comment now but thought tone friendly and way still open to
                    possible agreement. Sentiment here is changing towards some sort of agreement.
                    What do you think of method outlined in my 2255, May 19, and 2369, June 4?<note
                        n="1" xml:id="d634fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_402">pp. 402</ref> and <ref
                            target="#pg_432">432</ref>.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
