<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-03-19T23:59:59-05:00" frus:doc-dateTime-min="1915-03-19T00:00:00-05:00" n="1501" subtype="historical-document" type="document" xml:id="d1501">
                        <note rend="inline" type="source">File No. 811.142/587</note>
                        <head>
                            <hi rend="italic">The</hi>
                            <gloss type="from">
                                <hi rend="italic">Secretary of State</hi>
                            </gloss>
                            <hi rend="italic">to the Minister in Roumania, Servia, and Bulgaria</hi>
                                (<persName corresp="#p_VCJ1" type="to"><hi rend="italic">Vopicka</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-03-19">
                                    <hi rend="italic">March 19, 1915</hi>.</date>
                            </dateline>
                        </opener>
                        <p>77. Your March 4.<note n="1" xml:id="d1501fn1">Not printed.</note>
                            American Red Cross considering question tents for hospitals. Expects to
                            send in April Red Cross sanitary commission under Dr. <persName>Richard
                                P. Strong</persName>, professor tropical diseases, <pb facs="1300" n="1042" xml:id="pg_1042"/> Harvard University. Commission will
                            carry large stores, disinfecting apparatus, and supplies.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BWJ1">
                                    <hi rend="smallcaps">Bryan</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>