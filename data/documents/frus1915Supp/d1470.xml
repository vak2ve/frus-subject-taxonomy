    <text>
        <body>
            <div frus:doc-dateTime-max="1915-01-21T23:59:59-05:00"
                frus:doc-dateTime-min="1915-01-21T00:00:00-05:00" n="1470"
                subtype="historical-document" type="document" xml:id="d1470">
                <head>
                    <hi rend="italic">The</hi>
                    <gloss type="from">
                        <hi rend="italic">Secretary of State</hi>
                    </gloss>
                    <hi rend="italic">to the Minister in the Netherlands</hi> (<persName
                        corresp="#p_VDH1" type="to">
                        <hi rend="italic">Van Dyke</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-01-21">
                            <hi rend="italic">January 21, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>81. Your despatch 184, December 29. Department informed from Berlin tax removed
                    and money collected refunded. Please confirm facts and report.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
