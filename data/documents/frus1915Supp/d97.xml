<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-11-19T09:00:00-05:00" frus:doc-dateTime-min="1915-11-19T09:00:00-05:00" n="97" subtype="historical-document" type="document" xml:id="d97">
                        <note rend="inline" type="source">File No. 763.72119/89</note>
                        <head>
                            <hi rend="italic">The Minister in Switzerland</hi> (<persName corresp="#p_SPA1" type="from"><hi rend="italic">Stovall</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Berne</hi></placeName>, <date calendar="gregorian" when="1915-11-19T15:00:00+01:00">
                                    <hi rend="italic">November 19, 1915, 3 p. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received 8 p. m.</hi>]</dateline>
                        </opener>
                        <p>230. So-called peace conference called to meet here December 14 has been
                            postponed, it is said, because no French or English delegates can be
                            secured.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_SPA1">
                                    <hi rend="smallcaps">Stovall</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>