                subtype="historical-document" type="document" xml:id="d770">
                <note rend="inline" type="source">File No. 763.72112/1561a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at London</hi> (<persName corresp="#p_SRP1" type="to">
                        <hi rend="italic">Skinner</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-09-02">
                            <hi rend="italic">September 2, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>Are you aware of any instance in which charges for unloading in connection with
                    seizure shipments have been imposed on neutral vessel? Department understands
                    port charges are imposed on vessels in such cases. Please telegraph.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
