    <text>
        <body>
            <div frus:doc-dateTime-max="1915-12-30T23:59:59-05:00"
                frus:doc-dateTime-min="1915-12-30T00:00:00-05:00" n="1254"
                subtype="historical-document" type="document" xml:id="d1254">
                <note rend="inline" type="source">File No. 763.72111/3693</note>
                <head>
                    <hi rend="italic">The French Ambassador</hi> (<persName corresp="#p_JJAAJ1"
                        type="from">
                        <hi rend="italic">Jusserand</hi>
                    </persName>) <hi rend="italic">to the</hi>
                    <gloss type="to">
                        <hi rend="italic">Secretary of State</hi>
                    </gloss>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-12-30">
                            <hi rend="italic">December 30, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received January 3, 1916</hi>.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Secretary</hi>: I beg to acknowledge receipt of
                    your letter of December 29 concerning the presence of the cruiser <hi
                        rend="italic">Descartes</hi> in the vicinity of San Juan, and various
                    incidents connected therewith.</p>
                <p>I am making the necessary inquiries on the several points mentioned by you, and I
                    hope to be able soon to write again more fully.</p>
                <p>Believe me [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_JJAAJ1">
                            <hi rend="smallcaps">Jusserand</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
