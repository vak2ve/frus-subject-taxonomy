<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-05-20T14:00:00-05:00" frus:doc-dateTime-min="1915-05-20T14:00:00-05:00" n="50" subtype="historical-document" type="document" xml:id="d50">
                        <note rend="inline" type="source">File No. 763.72/1786</note>
                        <head>
                            <hi rend="italic">The Ambassador in Italy</hi> (<persName corresp="#p_PTN1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Rome</hi></placeName>, <date calendar="gregorian" when="1915-05-20T20:00:00+01:00">
                                    <hi rend="italic">May 20, 1915, 8 p. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received 11.30 p. m.</hi>]</dateline>
                        </opener>
                        <p>285. Chamber of Deputies approved this afternoon Government’s program
                            overwhelming majority. It includes defense considered to point to
                            declaration of war within few days.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_PTN1">
                                    <hi rend="smallcaps">Nelson Page</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>