    <text>
        <body>
            <div frus:doc-dateTime-max="1915-06-14T23:59:59-05:00"
                frus:doc-dateTime-min="1915-06-14T00:00:00-05:00" n="638"
                subtype="historical-document" type="document" xml:id="d638">
                <note rend="inline" type="source">File No. 300.115/3597</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> ad interim
                        to the Consul General at London</hi> (<persName corresp="#p_SRP1" type="to">
                        <hi rend="italic">Skinner</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-06-14">
                            <hi rend="italic">June 14, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>Your 7th<note n="1" xml:id="d638fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_434">p. 434</ref>.</note>
                    regarding cargo <hi rend="italic">Hilding</hi> and release of shipments. If
                    goods classified as contraband have been sent to prize court, will procurator
                    general consider evidence regarding innocent destination in the manner indicated
                    in your telegram? Please report.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
