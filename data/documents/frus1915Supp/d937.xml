    <text>
        <body>
            <div frus:doc-dateTime-max="1915-01-05T23:59:59-05:00"
                frus:doc-dateTime-min="1915-01-05T00:00:00-05:00" n="937"
                subtype="historical-document" type="document" xml:id="d937">
                <note rend="inline" type="source">File No. 195.1/248</note>
                <head>
                    <hi rend="italic">Mr. <persName type="from">John T. Walsh</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mobile, Ala.</hi>
                        </placeName>, <date calendar="gregorian" when="1915-01-05">
                            <hi rend="italic">January 5, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 4.40 p. m.</hi>]</dateline>
                </opener>
                <p>Will United States Government guarantee protection German steamer bought by
                    American citizens and transferred to American register, <hi rend="italic"
                        >bona-fide</hi> sale, loaded with cotton bound for Germany? Answer my
                    expense.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">John T. Walsh</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
