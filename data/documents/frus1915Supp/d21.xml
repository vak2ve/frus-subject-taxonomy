    <text>
        <body>
            <div frus:doc-dateTime-max="1915-03-06T23:59:59-05:00"
                frus:doc-dateTime-min="1915-03-06T00:00:00-05:00" n="21"
                subtype="historical-document" type="document" xml:id="d21">
                <note rend="inline" type="source">File No. 763.72/1553</note>
                <head>
                    <hi rend="italic">The Minister in Greece</hi> (<persName corresp="#p_DG1"
                        type="from">
                        <hi rend="italic">Droppers</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Athens</hi>
                        </placeName>, <date calendar="gregorian" when="1915-03-06">
                            <hi rend="italic">March 6, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received March 7, 8 p. m.</hi>]</dateline>
                </opener>
                <p>King unexpectedly declares inability to accept program of Prime Minister. Latter
                    resigns at once. Athens stunned.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DG1">
                            <hi rend="smallcaps">Droppers</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
