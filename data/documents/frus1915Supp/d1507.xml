    <text>
        <body>
            <div frus:doc-dateTime-max="1915-09-20T23:59:59-05:00"
                frus:doc-dateTime-min="1915-09-20T00:00:00-05:00" n="1507"
                subtype="historical-document" type="document" xml:id="d1507">
                <note rend="inline" type="source">File No. 811.142/983</note>
                <head>
                    <hi rend="italic">The Ambassador in Russia</hi> (<persName corresp="#p_MGT1"
                        type="from">
                        <hi rend="italic">Marye</hi>
                    </persName>) <hi rend="italic">to the</hi>
                    <gloss type="to">
                        <hi rend="italic">Secretary of State</hi>
                    </gloss>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Petrograd</hi>
                        </placeName>, <date calendar="gregorian" when="1915-09-20">
                            <hi rend="italic">September 20, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 2.40 p. m.</hi>]</dateline>
                </opener>
                <p>1001. Embassy Berlin requests permission for American Red Cross unit to journey
                    Russia to work among German prisoners of war. Russian Foreign Office on
                    receiving application immediately inquired <pb facs="1303" n="1045"
                        xml:id="pg_1045"/> what steps American Red Cross have taken to apply similar
                    relief Russian prisoners in Germany. See my telegram 235, July 23.<note n="1"
                        xml:id="d1507fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_1022">p. 1022</ref>.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_MGT1">
                            <hi rend="smallcaps">Marye</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
