<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-04-16T23:59:59-05:00" frus:doc-dateTime-min="1915-04-16T00:00:00-05:00" n="535" subtype="historical-document" type="document" xml:id="d535">
                            <note rend="inline" type="source">File No. 763.72112/1011</note>
                            <head>
                                <hi rend="italic">The Consul General at London</hi> (<persName corresp="#p_SRP1" type="from"><hi rend="italic">Skinner</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1915-04-16">
                                        <hi rend="italic">April 16, 1915</hi>.</date>
                                    <lb/> [<hi rend="italic">Received 3.20 p. m.</hi>]</dateline>
                            </opener>
                            <p>Advise as means of determining facts that Department Commerce
                                instruct American port authorities to forward promptly this office
                                certified copy manifests all ships proceeding to Europe with
                                information as to inspection cargo by British consul, charterer’s
                                name and other pertinent details.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_SRP1">
                                        <hi rend="smallcaps">Skinner</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>