                subtype="historical-document" type="document" xml:id="d168">
                <note rend="inline" type="source">File No. 811.0151/50</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-02-04">
                            <hi rend="italic">February 04, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>1182. From The Hague: “The Netherlands Government has positive information from
                    London that the British Admiralty now furnishes arms to merchant vessels for
                    resistance on ground that the German regulations sanction the same measure for
                    German merchant vessels.” Please confirm this.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
