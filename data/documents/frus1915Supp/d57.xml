                subtype="historical-document" type="document" xml:id="d57">
                <note rend="inline" type="source">File No. 763.72/1820</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName corresp="#p_PTN1"
                        type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1915-05-27T17:00:00+01:00">
                            <hi rend="italic">May 27, 1915, 5 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 6.45 p. m.</hi>]</dateline>
                </opener>
                <p>304. No declaration of war yet with Germany but when German Embassy demanded
                    passports its Counselor stated that probably German troops would be found with
                    Austrians on the frontier.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PTN1">
                            <hi rend="smallcaps">Nelson Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
