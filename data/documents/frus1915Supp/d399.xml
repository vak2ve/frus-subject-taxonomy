<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-03-31T23:59:59-05:00" frus:doc-dateTime-min="1915-03-31T00:00:00-05:00" n="399" subtype="historical-document" type="document" xml:id="d399">
                            <note rend="inline" type="source">File No. 763.72112/951</note>
                            <head>
                                <hi rend="italic">The Minister in the Netherlands</hi> (<persName corresp="#p_VDH1" type="from"><hi rend="italic">Van
                                    Dyke</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">The Hague</hi></placeName>, <date calendar="gregorian" when="1915-03-31">
                                        <hi rend="italic">March 31, 1915</hi>.</date>
                                    <lb/> [<hi rend="italic">Received April 1, 12.10 p.
                                    m.</hi>]</dateline>
                            </opener>
                            <p>230. Your 134, 29th.<note n="1" xml:id="d399fn1">Not printed.</note>
                                Oversea Trust for present prefers not accept non-contraband.
                                Exceptions only possible in special cases for <pb facs="0532" n="274" xml:id="pg_274"/> limited quantities by specific
                                arrangement. Tobacco out of question at present. I renew
                                recommendation of my previous despatches 186<note n="1" xml:id="d399fn2">Not printed.</note> and 201.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_VDH1">
                                        <hi rend="smallcaps">Van Dyke</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>