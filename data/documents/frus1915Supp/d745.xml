<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-08-19T15:00:00-05:00" frus:doc-dateTime-min="1915-08-19T04:55:00-05:00" n="745" subtype="historical-document" type="document" xml:id="d745">
                            <note rend="inline" type="source">File No. 841.857Ar1</note>
                            <head>
                                <hi rend="italic">The Vice Consul at Cork</hi> (<persName corresp="#p_TLC1" type="from"><hi rend="italic">Thompson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Queenstown</hi></placeName>, <date ana="#date_undated-inferred-from-document-content" calendar="gregorian" notAfter="1915-08-19T15:00:00-05:00" notBefore="1915-08-19T09:30:00-00:25" when="1915-08-19"><hi rend="italic">undated</hi></date>.<lb/>[<hi rend="italic">Received August 19, 1915, 3 p.
                                    m.</hi>]</dateline>
                            </opener>
                            <p>
                                <hi rend="italic">Arabic</hi> sunk at 9.30 to-day 60 miles from
                                Queenstown. Sunk in eleven minutes. Eleven boats of survivors being
                                brought here.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_TLC1">
                                        <hi rend="smallcaps">Thompson</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>