<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-04-08T23:59:59-05:00" frus:doc-dateTime-min="1915-04-08T00:00:00-05:00" n="516" subtype="historical-document" type="document" xml:id="d516">
                            <note rend="inline" type="source">File No. 362.112T41/5</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Consul General at London</hi> (<persName corresp="#p_SRP1" type="to"><hi rend="italic">Skinner</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-04-08">
                                        <hi rend="italic">April 8, 1915</hi>.</date>
                                </dateline>
                            </opener>
                            <p>Your telegram April 7, Thrasher case. Please ascertain positively
                                whether <hi rend="italic">Falaba</hi> carried guns, mounted or in
                                hold, and ammunition.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_BWJ1">
                                        <hi rend="smallcaps">Bryan</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>