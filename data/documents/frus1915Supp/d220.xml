    <text>
        <body>
            <div frus:doc-dateTime-max="1915-07-16T23:59:59-05:00"
                frus:doc-dateTime-min="1915-07-16T00:00:00-05:00" n="220"
                subtype="historical-document" type="document" xml:id="d220">
                <note rend="inline" type="source">File No. 763.72112/1349</note>
                <head>
                    <hi rend="italic">The Italian Ambassador</hi> (<persName corresp="#p_MDCVC1"
                        type="from">
                        <hi rend="italic">Macchi di Cellere</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Beverly Farms, Mass.</hi>
                        </placeName>, <date calendar="gregorian" when="1915-07-16">
                            <hi rend="italic">July 16, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received July 19</hi>.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary of state</hi>: Referring to the
                    previous correspondence exchanged on this matter, between the Department of
                    State and this Embassy, I beg to send you here enclosed a copy of the list of
                    contraband of war issued by the Royal Italian Government.</p>
                <p>I also enclose a copy of the Royal decree stating the principles of international
                    law the Royal Italian Government intends to apply during the war.<note n="1"
                        xml:id="d220fn1">Enclosures not printed. They correspond to the lists and
                        rules issued to date by the Allied Governments.</note>
                </p>
                <p>Believe me [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MDCVC1">
                            <hi rend="smallcaps">V. Macchi di Cellere</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
