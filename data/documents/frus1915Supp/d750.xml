    <text>
        <body>
            <div frus:doc-dateTime-max="1915-08-23T23:59:59-05:00"
                frus:doc-dateTime-min="1915-08-23T00:00:00-05:00" n="750"
                subtype="historical-document" type="document" xml:id="d750">
                <note rend="inline" type="source">File No. 841.857/18</note>
                <head>
                    <hi rend="italic">The Consul General at London</hi> (<persName corresp="#p_SRP1"
                        type="from">
                        <hi rend="italic">Skinner</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1915-08-23">
                            <hi rend="italic">August 23, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 8.15 a. m.</hi>]</dateline>
                </opener>
                <p>American Consul, Bristol, reports British ship <persName>
                        <hi rend="italic">Baron Erskine</hi>
                    </persName>, Avonmouth to New Orleans, destroyed submarine morning August 19.
                    Seventy-seven returning American muleteers on board all saved. Survivors in
                    Bristol.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SRP1">
                            <hi rend="smallcaps">Skinner</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
