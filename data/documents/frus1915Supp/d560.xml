    <text>
        <body>
            <div frus:doc-dateTime-max="1915-05-07T23:59:59-05:00"
                frus:doc-dateTime-min="1915-05-07T00:00:00-05:00" n="560"
                subtype="historical-document" type="document" xml:id="d560">
                <note rend="inline" type="source">File No. 841.857/97</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1915-05-07">
                            <hi rend="italic">May 7, 1915</hi>.</date>
                        <lb/> [<hi rend="italic">Received 3.06 p. m.</hi>]</dateline>
                </opener>
                <p>2060. The <hi rend="italic">Lusitania</hi> was torpedoed off the Irish coast and
                    sunk in half an hour. No news yet of passengers.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">American Ambassador</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
