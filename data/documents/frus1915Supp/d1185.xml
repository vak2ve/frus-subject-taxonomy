<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-04-09T23:59:59-05:00" frus:doc-dateTime-min="1915-04-09T00:00:00-05:00" n="1185" subtype="historical-document" type="document" xml:id="d1185">
                        <note rend="inline" type="source">File No. 763.72111Ei9/37</note>
                        <head>
                            <hi rend="italic">The Secretary of the Navy</hi> (<persName corresp="#p_DJ1" type="from"><hi rend="italic">Daniels</hi></persName>) <hi rend="italic">to the</hi>
                            <gloss type="to">
                                <hi rend="italic">Secretary of State</hi>
                            </gloss>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-04-09">
                                    <hi rend="italic">April 9, 1915</hi>.</date>
                            </dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to forward herewith, for
                            the information of the Department of State, copies of telegrams sent and
                            received by this Department relative to the enforcement of
                                neutrality.<note n="2" xml:id="d1185fn2">Only one printed.</note>
                        </p>
                        <p>Sincerely yours,</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_DJ1">
                                    <hi rend="smallcaps">Josephus Daniels</hi>
                                </persName>
                            </signed>
                        </closer>
                        <frus:attachment>
                            <opener>
                                <seg rendition="#center">[Enclosure—Telegram]</seg>
                            </opener>
                            <head>
                                <hi rend="italic">Flag Often U. S. S.</hi> “<hi rend="italic">Wyoming</hi>” (<persName type="from"><hi rend="italic">Fletcher</hi></persName>) <hi rend="italic">to the
                                    Secretary of the Navy</hi> (<persName corresp="#p_DJ1" type="to"><hi rend="italic">Daniels</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <date calendar="gregorian" when="1915-04-08">
                                        <hi rend="italic">April 8, 1915</hi>.</date>
                                </dateline>
                            </opener>
                            <p>I am informed by the collector of customs that the <persName>
                                    <hi rend="italic">Eitel Friedrich</hi>
                                </persName> has accepted internment. Necessary steps taken to
                                prevent departure.</p>
                            <closer>
                                <signed>
                                    <persName>
                                        <hi rend="smallcaps">Fletcher</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </frus:attachment>
                    </div>
                    </body></text></TEI>