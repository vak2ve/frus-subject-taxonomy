<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-09-24T23:59:59-05:00" frus:doc-dateTime-min="1915-09-24T00:00:00-05:00" n="812" subtype="historical-document" type="document" xml:id="d812">
                            <note rend="inline" type="source">File No. 841.857/40</note>
                            <head>
                                <hi rend="italic">The Consul at Cork</hi> (<persName corresp="#p_FW1" type="from"><hi rend="italic">Frost</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Queenstown</hi></placeName>, <date ana="#date_undated-inferred-from-outside-research" calendar="gregorian" when="1915-09-24">
                                        <hi rend="italic">undated</hi>
                                    </date>.<lb/>[<hi rend="italic">Received September 24, 1915, 8
                                        a. m.</hi>]</dateline>
                            </opener>
                            <p>
                                <hi rend="italic">Anglo-Columbian</hi>, British horse transport,
                                Montreal to England, torpedoed after chase 78 miles, off Fastnet,
                                9.30 this morning. Fair warning and time to take boats given. Six
                                Americans in crew. No casualties.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_FW1">
                                        <hi rend="smallcaps">Frost</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>