<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-09-28T11:00:00-05:00" frus:doc-dateTime-min="1915-09-28T11:00:00-05:00" n="818" subtype="historical-document" type="document" xml:id="d818">
                            <note rend="inline" type="source">File No. 763.72/2162</note>
                            <head>
                                <hi rend="italic">The Minister in Denmark</hi> (<persName corresp="#p_EMF1" type="from"><hi rend="italic">Egan</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Copenhagen</hi></placeName>, <date calendar="gregorian" when="1915-09-28T17:00:00+01:00">
                                        <hi rend="italic">September 28, 1915, 5 p. m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 8.10 p. m.</hi>]</dateline>
                            </opener>
                            <p>174. I am credibly informed that through secret methods British
                                destruction of German submarine boats shows remarkable progress.
                                Evident German alarm.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">American Minister</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>