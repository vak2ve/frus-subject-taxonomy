    <text>
        <body>
            <div frus:doc-dateTime-max="1915-04-03T23:59:59-05:00"
                frus:doc-dateTime-min="1915-04-03T00:00:00-05:00" n="510"
                subtype="historical-document" type="document" xml:id="d510">
                <note rend="inline" type="source">File No. 300.115G82/1</note>
                <head>
                    <hi rend="italic">The Consul General at Rotterdam</hi> (<persName
                        corresp="#p_LS1" type="from">
                        <hi rend="italic">Listoe</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rotterdam</hi>
                        </placeName>, <date calendar="gregorian" when="1915-04-03">
                            <hi rend="italic">April 3, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>Consul Fee, Bremen, wires steamer <hi rend="italic">Greenbrier</hi>, Captain
                        <persName>Dalton</persName>, sailed April 1 Bremerhaven New York with
                    general cargo sunk April 2, apparently mine explosion near North Frisian Island
                    Amrom. All thirty-eight members crew saved.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LS1">
                            <hi rend="smallcaps">Listoe</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
