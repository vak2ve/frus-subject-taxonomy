    <text>
        <body>
            <div frus:doc-dateTime-max="1915-01-19T13:00:00-05:00"
                frus:doc-dateTime-min="1915-01-19T13:00:00-05:00" n="457"
                subtype="historical-document" type="document" xml:id="d457">
                <note rend="inline" type="source">File No. 763.72112/634</note>
                <head>
                    <hi rend="italic">The Minister in Sweden</hi> (<persName corresp="#p_MIN1"
                        type="from">
                        <hi rend="italic">Morris</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Stockholm</hi>
                        </placeName>, <date calendar="gregorian" when="1915-01-19T19:00:00+01:00">
                            <hi rend="italic">January 19, 1915, 7 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 11.45 p. m.</hi>]</dateline>
                </opener>
                <p>14. Swedish Government has furnished me with memorandum calling attention to fact
                    that statistics of Swedish imports as set out in British note of January 7<note
                        n="1" xml:id="d457fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_299">p. 299</ref>.</note> do
                    not correspond with Swedish statistics of imports.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MIN1">
                            <hi rend="smallcaps">Morris</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
