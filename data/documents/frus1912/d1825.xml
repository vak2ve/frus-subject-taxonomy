                <note rend="inline" type="source">File No. 367.11/40.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Ambassador</gloss> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Constantinople</hi>
                        </placeName>, <date calendar="gregorian" when="1912-11-12">
                            <hi rend="italic">November 12, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>I have informed <hi rend="italic">Unalga’s</hi> commander that his services will
                    not be required in Turkish waters.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Rockhill.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
