    <text>
        <body>
            <div frus:doc-dateTime-max="1912-01-17T23:59:59-05:00"
                frus:doc-dateTime-min="1912-01-17T00:00:00-05:00" n="575"
                subtype="historical-document" type="document" xml:id="d575">
                <note rend="inline" type="source">File No. 822.00/202.]</note>
                <head>
                    <hi rend="italic">General <persName type="from">Montero</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guayaquil</hi>
                        </placeName>, (<date
                            ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                            calendar="gregorian" when="1912-01-17">undated</date>) <hi rend="italic"
                            >received January 17, 1912</hi>.</dateline>
                </opener>
                <p>My Government will fulfill every obligation contracted by Ecuador, and fully
                    respect foreign and especially American interests.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Pedro J. Montero</hi>, <lb/>
                        <hi rend="italic">Jefe Supremo.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
