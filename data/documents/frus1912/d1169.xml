<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-09-17T11:36:00-05:00" frus:doc-dateTime-min="1912-09-17T11:36:00-05:00" n="1169" subtype="historical-document" type="document" xml:id="d1169">
                        <note rend="inline" type="source">File No. 312.11/877.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Ambassador</gloss> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegrams.—Paraphrases.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                                    <hi rend="italic">Mexico</hi></placeName>, <date calendar="gregorian" when="1912-09-17T10:00:00-06:36">
                                    <hi rend="italic">September 17, 1912—10 a.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Note delivered this morning. Impossible last night.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Wilson.</hi>
                            </signed>
                        </closer>
