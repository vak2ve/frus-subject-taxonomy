                subtype="historical-document" type="document" xml:id="d1339">
                <note rend="inline" type="source">File No. 412.00/4.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">American Chargé d’Affaires</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#left">No. 489.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1911-08-22">
                            <hi rend="italic">August 22, 1911</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has received the Ambassador’s No.
                    712 of the 6th ultimo transmitting [etc.].</p>
                <p>With reference to the instructions requested by the Ambassador in this despatch,
                    you are referred to the Department’s No. 476 of the 17th instant, answering your
                    No. 734 of the 20th ultimo.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Huntington Wilson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
