                <note rend="inline" type="source">File No. 812.018/25.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">American Ambassador</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1912-04-11T15:00:00-05:00">
                            <hi rend="italic">April 11, 1912—3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>No formal representations desired in matter presented in your April 10, 11
                    a.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Huntington Wilson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
