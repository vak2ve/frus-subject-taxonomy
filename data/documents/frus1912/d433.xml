                subtype="historical-document" type="document" xml:id="d433">
                <note rend="inline" type="source">File No. 811.304M28/64.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Minister</gloss> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1912-03-11">
                            <hi rend="italic">March 11, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>The rearrangements for the reception of the remains will be modified as
                    desired.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Beaupré</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
