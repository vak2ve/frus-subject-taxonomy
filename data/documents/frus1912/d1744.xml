                subtype="historical-document" type="document" xml:id="d1744">
                <note rend="inline" type="source">File No. 861.0145/6.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">American Ambassador</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#left">No. 157.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1911-04-21">
                            <hi rend="italic">April 21, 1911</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has received your No. 506 of the
                    28th ultimo, in regard to the Russian law [etc.]</p>
                <p>The Department awaits the reply promised by the Minister for Foreign Affairs,
                    referred to in your despatch of February 13, 1911, and any further information
                    concerning this matter which you are able to obtain.</p>
                <p>I am [etc.]</p>
                <closer>For <signed>Mr. Knox</signed>: <lb/>
                    <signed>
                        <hi rend="smallcaps">Huntington Wilson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
