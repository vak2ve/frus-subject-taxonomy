                subtype="historical-document" type="document" xml:id="d90">
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">American Minister</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1912-04-05">
                            <hi rend="italic">April 5, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>Compliance with the request of the Chinese Foreign Minister referred to in your
                    April 4 does not involve formal recognition; it would be in harmony with our de
                    facto relations with the present administration. You may instruct consuls to
                    comply, with this understanding.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Huntington Wilson</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
