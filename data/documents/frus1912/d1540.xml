<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-09-05T23:59:59-05:00" frus:doc-dateTime-min="1912-09-05T00:00:00-05:00" n="1540" subtype="historical-document" type="document" xml:id="d1540">
                        <note rend="inline" type="source">File No. 817.48/11b.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the <gloss type="to">American
                                Minister</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1912-09-05">
                                    <hi rend="italic">September 5, 1912</hi></date>.</dateline>
                        </opener>
                        <p>American Red Cross authorizes further expenditure of $1,000. Food
                            supplies will be obtained as previously and shipped to Corinto on first
                            available steamer.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Adee.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>