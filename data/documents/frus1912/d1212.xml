<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-11-17T21:36:00-05:00" frus:doc-dateTime-min="1912-11-17T21:36:00-05:00" n="1212" subtype="historical-document" type="document" xml:id="d1212">
                        <note rend="inline" type="source">File No. 812.00/5513.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Consul at San Luis
                                    Potosí</gloss> to the <gloss type="to">Secretary of
                                    State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">San Luis Potosí</hi></placeName>, <date calendar="gregorian" when="1912-11-17T20:00:00-06:36">
                                    <hi rend="italic">November 17, 1912—8 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Cuidad Maiz, town 4,000 inhabitants, 90 miles east, taken by rebels.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bonney.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>