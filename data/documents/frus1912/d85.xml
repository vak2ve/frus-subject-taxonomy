                subtype="historical-document" type="document" xml:id="d85">
                <note rend="inline" type="source">File No. 893.00/1170.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Minister</gloss> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram—Extract.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1912-03-09">
                            <hi rend="italic">March 9, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>Yuan authorized by Nanking Assembly to be inaugurated at Peking on March 10.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Calhoun</hi>.</signed>
                </closer>
            </div>
        </body>
