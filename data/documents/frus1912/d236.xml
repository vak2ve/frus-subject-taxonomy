                subtype="historical-document" type="document" xml:id="d236">
                <note rend="inline" type="source">File No. 893.51/1032.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">American Minister</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1912-08-10">
                            <hi rend="italic">August 10, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>See the Department’s July 2. Provided your colleagues receive similar
                    instructions the Department approves.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Knox</hi>.</signed>
                </closer>
            </div>
        </body>
