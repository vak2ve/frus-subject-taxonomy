<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-02-07T23:59:59-05:00" frus:doc-dateTime-min="1912-02-07T00:00:00-05:00" n="1248" subtype="historical-document" type="document" xml:id="d1248">
                        <note rend="inline" type="source">File No. 812.2311/27.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Governor of Texas</gloss> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Austin, Texas</hi></placeName>, <date calendar="gregorian" when="1912-02-07">
                                    <hi rend="italic">February 7, 1912</hi></date>.</dateline>
                        </opener>
                        <p>Telegram this date asking formal approval on part of Texas State
                            government for permission of Mexican troops to pass over Texas, Eagle
                            Pass to El Paso, accompanied by United States troops, is not objected
                            to.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">O. B. Colquitt.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>