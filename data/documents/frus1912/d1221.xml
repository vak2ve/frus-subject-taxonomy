<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-02-26T14:36:00-05:00" frus:doc-dateTime-min="1912-02-26T14:36:00-05:00" n="1221" subtype="historical-document" type="document" xml:id="d1221">
                        <note rend="inline" type="source">File No. 812.06/2914.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Ambassador</gloss> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegrams.—Extracts.—Paraphrases.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                                    <hi rend="italic">Mexico</hi></placeName>, <date calendar="gregorian" when="1912-02-26T13:00:00-06:36">
                                    <hi rend="italic">February 26, 1912—1 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>I shall see the Minister for Foreign Affairs to-day in regard to your
                            February 25, 7 p.m.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Wilson.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>