<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-10-08T23:59:59-05:00" frus:doc-dateTime-min="1912-10-08T00:00:00-05:00" n="1391" subtype="historical-document" type="document" xml:id="d1391">
                        <note rend="inline" type="source">File No. 412.11/136.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the <gloss type="to">Secretary of
                                War</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Extract.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1912-10-08">
                                    <hi rend="italic">October 8, 1912</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your letter of the 25th ultimo in which [etc.]</p>
                        <p>I have the honor to transmit the requested memorials for your information
                            and to ask that when they have served their purpose they may be returned
                            for the files of this Department.</p>
                        <p>I have [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Huntington Wilson.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>