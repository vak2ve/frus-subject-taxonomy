<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1911-12-15T23:59:59-05:00" frus:doc-dateTime-min="1911-12-15T00:00:00-05:00" n="51" subtype="historical-document" type="document" xml:id="d51">
                        <note rend="inline" type="source">File No. 893.00/776.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">American Minister</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1911-12-15">
                                    <hi rend="italic">December 15, 1911</hi></date>.</dateline>
                        </opener>
                        <p>Your December 15. You are authorized to take the action suggested, on the
                            conditions mentioned.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Knox.</hi>
                            </signed>
                        </closer>
