<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1911-01-31T23:59:59-05:00" frus:doc-dateTime-min="1911-01-31T00:00:00-05:00" n="741" subtype="historical-document" type="document" xml:id="d741">
                        <note rend="inline" type="source">File No. 815.51/180.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Minister</gloss> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Paraphrase]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Tegucigalpa</hi></placeName>, <date calendar="gregorian" when="1911-01-31">
                                    <hi rend="italic">January 31, 1911</hi></date>.</dateline>
                        </opener>
                        <p>The Honduran Congress rejected the Loan Convention to-day, 33 to 5.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">McCreery.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>