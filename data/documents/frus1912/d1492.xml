<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-01-19T23:59:59-05:00" frus:doc-dateTime-min="1912-01-19T00:00:00-05:00" n="1492" subtype="historical-document" type="document" xml:id="d1492">
                        <note rend="inline" type="source">File No. 817.51/292.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the <gloss type="to">American Chargé
                                    d’Affaires</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1912-01-19">
                                    <hi rend="italic">January 19, 1912</hi></date>.</dateline>
                        </opener>
                        <p>Thayer accepts and will sail from San Juan January 22.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Wilson.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>