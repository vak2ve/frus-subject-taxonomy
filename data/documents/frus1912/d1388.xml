    <text>
        <body>
            <div frus:doc-dateTime-max="1912-09-18T23:59:59-05:00"
                frus:doc-dateTime-min="1912-09-18T00:00:00-05:00" n="1388"
                subtype="historical-document" type="document" xml:id="d1388">
                <note rend="inline" type="source">File No. 412.11/133.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">Secretary of War</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1912-09-18">
                            <hi rend="italic">September 18, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your letter of the 3d instant referring to the Joint Resolution of Congress
                    approved August 9, 1912, authorizing the War Department to investigate
                    [etc.].</p>
                <p>In reply I have the honor to enclose a list of claims of the character referred
                    to in your letter, which have been filed in the Department. This list shows the
                    names and addresses of the claimants.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alvey A. Adee.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
