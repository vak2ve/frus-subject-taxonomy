    <text>
        <body>
            <div frus:doc-dateTime-max="1912-12-26T23:59:59-05:00"
                frus:doc-dateTime-min="1912-12-26T00:00:00-05:00" n="1475"
                subtype="historical-document" type="document" xml:id="d1475">
                <note rend="inline" type="source">File No. 817.00/2203.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Minister</gloss> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Extract.]</seg>
                </opener>
                <opener>
                    <seg rendition="#left">No. 93.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1912-12-26">
                            <hi rend="italic">December 26, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform the Department that
                    the National Assembly in its session of December 18 canvassed the vote cast at
                    the polls on November 2, 1912, and thereupon officially declared Don Adolfo Díaz
                    and Don Fernando Solórzano elected President and Vice President, respectively,
                    for the four years beginning January 1, 1913.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">George T. Weitzel.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
