                subtype="historical-document" type="document" xml:id="d350">
                <note rend="inline" type="source">File No. 337.11/4.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">American Minister</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1912-05-28">
                            <hi rend="italic">May 28, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>Americans at Victoria de Las Tunas, Oriente, Cuba, have applied to the Department
                    for protection. Make suitable representations to Foreign Office. On receipt by
                    you of similar requests take like action and reserve rights of reclamation for
                    any damages suffered by Americans.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Knox</hi>.</signed>
                </closer>
            </div>
        </body>
