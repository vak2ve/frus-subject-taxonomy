                subtype="historical-document" type="document" xml:id="d1494">
                <note rend="inline" type="source">File No. 817.51/294.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">American Chargé d’Affaires</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1912-01-24">
                            <hi rend="italic">January 24, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has received your No. 161, of the
                    30th ultimo, transmitting a copy of the decree authorizing the financial
                    arrangement between Messrs. Brown Brothers and Company and Messrs. J. and W.
                    Seligman and Company, agents for the Republic of Nicaragua, and the Ethelburga
                    Syndicate, Limited, of London.</p>
                <p>Copies of your despatch and its enclosure have been sent to Mr. Ernest H.
                    Wands.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">P. C. Knox.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
