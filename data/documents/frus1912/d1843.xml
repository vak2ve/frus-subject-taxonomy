<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-03-23T23:59:59-05:00" frus:doc-dateTime-min="1912-03-23T00:00:00-05:00" n="1843" subtype="historical-document" type="document" xml:id="d1843">
                        <head>
                            <hi rend="italic">Remarks of Mr. Knox upon placing a wreath at the foot
                                of the statue of Bolívar in Caracas, Venezuela, March 23,
                            1912</hi>.</head>
                        <dateline>
                            <placeName>Caracas</placeName>, <date ana="#date_undated-inferred-from-document-head" calendar="gregorian" when="1912-03-23">March 23, 1912</date>
                        </dateline>
                        <p>
                            <hi rend="smallcaps">Mr. Minister</hi>: In the name of the people and of
                            the President of the United States I beg to lay this token of
                            appreciation, respect, and veneration at the foot of the statue of the
                            great Venezuelan Liberator.</p>
                        <postscript>
                            <p>[Remarks of Mr. Matos, Minister for Foreign Affairs, were extempore
                                and not taken.]</p>
                        </postscript>
                    </div>
                    </body></text></TEI>