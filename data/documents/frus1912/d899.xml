    <text>
        <body>
            <div frus:doc-dateTime-max="1912-08-07T23:59:59-05:00"
                frus:doc-dateTime-min="1912-08-07T00:00:00-05:00" n="899"
                subtype="historical-document" type="document" xml:id="d899">
                <note rend="inline" type="source">File No. 850a.001M33.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Minister</gloss> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">The Hague</hi>
                        </placeName>, <date calendar="gregorian" when="1912-08-07">
                            <hi rend="italic">August 7, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to transmit herewith inclosed,
                    at the request of the Minister for Foreign Affairs of Luxemburg, a letter<hi
                        rend="superscript">1</hi> with office copy and translation thereof, by which
                    Her Royal Highness, the Grand Duchess of the Grand Duchy of Luxemburg, notifies
                    the President of the United States of her accession to the throne.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lloyd Bryce.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
