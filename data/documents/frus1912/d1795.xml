                <note rend="inline" type="source">File No. 767.70/33.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Minister to Roumania</gloss>
                        to the <gloss type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegrams.—Paraphrases.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Bucharest</hi>
                        </placeName>, <date calendar="gregorian" when="1912-10-18">
                            <hi rend="italic">October 18, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>To-day Servia declared war with Turkey.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Jackson</hi>.</signed>
                </closer>
            </div>
        </body>
