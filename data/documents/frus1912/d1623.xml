<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1911-12-11T23:59:59-05:00" frus:doc-dateTime-min="1911-12-11T00:00:00-05:00" n="1623" subtype="historical-document" type="document" xml:id="d1623">
                        <note rend="inline" type="source">File No. 819.74/2.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of the Navy</gloss>
                                to the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of the Navy</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <lb/>
                                <date calendar="gregorian" when="1911-12-11">
                                    <hi rend="italic">December 11, 1911</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to request such
                            information as may be available concerning any wireless telegraph
                            installations existing or proposed on the Isthmus of Panama.</p>
                        <p>Respectfully,</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Geo. von L. Meyer.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>