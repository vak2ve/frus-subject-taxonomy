                subtype="historical-document" type="document" xml:id="d870">
                <note rend="inline" type="source">File No. 882.51/411.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Special Representative</gloss> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Hamburg</hi>
                        </placeName>, <date calendar="gregorian" when="1912-07-11">
                            <hi rend="italic">July 11, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>Falkner should be informed that interest at five per cent is demanded by the
                    creditors from July 1.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Skinner.</hi>
                    </signed>
                </closer>
            </div>
        </body>
