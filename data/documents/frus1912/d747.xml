                subtype="historical-document" type="document" xml:id="d747">
                <note rend="inline" type="source">File No. 815.51/208.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">American Minister</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1911-02-16">
                            <hi rend="italic">February 16, 1911</hi>
                        </date>.</dateline>
                </opener>
                <p>Bankers’ contracts executed in English February 15, and will soon be signed in
                    Spanish.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wilson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
