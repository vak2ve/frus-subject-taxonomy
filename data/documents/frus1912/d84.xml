    <text>
        <body>
            <div frus:doc-dateTime-max="1912-03-09T23:59:59-05:00"
                frus:doc-dateTime-min="1912-03-09T00:00:00-05:00" n="84"
                subtype="historical-document" type="document" xml:id="d84">
                <note rend="inline" type="source">File No. 893.001Y/9.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Chinese Minister</gloss> to the <gloss
                            type="to">Acting Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#left">No. 34.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chinese Legation</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1912-03-09">
                            <hi rend="italic">March 9, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I am instructed by my Government to inform you
                    that His Excellency Yuan Shih-Kai will take the oath of office and enter upon
                    the duties as Provisional President of the Republic of China, at Peking, on the
                    10th instant.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Chang Yin Tang</hi>.</signed>
                </closer>
            </div>
        </body>
