                subtype="historical-document" type="document" xml:id="d855">
                <note rend="inline" type="source">File No. 882.51/323.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Special Representative</gloss> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1912-04-09">
                            <hi rend="italic">April 9, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>Department’s March 27. Creditors are pressing me for prompt settlement, as it is
                    stated here that the interest has been paid.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Skinner.</hi>
                    </signed>
                </closer>
            </div>
        </body>
