<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1911-12-16T23:59:59-05:00" frus:doc-dateTime-min="1911-12-16T00:00:00-05:00" n="1487" subtype="historical-document" type="document" xml:id="d1487">
                        <note rend="inline" type="source">File No. 817.51/275.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Chargé
                                    d’Affaires</gloss> to the <gloss type="to">Secretary of
                                    State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Managua</hi></placeName>, <date calendar="gregorian" when="1911-12-16">
                                    <hi rend="italic">December 16, 1911</hi></date>.</dateline>
                        </opener>
                        <p>The Financial Agent, Colonel Ham, and Captain Wilson, assumed Chargé of
                            their respective posts today.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Gunther.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>