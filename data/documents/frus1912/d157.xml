    <text>
        <body>
            <div frus:doc-dateTime-max="1912-01-31T23:59:59-05:00"
                frus:doc-dateTime-min="1912-01-31T00:00:00-05:00" n="157"
                subtype="historical-document" type="document" xml:id="d157">
                <note rend="inline" type="source">File No. 893.00/1029.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">German Ambassador</gloss> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Imperial German Embassy</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1912-01-31">
                            <hi rend="italic">January 31, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: I have the honor respectfully
                    to inform your excellency that in view of the development of affairs in the Far
                    East the Imperial Government would desire to obtain confidential <pb facs="0225"
                        n="109" xml:id="pg_109"/> information as to the attitude of the Government
                    of the United States toward the said development.</p>
                <p>Expressing [etc.],</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">J. Bernstorff</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
