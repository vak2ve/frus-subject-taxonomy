<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-05-02T23:59:59-05:00" frus:doc-dateTime-min="1912-05-02T00:00:00-05:00" n="837" subtype="historical-document" type="document" xml:id="d837">
                        <note rend="inline" type="source">File No. 882.20/8.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Minister</gloss> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Monrovia</hi></placeName>, <date calendar="gregorian" when="1912-05-02">
                                    <hi rend="italic">May 2, 1912</hi></date>.</dateline>
                        </opener>
                        <p>Young and officers arrived yesterday.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Crum.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>