<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-02-15T23:59:59-05:00" frus:doc-dateTime-min="1912-02-15T00:00:00-05:00" n="70" subtype="historical-document" type="document" xml:id="d70">
                        <note rend="inline" type="source">File No. 893.00/1072.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Minister</gloss> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Extract.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Peking</hi></placeName>, <date calendar="gregorian" when="1912-02-15">
                                    <hi rend="italic">February 15, 1912</hi></date>.</dateline>
                        </opener>
                        <p>Resignation of Sun and Cabinet has been accepted by the Nanking Assembly.
                            Election of a new president set for to-day.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Calhoun.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>