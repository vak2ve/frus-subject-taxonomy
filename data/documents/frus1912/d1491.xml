<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-01-15T23:59:59-05:00" frus:doc-dateTime-min="1912-01-15T00:00:00-05:00" n="1491" subtype="historical-document" type="document" xml:id="d1491">
                        <note rend="inline" type="source">File No. 817.51/292</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Chargé
                                    d’Affaires</gloss> to the <gloss type="to">Secretary of
                                    State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Managua</hi></placeName>, <date calendar="gregorian" when="1912-01-15">
                                    <hi rend="italic">January 15, 1912</hi></date>.</dateline>
                        </opener>
                        <p>The President and Minister for Foreign Affairs agree to appoint Mr.
                            Thayer at $6,000 per annum.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Gunther.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>