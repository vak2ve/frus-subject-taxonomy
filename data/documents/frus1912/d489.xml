<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-01-26T23:59:59-05:00" frus:doc-dateTime-min="1912-01-26T00:00:00-05:00" n="489" subtype="historical-document" type="document" xml:id="d489">
                        <note rend="inline" type="source">File No. 839.00/488.]</note>
                        <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                        <opener>
                            <dateline rendition="#right">
                                <date calendar="gregorian" when="1912-01-26">
                                    <hi rend="italic">January 26, 1912</hi></date>.</dateline>
                        </opener>
                        <p>Furniss telegraphs: <quote rend="blockquote">
                                <p>I am convinced that the Haitian Government earnestly desires to
                                    maintain neutrality. Reports false as to shipment of arms and
                                    ammunition.</p>
                            </quote>
                        </p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Knox.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>