                <note rend="inline" type="source">File No. 839.00/488.]</note>
                <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <date calendar="gregorian" when="1912-01-26">
                            <hi rend="italic">January 26, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>Furniss telegraphs: <quote rend="blockquote">
                        <p>I am convinced that the Haitian Government earnestly desires to maintain
                            neutrality. Reports false as to shipment of arms and ammunition.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Knox.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
