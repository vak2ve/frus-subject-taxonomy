                <note rend="inline" type="source">File No. 839.00/723.]</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">American Minister</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.—Extract.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1912-11-29">
                            <hi rend="italic">November 29, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="italic">Petrel</hi> will reach Santo Domingo about December 12.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Knox.</hi>
                    </signed>
                </closer>
            </div>
        </body>
