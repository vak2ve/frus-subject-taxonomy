                subtype="historical-document" type="document" xml:id="d418">
                <note rend="inline" type="source">File No. 811.34537/107.</note>
                <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                <opener>
                    <seg rendition="#left">No. 477.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1912-10-23">
                            <hi rend="italic">October 23, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to transmit herewith the final
                        texts<note n="2" xml:id="d418fn2">Printed below, inclosure to No.
                        571.</note> in English and Spanish of the proposed convention for the
                    enlargement of the Guantánamo naval station.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">A. M. Beaupré</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
