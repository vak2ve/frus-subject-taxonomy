<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-11-09T23:59:59-05:00" frus:doc-dateTime-min="1912-11-09T00:00:00-05:00" n="1813" subtype="historical-document" type="document" xml:id="d1813">
                        <note rend="inline" type="source">File No. 367.11/41A.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the <gloss type="to">American
                                    Ambassador</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1912-11-09">
                                    <hi rend="italic">November 9, 1912</hi></date>.</dateline>
                        </opener>
                        <p>Armored cruisers <hi rend="italic">Tennessee</hi> and <hi rend="italic">Montana</hi> sail November 12 at latest. Will arrive Smyrna about
                            November 29 and Beirut about December 1, respectively.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Wilson.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>