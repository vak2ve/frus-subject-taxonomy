<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-05-11T23:59:59-05:00" frus:doc-dateTime-min="1912-05-11T00:00:00-05:00" n="1648" subtype="historical-document" type="document" xml:id="d1648">
                        <note rend="inline" type="source">File No. 819.74/15.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the <gloss type="to">Secretary of the
                                    Navy</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Extract]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1912-05-11">
                                    <hi rend="italic">May 11, 1912</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your letter of the 22d ultimo regarding the construction of
                            wireless telegraph stations in Panama and to transmit herewith for your
                            information copy of an instruction<note n="1" xml:id="d1648fn1">This is
                                the instruction of May 13 (see infra).</note> to the American
                            Minister at Panama.</p>
                        <p>I have [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Huntington Wilson.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>