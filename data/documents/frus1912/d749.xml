                subtype="historical-document" type="document" xml:id="d749">
                <note rend="inline" type="source">File No. 815.51/217.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Minister</gloss> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1911-02-21">
                            <hi rend="italic">February 21, 1911</hi>
                        </date>.</dateline>
                </opener>
                <p>Conclusion of any loan contract by Honduras prohibited by the Assembly on
                    February 20, pending report by a Commission of Jurists appointed to study the
                    debt of Honduras and ascertain its amount.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">McCreery.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
