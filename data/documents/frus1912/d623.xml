<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-12-18T23:59:59-05:00" frus:doc-dateTime-min="1912-12-18T00:00:00-05:00" n="623" subtype="historical-document" type="document" xml:id="d623">
                        <note rend="inline" type="source">File No. 422.11 G93/556.]</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Chargé
                                    d’Affaires</gloss> to the <gloss type="to">Secretary of
                                    State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Quito</hi></placeName>, <date calendar="gregorian" when="1912-12-18">
                                    <hi rend="italic">December 18, 1912</hi></date>.</dateline>
                        </opener>
                        <p>The President of the Senate, Doctor Alfredo Baquerizo Moreno, has been
                            appointed to represent Ecuador on the arbitral tribunal.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bingham.</hi>
                            </signed>
                        </closer>
                    </div>
                </body></text></TEI>