                subtype="historical-document" type="document" xml:id="d456">
                <note rend="inline" type="source">File No. 837.6112/26.</note>
                <head>
                    <hi rend="italic">Mr. <persName type="from">Isaac K. Champion</persName> to the
                            <gloss type="to">Assistant Solicitor of the Department of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Habana</hi>
                        </placeName> ([<date ana="#date_undated-inferred-from-document-content"
                            calendar="gregorian" notAfter="1912-12-28T23:59:59-05:00"
                            notBefore="1912-12-15T00:00:00-05:29">undated</date>;] <hi rend="italic"
                            >rec’d. Dec. 28, 1912</hi>).</dateline>
                </opener>
                <p>Very important to have immediate decision my affair, delay losing us valuable
                    time for survey. Please cable when I can expect decision.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Isaac Kay Champion</hi>.</signed>
                </closer>
            </div>
        </body>
