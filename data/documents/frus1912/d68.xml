                subtype="historical-document" type="document" xml:id="d68">
                <note rend="inline" type="source">File No. 701.9311/131.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Chinese Minister</gloss> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chinese Legation</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1912-02-14">
                            <hi rend="italic">February 14, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I am instructed by my Government to inform you
                    that the Emperor of China, by a decree dated the 12th of February, has formally
                    abdicated the throne, and vested his excellency Yuan Shih Kai with full power to
                    adopt and establish a republican form of government; and that pending the
                    establishment of such a government the diplomatic and consular officers of China
                    abroad are to continue in the discharge of their respective functions as
                    representatives of China without interruption.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Chang Yin Tang.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
