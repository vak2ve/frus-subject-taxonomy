                subtype="historical-document" type="document" xml:id="d4">
                <note rend="inline" type="source">File No. 811.44 Sh 5/a.</note>
                <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1912-10-31">
                            <hi rend="italic">October 31, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="italic">To the diplomatic and consular officers of the United
                        States:</hi>
                </p>
                <p>Vice President Sherman died nine forty-two last night, funeral November second,
                    two p.m. President by proclamation to-day orders representatives of the United
                    States in foreign countries to pay appropriate tribute for a period of thirty
                    days.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Adee.</hi>
                    </signed>
                </closer>
            </div>
        </body>
