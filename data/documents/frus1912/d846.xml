                subtype="historical-document" type="document" xml:id="d846">
                <note rend="inline" type="source">File No. 882.51/307A.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">Special Representative of Dr. Falkner</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1912-03-07">
                            <hi rend="italic">March 7, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p rend="flushleft">Mr. <hi rend="smallcaps">Robert P. Skinner</hi>, <lb/>
                    <hi rend="italic">American Consul General, Hamburg, Germany:</hi>
                </p>
                <p>You are to be detailed for not exceeding two months as Special Representative of
                    Dr. Roland P. Falkner, Financial Representative of Liberia. Cable whether you
                    can meet Reed Paige Clark, General Receiver of Customs of Liberia, at Embassy in
                    London on March 25, who will have full instructions.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wilson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
