<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-05-15T23:59:59-05:00" frus:doc-dateTime-min="1912-05-15T00:00:00-05:00" n="470" subtype="historical-document" type="document" xml:id="d470">
                        <note rend="inline" type="source">File No. 859.001F87/4.]</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Minister of Denmark</gloss> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Legation of Denmark</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1912-05-15">
                                    <hi rend="italic">May 15, 1912</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Mr. Secretary of State</hi>: I have the honor to
                            fulfill the painful duty of informing your excellency that His Majesty
                            my August Sovereign, King Frederik the VIII, died last night in the city
                            of Hamburg (Germany), while on a journey to regain His health.</p>
                        <p>Please accept [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">C. Moltke.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>