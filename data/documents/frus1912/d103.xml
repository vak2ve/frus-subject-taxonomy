<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-07-22T23:59:59-05:00" frus:doc-dateTime-min="1912-07-22T00:00:00-05:00" n="103" subtype="historical-document" type="document" xml:id="d103">
                        <note rend="inline" type="source">File No. 893.00/1384.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Ambassador to
                                    Japan</gloss> to the <gloss type="to">Secretary of
                                State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Summary.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                                    <hi rend="italic">Tokio</hi></placeName>, <date calendar="gregorian" when="1912-07-22">
                                    <hi rend="italic">July 22, 1912</hi></date>.</dateline>
                        </opener>
                        <p>This telegram acknowledges receipt of the Department’s instructions of
                            July 20 and says that the Minister for Foreign Affairs promises to give
                            the matter careful consideration.</p>
                    </div>
                    </body></text></TEI>