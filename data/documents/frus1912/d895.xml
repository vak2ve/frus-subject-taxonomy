<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-02-28T23:59:59-05:00" frus:doc-dateTime-min="1912-02-28T00:00:00-05:00" n="895" subtype="historical-document" type="document" xml:id="d895">
                        <note rend="inline" type="source">File No. 850a.001/2.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Grand Duchess</gloss> to the
                                    <gloss type="to">President</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Colmarberg</hi></placeName>, <date calendar="gregorian" when="1912-02-28">
                                    <hi rend="italic">February 28, 1912</hi></date>.</dateline>
                        </opener>
                        <p>I thank you most sincerely for the expression of sympathy so kindly
                            offered by yourself and the Government and people of the United States
                            on the occasion of our sad bereavement.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Marie Adelaide.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>