<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-01-11T23:59:59-05:00" frus:doc-dateTime-min="1912-01-11T00:00:00-05:00" n="1635" subtype="historical-document" type="document" xml:id="d1635">
                        <note rend="inline" type="source">File No. 819.74/6.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">American Minister</gloss></hi>.</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1912-01-11">
                                    <hi rend="italic">January 11, 1912</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: The Department acknowledges the receipt
                            of your confidential despatch No. 33, of December 26, 1911, relative to
                            the establishment of wireless telegraph stations on the Ishthmus of
                            Panama.</p>
                        <p>A copy of your despatch has been transmitted to the Secretary of the
                            Navy, for his information.</p>
                        <p>I am [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">P. C. Knox.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>