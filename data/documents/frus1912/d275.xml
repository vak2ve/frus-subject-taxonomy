<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1911-11-27T21:00:00-05:00" frus:doc-dateTime-min="1911-11-27T21:00:00-05:00" n="275" subtype="historical-document" type="document" xml:id="d275">
                        <note rend="inline" type="source">File No. 893.00/701.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Minister</gloss> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Peking</hi></placeName>, <date calendar="gregorian" when="1911-11-28T10:00:00+08:00">
                                    <hi rend="italic">November 28, 1911—10 a.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>I am requesting the Admiral to send 70 more marines for east side of
                            quarter.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Calhoun.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>