<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-11-11T23:59:59-05:00" frus:doc-dateTime-min="1912-11-11T00:00:00-05:00" n="1823" subtype="historical-document" type="document" xml:id="d1823">
                        <note rend="inline" type="source">File No. 367.11/27.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Ambassador to
                                    France</gloss> to the <gloss type="to">Secretary of
                                    State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                                    <hi rend="italic">Paris</hi></placeName>, <date calendar="gregorian" when="1912-11-11">
                                    <hi rend="italic">November 11, 1912</hi></date>.</dateline>
                        </opener>
                        <p>Your November 8. Instructions in accordance therewith have been sent by
                            the French Government.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Herrick.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>