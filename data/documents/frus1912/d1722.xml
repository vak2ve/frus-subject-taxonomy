<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-04-23T23:59:59-05:00" frus:doc-dateTime-min="1912-04-23T00:00:00-05:00" n="1722" subtype="historical-document" type="document" xml:id="d1722">
                        <note rend="inline" type="source">File No. 823.124/4.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Minister</gloss> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Lima</hi></placeName>, <date calendar="gregorian" when="1912-04-23">
                                    <hi rend="italic">April 23, 1912</hi></date>.</dateline>
                        </opener>
                        <p>Full power will be given the expert by means of a contract to continue
                            until the work is finished.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Howard.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>