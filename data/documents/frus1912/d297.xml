<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1911-12-12T23:59:59-05:00" frus:doc-dateTime-min="1911-12-12T00:00:00-05:00" n="297" subtype="historical-document" type="document" xml:id="d297">
                        <note rend="inline" type="source">File No. 893.00/772.</note>
                        <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                        <opener>
                            <dateline rendition="#right">
                                <date calendar="gregorian" when="1911-12-12">
                                    <hi rend="smallcaps">December</hi>
                                    <hi rend="italic">12, 1911</hi></date>.</dateline>
                        </opener>
                        <p rend="center">[Telegram.—Extract. Transmitted to the Secretary of State
                            December 12, 1911.]</p>
                        <p>Wu Ting Fang, recognized by all factions as in charge of foreign affairs,
                            has submitted apology for firing upon <hi rend="italic">Nanshan</hi> and
                            has given assurance of no repetition.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Murdock.</hi>
                            </signed>
                        </closer>
                    </div>
                </body></text></TEI>