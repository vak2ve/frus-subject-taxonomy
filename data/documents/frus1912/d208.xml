<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-06-15T21:00:00-05:00" frus:doc-dateTime-min="1912-06-15T21:00:00-05:00" n="208" subtype="historical-document" type="document" xml:id="d208">
                            <note rend="inline" type="source">File No. 893.51/945.</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the <gloss type="to">American Ambassador to
                                    France</gloss></hi>.</head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Department of State</hi>, <lb/>
                                        <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1912-06-15T21:00:00-05:00">
                                        <hi rend="italic">June 15, 1912—9 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Your June 13—12 a.m. If the other Governments concerned accept the
                                proposed agreement this Government also approves.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Knox.</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>