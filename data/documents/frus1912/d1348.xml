                <note rend="inline" type="source">File No. 412.11/36.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Ambassador</gloss> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1911-10-28">
                            <hi rend="italic">October 28, 1911</hi>
                        </date>.</dateline>
                </opener>
                <p>The President refuses to grant a further extension of time for filing claims
                    before the Claims Commission.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wilson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
