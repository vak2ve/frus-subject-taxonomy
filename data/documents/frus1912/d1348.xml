<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1911-10-28T23:59:59-05:00" frus:doc-dateTime-min="1911-10-28T00:00:00-05:00" n="1348" subtype="historical-document" type="document" xml:id="d1348">
                        <note rend="inline" type="source">File No. 412.11/36.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Ambassador</gloss> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                                    <hi rend="italic">Mexico</hi></placeName>, <date calendar="gregorian" when="1911-10-28">
                                    <hi rend="italic">October 28, 1911</hi></date>.</dateline>
                        </opener>
                        <p>The President refuses to grant a further extension of time for filing
                            claims before the Claims Commission.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Wilson.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>