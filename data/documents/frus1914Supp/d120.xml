<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-10T04:00:00-05:00" frus:doc-dateTime-min="1914-08-10T04:00:00-05:00" n="120" subtype="historical-document" type="document" xml:id="d120">
                        <note rend="inline" type="source">File No. 763.72/310</note>
                        <head>
                            <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName corresp="#p_PFC1" type="from"><hi rend="italic">Penfield</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Vienna</hi></placeName>, <date calendar="gregorian" when="1914-08-10T10:00:00+01:00">
                                <hi rend="italic">August 10, 1914, 10 a.m.</hi>
                            </date>
                            <lb/> [<hi rend="italic">Received 2:30 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Austria-Hungary declared war against Montenegro 9th instant.</p>
                        <closer>[File copy not signed].</closer>
                    </div>
                    </body></text></TEI>