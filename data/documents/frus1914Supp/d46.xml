                subtype="historical-document" type="document" xml:id="d46">
                <note rend="inline" type="source">File No. 763.72/42a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassadors, Ministers, and <gloss type="to">Principal Consular
                            Officers</gloss> in European Countries</hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-07-31T17:00:00-05:00">
                        <hi rend="italic">July 31, 1914, 5 p.m.</hi>
                    </date>
                </dateline>
                <p rend="center">[Circular telegram]</p>
                <p>Telegraph Department daily as to military, political and financial situation
                    without waiting for official confirmation of reports. State basis of information
                    and opinion as to credibility.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
