<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-10-05T13:00:00-05:00" frus:doc-dateTime-min="1914-10-05T00:00:00-05:00" n="896" subtype="historical-document" type="document" xml:id="d896">
                        <note rend="inline" type="source">File No. 763.72/1047</note>
                        <head>
                            <hi rend="italic">The Vice Consul at Kingston</hi>, <hi rend="italic">Jamaica</hi> (<persName corresp="#p_BAJ1" type="from"><hi rend="italic">Bundy</hi></persName>), <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Consulate</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Kingston, Jamaica</hi></placeName>, <date ana="#date_undated-inferred-from-document-content" calendar="gregorian" notAfter="1914-10-05T13:00:00-05:00" notBefore="1914-10-05T00:00:00-05:00"><hi rend="italic">undated</hi></date>. <lb/> [<hi rend="italic">Received October 5,
                                1914, 1 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>British authorities Jamaica ask boats under American flag carry no
                            Germans or Austrians, either crew or passengers, liable military duty
                            avoiding requirement search.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BAJ1">
                                    <hi rend="smallcaps">Bundy</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>