    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-13T06:00:00-05:00"
                frus:doc-dateTime-min="1914-08-13T06:00:00-05:00" n="128"
                subtype="historical-document" type="document" xml:id="d128">
                <note rend="inline" type="source">File No. 763.72/397</note>
                <head>
                    <hi rend="italic">The Vice Consul General at Cairo</hi> (<persName
                        corresp="#p_KP1" type="from">
                        <hi rend="italic">Knabenshue</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Consulate General</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Cairo</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-13T13:00:00+02:00">
                        <hi rend="italic">August 13, 1914, 1 p.m.</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received 3:30 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Referring to your cipher telegram August 12, 4 p.m.,<note n="3" xml:id="d128fn3"
                        >Not printed.</note> was informed to-day by the British Chargé d’Affaires
                    that Great Britain has declared war against Austria. Communications have ceased
                    between Egyptian Government and German diplomatic representative and consuls and
                    similar action will be taken with regard to Austrian representatives.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_KP1">
                            <hi rend="smallcaps">Knabenshue</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
