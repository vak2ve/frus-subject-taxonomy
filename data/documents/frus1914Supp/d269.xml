<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-12-11T15:00:00-05:00" frus:doc-dateTime-min="1914-12-11T15:00:00-05:00" n="269" subtype="historical-document" type="document" xml:id="d269">
                        <note rend="inline" type="source">File No. 883.00/49</note>
                        <head>
                            <hi rend="italic">The Consul General at Cairo</hi> (<persName corresp="#p_AO1" type="from"><hi rend="italic">Arnold</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Consulate General</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Cairo</hi></placeName>, <date calendar="gregorian" when="1914-12-11T22:00:00+02:00">
                                <hi rend="italic">December 11, 1914, 10 p.m.</hi>
                            </date>
                            <lb/> [<hi rend="italic">Received December 12, 10 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>
                            <persName>Prince Hussein</persName>, uncle of
                                <persName>Khedive</persName>, rumored about to be proclaimed by
                            British as Sultan of Egypt. If occurrence transpires and if diplomatic
                            agents invited to be present at the ceremony, telegraph instructions in
                            view of attitude of Turkey toward Egypt.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_AO1">
                                    <hi rend="smallcaps">Arnold</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>