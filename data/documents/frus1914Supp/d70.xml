    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-02T23:59:59-05:00"
                frus:doc-dateTime-min="1914-08-02T00:00:00-05:00" n="70"
                subtype="historical-document" type="document" xml:id="d70">
                <note rend="inline" type="source">File No. 763.72/53</note>
                <head>
                    <hi rend="italic">The German Chargé d’Affaires</hi> (<persName
                        corresp="#p_HVHEK1" type="from">
                        <hi rend="italic">Haniel</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">German Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Newport, Rhode Island</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-02">
                        <hi rend="italic">August 2, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 10:10 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>I am instructed by my Government to inform you that since first of August Germany
                    is in state of war with Russia.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HVHEK1">
                            <hi rend="smallcaps">Haniel</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
