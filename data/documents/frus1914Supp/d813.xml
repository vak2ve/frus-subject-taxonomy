<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-10-27T23:59:59-05:00" frus:doc-dateTime-min="1914-10-27T00:00:00-05:00" n="813" subtype="historical-document" type="document" xml:id="d813">
                        <note rend="inline" type="source">File No. 841.731/54a</note>
                        <head>
                            <hi rend="italic">The Acting <gloss type="from">Secretary of
                                    State</gloss> to the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                        <dateline>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-10-27">
                                <hi rend="italic">October 27, 1914</hi>.</date>
                        </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>405. Please confirm advices cable companies that cable addresses and
                            short signatures may now be used.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>