                subtype="historical-document" type="document" xml:id="d413">
                <note rend="inline" type="source">File No. 763.72112/483</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW2"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Berlin</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-15">
                        <hi rend="italic">December 15, 1914</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received December 16, 5:05 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>1099. By proclamation dated 14th instant German Government has added aluminum and
                    nickel to list of conditional contraband as numbers 19 and 20, respectively.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW2">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
