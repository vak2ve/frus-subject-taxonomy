<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-10-17T23:40:00-05:00" frus:doc-dateTime-min="1914-10-16T16:00:00-05:00" n="1343" subtype="historical-document" type="document" xml:id="d1343">
                        <note rend="inline" type="source">File No. 763.72112/181</note>
                        <head>
                            <hi rend="italic">The Chargé d’Affaires in Russia</hi> (<persName corresp="#p_WCS1" type="from"><hi rend="italic">Wilson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Petrograd</hi></placeName>, <date ana="#date_undated-inferred-from-document-content" calendar="gregorian" notAfter="1914-10-17T23:40:00-05:00" notBefore="1914-10-17T00:00:00+03:00"><hi rend="italic">undated</hi></date>. <lb/> [<hi rend="italic">Received October 17,
                                1914, 11:40 p.m.]</hi>
                        </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>69. Department’s circular telegram, September 24.<note n="2" xml:id="d1343fn1">
                                <hi rend="italic">Ante</hi>, <ref target="#pg_831">p.
                                831</ref>.</note> Russian Government is happy to render homage to
                            the noble initiatives of King of Spain and President of the United
                            States. In response to their appeal, Russian authorities have been
                            ordered to give the broadest application to Article 29 of the
                            Declaration of London.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_WCS1">
                                    <hi rend="smallcaps">Wilson</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>