<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-07-31T12:00:00-05:00" frus:doc-dateTime-min="1914-07-31T12:00:00-05:00" n="47" subtype="historical-document" type="document" xml:id="d47">
                        <note rend="inline" type="source">File No. 763.72/36</note>
                        <head>
                            <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName corresp="#p_PFC1" type="from"><hi rend="italic">Penfield</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Vienna</hi></placeName>, <date calendar="gregorian" when="1914-07-31T18:00:00+01:00">
                                <hi rend="italic">July 31, 1914, 6 p.m.</hi>
                            </date>
                            <lb/> [<hi rend="italic">Received 5:17 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Emperor this afternoon orders general mobilization all armed forces
                            Austria-Hungary including Landsturm. This is extremest military muster
                            of realm. Situation growing in seriousness.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_PFC1">
                                    <hi rend="smallcaps">Penfield</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>