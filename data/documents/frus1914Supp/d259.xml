    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-02T08:16:00-05:00"
                frus:doc-dateTime-min="1914-12-02T08:16:00-05:00" n="259"
                subtype="historical-document" type="document" xml:id="d259">
                <note rend="inline" type="source">File No. 763.72/1277</note>
                <head>
                    <hi rend="italic">The Minister in Roumania, Servia, and Bulgaria</hi> (<persName
                        corresp="#p_VCJ1" type="from">
                        <hi rend="italic">Vopicka</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                    <note n="2" xml:id="d259fn1">Repeated to the Ambassador in Turkey, December
                        4.</note>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Bucharest</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-02T15:00:00+01:44">
                        <hi rend="italic">December 2, 1914, 3 p.m.</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received December 3, 7:15 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Servian Minister for Foreign Affairs telegraphs that he has been notified by the
                    Italian Minister in Servia that the Turkish Government <pb facs="0456" n="142"
                        xml:id="pg_142"/> proclaimed holy war against Servia and her Allies. The
                    Royal Servian Government considers that all the treaties and conventions between
                    Servian Kingdom and the Turkish Government have ceased to exist.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_VCJ1">
                            <hi rend="smallcaps">Vopicka</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
