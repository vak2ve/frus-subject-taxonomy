    <text>
        <body>
            <div frus:doc-dateTime-max="1914-09-07T23:59:59-05:00"
                frus:doc-dateTime-min="1914-09-07T00:00:00-05:00" n="370"
                subtype="historical-document" type="document" xml:id="d370">
                <note rend="inline" type="source">File No. 763.72112/124</note>
                <head>
                    <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="from">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                    <note n="1" xml:id="d370fn1">Repeated to the Ambassador in Great Britain,
                        September 10. The reply to the British inquiry received from the Ambassador
                        in Germany, dated September 4 (File No. 763.72112/121), was a repetition of
                        his telegram of August 10, <hi rend="italic">ante</hi>, <ref
                            target="#pg_216">p. 216</ref>.</note>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Vienna</hi>
                    </placeName>, <date calendar="gregorian" when="1914-09-07">
                        <hi rend="italic">September 7, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received September 8, 10 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>17. Your 21, September 2.<note n="2" xml:id="d370fn2">Not printed.</note>
                    Austro-Hungarian Government desires British Government be notified that they
                    will treat as absolute <pb facs="0537" n="223" xml:id="pg_223"/> or conditional
                    contraband those objects and material which are enumerated in Articles 22 and 24
                    of Declaration of London.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1" type="from">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
