    <text>
        <body>
            <div frus:doc-dateTime-max="1914-09-29T13:45:00-05:00"
                frus:doc-dateTime-min="1914-09-28T19:00:00-05:00" n="1270"
                subtype="historical-document" type="document" xml:id="d1270">
                <note rend="inline" type="source">File No. 763.72116/57</note>
                <head>
                    <hi rend="italic">The Minister in Belgium</hi>, (<persName corresp="#p_WB1"
                        type="from">
                        <hi rend="italic">Whitlock</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <placeName>
                        <hi rend="italic">Antwerp</hi>
                    </placeName>, <date ana="#date_undated-inferred-from-document-content"
                        calendar="gregorian" notAfter="1914-09-29T13:45:00-05:00"
                        notBefore="1914-09-29T00:00:00+00:00">
                        <hi rend="italic">undated</hi>
                    </date>. <lb/> [<hi rend="italic">Received September 29, 1914, 1:45
                    p.m.</hi>]</dateline>
                <p rend="center">[Telegram]</p>
                <p>The time has not come and the occasion will not permit me to report on the
                    excesses of German soldiers in Belgium. While there may have been exaggerations
                    in the published stories, they are in spirit true and at a later date I shall
                    make a comprehensive report on this dreadful subject.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WB1">
                            <hi rend="smallcaps">Whitlock</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
