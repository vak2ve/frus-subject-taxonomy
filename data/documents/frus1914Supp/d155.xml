                subtype="historical-document" type="document" xml:id="d155">
                <note rend="inline" type="source">File No. 763.72/580</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName corresp="#p_PTN1"
                        type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Rome</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-23">
                        <hi rend="italic">August 23, 1914, noon</hi>.</date>
                    <lb/> [<hi rend="italic">Received 2 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Please send following to office of Naval Intelligence, Navy Department, from
                    Naval Attaché:</p>
                <p>Italy steadily preparing with expectation of good excuse arising in Balkans to
                    declare war on [Austria?]. Italian fleet concentrated Taranto. Abruzzi appointed
                    Commander in Chief. Austrian naval vessel Zenta sunk. Reported French-English
                    fleet basing near Corfu.</p>
                <closer>
                    <hi rend="smallcaps">American Embassy</hi>
                </closer>
            </div>
        </body>
