<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-25T15:00:00-05:00" frus:doc-dateTime-min="1914-08-25T15:00:00-05:00" n="161" subtype="historical-document" type="document" xml:id="d161">
                        <note rend="inline" type="source">File No. 124.551/12</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Belgium</hi> (<persName corresp="#p_WB1" type="to"><hi rend="italic">Whitlock</hi></persName>)</head>
                        <dateline>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-08-25T15:00:00-05:00">
                                <hi rend="italic">August 25, 1914, 3 p.m.</hi>
                            </date>
                        </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Your August 19, 6 p.m.<note n="1" xml:id="d161fn1">Not printed.</note>
                            Department must be guided by your judgment as to whether it is advisable
                            to move Legation from Brussels to Antwerp.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BWJ1">
                                    <hi rend="smallcaps">Bryan</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>