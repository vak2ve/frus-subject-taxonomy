                subtype="historical-document" type="document" xml:id="d368">
                <note rend="inline" type="source">File No. 763.72112/119</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                    <note n="1" xml:id="d368fn1">Transmitted to the Ambassadors in Germany and
                        Austria-Hungary, September 2.</note>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">London</hi>
                    </placeName>, <date calendar="gregorian" when="1914-09-01">
                        <hi rend="italic">September 1, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 5:30 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>547. With reference to the attitude of the Austro-Hungarian and German
                    Governments regarding the Declaration of London, the British Government ask that
                    further inquiry be made as to whether the two Governments in question have
                    specified the articles which they intend to treat as contraband of war.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">American Ambassador</hi>
                    </signed>
                </closer>
            </div>
        </body>
