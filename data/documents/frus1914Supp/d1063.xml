    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-13T23:59:59-05:00"
                frus:doc-dateTime-min="1914-08-13T00:00:00-05:00" n="1063"
                subtype="historical-document" type="document" xml:id="d1063">
                <note rend="inline" type="source">File No. 763.72111/322</note>
                <head>
                    <hi rend="italic">The Italian Chargé d’Affaires</hi> (<persName corresp="#p_BR1"
                        type="from">
                        <hi rend="italic">Borghetti</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">Italian Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Manchester, Massachusetts</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-13">
                        <hi rend="italic">August 13, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received August 14</hi>.] </dateline>
                <p rend="center">[Translation]</p>
                <p rend="flushleft">No. 1267]</p>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: By order of my Government I
                    have the honor to inform your excellency that by Royal decree of the 6th instant
                    the limit of territorial waters at sea, for the purposes of neutrality, has been
                    fixed at six nautical miles, and that special rules will be framed for the
                    determination of the said territorial waters in bays, bights, and gulfs, in
                    accordance with Article 2 of the said decree.<note n="1" xml:id="d1063fn1">A
                        similar extension of the limit of territorial waters (to five miles) decreed
                        by the Uruguayan Government on August 7, was transmitted by the Minister in
                        Uruguay in his No. 700, August 13 (File No. 763.72111/438).</note>
                </p>
                <p>This affords me a welcome opportunity to renew [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BR1">
                            <hi rend="smallcaps">R. Borghetti</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
