    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-04T23:59:59-05:00"
                frus:doc-dateTime-min="1914-12-04T00:00:00-05:00" n="670"
                subtype="historical-document" type="document" xml:id="d670">
                <note rend="inline" type="source">File No. 611.51L9/9</note>
                <head>
                    <hi rend="italic">The Secretary of the Embassy in France</hi> (<persName
                        corresp="#p_BRW1" type="from">
                        <hi rend="italic">Bliss</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Paris</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-04">
                        <hi rend="italic">December 4, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 12 midnight</hi>.] </dateline>
                <p rend="center">[Telegram]</p>
                <p>349. Your 303, 25th. Mr. <persName>Garrett</persName> given to understand by
                    Foreign Office that French Government might possibly grant request, if American
                    Government would give assurance that chrome ore sold to American manufacturers
                    was destined for American consumption and would not be exported.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BRW1">
                            <hi rend="smallcaps">Bliss</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
