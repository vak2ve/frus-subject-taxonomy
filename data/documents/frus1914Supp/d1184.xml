    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-19T23:59:59-05:00"
                frus:doc-dateTime-min="1914-12-19T00:00:00-05:00" n="1184"
                subtype="historical-document" type="document" xml:id="d1184">
                <note rend="inline" type="source">File No. 704.6291/6</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Persia</hi> (<persName corresp="#p_CJL1" type="to">
                        <hi rend="italic">Caldwell</hi>
                    </persName>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-19">
                        <hi rend="italic">December 19, 1914</hi>.</date>
                </dateline>
                <p rend="center">[Telegram]</p>
                <p>Department’s November 5.<note n="1" xml:id="d1184fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_745">p. 745</ref>.</note>
                    German Ambassador here states you have assumed protection Germans in Persia
                    owing to urgency. Department approves action and at request of Ambassador
                    desires you also when necessary take charge German interests in parts of Persia
                    occupied by Russian forces.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
