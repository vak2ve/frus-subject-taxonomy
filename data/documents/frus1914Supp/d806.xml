                subtype="historical-document" type="document" xml:id="d806">
                <note rend="inline" type="source">File No. 841.731/32A</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-10-01">
                        <hi rend="italic">October 1, 1914</hi>.</date>
                </dateline>
                <p rend="center">[Telegram]</p>
                <p>229. Are full address and signature still necessary on Department’s telegrams to
                    London and beyond?</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
