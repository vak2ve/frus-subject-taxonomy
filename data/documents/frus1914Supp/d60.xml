<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-01T09:00:00-05:00" frus:doc-dateTime-min="1914-08-01T09:00:00-05:00" n="60" subtype="historical-document" type="document" xml:id="d60">
                        <note rend="inline" type="source">File No. 763.72/38</note>
                        <head>
                            <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_HMT1" type="from"><hi rend="italic">Herrick</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Paris</hi></placeName>, <date calendar="gregorian" when="1914-08-01T14:00:00+00:00">
                                <hi rend="italic">August 1, 1914, 2 a.m.</hi>
                            </date>
                            <lb/> [<hi rend="italic">Received 11:01 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Orders for mobilization of French Army issued to-night.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_HMT1">
                                    <hi rend="smallcaps">Herrick</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>