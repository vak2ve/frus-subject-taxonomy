    <text>
        <body>
            <div frus:doc-dateTime-max="1914-10-30T23:59:59-05:00"
                frus:doc-dateTime-min="1914-10-30T00:00:00-05:00" n="814"
                subtype="historical-document" type="document" xml:id="d814">
                <note rend="inline" type="source">File No. 841.731/55</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">London</hi>
                    </placeName>, <date calendar="gregorian" when="1914-10-30">
                        <hi rend="italic">October 30, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 8 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>945. Your telegram 405, 27th. Foreign Office informs me that private individuals
                    telegraphing to this country are allowed to use registered cable addresses and
                    that signatures may be abbreviated but must indicate the source
                        unmistakably.<note n="1" xml:id="d814fn1">Following the receipt of this
                        telegram, the Department resumed the use of its own abbreviated forms of
                        addresses and signatures.</note>
                </p>
                <closer>
                    <hi rend="smallcaps">American Ambassador</hi>
                </closer>
            </div>
        </body>
