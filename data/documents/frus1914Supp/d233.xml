                subtype="historical-document" type="document" xml:id="d233">
                <note rend="inline" type="source">File No. 763.72/1143</note>
                <head>
                    <hi rend="italic">The Ambassador in Turkey</hi> (<persName corresp="#p_MH1"
                        type="from">
                        <hi rend="italic">Morgenthau</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Constantinople</hi>
                    </placeName>, <date calendar="gregorian" when="1914-10-29T11:00:00+02:00">
                        <hi rend="italic">October 29, 1914, 11 a.m.</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received 12:15 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>British Ambassador has just received a telegram from Cairo that Bedouins have
                    crossed frontier on their way to Suez Canal. He writes me it may mean war unless
                    his demand to the Grand Vizier to immediately withdraw Bedouins is complied
                    with.</p>
                <closer>
                    <hi rend="smallcaps">American Ambassador</hi>
                </closer>
            </div>
        </body>
