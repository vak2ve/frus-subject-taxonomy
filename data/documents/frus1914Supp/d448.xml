                subtype="historical-document" type="document" xml:id="d448">
                <note rend="inline" type="source">File No. 763.72112/568</note>
                <head>
                    <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="fro">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Vienna</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-16">
                        <hi rend="italic">December 16, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received December 17, 10 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>351. Your 258, November 8,<note n="1" xml:id="d448fn1">See footnote, <hi
                            rend="italic">ante</hi>, <ref target="#pg_291">p. 291</ref>
                    </note> Austro-Hungarian Government state that in navy regulations published May
                    2, 1913, raw cotton and cotton yarn are specified as non-contraband and
                    therefore free from seizure. Austro-Hungarian Government will adhere to this
                    rule conditional on reciprocity enemy states.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
