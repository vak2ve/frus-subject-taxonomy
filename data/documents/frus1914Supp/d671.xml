<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-12-07T08:30:00-05:00" frus:doc-dateTime-min="1914-12-06T19:00:00-05:00" n="671" subtype="historical-document" type="document" xml:id="d671">
                        <note rend="inline" type="source">File No. 611.46c 9/11</note>
                        <head>
                            <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">London</hi></placeName>, <date ana="#date_undated-inferred-from-document-content" calendar="gregorian" notAfter="1914-12-07T08:30:00-05:00" notBefore="1914-12-07T00:00:00+00:00"><hi rend="italic">undated</hi></date>. <lb/> [<hi rend="italic">Received December 7,
                                1914, 8:30 a.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>1201. Your 640, November 28, 660, December 2, 665, December 2,<note n="1" xml:id="d671fn1">Not printed.</note> and 681, December 4, presented
                            and are covered by my 1199, December 6.<note n="2" xml:id="d671fn2">
                                <hi rend="italic">Ante</hi>, <ref target="#pg_356">p. 356</ref>.
                                This is the Ambassador’s telegram conveying the proposed “working
                                arrangement” with regard both to embargoes and to interference with
                                ships and cargoes.</note>
                        </p>
                        <closer>
                            <hi rend="smallcaps">American Ambassador</hi>
                        </closer>
                    </div>
                    </body></text></TEI>