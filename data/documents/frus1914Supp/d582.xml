                subtype="historical-document" type="document" xml:id="d582">
                <note rend="inline" type="source">File No. 165.009/10</note>
                <head>
                    <hi rend="italic">The Minister in Sweden</hi> (<persName corresp="#p_MIN1"
                        type="from">
                        <hi rend="italic">Morris</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Stockholm</hi>
                    </placeName>, <date ana="#date_undated-inferred-from-document-content"
                        calendar="gregorian" notAfter="1914-10-17T19:45:00-05:00"
                        notBefore="1914-10-17T00:00:00+01:00">
                        <hi rend="italic">undated</hi>
                    </date>. <lb/> [<hi rend="italic">Received October 17, 1914, 7:45 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Department’s October 16 repeated from Christiania. Swedish authorities will not
                    prevent passage through Sweden of cotton shipped here from United States via
                    Norway or Denmark, but will not allow export to Germany of direct shipments from
                    United States to Swedish ports.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MIN1">
                            <hi rend="smallcaps">Morris</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
