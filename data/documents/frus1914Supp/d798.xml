<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-27T23:59:59-05:00" frus:doc-dateTime-min="1914-08-27T00:00:00-05:00" n="798" subtype="historical-document" type="document" xml:id="d798">
                        <note rend="inline" type="source">File No. 841.731</note>
                        <head>
                            <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi><note n="1" xml:id="d798fn1">Communicated to the American embassies
                                and legations concerned, August 28 (File No. 841.731/33a).</note>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">London</hi></placeName>, <date calendar="gregorian" when="1914-08-27">
                                <hi rend="italic">August 27, 1914</hi>.</date>
                            <lb/> [<hi rend="italic">Received 3:30 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>493. Please inform all foreign missions concerned that British censorship
                            regulations provide that only messages passing between diplomatic
                            missions and the Government at Washington may go in cipher. All others
                            must be open.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_PWH1">
                                    <hi rend="smallcaps">Page</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>