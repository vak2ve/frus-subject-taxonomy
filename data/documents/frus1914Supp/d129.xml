                subtype="historical-document" type="document" xml:id="d129">
                <note rend="inline" type="source">File No. 763.72/380</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">London</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-13">
                        <hi rend="italic">August 13, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 5:10 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>350. The Foreign Office has just notified me formally that a state of war exists
                    between Great Britain and Austria.</p>
                <closer>
                    <hi rend="smallcaps">American Ambassador</hi>
                </closer>
            </div>
        </body>
    </text>
