    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-04T23:59:59-05:00"
                frus:doc-dateTime-min="1914-12-04T00:00:00-05:00" n="1313"
                subtype="historical-document" type="document" xml:id="d1313">
                <note rend="inline" type="source">File No. 855.48/79</note>
                <head>
                    <hi rend="italic">The German Ambassador</hi> (<persName corresp="#p_BCJHV1"
                        type="from">
                        <hi rend="italic">Bernstorff</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">German Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-04">
                        <hi rend="italic">December 4, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received December 5</hi>.] </dateline>
                <p rend="center">[Translation]</p>
                <p rend="flushleft">No. 10078]</p>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: In acknowledging the receipt
                    of your excellency’s kind note of the 1st instant, I have the honor to reply to
                    your excellency that I concur in the proposals therein made.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BCJHV1">
                            <hi rend="smallcaps">J. Bernstorff</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
