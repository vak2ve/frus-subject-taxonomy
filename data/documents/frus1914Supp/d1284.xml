    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-24T23:59:59-05:00"
                frus:doc-dateTime-min="1914-12-24T00:00:00-05:00" n="1284"
                subtype="historical-document" type="document" xml:id="d1284">
                <note rend="inline" type="source">File No. 763.72/1255</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Roubaix</hi> (<persName corresp="#p_WJJC1" type="to">
                        <hi rend="italic">Watson</hi>
                    </persName>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-24">
                        <hi rend="italic">December 24, 1914</hi>.</date>
                </dateline>
                <p rend="flushleft">No. 8.]</p>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to your despatch No. 6 of October 17,
                    1914, in regard to negotiations to safeguard Roubaix, Tourcoing, and Lille, you
                    are instructed to avoid intervention in these matters in future and observe the
                    President’s proclamation of neutrality.</p>
                <p>I am [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Wilbur J. Carr</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
