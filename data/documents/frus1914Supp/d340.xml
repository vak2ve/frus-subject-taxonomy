<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-11-07T01:00:00-05:00" frus:doc-dateTime-min="1914-11-07T01:00:00-05:00" n="340" subtype="historical-document" type="document" xml:id="d340">
                        <note rend="inline" type="source">File No. 763.72/1176</note>
                        <head>
                            <hi rend="italic">The Consul at Nagasaki</hi> (<persName corresp="#p_DCF1" type="from"><hi rend="italic">Deichman</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Consulate</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Nagasaki</hi></placeName>, <date calendar="gregorian" when="1914-11-07T15:00:00+09:00">
                                <hi rend="italic">November 7, 1914, 3 p.m.</hi>
                            </date>
                            <lb/> [<hi rend="italic">Received 8 a.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Tsingtao fallen.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_DCF1">
                                    <hi rend="smallcaps">Deichman</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
