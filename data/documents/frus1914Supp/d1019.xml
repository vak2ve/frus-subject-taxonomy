    <text>
        <body>
            <div frus:doc-dateTime-max="1914-11-24T23:59:59-05:00"
                frus:doc-dateTime-min="1914-11-24T00:00:00-05:00" n="1019"
                subtype="historical-document" type="document" xml:id="d1019">
                <note rend="inline" type="source">File No. 763.72111/752</note>
                <head>
                    <hi rend="italic">The British Ambassador</hi> (<persName corresp="#p_SRSCA1"
                        type="from">
                        <hi rend="italic">Spring Rice</hi>
                    </persName>) <hi rend="italic">to the Acting <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <placeName>British Embassy</placeName>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-11-24">
                        <hi rend="italic">November 24, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received November 25</hi>.] </dateline>
                <p>
                    <hi rend="smallcaps">Dear Mr. <persName corresp="#p_LR1">Lansing</persName>
                    </hi>: With reference to your letter of the 20th instant<note n="1"
                        xml:id="d1019fn1">Not printed.</note> and previous correspondence respecting
                    the Italian <persName>S. S. <hi rend="italic">Amistà</hi>
                    </persName>, <persName corresp="#p_GSE1">Sir Edward Grey</persName> desires me
                    to inform you that he has only just heard that this vessel did in fact put into
                    Barbados on October 28, in accordance with her clearance papers. I am to express
                    to you <persName corresp="#p_GSE1">Sir Edward Grey</persName>’s regret for the
                    inaccuracy on this point which was, quite unintentionally, contained in my note
                    No. 371 of the 31st ultimo.<note n="2" xml:id="d1019fn2">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_629">p. 629</ref>.</note>
                </p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SRSCA1">
                            <hi rend="smallcaps">Cecil Spring Rice</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
