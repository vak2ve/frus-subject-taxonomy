    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-28T23:59:59-05:00"
                frus:doc-dateTime-min="1914-12-28T00:00:00-05:00" n="563"
                subtype="historical-document" type="document" xml:id="d563">
                <note rend="inline" type="source">File No. 768.72112/546</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">London</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-28">
                        <hi rend="italic">December 28, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 6 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>1342. Your 836, December 26,<note n="2" xml:id="d563fn2">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_372">p. 372</ref>.</note>
                    received 27th, was presented to Foreign Office to-day. <persName
                        corresp="#p_GSE1">Sir Edward Grey</persName> will not return to London until
                    30th when I shall have a conversation with him on the subject.</p>
                <closer>
                    <hi rend="smallcaps">American Ambassador</hi>
                </closer>
            </div>
        </body>
    </text>
