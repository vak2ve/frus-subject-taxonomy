    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-03T13:00:00-05:00"
                frus:doc-dateTime-min="1914-08-03T13:00:00-05:00" n="81"
                subtype="historical-document" type="document" xml:id="d81">
                <note rend="inline" type="source">File No. 763.72119/5</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">London</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-03T18:00:00+00:00">
                        <hi rend="italic">August 3, 1914, 6 p.m.</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received 8 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>258. Your August 1, 10 p.m.<note n="1" xml:id="d81fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_29">p. 29</ref>.</note> My
                    very definite opinion is that there is not the slightest chance of any result if
                    our good offices be offered at any continental capital. This is confirmed by the
                    judgment of the British Foreign Office. We may have a chance after the war has
                    reached a breathing space.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
