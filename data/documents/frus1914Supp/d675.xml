<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-12-22T23:59:59-05:00" frus:doc-dateTime-min="1914-12-22T00:00:00-05:00" n="675" subtype="historical-document" type="document" xml:id="d675">
                        <note rend="inline" type="source">File No. 611.479/89</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                        <dateline>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-12-22">
                                <hi rend="italic">December 22, 1914</hi>.</date>
                        </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>815. Hides from Melbourne for Avery and Lowry, Boston, guaranteed against
                            reexportation from United States. Use good offices to secure export.
                            Sydney cabled.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BWJ1">
                                    <hi rend="smallcaps">Bryan</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>