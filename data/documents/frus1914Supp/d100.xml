                subtype="historical-document" type="document" xml:id="d100">
                <note rend="inline" type="source">File No. 763.72111N39/9</note>
                <head>
                    <hi rend="italic">The Chargé d’Affaires in Denmark</hi> (<persName
                        corresp="#p_MAR1" type="from">
                        <hi rend="italic">Magruder</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Copenhagen</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-05T19:00:00+01:00">
                        <hi rend="italic">August 5, 1914, 7 p.m.</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received 10 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>The neutrality of Denmark proclaimed August 4.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MAR1">
                            <hi rend="smallcaps">Magruder</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
