                subtype="historical-document" type="document" xml:id="d1291">
                <note rend="inline" type="source">File No. 855.48/5</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-10-19">
                        <hi rend="italic">October 19, 1914</hi>.</date>
                </dateline>
                <p rend="center">[Telegram]</p>
                <p>341. Telegram from Embassy Berlin 17th instant states that German Government
                    approves of plan to supply the population of Belgium with food. You are
                    authorized therefore to proceed on lines of your 786 [783], October 6.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
