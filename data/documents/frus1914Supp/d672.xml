<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-12-09T23:59:59-05:00" frus:doc-dateTime-min="1914-12-09T00:00:00-05:00" n="672" subtype="historical-document" type="document" xml:id="d672">
                        <note rend="inline" type="source">File No. 611.51L9/10</note>
                        <head>The <gloss type="from">Secretary of State</gloss> to the Ambassador in
                            France (<persName corresp="#p_SWG1" type="to">Sharp</persName>)</head>
                        <dateline>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-12-09">
                                <hi rend="italic">December 9, 1914</hi>.</date>
                        </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>360. Your 349, 4th. American importers will give any bond required,
                            assuring importations chrome ore for American consumption only. Renew
                            representations.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BWJ1">
                                    <hi rend="smallcaps">Bryan</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>