                subtype="historical-document" type="document" xml:id="d875">
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Consul General at Rotterdam</hi> (<persName corresp="#p_LS1" type="to">
                        <hi rend="italic">Listoe</hi>
                    </persName>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-11-02">
                        <hi rend="italic">November 2, 1914</hi>.</date>
                </dateline>
                <p rend="center">[Telegram]</p>
                <p>Your November 1. The consulate should not undertake to forward any commercial
                    correspondence, as such mail should go by ordinary channels.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
