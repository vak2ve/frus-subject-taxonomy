                <note rend="inline" type="source">File No. 763.72111N39/3</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State to the Minister in
                            Belgium</gloss>
                    </hi> (<persName corresp="#p_WB1" type="to">
                        <hi rend="italic">Whitlock</hi>
                    </persName>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-04T18:00:00-05:00">
                        <hi rend="italic">August 4, 1914, 6 p.m.</hi>
                    </date>
                </dateline>
                <p rend="center">[Telegram]</p>
                <p>Regret telegram from parliamentary group arrived after war declared.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
