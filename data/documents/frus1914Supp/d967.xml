<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-31T23:59:59-05:00" frus:doc-dateTime-min="1914-08-31T00:00:00-05:00" n="967" subtype="historical-document" type="document" xml:id="d967">
                        <note rend="inline" type="source">File No. 763.72111/96</note>
                        <head>
                            <hi rend="italic">The German Ambassador</hi> (<persName corresp="#p_BCJHV1" type="from"><hi rend="italic">Bernstorff</hi></persName>) <hi rend="italic">to the (<gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <placeName>
                                <hi rend="italic">New York</hi></placeName>, <date calendar="gregorian" when="1914-08-31">
                                <hi rend="italic">August 31, 1914</hi>.</date>
                            <lb/> [<hi rend="italic">Received 12:20 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>I beg to draw your attention to the fact that the White Star liner <hi rend="italic">Adriatic</hi> entered this port armed with cannons and
                            has not left New York within twenty-four hours.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BCJHV1">
                                    <hi rend="smallcaps">J. Bernstorff</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>