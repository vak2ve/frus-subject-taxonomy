    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-07T23:59:59-05:00"
                frus:doc-dateTime-min="1914-08-07T00:00:00-05:00" n="703"
                subtype="historical-document" type="document" xml:id="d703">
                <note rend="inline" type="source">File No. 763.72/292</note>
                <head>
                    <hi rend="italic">The Swedish Minister</hi> (<persName corresp="#p_EWAF1"
                        type="from">
                        <hi rend="italic">Ekengren</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">Swedish Legation</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Bar Harbor, Maine</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-07">
                        <hi rend="italic">August 7, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received August 9</hi>.] </dateline>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In conformity with telegraphic instructions
                    received to-day from my Government I have the honor to inform your excellency
                    that mines being planted at different points in the Swedish territorial waters,
                    navigators are invited to conform with the regulations issued by the Swedish
                    local authorities and not visit any Swedish port without employing pilot.</p>
                <p>My telegram of this date is hereby confirmed.<note n="1" xml:id="d703fn1">Not
                        printed.</note>
                </p>
                <p>With renewed assurances [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_EWAF1">
                            <hi rend="smallcaps">W. A. F. Ekengren</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
