                <note rend="inline" type="source">File No. 611.479/27</note>
                <head>
                    <hi rend="italic">The Consul General at Sydney, Australia</hi> (<persName
                        type="from">
                        <hi rend="italic">Bray</hi>
                    </persName>), <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Consulate General</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Sydney</hi>
                    </placeName>, <date ana="#date_undated-inferred-from-document-content"
                        calendar="gregorian" notAfter="1914-11-02T09:00:00-05:00"
                        notBefore="1914-11-01T00:00:00+10:00">
                        <hi rend="italic">undated</hi>
                    </date>. <lb/> [<hi rend="italic">Received November 2, 1914, 9 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Except with consent Minister Customs prohibited wool, hides, woolly sheepskins,
                    meat, coal, flour, wheat, sugar. Official guarantees against reexport facilitate
                    permits. Minister being urged modify restrictions on exports to United
                    States.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Bray</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
