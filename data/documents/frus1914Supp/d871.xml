    <text>
        <body>
            <div frus:doc-dateTime-max="1914-10-24T23:59:59-05:00"
                frus:doc-dateTime-min="1914-10-23T18:41:00-05:00" n="871"
                subtype="historical-document" type="document" xml:id="d871">
                <note rend="inline" type="source">File No. 841.711/6</note>
                <head>
                    <hi rend="italic">The Consul General at Rotterdam</hi> (<persName
                        corresp="#p_LS1" type="from">
                        <hi rend="italic">Listoe</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Rotterdam</hi>
                    </placeName>, <date ana="#date_undated-inferred-from-document-content"
                        calendar="gregorian" notAfter="1914-10-24T23:59:59-05:00"
                        notBefore="1914-10-24T00:00:00+00:19">
                        <hi rend="italic">undated</hi>
                    </date>. <lb/> [<hi rend="italic">Received October 24, 1914</hi>.] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Have not knowingly transmitted commercial correspondence between belligerent
                    countries. Positive instructions on subject much desired.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LS1">
                            <hi rend="smallcaps">Listoe</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
