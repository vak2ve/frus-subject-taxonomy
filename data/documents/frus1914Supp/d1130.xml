<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-08T23:59:59-05:00" frus:doc-dateTime-min="1914-08-08T00:00:00-05:00" n="1130" subtype="historical-document" type="document" xml:id="d1130">
                        <note rend="inline" type="source">File No. 763.72111W74/1</note>
                        <head>
                            <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW2" type="from"><hi rend="italic">Gerard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <placeName>
                                <hi rend="italic">Berlin</hi></placeName>, <date calendar="gregorian" when="1914-08-08">
                                <hi rend="italic">August 8, 1914</hi>.</date> [<hi rend="italic">Received August 9, 7 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>German Government will observe neutrality of Liberia.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_GJW2">
                                    <hi rend="smallcaps">Gerard</hi>
                                </persName>
                            </signed>
                        </closer>
