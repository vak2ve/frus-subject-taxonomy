                subtype="historical-document" type="document" xml:id="d677">
                <note rend="inline" type="source">File No. 611.479/97</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">London</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-23">
                        <hi rend="italic">December 23, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 8:30 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>1325. Your 806 presented but I have small hope for reasons explained in my 1080
                        [<hi rend="italic">1079</hi>] of November 17. See last sentence of that
                    telegram. No wool allowed to be exported from Great Britain or colonies.</p>
                <closer>
                    <hi rend="smallcaps">American Ambassador</hi>
                </closer>
            </div>
        </body>
    </text>
