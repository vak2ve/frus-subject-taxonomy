<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-05T23:59:59-05:00" frus:doc-dateTime-min="1914-08-05T00:00:00-05:00" n="96" subtype="historical-document" type="document" xml:id="d96">
                        <note rend="inline" type="source">File No. 768.72/114</note>
                        <head>
                            <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">London</hi></placeName>, <date calendar="gregorian" when="1914-08-05">
                                <hi rend="italic">August 5, 1914</hi>.</date>
                            <lb/> [<hi rend="italic">Received 12:40 a.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>271. I have received at this moment, 1:40 a.m., August 5, a note from the
                            Foreign Office dated August 4 informing me that a state of war exists
                            between Great Britain and Germany.</p>
                        <closer>
                            <hi rend="smallcaps">American Ambassador</hi>
                        </closer>
                    </div>
                    </body></text></TEI>