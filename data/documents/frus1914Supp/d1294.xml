                subtype="historical-document" type="document" xml:id="d1294">
                <head>The <gloss type="from">Acting Secretary of State</gloss> to the Minister in
                    Belgium (<persName corresp="#p_WB1" type="to">
                        <hi rend="italic">Whitlock</hi>
                    </persName>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-10-20">
                        <hi rend="italic">October 20, 1914</hi>.</date>
                </dateline>
                <p rend="center">[Telegram]</p>
                <p>40. Your telegram October 19 [<hi rend="italic">16</hi>], 10 a.m., transmitted
                    via London regarding relief of Belgium. Department approves your action and has
                    given instructions to the Ambassador at London to render you and your Spanish
                    colleague every assistance.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
