<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-09-03T23:59:59-05:00" frus:doc-dateTime-min="1914-09-03T00:00:00-05:00" n="179" subtype="historical-document" type="document" xml:id="d179">
                        <note rend="inline" type="source">File No. 763.72/788</note>
                        <head>
                            <hi rend="italic">The German Ambassador</hi> (<persName corresp="#p_BCJHV1" type="from"><hi rend="italic">Bernstorff</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">German Embassy</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-09-03">
                                <hi rend="italic">September 3, 1914</hi>.</date>
                            <lb/> [<hi rend="italic">Received September 4</hi>.] </dateline>
                        <p rend="flushleft">No. A 1108/14]</p>
                        <p>
                            <hi rend="smallcaps">Mr. Secretary of State</hi>: I have the honor to
                            inform your excellency that I am instructed by my Government to deny
                            most categorically the rumors circulated by English agencies to the
                            effect that <pb facs="0402" n="88" xml:id="pg_88"/> Germany, in case she
                            emerges victorious from the present war, intends to seek expansion in
                            South America.</p>
                        <p>Accept [etc.]</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BCJHV1">
                                    <hi rend="smallcaps">J. Bernstorff</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>