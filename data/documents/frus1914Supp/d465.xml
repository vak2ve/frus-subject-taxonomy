    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-18T23:59:59-05:00"
                frus:doc-dateTime-min="1914-08-18T00:00:00-05:00" n="465"
                subtype="historical-document" type="document" xml:id="d465">
                <note rend="inline" type="source">File No. 300.115/63</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">Page</persName>) <hi rend="italic">to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">London</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-18">
                        <hi rend="italic">August 18, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received August 19, 11:30 a.m.</hi>] </dateline>
                <p rend="flushleft">[Telegram]</p>
                <p>405. Your August 13, 8 p.m. <persName corresp="#p_GSE1">Sir Edward
                        Grey</persName> informs me that the British Government will consider claims
                    of American shippers whose cargoes destined for parts of British enemies are
                    diverted to British ports and sold. If such claims for loss by such diversion be
                    established, the British Government will in due time pay them.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">American Ambassador</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
