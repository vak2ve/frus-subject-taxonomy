                subtype="historical-document" type="document" xml:id="d776">
                <note rend="inline" type="source">File No. 195.1/62</note>
                <head>
                    <hi rend="italic">The Consul General at Rio de Janeiro</hi> (<persName
                        corresp="#p_BAL1" type="from">
                        <hi rend="italic">Burnell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Consulate General</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Rio De Janeiro</hi>
                    </placeName>, <date ana="#date_undated-inferred-from-document-content"
                        calendar="gregorian" notAfter="1914-09-22T02:20:00-05:00"
                        notBefore="1914-09-21T00:00:00-03:00">
                        <hi rend="italic">undated</hi>
                    </date>. <lb/> [<hi rend="italic">Received September 22, 1914, 2:20 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>The British Consul states that acting under instructions from the British
                    Legation he cannot until so instructed close register of steamer <persName>
                        <hi rend="italic">Robert Dollar</hi>
                    </persName>. British Legation is awaiting instructions in the premises from
                    London.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BAL1">
                            <hi rend="smallcaps">Burnell</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
