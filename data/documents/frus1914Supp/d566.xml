                subtype="historical-document" type="document" xml:id="d566">
                <note rend="inline" type="source">File No. 763.72112/561</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">London</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-31">
                        <hi rend="italic">December 31, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 10:30 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>13740. <persName corresp="#p_GSE1">Sir Edward Grey</persName> has just informed
                    me that he will prepare a note in reply to your note in as short a time as
                    possible “in the same tone.”</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
