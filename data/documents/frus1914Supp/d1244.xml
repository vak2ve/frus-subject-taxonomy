    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-09T17:00:00-05:00"
                frus:doc-dateTime-min="1914-12-09T17:00:00-05:00" n="1244"
                subtype="historical-document" type="document" xml:id="d1244">
                <note rend="inline" type="source">File No. 763.72/1298</note>
                <head>
                    <hi rend="italic">The Ambassador in Turkey</hi> (<persName corresp="#p_MH1"
                        type="from">
                        <hi rend="italic">Morgenthau</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Constantinople</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-10T00:00:00+02:00">
                        <hi rend="italic">December 10, 1914, 12 midnight</hi>.</date>
                    <lb/> [<hi rend="italic">Received December 11, 8:15 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>143. Your 124, 8th.<note n="1" xml:id="d1244fn1">See footnote 2, <hi
                            rend="italic">ante</hi>, <ref target="#pg_784">p. 784</ref>.</note>
                    Contents communicated to Minister of the Interior who is acting Minister of War.
                    He seems absolutely indifferent to being held personally responsible.</p>
                <closer>
                    <hi rend="smallcaps">American Ambassador</hi>
                </closer>
            </div>
        </body>
