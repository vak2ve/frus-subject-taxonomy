                subtype="historical-document" type="document" xml:id="d1324">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName corresp="#p_HMT1" type="to">
                        <hi rend="italic">Herrick</hi>
                    </persName>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-09-01">
                        <hi rend="italic">September 1, 1914</hi>.</date>
                </dateline>
                <p rend="center">[Telegram]</p>
                <p>17. The American Red Cross vessel will stop at Havre. Ascertain whether French
                    authorities at that port will remit port duties.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
