                subtype="historical-document" type="document" xml:id="d790">
                <note rend="inline" type="source">File No. 763.72/143</note>
                <head>
                    <hi rend="italic">The Consul at St. Pierre</hi> (<persName corresp="#p_KEC1"
                        type="from">
                        <hi rend="italic">Kemp</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">St. Pierre</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-05T14:00:00-04:00">
                        <hi rend="italic">August 5, 1914, 2 p.m.</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received 1:40 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Will you authorize protection as neutral property telegraph cables leased by the
                    Western Union at this place?</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Kemp</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
