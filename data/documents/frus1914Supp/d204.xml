                subtype="historical-document" type="document" xml:id="d204">
                <note rend="inline" type="source">File No. 763.72/917</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW2"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Berlin</hi>
                    </placeName>, <date calendar="gregorian" when="1914-09-19T15:00:00+01:00">
                        <hi rend="italic">September 19, 1914, 3 p.m.</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received September 20, 1:15 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>228. Turkish fleet being remanned by Germans and think will soon be in war.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW2">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
