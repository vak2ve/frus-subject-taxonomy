                subtype="historical-document" type="document" xml:id="d860">
                <note rend="inline" type="source">File No. 841.711/196</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-09-21">
                        <hi rend="italic">September 21, 1914</hi>.</date>
                </dateline>
                <p rend="center">[Telegram]</p>
                <p>162. Investigate and report on press reports that United States mail on
                        <persName>S. S. <hi rend="italic">Noordam</hi>
                    </persName> has been examined by British and either seized or held up.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
