<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-09-04T23:59:59-05:00" frus:doc-dateTime-min="1914-09-04T00:00:00-05:00" n="1258" subtype="historical-document" type="document" xml:id="d1258">
                        <note rend="inline" type="source">File No. 763.72116/18</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Consul General at Antwerp</hi> (<persName corresp="#p_DHW1"><hi rend="italic">Diederch</hi></persName>)</head>
                        <dateline>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-09-04">
                                <hi rend="italic">September 4, 1914</hi>.</date>
                        </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Your September 2.<note n="1" xml:id="d1258fn1">Not printed.</note> Please
                            confine yourself to statement of facts. Our neutrality does not permit
                            an expression of opinion by our diplomatic or consular officers.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BWJ1">
                                    <hi rend="smallcaps">Bryan</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>