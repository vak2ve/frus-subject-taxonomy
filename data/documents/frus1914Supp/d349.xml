<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-12-30T18:00:00-05:00" frus:doc-dateTime-min="1914-12-30T18:00:00-05:00" n="349" subtype="historical-document" type="document" xml:id="d349">
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in China</hi> (<persName corresp="#p_RPS1" type="to"><hi rend="italic">Reinsch</hi></persName>)</head>
                        <dateline>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-12-30T18:00:00-05:00">
                                <hi rend="italic">December 30, 1914, 6 p.m.</hi>
                            </date>
                        </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Your telegram of December 23, 2 p.m.</p>
                        <p>Has China informed British Government of the demand?</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BWJ1">
                                    <hi rend="smallcaps">Bryan</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>