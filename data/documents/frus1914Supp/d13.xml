    <text>
        <body>
            <div frus:doc-dateTime-max="1914-09-24T11:00:00-05:00"
                frus:doc-dateTime-min="1914-09-24T00:00:00-05:00" n="13"
                subtype="historical-document" type="document" xml:id="d13">
                <note rend="inline" type="source">File No. 711.0012/517</note>
                <head>
                    <hi rend="italic">The Russian Ambassador</hi> (<persName corresp="#p_BG1"
                        type="from">
                        <hi rend="italic">Bakhméteff</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <placeName>
                        <hi rend="italic">Newport, Rhode Island</hi>
                    </placeName>, <date ana="#date_undated-inferred-from-document-content"
                        calendar="gregorian" notAfter="1914-09-24T11:00:00-05:00"
                        notBefore="1914-09-24T00:00:00-05:00">
                        <hi rend="italic">undated</hi>
                    </date>. <lb/> [<hi rend="italic">Received September 24, 1914, 11 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>I have great pleasure in informing you that the Imperial Government, wishing to
                    give a proof of its good-will and friendship to the Government of the United
                    States, has directed me to negotiate and sign a peace treaty with you.<note
                        n="2" xml:id="d13fn1">The treaty was signed on October 1. <hi rend="italic"
                            >Ibid</hi>., <ref target="frus1915#pg_1283">p. 1283</ref>.</note> I will
                    come to Washington as soon as I have prepared the draft.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BG1">
                            <hi rend="smallcaps">Bakhméteff</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
