<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-12-28T13:00:00-05:00" frus:doc-dateTime-min="1914-12-28T13:00:00-05:00" n="678" subtype="historical-document" type="document" xml:id="d678">
                        <note rend="inline" type="source">File No. 611.479/98</note>
                        <head>
                            <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">London</hi></placeName>, <date calendar="gregorian" when="1914-12-28T18:00:00+00:00">
                                <hi rend="italic">December 23, 1914, 6 p.m.</hi>
                            </date>
                            <lb/> [<hi rend="italic">Received 8. 30 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>1326. Your 815, December 22. I have presented same but British Government
                            awaits our answer to proposed arrangement, see my 1199, December 6.<note n="1" xml:id="d678fn1">
                                <hi rend="italic">Ante</hi>, <ref target="#pg_356">p.
                                356</ref>.</note>
                        </p>
                        <closer>
                            <hi rend="smallcaps">American Ambassador</hi>
                        </closer>
                    </div>
