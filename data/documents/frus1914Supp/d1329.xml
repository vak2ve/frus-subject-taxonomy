    <text>
        <body>
            <div frus:doc-dateTime-max="1914-09-06T23:59:59-05:00"
                frus:doc-dateTime-min="1914-09-06T00:00:00-05:00" n="1329"
                subtype="historical-document" type="document" xml:id="d1329">
                <note rend="inline" type="source">File No. 811.142/278</note>
                <head>
                    <hi rend="italic">The Minister in the Netherlands</hi> (<persName
                        corresp="#p_VDH1" type="from">
                        <hi rend="italic">Van Dyke</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">The Hague</hi>
                    </placeName>, <date calendar="gregorian" when="1914-09-06">
                        <hi rend="italic">September 6, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 4:57 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>13. Netherlands Government informs me there will be no port charges for American
                    Red Cross vessel at Rotterdam.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_VDH1">
                            <hi rend="smallcaps">Van Dyke</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
