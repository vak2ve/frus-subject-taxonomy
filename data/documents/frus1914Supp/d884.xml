<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-12-24T23:59:59-05:00" frus:doc-dateTime-min="1914-12-24T00:00:00-05:00" n="884" subtype="historical-document" type="document" xml:id="d884">
                        <note rend="inline" type="source">File No. 124.0665/9</note>
                        <head>
                            <hi rend="italic">The Minister in Servia</hi> (<persName corresp="#p_VCJ1" type="from"><hi rend="italic">Vopicka</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Nish</hi></placeName>, <date calendar="gregorian" when="1914-12-24">
                                <hi rend="italic">December 24, 1914</hi>.</date>
                            <lb/> [<hi rend="italic">Received 8:50 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Servian Government just notified me that it agrees to the proposed postal
                            regulations respecting seals submitted by American government.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_VCJ1">
                                    <hi rend="smallcaps">Vopicka</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                </body></text></TEI>