    <text>
        <body>
            <div frus:doc-dateTime-max="1914-10-19T23:59:59-05:00"
                frus:doc-dateTime-min="1914-10-19T00:00:00-05:00" n="1344"
                subtype="historical-document" type="document" xml:id="d1344">
                <note rend="inline" type="source">File No. 763.72112/187</note>
                <head>
                    <hi rend="italic">The Minister in Belgium</hi> (<persName corresp="#p_WB1"
                        type="from">
                        <hi rend="italic">Whitlock</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Brussels</hi>
                    </placeName>, <date calendar="gregorian" when="1914-10-19">
                        <hi rend="italic">October 19, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Repetition received October 20, 8 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Department’s circular September 24<note n="2" xml:id="d1344fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_831">p. 831</ref>.</note>
                    regarding agreement to consider hospital supplies as neither contraband nor
                    conditional contraband of war was duly communicated to Belgian Government. No,
                    reply has as yet been received.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WB1">
                            <hi rend="smallcaps">Whitlock</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
