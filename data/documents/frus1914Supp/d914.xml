    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-06T23:59:59-05:00"
                frus:doc-dateTime-min="1914-08-06T00:00:00-05:00" n="914"
                subtype="historical-document" type="document" xml:id="d914">
                <note rend="inline" type="source">File No. 763.72112/38</note>
                <head>
                    <hi rend="italic">The Acting Secretary of the Treasury</hi> (<persName
                        corresp="#p_NBR1" type="from">
                        <hi rend="italic">Newton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">Treasury Department</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-06">
                        <hi rend="italic">August 6, 1914</hi>.</date>
                </dateline>
                <p rend="center">[Telegram]</p>
                <p>Please advise whether any duties devolve upon collectors of customs and other
                    officers of this department to prevent the exportation of so-called contraband
                    of war in the ordinary course of commerce; if so, please give list of articles
                    recognized as contraband.<note n="2" xml:id="d914fn1">See the letter of the
                        Acting Secretary of Commerce to the Secretary of State, August 6, 1914, <hi
                            rend="italic">post</hi>, <ref target="#pg_595">p. 595</ref>, for
                        instructions of August 5 to the collector of customs at New York regarding
                        the clearance of foreign merchant vessels, containing the following
                        directions: It must be unquestionable that she has no arms or munitions of
                        war aboard.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_NBR1">
                            <hi rend="smallcaps">B. R. Newton</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
