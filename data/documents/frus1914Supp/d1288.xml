<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-10-17T23:59:59-05:00" frus:doc-dateTime-min="1914-10-17T00:00:00-05:00" n="1288" subtype="historical-document" type="document" xml:id="d1288">
                        <note rend="inline" type="source">File No. 855.48/5</note>
                        <head>
                            <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW2" type="from"><hi rend="italic">Gerard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Berlin</hi></placeName>, <date calendar="gregorian" when="1914-10-17">
                                <hi rend="italic">October 17, 1914</hi>.</date>
                            <lb/> [<hi rend="italic">Received October 18, 1:40 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>541. The German Government approves of the plan to supply the population
                            of Belgium with food.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_GJW2">
                                    <hi rend="smallcaps">Gerard</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>