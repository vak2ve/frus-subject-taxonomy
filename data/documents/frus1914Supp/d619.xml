    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-30T06:00:00-05:00"
                frus:doc-dateTime-min="1914-12-30T06:00:00-05:00" n="619"
                subtype="historical-document" type="document" xml:id="d619">
                <note rend="inline" type="source">File No. 665.11251/42</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName corresp="#p_PTN1"
                        type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Rome</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-30T12:00:00+01:00">
                        <hi rend="italic">December 30, 1914, 12 noon</hi>.</date>
                    <lb/> [<hi rend="italic">Received 5:30 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>141. Am assured by Foreign Office cotton may now be shipped freely to order as
                    before decree of November 13 with no embargo on reexportation.<note n="1"
                        xml:id="d619fn1">Not printed. For summary of reexportation provision, see
                        Department’s No. 564, November 18, 1914, printed <hi rend="italic"
                        >ante</hi>, <ref target="#pg_347">p. 347</ref>.</note>
                </p>
                <closer>
                    <hi rend="smallcaps">American Ambassador</hi>
                </closer>
            </div>
        </body>
