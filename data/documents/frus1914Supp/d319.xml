    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-25T19:00:00-05:00"
                frus:doc-dateTime-min="1914-08-25T19:00:00-05:00" n="319"
                subtype="historical-document" type="document" xml:id="d319">
                <note rend="inline" type="source">File No. 768.72/616</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName corresp="#p_GGW1"
                        type="from">
                        <hi rend="italic">Guthrie</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Tokyo</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-26T09:00:00+09:00">
                        <hi rend="italic">August 26, 1914, 9 a.m.</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received 4 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Referring to the Embassy’s telegram of August 24, 5 p.m., satisfactory
                    arrangement has been completed.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GGW1">
                            <hi rend="smallcaps">Guthrie</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
