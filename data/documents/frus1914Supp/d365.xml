    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-27T22:02:00-05:00"
                frus:doc-dateTime-min="1914-08-26T16:30:00-05:00" n="365"
                subtype="historical-document" type="document" xml:id="d365">
                <note rend="inline" type="source">File No. 763.72112/112</note>
                <head>
                    <hi rend="italic">The Chargé d’Affaires in Russia</hi> (<persName
                        corresp="#p_WCS1" type="from">
                        <hi rend="italic">Wilson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">St. Petersburg</hi>
                    </placeName>, <date ana="#date_undated-inferred-from-document-content"
                        calendar="gregorian" notAfter="1914-08-27T22:02:00-05:00"
                        notBefore="1914-08-27T00:00:00+02:30">
                        <hi rend="italic">undated</hi>
                    </date>. <lb/> [<hi rend="italic">Received August 27, 1914, 10:02 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Russian Government accepts Declaration of London with exact modifications adopted
                    by England and France.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WCS1">
                            <hi rend="smallcaps">Wilson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
