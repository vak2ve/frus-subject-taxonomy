                subtype="historical-document" type="document" xml:id="d127">
                <note rend="inline" type="source">File No. 763.72/369</note>
                <head>
                    <hi rend="italic">The Chargé d’Affaires in Russia</hi> (<persName
                        corresp="#p_WCS1" type="from">
                        <hi rend="italic">Wilson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">St. Petersburg</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-12T11:00:00+02:30">
                        <hi rend="italic">August 12, 1914, 11 a.m.</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received August 13, 8:30 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Department’s August 4, 7 p.m.<note n="1" xml:id="d127fn1">See footnote, <hi
                            rend="italic">ante</hi>, <ref target="#pg_42">p. 42</ref>.</note>
                    Emperor leaving for Moscow requests President’s communication be presented in
                    writing through Minister for Foreign Affairs. Shall I comply?<note n="2"
                        xml:id="d127fn2">Answer, “Yes,” telegraphed August 13, 8 p.m.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_WCS1">
                            <hi rend="smallcaps">Wilson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
