                subtype="historical-document" type="document" xml:id="d749">
                <note rend="inline" type="source">File No. 840.48/232</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW2"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Berlin</hi>
                    </placeName>, <date ana="#date_undated-inferred-from-document-content"
                        calendar="gregorian" notAfter="1914-08-13T17:40:00-05:00"
                        notBefore="1914-08-13T00:00:00+01:00">
                        <hi rend="italic">undated</hi>
                    </date>. <lb/> [<hi rend="italic">Received August 13, 1914, 9:40 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>German Government agrees to refrain from interference with American transports on
                    condition that all other nations at war assure the United States of their
                    respective willingness to agree. Also German Government will issue passes to
                    these ships on hearing from you to this effect.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW2" type="from">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
