    <text>
        <body>
            <div frus:doc-dateTime-max="1914-11-03T23:59:59-05:00"
                frus:doc-dateTime-min="1914-11-03T00:00:00-05:00" n="1297"
                subtype="historical-document" type="document" xml:id="d1297">
                <note rend="inline" type="source">File No. 855.48/24</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">London</hi>
                    </placeName>, <date calendar="gregorian" when="1914-11-03">
                        <hi rend="italic">November, 3, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 11:30 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>969. My telegram No. 940, 30th.<note n="1" xml:id="d1297fn1">Not printed.</note>
                    <persName corresp="#p_VDH1">Van Dyke</persName> telegraphs that French Minister,
                    The Hague, threatens to protest against transit of foodstuffs through
                    Netherlands unless French Government notifies their Minister at The Hague of its
                    approbation.</p>
                <closer>
                    <hi rend="smallcaps">American Ambassador</hi>
                </closer>
            </div>
        </body>
