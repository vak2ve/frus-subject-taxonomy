                subtype="historical-document" type="document" xml:id="d1212">
                <note rend="inline" type="source">File No. 867.00/662</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW2"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Berlin</hi>
                    </placeName>, <date calendar="gregorian" when="1914-09-14">
                        <hi rend="italic">September 14, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received September 15, 4 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>148. German Foreign Office says that German Ambassador Turkey now thinks it would
                    be a good thing if neutral warship should be sent to protect foreigners Turkish
                    coast.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW2">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
