<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-07-30T23:59:59-05:00" frus:doc-dateTime-min="1914-07-30T00:00:00-05:00" n="44" subtype="historical-document" type="document" xml:id="d44">
                        <note rend="inline" type="source">File No. 763.72/29</note>
                        <head>
                            <hi rend="italic">The Consul General at Hamburg</hi> (<persName corresp="#p_MHH1" type="from"><hi rend="italic">Morgan</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Consulate General</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Hamburg</hi></placeName>, <date calendar="gregorian" when="1914-07-30">
                                <hi rend="italic">July 30, 1914</hi>.</date>
                            <lb/> [<hi rend="italic">Received July 31, 9:10 a.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>
                            <hi rend="italic">Imperator</hi> will not sail.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_MHH1">
                                    <hi rend="smallcaps">Morgan</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>