    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-21T18:00:00-05:00"
                frus:doc-dateTime-min="1914-08-21T18:00:00-05:00" n="316"
                subtype="historical-document" type="document" xml:id="d316">
                <note rend="inline" type="source">File No. 768.72/574</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW2"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Berlin</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-22T00:00:00+01:00">
                        <hi rend="italic">August 22, 1914, 12 midnight</hi>.</date>
                    <lb/> [<hi rend="italic">Received August 23, 5:26 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Austrian Embassy requests that following message be telegraphec:</p>
                <p>Berlin, August 22, 1914. To the Austro-Hungarian Ambassador in Tokyo. H. M. S.
                    Empress Elizabeth, harboring at Tsingtao, should disarm, crew to proceed to
                    Tientsin.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BCJHV1">
                            <hi rend="smallcaps">Berchtold</hi>
                        </persName>
                        <lb/>
                        <persName corresp="#p_GJW2">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
