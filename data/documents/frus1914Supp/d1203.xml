<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-22T23:59:59-05:00" frus:doc-dateTime-min="1914-08-22T00:00:00-05:00" n="1203" subtype="historical-document" type="document" xml:id="d1203">
                        <note rend="inline" type="source">File No. 367.11/186</note>
                        <head>
                            <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW2" type="from"><hi rend="italic">Gerard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Berlin</hi></placeName>, <date calendar="gregorian" when="1914-08-22">
                                <hi rend="italic">August 22, 1914</hi>.</date>
                            <lb/> [<hi rend="italic">Received 12:30 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Substance of your telegram of August 19, 9 p.m., presented to the Foreign
                            Office. They have refused suggestion your proposals.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_GJW2">
                                    <hi rend="smallcaps">Gerard</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>