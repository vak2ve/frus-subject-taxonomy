                subtype="historical-document" type="document" xml:id="d104">
                <note rend="inline" type="source">File No. 124.551/9a</note>
                <head>
                    <hi rend="italic">The <gloss type="to">Secretary of State</gloss> to the
                        Minister in Belgium</hi> (<persName corresp="#p_WB1" type="to">
                        <hi rend="italic">Whitlock</hi>
                    </persName>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-06T19:36:00-05:00">
                        <hi rend="italic">August 6, 1914, 7:36 p.m.</hi>
                    </date>
                </dateline>
                <p rend="center">[Telegram]</p>
                <p>Your August 5, 9 a.m. Move Legation if desirable.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
