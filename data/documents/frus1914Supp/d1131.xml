<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-11T16:00:00-05:00" frus:doc-dateTime-min="1914-08-10T19:00:00-05:00" n="1131" subtype="historical-document" type="document" xml:id="d1131">
                        <note rend="inline" type="source">File No. 763.72111W74/2</note>
                        <head>
                            <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_HMT1" type="from"><hi rend="italic">Herrick</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <placeName>
                                <hi rend="italic">Paris</hi></placeName>, <date ana="#date_undated-inferred-from-document-content" calendar="gregorian" notAfter="1914-08-11T16:00:00-05:00" notBefore="1914-08-11T00:00:00+00:00"><hi rend="italic">undated</hi></date>. <lb/> [<hi rend="italic">Received August 11,
                                1914, 4 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>French Government agrees respect neutrality Liberia.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_HMT1">
                                    <hi rend="smallcaps">Herrick</hi>
                                </persName>
                            </signed>
                        </closer>
