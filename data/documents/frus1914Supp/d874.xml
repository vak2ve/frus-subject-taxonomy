                subtype="historical-document" type="document" xml:id="d874">
                <note rend="inline" type="source">File No. 841.711/10</note>
                <head>
                    <hi rend="italic">The Consul General at Rotterdam</hi> (<persName
                        corresp="#p_LS1" type="from">
                        <hi rend="italic">Listoe</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-11-01">
                        <hi rend="italic">November 1, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 11:25 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>May commercial correspondence from belligerent countries to America be
                    transmitted?</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LS1">
                            <hi rend="smallcaps">Listoe</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
