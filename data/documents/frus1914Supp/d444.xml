    <text>
        <body>
            <div frus:doc-dateTime-max="1914-11-11T23:59:59-05:00"
                frus:doc-dateTime-min="1914-11-11T00:00:00-05:00" n="444"
                subtype="historical-document" type="document" xml:id="d444">
                <note rend="inline" type="source">File No. 763.72112/380</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW2"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Berlin</hi>
                    </placeName>, <date calendar="gregorian" when="1914-11-11">
                        <hi rend="italic">November 11, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received November 16, 8 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>821. Your 514, October 28. Foreign Office informs me that under No. 27 of the
                    German prize ordinance [of September 30, 1909], cotton and cotton yarn shall not
                    be declared contraband. These goods cannot, therefore [as a matter of course],
                    be taken from neutral vessels. The German Government will abide by this attitude
                    as long as the enemy powers do not treat cotton and cotton yarn differently and
                    the neutral powers do not acquiesce in such treatment.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW2" type="from">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
