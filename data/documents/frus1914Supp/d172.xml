<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-28T23:59:59-05:00" frus:doc-dateTime-min="1914-08-28T00:00:00-05:00" n="172" subtype="historical-document" type="document" xml:id="d172">
                        <note rend="inline" type="source">File No. 763.72/709</note>
                        <head>
                            <hi rend="italic">The Belgian Minister</hi> (<persName corresp="#p_HE1" type="from"><hi rend="italic">Havenith</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">Belgian Legation</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-08-28">
                                <hi rend="italic">August 28, 1914</hi>.</date>
                            <lb/> [<hi rend="italic">Received August 29</hi>.]</dateline>
                        <p rend="center">[Translation]</p>
                        <p>Mr. Secretary of State: I have the honor to inform your excellency that I
                            have just received a cablegram from my Government advising me that
                            Austria-Hungary had declared war on Belgium.</p>
                        <p>Be pleased [etc.]</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_HE1">
                                    <hi rend="smallcaps">E. Havenith</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>