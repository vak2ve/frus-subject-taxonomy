                subtype="historical-document" type="document" xml:id="d1204">
                <note rend="inline" type="source">File No. 367.11/193</note>
                <head>
                    <hi rend="italic">The Chargé d’Affaires in Russia</hi> (<persName
                        corresp="#p_WCS1" type="from">
                        <hi rend="italic">Wilson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">St. Petersburg</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-24T18:00:00+02:30">
                        <hi rend="italic">August 24, 1914, 6 p.m.</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received August 25, 11:30 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Department’s August 21, 4 p.m.<note n="1" xml:id="d1204fn1">Not printed.</note>
                    Minister for Foreign Affairs says personally he thinks the idea of sending
                    American ships to Turkish waters excellent and the more the better. Before gives
                    a definite official answer wishes to confer with English and French
                    Governments.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WCS1">
                            <hi rend="smallcaps">Wilson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
