    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-02T10:41:00-05:00"
                frus:doc-dateTime-min="1914-08-02T10:41:00-05:00" n="67"
                subtype="historical-document" type="document" xml:id="d67">
                <note rend="inline" type="source">File No. 763.72/57</note>
                <head>
                    <hi rend="italic">The Minister in the Netherlands</hi> (<persName
                        corresp="#p_VDH1" type="from">
                        <hi rend="italic">Van Dyke</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">The Hague</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-02T16:00:00+00:19">
                        <hi rend="italic">August 2, 1914, 4 p.m.</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received 2:49 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Telegraphic reports that German army advanced through Grand Duchy of Luxemburg,
                    occupied government buildings on the way into France via Metz.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_VDH1">
                            <hi rend="smallcaps">Van Dyke</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
