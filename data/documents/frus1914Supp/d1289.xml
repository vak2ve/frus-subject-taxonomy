                subtype="historical-document" type="document" xml:id="d1289">
                <note rend="inline" type="source">File No. 840.48/833</note>
                <head>
                    <hi rend="italic">The Minister in Belgium</hi> (<persName corresp="#p_WB1"
                        type="from">
                        <hi rend="italic">Whitlock</hi>
                    </persName>) <hi rend="italic">to <gloss type="to">the President</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Brussels</hi>
                    </placeName>, <date calendar="gregorian" when="1914-10-16">
                        <hi rend="italic">October 16, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received October 19, 11 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>21. <hi rend="smallcaps">The President, Washington</hi>: In two weeks the civil
                    population of Belgium, already in misery, will face starvation. In view of this
                    fact, and at the request of the relief committee, I venture to call your
                    attention to my telegram to the Department dated 16th October in the conviction
                    that your great heart will find some way by which America may help to provide
                    food for these hungry ones in the dark days of the terrible winter that is
                    coming on.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WB1">
                            <hi rend="smallcaps">Whitlock</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
