    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-13T14:00:00-05:00"
                frus:doc-dateTime-min="1914-08-13T14:00:00-05:00" n="358"
                subtype="historical-document" type="document" xml:id="d358">
                <note rend="inline" type="source">File No. 763.72112/81</note>
                <head>
                    <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="from">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Vienna</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-13T20:00:00+01:00">
                        <hi rend="italic">August 13, 1914, 8 p.m.</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received August 14, 8:30 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Your August 6. Austro-Hungarian Government have instructed their forces to
                    observe stipulations of Declaration of London as applied to naval as well as
                    land warfare during present conflict conditional on like observance on part of
                    the enemy.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
