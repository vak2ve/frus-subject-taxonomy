<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-09-23T23:59:59-05:00" frus:doc-dateTime-min="1914-09-23T00:00:00-05:00" n="777" subtype="historical-document" type="document" xml:id="d777">
                        <note rend="inline" type="source">File No. 195.1/68</note>
                        <head>
                            <hi rend="italic">The Consul General at Rio de Janeiro</hi> (<persName corresp="#p_BAL1" type="from"><hi rend="italic">Burnell</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Consulate General</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Rio De Janeiro</hi></placeName>, <date calendar="gregorian" when="1914-09-23">
                                <hi rend="italic">September 23, 1914</hi>.</date>
                            <lb/> [<hi rend="italic">Received 4 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Provisional register issued and delivered to steamer <persName>
                                <hi rend="italic">Robert Dollar</hi>
                            </persName> September 22, although vessel sailed to-day by order of
                            owners under British register.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BAL1">
                                    <hi rend="smallcaps">Burnell</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>