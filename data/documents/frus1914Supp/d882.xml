    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-08T23:59:59-05:00"
                frus:doc-dateTime-min="1914-12-08T00:00:00-05:00" n="882"
                subtype="historical-document" type="document" xml:id="d882">
                <note rend="inline" type="source">File No. 124.0665/1</note>
                <head>
                    <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="from">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Vienna</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-08">
                        <hi rend="italic">December 8, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received December 9, 7:30 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>334. Your 305, 25th. Austro-Hungarian Government agrees to proposal for
                    inviolability of all diplomatic and consular correspondence on conditions
                    specified. Have instructed consuls.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
