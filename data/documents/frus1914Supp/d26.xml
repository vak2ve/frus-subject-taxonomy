                subtype="historical-document" type="document" xml:id="d26">
                <note rend="inline" type="source">File No. 763.72/4</note>
                <head>
                    <hi rend="italic">The Chargé d’Affaires in Russia</hi> (<persName
                        corresp="#p_WCS1" type="from">
                        <hi rend="italic">Wilson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">St. Petersburg</hi>
                    </placeName>, <date calendar="gregorian" when="1914-07-27T16:00:00+02:30">
                        <hi rend="italic">July 27, 1914, 4 p.m.</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received 11:05 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Situation though still acute less so than yesterday and chances of peace
                    improved, though army clamoring for war.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WCS1">
                            <hi rend="smallcaps">Wilson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
