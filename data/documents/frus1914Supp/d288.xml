                subtype="historical-document" type="document" xml:id="d288">
                <note rend="inline" type="source">File No. 763.72111/4</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé d’Affaires in China</hi> (<persName corresp="#p_MJVA1" type="to">
                        <hi rend="italic">MacMurray</hi>
                    </persName>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-07T17:00:00-05:00">
                        <hi rend="italic">August 7, 1914, 5 p.m.</hi>
                    </date>
                </dateline>
                <p rend="center">[Telegram]</p>
                <p>Your August 3, 11 p.m. Previous to the receipt of your telegram the Chinese
                    Minister here on August 3 left a memorandum with the Department requesting the
                    American Government to take the action mentioned in your inquiry. The Department
                    is giving the matter careful consideration.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
