    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-11T19:00:00-05:00"
                frus:doc-dateTime-min="1914-08-10T18:00:00-05:00" n="123"
                subtype="historical-document" type="document" xml:id="d123">
                <note rend="inline" type="source">File No. 763.72/334</note>
                <head>
                    <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="from">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Vienna</hi>
                    </placeName>, <date ana="#date_undated-inferred-from-document-content"
                        calendar="gregorian" notAfter="1914-08-11T19:00:00-05:00"
                        notBefore="1914-08-11T00:00:00+01:00">
                        <hi rend="italic">undated</hi>
                    </date>. <lb/> [<hi rend="italic">Received August 11, 1914, 7 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Austro-Hungarian Government to-day gave French Ambassador passports.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
