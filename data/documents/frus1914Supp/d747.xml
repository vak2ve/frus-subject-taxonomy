<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-13T14:00:00-05:00" frus:doc-dateTime-min="1914-08-12T18:00:00-05:00" n="747" subtype="historical-document" type="document" xml:id="d747">
                        <note rend="inline" type="source">File No. 840.48/224</note>
                        <head>
                            <hi rend="italic">The Consul General at Genoa</hi> (<persName corresp="#p_JJE1" type="from"><hi rend="italic">Jones</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Consulate General</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Genoa</hi></placeName>, <date ana="#date_undated-inferred-from-document-content" calendar="gregorian" notAfter="1914-08-13T14:00:00-05:00" notBefore="1914-08-13T00:00:00+01:00"><hi rend="italic">undated</hi></date>. <lb/> [<hi rend="italic">Received August 13,
                                1914, 2 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Two German liners here in port, <persName>
                                <hi rend="italic">Moltke</hi>
                            </persName> and <persName>
                                <hi rend="italic">König Albert</hi></persName>. If Government will
                            use its good offices with England, possibly I could arrange sailing
                            these ships to carry home stranded destitute Americans.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_JJE1">
                                    <hi rend="smallcaps">J. Jones</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>