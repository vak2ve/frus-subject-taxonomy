    <text>
        <body>
            <div frus:doc-dateTime-max="1914-09-04T23:59:59-05:00"
                frus:doc-dateTime-min="1914-09-04T00:00:00-05:00" n="180"
                subtype="historical-document" type="document" xml:id="d180">
                <note rend="inline" type="source">File No. 763.72111/357</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Belgian Minister</hi> (<persName corresp="#p_HE1" type="to">
                        <hi rend="italic">Havenith</hi>
                    </persName>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-09-04">
                        <hi rend="italic">September 4, 1914</hi>.</date>
                </dateline>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of August 20, 1914, in which by direction of your Government you
                    protest against the violation of Belgian neutrality by the German Army.<note
                        n="1" xml:id="d180fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_71">p. 71</ref>.</note>
                </p>
                <p>Accept [etc.]</p>
                <p>For the Secretary of State:</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Robert Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
