<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-11-21T11:00:00-05:00" frus:doc-dateTime-min="1914-11-21T11:00:00-05:00" n="1013" subtype="historical-document" type="document" xml:id="d1013">
                        <note rend="inline" type="source">File No. 763.72111Sa1/1</note>
                        <head>
                            <hi rend="italic">The Vice Consul at Valparaiso</hi> (<persName corresp="#p_EAB1" type="from"><hi rend="italic">Easterling</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Consulate</hi>, <lb/>
                            <placeName><hi rend="italic">Valparaiso</hi></placeName>, <date calendar="gregorian" when="1914-11-21T11:00:00-05:00">
                                <hi rend="italic">November 21, 1914, 11 a.m.</hi>
                            </date>
                            <lb/> [<hi rend="italic">Received 3 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>
                            <hi rend="italic">Sacramento</hi> reports cargo taken by German war
                            vessels [and prisoners put aboard?] from French sailing vessel <hi rend="italic">Valentine</hi> which was sunk by Germans.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_EAB1">
                                    <hi rend="smallcaps">Easterling</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>