<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-10-07T15:50:00-05:00" frus:doc-dateTime-min="1914-10-06T19:00:00-05:00" n="1275" subtype="historical-document" type="document" xml:id="d1275">
                        <note rend="inline" type="source">File No. 763.72/1061</note>
                        <head>
                            <hi rend="italic">The Consul General at Antwerp</hi> (<persName corresp="#p_DHW1" type="from"><hi rend="italic">Diederich</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Consulate General</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Antwerp</hi></placeName>, <date ana="#date_undated-inferred-from-document-content" calendar="gregorian" notAfter="1914-10-07T15:50:00-05:00" notBefore="1914-10-07T00:00:00+00:00"><hi rend="italic">undated</hi></date>. <lb/> [<hi rend="italic">Received October 7,
                                1914, 3:30 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Immediate bombardment announced. Is there no hope intercession American
                            Government to prevent carnage and destruction?</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_DHW1">
                                    <hi rend="smallcaps">Diederich</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>