    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-02T23:59:59-05:00"
                frus:doc-dateTime-min="1914-08-02T00:00:00-05:00" n="68"
                subtype="historical-document" type="document" xml:id="d68">
                <note rend="inline" type="source">File No. 763.72/56</note>
                <head>
                    <hi rend="italic">The Russian Ambassador</hi> (<persName corresp="#p_BG1"
                        type="from">
                        <hi rend="italic">Bakhméteff</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">Russian Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Newport, Rhode Island</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-02">
                        <hi rend="italic">August 2, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 3 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>I have just been informed by my Government that Germany has declared war on
                    us.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BG1">
                            <hi rend="smallcaps">Bakhméteff</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
