    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-24T23:59:59-05:00"
                frus:doc-dateTime-min="1914-12-24T00:00:00-05:00" n="679"
                subtype="historical-document" type="document" xml:id="d679">
                <note rend="inline" type="source">File No. 611.51L9/15</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_SWG1"
                        type="from">
                        <hi rend="italic">Sharp</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Paris</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-24">
                        <hi rend="italic">December 24, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 11 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>403. Department’s 257, November 11.<note n="2" xml:id="d679fn1">Not
                        printed.</note> French Government authorizes export chrome ore New Caledonia
                    provided seller gives bond at customhouse, port of departure, to be released by
                    French consul at New York upon arrival shipment.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SWG1">
                            <hi rend="smallcaps">Sharp</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
