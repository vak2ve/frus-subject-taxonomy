                subtype="historical-document" type="document" xml:id="d1230">
                <note rend="inline" type="source">File No. 367.116/248</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Turkey</hi> (<persName corresp="#p_MH1" type="to">
                        <hi rend="italic">Morgenthau</hi>
                    </persName>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-12-15">
                        <hi rend="italic">December 15, 1914</hi>.</date>
                </dateline>
                <p rend="center">[Telegram]</p>
                <p>151. Your 123, December 5, 8 p.m. Please continue to protest to Turkish
                    Government against any change or disregard of the original privileges or
                    capitulations under which American institutions, both religious and educational,
                    were established, pointing out that this Government can not accept any
                    modification of capitulations without previous agreement.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
