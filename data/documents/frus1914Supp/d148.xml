                <note rend="inline" type="source">File No. 124.551/10</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Belgium</hi> (<persName corresp="#p_WB1" type="to">
                        <hi rend="italic">Whitlock</hi>
                    </persName>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-19">
                        <hi rend="italic">August 19, 1914</hi>.</date>
                </dateline>
                <p rend="center">[Telegram]</p>
                <p>Your August 17, 5 p.m. Department approves your course of action.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
