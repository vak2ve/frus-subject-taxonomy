<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-07T14:00:00-05:00" frus:doc-dateTime-min="1914-08-07T14:00:00-05:00" n="1161" subtype="historical-document" type="document" xml:id="d1161">
                        <note rend="inline" type="source">File No. 701.6261/7</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé d’Affaires in Russia</hi> (<persName corresp="#p_WCS1" type="to"><hi rend="italic">Wilson</hi></persName>)</head>
                        <dateline>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-08-07T14:00:00-05:00">
                                <hi rend="italic">August 7, 1914, 2 p.m.</hi>
                            </date>
                        </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Your August 5, 10 p.m. Department unable to take up matter with Russian
                            Ambassador.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BWJ1">
                                    <hi rend="smallcaps">Bryan</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>