<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-07-30T16:15:00-05:00" frus:doc-dateTime-min="1914-07-29T18:00:00-05:00" n="39" subtype="historical-document" type="document" xml:id="d39">
                        <note rend="inline" type="source">File No. 763.72/24</note>
                        <head>
                            <hi rend="italic">The Consul at Gibraltar</hi> (<persName corresp="#p_SRL1" type="from"><hi rend="italic">Sprague</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Consulate</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Gibraltar</hi></placeName>, <date ana="#date_undated-inferred-from-document-content" calendar="gregorian" notAfter="1914-07-30T16:15:00-05:00" notBefore="1914-07-30T00:00:00+01:00"><hi rend="italic">undated</hi></date>. <lb/> [<hi rend="italic">Received July 30,
                                1914, 4:15 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>
                            <persName corresp="#p_GLM1">Garrison</persName> mobilized.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_SRL1">
                                    <hi rend="smallcaps">Sprague</hi>
                                </persName>
                            </signed>
                        </closer>
