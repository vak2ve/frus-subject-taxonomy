    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-01T23:59:59-05:00"
                frus:doc-dateTime-min="1914-08-01T00:00:00-05:00" n="701"
                subtype="historical-document" type="document" xml:id="d701">
                <note rend="inline" type="source">File No. 763.72/134</note>
                <head>
                    <hi rend="italic">The Netherlands Chargé d’Affaires</hi> (<persName
                        corresp="#p_DBWH1" type="from">
                        <hi rend="italic">De Beaufort</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">Legation of the Netherlands</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-01">
                        <hi rend="italic">August 1, 1914</hi>.</date>
                </dateline>
                <p rend="center">[Translation]</p>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: By order of my Government I
                    have the honor to apprise your excellency, as required by Article 4 of the
                    convention of 1907 concerning submarine mines, that the North Sea and Goeree
                    passes have been obstructed with submarine mines and that preparations are being
                    made to obstruct the other passes.</p>
                <p>Be pleased [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DBWH1">
                            <hi rend="smallcaps">W. de Beaufort</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
