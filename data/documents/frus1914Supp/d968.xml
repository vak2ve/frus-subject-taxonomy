    <text>
        <body>
            <div frus:doc-dateTime-max="1914-09-01T23:59:59-05:00"
                frus:doc-dateTime-min="1914-09-01T00:00:00-05:00" n="968"
                subtype="historical-document" type="document" xml:id="d968">
                <note rend="inline" type="source">File No. 763.72111/113</note>
                <head>
                    <hi rend="italic">The German Ambassador</hi> (<persName corresp="#p_BCJHV1"
                        type="from">
                        <hi rend="italic">Bernstorff</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <placeName>New York</placeName>, <date calendar="gregorian" when="1914-09-01">
                        <hi rend="italic">September 1, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 8:10 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>British steamer <hi rend="italic">Merion</hi>, American Line, 13,000 tons burden,
                    arrived last night at Philadelphia armed with six cannons. Intends staying
                    several days. Takes freight for Liverpool.</p>
                <p>I beg to draw your attention to the above.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BCJHV1">J. Bernstorff</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
