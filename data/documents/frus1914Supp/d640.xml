    <text>
        <body>
            <div frus:doc-dateTime-max="1914-10-31T12:00:00-05:00"
                frus:doc-dateTime-min="1914-10-31T12:00:00-05:00" n="640"
                subtype="historical-document" type="document" xml:id="d640">
                <note rend="inline" type="source">File No. 165.102/226</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW2"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Berlin</hi>
                    </placeName>, <date calendar="gregorian" when="1914-10-31T18:00:00+01:00">
                        <hi rend="italic">October 31, 1914, 6 p.m.</hi>
                    </date>
                    <lb/> [<hi rend="italic">Received November 1, 7:30 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>683. Department’s 516, 29th.<note n="1" xml:id="d640fn1">Not printed.</note> Your
                    448, 19th, seems satisfactory to German Government as they allow the export of
                    dyestuffs, cyanide, and chemicals.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW2">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
