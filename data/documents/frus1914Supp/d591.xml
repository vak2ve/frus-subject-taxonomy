<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-10-27T23:59:59-05:00" frus:doc-dateTime-min="1914-10-27T00:00:00-05:00" n="591" subtype="historical-document" type="document" xml:id="d591">
                        <note rend="inline" type="source">File No. 300.115/967</note>
                        <head>
                            <hi rend="italic">The Minister in the Netherlands</hi> (<persName corresp="#p_VDH1"><hi rend="italic">Van Dyke</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">The Hague</hi></placeName>, <date calendar="gregorian" when="1914-10-27">
                                <hi rend="italic">October 27, 1914</hi>.</date>
                            <lb/> [<hi rend="italic">Received 5:45 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>55. Your 48, 26th. Permission to consign goods to Netherlands Government
                            must be had from Mr. <persName>Bock</persName> of the Department of
                            Commerce at The Hague.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_VDH1">
                                    <hi rend="smallcaps">Van Dyke</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>