    <text>
        <body>
            <div frus:doc-dateTime-max="1914-09-08T23:59:59-05:00"
                frus:doc-dateTime-min="1914-09-08T00:00:00-05:00" n="10"
                subtype="historical-document" type="document" xml:id="d10">
                <note rend="inline" type="source">File No. 711.0012/491</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_HMT1"
                        type="from">
                        <hi rend="italic">Herrick</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Paris</hi>
                    </placeName>, <date calendar="gregorian" when="1914-09-08">
                        <hi rend="italic">September 8, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 10:05 a.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>49. Your 47, September 4. <persName>Garrett</persName> telegraphs that French
                    Foreign Office is in communication with British Foreign Office regarding date
                    for signing treaty.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HMT1">
                            <hi rend="smallcaps">Herrick</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
