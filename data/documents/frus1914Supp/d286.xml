<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-07T13:00:00-05:00" frus:doc-dateTime-min="1914-08-07T13:00:00-05:00" n="286" subtype="historical-document" type="document" xml:id="d286">
                        <note rend="inline" type="source">File No. 763.72111/3</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé d’Affaires in China</hi> (<persName corresp="#p_MJVA1" type="to"><hi rend="italic">MacMurray</hi></persName>)</head>
                        <dateline>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-08-07T13:00:00-05:00">
                                <hi rend="italic">August 7, 1914, 1 p.m.</hi>
                            </date>
                        </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Your telegram of August 3, 5 p.m. The Department authorizes Legation to
                            participate in proposed arrangement to neutralize all foreign
                            settlements in China not including leased areas.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BWJ1">
                                    <hi rend="smallcaps">Bryan</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>