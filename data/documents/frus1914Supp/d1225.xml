<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-11-30T23:59:59-05:00" frus:doc-dateTime-min="1914-11-30T00:00:00-05:00" n="1225" subtype="historical-document" type="document" xml:id="d1225">
                        <note rend="inline" type="source">File No. 763.72/1239</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Ambassador in Turkey</hi> (<persName corresp="#p_MH1" type="to"><hi rend="italic">Morgenthau</hi></persName>)</head>
                        <dateline>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-11-30">
                                <hi rend="italic">November 30, 1914</hi>.</date>
                        </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>82. Your 47, 17th, 5 p.m. Department considers that the matter is closed,
                            and therefore deems it advisable that no further investigation is [<hi rend="italic">be</hi>] made.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>