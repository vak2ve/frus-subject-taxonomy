                subtype="historical-document" type="document" xml:id="d1325">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in the Netherlands</hi> (<hi rend="italic">
                        <persName corresp="#p_VDH1" type="to">Van Dyke</persName>
                    </hi>)</head>
                <dateline>
                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Washington</hi>
                    </placeName>, <date calendar="gregorian" when="1914-09-01">
                        <hi rend="italic">September 1, 1914</hi>.</date>
                </dateline>
                <p rend="center">[Telegram]</p>
                <p>6. The American Red Cross vessel will stop at Rotterdam. Ascertain whether
                    Netherlands authorities at that port will remit port duties.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWJ1">
                            <hi rend="smallcaps">Bryan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
