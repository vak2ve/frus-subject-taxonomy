<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-21T23:59:59-05:00" frus:doc-dateTime-min="1914-08-21T00:00:00-05:00" n="8" subtype="historical-document" type="document" xml:id="d8">
                        <note rend="inline" type="source">File No. 711.0012/468</note>
                        <head>
                            <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW2" type="from"><hi rend="italic">Gerard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Berlin</hi></placeName>, <date calendar="gregorian" when="1914-08-21">
                                <hi rend="italic">August 21, 1914</hi>.</date>
                            <lb/> [<hi rend="italic">Received August 22, 9 a.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Sorry to report no hope peace treaty.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_GJW2">
                                    <hi rend="smallcaps">Gerard</hi>
                                </persName>
                            </signed>
                        </closer>
