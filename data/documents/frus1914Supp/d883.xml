<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-12-11T23:59:59-05:00" frus:doc-dateTime-min="1914-12-11T00:00:00-05:00" n="883" subtype="historical-document" type="document" xml:id="d883">
                        <note rend="inline" type="source">File No. 124.0665/2</note>
                        <head>
                            <hi rend="italic">The Ambassador in Russia</hi> (<persName corresp="#p_MGT1" type="from"><hi rend="italic">Marye</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Petrograd</hi></placeName>, <date calendar="gregorian" when="1914-12-11">
                                <hi rend="italic">December 11, 1914</hi>.</date>
                            <lb/> [<hi rend="italic">Received 7:30 p.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>146. Department’s 91, 4th.<note n="1" xml:id="d883fn1">Not
                                printed.</note> Foreign Office states exemption from censure or
                            correspondence of diplomatic and consular officers guaranteed by decree
                            of August 2 concerning temporary military censorship, according to which
                            censorship does not apply to letters, telegrams, and despatches of
                            diplomatic and consular officials but [all] such must be presented to
                            postal and telegraph officials clearly marked as belonging to such
                            diplomatic or consular officials.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_MGT1">
                                    <hi rend="smallcaps">Marye</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>