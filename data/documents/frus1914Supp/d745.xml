<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-09T23:59:59-05:00" frus:doc-dateTime-min="1914-08-09T00:00:00-05:00" n="745" subtype="historical-document" type="document" xml:id="d745">
                        <note rend="inline" type="source">File No. 840.48/126</note>
                        <head>
                            <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName corresp="#p_PFC1" type="from"><hi rend="italic">Penfield</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <placeName>
                                <hi rend="italic">Vienna</hi></placeName>, <date calendar="gregorian" when="1914-08-09">
                                <hi rend="italic">August 9, 1914</hi>.</date>
                            <lb/> [<hi rend="italic">Received August 10, 7:30 a.m.</hi>] </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Austro-Hungarian Government agrees to exemption from military law such
                            vessels as may be chartered by Americans for transportation citizens to
                            the United States on condition that vessels are used exclusively for
                            purpose named and that other belligerent states agree to proposal. They
                            ask to be kept fully informed.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_PFC1">
                                    <hi rend="smallcaps">Penfield</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>