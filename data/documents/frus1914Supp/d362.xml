    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-23T23:59:59-05:00"
                frus:doc-dateTime-min="1914-08-23T00:00:00-05:00" n="362"
                subtype="historical-document" type="document" xml:id="d362">
                <note rend="inline" type="source">File No. 763.72112/107</note>
                <head>
                    <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="from">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">Vienna</hi>
                    </placeName>, <date calendar="gregorian" when="1914-08-23">
                        <hi rend="italic">August 23, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 5 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Your August 21 [20] via Berlin. In all declarations of war Austro-Hungarian
                    Government has announced adherence to provisions Declaration of London on
                    condition reciprocity.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
