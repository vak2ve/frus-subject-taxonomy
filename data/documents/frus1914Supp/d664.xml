    <text>
        <body>
            <div frus:doc-dateTime-max="1914-11-17T23:59:59-05:00"
                frus:doc-dateTime-min="1914-11-17T00:00:00-05:00" n="664"
                subtype="historical-document" type="document" xml:id="d664">
                <note rend="inline" type="source">File No. 611.479/52</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">London</hi>
                    </placeName>, <date calendar="gregorian" when="1914-11-17">
                        <hi rend="italic">November 17, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 10 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>1079. Your 507, November 10, and 513, November 11.<note n="1" xml:id="d664fn1"
                        >No. 507 not printed.</note>
                </p>
                <p>
                    <persName corresp="#p_GSE1">Sir Edward Grey</persName> informs me that all meat
                    and wool and wool skins in the United Kingdom and colonies are required by
                    British on account of war and that preembargo contracts cannot be filled because
                    the necessities of the state must override all private contracts. This
                    derangement of trade is one of necessary results of war and from such
                    derangements British subjects of course suffer more and more of them suffer than
                    neutrals.</p>
                <closer>
                    <hi rend="smallcaps">American Ambassador</hi>
                </closer>
            </div>
        </body>
