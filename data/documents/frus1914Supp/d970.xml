<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-09-03T23:59:59-05:00" frus:doc-dateTime-min="1914-09-03T00:00:00-05:00" n="970" subtype="historical-document" type="document" xml:id="d970">
                        <note rend="inline" type="source">File No. 763.72111/96</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the German Ambassador</hi> (<persName corresp="#p_BCJHV1" type="to"><hi rend="italic">Bernstorff</hi></persName>)</head>
                        <dateline>
                            <hi rend="smallcaps">Department of State</hi>, <placeName>
                                <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-09-03">
                                <hi rend="italic">September 3, 1914</hi>.</date>
                        </dateline>
                        <p rend="center">[Telegram]</p>
                        <p>Your telegram August 31 regarding <persName>S. S. <hi rend="italic">Adriatic</hi></persName>. Department being satisfied that
                            vessel is merchantman has allowed clearance accordingly.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BWJ1">
                                    <hi rend="smallcaps">W. J. Bryan</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>