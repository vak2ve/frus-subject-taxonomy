                subtype="historical-document" type="document" xml:id="d434">
                <note rend="inline" type="source">File No. 763.72112/197</note>
                <head>
                    <hi rend="italic">The Consul General at London</hi> (<persName corresp="#p_SRP1"
                        type="from">
                        <hi rend="italic">Skinner</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <dateline>
                    <hi rend="smallcaps">American Consulate General</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">London</hi>
                    </placeName>, <date calendar="gregorian" when="1914-10-19">
                        <hi rend="italic">October 19, 1914</hi>.</date>
                    <lb/> [<hi rend="italic">Received 3:45 p.m.</hi>] </dateline>
                <p rend="center">[Telegram]</p>
                <p>Holland-America Line hears that British Government intends to declare cotton
                    conditional contraband.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SRP1">
                            <hi rend="smallcaps">Skinner</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
