                                ana="#date_undated-inferred-from-sibling-dates" calendar="gregorian"
                                when="1979-03-14">undated</date>
                        </dateline>
                    </opener>
                    <p rend="center">
                        <hi rend="italic">ISRAEL: EQUIPMENT</hi>
                    </p>
                    <table cols="2">
