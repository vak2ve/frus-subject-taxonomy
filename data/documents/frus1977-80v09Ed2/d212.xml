                    <note rend="inline">
                        <hi rend="strong">Tab A</hi>
                    </note>
                    <head>
                        <hi rend="strong">List Prepared in the Department of Defense</hi>
                        <note n="3" xml:id="d212fn3">No classification marking.</note>
                    </head>
