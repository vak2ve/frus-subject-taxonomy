    <text>
        <body>
            <div frus:doc-dateTime-max="1942-08-12T00:30:00-05:00"
                frus:doc-dateTime-min="1942-08-12T00:30:00-05:00" n="114"
                subtype="historical-document" type="document" xml:id="d114">
                <note rend="inline" type="source">740.0011 Pacific War/2720: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in India</hi> (<persName type="from">
                        <hi rend="italic">Merrell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">New Delhi</hi>
                        </placeName>, <date calendar="gregorian" when="1942-08-12T11:00:00+05:30"
                            >August 12, 1942—11 a.m.</date>
                        <lb/> [Received August 12—7:32 a.m.]</dateline>
                </opener>
                <p>596. At the request of Mr. Currie, General Stilwell has ordered Davies to
                    accompany Currie to Washington following which journey Davies is to return
                    promptly to this theater.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Merrell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
