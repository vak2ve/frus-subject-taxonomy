                subtype="historical-document" type="document" xml:id="d189">
                <note rend="inline" type="source">793.94/17094: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Gauss</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chungking</hi>
                        </placeName>, <date calendar="gregorian" when="1942-09-21T14:00:00+07:00"
                            >September 21, 1942—2 p.m.</date>
                        <lb/> [Received September 22—8:23 p.m.]</dateline>
                </opener>
                <p>1072. For information of the Department only and not for other Government
                    agencies. The information contained in Embassy’s Nos. 1070 and 1071 was obtained
                    from Chou En-lai, Communist Party representative in Chungking.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gauss</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
