                subtype="historical-document" type="document" xml:id="d398">
                <note rend="inline" type="source">893.51/7484c: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Gauss</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1942-05-07T17:00:00-04:00"
                            >May 7, 1942—5 p.m.</date>
                    </dateline>
                </opener>
                <p>365. For Adler from the Secretary of the Treasury.</p>
                <p>“Fox has left Washington to return to Chungking by plane. He is expected to
                    arrive at Chungking about June 5.”</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
