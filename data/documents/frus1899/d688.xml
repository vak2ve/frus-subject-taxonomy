    <text>
        <body>
            <div frus:doc-dateTime-max="1899-12-20T23:59:59-05:00"
                frus:doc-dateTime-min="1899-12-20T00:00:00-05:00" n="688"
                subtype="historical-document" type="document" xml:id="d688">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Storer</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1899-12-20">
                            <hi rend="italic">December 20, 1899</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 113.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your No.
                    135, of the 5th instant, inclosing a copy of a note from the Spanish foreign
                    office stating that arrangements have been made for the payment of the interest
                    due for the years 1898 and 1899 on the Spanish indemnity debt under the treaty
                    of 1834.</p>
                <p>The Government of the United States cordially appreciates the friendly and just
                    spirit shown by the Government of Spain in this arrangement of the matter.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
