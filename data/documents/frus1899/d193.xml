                <head>
                    <hi rend="italic">Mr. <persName type="from">Powell</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port au Prince</hi>
                        </placeName>,<lb/>
                        <date calendar="gregorian" when="1899-07-27">
                            <hi rend="italic">July 27, 1899</hi>
                        </date>.</dateline>
                </opener>
                <p>Heureaux has been assassinated. Further information later.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Powell.</hi>
                    </signed>
                </closer>
            </div>
        </body>
