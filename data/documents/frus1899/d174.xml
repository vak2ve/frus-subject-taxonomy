<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-10-03T23:59:59-05:00" frus:doc-dateTime-min="1898-10-03T00:00:00-05:00" n="174" subtype="historical-document" type="document" xml:id="d174">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Hart</persName></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1898-10-03"><hi rend="italic">October 3,
                                1898</hi></date>.</dateline></opener>
                        <p>The Panama Star and Herald claim is in the charge of this Government, and
                            you will press its immediate payment.</p>
                        <closer><signed><hi rend="smallcaps">Hay.</hi></signed></closer>
                    </div>
                    </body></text></TEI>