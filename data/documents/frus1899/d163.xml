    <text>
        <body>
            <div frus:doc-dateTime-max="1899-11-17T23:59:59-05:00"
                frus:doc-dateTime-min="1899-11-17T00:00:00-05:00" n="163"
                subtype="historical-document" type="document" xml:id="d163">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Wu</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>
                        <date calendar="gregorian" when="1899-11-17">
                            <hi rend="italic">November 17, 1899</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 115.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 15th instant protesting against the alleged action of the
                    military authorities of the United States at Manila in refusing to permit the
                    landing there of Chinese subjects exempted by the treaty of 1894 between the
                    United States and China, and requesting that Major-General Otis be instructed to
                    the end that such exempted classes be permitted to land.</p>
                <p>A copy of your note has been communicated to the Secretary of War.</p>
                <p>Accept, etc.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
