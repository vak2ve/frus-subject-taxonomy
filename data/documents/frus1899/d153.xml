    <text>
        <body>
            <div frus:doc-dateTime-max="1899-02-24T23:59:59-05:00"
                frus:doc-dateTime-min="1899-02-24T00:00:00-05:00" n="153"
                subtype="historical-document" type="document" xml:id="d153">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Wu</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1899-02-24">
                            <hi rend="italic">February 24, 1899</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 88.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 18th instant, presenting additional observations on the subject
                    of the proposed extension of the present Chinese-exclusion laws of the United
                    States to the Hawaiian Islands.</p>
                <p>I have sent copies of your note to the Committee on Foreign Relations of the
                    Senate and to the Committee on Foreign Affairs of the House of Representatives,
                    for their information and consideration.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
