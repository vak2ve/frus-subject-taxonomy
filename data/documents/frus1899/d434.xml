                subtype="historical-document" type="document" xml:id="d434">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Draper</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1899-07-24">
                            <hi rend="italic">July 24, 1899</hi>
                        </date>.</dateline>
                </opener>
                <p>Inform minister for foreign affairs that the governor of Louisiana is
                    investigating the alleged lynching of persons born in Italy, and that this
                    Government will take all legal steps to secure justice which the facts may
                    warrant.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
