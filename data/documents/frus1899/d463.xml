    <text>
        <body>
            <div frus:doc-dateTime-max="1899-09-13T23:59:59-05:00"
                frus:doc-dateTime-min="1899-09-13T00:00:00-05:00" n="463"
                subtype="historical-document" type="document" xml:id="d463">
                <head>
                    <hi rend="italic">Governor <persName type="from">Foster</persName> to Mr.
                            <persName type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Baton Rouge, La.</hi>
                        </placeName>, <date calendar="gregorian" when="1899-09-13">
                            <hi rend="italic">September 13, 1899</hi>
                        </date>.</dateline>
                </opener>
                <p>I forward by mail to-day the report of the judge and district attorney in the
                    case of the alleged lynching of Italian citizens in the parish of Madison.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Murphy J. Foster</hi>,<lb/>
                        <hi rend="italic">Governor of Louisiana.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
