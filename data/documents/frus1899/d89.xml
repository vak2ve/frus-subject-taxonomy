                subtype="historical-document" type="document" xml:id="d89">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Porter</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1899-11-21">
                            <hi rend="italic">November 21, 1899</hi>
                        </date>.</dateline>
                </opener>
                <p>Informally submit to French Government form of declaration outlined in inclosures
                    with instruction No. 664 of September 6, and ask whether France will join.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
