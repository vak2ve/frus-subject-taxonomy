<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-11-10T23:59:59-05:00" frus:doc-dateTime-min="1898-11-10T00:00:00-05:00" n="183" subtype="historical-document" type="document" xml:id="d183">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Hart</persName></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1898-11-10"><hi rend="italic">November 10,
                                    1898</hi></date>.</dateline></opener>
                        <p>Will accept payment Star and Herald claim in installments, $10,000 each,
                            at one, two, and three months, American currency.</p>
                        <closer><signed><hi rend="smallcaps">Hay.</hi></signed></closer>
                    </div>
                    </body></text></TEI>