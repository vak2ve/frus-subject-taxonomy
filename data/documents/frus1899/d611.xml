<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1899-04-15T23:59:59-05:00" frus:doc-dateTime-min="1899-04-15T00:00:00-05:00" n="611" subtype="historical-document" type="document" xml:id="d611">
                        <head><hi rend="italic">Mr. <persName type="from">Choate</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Embassy</hi>,<lb/><hi rend="italic">London</hi></placeName>, <date calendar="gregorian" when="1899-04-15"><hi rend="italic">April 15,
                                1899</hi></date>.</dateline></opener>
                        <p>I have accepted joint agreement in terms of British minister for foreign
                            affairs telegrams as obtained from the foreign office.</p>
                        <closer><signed><hi rend="smallcaps">Choate.</hi></signed></closer>
                    </div>
                    </body></text></TEI>