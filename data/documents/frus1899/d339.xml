                <head>
                    <hi rend="italic">Mr. <persName type="from">Hunter</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guatemala</hi>
                        </placeName>, <date calendar="gregorian" when="1899-01-28">
                            <hi rend="italic">January 28, 1899</hi>
                        </date>. (Received 10.54 p.m.,</dateline>
                </opener>
                <p>Original credentials presented and have been officially recognized by President
                    Honduras; particulars by mail.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hunter.</hi>
                    </signed>
                </closer>
            </div>
