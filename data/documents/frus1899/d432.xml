<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1899-07-22T23:59:59-05:00" frus:doc-dateTime-min="1899-07-22T00:00:00-05:00" n="432" subtype="historical-document" type="document" xml:id="d432">
                        <head><hi rend="italic">Governor <persName type="from">Foster</persName> to
                                Mr. <persName type="to">Hay</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Baton
                                        Rouge, La.</hi></placeName>, <date calendar="gregorian" when="1899-07-22"><hi rend="italic">July 22,
                                1899</hi></date>.</dateline></opener>
                        <p>Your telegram will receive my immediate attention and will further advise
                            you.</p>
                        <closer><signed><hi rend="smallcaps">Murphy J. Foster</hi>, <hi rend="italic">Governor.</hi></signed></closer>
                    </div>
                    </body></text></TEI>