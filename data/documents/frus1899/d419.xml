    <text>
        <body>
            <div frus:doc-dateTime-max="1899-12-08T23:59:59-05:00"
                frus:doc-dateTime-min="1899-12-08T00:00:00-05:00" n="419"
                subtype="historical-document" type="document" xml:id="d419">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to <persName
                            type="to">Baron de Fava</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1899-12-08">
                            <hi rend="italic">December 8, 1899</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 538.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: In accordance with your request I
                    transmitted at once a copy of your latest notes on the subject of the Italian
                    bureau to my colleague of the Treasury.</p>
                <p>I regret once more to have to inform your excellency that this Government does
                    not see its way clear to reopen the subject.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
