                subtype="historical-document" type="document" xml:id="d775">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Russell</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Caracas</hi>
                        </placeName>, <date calendar="gregorian" when="1899-09-15">
                            <hi rend="italic">September 15, 1899</hi>
                        </date>.</dateline>
                </opener>
                <p>Revolutionists took Valencia yesterday. President returning to Caracas. Where is
                    war vessel? Permission granted to make survey mentioned yesterday’s cable.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Russell.</hi>
                    </signed>
                </closer>
            </div>
        </body>
