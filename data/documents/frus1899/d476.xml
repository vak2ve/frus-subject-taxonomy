    <text>
        <body>
            <div frus:doc-dateTime-max="1899-09-29T23:59:59-05:00"
                frus:doc-dateTime-min="1899-09-29T00:00:00-05:00" n="476"
                subtype="historical-document" type="document" xml:id="d476">
                <head>
                    <hi rend="italic">
                        <persName type="from">Baron Fava</persName> to Mr. <persName type="to"
                            >Hill</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lenox, Mass.</hi>
                        </placeName>, <date calendar="gregorian" when="1899-09-29">
                            <hi rend="italic">September 29, 1899</hi>
                        </date>.</dateline>
                </opener>
                <p>Please kindly wire if it is from your special agent that you are awaiting
                    expected additional information mentioned in your telegram of 25th instant.
                    Thanks.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Fava.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
