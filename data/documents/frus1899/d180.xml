<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-11-01T23:59:59-05:00" frus:doc-dateTime-min="1898-11-01T00:00:00-05:00" n="180" subtype="historical-document" type="document" xml:id="d180">
                        <head><hi rend="italic">Mr. <persName type="from">Hill</persName> to Mr.
                                    <persName type="to">Hart</persName></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1898-11-01"><hi rend="italic">November 1,
                                1898</hi></date>.</dateline></opener>
                        <p>Proceed with demand Star Herald claim. This Government imperatively
                            insists on prompt payment.</p>
                        <closer><signed><hi rend="smallcaps">Hill.</hi></signed></closer>
                    </div>
                    </body></text></TEI>