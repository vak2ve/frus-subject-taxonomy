                subtype="historical-document" type="document" xml:id="d425">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hill</persName> to <persName
                            type="to">Baron de Fava</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1899-12-22">
                            <hi rend="italic">December 22, 1899</hi>
                        </date>.</dateline>
                </opener>
                <p>Your telegrams received. Have proposed to Treasury admission of Italian agent to
                    Barge Office as you desire, but reply has not yet been received. Will inform you
                    as soon as possible.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">David J. Hill.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
