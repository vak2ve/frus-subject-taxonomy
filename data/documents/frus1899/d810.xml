    <text>
        <body>
            <div frus:doc-dateTime-max="1899-12-04T23:59:59-05:00"
                frus:doc-dateTime-min="1899-12-04T00:00:00-05:00" n="810"
                subtype="historical-document" type="document" xml:id="d810">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Loomis</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1899-12-04">
                            <hi rend="italic">December 4, 1899</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 310.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your No. 352
                    of the 20th ultimo, reporting that you had on that date officially recognized
                    the government of General Castro.</p>
                <p>Your recognition of his government is approved.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
