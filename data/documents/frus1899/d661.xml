    <text>
        <body>
            <div frus:doc-dateTime-max="1900-04-17T23:59:59-05:00"
                frus:doc-dateTime-min="1900-04-17T00:00:00-05:00" n="661"
                subtype="historical-document" type="document" xml:id="d661">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hill</persName> to the <persName
                            type="to">Duke de Arcos</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Personal.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1900-04-17">
                            <hi rend="italic">April 17, 1900</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Minister</hi>: I quote for your information the
                    following cablegram received from the military governor of the Philippine
                    Islands, and dated the 10th instant: <quote rend="blockquote">
                        <p>Shipped for Spain to-day 13 officers, 258 men, Spanish army, released
                            from insurgents, 17 wives and children.</p>
                    </quote>
                </p>
                <p>Very truly, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">David J. Hill</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
