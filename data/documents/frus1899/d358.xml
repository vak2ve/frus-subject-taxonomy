    <text>
        <body>
            <div frus:doc-dateTime-max="1899-04-11T23:59:59-05:00"
                frus:doc-dateTime-min="1899-04-11T00:00:00-05:00" n="358"
                subtype="historical-document" type="document" xml:id="d358">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Beaupre</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1899-04-11">
                            <hi rend="italic">April 11, 1899</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 141.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                    dispatch, No. 159, of the 22d ultimo, explaining the case between Honduras and
                    Great Britain which you have been requested to arbitrate.</p>
                <p>The Department approves the conditions, as stated in the dispatch, under which
                    the submission is made.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
