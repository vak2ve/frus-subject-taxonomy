    <text>
        <body>
            <div frus:doc-dateTime-max="1899-07-25T23:59:59-05:00"
                frus:doc-dateTime-min="1899-07-25T00:00:00-05:00" n="488"
                subtype="historical-document" type="document" xml:id="d488">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Buck</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1899-07-25">
                            <hi rend="italic">July 25, 1899</hi>
                        </date>.</dateline>
                </opener>
                <p>If permission be necessary to land and pasture at Nagasaki or Yokohama United
                    States Army horses in transit to Manila, request it.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
