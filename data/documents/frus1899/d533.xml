<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1899-02-27T23:59:59-05:00" frus:doc-dateTime-min="1899-02-27T00:00:00-05:00" n="533" subtype="historical-document" type="document" xml:id="d533">
                        <head><hi rend="italic">Mr. <persName type="from">Merry</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Managua</hi></placeName>, <date calendar="gregorian" when="1899-02-27"><hi rend="italic">February 27,
                                    1899</hi></date>.</dateline></opener>
                        <p>The capital of Mosquito Territory has been captured by the Government of
                            Nicaragua. United States, English naval forces landed temporarily.</p>
                        <closer><signed><hi rend="smallcaps">Merry.</hi></signed></closer>
                    </div>
                    </body></text></TEI>