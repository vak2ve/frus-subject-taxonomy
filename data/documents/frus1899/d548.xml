                <head>
                    <hi rend="italic">Mr. <persName type="from">Merry</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Salvador</hi>
                        </placeName>, <date calendar="gregorian" when="1899-04-07">
                            <hi rend="italic">April 7, 1899</hi>
                        </date>.</dateline>
                </opener>
                <p>Your two cables received; just leaving for Managua, whence will reply Monday.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Merry.</hi>
                    </signed>
                </closer>
            </div>
        </body>
