    <text>
        <body>
            <div frus:doc-dateTime-max="1899-11-18T23:59:59-05:00"
                frus:doc-dateTime-min="1899-11-18T00:00:00-05:00" n="762"
                subtype="historical-document" type="document" xml:id="d762">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Loomis</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1899-11-18">
                            <hi rend="italic">November 18, 1899</hi>
                        </date>.</dateline>
                </opener>
                <p>Three hundred and forty-five received. Insist on ship’s papers being delivered to
                    the United States consul, in accordance with practice of modern nations. Invite
                    coincident action by other ministers.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
