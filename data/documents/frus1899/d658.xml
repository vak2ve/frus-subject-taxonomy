                subtype="historical-document" type="document" xml:id="d658">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to the <persName
                            type="to">Duke de Arcos</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1900-03-07">
                            <hi rend="italic">March 7, 1900</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 80.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to advise you that this
                    Department has received through the Navy Department a copy of a telegram from
                    Rear-Admiral Watson, dated the 1st instant, announcing that he had brought to
                    Manila from the Gulf of Rajay, 508 rescued Spanish prisoners.</p>
                <p>Accept, etc.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
