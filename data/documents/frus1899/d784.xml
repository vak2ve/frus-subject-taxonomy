                subtype="historical-document" type="document" xml:id="d784">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hill</persName> to Mr. <persName
                            type="to">Loomis</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1899-10-10">
                            <hi rend="italic">October 10, 1899</hi>
                        </date>.</dateline>
                </opener>
                <p>Secretary of the Navy authorizes commander of the <hi rend="italic">Detroit</hi>
                    to permit suggested conference to take place on board if so requested.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hill</hi>, <hi rend="italic">Acting.</hi>
                    </signed>
                </closer>
            </div>
        </body>
