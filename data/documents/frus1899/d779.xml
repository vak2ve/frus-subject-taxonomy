    <text>
        <body>
            <div frus:doc-dateTime-max="1899-09-19T23:59:59-05:00"
                frus:doc-dateTime-min="1899-09-19T00:00:00-05:00" n="779"
                subtype="historical-document" type="document" xml:id="d779">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr. <persName
                            type="to">Russell</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1899-09-19">
                            <hi rend="italic">September 19, 1899</hi>
                        </date>.</dateline>
                </opener>
                <p>Flag should only be shown by citizens. You may notify authorities of any menaced
                    Cuban property and use good offices for them.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Adee.</hi>
                    </signed>
                </closer>
            </div>
        </body>
