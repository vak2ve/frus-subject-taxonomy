<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1950-01-27T23:59:59-05:00" frus:doc-dateTime-min="1950-01-27T00:00:00-05:00" n="9" subtype="historical-document" type="document" xml:id="d9">
                        <note rend="inline" type="source">740.5 <gloss target="#t_MAP1">MAP</gloss>/1–2750</note>
                        <head>
                            <hi rend="italic">Memorandum by the <gloss type="from">President</gloss>
                                to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1950-01-27">January 27,
                                1950</date>.</dateline>
                        </opener>
                        <p>I have today approved, as satisfying the pertinent provisions of the
                            Mutual Defense Assistance Act of 1949, the recommendations for the
                            integrated defense of the North Atlantic area made by the North Atlantic
                            Council and Defense Committee.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Harry Truman</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>