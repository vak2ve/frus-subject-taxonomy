                subtype="historical-document" type="document" xml:id="d130">
                <note rend="inline" type="source">740.0011 Pacific War/939: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Paraguay</hi> (<persName type="from">
                        <hi rend="italic">Frost</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Asunción</hi>
                        </placeName>, <date calendar="gregorian" when="1941-12-10T18:00:00-04:00"
                            >December 10, 1941—6 p.m.</date>
                        <lb/>[Received 8:10 p.m.]</dateline>
                </opener>
                <p>221. Department’s circular telegram December 8, 1 a.m. The Government feels that
                    use of communications facilities here in ways inimical to continental defense is
                    unlikely from practical standpoint but will give matter earnest attention.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Frost</hi>
                    </signed>
                </closer>
            </div>
        </body>
