<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-12-11T15:00:00-05:00" frus:doc-dateTime-min="1941-12-11T15:00:00-05:00" n="13" subtype="historical-document" type="document" xml:id="d13">
                        <note rend="inline" type="source">740.00111 A.R.N.C./217a: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Brazil</hi> (<persName type="to"><hi rend="italic">Caffery</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1941-12-11T15:00:00-05:00">December 11, 1941—3
                                p.m.</date></dateline>
                        </opener>
                        <p>1340. Please deliver following message from Professor Fenwick to Dr.
                            Mello Franco:<note n="25" xml:id="d13fn1">Afranio de Mello Franco,
                                Brazilian member of the Neutrality Committee.</note></p>
                        <p>“Recommend Committee consider possible ways of extending functions to
                            meet present emergency.”</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>