                subtype="historical-document" type="document" xml:id="d242">
                <note rend="inline" type="source">714.44A15/237: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Guatemala</hi> (<persName type="to">
                        <hi rend="italic">Des Portes</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1941-05-21T19:00:00-04:00"
                            >May 21, 1941—7 p.m.</date>
                    </dateline>
                </opener>
                <p>48. Your 69, May 17, noon. The Department hopes that you will be able discreetly
                    to ascertain directly from the Foreign Minister whether he has made to the
                    British Minister the proposal referred to in your telegram under reference.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
