                subtype="historical-document" type="document" xml:id="d149">
                <note rend="inline" type="source">740.0011 Pacific War/1436: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Venezuela</hi> (<persName type="from">
                        <hi rend="italic">Corrigan</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Caracas</hi>
                        </placeName>, <date calendar="gregorian" when="1941-12-27">December 27,
                            1941</date>.<lb/>[Received December 27—4:22 p.m.]</dateline>
                </opener>
                <p>335. Department’s circular December 8, 1 a.m. President informed me this morning
                    that Cabinet decided yesterday to suspend as from today all cable and radio
                    communication between Venezuela and non-American countries.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Corrigan</hi>
                    </signed>
                </closer>
            </div>
        </body>
