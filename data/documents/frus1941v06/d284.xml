                subtype="historical-document" type="document" xml:id="d284">
                <note rend="inline" type="source">722.2315/2561: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Peru</hi> (<persName type="from">
                        <hi rend="italic">Norweb</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1941-11-23">November 23,
                            1941</date>.<lb/>[Received 4:49 p.m.]</dateline>
                </opener>
                <p>628. Official communication announcing liberation of civilian and military
                    prisoners published in press this morning.</p>
                <p>Repeated to Quito.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Norweb</hi>
                    </signed>
                </closer>
            </div>
        </body>
