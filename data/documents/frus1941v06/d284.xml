<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-11-23T23:59:59-05:00" frus:doc-dateTime-min="1941-11-23T00:00:00-05:00" n="284" subtype="historical-document" type="document" xml:id="d284">
                            <note rend="inline" type="source">722.2315/2561: Telegram</note>
                            <head><hi rend="italic">The Ambassador in Peru</hi> (<persName type="from"><hi rend="italic">Norweb</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Lima</hi></placeName>, <date calendar="gregorian" when="1941-11-23">November 23, 1941</date>.<lb/>[Received
                                    4:49 p.m.]</dateline>
                            </opener>
                            <p>628. Official communication announcing liberation of civilian and
                                military prisoners published in press this morning.</p>
                            <p>Repeated to Quito.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Norweb</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>