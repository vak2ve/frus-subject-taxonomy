                subtype="historical-document" type="document" xml:id="d103">
                <note rend="inline" type="source">740.0011 Pacific War/1417: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in El Salvador</hi> (<persName type="from">
                        <hi rend="italic">Frazer</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Salvador</hi>
                        </placeName> [<date
                            ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                            calendar="gregorian" notAfter="1941-12-26T14:11:00-06:00"
                            notBefore="1941-12-12T00:00:00-06:00">undated</date>].<lb/>[Received
                        December 26, 1941—2:11 p.m.]</dateline>
                </opener>
                <p>135. Department’s circular telegram December 8, 1 a.m. This Government already
                    enacted measures mentioned.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Frazer</hi>
                    </signed>
                </closer>
            </div>
        </body>
