<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-04-18T20:00:00-05:00" frus:doc-dateTime-min="1941-04-18T20:00:00-05:00" n="500" subtype="historical-document" type="document" xml:id="d500">
                        <note rend="inline" type="source">810.20 Defense/667<hi rend="superscript">2/6</hi>: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from"><hi rend="italic">Caffery</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Rio de
                                        Janeiro</hi></placeName>, <date calendar="gregorian" when="1941-04-18T22:00:00-03:00">April 18, 1941—10
                                p.m.</date><lb/>[Received April 19—10:46 a.m.]</dateline>
                        </opener>
                        <p>327. For the Under Secretary. Department’s 209, April 17, 8 p.m. Aranha
                            says he agrees.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Caffery</hi>
                            </signed>
                        </closer>
