    <text>
        <body>
            <div frus:doc-dateTime-max="1861-10-30T23:59:59-05:00"
                frus:doc-dateTime-min="1861-10-30T00:00:00-05:00" n="264"
                subtype="historical-document" type="document" xml:id="d264">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Seward</persName> to Mr. <persName
                            type="to">Pike</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#left">No. 28.]</seg>
                    <dateline rendition="#right">
                        <hi rend="smallcaps">Department of State</hi>,<lb/>
                        <placeName>
                            <hi rend="italic">Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1861-10-30">
                            <hi rend="italic">October</hi> 30, 1861</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Your despatch of October 9 (No. 20) has been
                    received. We wait with much interest the result of your application to the
                    government of the Netherlands for explanations of the hospitalities extended by
                    its colonial authorities to privateers.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">James S. Pike</hi>, Esq., <hi rend="italic">&amp;c.,
                            &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
