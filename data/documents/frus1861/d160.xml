    <text>
        <body>
            <div frus:doc-dateTime-max="1861-11-07T23:59:59-05:00"
                frus:doc-dateTime-min="1861-11-07T00:00:00-05:00" n="160"
                subtype="historical-document" type="document" xml:id="d160">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Seward</persName> to Mr. <persName
                            type="to">Dayton</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#left">No. 80.]</seg>
                    <dateline rendition="#right">
                        <hi rend="smallcaps">Department of State</hi>,<lb/>
                        <placeName>
                            <hi rend="italic">Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1861-11-07">
                            <hi rend="italic">November</hi> 7, 1861</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your despatch of October 22, (No. 69,) which is accompanied by a note from Mr.
                    Thouvenel on the subject of my despatch to you, No. 56.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">William L. Seward</hi>, Esq., <hi rend="italic"
                            >&amp;c., &amp;c., &amp;c</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
