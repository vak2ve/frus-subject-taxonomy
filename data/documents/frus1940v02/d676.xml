                subtype="historical-document" type="document" xml:id="d676">
                <note rend="inline" type="source">851.30/94: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Algiers</hi> (<persName type="from">
                        <hi rend="italic">Cole</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Algiers</hi>
                        </placeName>, <date calendar="gregorian" when="1940-10-29T15:00:00+01:00"
                            >October 29, 1940—3 p.m.</date>
                        <lb/> [Received October 30—2 a.m.]</dateline>
                </opener>
                <p>139. Reliable source states, “Local high command of naval forces has received a
                    telegram from Admiral Darlan,<note n="79" xml:id="d676fn79">Jean François
                        Darlan, Minister of Marine in the French (Vichy) Government.</note> ‘I need
                    French Fleet kept in complete readiness day and night to save our Empire.’”</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cole</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
