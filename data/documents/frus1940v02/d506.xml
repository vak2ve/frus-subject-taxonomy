                subtype="historical-document" type="document" xml:id="d506">
                <note rend="inline" type="source">124.513/1335: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Bordeaux</hi> (<persName type="to">
                        <hi rend="italic">Waterman</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-06-15">June 15,
                            1940</date>.</dateline>
                </opener>
                <p>150. For Ambassador Biddle. Your 14, 14th. The Embassy at Berlin has been
                    instructed to inform the appropriate German authorities.</p>
                <pb facs="0452" n="443" xml:id="pg_443"/>
                <p>The Department assumes that you will arrange for the personnel now at the four
                    chateaux named to follow you to the temporary seat of the French Government as
                    soon as their presence in the Tours region no longer serves any useful
                    purpose.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
