                subtype="historical-document" type="document" xml:id="d625">
                <note rend="inline" type="source">351.115/1a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in France</hi> (<persName type="to">
                        <hi rend="italic">Matthews</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-10-17">October 17,
                            1940</date>.</dateline>
                </opener>
                <p>1594. Report by cable action now being taken by Embassy where American property
                    is occupied or requisitioned by German authorities and success of such action,
                    together with any comments you may care to make regarding measures which
                    Americans should take to protect their interests in such cases.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
