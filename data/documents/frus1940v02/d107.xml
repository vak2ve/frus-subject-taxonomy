                subtype="historical-document" type="document" xml:id="d107">
                <note rend="inline" type="source">340.1115A/671b: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Switzerland</hi> (<persName type="to">
                        <hi rend="italic">Harrison</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-05-21">May 21,
                            1940</date>.</dateline>
                </opener>
                <p>55. After consulting offices in Switzerland please cable whether American
                    citizens are able to proceed promptly to Genoa from Switzerland for embarkation
                    United States. Is there any difficulty in obtaining Swiss exit visas or Italian
                    entrance and exit visas?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
