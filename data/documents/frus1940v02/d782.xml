<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-11-13T15:00:00-05:00" frus:doc-dateTime-min="1940-11-13T15:00:00-05:00" n="782" subtype="historical-document" type="document" xml:id="d782">
                            <note rend="inline" type="source">840.4061 Motion Pictures/41:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Chargé in Germany</hi> (<persName type="to"><hi rend="italic">Morris</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1940-11-13T15:00:00-05:00">November 13, 1940—3 p.m.</date>
                                </dateline>
                            </opener>
                            <p>2998. Your 4515, October 30, 7 p.m. You are instructed to present a
                                note to the German Government in the form recommended in your
                                telegram.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Welles</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>