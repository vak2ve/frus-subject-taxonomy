                subtype="historical-document" type="document" xml:id="d109">
                <note rend="inline" type="source">340.1115A/663: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Ireland</hi> (<persName type="from">
                        <hi rend="italic">Gray</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Dublin</hi>
                        </placeName>, <date calendar="gregorian" when="1940-05-22T13:00:00+01:00"
                            >May 22, 1940—1 p.m.</date>
                        <lb/> [Received May 22—8:32 a.m.]</dateline>
                </opener>
                <p>20. Consul’s preliminary estimate indicates probably less than 600 Americans in
                    Ireland desirous to return. No new arrivals.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gray</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
