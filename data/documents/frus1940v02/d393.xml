                <note rend="inline" type="source">500.C115/1412: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at Geneva</hi> (<persName type="to">
                        <hi rend="italic">Tittmann</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-06-18T18:00:00-04:00"
                            >June 18, 1940—6 p.m.</date>
                    </dateline>
                </opener>
                <p>67. Your 90, June 14, 8 p.m. From State and Labor:</p>
                <p>Please inform Winant that we regret that it is not possible at this time to
                    extend such an invitation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
