                subtype="historical-document" type="document" xml:id="d88">
                <note rend="inline" type="source">340.1115A/604b: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Italy</hi> (<persName type="to">
                        <hi rend="italic">Phillips</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-05-15T03:00:00-04:00"
                            >May 15, 1940—3 a.m.</date>
                    </dateline>
                </opener>
                <p>117. Please telegraph best estimate of the number of Americans who will leave
                    Italy following your warning and number for whom special arrangements may have
                    to be made should the Mediterranean be closed So American shipping.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
