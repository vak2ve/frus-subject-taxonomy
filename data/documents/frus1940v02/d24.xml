<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-03-05T15:00:00-05:00" frus:doc-dateTime-min="1940-03-05T15:00:00-05:00" n="24" subtype="historical-document" type="document" xml:id="d24">
                            <note rend="inline" type="source">740.00111A Combat Areas/177:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in the United Kingdom</hi> (<persName type="to"><hi rend="italic">Johnson</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1940-03-05T15:00:00-05:00">March
                                        5, 1940—3 p.m.</date>
                                </dateline>
                            </opener>
                            <p>418. Your 490, February 28, 8 p.m. Please convey following message to
                                the Naval Person from the President: <quote rend="blockquote">
                                    <p>“Upon my return to Washington, I received your message. I
                                        deeply appreciate your efforts. I am having the situation
                                        thoroughly studied and will communicate with you further as
                                        soon as possible.”</p>
                                </quote>
                            </p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>