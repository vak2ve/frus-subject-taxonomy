    <text>
        <body>
            <div frus:doc-dateTime-max="1940-05-14T23:59:59-05:00"
                frus:doc-dateTime-min="1940-05-14T00:00:00-05:00" n="865"
                subtype="historical-document" type="document" xml:id="d865">
                <note rend="inline" type="source">856D.01/38</note>
                <head>
                    <hi rend="italic">The Netherland Minister</hi> (<persName type="from">
                        <hi rend="italic">Loudon</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 2693</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-05-14">May 14,
                            1940</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to confirm the message which I
                    have communicated by telephone to Mr. Berle, the Assistant Secretary of State,
                    that I am in receipt of a telegram from the Netherlands Minister of Foreign
                    Affairs, worded: <quote rend="blockquote">
                        <p>“We have absolute conviction that no alteration in political or legal
                            status Netherlands East or West Indies is contemplated by Allies and we
                            also feel confident about Japan.”</p>
                    </quote>
                </p>
                <p>Please accept [etc.]</p>
                <closer>
                    <signed>A. <hi rend="smallcaps">Loudon</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
