    <text>
        <body>
            <div frus:doc-dateTime-max="1940-04-11T16:00:00-05:00"
                frus:doc-dateTime-min="1940-04-11T16:00:00-05:00" n="62"
                subtype="historical-document" type="document" xml:id="d62">
                <note rend="inline" type="source">340.1115A/513: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Sweden</hi> (<persName type="to">
                        <hi rend="italic">Sterling</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-04-11T16:00:00-05:00"
                            >April 11, 1940—4 p.m.</date>
                    </dateline>
                </opener>
                <p>65. Your 48, April 10, 3 p.m.,<note n="9" xml:id="d62fn9">Not printed.</note> and
                    Department’s 62, April 10, 9 p.m. With respect to query number 3 German vessels
                    Tralleborg–Sassnitz route may be used when neutral vessels not reasonably
                    available.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
