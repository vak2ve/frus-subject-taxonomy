                subtype="historical-document" type="document" xml:id="d640">
                <note rend="inline" type="source">740.00119 European War 1939/437: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Turns</hi> (<persName type="from">
                        <hi rend="italic">Heisler</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tunis</hi>
                        </placeName>, <date calendar="gregorian" when="1940-07-03T12:00:00+02:00"
                            >July 3, 1940—noon</date>.<lb/>[Received July 4—10:26 p.m.]</dateline>
                </opener>
                <p>20. Tunis is very quiet and I am now informed at the Residence General here that
                    this Government is in entire agreement with the <pb facs="0583" n="574"
                        xml:id="pg_574"/> present Government of France and that this country will
                    comply with armistice conditions.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Heisler</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
