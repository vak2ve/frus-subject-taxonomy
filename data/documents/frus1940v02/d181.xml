    <text>
        <body>
            <div frus:doc-dateTime-max="1940-07-03T07:00:00-05:00"
                frus:doc-dateTime-min="1940-07-03T07:00:00-05:00" n="181"
                subtype="historical-document" type="document" xml:id="d181">
                <note rend="inline" type="source">340.1115A/1066: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Germany</hi> (<persName type="from">
                        <hi rend="italic">Heath</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1940-07-03T14:00:00+02:00"
                            >July 3, 1940—2 p.m.</date>
                        <lb/> [Received July 3—1:44 p.m.]</dateline>
                </opener>
                <p>2311. Following from Gordon.</p>
                <quote rend="blockquote">
                    <p>“Will Department please instruct Harrison in Bern to request the Swiss
                        Government to issue instructions to the Swiss Minister to The Hague to grant
                        visas with no more than a few hours delay to Americans who may be given a
                        sudden chance of evacuation and regarding whom the Legation at The Hague
                        will give assurances to the Swiss Minister there that these Americans are
                        only crossing Switzerland in transit on their way to a port of embarkation
                        for the United States. Gordon.”</p>
                </quote>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Heath</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
