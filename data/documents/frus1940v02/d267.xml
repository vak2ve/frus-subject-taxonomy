<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-03-26T19:00:00-05:00" frus:doc-dateTime-min="1940-03-26T19:00:00-05:00" n="267" subtype="historical-document" type="document" xml:id="d267">
                            <note rend="inline" type="source">740.00115 European War 1939/28:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in France</hi> (<persName type="to"><hi rend="italic">Murphy</hi></persName>)<note n="15" xml:id="d267fn15">The same, <hi rend="italic">mutatis
                                        mutandis</hi>, to the Ambassador in the United Kingdom, as
                                    telegram No. 565, March 26, 7 p.m., and to the Chargé in
                                    Germany, as telegram No. 738, March 26, 11 p.m.</note>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1940-03-26T19:00:00-05:00">March
                                        26, 1940—7 p.m.</date>
                                </dateline>
                            </opener>
                            <p>229. Department’s 1107, September 29, 5 p.m.<note n="16" xml:id="d267fn16">
                                    <ref target="frus1939v01#pg_641">
                                        <hi rend="italic">Foreign Relations</hi>, 1939, vol. <hi rend="smallcaps">i</hi>, p. 641</ref>.</note> Please
                                inquire at Foreign Office and report present status of
                                negotiations.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>