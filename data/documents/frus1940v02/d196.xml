<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-07-28T09:00:00-05:00" frus:doc-dateTime-min="1940-07-28T09:00:00-05:00" n="196" subtype="historical-document" type="document" xml:id="d196">
                            <note rend="inline" type="source">811.111 Quota 56/276: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Consul General at Amsterdam</hi>
                                    (<persName type="to"><hi rend="italic">Lee</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1940-07-28T10:00:00-04:00">July
                                        28, 1940—10 a.m.</date>
                                </dateline>
                            </opener>
                            <p>128. Your 340, 17th. You are authorized to issue nonpreference visas
                                under the Netherland quota in urgent cases to nonquota relatives of
                                American citizens.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Welles</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>