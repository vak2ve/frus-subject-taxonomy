                <note rend="inline" type="source">740.0011 European War 1939/3966: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at Casablanca</hi> (<persName type="to">
                        <hi rend="italic">Goold</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-06-24T18:00:00-04:00"
                            >June 24, 1940—6 p.m.</date>
                    </dateline>
                </opener>
                <p>21. Your 30, June 18, 10 p.m.<note n="36" xml:id="d635fn36">Not printed.</note>
                    Please continue to keep the Department informed of all developments relating to
                    the position of French Morocco toward the war.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
