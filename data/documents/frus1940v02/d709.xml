<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-12-07T18:00:00-05:00" frus:doc-dateTime-min="1940-12-07T18:00:00-05:00" n="709" subtype="historical-document" type="document" xml:id="d709">
                            <note rend="inline" type="source">740.0011 European War 1939/6997:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Consul at Dakar</hi> (<persName type="to"><hi rend="italic">Wasson</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1940-12-07T18:00:00-05:00">December 7, 1940—6 p.m.</date>
                                </dateline>
                            </opener>
                            <p>34. Please comment on report from Algiers that nine German aviators,
                                reported to be members of an armistice commission, have just passed
                                through that city returning from Dakar.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>