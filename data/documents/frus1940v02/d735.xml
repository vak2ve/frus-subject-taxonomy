<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-11-10T05:00:00-05:00" frus:doc-dateTime-min="1940-11-10T05:00:00-05:00" n="735" subtype="historical-document" type="document" xml:id="d735">
                            <note rend="inline" type="source">740.0011 European War 1939/6581:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The Consul at Dakar</hi> (<persName type="from"><hi rend="italic">Wasson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Dakar</hi></placeName>, <date calendar="gregorian" when="1940-11-10T09:00:00-01:00">November 10, 1940—9 a.m.</date>
                                    <lb/> [Received 3:10 p.m.]</dateline>
                            </opener>
                            <p>53. In official circles it is stated that the military forces under
                                the command of De Gaulle have completed the occupation of Gabon.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Wasson</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>