                subtype="historical-document" type="document" xml:id="d805">
                <note rend="inline" type="source">740.00119 European War 1939/315: Telegram</note>
                <head>
                    <hi rend="italic">Mr. <persName type="from">Myron C. Taylor</persName>, Personal
                        Representative of the President to <persName type="to">Pope Pius
                            XII</persName>, to President <persName>Roosevelt</persName>
                    </hi>
                    <note n="13" xml:id="d805fn13">Transmitted to the Department by the Ambassador
                        in Italy as telegram No. 287.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1940-04-25T12:00:00+01:00"
                            >April 25, 1940—noon</date>.<lb/>[Received April 25—8:50
                        a.m.]</dateline>
                </opener>
                <p>15. While awaiting your response to my telegrams numbers 13 and 14 Vatican
                    authorities desire to see me Friday<note n="14" xml:id="d805fn14">April
                        26.</note> and I consider it important at that time to advise the Pope of
                    your views.</p>
                <closer>[<signed>
                        <hi rend="smallcaps">Taylor</hi>
                    </signed>]</closer>
            </div>
        </body>
