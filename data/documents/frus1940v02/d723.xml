<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-06-24T17:00:00-05:00" frus:doc-dateTime-min="1940-06-24T17:00:00-05:00" n="723" subtype="historical-document" type="document" xml:id="d723">
                            <note rend="inline" type="source">740.0011 European War 1939/4174a:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Consul at Lagos</hi> (<persName type="to"><hi rend="italic">Jester</hi></persName>)<note n="12" xml:id="d723fn12">The same telegram was sent on the same date to
                                    the Consul at Leopoldville.</note>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1940-06-24T18:00:00-04:00">June
                                        24, 1940—6 p.m.</date>
                                </dateline>
                            </opener>
                            <p>Department would appreciate receiving by telegraph any information
                                you may be able to obtain in regard to the attitude of the armed
                                forces in French colonial territories toward carrying on the
                                war.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>