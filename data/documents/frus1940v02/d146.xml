<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-06-01T23:59:59-05:00" frus:doc-dateTime-min="1940-06-01T00:00:00-05:00" n="146" subtype="historical-document" type="document" xml:id="d146">
                            <note rend="inline" type="source">340.1115A/886a: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in the United Kingdom</hi> (<persName type="to"><hi rend="italic">Kennedy</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1940-06-01">June 1,
                                    1940</date>.</dateline>
                            </opener>
                            <p>1060. Alien mothers or fathers resident in United States and properly
                                documented may be embarked on board S. S. <hi rend="italic">President Roosevelt</hi> with accompanying American children.
                                Please advise offices concerned including Galway in reply to its
                                telegram of May 31.<note n="81" xml:id="d146fn81">Not
                                    printed.</note>
                            </p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>