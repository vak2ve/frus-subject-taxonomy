<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-01-14T13:00:00-05:00" frus:doc-dateTime-min="1934-01-14T13:00:00-05:00" n="83" subtype="historical-document" type="document" xml:id="d83">
                        <note rend="inline" type="source">837.00/4609: Telegram</note>
                        <head><hi rend="italic">The Personal Representative of the President</hi>
                                (<persName type="from"><hi rend="italic">Caffery</hi></persName>)
                                <hi rend="italic">to the <gloss type="to">Acting Secretary of
                                    State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Habana</hi></placeName>, <date calendar="gregorian" when="1934-01-14T13:00:00-05:00">January 14, 1934—1
                                p.m.</date><lb/>[Received 1:13 p.m.]</dateline>
                        </opener>
                        <p>16. My No. 14, January 14, noon. It is hoped, of course, to include
                            representation of some if not all opposition groups in the Mendieta</p>
                        <closer><signed><hi rend="smallcaps">Caffery</hi></signed></closer>
                    </div>
                    </body></text></TEI>