                <note rend="inline" type="source">838.516/293a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Haiti</hi> (<persName type="to">
                        <hi rend="italic">Armour</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-06-04T19:00:00-04:00"
                            >June 4, 1934—7 p.m.</date>
                    </dateline>
                </opener>
                <p>41. Please cable present status of bank sales contract and proposed treaty.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
