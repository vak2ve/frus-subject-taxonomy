                subtype="historical-document" type="document" xml:id="d507">
                <note rend="inline" type="source">611.1731/72: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Dawson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1934-09-29T11:00:00-06:00"
                            >September 29, 1934—11 a.m.</date>
                        <lb/>[Received 2:20 p.m.]</dateline>
                </opener>
                <p>158. Yes. Congress will probably adjourn October 5th; next regular session starts
                    December 15th and lasts under constitution for 45 to 60 “meetings” (not
                    days).</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dawson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
