                subtype="historical-document" type="document" xml:id="d552">
                <note rend="inline" type="source">817.00/8072: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Lane</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1934-06-25T12:00:00-06:00"
                            >June 25, 1934—noon</date>.<lb/>[Received 1:55 p.m.]</dateline>
                </opener>
                <p>134. Statement as approved by the Department’s 38, June 23 [<hi rend="italic"
                        >24</hi>], 3 [<hi rend="italic">5</hi>] p.m., being released for publication
                    in the local press this evening.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lane</hi>
                    </signed>
                </closer>
            </div>
        </body>
