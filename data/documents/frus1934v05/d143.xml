<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-08-15T09:00:00-05:00" frus:doc-dateTime-min="1934-08-15T09:00:00-05:00" n="143" subtype="historical-document" type="document" xml:id="d143">
                        <note rend="inline" type="source">611.3731/906: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Cuba</hi> (<persName type="from"><hi rend="italic">Caffery</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Habana</hi></placeName>, <date calendar="gregorian" when="1934-08-15T09:00:00-05:00">August 15, 1934—9
                                a.m.</date><lb/>[Received 10:30 a.m.]</dateline>
                        </opener>
                        <p>393. Desire Department’s views on immediate reduction consular invoice
                            fee set forth in my telegram No. 380, August 10, noon.</p>
                        <closer><signed><hi rend="smallcaps">Caffery</hi></signed></closer>
                    </div>
