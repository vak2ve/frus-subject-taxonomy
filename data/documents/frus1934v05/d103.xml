                subtype="historical-document" type="document" xml:id="d103">
                <note rend="inline" type="source">837.01/70: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Personal Representative of the President</hi> (<persName type="to">
                        <hi rend="italic">Caffery</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-01-23">January 23,
                            1934</date>.</dateline>
                </opener>
                <p>15. Under authorization of the President you will please extend immediately to
                    the Government of Cuba on behalf of the United States a formal and cordial
                    recognition.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
