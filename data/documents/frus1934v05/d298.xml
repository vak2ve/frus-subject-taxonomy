                subtype="historical-document" type="document" xml:id="d298">
                <note rend="inline" type="source">611.1431/76: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Guatemala</hi> (<persName type="from">
                        <hi rend="italic">Hanna</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guatemala</hi>
                        </placeName>, <date calendar="gregorian" when="1934-09-29T12:00:00-06:00"
                            >September 29, 1934—noon</date>.<lb/>[Received 2:45 p.m.]</dateline>
                </opener>
                <p>62. Department’s telegram No. 58, September 28, 6 p.m.<note n="9"
                        xml:id="d298fn9">
                        <hi rend="italic">Post</hi>, <ref target="#pg_520">p. 520</ref>.</note> The
                    Minister for Foreign Affair’s has just told me that the agreement will go into
                    effect immediately on signature by President Ubico acting under his
                    extraordinary powers but must be submitted to the Legislative Assembly for
                    ratification when it convenes next March.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hanna</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
