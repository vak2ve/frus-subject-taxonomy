                subtype="historical-document" type="document" xml:id="d374">
                <note rend="inline" type="source">838.516/283: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Haiti</hi> (<persName type="from">
                        <hi rend="italic">Armour</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port-au-Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1934-05-12T13:00:00-05:00"
                            >May 12, 1934—1 p.m.</date>
                        <lb/>[Received 2:30 p.m.]</dateline>
                </opener>
                <p>44. Legation’s May 11, 1 p.m. Bank contract signed this morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Armour</hi>
                    </signed>
                </closer>
            </div>
        </body>
