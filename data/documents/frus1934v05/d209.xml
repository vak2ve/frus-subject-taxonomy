                subtype="historical-document" type="document" xml:id="d209">
                <note rend="inline" type="source">816.01/355: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Guatemala</hi> (<persName type="to">
                        <hi rend="italic">Lawton</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-01-15T13:00:00-05:00"
                            >January 15, 1934—1 p.m.</date>
                    </dateline>
                </opener>
                <p>3. Department’s telegram No. 1, January 12, 5 p.m. Please inform President Ubico
                    immediately that the Department is informed concerning President Sacasa’s plan,
                    is in sympathy with it, and hopes that President Ubico will agree to it.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
