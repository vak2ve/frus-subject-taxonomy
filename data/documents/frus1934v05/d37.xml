                subtype="historical-document" type="document" xml:id="d37">
                <note rend="inline" type="source">825.5151/234: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Chile</hi> (<persName type="to">
                        <hi rend="italic">Scotten</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-11-23T12:00:00-05:00"
                            >November 23, 1934—noon</date>.</dateline>
                </opener>
                <p>81. Your 108, November 21, noon. The Department is gratified that the Embassy has
                    succeeded in obtaining more favorable terms for the American interests involved
                    and expresses its appreciation of your efforts.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
