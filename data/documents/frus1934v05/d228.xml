    <text>
        <body>
            <div frus:doc-dateTime-max="1934-01-18T19:45:00-05:00"
                frus:doc-dateTime-min="1934-01-18T19:45:00-05:00" n="228"
                subtype="historical-document" type="document" xml:id="d228">
                <note rend="inline" type="source">816.01/378: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Lane</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1934-01-18T19:00:00-05:45"
                            >January 18, 1934—7 p.m.</date>
                        <lb/>[Received 9 p.m.]</dateline>
                </opener>
                <p>17. I have not communicated to Niearaguan Government information contained in
                    Lawton’s January 18, noon.<note n="20" xml:id="d228fn20">See last sentence of
                        telegram No. 3, <ref target="#pg_237">p. 237</ref>.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lane</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
