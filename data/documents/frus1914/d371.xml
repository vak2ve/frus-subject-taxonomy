                subtype="historical-document" type="document" xml:id="d371">
                <note rend="inline" type="source">File No. 339.41/3.</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Sullivan</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1914-05-13">
                            <hi rend="italic">May 13, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>British Chargé d’Affaires received cable that British railroad property is being
                    injured and asks protection by ship at Sanchez.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sullivan</hi>
                    </signed>.</closer>
            </div>
        </body>
