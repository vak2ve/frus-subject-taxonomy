<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-11-23T23:59:59-05:00" frus:doc-dateTime-min="1914-11-23T00:00:00-05:00" n="968" subtype="historical-document" type="document" xml:id="d968">
                        <note rend="inline" type="source">File No. 812.00/13875.</note>
                        <head>
                            <hi rend="italic">Consul <persName type="from">Bonney</persName> to the
                                    <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">San Luis Potosi</hi></placeName>, <date calendar="gregorian" when="1914-11-23">
                                    <hi rend="italic">November 23, 1914</hi></date>.</dateline>
                        </opener>
                        <p>San Luis Potosí is now the temporary capital of Mexico. Convention troops
                            have advanced easterly and southerly.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bonney</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>