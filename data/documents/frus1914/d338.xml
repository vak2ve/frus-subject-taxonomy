    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-28T22:00:00-05:00"
                frus:doc-dateTime-min="1914-08-28T22:00:00-05:00" n="338"
                subtype="historical-document" type="document" xml:id="d338">
                <note rend="inline" type="source">File No. 839.00/1498a.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Chargé
                            <persName type="to">White</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-08-28T22:00:00-05:00">
                            <hi rend="italic">August 28, 1914, 10 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>You will call upon the new Provisional President installed yesterday and present
                    the compliments and good wishes of this Government and enter into diplomatic
                    relations with him as Chief Executive of the Dominican Republic.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
