<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-01-19T23:59:59-05:00" frus:doc-dateTime-min="1914-01-19T00:00:00-05:00" n="1641" subtype="historical-document" type="document" xml:id="d1641">
                        <note rend="inline" type="source">File No. 511.4A1/1443.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Minister of the
                                    Netherlands</gloss> to the <gloss type="to">Secretary of
                                    State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#left">No. 1688.]</seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Legation of the Netherlands</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-01-19">
                                    <hi rend="italic">January 19, 1914</hi></date>.</dateline>
                        </opener>
                        <p>[Shows that the powers not yet signatories of the Convention of January
                            23, 1912, were, on December 31, 1913: Austria-Hungary, Bulgaria, Greece,
                            Serbia, Turkey and Uruguay.]</p>
                    </div>
