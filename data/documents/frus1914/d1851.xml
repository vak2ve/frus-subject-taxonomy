    <text>
        <body>
            <div frus:doc-dateTime-max="1914-01-02T23:59:59-05:00"
                frus:doc-dateTime-min="1914-01-02T00:00:00-05:00" n="1851"
                subtype="historical-document" type="document" xml:id="d1851">
                <note rend="inline" type="source">File No. 831.404/10.</note>
                <head>
                    <hi rend="italic">Chargé <persName type="from">Caffery</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 134.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Caracas</hi>
                        </placeName>, <date calendar="gregorian" when="1914-01-02">
                            <hi rend="italic">January 2, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: With reference to my despatch No. 99 of October
                    26, 1911, in regard to the extensions of the provisions of the law of
                    ecclesiastical patronage to foreign missionary societies, I have the honor to
                    enclose herewith copies of a letter<note n="1" xml:id="d1851fn1">Not
                        printed.</note> presented to me in triplicate by some of the American
                    missionaries established in Venezuela.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Jefferson Caffery</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
