    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-01T08:49:00-05:00"
                frus:doc-dateTime-min="1914-12-01T08:49:00-05:00" n="554"
                subtype="historical-document" type="document" xml:id="d554">
                <note rend="inline" type="source">File No. 838.00/1040.</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Blanchard</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Extract.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1914-12-01T09:00:00-04:49">
                            <hi rend="italic">December 1, 1914, 9 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>I respectfully request earliest possible instructions whether I am to negotiate
                    recognition of Theodore in conformity with instructions November 21, 7 p.m., or
                    November 24, 5 p.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blanchard</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
