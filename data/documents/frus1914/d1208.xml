<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-03-23T23:59:59-05:00" frus:doc-dateTime-min="1914-03-23T00:00:00-05:00" n="1208" subtype="historical-document" type="document" xml:id="d1208">
                        <note rend="inline" type="source">File No. 812.512/219.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Vice-Consul <persName type="to">Stadden</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-03-23">
                                    <hi rend="italic">March 23, 1914</hi></date>.</dateline>
                        </opener>
                        <p>Your March 19th. Advise American citizens to pay tax under protest,
                            making protest a matter of record if possible, and to take receipts.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>