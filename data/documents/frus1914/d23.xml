                subtype="historical-document" type="document" xml:id="d23">
                <note rend="inline" type="source">File No. 835.001/38a.</note>
                <head>
                    <hi rend="italic">Chargé <persName type="from">Lorillard</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1914-08-09">
                            <hi rend="italic">August 9, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>President of the Republic Saenz Pena died suddenly early this morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lorillard</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
