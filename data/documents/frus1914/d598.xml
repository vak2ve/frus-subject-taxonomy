                subtype="historical-document" type="document" xml:id="d598">
                <note rend="inline" type="source">File No. 838.00/1014.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Minister <persName type="to">Blanchard</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegrams.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-11-04">
                            <hi rend="italic">November 4, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>Your November 3. Action approved. You are authorized to take all necessary
                    measures for the protection of Charles Zamor and Cabinet.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>.</closer>
            </div>
        </body>
