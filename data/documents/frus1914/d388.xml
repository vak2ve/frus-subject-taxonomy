<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-02-14T18:00:00-05:00" frus:doc-dateTime-min="1914-02-14T18:00:00-05:00" n="388" subtype="historical-document" type="document" xml:id="d388">
                        <note rend="inline" type="source">File No. 822.00/351a.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Minister <persName type="to">Hartman</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-02-14T18:00:00-05:00">
                                    <hi rend="italic">February 14, 1914, 6 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Press reports revolutionary troops occupy Tulcan. Report briefly by
                            telegraph revolutionary situation and strength of Plaza’s
                            Government.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Moore</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>