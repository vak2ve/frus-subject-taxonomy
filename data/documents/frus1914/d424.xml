                subtype="historical-document" type="document" xml:id="d424">
                <note rend="inline" type="source">File No. 322.112J72.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                        General <persName type="to">Goding</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-03-09">
                            <hi rend="italic">March 9, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>Forward to the Legation and Department as soon as obtainable certified copy
                    evidence and brief of law Jones’ case.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
