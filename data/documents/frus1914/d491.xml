<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-01-23T23:59:59-05:00" frus:doc-dateTime-min="1914-01-23T00:00:00-05:00" n="491" subtype="historical-document" type="document" xml:id="d491">
                        <note rend="inline" type="source">File No. 838.00/762.</note>
                        <head>
                            <hi rend="italic">Consul <persName type="from">Livingston</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Cape Haitien</hi></placeName>, <date calendar="gregorian" when="1914-01-23">
                                    <hi rend="italic">January 23, 1914</hi></date>.</dateline>
                        </opener>
                        <p>Committee of Public Safety, named by revolution, has removed customs
                            officials and appointed commission. National Bank of Haiti protests to
                            Consulate.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Livingston</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>