<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-10-08T23:59:59-05:00" frus:doc-dateTime-min="1913-10-08T00:00:00-05:00" n="1275" subtype="historical-document" type="document" xml:id="d1275">
                        <note rend="inline" type="source">File No. 312.115/15.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Consul <persName type="to">Alger</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1913-10-08">
                                    <hi rend="italic">October 8, 1913</hi></date>.</dateline>
                        </opener>
                        <p>Your October 6th. Informally protest to Riveros against forced loan from
                            Rosario Mining Company.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Moore</hi></signed>.</closer>
                    </div>
