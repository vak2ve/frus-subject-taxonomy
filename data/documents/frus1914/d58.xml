    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-17T23:59:59-05:00"
                frus:doc-dateTime-min="1914-12-17T00:00:00-05:00" n="58"
                subtype="historical-document" type="document" xml:id="d58">
                <note rend="inline" type="source">File No. 893.03/10.</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Reinsch</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 471.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1914-12-17">
                            <hi rend="italic">December 17, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to transmit herewith a
                        translation,<note n="13" xml:id="d58fn13">Not printed.</note> as published
                    in the Peking Gazette of October 26, 27, 28 and 29, 1914, of the draft of the
                    law on the organization of the Li Fa Yuan—National Assembly of the Chinese
                    Republic. The first election of members to this body will take place during the
                    year 1915.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Paul S. Reinsch</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
