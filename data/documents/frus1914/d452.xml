<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-11-04T23:59:59-05:00" frus:doc-dateTime-min="1914-11-04T00:00:00-05:00" n="452" subtype="historical-document" type="document" xml:id="d452">
                        <note rend="inline" type="source">File No. 351.117/17.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Ambassador <persName type="to">Herrick</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-11-04">
                                    <hi rend="italic">November 4, 1914</hi></date>.</dateline>
                        </opener>
                        <p>233. Your 231, October 28. Did Chandeysson voluntarily enlist in the
                            French Army? If not, ask for release on the ground of American
                            citizenship.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>