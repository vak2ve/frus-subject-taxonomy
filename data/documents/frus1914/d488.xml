    <text>
        <body>
            <div frus:doc-dateTime-max="1914-01-21T23:59:59-05:00"
                frus:doc-dateTime-min="1914-01-21T00:00:00-05:00" n="488"
                subtype="historical-document" type="document" xml:id="d488">
                <note rend="inline" type="source">File No. 838.00/747.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Smith</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-01-21">
                            <hi rend="italic">January 21, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>In view of the situation, <hi rend="italic">Nashville</hi> ordered to proceed to
                    Cape Haitien for protection of American interests. Keep Department informed as
                    to situation at Port au Prince.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
