<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-10-18T19:41:00-05:00" frus:doc-dateTime-min="1914-10-18T19:41:00-05:00" n="933" subtype="historical-document" type="document" xml:id="d933">
                        <note rend="inline" type="source">File No. 812.00/13531.</note>
                        <head>
                            <hi rend="italic">Special Agent <persName type="from">Carothers</persName> to the <gloss type="to">Secretary of
                                    State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Guadalupe</hi></placeName>, <date calendar="gregorian" when="1914-10-18T18:00:00-06:41">
                                    <hi rend="italic">October 18, 1914, 6 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>General Villa authorized me this afternoon to inform Department of State
                            that he will support any provisional president that may be selected by
                            the Convention except Carranza.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Carothers</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>