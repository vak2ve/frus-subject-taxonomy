    <text>
        <body>
            <div frus:doc-dateTime-max="1914-11-09T23:59:59-05:00"
                frus:doc-dateTime-min="1914-11-09T00:00:00-05:00" n="1331"
                subtype="historical-document" type="document" xml:id="d1331">
                <note rend="inline" type="source">File No. 312.115/106.</note>
                <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                <opener>
                    <seg rendition="#center">[Extract.]</seg>
                </opener>
                <opener>
                    <seg rendition="#left">No. 532.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Consulate</hi>, <lb/>
                            <hi rend="italic">Guadalajara</hi>
                        </placeName>, <date calendar="gregorian" when="1914-11-09">
                            <hi rend="italic">November 9, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>:* * * I have the honor to say that this company
                    [Compañía Galletera Nacional] has been advised direct from the tax office, that
                    the forced loan imposed upon them has been abrogated.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Will B. Davis</hi>
                    </signed>.</closer>
            </div>
        </body>
