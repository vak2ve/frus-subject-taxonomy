                <note rend="inline" type="source">File No. 422.11G93/737.</note>
                <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Quito</hi>
                        </placeName>, <date calendar="gregorian" when="1914-02-01">
                            <hi rend="italic">February 1, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>Arbitrators have failed absolutely to agree, and Judge Miller leaves for home
                    February 4.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hartman</hi>
                    </signed>.</closer>
            </div>
