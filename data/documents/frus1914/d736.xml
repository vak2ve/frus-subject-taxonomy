<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-04-26T23:59:59-05:00" frus:doc-dateTime-min="1914-04-26T00:00:00-05:00" n="736" subtype="historical-document" type="document" xml:id="d736">
                        <note rend="inline" type="source">File No. 812.00/11744c.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                    <gloss type="to">American diplomatic missions</gloss>.</hi><note n="19" xml:id="d736fn19">Sent to all missions in America and Europe
                                and to Japan and China.</note>
                        </head>
                        <opener>
                            <seg rendition="#center">[Circular telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-04-26">
                                    <hi rend="italic">April 26, 1914</hi></date>.</dateline>
                        </opener>
                        <p>Please communicate to the Foreign Office the following note from
                            Ambassador of Brazil and Ministers of Argentina and Chile, together with
                            the President’s reply through the Secretary of State.</p>
                        <p>[Texts of the note of April 25 and the reply.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>