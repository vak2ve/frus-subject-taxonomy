<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-05-16T23:59:59-05:00" frus:doc-dateTime-min="1914-05-16T00:00:00-05:00" n="760" subtype="historical-document" type="document" xml:id="d760">
                        <note rend="inline" type="source">File No. 812.00/12001a.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                    <persName type="to">H. Percival Dodge</persName>, Esquire.</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-05-16">
                                    <hi rend="italic">May 16, 1914</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: You are hereby designated Secretary to
                            the Special Commission of the President of the United States near the
                            Mediators in the conferences to be held at Niagara Falls, Ontario.</p>
                        <p>I am [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">W. J. Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>