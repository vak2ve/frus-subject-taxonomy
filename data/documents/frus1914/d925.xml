                subtype="historical-document" type="document" xml:id="d925">
                <note rend="inline" type="source">File No. 812.00/13384.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Brazilian Minister</gloss> to Mexico.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-10-01T19:00:00-05:00">
                            <hi rend="italic">October 1, 1914, 7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>267. Department anxiously awaiting reply to its September 22 with reference to
                    guaranties against the exaction of further import duties, municipal taxes, etc.,
                    upon American evacuation of Vera Cruz.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. J. Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
