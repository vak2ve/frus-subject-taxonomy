                subtype="historical-document" type="document" xml:id="d1110">
                <note rend="inline" type="source">File No. 312.11/5139.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Vice
                        Consul <persName type="to">Bevan</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-09-03">
                            <hi rend="italic">September 3, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>Your August 31. Your refusal to extend financial assistance to Americans who have
                    returned to Tampico since April is approved. This information has been given to
                    the press as suggested.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
