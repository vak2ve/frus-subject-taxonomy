<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-14T23:59:59-05:00" frus:doc-dateTime-min="1914-08-14T00:00:00-05:00" n="877" subtype="historical-document" type="document" xml:id="d877">
                        <note rend="inline" type="source">File No. 812.00/12847.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">Brazilian Minister</gloss> to Mexico.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-08-14">
                                    <hi rend="italic">August 14, 1914</hi></date>.</dateline>
                        </opener>
                        <p>207. Your 126. Agreement satisfactory. Peaceful transfer of power is
                            assured. The President appreciates the ability with which you have
                            handled this matter. Again accept our thanks.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">W. J. Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>