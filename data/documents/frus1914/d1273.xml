<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-10-01T23:59:59-05:00" frus:doc-dateTime-min="1913-09-24T00:00:00-05:00" n="1273" subtype="historical-document" type="document" xml:id="d1273">
                        <note rend="inline" type="source">File No. 812.00/9031.</note>
                        <head>
                            <hi rend="italic">Chargé <persName type="from">O’Shaughnessy</persName>
                                to the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Extract.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                                    <hi rend="italic">Mexico City</hi>
                                </placeName> (<date ana="#date_undated-inferred-from-document-content-and-sibling-dates" calendar="gregorian" notAfter="1913-10-01T23:59:59-05:00" notBefore="1913-09-24T00:00:00-05:00"><hi rend="italic">undated</hi></date><hi rend="italic">; received October 1,
                                    1913</hi>).</dateline>
                        </opener>
                        <p>523.* * * A movement is on foot to raise a loan from the great petroleum
                            interests under threat of the national expropriation of all petroleum
                            bearing lands within the United Mexican States.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Nelson O’Shaughnessy</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>