<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-06-15T23:59:59-05:00" frus:doc-dateTime-min="1914-06-15T00:00:00-05:00" n="1216" subtype="historical-document" type="document" xml:id="d1216">
                        <note rend="inline" type="source">File No. 812.6363/91.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Consul <persName type="to">Miller</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-06-15">
                                    <hi rend="italic">June 15, 1914</hi></date>.</dateline>
                        </opener>
                        <p>Your June 3, 8 p.m. In order to safeguard their possible future
                            interests, American citizens should be advised to pay oil production
                            taxes under protest.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>