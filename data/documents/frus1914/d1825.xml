<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-06-30T23:59:59-05:00" frus:doc-dateTime-min="1914-06-30T00:00:00-05:00" n="1825" subtype="historical-document" type="document" xml:id="d1825">
                        <note rend="inline" type="source">File No. 816.00/192.</note>
                        <head>
                            <hi rend="italic">Chargé <persName type="from">Tennant</persName> to the
                                    <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#left">No. 364.]</seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">San Salvador</hi></placeName>, <date calendar="gregorian" when="1914-06-30">
                                    <hi rend="italic">June 30, 1914</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to transmit herewith a
                            copy and translation of a clipping from the <hi rend="italic">Diario de
                                El Salvador</hi>, of a report of the Committee on Powers and Excuses
                            of the National Legislative Assembly of Salvador,<note n="3" xml:id="d1825fn3">Not printed.</note> relative to the request of the
                            President of Salvador, don Carlos Melendez, for permission to resign the
                            Presidency of the Republic in order to comply with the Constitution and
                            legally become candidate for the Presidency for the ensuing term of four
                            years.</p>
                        <p>I have [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Henry F. Tennant</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>