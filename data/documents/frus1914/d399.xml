<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-03-23T23:59:59-05:00" frus:doc-dateTime-min="1914-03-23T00:00:00-05:00" n="399" subtype="historical-document" type="document" xml:id="d399">
                        <note rend="inline" type="source">File No. 822.00/374.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Consul General <persName type="to">Goding</persName>.</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-03-23">
                                    <hi rend="italic">March 23, 1914</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: The Department has received your despatch
                            No. 17 of February 12, 1914, with regard to the revolutionary situation
                            in Esmeraldas.</p>
                        <p>The Department has been fully informed regarding the revolutionary
                            movement in question,</p>
                        <p>I am [etc.]</p>
                        <closer>For the Secretary of State: <lb/>
                            <signed>
                                <hi rend="smallcaps">Wilbur J. Carr</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>