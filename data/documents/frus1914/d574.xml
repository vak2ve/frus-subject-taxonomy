<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-12-21T08:49:00-05:00" frus:doc-dateTime-min="1914-12-21T08:49:00-05:00" n="574" subtype="historical-document" type="document" xml:id="d574">
                        <note rend="inline" type="source">File No. 838.00/1068.</note>
                        <head>
                            <hi rend="italic">Minister <persName type="from">Blanchard</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Port au Prince</hi></placeName>, <date calendar="gregorian" when="1914-12-21T09:00:00-04:49">
                                    <hi rend="italic">December 21, 1914, 9 a.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>My telegram December 15, 11 p.m. Instructions your December 12, 5 p.m.
                            complied with verbally morning of December 17 and in writing on the 19th
                            upon request of Minister of Foreign Affairs.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Blanchard</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>