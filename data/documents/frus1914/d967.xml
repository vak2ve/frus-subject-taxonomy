<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-11-23T14:36:00-05:00" frus:doc-dateTime-min="1914-11-23T14:36:00-05:00" n="967" subtype="historical-document" type="document" xml:id="d967">
                        <note rend="inline" type="source">File No. 812.00/13872.</note>
                        <head>
                            <hi rend="italic">Consul <persName type="from">Canada</persName> to the
                                    <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Vera Cruz</hi></placeName>, <date calendar="gregorian" when="1914-11-23T13:00:00-06:36">
                                    <hi rend="italic">November 23, 1914, 1 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Transports have left harbor. No friction between American and
                            Constitutionalist troops.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Canada</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>