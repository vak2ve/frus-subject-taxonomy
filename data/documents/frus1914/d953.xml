<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-11-10T20:36:00-05:00" frus:doc-dateTime-min="1914-11-10T20:36:00-05:00" n="953" subtype="historical-document" type="document" xml:id="d953">
                        <note rend="inline" type="source">File No. 812.00/13741.</note>
                        <head>
                            <hi rend="italic">Special Agent <persName type="from">Canova</persName>
                                to the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Extract.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Aguascalientes</hi></placeName>, <date calendar="gregorian" when="1914-11-10T19:00:00-06:36">
                                    <hi rend="italic">November 10, 1914, 7 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>The Convention has just declared Carranza in rebellion.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Canova</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>