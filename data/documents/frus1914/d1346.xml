                subtype="historical-document" type="document" xml:id="d1346">
                <note rend="inline" type="source">File No. 312/52/110.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                            <persName type="to">Alger</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-01-14">
                            <hi rend="italic">January 14, 1914</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your telegram January 9. Department’s December 18 intended to instruct you to
                    extend same protection to other foreigners as to Americans,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
