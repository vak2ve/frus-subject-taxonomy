                subtype="historical-document" type="document" xml:id="d564">
                <note rend="inline" type="source">File No. 838.516/13.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Blanchard</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-12-10T13:00:00-05:00">
                            <hi rend="italic">December 10, 1914, 1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Please transmit following telegram to National Bank of the Republic of Haiti:</p>
                <p>[Telegram quoted in above telegram.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
