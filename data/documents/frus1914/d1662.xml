    <text>
        <body>
            <div frus:doc-dateTime-max="1914-09-18T23:59:59-05:00"
                frus:doc-dateTime-min="1914-09-18T00:00:00-05:00" n="1662"
                subtype="historical-document" type="document" xml:id="d1662">
                <note rend="inline" type="source">File No. 817.00/2347.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Minister <persName type="to">Jefferson</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-09-18">
                            <hi rend="italic">September 18, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has received and has read with
                    interest your No. 109 of August 19, 1914, reporting in regard to the alleged
                    participation of one Clifford D. Sands, an American citizen, in an unsuccessful
                    attack on the police barracks at Bluefields.</p>
                <p>You will keep the Department advised with regard to this case.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
