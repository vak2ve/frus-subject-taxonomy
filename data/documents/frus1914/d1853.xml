<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-04-16T23:59:59-05:00" frus:doc-dateTime-min="1914-04-16T00:00:00-05:00" n="1853" subtype="historical-document" type="document" xml:id="d1853">
                        <note rend="inline" type="source">File No. 831.404/13a.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">McGoodwin</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-04-16">
                                    <hi rend="italic">April 16, 1914</hi></date>.</dateline>
                        </opener>
                        <p>You will please express the interest of the Government of the United
                            States in obtaining permission for American clergymen to exercise the
                            ministry in the Republic of Venezuela and the introduction of this
                            measure into the revised Constitution.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>