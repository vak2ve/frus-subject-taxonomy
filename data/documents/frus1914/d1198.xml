<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-02-24T23:59:59-05:00" frus:doc-dateTime-min="1914-02-24T00:00:00-05:00" n="1198" subtype="historical-document" type="document" xml:id="d1198">
                        <note rend="inline" type="source">File No. 812.512/189.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Vice Consul <persName type="to">Stadden</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-02-24">
                                    <hi rend="italic">February 24, 1914</hi></date>.</dateline>
                        </opener>
                        <p>Your February 21. If attempt is made to impose war tax on American
                            citizens, you will make formal protest.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>