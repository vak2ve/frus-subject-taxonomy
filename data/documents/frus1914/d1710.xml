<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-05-19T23:59:59-05:00" frus:doc-dateTime-min="1914-05-19T00:00:00-05:00" n="1710" subtype="historical-document" type="document" xml:id="d1710">
                        <note rend="inline" type="source">File No. 850d.00/265b.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Schmedeman</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-05-19">
                                    <hi rend="italic">May 19, 1914</hi></date>.</dateline>
                        </opener>
                        <p>Inform Foreign Office Department has appointed Fred K. Nielsen, Assistant
                            Solicitor of this Department, as its technical delegate to assist
                            delegates of this Government at the Spitzbergen Conference.<note n="2" xml:id="d1710fn2">Mr. Nielsen was later appointed plenipotentiary
                                delegate.</note>
                        </p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>