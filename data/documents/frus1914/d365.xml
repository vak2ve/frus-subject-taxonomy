    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-10T23:59:59-05:00"
                frus:doc-dateTime-min="1914-12-10T00:00:00-05:00" n="365"
                subtype="historical-document" type="document" xml:id="d365">
                <note rend="inline" type="source">File No. 839.001B14/1.</note>
                <head>
                    <hi rend="italic">Ex-President <persName type="from">Báez</persName> to
                        President <persName type="to">Wilson</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santo Domingo</hi>
                        </placeName>, <lb/>
                        <date calendar="gregorian" when="1914-12-10">
                            <hi rend="italic">December 10, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>My patriotic aspiration was fulfilled with free suffrage and lawful transfer of
                    power. I thankfully acknowledge your honoring congratulations and take pleasure
                    in offering to you the assurance of my highest personal esteem.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Doctor Báez</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
