<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-05-12T23:59:59-05:00" frus:doc-dateTime-min="1914-05-12T00:00:00-05:00" n="1645" subtype="historical-document" type="document" xml:id="d1645">
                        <note rend="inline" type="source">File No. 511.4A1/1469.</note>
                        <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                        <opener>
                            <seg rendition="#left">No. 2424.]</seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Legation of the Netherlands</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-05-12">
                                    <hi rend="italic">May 12, 1914</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Mr. Secretary of State</hi>: Referring to your
                            communication of the 19th [18th] of April last, I have the honor of
                            bringing to your attention the fact that it appears from a telegram
                            which I have just received from my Government that the Opium Conference
                            will meet at The Hague on the 15th of next June.</p>
                        <p>Accept [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">W. L. F. C. de Rappard</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>