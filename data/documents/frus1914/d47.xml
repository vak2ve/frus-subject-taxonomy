<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-12-15T23:59:59-05:00" frus:doc-dateTime-min="1914-12-15T00:00:00-05:00" n="47" subtype="historical-document" type="document" xml:id="d47">
                        <note rend="inline" type="source">File No. 701.7411/11.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Appointed Bulgarian
                                    Minister</gloss> to the <gloss type="to">Secretary of
                                    State</gloss>.</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>1761 <hi rend="smallcaps">N Street</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-12-15">
                                    <hi rend="italic">Dec. 15, 1914</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: Having recently arrived to take
                            possession of the post to which I have been appointed by His Majesty the
                            King of the Bulgarians, I will be greatly obliged to you if you will
                            kindly grant me an audience at a time most convenient to you.</p>
                        <p>I have [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Stephan Panaretoff</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>