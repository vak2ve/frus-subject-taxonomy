<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-05-15T23:59:59-05:00" frus:doc-dateTime-min="1914-05-15T00:00:00-05:00" n="759" subtype="historical-document" type="document" xml:id="d759">
                        <note rend="inline" type="source">File No. 812.00/12019.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Spanish Ambassador</gloss> to
                                the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Spanish Embassy</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-05-15">
                                    <hi rend="italic">May 15, 1914</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Mr. Secretary</hi>: I have the honor to inform your
                            excellency that the Minister of Foreign Relations of Mexico has asked me
                            to telegraph to express in his name the most earnest thanks to the
                            Government of the United States for the attentions shown to the members
                            of the Mexican delegation on their arrival in the territory of the
                            Union.</p>
                        <p>I avail [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Juan Riaño</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>