<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-02-17T23:59:59-05:00" frus:doc-dateTime-min="1914-02-17T00:00:00-05:00" n="595" subtype="historical-document" type="document" xml:id="d595">
                        <note rend="inline" type="source">File No. 838.00/846.</note>
                        <head>
                            <hi rend="italic">Consul <persName type="from">Livingston</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Cape Haitien</hi></placeName>, <date calendar="gregorian" when="1914-02-17">
                                    <hi rend="italic">February 17, 1914</hi></date>.</dateline>
                        </opener>
                        <p>Wife of Charles Zamor with four children under twelve years wish to come
                            into Consulate in case of necessity.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Livingston</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>