<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-07-27T23:59:59-05:00" frus:doc-dateTime-min="1914-07-27T00:00:00-05:00" n="843" subtype="historical-document" type="document" xml:id="d843">
                        <note rend="inline" type="source">File No. 812.00/12612.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">Brazilian Minister</gloss> to Mexico.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-07-27">
                                    <hi rend="italic">July 27, 1914</hi></date>.</dateline>
                        </opener>
                        <p>181. Substance your 98, July 26, has been communicated to Vice Consul
                            Silliman at Tampico, with appropriate instructions to convey same to
                            General Carranza.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">W. J. Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>