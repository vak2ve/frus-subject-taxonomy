<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-11-30T23:59:59-05:00" frus:doc-dateTime-min="1914-11-30T00:00:00-05:00" n="190" subtype="historical-document" type="document" xml:id="d190">
                        <note rend="inline" type="source">File No. 817.00/2380.</note>
                        <head>
                            <hi rend="italic">Minister <persName type="from">Hale</persName> to the
                                    <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Extract.]</seg>
                        </opener>
                        <opener>
                            <seg rendition="#left">No. 47.]</seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">San José</hi></placeName>, <date calendar="gregorian" when="1914-11-30">
                                    <hi rend="italic">November 30, 1914</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to report that * *
                            *Julian Irias, well known to the Department, and half a dozen “Generals
                            “of, or connected with the affairs of, Nicaragua have been conferring
                            here a good deal in the last few days. * * *</p>
                        <p>I have [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">E. J. Hale</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>