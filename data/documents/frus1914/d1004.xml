    <text>
        <body>
            <div frus:doc-dateTime-max="1914-05-27T23:59:59-05:00"
                frus:doc-dateTime-min="1914-05-27T00:00:00-05:00" n="1004"
                subtype="historical-document" type="document" xml:id="d1004">
                <note rend="inline" type="source">File No. 703.3212/11.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Brazilian Chargé d’Affaires</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-05-27">
                            <hi rend="italic">May 27, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to enclose herewith for the
                    Embassy’s information a copy of a telegram from the President of the American
                        <pb facs="0762" n="646" xml:id="pg_646"/> Colony in Mexico City, informing
                    the Department of a vote of thanks tendered to the Brazilian Minister by the
                    members of the American Colony for his services to Americans.</p>
                <p>Accept [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
