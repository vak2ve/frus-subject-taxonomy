                subtype="historical-document" type="document" xml:id="d520">
                <note rend="inline" type="source">File No. 838.00/935.</note>
                <head>
                    <hi rend="italic">Consul <persName type="from">Livingston</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Consulate</hi>, <lb/>
                            <hi rend="italic">Cape Haitien</hi>
                        </placeName>, <date calendar="gregorian" when="1914-06-19">
                            <hi rend="italic">June 19, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>Revolutionists interfering with operations of railroad, whole line in their
                    possession, train overdue, wires cut and handcar fired on. Warship
                    necessary.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Livingston</hi>
                    </signed>.</closer>
            </div>
        </body>
