    <text>
        <body>
            <div frus:doc-dateTime-max="1914-04-22T23:59:59-05:00"
                frus:doc-dateTime-min="1914-04-22T00:00:00-05:00" n="721"
                subtype="historical-document" type="document" xml:id="d721">
                <note rend="inline" type="source">File No. 812.00/11744a.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Bolivian Minister</gloss>.</hi>
                    <note n="16" xml:id="d721fn16">The same to the diplomatic representatives of
                        China, Colombia, Costa Rica, Cuba, Dominican Republic, Ecuador, Guatemala,
                        Haiti, Honduras, Japan, Nicaragua, Panama, Paraguay, Persia, Peru, Salvador,
                        Siam, Uruguay, and Venezuela.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-04-22">
                            <hi rend="italic">April 22, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to enclose herewith for your
                    information a copy of the address delivered by the President to Congress on
                    April 20, 1914, regarding the situation which has arisen in the dealings of the
                    United States with General Victoriano Huerta at Mexico City.</p>
                <p>Accept [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
