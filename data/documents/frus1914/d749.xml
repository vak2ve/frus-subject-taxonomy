                subtype="historical-document" type="document" xml:id="d749">
                <note rend="inline" type="source">File No. 812.00/11802a.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to <gloss
                            type="to">American diplomatic officers</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Circular telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-05-02">
                            <hi rend="italic">May 2, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>The Mediators have submitted to the United States Government, and are submitting
                    to Huerta and Carranza, requests that representatives be appointed by each to
                    confer with the Mediators.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
