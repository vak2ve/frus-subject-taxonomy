                subtype="historical-document" type="document" xml:id="d1570">
                <note rend="inline" type="source">File No. 312.62/40.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Chargé <persName type="to">O’Shaughnessy</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-01-10T19:00:00-05:00">
                            <hi rend="italic">January 10, 1914, 7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your 720, January 9th. Navy Department has sent appropriate instructions to
                    Admiral Cowles regarding situation at Tepic.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Moore</hi>
                    </signed>.</closer>
            </div>
        </body>
