<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-11-24T13:49:00-05:00" frus:doc-dateTime-min="1914-11-24T13:49:00-05:00" n="549" subtype="historical-document" type="document" xml:id="d549">
                        <note rend="inline" type="source">File No. 838.002/31.</note>
                        <head>
                            <hi rend="italic">Minister <persName type="from">Blanchard</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Port au Prince</hi></placeName>, <date calendar="gregorian" when="1914-11-24T14:00:00-04:49">
                                    <hi rend="italic">November 24, 1914, 2 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Bill introduced in Chamber of Deputies for the issue of 16,000,000
                            gourdes, paper currency.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Blanchard</hi></signed>.</closer>
                    </div>
