    <text>
        <body>
            <div frus:doc-dateTime-max="1914-07-25T23:59:59-05:00"
                frus:doc-dateTime-min="1914-07-25T00:00:00-05:00" n="15"
                subtype="historical-document" type="document" xml:id="d15">
                <note rend="inline" type="source">File No. 811f.812/589a.</note>
                <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-07-25">
                            <hi rend="italic">July 25, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="italic">To the American Consular Officers including Consular
                        Agents</hi>.</p>
                <p>
                    <hi rend="smallcaps">Gentlemen</hi>: There is being forwarded to your office
                    under separate cover a copy of the Executive order of July 9, 1914, prescribing
                    the rules and regulations for the operation and navigation of the Panama Canal
                    and approaches thereto including all waters under its jurisdiction.<note n="7"
                        xml:id="d15fn7">Not printed.</note>
                </p>
                <p>You should bring the provisions of this order to the attention of all interested
                    persons in your consular jurisdiction.</p>
                <p>I am [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <hi rend="smallcaps">Wilbur J. Carr</hi>
                    </signed>.</closer>
            </div>
        </body>
