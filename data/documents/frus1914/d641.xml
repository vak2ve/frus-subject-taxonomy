    <text>
        <body>
            <div frus:doc-dateTime-max="1914-04-01T23:59:59-05:00"
                frus:doc-dateTime-min="1914-04-01T00:00:00-05:00" n="641"
                subtype="historical-document" type="document" xml:id="d641">
                <note rend="inline" type="source">File No. 895.102/19.</note>
                <head>
                    <hi rend="italic">Consul General <persName type="from">Miller</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Consulate General</hi>, <lb/>
                            <hi rend="italic">Seoul</hi>
                        </placeName>, <date calendar="gregorian" when="1914-04-01">
                            <hi rend="italic">April 1, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>Foreign settlements abolished from to-day.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Miller</hi>
                    </signed>.</closer>
            </div>
        </body>
