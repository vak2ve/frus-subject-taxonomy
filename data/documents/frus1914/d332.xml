                subtype="historical-document" type="document" xml:id="d332">
                <note rend="inline" type="source">File No. 839.00/1476a.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Gonzales</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-08-13T18:00:00-05:00">
                            <hi rend="italic">August 13, 1914, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>For Commission proceeding to Santo Domingo: <quote rend="blockquote">
                        <p>You are instructed to observe and follow out with utmost care plan which
                            has been presented you by the Secretary of State. No opportunity for
                            argument should be given to any person or faction. It is desired that
                            you present plan and see that it is complied with.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
