    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-18T09:49:00-05:00"
                frus:doc-dateTime-min="1914-12-18T09:49:00-05:00" n="572"
                subtype="historical-document" type="document" xml:id="d572">
                <note rend="inline" type="source">File No. 838.516/23.</note>
                <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1914-12-18T10:00:00-04:49">
                            <hi rend="italic">December 18, 1914, 10 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your December 15, 6 p.m. Gold embarked yesterday <hi rend="italic">Machias</hi>
                    by unarmed marines. No disturbance. <hi rend="italic">Machias</hi> sailed at two
                    and <hi rend="italic">Hancock</hi> at five p.m. <hi rend="italic">Wheeling</hi>
                    in port.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blanchard</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
