<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-04-11T23:59:59-05:00" frus:doc-dateTime-min="1914-04-11T00:00:00-05:00" n="75" subtype="historical-document" type="document" xml:id="d75">
                        <note rend="inline" type="source">File No. 493.11/494.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">Charge d’Affaires of China</gloss>.</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-04-11">
                                    <hi rend="italic">April 11, 1914</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I beg to enclose herewith check for
                            $45,147.97, drawn on the Treasury of the United States and payable to
                            your order as Charge d’Affaires of China. The amount named represents
                            the portion of the January 1914 indemnity payment refundable to China,
                            as shown by the Treasury Department’s letter<note n="25" xml:id="d75fn25">Not printed.</note> on the subject, copy of which
                            is enclosed herewith.</p>
                        <p>Accept [etc.]</p>
                        <closer>For the Secretary of State: <lb/>
                            <signed>
                                <hi rend="smallcaps">Robert Lansing</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>