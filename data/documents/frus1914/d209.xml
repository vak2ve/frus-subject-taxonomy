                subtype="historical-document" type="document" xml:id="d209">
                <note rend="inline" type="source">File No. 837.13/30.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> of Minister
                            <persName type="to">Gonzales</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washing ton</hi>
                        </placeName>, <date calendar="gregorian" when="1914-12-04">
                            <hi rend="italic">December 4, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>Your November 27. Department has no especial interest in this case.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
