    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-01T23:59:59-05:00"
                frus:doc-dateTime-min="1914-12-01T00:00:00-05:00" n="45"
                subtype="historical-document" type="document" xml:id="d45">
                <note rend="inline" type="source">File No. 701.7411/8.</note>
                <head>
                    <hi rend="italic">Consul General <persName type="from">Rockhill</persName> to
                        the <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Consulate General of Bulgaria</hi>, <lb/>
                            <hi rend="italic">New York</hi>
                        </placeName>, <date calendar="gregorian" when="1914-12-01">
                            <hi rend="italic">December 1, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honour to inform you that Mr. Stephan
                    Panaretoff, the newly appointed Minister from Bulgaria to Washington, is
                    expected to arrive at New York on the steamship <hi rend="italic"
                    >Kroonland</hi>, due the fourth instant.</p>
                <p>Through the courtesy of the collector of the port of New York I have arranged to
                    meet Mr. Panaretoff on arrival of the steamer at quarantine; should you desire
                    me to convey any message to the Minister, kindly command me.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Clayton Rockhill</hi>
                    </signed>.</closer>
            </div>
        </body>
