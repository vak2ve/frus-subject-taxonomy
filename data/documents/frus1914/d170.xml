<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-06-24T23:59:59-05:00" frus:doc-dateTime-min="1914-06-24T00:00:00-05:00" n="170" subtype="historical-document" type="document" xml:id="d170">
                        <note rend="inline" type="source">File No. 711.21/277.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Thomson</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#left">No. 26.]</seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-06-24">
                                    <hi rend="italic">June 24, 1914</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: The Department has received your telegram
                            of June 17, 3 p.m.</p>
                        <p>The Department will be glad to be promptly advised when any formal
                            arrangements shall be proposed for spending the amount stipulated for
                            payment by the United States in the pending treaty between the United
                            States and Colombia.</p>
                        <p>I am [etc.]</p>
                        <closer>For the Secretary of State: <lb/>
                            <signed>
                                <hi rend="smallcaps">Robert Lansing</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>