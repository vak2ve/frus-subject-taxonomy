<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-10-17T23:59:59-05:00" frus:doc-dateTime-min="1914-10-17T00:00:00-05:00" n="1327" subtype="historical-document" type="document" xml:id="d1327">
                        <note rend="inline" type="source">File No. 312.115/100.</note>
                        <head>
                            <hi rend="italic">Vice Consul <persName type="from">Davis</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Guadalajara</hi></placeName>, <date calendar="gregorian" when="1914-10-17">
                                    <hi rend="italic">October 17, 1914</hi></date>.</dateline>
                        </opener>
                        <p>Government threatening attachment Compañía Galletera Nacional,
                            notwithstanding my formal protest. See my dispatch 508, September 10,
                            and instruct.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Davis</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>