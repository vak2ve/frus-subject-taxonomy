<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-03-14T23:59:59-05:00" frus:doc-dateTime-min="1914-03-14T00:00:00-05:00" n="1515" subtype="historical-document" type="document" xml:id="d1515">
                            <note rend="inline" type="source">File No. 812.00/11151.</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the <gloss type="to">Italian Ambassador</gloss>.</hi><note n="137" xml:id="d1515fn137">The same to the Embassies of
                                    Austria-Hungary, France, Germany, Great Britain, Japan and
                                    Spain.</note>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Department of State</hi>, <lb/>
                                        <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-03-14">
                                        <hi rend="italic">March 14, 1914</hi></date>.</dateline>
                            </opener>
                            <p>
                                <hi rend="smallcaps">My Dear Mr. Ambassador</hi>: I take pleasure in
                                enclosing for your information a copy of a communication from
                                General Carranza, received through our Consul at Nogales
                                yesterday.</p>
                            <p>Assuring you [etc.]</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">W. J. Bryan</hi></signed>.</closer>
                        </div>
                        </body></text></TEI>