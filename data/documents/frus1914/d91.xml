                subtype="historical-document" type="document" xml:id="d91">
                <note rend="inline" type="source">File No. 493.11/512.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Chargé
                            <persName type="to">MacMurray</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-08-11">
                            <hi rend="italic">August 11, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department is in receipt of the Legation’s
                    despatch No. 299 of July 8, 1914, enclosing report of Mr. C. L. L. Williams on
                    the status of the claims arising out of the revolution of 1911.</p>
                <p>The Department regards Mr. Williams as deserving of commendation for his
                    excellent work as claims delegate.</p>
                <p>I am [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>.</closer>
            </div>
        </body>
