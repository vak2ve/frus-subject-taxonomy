<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-04-30T23:59:59-05:00" frus:doc-dateTime-min="1913-04-30T00:00:00-05:00" n="1196" subtype="historical-document" type="document" xml:id="d1196">
                        <note rend="inline" type="source">File No. 812.512/19.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Vice Consul <persName type="to">Bowman</persName>.</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1913-04-30">
                                    <hi rend="italic">April 30, 1913</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: The Department has received your despatch
                            No. 230 of April 12, 1913, with regard to the payment of taxes on mining
                            claims in Sonora owned by Americans.</p>
                        <p>In this connection your attention is referred to the Department’s
                            telegram of April 26, 1913, [to Vice Consul Simpich] upon the
                            subject.</p>
                        <p>I am [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Wilbur J. Carr</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>