<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-06T12:40:00-05:00" frus:doc-dateTime-min="1914-08-06T12:40:00-05:00" n="331" subtype="historical-document" type="document" xml:id="d331">
                        <note rend="inline" type="source">File No. 839.00/1460.</note>
                        <head>
                            <hi rend="italic">Consul <persName type="from">Henry</persName> to the
                                    <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Puerto Plata</hi></placeName>, <date calendar="gregorian" when="1914-08-06T13:00:00-04:40">
                                    <hi rend="italic">August 6, 1914, 1 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>General armistice for fifteen days just signed, taking effect six
                            tonight.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Henry</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>