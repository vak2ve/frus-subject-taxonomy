<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-03-09T23:59:59-05:00" frus:doc-dateTime-min="1914-03-09T00:00:00-05:00" n="1200" subtype="historical-document" type="document" xml:id="d1200">
                        <note rend="inline" type="source">File No. 812.512/205.</note>
                        <head>
                            <hi rend="italic">Consul <persName type="from">Alger</persName> to the
                                    <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Mazatlan</hi></placeName>, <date calendar="gregorian" when="1914-03-09">
                                    <hi rend="italic">March 9, 1914</hi></date>.</dateline>
                        </opener>
                        <p>Constitutionalists continue collection mining taxes from Americans
                            although same have been paid to Federals.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Alger</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>