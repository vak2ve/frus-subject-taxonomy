                subtype="historical-document" type="document" xml:id="d991">
                <note rend="inline" type="source">File No. 125.0012/85a.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Special
                        Agent <persName type="to">Carothers</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-04-25T20:00:00-05:00">
                            <hi rend="italic">April 25, 1914, 8 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Durango and Torreon were instructed by telegraph April 24:</p>
                <p>[Quotes text of first above telegram of April 24, 2 p.m.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
