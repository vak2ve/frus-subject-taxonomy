<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-03-09T18:00:00-05:00" frus:doc-dateTime-min="1914-03-09T18:00:00-05:00" n="425" subtype="historical-document" type="document" xml:id="d425">
                        <note rend="inline" type="source">File No. 322.112J72/3.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Hartman</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-03-09T18:00:00-05:00">
                                    <hi rend="italic">March 9, 1914, 6 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Your March 7, 11 a.m. When testimony received cable brief synopsis to
                            Department and if facts and law warrant request immediate release of
                            Jones.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>