                <note rend="inline" type="source">File No. 839.00/1045.</note>
                <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-01-31T18:00:00-05:00">
                            <hi rend="italic">January 31, 1914, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Represent to Minister for Foreign Affairs that the Department has received the
                    news contained in your January 29, 5 p.m. with gratification.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
