<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-10-01T23:59:59-05:00" frus:doc-dateTime-min="1914-10-01T00:00:00-05:00" n="346" subtype="historical-document" type="document" xml:id="d346">
                        <note rend="inline" type="source">File No. 839.00/1533.</note>
                        <head>
                            <hi rend="italic">Commissioner <persName type="from">Smith</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegrams.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Santo Domingo</hi></placeName>, [<date ana="#date_undated-inferred-from-document-content-and-sibling-dates" calendar="gregorian" when="1914-10-01"><hi rend="italic">undated</hi></date><hi rend="italic">; received October 1,
                                    1914.</hi>]</dateline>
                        </opener>
                        <p>Presidential candidates will be Jiménez, Vásquez, Velásquez and Vidal.
                            General pacification is advancing. Commission constantly watchful.
                            Apparently good feeling prevails at present.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Smith</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>