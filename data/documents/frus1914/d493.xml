                subtype="historical-document" type="document" xml:id="d493">
                <note rend="inline" type="source">File No. 838.00/762.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                            <persName type="to">Livingston</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-01-25">
                            <hi rend="italic">January 25, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>Your January 23. Use all possible persuasion to cause de facto administrators of
                    customs to respect Haiti’s obligations to National Bank of Haiti.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
