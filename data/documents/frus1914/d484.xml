<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-04-07T23:59:59-05:00" frus:doc-dateTime-min="1914-04-07T00:00:00-05:00" n="484" subtype="historical-document" type="document" xml:id="d484">
                        <note rend="inline" type="source">File No. 702.6811/40.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">Chargé d’Affaires of Greece</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#left">No. 202.]</seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-04-07">
                                    <hi rend="italic">April 7, 1914</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: In further reply to your note of December
                            17, 1913, advising the Department [etc.] the Department herewith
                            transmits to you for your information a copy of a letter from the
                            Attorney General to the Department, dated April 1, 1914, in reply to the
                            Department’s letter of March 28, 1914, calling attention to this
                            case.</p>
                        <p>Accept [etc.]</p>
                        <closer>For the Secretary of State: <lb/>
                            <signed>
                                <hi rend="smallcaps">Robert Lansing</hi></signed>.</closer>
                    </div>
                </body></text></TEI>