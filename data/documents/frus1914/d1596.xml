                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tampico</hi>
                        </placeName>, <date calendar="gregorian" when="1914-08-06T21:00:00-06:41">
                            <hi rend="italic">August 6, 1914, 9 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Referring my August 2, 9 p.m. Steamship <hi rend="italic">Antonina</hi> was
