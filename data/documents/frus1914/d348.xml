    <text>
        <body>
            <div frus:doc-dateTime-max="1914-10-08T17:00:00-05:00"
                frus:doc-dateTime-min="1914-10-08T17:00:00-05:00" n="348"
                subtype="historical-document" type="document" xml:id="d348">
                <note rend="inline" type="source">File No. 839.00/1557.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Chargé <persName type="to">White</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-10-08T17:00:00-05:00">
                            <hi rend="italic">October 8, 1914, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>The Department approves postponement of elections for one week and allowance of
                    three instead of two days for voting.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>.</closer>
            </div>
        </body>
