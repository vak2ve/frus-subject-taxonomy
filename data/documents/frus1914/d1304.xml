<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-01-24T23:59:59-05:00" frus:doc-dateTime-min="1914-01-24T00:00:00-05:00" n="1304" subtype="historical-document" type="document" xml:id="d1304">
                        <note rend="inline" type="source">File No. 312.115/48.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                chargé <persName type="to">O’Shaughnessy</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-01-24">
                                    <hi rend="italic">January 24, 1914</hi></date>.</dateline>
                        </opener>
                        <p>622. Your January 22. Present formal protest to central administration
                            against imposition of forced loans upon American citizens.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>