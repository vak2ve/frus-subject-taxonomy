<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-10-23T23:59:59-05:00" frus:doc-dateTime-min="1914-10-23T00:00:00-05:00" n="145" subtype="historical-document" type="document" xml:id="d145">
                        <note rend="inline" type="source">File No. 893.631/4.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Minister <persName type="to">Reinsch</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#left">No. 179.]</seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-10-23">
                                    <hi rend="italic">October 23, 1914</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: Receipt is acknowledged of the Legation’s
                            despatch No. 364 of September 11, 1914, with enclosure, relating to the
                            objections which this Government has raised against certain provisions
                            of the Chinese Mining Regulations promulgated March 11, 1914.</p>
                        <p>The Department approves the attitude taken by the Legation in this
                            matter.</p>
                        <p>I am [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Robert Lansing</hi></signed>.</closer>
                    </div>
                </body></text></TEI>