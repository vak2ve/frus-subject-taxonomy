                subtype="historical-document" type="document" xml:id="d1378">
                <note rend="inline" type="source">File No. 312.52/221a.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Special
                        Agent <persName type="to">Carothers</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-04-09">
                            <hi rend="italic">April 9, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>Newspapers this morning printed statement from General Carranza to the effect
                    that property of Spaniards expelled from Torreon will not be molested. Please
                    telegraph immediately if this is authentic.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. J. Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
