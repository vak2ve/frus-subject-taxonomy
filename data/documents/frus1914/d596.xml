    <text>
        <body>
            <div frus:doc-dateTime-max="1914-02-17T23:59:59-05:00"
                frus:doc-dateTime-min="1914-02-17T00:00:00-05:00" n="596"
                subtype="historical-document" type="document" xml:id="d596">
                <note rend="inline" type="source">File No. 838.00/846.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                            <persName type="to">Livingston</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-02-17">
                            <hi rend="italic">February 17, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>You may afford shelter to women and children mentioned if necessary to shield
                    them from violence.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
