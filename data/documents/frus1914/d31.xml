<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-06-30T23:59:59-05:00" frus:doc-dateTime-min="1914-06-30T00:00:00-05:00" n="31" subtype="historical-document" type="document" xml:id="d31">
                        <note rend="inline" type="source">File No. 863.0011/9.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">Ambassador of Austria-Hungary</gloss>.</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-06-30">
                                    <hi rend="italic">June 30, 1914</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My dear Mr. Ambassador</hi>: I am greatly shocked
                            and grieved to learn of the terrible affliction which has befallen the
                            people of Austria-Hungary through the assassination of the Archduke
                            Franz Ferdinand and his wife, and I beg of you, my dear Dr. Dumba, to
                            accept, personally, this expression of my profound sympathy.</p>
                        <p>I am [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">W. J. Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>