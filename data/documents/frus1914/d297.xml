    <text>
        <body>
            <div frus:doc-dateTime-max="1914-05-14T23:59:59-05:00"
                frus:doc-dateTime-min="1914-05-14T00:00:00-05:00" n="297"
                subtype="historical-document" type="document" xml:id="d297">
                <note rend="inline" type="source">File No. 839.00/1225.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Chargé d’Affaires of the Dominican
                            Republic</gloss> to the <gloss type="to">Secretary of
                        State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <seg rendition="#left">No. 39.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Dominican Legation</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-05-14">
                            <hi rend="italic">May 14, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary</hi>: I have the honor to inform you that by
                    a cablegram dated yesterday and received to-day my Government informs me that
                    because of the state of rebellion existing in the cities of Puerto Plata and
                    Monte Cristi and as a measure tending to restore peace, the ports of Puerto
                    Plata and Monte Cristi have been declared closed to commerce and blockaded.</p>
                <p>I avail [etc.],</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">I. A. Cernuda</hi>
                    </signed>.</closer>
            </div>
        </body>
