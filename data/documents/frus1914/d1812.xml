    <text>
        <body>
            <div frus:doc-dateTime-max="1914-05-26T23:59:59-05:00"
                frus:doc-dateTime-min="1914-05-26T00:00:00-05:00" n="1812"
                subtype="historical-document" type="document" xml:id="d1812">
                <note rend="inline" type="source">File No. 823.00/178a.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">McMillin</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-05-26">
                            <hi rend="italic">May 26, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>You are instructed to call on the Minister for Foreign Affairs on May 27 and
                    inform him that the United States recognizes the Government of Colonel Benavides
                    as the Provisional Government of Peru. Inform diplomatic representatives of
                    Argentina, Brazil and Chile at Lima, in order that they may recognize at the
                    same time.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
