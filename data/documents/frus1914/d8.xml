    <text>
        <body>
            <div frus:doc-dateTime-max="1914-05-27T23:59:59-05:00"
                frus:doc-dateTime-min="1914-05-27T00:00:00-05:00" n="8"
                subtype="historical-document" type="document" xml:id="d8">
                <note rend="inline" type="source">File No. 811.607G/738a.</note>
                <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-05-27">
                            <hi rend="italic">May 27, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="italic">To the American Diplomatic and Consular Officers</hi>.</p>
                <p>
                    <hi rend="smallcaps">Gentlemen</hi>: There is appended for your information
                    circular No. 4<note n="5" xml:id="d8fn5">Not printed. It supplements No. 3,
                        referred to in the preceding circular concerning Chinese
                        participants.</note> of the Department of Labor containing the regulations
                    governing <pb facs="0125" n="9" xml:id="pg_9"/> the admission and return of
                    aliens participating in the Panama-Pacific International Exposition and the
                    Panama-California Exposition, to be held in California in the year 1915.</p>
                <p>I am [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <hi rend="smallcaps">Wilbur J. Carr</hi>
                    </signed>.</closer>
            </div>
        </body>
