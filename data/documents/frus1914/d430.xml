<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-06-27T23:59:59-05:00" frus:doc-dateTime-min="1914-06-27T00:00:00-05:00" n="430" subtype="historical-document" type="document" xml:id="d430">
                        <note rend="inline" type="source">File No. 322.112J72/16.</note>
                        <head>
                            <hi rend="italic">Consul General <persName type="from">Goding</persName>
                                to the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#left">No. 46.]</seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate General</hi>, <lb/>
                                    <hi rend="italic">Guayaquil</hi></placeName>, <date calendar="gregorian" when="1914-06-27">
                                    <hi rend="italic">June 27, 1914</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to enclose certified
                            copy of the judge’s decree<note n="8" xml:id="d430fn8">Not
                                printed.</note> discharging the bondsmen of Mr. Robert B. Jones,
                            which closes the case. The document was called for in Department
                            telegram dated March 16, 1914. A similar copy has been sent to the
                            American Legation at Quito, and an uncertified copy has been placed on
                            file on this office.</p>
                        <p>I have [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Frederic W. Goding</hi></signed>.</closer>
                    </div>
                </body></text></TEI>