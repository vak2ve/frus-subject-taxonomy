                subtype="historical-document" type="document" xml:id="d1704">
                <note rend="inline" type="source">File No. 817.812/102b.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Jefferson</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-12-16">
                            <hi rend="italic">December 16, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>Senate Committee favorably reported Nicaraguan treaty to-day. Hope to secure
                    consideration in the Senate soon after holidays.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
