<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-08-08T23:59:59-05:00" frus:doc-dateTime-min="1914-08-08T00:00:00-05:00" n="1598" subtype="historical-document" type="document" xml:id="d1598">
                            <note rend="inline" type="source">File No. 312.62/95.</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the <gloss type="to">German Chargé d’Affaires</gloss>.</hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Department of State</hi>, <lb/>
                                        <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-08-08">
                                        <hi rend="italic">August 8, 1914</hi></date>.</dateline>
                            </opener>
                            <p>Your telegram August 4th. This Government will continue to use its
                                good offices as it has done in the past.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">W. J. Bryan</hi></signed>.</closer>
                        </div>
                        </body></text></TEI>