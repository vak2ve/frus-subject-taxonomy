    <text>
        <body>
            <div frus:doc-dateTime-max="1914-11-12T23:59:59-05:00"
                frus:doc-dateTime-min="1914-11-12T00:00:00-05:00" n="453"
                subtype="historical-document" type="document" xml:id="d453">
                <note rend="inline" type="source">File No. 351.117/18.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                        Ambassador <persName type="to">Herrick</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-11-12">
                            <hi rend="italic">November 12, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>261. Department informed Jean Eloi Candevan born at Poey, Basses Pyrenees,
                    December 1, 1877; emigrated to this country at age of sixteen; naturalized as
                    American citizen 1902; impressed into French army at Poey. Investigate; ask for
                    release.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
