                subtype="historical-document" type="document" xml:id="d672">
                <note rend="inline" type="source">File No. 812.00/11988.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of the Navy</gloss> to
                        Admiral <persName type="to">Fletcher</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Navy Department</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-04-12T12:00:00-05:00">
                            <hi rend="italic">April 12, 1914, 12 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>No action will be decided one way or the other until the President arrives.
                    Direct Mayo not to press salute until ordered.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Daniels</hi>
                    </signed>.</closer>
            </div>
        </body>
