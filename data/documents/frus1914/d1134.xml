    <text>
        <body>
            <div frus:doc-dateTime-max="1914-05-08T23:59:59-05:00"
                frus:doc-dateTime-min="1914-05-08T00:00:00-05:00" n="1134"
                subtype="historical-document" type="document" xml:id="d1134">
                <note rend="inline" type="source">File No. 812.6363/47.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">British Ambassador</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-05-08">
                            <hi rend="italic">May 8, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Ambassador</hi>: I beg to acknowledge the
                    receipt of your note of May 1, from which I am gratified to learn that you
                    concur in the suggestion in my note of the same day’s date regarding the
                    neutralization of the oil wells of Mexico.</p>
                <p>Thanking you [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. J. Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
