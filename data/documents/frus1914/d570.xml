<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-12-15T18:00:00-05:00" frus:doc-dateTime-min="1914-12-15T18:00:00-05:00" n="570" subtype="historical-document" type="document" xml:id="d570">
                        <note rend="inline" type="source">File No. 838.516/17.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Blanchard</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-12-15T18:00:00-05:00">
                                    <hi rend="italic">December 15, 1914, 6 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Your December 14, 11 a.m. Request Commanding Officer <hi rend="italic">Hancock</hi> to land as many marines as necessary to furnish safe
                            escort for gold from bank to <hi rend="italic">Machias</hi>.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>