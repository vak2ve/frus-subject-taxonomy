<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1911-05-27T23:59:59-05:00" frus:doc-dateTime-min="1911-05-27T00:00:00-05:00" n="95" subtype="historical-document" type="document" xml:id="d95">
                        <note rend="inline" type="source">File No. 893.811/46.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Calhoun</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1911-05-27">
                                    <hi rend="italic">May 27, 1911</hi></date>.</dateline>
                        </opener>
                        <p>The Red Cross requests Department to inform you that engineer will be
                            chosen within few days and urged to leave without delay.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Knox</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>