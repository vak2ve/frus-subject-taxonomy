<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-04-12T12:00:00-05:00" frus:doc-dateTime-min="1914-04-12T12:00:00-05:00" n="673" subtype="historical-document" type="document" xml:id="d673">
                        <note rend="inline" type="source">File No. 812.00/11486.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Chargé <persName type="to">O’Shaughnessy</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Extract.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-04-12T12:00:00-05:00">
                                    <hi rend="italic">April 12, 1914, 12 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>743. Your 844 April 12, 9 a.m. I prefer not to answer definitely until
                            after the President returns, which will be about seven o’clock to-morrow
                            morning.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>