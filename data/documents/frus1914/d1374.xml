                subtype="historical-document" type="document" xml:id="d1374">
                <note rend="inline" type="source">File No. 312.52/216.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Special
                        Agent <persName type="to">Carothers</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-04-08">
                            <hi rend="italic">April 8, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>Your April 8. The Red Cross will doubtless be able to extend some assistance to
                    destitute Spanish refugees from Torreon. Please ascertain if such assistance
                    will be acceptable to them, and the amount necessary for temporary relief.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
