    <text>
        <body>
            <div frus:doc-dateTime-max="1914-07-06T23:59:59-05:00"
                frus:doc-dateTime-min="1914-07-06T00:00:00-05:00" n="1174"
                subtype="historical-document" type="document" xml:id="d1174">
                <note rend="inline" type="source">File No. 812.63/11.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Spanish Ambassador</gloss> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Spanish Embassy</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-07-06">
                            <hi rend="italic">July 6, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary</hi>: I have the honor to acknowledge receipt
                    of your excellency’s note of July 2, 1914, in which you state: [Quotes Spanish
                    translation of note to the Spanish Ambassador of July 2, 1914.]</p>
                <p>I have the honor, in reply to this note, to inform you that I am authorized by my
                    Government to accept the agreement proposed by your excellency, and I do accept
                    it, at the same time assuring you of my highest consideration.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Juan Riaño</hi>
                    </signed>.</closer>
            </div>
        </body>
