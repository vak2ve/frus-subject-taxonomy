    <text>
        <body>
            <div frus:doc-dateTime-max="1914-12-05T23:59:59-05:00"
                frus:doc-dateTime-min="1914-12-05T00:00:00-05:00" n="359"
                subtype="historical-document" type="document" xml:id="d359">
                <note rend="inline" type="source">File No. 839.00/1639.</note>
                <head>
                    <hi rend="italic">Chargé <persName type="from">White</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Extract.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Santo Domingo</hi>
                        </placeName>, [<date
                            ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                            calendar="gregorian" when="1914-12-05">
                            <hi rend="italic">undated</hi>
                        </date>
                        <hi rend="italic">, received December 5, 1914, 3 p.m.</hi>].</dateline>
                </opener>
                <p>The National Assembly with constitutional quorum proclaimed Jiménez President
                    this afternoon. Official oath tomorrow morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">White</hi>
                    </signed>.</closer>
            </div>
        </body>
