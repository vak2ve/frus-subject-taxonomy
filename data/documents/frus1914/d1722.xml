<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-04-07T23:59:59-05:00" frus:doc-dateTime-min="1914-04-07T00:00:00-05:00" n="1722" subtype="historical-document" type="document" xml:id="d1722">
                        <note rend="inline" type="source">File No. 419.11D29/50a.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Price</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-04-07">
                                    <hi rend="italic">April 7, 1914</hi></date>.</dateline>
                        </opener>
                        <p>Inform Foreign Office that this Government insists upon immediate
                            settlement of matters growing out of the Cocoa Grove disturbances of
                            July 4, 1912. Report by telegraph.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>