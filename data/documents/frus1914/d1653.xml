                <note rend="inline" type="source">File No. 511.4A1/1488.</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Williams</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Athens</hi>
                        </placeName>, <date calendar="gregorian" when="1914-07-10">
                            <hi rend="italic">July 10, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>Greek Government accepts without reservation Opium Convention.
                    Congratulations.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Williams</hi>
                    </signed>.</closer>
            </div>
        </body>
