<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-05-23T23:59:59-05:00" frus:doc-dateTime-min="1914-05-23T00:00:00-05:00" n="1002" subtype="historical-document" type="document" xml:id="d1002">
                        <note rend="inline" type="source">File No. 703.3212/11.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">President of the American
                                    Colony at Mexico City</gloss> to the <gloss type="to">Secretary
                                    of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Mexico</hi></placeName>, <date calendar="gregorian" when="1914-05-23">
                                    <hi rend="italic">May 23, 1914</hi></date>.</dateline>
                        </opener>
                        <p>Meeting American Colony voted grateful thanks to Brazilian Minister for
                            untiring, splendid services rendered Americans and watchful care in
                            their behalf.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">C. H. M. y Agramonte</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>