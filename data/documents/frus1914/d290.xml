                subtype="historical-document" type="document" xml:id="d290">
                <note rend="inline" type="source">File No. 839.00/1184.</note>
                <head>
                    <hi rend="italic">Consul <persName type="from">Henry</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Consulate</hi>, <lb/>
                            <hi rend="italic">Puerto Plata</hi>
                        </placeName>, <date calendar="gregorian" when="1914-04-28T09:00:00-04:40">
                            <hi rend="italic">April 28, 1914, 9 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>American steamer <hi rend="italic">Algonquin</hi> failed to enter port. De facto
                    blockade existing. Is it possible to send war ship? Town is being shelled.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Henry</hi>
                    </signed>.</closer>
            </div>
        </body>
