    <text>
        <body>
            <div frus:doc-dateTime-max="1914-11-02T23:59:59-05:00"
                frus:doc-dateTime-min="1914-11-02T00:00:00-05:00" n="120"
                subtype="historical-document" type="document" xml:id="d120">
                <note rend="inline" type="source">File No. 893.811/156.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">American Red Cross</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-11-02">
                            <hi rend="italic">November 2, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sirs</hi>: There is enclosed herewith, for your information
                    and for whatever action you may deem appropriate, paraphrase of a telegram <pb
                        facs="0230" n="114" xml:id="pg_114"/> received to-day by the Department of
                    State from the American Minister at Peking regarding the need for immediate
                    relief work in the Huai River region.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
