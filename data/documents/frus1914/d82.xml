    <text>
        <body>
            <div frus:doc-dateTime-max="1914-11-30T23:59:59-05:00"
                frus:doc-dateTime-min="1914-11-30T00:00:00-05:00" n="82"
                subtype="historical-document" type="document" xml:id="d82">
                <note rend="inline" type="source">File No. 493.11/542.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Chinese Charge d’Affaires</gloss> to
                        the <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chinese Legation</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-11-30">
                            <hi rend="italic">November 30, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My dear Mr. Secretary</hi>: I beg to inform you that I have
                    just received from the Treasurer of the United States a check for two hundred
                    thousand dollars ($200,000), drawn in my favor as Counselor in charge of the
                    Chinese Legation, for part payment of the balance of the Chinese Indemnity of
                    1900, returnable to the Chinese Government.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Yung Kwai</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
