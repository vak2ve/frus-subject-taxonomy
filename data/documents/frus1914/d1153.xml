    <text>
        <body>
            <div frus:doc-dateTime-max="1914-06-02T23:59:59-05:00"
                frus:doc-dateTime-min="1914-06-02T00:00:00-05:00" n="1153"
                subtype="historical-document" type="document" xml:id="d1153">
                <note rend="inline" type="source">File No. 812.6363/87.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Netherlands Minister</gloss> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Netherlands Legation</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-06-02">
                            <hi rend="italic">June 2, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to acknowledge receipt of
                    your note of to-day, in which is stated: [Quotes note of June 2, 1914, printed
                    on the preceding page.]</p>
                <p>I have the honor to inform you in reply that I am authorized by my Government to
                    accept in their name the agreement as described above, which they will therefore
                    regard as coming into effect from this day’s date.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. L. F. C. de Rappard</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
