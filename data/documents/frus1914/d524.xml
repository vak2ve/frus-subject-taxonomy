    <text>
        <body>
            <div frus:doc-dateTime-max="1914-06-26T23:59:59-05:00"
                frus:doc-dateTime-min="1914-06-26T00:00:00-05:00" n="524"
                subtype="historical-document" type="document" xml:id="d524">
                <note rend="inline" type="source">File No. 838.00/930.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                            <persName type="to">Livingston</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-06-26">
                            <hi rend="italic">June 26, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has received your despatch No. 231
                    of May 26, 1914, with regard to the revolutionary situation in Haiti.</p>
                <p>The despatch has been read with interest by the Department and it approves the
                    course pursued by you as outlined therein.</p>
                <p>I am [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <hi rend="smallcaps">Wilbur J. Carr</hi>
                    </signed>.</closer>
            </div>
        </body>
