                subtype="historical-document" type="document" xml:id="d236">
                <note rend="inline" type="source">File No. 839.00/1045.</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Sullivan</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1914-01-29T17:00:00-04:40">
                            <hi rend="italic">January 29, 1914, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Legation has induced Dominican Government to release all political prisoners
                    including Velásquez who enters his candidacy for the presidency in coming
                    election.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sullivan</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
