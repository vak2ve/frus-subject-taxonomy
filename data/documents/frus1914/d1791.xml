<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-07-14T23:59:59-05:00" frus:doc-dateTime-min="1914-07-14T00:00:00-05:00" n="1791" subtype="historical-document" type="document" xml:id="d1791">
                        <note rend="inline" type="source">File No. 891.001/30.</note>
                        <head>
                            <hi rend="italic">Minister <persName type="from">Russell</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Teheran</hi></placeName>, <date calendar="gregorian" when="1914-07-14">
                                    <hi rend="italic">July 14, 1914</hi></date>.</dateline>
                        </opener>
                        <p>Ministry for Foreign Affairs wants you to telegraph constituting me a
                            Special Ambassador at the coronation of the Shah same as the other
                            Ministers.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Russell</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>