                subtype="historical-document" type="document" xml:id="d1003">
                <note rend="inline" type="source">File No. 703.3212/11.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Brazilian Minister</gloss> to Mexico.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-05-25">
                            <hi rend="italic">May 25, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>81. American Colony, Mexico City, May 23, telegraphed Department grateful thanks
                    to you for your untiring, splendid services rendered Americans and for your
                    watchful care in their behalf.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. J. Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
