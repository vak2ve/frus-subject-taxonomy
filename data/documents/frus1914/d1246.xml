    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-01T23:59:59-05:00"
                frus:doc-dateTime-min="1914-08-01T00:00:00-05:00" n="1246"
                subtype="historical-document" type="document" xml:id="d1246">
                <note rend="inline" type="source">File No. 812.512/380.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Vice
                        Consul <persName type="to">Bevan</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-08-01">
                            <hi rend="italic">August 1, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>Advise the Department fully of the amount and character of war tax as soon as
                    lists are received, and to what extent American interests are affected, and
                    advise against any tax which is unreasonable or excessive. Department will
                    advise you upon receipt of necessary information.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
