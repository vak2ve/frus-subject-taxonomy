<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-02-21T23:59:59-05:00" frus:doc-dateTime-min="1914-02-21T00:00:00-05:00" n="1484" subtype="historical-document" type="document" xml:id="d1484">
                            <note rend="inline" type="source">File No. 312.41/124.</note>
                            <head>
                                <hi rend="italic">Special Agent <persName type="from">Carothers</persName> to the <gloss type="to">Secretary of
                                        State</gloss>.</hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">El Paso</hi></placeName>, <date calendar="gregorian" when="1914-02-21">
                                        <hi rend="italic">February 21, 1914</hi></date>.</dateline>
                            </opener>
                            <p>
                                <hi rend="smallcaps">Sir</hi>: I have the honor to enclose original
                                copy of the sentence under which William Benton was executed.<note n="135" xml:id="d1484fn135">Not printed.</note>
                            </p>
                            <p>I have [etc.]</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">G. C. Carothers</hi></signed>.</closer>
                        </div>
                        </body></text></TEI>