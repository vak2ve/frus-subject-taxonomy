<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-07-21T23:59:59-05:00" frus:doc-dateTime-min="1914-07-21T00:00:00-05:00" n="1792" subtype="historical-document" type="document" xml:id="d1792">
                        <note rend="inline" type="source">File No. 891.001/30.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Russell</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1914-07-21">
                                    <hi rend="italic">July 21, 1914</hi></date>.</dateline>
                        </opener>
                        <p>You are accredited as Special Representative of the President at
                            coronation. This gives you rank of Ambassador Extraordinary and
                            Plenipotentiary.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>