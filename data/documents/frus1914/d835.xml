<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-07-24T23:59:59-05:00" frus:doc-dateTime-min="1914-07-24T00:00:00-05:00" n="835" subtype="historical-document" type="document" xml:id="d835">
                        <note rend="inline" type="source">File No. 812.001H87/3.</note>
                        <head>
                            <hi rend="italic">Vice Consul <persName type="from">Bundy</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Kingston, Jamaica</hi></placeName>, <date calendar="gregorian" when="1914-07-24">
                                    <hi rend="italic">July 24, 1914</hi></date>.</dateline>
                        </opener>
                        <p>Huerta arrived by cruiser <hi rend="italic">Dresden</hi> July 24, 2
                            p.m.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bundy</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>