                subtype="historical-document" type="document" xml:id="d676">
                <note rend="inline" type="source">File No. 812.00/11486.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Chargé
                            <persName type="to">O’Shaughnessy</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-04-13T20:00:00-05:00">
                            <hi rend="italic">April 13, 1914, 8 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>747. Your 847, April 12, 2 p.m. We are investigating statements contained in
                    Huerta’s reply. Will answer tomorrow. In meantime hope Huerta will reconsider
                    position taken.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
