                subtype="historical-document" type="document" xml:id="d1434">
                <note rend="inline" type="source">File No. 312.52/380.</note>
                <head>
                    <hi rend="italic">Consul <persName type="from">Miller</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                    <note n="128" xml:id="d1434fn128">Communicated to the Spanish Ambassador July
                        27, 1914.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Consulate</hi>, <lb/>
                            <hi rend="italic">Tampico</hi>
                        </placeName>, <date calendar="gregorian" when="1914-07-23">
                            <hi rend="italic">July 23, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>Marcial Guerrero, Spanish priest at Cerritos, San Luis Potosi, arrived Tampico.
                    Is detained at Jefatura de Armas awaiting transportation from country, he having
                    been expelled from country by order of military commander at Cerritos. Is a
                    Spanish subject.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Miller</hi>
                    </signed>.</closer>
            </div>
        </body>
