                subtype="historical-document" type="document" xml:id="d1060">
                <note rend="inline" type="source">File No. 312.11/8699.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                            <persName type="to">Lespinasse</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-04-22T16:00:00-05:00">
                            <hi rend="italic">April 22, 1914, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your April 20. Provide all Americans with passage who may require assistance. Use
                    your judgment as to routing them via New Orleans or Galveston.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
