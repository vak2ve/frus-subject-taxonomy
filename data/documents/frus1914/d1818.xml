    <text>
        <body>
            <div frus:doc-dateTime-max="1914-10-12T23:59:59-05:00"
                frus:doc-dateTime-min="1914-10-12T00:00:00-05:00" n="1818"
                subtype="historical-document" type="document" xml:id="d1818">
                <note rend="inline" type="source">File No. 871.001/6.</note>
                <head>
                    <hi rend="italic">President <persName type="from">Wilson</persName> to Queen
                            <persName type="to">Elizabeth</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The White House</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-10-12">
                            <hi rend="italic">October 12, 1914</hi>
                        </date>.</dateline>
                </opener>
                <p>I am deeply grieved to learn of the death of His Majesty and I offer to Your
                    Majesty, to the royal family and to the Roumanian nation the sincere condolences
                    of the Government and people of the United States and the expression of my own
                    deep sympathy in your great sorrow.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Woodrow Wilson</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
