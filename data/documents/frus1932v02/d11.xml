                subtype="historical-document" type="document" xml:id="d11">
                <note rend="inline" type="source">890b.6363 Gulf Oil Corporation/42: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Great Britain (<persName corresp="#p_AR1" type="to"
                            >Atherton</persName>)</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-03-22T18:00:00-05:00"
                            >March 22, 1932—6 p.m.</date>
                    </dateline>
                </opener>
                <p>95. Your 112, March 18, 5 p.m.<note n="12" xml:id="d11fn12">Not printed.</note>
                    Please telegraph summary of note which you propose to send to <persName
                        corresp="#p_OSL1">Oliphant</persName>.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
