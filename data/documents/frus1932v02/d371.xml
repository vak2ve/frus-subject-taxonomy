                subtype="historical-document" type="document" xml:id="d371">
                <note rend="inline" type="source">611.57241/223</note>
                <head>
                    <hi rend="italic">The Norwegian Minister (<persName type="from"
                            >Bachke</persName>) to the <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <p>The Minister of Norway presents his compliments to the Secretary of State and has
                    the honor to inquire, with reference to the notes of January 20, 1932,
                    concerning free importation privileges for Norwegian respectively American
                    consular officials, [<hi rend="italic">sic</hi>] if the arrangement established
                    through the said notes is considered applicable to Norwegian consuls residing in
                    colonies and possessions of the United States of America.</p>
                <closer>
                    <dateline rendition="#left">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-02-25">February 25,
                            1932</date>.</dateline>
                </closer>
            </div>
        </body>
    </text>
