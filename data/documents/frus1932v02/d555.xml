    <text>
        <body>
            <div frus:doc-dateTime-max="1932-09-02T23:59:59-05:00"
                frus:doc-dateTime-min="1932-09-02T00:00:00-05:00" n="555"
                subtype="historical-document" type="document" xml:id="d555">
                <note rend="inline" type="source">882.01 Foreign Control/345</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Firestone Plantations Company</gloss>
                        to the <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Akron, Ohio</hi>
                        </placeName>, <date calendar="gregorian" when="1932-09-02">September 2,
                            1932</date>.<lb/>[Received September 3.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: We are herewith transmitting for the information
                    of the Department of State copy of an invitation received from The Secretary
                    General of the League of Nations, dated August 24th, 1932.<note n="67"
                        xml:id="d555fn67">Not printed; it was similar to the one sent to the Finance
                        Corporation of America, <ref target="#pg_751">p. 751</ref>.</note>
                </p>
                <p>No reply has been made to this message.</p>
                <p>Yours very truly,</p>
                <closer>
                    <hi rend="smallcaps">Firestone Plantations Company</hi>
                    <lb/>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">B. M. Robinson</hi>
                        </persName>, <hi rend="italic">Secretary</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
