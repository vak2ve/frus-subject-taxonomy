                subtype="historical-document" type="document" xml:id="d19">
                <note rend="inline" type="source">890b.6363 Gulf Oil Corporation/159:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain (<persName type="from"
                            >Mellon</persName>) to the <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1932-10-18T11:00:00+00:00"
                            >October 18, 1932—11 a.m.</date>
                        <lb/>[Received October 18—6:51 a.m.]</dateline>
                </opener>
                <p>298. I presented views outlined in your 258, October 4, 6 p.m., yesterday to
                        <persName corresp="#p_VSRG1">Vansittart</persName> and urged early
                    action.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Mellon</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
