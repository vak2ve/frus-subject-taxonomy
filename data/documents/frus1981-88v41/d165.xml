                    <item>
                        <list>
                            <head>
                                <hi rend="italic">
                                    <gloss target="#t_NSC_1">NSC</gloss>
                                </hi>
                            </head>
                            <item>Mr. <persName corresp="#p_GMA_1">Michael Guhin</persName>
                            </item>
                            <item>Col <persName corresp="#p_WMO_1">Michael Wheeler</persName>
                            </item>
