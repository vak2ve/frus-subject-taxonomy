<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-02-09T16:00:00-05:00" frus:doc-dateTime-min="1915-02-09T16:00:00-05:00" n="243" subtype="historical-document" type="document" xml:id="d243">
                        <note rend="inline" type="source">File No. 839.00/1674.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Sullivan</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-02-09T16:00:00-05:00">
                                    <hi rend="italic">February 9, 1915—4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Your February 8, 8 a.m. We are pleased to learn of peaceful termination
                            of controversy between Puerto Plata and President Jiménes.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>