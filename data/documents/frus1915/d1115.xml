                <note rend="inline" type="source">File No. 612.1123/50.</note>
                <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vera Cruz</hi>
                        </placeName>, <date calendar="gregorian" when="1915-03-02">
                            <hi rend="italic">March 2, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>Conference entirely unsuccessful. Am informed this morning by Secretary of
                    Foreign Relations that port is closed until further notice.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Silliman.</hi>
                    </signed>
                </closer>
            </div>
