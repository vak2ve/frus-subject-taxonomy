<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-09-09T16:00:00-05:00" frus:doc-dateTime-min="1915-09-09T16:00:00-05:00" n="980" subtype="historical-document" type="document" xml:id="d980">
                        <note rend="inline" type="source">File No. 812.00/16037.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Mr. <persName type="to">Parker</persName>, representing American
                                interests in Mexico</hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-09-09T16:00:00-05:00">
                                    <hi rend="italic">September 9, 1915—4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>45. Your 50, September 4. Department is again making representations to
                            Carranza behalf suffering poor in Mexico City.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>