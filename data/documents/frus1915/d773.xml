                <note rend="inline" type="source">File No. 882.00/515.</note>
                <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1915-11-28">
                            <hi rend="italic">November 28, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="italic">Chester</hi> here. The port of Sinoe opened after fight.
                    Twenty natives and two soldiers killed. Campaign against rebellious tribes
                    proceeding.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bundy.</hi>
                    </signed>
                </closer>
            </div>
        </body>
