<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-11-28T23:59:59-05:00" frus:doc-dateTime-min="1915-11-28T00:00:00-05:00" n="773" subtype="historical-document" type="document" xml:id="d773">
                        <note rend="inline" type="source">File No. 882.00/515.</note>
                        <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Monrovia</hi></placeName>, <date calendar="gregorian" when="1915-11-28">
                                    <hi rend="italic">November 28, 1915</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="italic">Chester</hi> here. The port of Sinoe opened after
                            fight. Twenty natives and two soldiers killed. Campaign against
                            rebellious tribes proceeding.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bundy.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>