<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-08-05T23:59:59-05:00" frus:doc-dateTime-min="1915-08-05T00:00:00-05:00" n="1328" subtype="historical-document" type="document" xml:id="d1328">
                        <note rend="inline" type="source">File No. 812.00/15649.</note>
                        <head>
                            <hi rend="italic">Special Agent <persName type="from">Carothers</persName> to the <gloss type="to">Secretary of
                                    State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram—Extract.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">El Paso</hi></placeName>, <date calendar="gregorian" when="1915-08-05">
                                    <hi rend="italic">August 5, 1915</hi></date>.</dateline>
                        </opener>
                        <p>General Villa arrived Juarez this morning. I will see him during the day
                            and renew my efforts.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Carothers.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>