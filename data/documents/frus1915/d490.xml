                subtype="historical-document" type="document" xml:id="d490">
                <note rend="inline" type="source">File No. 711.38/54.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Blanchard</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-11-30T17:00:00-05:00">
                            <hi rend="italic">November 30, 1915—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your November 29, 6 p.m. Satisfactory conclusion of this matter is very
                    gratifying to the Department.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>.</signed>
                </closer>
            </div>
        </body>
