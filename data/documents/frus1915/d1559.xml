    <text>
        <body>
            <div frus:doc-dateTime-max="1915-08-19T23:59:59-05:00"
                frus:doc-dateTime-min="1915-08-19T00:00:00-05:00" n="1559"
                subtype="historical-document" type="document" xml:id="d1559">
                <note rend="inline" type="source">File No. 312.52/656.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Spanish Ambassador</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-08-19">
                            <hi rend="italic">August 19, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to acknowledge the
                    receipt of your telegram of the 12th instant in which you ask [etc.]</p>
                <p>I have the honor to say in reply that the Department has communicated a copy of
                    your telegram to the Secretary of the Navy, and asked him to have the
                    instructions desired by you given by wire to the commanders of American vessels
                    in Mexican waters.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
