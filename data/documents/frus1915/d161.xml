    <text>
        <body>
            <div frus:doc-dateTime-max="1915-01-11T23:59:59-05:00"
                frus:doc-dateTime-min="1915-01-11T00:00:00-05:00" n="161"
                subtype="historical-document" type="document" xml:id="d161">
                <note rend="inline" type="source">File No. 893.811/175.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Reinsch</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 233.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-01-11">
                            <hi rend="italic">January 11, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In further reply to your despatch No. 424 of
                    October 28, 1914, relating to the need of an advance of $5,000,000 on the
                    proposed Huai River loan, I send you herewith copy of a letter dated January 6,
                    1915, from the American Red Cross to the Department of State on these
                    matters.</p>
                <p>The Department has today telegraphed you in the sense suggested by the Red
                    Cross.</p>
                <p>I am [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
