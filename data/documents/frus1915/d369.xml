                <note rend="inline" type="source">File No. 322.112St8.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Hartman</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-04-26">
                            <hi rend="italic">April 26, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>Your April 24. Insist that authorities permit American prisoner free
                    communication with his diplomatic and consular representatives.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>.</signed>
                </closer>
            </div>
        </body>
