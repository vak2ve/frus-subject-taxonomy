<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-05-14T23:59:59-05:00" frus:doc-dateTime-min="1915-05-14T00:00:00-05:00" n="374" subtype="historical-document" type="document" xml:id="d374">
                        <note rend="inline" type="source">File No. 322.112St8/2.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Hartman</persName></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-05-14">
                                    <hi rend="italic">May 14, 1915</hi></date>.</dateline>
                        </opener>
                        <p>Your April 29. Guayaquil reports consular agent investigated arrest
                            Strong, found no evidence against prisoner. Use best efforts obtain
                            Strong’s release.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>