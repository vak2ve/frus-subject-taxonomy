<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-05-01T23:59:59-05:00" frus:doc-dateTime-min="1915-05-01T00:00:00-05:00" n="1399" subtype="historical-document" type="document" xml:id="d1399">
                        <note rend="inline" type="source">File No. 812.512/647</note>
                        <head>
                            <hi rend="italic">Consul General <persName type="from">Shanklin</persName> to the <gloss type="to">Secretary of
                                    State</gloss></hi>.</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate General at Mexico
                                        City</hi>, <lb/>
                                    <hi rend="italic">Written at Vera Cruz, Mexico</hi></placeName>,
                                    <date calendar="gregorian" when="1915-05-01">
                                    <hi rend="italic">May 1, 1915</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge receipt,
                            today, of the Department’s instruction of March 12, No. 710, the
                            contents of which will be transmitted by me to American citizens
                            inquiring in regard to the payment of their mining taxes.</p>
                        <p>I have [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Arnold Shanklin.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>