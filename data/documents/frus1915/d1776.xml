                subtype="historical-document" type="document" xml:id="d1776">
                <note rend="inline" type="source">File No. 419.11D29/100.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Price</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-08-07">
                            <hi rend="italic">August 7, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>Your July 27. Discreetly propose to Foreign Office as arbiter Cocoa Grove claims
                    Netherlands Minister to United States, who it is understood, is also accredited
                    to Panama. Request prompt reply.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing.</hi>
                    </signed>
                </closer>
            </div>
        </body>
