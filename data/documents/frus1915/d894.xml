                subtype="historical-document" type="document" xml:id="d894">
                <note rend="inline" type="source">File No. 812.00/15194.</note>
                <head>
                    <hi rend="italic">Consul <persName type="from">Schmutz</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Extract.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Consulate</hi>, <lb/>
                            <hi rend="italic">Aguascalientes</hi>
                        </placeName>, <date calendar="gregorian" when="1915-06-05">
                            <hi rend="italic">June 5, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    the President’s messages to the leaders of the several armed factions in Mexico.
                    * * * Up to this moment the local paper has limited itself to publishing a
                    translation of the message without comment.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gaston Schmutz.</hi>
                    </signed>
                </closer>
            </div>
        </body>
