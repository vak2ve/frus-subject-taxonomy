                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">American Embassy</hi>, <lb/>
                                        <hi rend="italic">Madrid</hi></placeName>, <date calendar="gregorian" when="1915-03-15">
                                        <hi rend="italic">March 15, 1915</hi></date>.</dateline>
