<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-01-02T23:59:59-05:00" frus:doc-dateTime-min="1915-01-02T00:00:00-05:00" n="442" subtype="historical-document" type="document" xml:id="d442">
                        <note rend="inline" type="source">File No. 811.54441/11.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Ambassador <persName type="to">Page</persName></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-01-02">
                                    <hi rend="italic">January 2, 1915</hi></date>.</dateline>
                        </opener>
                        <p>869. Presidential Proclamation has been issued effective January 1, 1915,
                            on understanding British Order in Council will be issued to take effect
                            same date. Bring this at once to attention Foreign Office.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>