<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-06-26T23:59:59-05:00" frus:doc-dateTime-min="1915-06-26T00:00:00-05:00" n="1139" subtype="historical-document" type="document" xml:id="d1139">
                        <note rend="inline" type="source">File No. 812.001H87/20.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Collector <persName type="to">Cobb</persName></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-06-26">
                                    <hi rend="italic">June 26, 1915</hi></date>.</dateline>
                        </opener>
                        <p>Advise immediately and cooperate with El Paso representative Department
                            of Justice.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing.</hi>
                            </signed>
                        </closer>
                    </div>
