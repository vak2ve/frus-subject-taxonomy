    <text>
        <body>
            <div frus:doc-dateTime-max="1915-05-21T23:59:59-05:00"
                frus:doc-dateTime-min="1915-05-21T00:00:00-05:00" n="1834"
                subtype="historical-document" type="document" xml:id="d1834">
                <note rend="inline" type="source">File No. 816.1052/47.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Price</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 149.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-05-21">
                            <hi rend="italic">May 21, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Supplementing despatch No. 146, of May 17, 1915,
                    there is transmitted herewith, for your information, a copy of a letter from the
                    Department of War, dated May 15, 1915, regarding American control of the police
                    in Panama.</p>
                <p>I am [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing.</hi>
                    </signed>
                </closer>
            </div>
        </body>
