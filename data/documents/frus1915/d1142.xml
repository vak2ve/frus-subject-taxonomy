<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-06-21T23:59:59-05:00" frus:doc-dateTime-min="1915-06-21T00:00:00-05:00" n="1142" subtype="historical-document" type="document" xml:id="d1142">
                        <note rend="inline" type="source">File No. 812.001H87/21.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Collector <persName type="to">Cobb</persName></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-06-21">
                                    <hi rend="italic">June 21, 1915</hi></date>.</dateline>
                        </opener>
                        <p>The Department appreciates your prompt, efficient action.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Osborne.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>