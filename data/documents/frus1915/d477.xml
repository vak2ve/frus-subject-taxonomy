                subtype="historical-document" type="document" xml:id="d477">
                <note rend="inline" type="source">File No. 711.38/40.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Chargé
                            <persName type="to">Davis</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-10-15T16:00:00-05:00">
                            <hi rend="italic">October 15, 1915—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your October 14, 2 p.m. The Department approves your action and confidently
                    expects Haitian Government to make every effort to obtain favorable vote of
                    Senate without delay.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>.</signed>
                </closer>
            </div>
        </body>
