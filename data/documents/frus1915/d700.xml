<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-09-28T23:59:59-05:00" frus:doc-dateTime-min="1915-09-28T00:00:00-05:00" n="700" subtype="historical-document" type="document" xml:id="d700">
                        <note rend="inline" type="source">File No. 365.117/170.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Ambassador <persName type="to">Page</persName></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-09-28">
                                    <hi rend="italic">September 28, 1915</hi></date>.</dateline>
                        </opener>
                        <p>332. Your despatch August 20. Ask early decision Ajello case, calling
                            attention Ajello served as juryman on several occasions New York courts,
                            fulfilling his duties as American citizen.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Polk.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>