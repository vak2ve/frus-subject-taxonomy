                <note rend="inline" type="source">File No. 812.404/47.</note>
                <head>
                    <hi rend="italic">Vice Consul <persName type="from">Bevan</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Extract.]</seg>
                </opener>
                <opener>
                    <seg rendition="#left">No. 1346.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Consulate</hi>, <lb/>
                            <hi rend="italic">Tampico</hi>
                        </placeName>, <date calendar="gregorian" when="1915-01-18">
                            <hi rend="italic">January 18, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>. I have the honor to acknowledge receipt of the
                    Department’s telegraphic instruction of January 14 [etc.]</p>
                <pb facs="1127" n="1011" xml:id="pg_1011"/>
                <p>There were no outrages committed either against the priests or nuns in this
                    consular district during the year 1914. * * *</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Thos. H. Bevan.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
