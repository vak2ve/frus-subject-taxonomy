<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-01-16T23:59:59-05:00" frus:doc-dateTime-min="1915-01-16T00:00:00-05:00" n="1496" subtype="historical-document" type="document" xml:id="d1496">
                        <note rend="inline" type="source">File No. 812.404/34.</note>
                        <head>
                            <hi rend="italic">Consul <persName type="from">Guyant</persName> to the
                                    <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Ensenada</hi></placeName>, <date calendar="gregorian" when="1915-01-16">
                                    <hi rend="italic">January 16, 1915</hi></date>.</dateline>
                        </opener>
                        <p>Department’s January 14. No cases of this kind have occurred in this
                            district.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Guyant.</hi>
                            </signed>
                        </closer>
                    </div>
