                subtype="historical-document" type="document" xml:id="d680">
                <note rend="inline" type="source">File No. 365.117/100.</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Page</persName> to the <gloss
                            type="to">Secretary of State ad interim</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegrams.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1915-06-17">
                            <hi rend="italic">June 17, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>331. Department’s 261, June 14, Da Prato case. Presented yesterday personally a
                    further note to Minister Foreign Affairs and urged prompt action. He promised to
                    have matter carefully studied immediately.</p>
                <closer>
                    <hi rend="smallcaps">American Embassy.</hi>
                </closer>
            </div>
        </body>
