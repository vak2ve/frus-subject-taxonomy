<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-10-08T23:59:59-05:00" frus:doc-dateTime-min="1915-10-08T00:00:00-05:00" n="1562" subtype="historical-document" type="document" xml:id="d1562">
                            <note rend="inline" type="source">File No. 312.52/674.</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the <gloss type="to">Spanish Ambassador</gloss></hi>.</head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Department of State</hi>, <lb/>
                                        <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-10-08">
                                        <hi rend="italic">October 8, 1915</hi></date>.</dateline>
                            </opener>
                            <p>Your telegram October 6. Appropriate instructions have been sent
                                Department’s representative at Vera Cruz regarding restoration
                                property of Teresian and Jesus Maria Colleges in Yucatan.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Robert Lansing.</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>