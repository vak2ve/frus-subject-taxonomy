<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-07-29T23:59:59-05:00" frus:doc-dateTime-min="1915-07-29T00:00:00-05:00" n="956" subtype="historical-document" type="document" xml:id="d956">
                        <note rend="inline" type="source">File No. 812.00/17548.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Ambassador of Brazil</gloss> to
                                the <gloss type="to">Secretary of State</gloss>.</hi><note n="32" xml:id="d956fn32">Similar acceptances received from the other
                                diplomatic representatives.</note>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Long Branch, N. J.</hi></placeName>, <date calendar="gregorian" when="1915-07-29">
                                    <hi rend="italic">July 29, 1915</hi></date>.</dateline>
                        </opener>
                        <p>Will be present August 5 at 3 o’clock. Am cabling again to Rio.<note n="33" xml:id="d956fn33">Refers to the Secretary’s message to him
                                dated July 26.</note>
                        </p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Gama.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>