<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-04-08T23:59:59-05:00" frus:doc-dateTime-min="1915-04-08T00:00:00-05:00" n="1134" subtype="historical-document" type="document" xml:id="d1134">
                        <note rend="inline" type="source">File No. 812.001H87/10.</note>
                        <head>
                            <hi rend="italic">Consul General <persName type="from">Hurst</persName>
                                to the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate General</hi>, <lb/>
                                    <hi rend="italic">Barcelona</hi></placeName>, <date calendar="gregorian" when="1915-04-08">
                                    <hi rend="italic">April 8, 1915</hi></date>.</dateline>
                        </opener>
                        <p>Spanish line Company Transatlantic steamer <hi rend="italic">Antonio
                                Lopez</hi> due New York April 12 with General Huerta on board.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hurst.</hi>
                            </signed>
                        </closer>
                    </div>
