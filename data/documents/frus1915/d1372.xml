                <note rend="inline" type="source">File No. 812.63/153.</note>
                <head>
                    <hi rend="italic">Special Agent <persName type="from">Carothers</persName> to
                        the <gloss type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegrams.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">El Paso</hi>
                        </placeName>, <date calendar="gregorian" when="1915-11-23">
                            <hi rend="italic">November 23, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>Following received from Douglas today: <quote rend="blockquote">
                        <p>Obregon yesterday advised mining companies to resume work in Sonora,
                            guaranteeing safety of themselves and their properties.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Carothers.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
