<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-11-23T23:59:59-05:00" frus:doc-dateTime-min="1915-11-23T00:00:00-05:00" n="1372" subtype="historical-document" type="document" xml:id="d1372">
                        <note rend="inline" type="source">File No. 812.63/153.</note>
                        <head>
                            <hi rend="italic">Special Agent <persName type="from">Carothers</persName> to the <gloss type="to">Secretary of
                                    State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegrams.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">El Paso</hi></placeName>, <date calendar="gregorian" when="1915-11-23">
                                    <hi rend="italic">November 23, 1915</hi></date>.</dateline>
                        </opener>
                        <p>Following received from Douglas today: <quote rend="blockquote">
                                <p>Obregon yesterday advised mining companies to resume work in
                                    Sonora, guaranteeing safety of themselves and their
                                    properties.</p>
                            </quote>
                        </p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Carothers.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>