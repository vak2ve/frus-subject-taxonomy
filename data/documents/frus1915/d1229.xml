<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-01-11T23:59:59-05:00" frus:doc-dateTime-min="1915-01-11T00:00:00-05:00" n="1229" subtype="historical-document" type="document" xml:id="d1229">
                        <note rend="inline" type="source">File No. 812.6368/147.</note>
                        <head>
                            <hi rend="italic">Vice Consul <persName type="from">Bevan</persName> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Tampico</hi></placeName>, <date calendar="gregorian" when="1915-01-11">
                                    <hi rend="italic">January 11, 1915</hi></date>.</dateline>
                        </opener>
                        <p>Penn-Mex Oil Company and the Aguilar Petroleum Company have been closed
                            down by decree signed by Sub-Secretary of Fomento and authorized by
                            First Chief of the Constitutionalist Army.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bevan.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>