<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-08-05T23:59:59-05:00" frus:doc-dateTime-min="1915-08-05T00:00:00-05:00" n="1326" subtype="historical-document" type="document" xml:id="d1326">
                        <note rend="inline" type="source">File No. 812.512/745.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Consul General <persName type="to">Hanna</persName></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-08-05">
                                    <hi rend="italic">August 5, 1915</hi></date>.</dateline>
                        </opener>
                        <p>Your August 4, 1 p.m. Department telegraphing Silliman endeavor obtain
                            immediate sending of desired instructions to tax collector,
                            Monterey.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>