<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-08-11T23:59:59-05:00" frus:doc-dateTime-min="1915-08-11T00:00:00-05:00" n="1557" subtype="historical-document" type="document" xml:id="d1557">
                            <note rend="inline" type="source">File No. 701.5212/52.</note>
                            <head>
                                <hi rend="italic">Special Agent <persName type="from">Carothers</persName> to the <gloss type="to">Secretary of
                                        State</gloss></hi>.</head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">El Paso</hi></placeName>, <date calendar="gregorian" when="1915-08-11">
                                        <hi rend="italic">August 11, 1915</hi></date>.</dateline>
                            </opener>
                            <p>Señor Zapico is here, having arrived on the 9th from Chihuahua.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Carothers.</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>