                <note rend="inline" type="source">File No. 882.00/525.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">President</gloss> to the <gloss
                            type="to">Acting Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">White House</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-10-01">
                            <hi rend="italic">October 1, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Polk</hi>: I think that the <hi rend="italic"
                        >Chester</hi> ought by all means to be sent.</p>
                <p>Faithfully yours,</p>
                <closer>
                    <signed>W. W. <lb/> [<hi rend="smallcaps">Woodrow Wilson</hi>]</signed>
                </closer>
            </div>
        </body>
    </text>
