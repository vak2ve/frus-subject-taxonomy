<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-02-03T23:59:59-05:00" frus:doc-dateTime-min="1915-02-03T00:00:00-05:00" n="1674" subtype="historical-document" type="document" xml:id="d1674">
                            <note rend="inline" type="source">File No. 312.93/82.</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to Special Agent <persName type="to">Carothers</persName></hi>.<note n="10" xml:id="d1674fn10">Similar telegram to the American consul at Ensenada.</note>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Department of State</hi>, <lb/>
                                        <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-02-03">
                                        <hi rend="italic">February 3, 1915</hi></date>.</dateline>
                            </opener>
                            <p>At request Chinese Minister ask Villa order authorities Mexicali
                                repeal law claimed to be unjust and discriminatory requiring Chinese
                                residents pay monthly tax two dollars.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Bryan.</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>