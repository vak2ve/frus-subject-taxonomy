<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-08-24T23:59:59-05:00" frus:doc-dateTime-min="1915-08-24T00:00:00-05:00" n="694" subtype="historical-document" type="document" xml:id="d694">
                        <note rend="inline" type="source">File No. 365.117/135.</note>
                        <head>
                            <hi rend="italic">Ambassador <persName type="from">Page</persName> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                                    <hi rend="italic">Rome</hi></placeName>, <date calendar="gregorian" when="1915-08-24">
                                    <hi rend="italic">August 24, 1915</hi></date>.</dateline>
                        </opener>
                        <p>383. Referring Department’s 282, July 12. Foreign Office reports today Da
                            Prato has been released.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Nelson Page.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>