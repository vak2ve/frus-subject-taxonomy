                subtype="historical-document" type="document" xml:id="d493">
                <note rend="inline" type="source">File No. 838.00/1084.</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Sullivan</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1915-01-18">
                            <hi rend="italic">January 18, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>I am informed by Receivership that Dominicans under Julio Castillo are supporting
                    Haitian revolution. Have informed Dominican Government and am promised speedy
                    action to prevent this activity.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sullivan</hi>.</signed>
                </closer>
            </div>
        </body>
