                subtype="historical-document" type="document" xml:id="d906">
                <note rend="inline" type="source">File No. 812.00/15273.</note>
                <head>
                    <hi rend="italic">Consul <persName type="from">Guyant</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Ensenada</hi>
                        </placeName>, <date calendar="gregorian" when="1915-06-12">
                            <hi rend="italic">June 12, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    the Department’s telegram of June 2, 1915, quoting the message of the President
                    to the Mexican revolutionary chiefs. The message has been given publicity in
                    this District and has been favorably commented upon by Mexicans.</p>
                <p>I have [etc]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Claude E. Guyant.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
