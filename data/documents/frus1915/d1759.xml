                subtype="historical-document" type="document" xml:id="d1759">
                <note rend="inline" type="source">File No. 419.11D29/79.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Price</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-03-10">
                            <hi rend="italic">March 10, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>Your March 5. Unless you perceive serious objection, comply instruction 104 so
                    amended as to apply final action all courts concerned in inquiry.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan.</hi>
                    </signed>
                </closer>
            </div>
        </body>
