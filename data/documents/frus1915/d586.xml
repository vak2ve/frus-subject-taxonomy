                subtype="historical-document" type="document" xml:id="d586">
                <note rend="inline" type="source">File No. 838.516/28.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Blanchard</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-01-04T12:00:00-05:00">
                            <hi rend="italic">January 4, 1915—noon</hi>
                        </date>.</dateline>
                </opener>
                <p>We understand threats are made against Williams and other employees of the Bank.
                    Keep in constant communication with the Bank and notify the Government that you
                    are instructed not to permit harm to be done to any American or other foreign
                    employee. Keep us constantly advised of situation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
