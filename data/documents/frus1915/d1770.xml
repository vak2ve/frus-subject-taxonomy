                subtype="historical-document" type="document" xml:id="d1770">
                <note rend="inline" type="source">File No. 419.11D29/93.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Price</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-05-20">
                            <hi rend="italic">May 20, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>Your May 18. Report what pending cases you consider possible of settlement by
                    agreement.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan.</hi>
                    </signed>
                </closer>
            </div>
        </body>
