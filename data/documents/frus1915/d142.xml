<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-05-08T20:00:00-05:00" frus:doc-dateTime-min="1915-05-08T20:00:00-05:00" n="142" subtype="historical-document" type="document" xml:id="d142">
                        <note rend="inline" type="source">File No. 793.94/342.</note>
                        <head>
                            <hi rend="italic">Chargé <persName type="from">Wheeler</persName> to the
                                    <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                                    <hi rend="italic">Tokyo</hi></placeName>, <date calendar="gregorian" when="1915-05-09T10:00:00+09:00">
                                    <hi rend="italic">May 9, 1915—10 a.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Japanese Minister for Foreign Affairs informs me that a telegram has been
                            received from Hioki in Peking stating that the Chinese Government has
                            unconditionally accepted the ultimatum.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Wheeler.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>