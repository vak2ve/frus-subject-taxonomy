<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-12-21T23:59:59-05:00" frus:doc-dateTime-min="1915-12-21T00:00:00-05:00" n="1219" subtype="historical-document" type="document" xml:id="d1219">
                        <note rend="inline" type="source">File No. 312.11/7108.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of the Navy</gloss>
                                to Admiral <persName type="to">Winslow</persName></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Navy Department</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-12-21">
                                    <hi rend="italic">December 21, 1915</hi></date>.</dateline>
                        </opener>
                        <p>Troops will not be landed without instructions from the Department. It is
                            desired that you keep the Department fully informed as to
                            conditions.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Daniels.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>