                subtype="historical-document" type="document" xml:id="d1429">
                <note rend="inline" type="source">File No. 312.115/113.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Special
                        Agent <persName type="to">Carothers</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-01-14">
                            <hi rend="italic">January 14, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>Penn-Mex Company, American Corporation, reports General Peláez, assuming to
                    represent Villa vicinity Tuxpam, seized company’s payroll because failure to pay
                    demanded contribution 50,000 pesos.</p>
                <p>Please request Villa to order withdrawal demand, restoration company’s property,
                    adequate protection thereto, with permission continue operations.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan.</hi>
                    </signed>
                </closer>
            </div>
        </body>
