<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-10-14T23:59:59-05:00" frus:doc-dateTime-min="1915-10-14T00:00:00-05:00" n="704" subtype="historical-document" type="document" xml:id="d704">
                        <note rend="inline" type="source">File No. 365.117/183.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Ambassador <persName type="to">Page</persName></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-10-14">
                                    <hi rend="italic">October 14, 1915</hi></date>.</dateline>
                        </opener>
                        <p>351 Your 408, October 11. Mazza’s father not naturalized. Declared
                            intention October 31, 1896.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>