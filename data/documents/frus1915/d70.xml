<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-01-28T16:00:00-05:00" frus:doc-dateTime-min="1915-01-28T16:00:00-05:00" n="70" subtype="historical-document" type="document" xml:id="d70">
                        <note rend="inline" type="source">File No. 793.94/214.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Reinsch</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-01-28T16:00:00-05:00">
                                    <hi rend="italic">January 28, 1915—4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Your telegrams of January 23, 7 p.m., January 24, 2 a.m., January 26, 8
                            p.m. The matter is having careful and prompt attention. Keep the
                            Department fully informed.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>