                <note rend="inline" type="source">File No. 812.001H87/40.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Confidential Agent of the Provisional Government of
                            Mexico</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-07-10">
                            <hi rend="italic">July 10, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has received your letter of July
                    3, in relation to the desired extradition of General Victoriano Huerta.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
