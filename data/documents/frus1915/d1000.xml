<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-10-18T23:59:59-05:00" frus:doc-dateTime-min="1915-10-18T00:00:00-05:00" n="1000" subtype="historical-document" type="document" xml:id="d1000">
                        <note rend="inline" type="source">File No. 812.00/17556a.</note>
                        <head>
                            <hi rend="italic">Secretary <persName type="from">Crane</persName> to
                                the <gloss type="to">Ambassador of Argentina</gloss>.</hi><note n="48" xml:id="d1000fn48">The same to the other conferees.</note>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-10-18">
                                    <hi rend="italic">October 18, 1915</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My dear Mr. Ambassador</hi>: Confirming my
                            telephone conversation of Saturday, I have the honor to inform you that
                            a meeting of the Conferees on the Mexican situation has been called by
                            the Secretary of State to assemble at the Department this afternoon at
                            three o’clock.</p>
                        <p>I am [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Richard Crane</hi>. <lb/>
                                <hi rend="italic">Private Secretary.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>