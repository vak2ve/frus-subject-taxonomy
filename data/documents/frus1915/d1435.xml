<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-02-24T23:59:59-05:00" frus:doc-dateTime-min="1915-02-24T00:00:00-05:00" n="1435" subtype="historical-document" type="document" xml:id="d1435">
                        <note rend="inline" type="source">File No. 312.115/123.</note>
                        <head>
                            <hi rend="italic">Vice Consul <persName type="from">Davis</persName> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Guadalajara</hi></placeName>, <date calendar="gregorian" when="1915-02-24">
                                    <hi rend="italic">February 24, 1915</hi></date>.</dateline>
                        </opener>
                        <p>General, Northern Division, called meeting foreigners for the purpose of
                            exacting contributions support of the army. I objected as to Americans,
                            withdrawing from meeting.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Davis.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>