                subtype="historical-document" type="document" xml:id="d803">
                <note rend="inline" type="source">File No. 812.00/14252a.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Brazilian Minister to Mexico</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-01-21">
                            <hi rend="italic">January 21, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>417. Please refer to my number 360, December 16,<note n="3" xml:id="d803fn3">See
                            <ref target="frus1914#pg_633">For. Rel. 1914, p. 633</ref>.</note> and
                    present the same instructions, therein conveyed, to Provisional President
                    Garza.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. J. Bryan.</hi>
                    </signed>
                </closer>
            </div>
        </body>
