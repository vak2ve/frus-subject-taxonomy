<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-03-08T23:59:59-05:00" frus:doc-dateTime-min="1915-03-08T00:00:00-05:00" n="1250" subtype="historical-document" type="document" xml:id="d1250">
                        <note rend="inline" type="source">File No. 812.6363/178.</note>
                        <head>
                            <hi rend="italic">Consul <persName type="from">Canada</persName> to the
                                    <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Vera Cruz</hi></placeName>, <date calendar="gregorian" when="1915-03-08">
                                    <hi rend="italic">March 8, 1915</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge receipt
                            of the Department’s telegraphic instructions of January 13, 1915,
                            protesting against the application to Americans and other foreigners of
                            the decree suspending the operation of oil wells, and to transmit
                            enclosed herewith the reply of the Constitutionalist Foreign Office to
                            my representations.</p>
                        <p>I have [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Wm. W. Canada.</hi>
                            </signed>
                        </closer>
                        <frus:attachment>
                            <opener>
                                <seg rendition="#center">[Inclosure—Translation.]</seg>
                            </opener>
                            <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Department of Foreign Relations</hi>, <lb/>
                                        <hi rend="italic">Vera Cruz</hi></placeName>, <date calendar="gregorian" when="1915-01-14">
                                        <hi rend="italic">January 14, 1915</hi></date>.</dateline>
                            </opener>
                            <p>
                                <hi rend="smallcaps">Mr. Consul</hi>: Answering your note of
                                yesterday’s date, in which in the name of your Government you
                                formulate a protest with regard to the suspension of work on oil
                                wells, I inform you that due note has been taken of your
                                protest.</p>
                            <p>Please accept [etc.]</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">M. Dávalos</hi>.</signed>
                            </closer>
                        </frus:attachment>
                    </div>
                    </body></text></TEI>