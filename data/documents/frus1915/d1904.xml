                <note rend="inline" type="source">File No. 367.54/18.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                        Ambassador <persName type="to">Morgenthau</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-03-04">
                            <hi rend="italic">March 4, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>459. In view of situation in Turkey, Swiss Minister here requests that you use
                    your good offices to afford Swiss citizens in Turkey ample protection.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan.</hi>
                    </signed>
                </closer>
            </div>
        </body>
