<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-09-04T23:59:59-05:00" frus:doc-dateTime-min="1915-09-04T00:00:00-05:00" n="1347" subtype="historical-document" type="document" xml:id="d1347">
                        <note rend="inline" type="source">File No. 812.512/784.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Acting Consul General <persName type="to">Robertson</persName></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-09-04">
                                    <hi rend="italic">September 4, 1915</hi></date>.</dateline>
                        </opener>
                        <p>Silliman telegraphs September 1 as follows in reply Department’s telegram
                            August 31 communicating your August 28:</p>
                        <p>[Quotes Mr. Silliman’s telegram of September 1.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing.</hi>
                            </signed>
                        </closer>
