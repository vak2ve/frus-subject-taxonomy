                subtype="historical-document" type="document" xml:id="d107">
                <note rend="inline" type="source">File No. 793.94/251.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                        Ambassador <persName type="to">Guthrie</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-03-17T17:00:00-05:00">
                            <hi rend="italic">March 17, 1915—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your telegram of March 17, 1 p.m. Our note was not presented at the request or
                    suggestion of China or any other Power.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan.</hi>
                    </signed>
                </closer>
            </div>
        </body>
