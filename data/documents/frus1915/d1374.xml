<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-11-27T23:59:59-05:00" frus:doc-dateTime-min="1915-11-27T00:00:00-05:00" n="1374" subtype="historical-document" type="document" xml:id="d1374">
                        <note rend="inline" type="source">File No. 812.512/911.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Mr. <persName type="to">Parker</persName>,
                                representing American interests in Mexico</hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-11-27">
                                    <hi rend="italic">November 27, 1915</hi></date>.</dateline>
                        </opener>
                        <p>145. Your telegram 161, November 22. On ground of injustice to American
                            interests, protest against proposed increase in mining taxes.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Polk.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>