                subtype="historical-document" type="document" xml:id="d892">
                <note rend="inline" type="source">File No. 812.00/15135.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Special
                        Agent <persName type="to">Silliman</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-06-05T10:00:00-05:00">
                            <hi rend="italic">June 5, 1915—10 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Communicate immediately to Carranza the following message received through
                    Brazilian Minister, Mexico City:</p>
                <p>[Message for Carranza forwarded in Mr. Cardoso de Oliveira’s telegram 603 of June
                    4, 10 a.m.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan.</hi>
                    </signed>
                </closer>
            </div>
        </body>
