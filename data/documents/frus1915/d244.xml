                subtype="historical-document" type="document" xml:id="d244">
                <note rend="inline" type="source">File No. 839.00/1657.</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Sullivan</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegrams.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1915-02-09T22:00:00-04:40">
                            <hi rend="italic">February 9, 1915—10 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Peace prevails at Puerto Plata. Government officials installed. Dominican
                    Government expresses appreciation of helpful assistance given by Commander of
                        <hi rend="italic">Castine.</hi>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sullivan.</hi>
                    </signed>
                </closer>
            </div>
        </body>
