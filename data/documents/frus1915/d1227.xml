<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-05-13T23:59:59-05:00" frus:doc-dateTime-min="1915-05-13T00:00:00-05:00" n="1227" subtype="historical-document" type="document" xml:id="d1227">
                        <note rend="inline" type="source">File No. 312.112M22/32.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">Brazilian Minister to
                            Mexico</gloss></hi>.</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-05-13">
                                    <hi rend="italic">May 13, 1915</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your No. 149 of April 16, transmitting correspondence
                            regarding the payment of indemnity by the Administration of the
                            Convention for the death of John B. McManus, which has been read with
                            interest.</p>
                        <p>Thanking you [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">W. J. Bryan.</hi>
                            </signed>
                        </closer>
                    </div>
                </body></text></TEI>