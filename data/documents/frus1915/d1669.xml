                <note rend="inline" type="source">File No. 312.67/58.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Mr.
                            <persName type="to">J. E. Touche</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-09-17">
                            <hi rend="italic">September 17, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>Carothers, El Paso, and Consul, Chihuahua, instructed render good offices your
                    behalf.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing.</hi>
                    </signed>
                </closer>
            </div>
        </body>
