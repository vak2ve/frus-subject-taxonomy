                subtype="historical-document" type="document" xml:id="d580">
                <note rend="inline" type="source">File No. 838.00/1373.</note>
                <head>
                    <hi rend="italic">Admiral <persName type="from">Caperton</persName> to the
                            <gloss type="to">Secretary of the Navy</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegrams.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1915-11-22">
                            <hi rend="italic">November 22, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>All operations except protective patrolling have been suspended. Directions have
                    been given that loss of life both sides be avoided if possible.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caperton</hi>.</signed>
                </closer>
            </div>
        </body>
