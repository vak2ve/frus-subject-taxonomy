<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-04-25T09:49:00-05:00" frus:doc-dateTime-min="1915-04-25T09:49:00-05:00" n="522" subtype="historical-document" type="document" xml:id="d522">
                        <note rend="inline" type="source">File No. 838.00/1158.</note>
                        <head>
                            <hi rend="italic">Consul <persName type="from">Livingston</persName> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegrams.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Cape Haitien</hi></placeName>, <date calendar="gregorian" when="1915-04-25T10:00:00-04:49">
                                    <hi rend="italic">April 25, 1915—10 a.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Government troops at Fort Liberté revolted and marching in direction Cape
                            Haitien.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Livingston</hi>.</signed>
                        </closer>
                    </div>
