                subtype="historical-document" type="document" xml:id="d711">
                <note rend="inline" type="source">File No. 894.001Y8/9.</note>
                <head>
                    <hi rend="italic">Chargé <persName type="from">Wheeler</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1915-04-21">
                            <hi rend="italic">April 21, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to report that, the period of
                    mourning for the late Empress. Dowager having ended, the date of the coronation
                    of the Emperor has been officially announced, the ceremonies to take place at
                    Kyoto on November 15 next.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Post Wheeler.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
