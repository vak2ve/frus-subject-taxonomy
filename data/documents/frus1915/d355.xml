<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-10-13T15:14:00-05:00" frus:doc-dateTime-min="1915-10-13T15:14:00-05:00" n="355" subtype="historical-document" type="document" xml:id="d355">
                        <note rend="inline" type="source">File No. 422.11G93/813.</note>
                        <head>
                            <hi rend="italic">Minister <persName type="from">Hartman</persName> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Quito</hi></placeName>, <date calendar="gregorian" when="1915-10-13T15:00:00-05:14">
                                    <hi rend="italic">October 13, 1915—3 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Department’s October 11, 6 p.m. Formal protest delivered to the Minister
                            for Foreign Affairs this morning.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hartman</hi>.</signed>
                        </closer>
                    </div>
