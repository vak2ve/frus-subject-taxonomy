<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-08-28T21:00:00-05:00" frus:doc-dateTime-min="1915-08-28T21:00:00-05:00" n="560" subtype="historical-document" type="document" xml:id="d560">
                        <note rend="inline" type="source">File No. 838.00/1277.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Chargé <persName type="to">Johnson</persName></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-08-28T21:00:00-05:00">
                                    <hi rend="italic">August 28, 1915—9 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Department has no objection to Bobo being landed at Santiago de Cuba.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>