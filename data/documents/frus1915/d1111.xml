                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Consulate</hi>, <lb/>
                            <hi rend="italic">Nogales</hi>
                        </placeName>, <date calendar="gregorian" when="1915-11-26T13:00:00-07:23">
                            <hi rend="italic">November 26, 1915—1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Nogales occupied by Carrancistas. Order restored.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Simpich.</hi>
                    </signed>
                </closer>
