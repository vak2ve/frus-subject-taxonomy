<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-08-19T23:59:59-05:00" frus:doc-dateTime-min="1915-08-19T00:00:00-05:00" n="452" subtype="historical-document" type="document" xml:id="d452">
                        <note rend="inline" type="source">File No. 711.38/58a.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Chargé <persName type="to">Davis</persName></hi>.</head>
                        <opener>
                            <seg rendition="#left">No. 36.]</seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-08-19">
                                    <hi rend="italic">August 19, 1915</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: Referring to the Department’s telegram of
                            the 14th instant, I enclose herewith the President’s full power<note n="5" xml:id="d452fn5">Printed in the telegram referred to.</note>
                            authorizing you to negotiate and sign the treaty mentioned in that
                            telegram.</p>
                        <p>I am [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Robert Lansing</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>