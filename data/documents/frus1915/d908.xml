<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-06-13T23:59:59-05:00" frus:doc-dateTime-min="1915-06-13T00:00:00-05:00" n="908" subtype="historical-document" type="document" xml:id="d908">
                        <note rend="inline" type="source">File No. 812.00/15312.</note>
                        <head>
                            <hi rend="italic">Consul <persName type="from">Bonney</persName> to the
                                    <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Extract.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">San Luis Potosi</hi></placeName>, <date calendar="gregorian" when="1915-06-13">
                                    <hi rend="italic">June 13, 1915</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to report that the note
                            addressed by President Wilson to leaders of factions in Mexico, as
                            published, was well received by all classes, and in this district is
                            regarded as an exceedingly fortunate expression.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Wilbert L. Bonney.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>