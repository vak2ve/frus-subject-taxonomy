<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-03-09T23:59:59-05:00" frus:doc-dateTime-min="1915-03-09T00:00:00-05:00" n="1251" subtype="historical-document" type="document" xml:id="d1251">
                        <note rend="inline" type="source">File No. 812.6363/174.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Special Agent <persName type="to">Silliman</persName></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-03-09">
                                    <hi rend="italic">March 9, 1915</hi></date>.</dateline>
                        </opener>
                        <p>See Canada’s March 6. Make vigorous protest against threatened
                            destruction. Request appropriate immediate orders.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">W. J. Bryan.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>