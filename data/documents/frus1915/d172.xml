<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-12-31T23:59:59-05:00" frus:doc-dateTime-min="1915-12-31T00:00:00-05:00" n="172" subtype="historical-document" type="document" xml:id="d172">
                        <note rend="inline" type="source">File No. 893.811/202.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">American Red Cross</gloss>.</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-12-31">
                                    <hi rend="italic">December 31, 1915</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Gentlemen</hi>: I have to enclose herewith for your
                            information paraphrase of a telegram of December 30, 1915, from the
                            American Minister at Peking, relative to the proposed Huai River
                            Conservancy loan.</p>
                        <p>I am [etc.]</p>
                        <closer>For the Secretary of State: <lb/>
                            <signed>
                                <hi rend="smallcaps">Alvey A. Adee.</hi>
                            </signed>
                        </closer>
                    </div>
                </body></text></TEI>