<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-12-11T23:59:59-05:00" frus:doc-dateTime-min="1915-12-11T00:00:00-05:00" n="715" subtype="historical-document" type="document" xml:id="d715">
                        <note rend="inline" type="source">File No. 894.001Y8/28a.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Ambassador <persName type="to">Guthrie</persName></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegrams.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-12-11">
                                    <hi rend="italic">December 11, 1915</hi></date>.</dateline>
                        </opener>
                        <p>You are instructed to express to the Japanese Government thanks of the
                            American people for courtesies extended to American diplomatic and naval
                            representation during ceremonies and festivities in honor of the formal
                            accession of the Emperor.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>