                subtype="historical-document" type="document" xml:id="d995">
                <note rend="inline" type="source">File No. 812.00/16597.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Minister of Bolivia</gloss> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Bolivia</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-10-13">
                            <hi rend="italic">October 13, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My dear Mr. Secretary</hi>: I am pleased to advise you that
                    I am authorized by my Government to recognize Carranza, and am ready to act in
                    the matter as soon as will decide [sic].</p>
                <p>I remain [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Y. Calderón.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
