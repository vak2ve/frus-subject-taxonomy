    <text>
        <body>
            <div frus:doc-dateTime-max="1915-03-06T23:59:59-05:00"
                frus:doc-dateTime-min="1915-03-06T00:00:00-05:00" n="834"
                subtype="historical-document" type="document" xml:id="d834">
                <note rend="inline" type="source">File No. 812.00/14501.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Ambassador of Spain</gloss>.</hi>
                    <note n="9" xml:id="d834fn9">The same to the Ambassadors of Brazil, Germany and
                        Great Britain.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-03-06">
                            <hi rend="italic">March 6, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Ambassador</hi>: I desire to call to your
                    attention that in view of the peril to Americans in Mexico City the Department
                    is tonight telegraphing to Mexico City and Vera Cruz messages for delivery to
                    General Carranza and General Obregon to the effect that this Government will
                    hold them personally responsible for their conduct.</p>
                <p>Sincerely yours,</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
