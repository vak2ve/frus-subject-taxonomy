                <note rend="inline" type="source">File No. 882.00/499.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                        Ambassador <persName type="to">Page</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-10-21">
                            <hi rend="italic">October 21, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>2320. Legation Monrovia reports <hi rend="italic">Highflyer</hi> put to sea
                    October 20. Take no further action with British Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing.</hi>
                    </signed>
                </closer>
            </div>
        </body>
