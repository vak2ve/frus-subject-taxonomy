                subtype="historical-document" type="document" xml:id="d1567">
                <note rend="inline" type="source">File No. 312.115/226.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                            <persName type="to">Alger</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-10-19">
                            <hi rend="italic">October 19, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>At request Spanish Embassy, ask General Diéguez to withdraw forced loan 100,000
                    pesos imposed on Bank of Mazatlan, majority of stock of which said to be owned
                    by Spaniards.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
