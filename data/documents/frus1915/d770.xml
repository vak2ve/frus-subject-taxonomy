<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-11-09T23:59:59-05:00" frus:doc-dateTime-min="1915-11-09T00:00:00-05:00" n="770" subtype="historical-document" type="document" xml:id="d770">
                        <note rend="inline" type="source">File No. 882.00/504.</note>
                        <head>
                            <hi rend="italic">Chargé <persName type="from">Bundy</persName> to the
                                    <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Monrovia</hi></placeName>, <date calendar="gregorian" when="1915-11-09">
                                    <hi rend="italic">November 9, 1915</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="italic">Chester</hi> arrived Monrovia yesterday.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bundy.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>