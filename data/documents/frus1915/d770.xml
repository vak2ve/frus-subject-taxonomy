                <note rend="inline" type="source">File No. 882.00/504.</note>
                <head>
                    <hi rend="italic">Chargé <persName type="from">Bundy</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1915-11-09">
                            <hi rend="italic">November 9, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="italic">Chester</hi> arrived Monrovia yesterday.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bundy.</hi>
                    </signed>
                </closer>
            </div>
        </body>
