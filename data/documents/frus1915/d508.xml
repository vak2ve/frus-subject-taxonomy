                subtype="historical-document" type="document" xml:id="d508">
                <note rend="inline" type="source">File No. 838.00/1124.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                            <persName type="to">Livingston</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-03-01">
                            <hi rend="italic">March 1, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>U. S. S. <hi rend="italic">Wheeling</hi> will arrive Cape Haitien Wednesday
                    morning, March 3, to take you Port au Prince. Be ready when vessel arrives.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>.</signed>
                </closer>
            </div>
        </body>
