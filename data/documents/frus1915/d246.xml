<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-03-27T13:00:00-05:00" frus:doc-dateTime-min="1915-03-27T13:00:00-05:00" n="246" subtype="historical-document" type="document" xml:id="d246">
                        <note rend="inline" type="source">File No. 839.00/1682.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Sullivan</persName>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-03-27T13:00:00-05:00">
                                    <hi rend="italic">March 27, 1915—1 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Your March 25, 10 a.m. Navy Department has directed fleet commander in
                            chief send gunboat Santo Domingo City.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>