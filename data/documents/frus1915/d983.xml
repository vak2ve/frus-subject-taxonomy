<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-09-13T23:59:59-05:00" frus:doc-dateTime-min="1915-09-13T00:00:00-05:00" n="983" subtype="historical-document" type="document" xml:id="d983">
                        <note rend="inline" type="source">File No. 812.00/17552a.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">Minister of Guatemala</gloss></hi>.<note n="43" xml:id="d983fn43">Similar communications to the other
                                conferees.</note>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-09-13">
                                    <hi rend="italic">September 13, 1915</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Minister</hi>: I have arranged for a
                            meeting of the Conferees on the Mexican situation, to be held in my
                            office on September 15 at three o’clock. If you cannot arrange to be
                            present, please be good enough to let me know in advance.</p>
                        <p>I am [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Robert Lansing.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>