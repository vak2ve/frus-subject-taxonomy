<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-03-26T23:59:59-05:00" frus:doc-dateTime-min="1915-03-26T00:00:00-05:00" n="1255" subtype="historical-document" type="document" xml:id="d1255">
                        <note rend="inline" type="source">File No. 812.512/576.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Vice Consul <persName type="to">Bevan</persName></hi>.</head>
                        <opener>
                            <seg rendition="#left">No. 786.]</seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-03-26">
                                    <hi rend="italic">March 26, 1915</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: The Department has received your despatch
                            No. 1369 of March 6, 1915, transmitting a copy of a notice in regard to
                            the payments on the stamp tax for petroleum, [etc.].</p>
                        <p>You are instructed to report the developments in this case.</p>
                        <p>I am [etc.]</p>
                        <closer>For the Secretary of State: <lb/>
                            <signed>
                                <hi rend="smallcaps">Wilbur J. Carr.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>