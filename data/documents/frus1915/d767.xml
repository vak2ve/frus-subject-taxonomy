                subtype="historical-document" type="document" xml:id="d767">
                <note rend="inline" type="source">File No. 882.00/500.</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Page</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">London</hi>
                        </placeName>, <date calendar="gregorian" when="1915-10-21">
                            <hi rend="italic">October 21, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>3070. Your 2312, October 20. The British Government has telegraphed its Consul
                    General at Monrovia to instruct the commander of the <hi rend="italic"
                        >Highflyer</hi> to depart immediately unless disorder demands its
                    presence.</p>
                <closer>
                    <hi rend="smallcaps">American Ambassador.</hi>
                </closer>
            </div>
        </body>
