<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-03-25T09:40:00-05:00" frus:doc-dateTime-min="1915-03-25T09:40:00-05:00" n="245" subtype="historical-document" type="document" xml:id="d245">
                        <note rend="inline" type="source">File No. 839.00/1682.</note>
                        <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Santo Domingo</hi></placeName>, <date calendar="gregorian" when="1915-03-25T10:00:00-04:40">
                                    <hi rend="italic">March 25, 1915—10 a.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>I believe highly desirable that a gunboat be at this city as soon as
                            possible.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Sullivan.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>