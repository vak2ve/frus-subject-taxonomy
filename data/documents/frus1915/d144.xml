<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-05-12T23:59:59-05:00" frus:doc-dateTime-min="1915-05-12T00:00:00-05:00" n="144" subtype="historical-document" type="document" xml:id="d144">
                        <note rend="inline" type="source">File No. 793.94/351a, b.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">Japanese Ambassador</gloss>.</hi><note n="50" xml:id="d144fn50">Mutatis mutandis to the Chinese Minister.</note>
                        </head>
                        <opener>
                            <seg rendition="#left">No. 118.]</seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-05-12">
                                    <hi rend="italic">May 12, 1915</hi></date>,</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Excellency</hi>: I have the honor to enclose
                            herewith for your information copy of a telegram sent by the Department
                            of State yesterday afternoon to the American Embassy at Tokyo, relative
                            to the treaty rights of the United States and its citizens in China in
                            connection with any agreement or undertaking which has been entered into
                            between the Governments of Japan and China as a result of the
                            negotiations which have recently been conducted between those two
                            Governments and which are still pending.</p>
                        <p>Accept [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">W. J. Bryan.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>