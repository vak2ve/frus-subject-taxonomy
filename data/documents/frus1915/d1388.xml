<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-03-23T23:59:59-05:00" frus:doc-dateTime-min="1915-03-23T00:00:00-05:00" n="1388" subtype="historical-document" type="document" xml:id="d1388">
                        <note rend="inline" type="source">File No. 812.512/582.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Consul <persName type="to">Guyant</persName></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-03-23">
                                    <hi rend="italic">March 23, 1915</hi></date>.</dateline>
                        </opener>
                        <p>Your 337, March 15. In addition to advice reported as given American
                            citizens, advise them make protest matter of record if possible and take
                            receipts.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>