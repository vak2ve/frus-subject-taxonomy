<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-10-13T23:59:59-05:00" frus:doc-dateTime-min="1915-10-13T00:00:00-05:00" n="1565" subtype="historical-document" type="document" xml:id="d1565">
                            <note rend="inline" type="source">File No. 312.52/702.</note>
                            <head>
                                <hi rend="italic">Special Agent <persName type="from">Belt</persName> to the <gloss type="to">Secretary of
                                        State</gloss></hi>.</head>
                            <opener>
                                <seg rendition="#center">[Telegram.]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Tampico</hi></placeName>, <date calendar="gregorian" when="1915-10-13">
                                        <hi rend="italic">October 13, 1915</hi></date>.</dateline>
                            </opener>
                            <p>Department’s October 2, property Felipe Muriedos, San Luis Potosí.
                                Foreign Office requests this case and future cases involving Spanish
                                subjects or interests be handled through Spanish representative who
                                is fully accredited before Constitutionalist Government.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">John W. Belt.</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>