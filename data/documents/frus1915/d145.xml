                subtype="historical-document" type="document" xml:id="d145">
                <note rend="inline" type="source">File No. 793.94/352.</note>
                <head>
                    <hi rend="italic">Chargé <persName type="from">Wheeler</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Tokyo</hi>
                        </placeName> [<date
                            ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                            calendar="gregorian" notAfter="1915-05-13T23:59:59-05:00"
                            notBefore="1915-05-12T00:00:00-05:00">
                            <hi rend="italic">not dated</hi>
                        </date>
                        <hi rend="italic">; received May 13, 1915.</hi>]</dateline>
                </opener>
                <p>Your cable of May 11, 5 p.m. Note was handed to Japanese Minister for Foreign
                    Affairs at 2.30 this afternoon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wheeler.</hi>
                    </signed>
                </closer>
            </div>
        </body>
