<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-06-02T23:59:59-05:00" frus:doc-dateTime-min="1915-06-02T00:00:00-05:00" n="1293" subtype="historical-document" type="document" xml:id="d1293">
                        <note rend="inline" type="source">File No. 812.63/105.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Special Agent <persName type="to">Silliman</persName></hi>.</head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-06-02">
                                    <hi rend="italic">June 2, 1915</hi></date>.</dateline>
                        </opener>
                        <p>Consul, Mazatlan, requests information about reported decree issued Vera
                            Cruz prohibiting exportation mine products. Investigate. Report.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>