                <note rend="inline" type="source">821.7961/18: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Colombia</hi> (<persName type="from">
                        <hi rend="italic">Caffery</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bogotá</hi>
                        </placeName>, <date calendar="gregorian" when="1929-03-01T16:00:00-05:00"
                            >March 1, 1929—4 p.m.</date>
                        <lb/>[Received 5 p.m.]</dateline>
                </opener>
                <p>29. Department’s 18, February 28, 7 p.m. Yes, on Wednesday.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caffery</hi>
                    </signed>
                </closer>
            </div>
        </body>
