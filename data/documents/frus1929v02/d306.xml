<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-12-02T17:00:00-05:00" frus:doc-dateTime-min="1929-12-02T17:00:00-05:00" n="306" subtype="historical-document" type="document" xml:id="d306">
                        <note rend="inline" type="source">861.77 Chinese Eastern/539:
                            Telegram</note>
                        <head><hi rend="italic">The Minister in Panama</hi> (<persName type="from"><hi rend="italic">South</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Panama</hi></placeName>, <date calendar="gregorian" when="1929-12-02T17:00:00-05:00">December 2, 1929—5
                                p.m.</date><lb/>[Received 6:30 p.m.]</dateline></opener>
                        <p>93. Minister for Foreign Affairs states Panaman Government will
                            immediately take the action indicated in penultimate sentence of your
                            circular December 1, 5 [<hi rend="italic">4</hi>] p.m.</p>
                        <closer>(Not signed)</closer>
                    </div>
                    </body></text></TEI>