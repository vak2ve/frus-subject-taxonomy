<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-07-12T15:00:00-05:00" frus:doc-dateTime-min="1929-07-12T15:00:00-05:00" n="770" subtype="historical-document" type="document" xml:id="d770">
                        <note rend="inline" type="source">811.91293/160: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in China</hi> (<persName type="to"><hi rend="italic">MacMurray</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1929-07-12T16:00:00-04:00">July 12, 1929—4
                                p.m.</date></dateline></opener>
                        <p>229. Your 556, July 10, 7 p.m. Withhold action Abend case until further
                            instructions. After communicating complaint to <hi rend="italic">New
                                York Times</hi> Department is awaiting further word from the <hi rend="italic">Times</hi>.</p>
                        <closer><signed><hi rend="smallcaps">Stimson</hi></signed></closer>
                    </div>
                    </body></text></TEI>