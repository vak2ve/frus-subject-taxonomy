                subtype="historical-document" type="document" xml:id="d403">
                <note rend="inline" type="source">861.77 Chinese Eastern/755: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName type="from">
                        <hi rend="italic">Perkins</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1929-12-28T13:00:00+08:00"
                            >December 28, 1929—1 p.m.</date>
                        <lb/>[Received December 28—10:35 a.m.]</dateline>
                </opener>
                <p>1196. Legation’s 1185, December 24, noon.<note n="17a" xml:id="d403fn17a">Not
                        printed.</note> Japanese Embassy in Moscow has been informed by the Soviet
                    Foreign Office that all Soviet troops in Manchuria were withdrawn on December
                    23rd.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Perkins</hi>
                    </signed>
                </closer>
            </div>
        </body>
