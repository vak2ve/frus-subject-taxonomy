    <text>
        <body>
            <div frus:doc-dateTime-max="1929-02-06T23:59:59-05:00"
                frus:doc-dateTime-min="1929-02-06T00:00:00-05:00" n="800"
                subtype="historical-document" type="document" xml:id="d800">
                <note rend="inline" type="source">611.9331/153</note>
                <head>
                    <hi rend="italic">The Chinese Minister for Foreign Affairs</hi> (<persName
                        type="from">
                        <hi rend="italic">C. T. Wang</hi>
                    </persName>) <hi rend="italic">to the Counselor of the American Legation in
                        China</hi> (<persName type="to">
                        <hi rend="italic">Perkins</hi>
                    </persName>)<note n="10" xml:id="d800fn10">Copy transmitted to the Department by
                        the Minister in China in his despatch No. 1919, February 15; received March
                        18, 1929.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Translation]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1929-02-06">February 6,
                            1929</date>.</dateline>
                    <seg rendition="#left">660</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of today’s date, reading as follows:</p>
                <p>[Here follows the text of note printed, <hi rend="italic">supra</hi>.]</p>
                <p>I hereby confirm that such is the National Government’s understanding of the
                    purport and intent of this treaty.</p>
                <p>I avail myself [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Chengting T. Wang</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
