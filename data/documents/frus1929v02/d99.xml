<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-07-18T01:00:00-05:00" frus:doc-dateTime-min="1929-07-18T01:00:00-05:00" n="99" subtype="historical-document" type="document" xml:id="d99">
                        <note rend="inline" type="source">861.77 Chinese Eastern/34: Telegram</note>
                        <head><hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">MacMurray</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1929-07-18T14:00:00+08:00">July 18, 1929—2
                                p.m.</date><lb/>[Received July 18—10:45 a.m.]</dateline></opener>
                        <p>584. My 583[bis], July 17, midnight. Following from American Consul at
                            Harbin: <quote rend="blockquote">
                                <p>“July 16, noon. Soviet ultimatum published here by Japanese news
                                    agency last evening. Yesterday afternoon Chinese authorities
                                    closed and took over railway’s four libraries here. Arriving
                                    passengers report mobilization Soviet troops at Irkutsk and
                                    Chita.”</p>
                            </quote></p>
                        <closer><signed><hi rend="smallcaps">MacMurray</hi></signed></closer>
                    </div>
                    </body></text></TEI>