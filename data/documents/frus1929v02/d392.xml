<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-12-18T06:00:00-05:00" frus:doc-dateTime-min="1929-12-18T06:00:00-05:00" n="392" subtype="historical-document" type="document" xml:id="d392">
                        <note rend="inline" type="source">861.77 Chinese Eastern/707:
                            Telegram</note>
                        <head><hi rend="italic">The Chargé in China</hi> (<persName type="from"><hi rend="italic">Perkins</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peiping</hi></placeName>, <date calendar="gregorian" when="1929-12-18T19:00:00+08:00">December 18, 1929—7
                                p.m.</date><lb/>[Received December 18—2 p.m.]</dateline></opener>
                        <p>1167. My 1160, December 18, 11 a.m. Following from American Consul,
                            Harbin: <quote rend="blockquote">
                                <p>“December 18, 11 a.m. International car has been ordered to
                                    return to Buketu by the Chinese military command. It appears
                                    that Red Mongol detachment started an encircling movement which
                                    forced Chinese military to withdraw on the [railway?] to
                                    Mientuho, possibly to Buketu.”</p>
                            </quote></p>
                        <closer><signed><hi rend="smallcaps">Perkins</hi></signed></closer>
                    </div>
                    </body></text></TEI>