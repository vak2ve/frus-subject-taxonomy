                        <head>90. Summary of Conclusions of a Washington Special Actions Group
                                Meeting<note n="1" type="source" xml:id="d90fn1">Source: National
                                Archives, <persName corresp="#p_NRM1">Nixon</persName> Presidential
                                Materials, <gloss target="#t_NSC1">NSC</gloss> Files, <gloss target="#t_NSC1">NSC</gloss> Institutional Files (H-Files), Box
                                H–116, Washington Special Actions Group, <gloss target="#t_WSAG1">WSAG</gloss> Minutes (Originals) 1–3–72 to 7–24–72. Top Secret;
                                Sensitive. The meeting took place in the White House Situation
                                Room.</note>
                        </head>
                        <opener><dateline rendition="#right">
                                <placeName>Washington</placeName>, <date calendar="gregorian" from="1972-04-20T10:05:00-05:00" to="1972-04-20T11:31:00-05:00">April 20, 1972, 10:05–11:31 a.m.</date>
                            </dateline></opener>
                        <list type="subject">
                            <head>SUBJECT</head>
                            <item>Vietnam</item>
                        </list>
                        <list type="participants">
                            <head>PARTICIPANTS</head>
                            <item>Chairman</item>
                            <item>Maj. Gen. <persName corresp="#p_HAM1">Alexander Haig</persName>
                            </item>
                            <item>State</item>
                            <item>
                                <persName corresp="#p_JUA1">U. Alexis Johnson</persName>
                            </item>
                            <item>
                                <persName corresp="#p_SWH1">William Sullivan</persName>
                            </item>
                            <item>Defense</item>
                            <item>
                                <persName corresp="#p_RK1">Kenneth Rush</persName>
                            </item>
                            <item>
                                <persName corresp="#p_NGW1">G. Warren Nutter</persName>
                            </item>
                            <item>R/Adm. William R. Flanagan</item>
                            <item>
                                <gloss target="#t_JCS1">JCS</gloss>
                            </item>
                            <item>Adm. <persName corresp="#p_MTH1">Thomas H. Moorer</persName>
                            </item>
                            <item>
                                <gloss target="#t_CIA1">CIA</gloss>
                            </item>
                            <item>
                                <persName corresp="#p_CGA1">George Carver</persName>
                            </item>
                            <item>
                                <gloss target="#t_NSC1">NSC</gloss>
                            </item>
                            <item>
                                <persName corresp="#p_KRT1">Richard T. Kennedy</persName>
                            </item>
                            <item>
                                <persName corresp="#p_HJH1">John H. Holdridge</persName>
                            </item>
