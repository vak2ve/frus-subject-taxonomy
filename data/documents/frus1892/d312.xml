    <text>
        <body>
            <div frus:doc-dateTime-max="1892-03-04T23:59:59-05:00"
                frus:doc-dateTime-min="1892-03-04T00:00:00-05:00" n="312"
                subtype="historical-document" type="document" xml:id="d312">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr. <persName
                            type="to">Smith</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-03-04">
                            <hi rend="italic">March 4, 1892</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="italic">Indiana</hi> consigned R. W. Sargent, her captain; cargo,
                    29,144 sacks flour, 383 packages provisions; total, 2,130 tons.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blaine.</hi>
                    </signed>
                </closer>
            </div>
        </body>
