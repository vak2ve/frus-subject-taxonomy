    <text>
        <body>
            <div frus:doc-dateTime-max="1892-01-14T23:59:59-05:00" frus:doc-dateTime-min="1892-01-14T00:00:00-05:00" n="168" subtype="historical-document" type="document" xml:id="d168">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr.
                                <persName type="to">Lincoln</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-01-14">
                            <hi rend="italic">January 14,
                            1892</hi>
                        </date>.</dateline>
                </opener>
                <p>Express deep regret and sincere condolences of the President by reason of the
                        lamented death of the Duke of Clarence and Avondale.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blaine.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
