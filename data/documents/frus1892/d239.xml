<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1892-08-19T23:59:59-05:00" frus:doc-dateTime-min="1892-08-19T00:00:00-05:00" n="239" subtype="historical-document" type="document" xml:id="d239">
                        <head><hi rend="italic">Mr. <persName type="from">Foster</persName> to Mr.
                                    <persName type="to">Herbert</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram].</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1892-08-19"><hi rend="italic">August 19,
                                1892</hi></date>.</dateline></opener>
                        <p>You can see me any hour in the morning between 8 and 11.</p>
                        <closer><signed><hi rend="smallcaps">John W. Foster.</hi></signed></closer>
                    </div>
                    </body></text></TEI>