    <text>
        <body>
            <div frus:doc-dateTime-max="1892-01-29T23:59:59-05:00"
                frus:doc-dateTime-min="1892-01-29T00:00:00-05:00" n="65"
                subtype="historical-document" type="document" xml:id="d65">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr. <persName
                            type="to">Denby</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-01-29">
                            <hi rend="italic">January 29, 1892</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 697.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department is highly gratified to learn by
                    your No. 1441, of 8th ultimo, of the practical suppression of the rebellion in
                    Mongolia.</p>
                <p>You will take occasion to communicate to the Yamen such expression as you may
                    deem proper of the satisfaction which this intelligence has afforded to the
                    Government and people of the United States.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">James G. Blaine</hi>.</signed>
                </closer>
            </div>
        </body>
