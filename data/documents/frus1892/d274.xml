    <text>
        <body>
            <div frus:doc-dateTime-max="1892-01-07T23:59:59-05:00" frus:doc-dateTime-min="1892-01-07T00:00:00-05:00" n="274" subtype="historical-document" type="document" xml:id="d274">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Durham</persName> to Mr.
                                <persName type="to">Blaine</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of
                                    the United States</hi>,<lb/>
                            <hi rend="italic">Port au Prince,
                                    Haiti</hi>
                        </placeName>, <date calendar="gregorian" when="1892-01-07">
                            <hi rend="italic">January 7, 1892</hi>
                        </date>.
                            (Received January 26, 1892.)</dateline>
                    <seg rendition="#left">No. 36.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I regret to have to inform you that the
                        political situation here is uncertain. Two refugees have already asked the
                        asylum of my residence at Turgeau.</p>
                <p>I am etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John S. Durham.</hi>
                    </signed>
                </closer>
            </div>
        </body>
