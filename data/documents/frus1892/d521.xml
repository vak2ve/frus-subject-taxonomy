    <text>
        <body>
            <div frus:doc-dateTime-max="1892-09-10T23:59:59-05:00" frus:doc-dateTime-min="1892-09-10T00:00:00-05:00" n="521" subtype="historical-document" type="document" xml:id="d521">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Señor
                                    <persName type="to">Bolet Peraza</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-09-10">
                            <hi rend="italic">September 10,
                                    1892</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="italic">South Portland</hi> held for investigation. Your proofs
                            of violation of neutrality should he exhibited to collector without
                            delay.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alvey A. Adee</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
