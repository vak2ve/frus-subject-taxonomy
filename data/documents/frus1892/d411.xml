    <text>
        <body>
            <div frus:doc-dateTime-max="1892-02-10T23:59:59-05:00" frus:doc-dateTime-min="1892-02-10T00:00:00-05:00" n="411" subtype="historical-document" type="document" xml:id="d411">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr.
                                <persName type="to">Hirsch</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-02-10">
                            <hi rend="italic">February 10,
                            1892</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 281.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your No.
                        379 of 22d ultimo, and to approve the note of 21st ultimo, in which you
                        protest against the provisions of a ministerial order recently sent to the
                        provinces concerning the conditions for opening and maintaining schools, as
                        not warranted.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">James G. Blaine.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
