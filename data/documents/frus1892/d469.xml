    <text>
        <body>
            <div frus:doc-dateTime-max="1892-09-07T23:59:59-05:00"
                frus:doc-dateTime-min="1892-09-07T00:00:00-05:00" n="469"
                subtype="historical-document" type="document" xml:id="d469">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Foster</persName> to Mr. <persName
                            type="to">Newberry</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-09-07">
                            <hi rend="italic">September 7, 1892</hi>
                        </date>.</dateline>
                </opener>
                <p>You are authorized to accept the proposition of Turkish Government to pay £350
                    for house and £250 indemnity.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Foster.</hi>
                    </signed>
                </closer>
            </div>
        </body>
