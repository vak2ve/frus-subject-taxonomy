    <text>
        <body>
            <div frus:doc-dateTime-max="1892-06-01T23:59:59-05:00" frus:doc-dateTime-min="1892-06-01T00:00:00-05:00" n="448" subtype="historical-document" type="document" xml:id="d448">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr.
                                <persName type="to">Hirsch</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-06-01">
                            <hi rend="italic">June 1,
                            1892</hi>
                        </date>.</dateline>
                </opener>
                <p>Has interference with Stamford Company at Alexandretta been stopped?
                        President wishes to know.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blaine.</hi>
                    </signed>
                </closer>
            </div>
        </body>
