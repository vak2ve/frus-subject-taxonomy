    <text>
        <body>
            <div frus:doc-dateTime-max="1892-08-20T23:59:59-05:00" frus:doc-dateTime-min="1892-08-20T00:00:00-05:00" n="243" subtype="historical-document" type="document" xml:id="d243">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Herbert</persName> to Mr.
                                    <persName type="to">Foster</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">British
                                        Legation</hi>
                        </placeName>,<lb/>
                        <hi rend="italic">Saturday</hi>, <date calendar="gregorian" when="1892-08-20">
                            <hi rend="italic">August 20,
                            1892</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Foster</hi>: According to a telegram
                            which I have just received from Canada I shall be able to make the
                            communication in regard to the canal tolls on Monday.</p>
                <p>Yours very truly,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Michael H.
                            Herbert.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
