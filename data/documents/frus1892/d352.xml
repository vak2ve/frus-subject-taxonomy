    <text>
        <body>
            <div frus:doc-dateTime-max="1888-10-04T23:59:59-05:00"
                frus:doc-dateTime-min="1888-10-04T00:00:00-05:00" n="352"
                subtype="historical-document" type="document" xml:id="d352">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Strobel</persName> to Mr. <persName
                            type="to">Bayard</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1888-10-04">
                            <hi rend="italic">October 4, 1888</hi>
                        </date>. (Received October 20.)</dateline>
                    <seg rendition="#left">No. 356.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to report that I have on this
                    date recalled the attention of the minister of state to the subject of an
                    indemnity to Mr. Doane, the American missionary, in the sense indicated in the
                    Department’s No. 324, of the 20th ultimo.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edward H. Strobel</hi>.<lb/>
                        <hi rend="italic">Chargé d’Affaires ad interim.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
