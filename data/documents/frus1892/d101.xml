    <text>
        <body>
            <div frus:doc-dateTime-max="1892-12-12T23:59:59-05:00" frus:doc-dateTime-min="1892-12-12T00:00:00-05:00" n="101" subtype="historical-document" type="document" xml:id="d101">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Foster</persName> to Mr.
                                <persName type="to">Denby</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-12-12">
                            <hi rend="italic">December 12,
                            1892</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 765.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I transmit for your information, a copy of
                        correspondence with the Minister of China here, relative to the recent
                        legislation of the United States in respect to Chinese subjects in this
                            country.<note n="*" xml:id="d101fn1">The inclosures herein referred to
                            are the notes of November 7 and 11 from and of December 10 to the
                            Minister of China.</note>
                </p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John W. Foster.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
