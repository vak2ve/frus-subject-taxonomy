    <text>
        <body>
            <div frus:doc-dateTime-max="1892-02-26T23:59:59-05:00" frus:doc-dateTime-min="1892-02-26T00:00:00-05:00" n="310" subtype="historical-document" type="document" xml:id="d310">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr.
                                <persName type="to">Smith</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-02-26">
                            <hi rend="italic">February 26,
                            1892</hi>
                        </date>.</dateline>
                </opener>
                <p>Distribute funds one-half British-American Church, three-tenths Jewish
                        society, and two-tenths Tolstoi.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blaine.</hi>
                    </signed>
                </closer>
            </div>
        </body>
