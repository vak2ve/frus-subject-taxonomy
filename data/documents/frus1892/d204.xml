                subtype="historical-document" type="document" xml:id="d204">
                <head>
                    <hi rend="italic">Sir <persName type="from">Julian Pauncefote</persName> to Mr.
                            <persName type="to">Blaine</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">British Legation</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-01-14">
                            <hi rend="italic">January 14, 1892</hi>
                        </date>. (Received January 14.)</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: It is my sorrowful duty to announce to you the
                    lamentable intelligence, which I have just received from the Marquis of
                    Salisbury, of the death this morning, at Sandringham, of His Royal Highness the
                    Duke of Clarence and Avondale.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Julian Pauncefote.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
