<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1892-10-20T23:59:59-05:00" frus:doc-dateTime-min="1892-10-20T00:00:00-05:00" n="486" subtype="historical-document" type="document" xml:id="d486">
                    <head><hi rend="italic">Mr. <persName type="from">Wharton</persName> to Mr.
                                <persName type="to">Newberry</persName>.</hi></head>
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1892-10-20"><hi rend="italic">October 20,
                            1892</hi></date>.</dateline></opener>
                    <p>Insist upon full protection for Bartlett and other persons complaining of
                        interference.</p>
                    <closer><signed><hi rend="smallcaps">Wharton.</hi></signed></closer>
                </div>
                </body></text></TEI>