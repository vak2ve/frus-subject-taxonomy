    <text>
        <body>
            <div frus:doc-dateTime-max="1890-10-20T23:59:59-05:00" frus:doc-dateTime-min="1890-10-20T00:00:00-05:00" n="362" subtype="historical-document" type="document" xml:id="d362">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr.
                                <persName type="to">Newberry</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1890-10-20">
                            <hi rend="italic">October 20,
                            1890</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 134.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I inclose the commission of Herbert L. Rand, a
                        citizen of the State of Illinois, as consul of the United States at Ponape,
                        Caroline Islands.</p>
                <p>You are instructed to apply in the proper quarter for recognition of Mr. Rand
                        in his official capacity, and to inform him of the result in the usual
                        manner.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">James G. Blaine.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>Inclosure commission dated September 9, 1890.</p>
                </postscript>
            </div>
        </body>
