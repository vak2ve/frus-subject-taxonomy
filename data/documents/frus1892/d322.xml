<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1892-04-02T23:59:59-05:00" frus:doc-dateTime-min="1892-04-02T00:00:00-05:00" n="322" subtype="historical-document" type="document" xml:id="d322">
                    <head><hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr.
                                <persName type="to">Smith</persName>.</hi></head>
                    <opener><seg rendition="#center">[Telegram].</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department
                                    of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1892-04-02"><hi rend="italic">April 2,
                            1892</hi></date>.</dateline></opener>
                    <p>Draw for $1,279.95 additional relief sufferers. Distribute as per telegram
                        18th.</p>
                    <closer><signed><hi rend="smallcaps">Blaine.</hi></signed></closer>
                </div>
                </body></text></TEI>