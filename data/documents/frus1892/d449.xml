                <head>
                    <hi rend="italic">Mr. <persName type="from">Hirsch</persName> to Mr.
                                <persName type="to">Blaine</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Constantinople</hi>
                        </placeName>, <date calendar="gregorian" when="1892-06-02">
                            <hi rend="italic">June 2,
                            1892</hi>
                        </date>.</dateline>
                </opener>
                <p>All interference with Stamford Company stopped May 17.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hirsch</hi>.</signed>
                </closer>
            </div>
