                subtype="historical-document" type="document" xml:id="d506">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Foster</persName> to Mr. <persName
                            type="to">Scruggs</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-09-29">
                            <hi rend="italic">September 29, 1892</hi>
                        </date>.</dateline>
                </opener>
                <p>No precedent for action requested. In view of action of courts can not give
                    instruction desired.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Foster.</hi>
                    </signed>
                </closer>
            </div>
        </body>
