                subtype="historical-document" type="document" xml:id="d327">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr. <persName
                            type="to">Wurts</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-04-29">
                            <hi rend="italic">April 29, 1892</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="italic">Conemaugh</hi>, Spencer, captain; sailed Philadelphia for
                    Riga; cargo over 5,000,000 pounds provisions, Russian sufferers.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blaine.</hi>
                    </signed>
                </closer>
            </div>
        </body>
