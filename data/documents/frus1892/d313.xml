    <text>
        <body>
            <div frus:doc-dateTime-max="1892-03-14T23:59:59-05:00" frus:doc-dateTime-min="1892-03-14T00:00:00-05:00" n="313" subtype="historical-document" type="document" xml:id="d313">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Wharton</persName> to Mr.
                                <persName type="to">Smith</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-03-14">
                            <hi rend="italic">March 14,
                            1892</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="italic">Missouri</hi> consigned Libau; sailed; cargo, 6,000,000
                        pounds flour and corn meal.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wharton</hi>,<lb/>
                        <hi rend="italic">Acting
                                Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
