<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1946-04-03T12:00:00-05:00" frus:doc-dateTime-min="1946-04-03T12:00:00-05:00" n="367" subtype="historical-document" type="document" xml:id="d367">
                        <note rend="inline" type="source">740.00119 Control (Japan)/4–346: Circular
                            telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Certain <gloss type="to">Diplomatic and
                                    Consular Officers</gloss></hi><note n="94" xml:id="d367fn1">At
                                Bangkok, Batavia, Chungking, London, and Singapore.</note></head>
                        <opener>
                            <seg rendition="#left"><hi rend="smallcaps">secret</hi></seg>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1946-04-03T12:00:00-05:00">April 3,
                                1946—noon</date>.</dateline>
                        </opener>
                        <p>MacArthur has notified Mountbatten<note n="95" xml:id="d367fn2">Adm. Lord
                                Louis Mountbatten, Supreme Allied Commander, Southeast Asia.</note>
                            of detailed plans for sinking and otherwise disposing of large Japanese
                            naval vessels and submarines and requested Mountbatten take similar
                            action.</p>
                        <closer><signed><hi rend="smallcaps">Acheson</hi></signed></closer>
                    </div>
                    </body></text></TEI>