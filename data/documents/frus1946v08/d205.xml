<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1946-05-28T08:00:00-05:00" frus:doc-dateTime-min="1946-05-28T08:00:00-05:00" n="205" subtype="historical-document" type="document" xml:id="d205">
                        <note rend="inline" type="source">740.00119 Control (Japan)/5–2846: Circular
                            telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Certain <gloss type="to">American Diplomatic
                                Officers</gloss></hi><note n="8" xml:id="d205fn1">At Lisbon, London,
                                Moscow, Nanking, and The Hague.</note></head>
                        <opener>
                            <seg rendition="#left"><hi rend="smallcaps">restricted</hi></seg>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1946-05-28T09:00:00-04:00">May 28, 1946—9
                                a.m.</date></dateline>
                        </opener>
                        <p>Brit Commonwealth Occupation Force Japan given occupational
                            responsibility for Shikoku Island.</p>
                        <closer><signed><hi rend="smallcaps">Byrnes</hi></signed></closer>
                    </div>
