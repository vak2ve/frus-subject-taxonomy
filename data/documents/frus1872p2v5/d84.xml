    <text>
        <body>
            <div frus:doc-dateTime-max="1872-04-06T23:59:59-05:00" frus:doc-dateTime-min="1872-04-06T00:00:00-05:00" n="84" subtype="historical-document" type="document" xml:id="d84">
                <note rend="inline" type="source">No. 58.</note>
                <head>
                    <persName type="from">The Attorney-General</persName> to <persName type="to">the Secretary of State</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of Justice</hi>, <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1872-04-06">
                            <hi rend="italic">April</hi> 6, 1872.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inclose for your
                            consideration and use * * a statement prepared and addressed to me by
                            Henry R. Crosby, esq., for whose reliability I am willing to vouch. * *
                            *</p>
                <closer>
                    <signed>GEO. H. WILLIAMS, <hi rend="italic">Attorney-General.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">Hamilton Fish</hi>, <hi rend="italic">Secretary of State.</hi>
                    </p>
                </postscript>
            </div>
        </body>
