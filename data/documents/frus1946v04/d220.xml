                <note rend="inline" type="source">C.P.(Gen)Doc.1.O.6.</note>
                <head>
                    <hi rend="smallcaps">Article 16, paragraph 1</hi>
                </head>
                <dateline>
                    <date ana="#date_undated-inferred-from-outside-research" calendar="gregorian"
                        notAfter="1946-10-15T23:59:59+01:00" notBefore="1946-07-29T00:00:00+01:00"
                        >undated</date>
                </dateline>
                <p>Delete the text: <quote rend="blockquote">
                        <p>“Excess war material of Allied origin shall be placed at the disposal of
                            the Allied or Associated Power concerned …” and replace it by the
                            following text: <quote rend="blockquote">
                                <p>“War material of United Nations origin shall be put at the
                                    disposal of the United Nation concerned …”</p>
                            </quote>
                        </p>
                    </quote>
                </p>
            </div>
