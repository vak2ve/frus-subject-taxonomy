                <note rend="inline" type="source">C.P.(Gen)Doc.1.J.32.</note>
                <head>
                    <hi rend="smallcaps">Article 27</hi>
                </head>
                <dateline>
                    <date ana="#date_undated-inferred-from-outside-research" calendar="gregorian"
                        notAfter="1946-10-15T23:59:59+01:00" notBefore="1946-07-29T00:00:00+01:00"
                        >undated</date>
                </dateline>
                <p>Add the following paragraph after Article 27: <quote rend="blockquote">
                        <p>“<hi rend="italic">Bulgaria likewise waives, on behalf of the Bulgarian
                                Government or of Bulgarian nationals against Greece all monetary
                                claims in respect of anything that occurred before the entry into
                                force of the present Treaty</hi>.”</p>
                    </quote>
                </p>
            </div>
