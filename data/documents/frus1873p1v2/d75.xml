<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1873-02-11T23:59:59-05:00" frus:doc-dateTime-min="1873-02-11T00:00:00-05:00" n="75" subtype="historical-document" type="document" xml:id="d75">
                    <head>No. 381.<lb/><hi rend="italic">General <persName corresp="#p_DES1" type="from">Sickles</persName> to Mr. <persName corresp="#p_HF1" type="to">Fish</persName>.</hi></head>
                    <opener>
                        <seg rendition="#center">[Telegram.]</seg>
                    </opener>
                    <opener>
                        <dateline rendition="#right"><placeName><hi rend="smallcaps">Madrid</hi></placeName>, <date calendar="gregorian" when="1873-02-11"><hi rend="italic">February</hi> 11,
                            1873</date>.</dateline>
                    </opener>
                    <p>Chamber of Deputies declares itself in permanent session on motion of
                        Figueras, republican deputy.</p>
                    <closer>
                        <signed><persName corresp="#p_DES1">SICKLES</persName>.</signed>
                    </closer>
                </div>
                </body></text></TEI>