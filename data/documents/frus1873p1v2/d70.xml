            <div frus:doc-dateTime-max="1873-01-18T23:59:59-05:00" frus:doc-dateTime-min="1873-01-18T00:00:00-05:00" n="70" subtype="historical-document" type="document" xml:id="d70">
                <head>No. 376.<lb/>
                    <hi rend="italic">General <persName corresp="#p_DES1" type="from">Sickles</persName> to Mr. <persName corresp="#p_HF1" type="to">Fish</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Rec’d Jan. 18, 6.45 p.m.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1873-01-18">
                            <hi rend="italic">January</hi>, 18,
                            1873</date>.</dateline>
                </opener>
                <p>Orders given by minister of ultramar that no fines be imposed on captains or
                        supercargoes in Cuba without approval of intendente.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DES1">SICKLES</persName>.</signed>
                </closer>
            </div>
        </body>
