            <div frus:doc-dateTime-max="1873-02-11T23:59:59-05:00" frus:doc-dateTime-min="1873-02-11T00:00:00-05:00" n="78" subtype="historical-document" type="document" xml:id="d78">
                <head>No. 384.<lb/>
                    <hi rend="italic">General <persName corresp="#p_DES1" type="from">Sickles</persName> to Mr. <persName corresp="#p_HF1" type="to">Fish</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Rec’d Feb. 12—10 a.m.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1873-02-11">
                            <hi rend="italic">February</hi> 11,
                            1873</date>.</dateline>
                </opener>
                <p>Abdication of King read at 3 this afternoon in Chamber of Deputies. Senate
                        and house go into joint session.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DES1">SICKLES</persName>.</signed>
                </closer>
            </div>
        </body>
