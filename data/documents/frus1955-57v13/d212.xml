                        </placeName>, <date calendar="gregorian" from="1956-01-30T14:15:00-05:00"
                            to="1956-01-30T16:00:00-05:00" type="conversation-or-meeting-date"
                            >January 30, 1956, <hi rend="italic">2:15–4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
