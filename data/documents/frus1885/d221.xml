    <text>
        <body>
            <div frus:doc-dateTime-max="1885-08-28T23:59:59-05:00" frus:doc-dateTime-min="1885-08-28T00:00:00-05:00" n="221" subtype="historical-document" type="document" xml:id="d221">
                <opener>
                    <seg rendition="#center">No. 221.</seg>
                </opener>
                <head>
                    <hi rend="italic">Mr. <persName type="from">Becerra</persName> to Mr.
                                    <persName type="to">Bayard</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Cape
                                        May, N. J.</hi>
                        </placeName>, <date calendar="gregorian" when="1885-08-28">
                            <hi rend="italic">August</hi> 28,
                                1885</date>.</dateline>
                </opener>
                <p>Peace in Colombia. Prestan hanged to-day in Colon.</p>
                <closer>
                    <signed>BECERRA.</signed>
                </closer>
            </div>
        </body>
