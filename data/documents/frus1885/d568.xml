    <text>
        <body>
            <div frus:doc-dateTime-max="1885-11-27T23:59:59-05:00" frus:doc-dateTime-min="1885-11-27T00:00:00-05:00" n="568" subtype="historical-document" type="document" xml:id="d568">
                <opener>
                    <seg rendition="#center">No. 568.</seg>
                </opener>
                <head>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName> to Mr.
                                <persName type="to">Strobel</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1885-11-27">
                            <hi rend="italic">November</hi> 27,
                            1885</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Strobel</hi>,<lb/>
                    <hi rend="italic">Chargé, Madrid:</hi>
                </p>
                <p>Tender to Queen regent sincere condolence of President and people of the
                        United States.</p>
                <closer>
                    <signed>BAYARD.</signed>
                </closer>
            </div>
        </body>
