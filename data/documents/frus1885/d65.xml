    <text>
        <body>
            <div frus:doc-dateTime-max="1885-04-01T23:59:59-05:00" frus:doc-dateTime-min="1885-04-01T00:00:00-05:00" n="65" subtype="historical-document" type="document" xml:id="d65">
                <opener>
                    <seg rendition="#center">No. 65.</seg>
                </opener>
                <head>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName> to Mr.
                                <persName type="to">Hall</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1885-04-01">
                            <hi rend="italic">April</hi> 1,
                            1885</date>.</dateline>
                </opener>
                <p>Mr. Hall is informed that he has previously been authorized to offer the good
                        offices of the United States in the interest of peace and to avert a
                        conflict.</p>
            </div>
        </body>
