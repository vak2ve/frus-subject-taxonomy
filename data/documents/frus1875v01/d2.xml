    <text>
        <body>
            <div frus:doc-dateTime-max="1875-11-15T23:59:59-05:00" frus:doc-dateTime-min="1875-11-15T00:00:00-05:00" n="2" subtype="historical-document" type="document" xml:id="d2">
                <head>[Untitled]</head>
                <p rend="flushleft">To <hi rend="smallcaps">the President</hi>:</p>
                <p>The Secretary of State has the honor to transmit herewith a report concerning
                        the business of the Court of Commissioners of Alabama Claims, made through
                        its clerk.</p>
                <p>In this connection he has the honor to call your attention to the statement
                        contained therein that, in the opinion of the court, it will be impossible
                        to complete the work before it within the time allowed by existing
                        provisions of law therefor.</p>
                <closer>
                    <signed>HAMILTON FISH.</signed>
                    <lb/>
                    <dateline rendition="#left">
                        <hi rend="smallcaps">Department of
                                    State</hi>,<lb/>
                        <placeName>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1875-11-15">
                            <hi rend="italic">November</hi> 15,
                            1875</date>.</dateline>
                </closer>
            </div>
        </body>
    </text>
