                subtype="historical-document" type="document" xml:id="d225">
                <note rend="inline" type="source">835.852/6–1747: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Embassy in Argentina</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">us urgent</hi>
                        <lb/>
                        <hi rend="smallcaps">restricted</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1947-06-17T19:00:00-04:00"
                            >June 17, 1947—7 p.m.</date>
                    </dateline>
                </opener>
                <p>531. <gloss target="#t_Deptel1">Deptel</gloss> 322 Apr 19.<note n="83"
                        xml:id="d225fn1">Not printed.</note>
                    <gloss target="#t_MaritComm1">Marit Com</gloss> June 13 approved application
                    Newport News Shipbuilding Co to enter into contract with Dodero to convert 2
                    CVEs–51 and 52 to commercial cargo vessels. Formal transfer order to be issued
                    when conversion completed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Marshall</hi>
                    </signed>
                </closer>
            </div>
        </body>
