<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Ambassador in Panama (
                        Hines
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1947v08</bibl><bibl type="frus-document-id">d787</bibl><bibl type="frus-document-number">787</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1947-11-01T09:00:00-05:00" notAfter="1947-11-01T09:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1947-11-01T09:00:00-05:00" frus:doc-dateTime-min="1947-11-01T09:00:00-05:00" n="787" subtype="historical-document" type="document" xml:id="d787">
                <note rend="inline" type="source">711F.1914/11–147: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Panama</hi> (<persName type="from">
                        <hi rend="italic">Hines</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Panamá</hi>
                        </placeName>, <date calendar="gregorian" when="1947-11-01T09:00:00-05:00">November 1, 1947—9 a.m.</date>
                    </dateline>
                </opener>
                <p>638. <gloss target="#t_Deptel1">Deptel</gloss> 478, October 31.<note n="63" xml:id="d787fn1">Not printed.</note> Virtual agreement has been reached on
                    rentals [as] follows: No change in previous rental for Rio Hato and San José; 25
                    dollars per hectare for all other lands both public and private. Road
                    maintenance payment still under discussion at my having suggested 100,000 and
                    Panama asking 150,000. Believe we can settle for 125,000 or a little less. With
                    exception of roads, arrangements so far conform to army expectations.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hines</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
