<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Chargé in Haiti (
                        McBride
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1947v08</bibl><bibl type="frus-document-id">d647</bibl><bibl type="frus-document-number">647</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1947-10-03T00:00:00-05:00" notAfter="1947-10-03T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1947-10-03T23:59:59-05:00" frus:doc-dateTime-min="1947-10-03T00:00:00-05:00" n="647" subtype="historical-document" type="document" xml:id="d647">
                <note rend="inline" type="source">838.51/10–347</note>
                <head>
                    <hi rend="italic">The Chargé in Haiti</hi> (<persName type="from">
                        <hi rend="italic">McBride</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">restricted</hi>
                        <lb/> No. 715</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port-au-Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1947-10-03">October 3,
                            1947</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: With reference to Embassy’s telegram number 368
                    of September 30 and previous correspondence<note n="28" xml:id="d647fn1">None
                        printed.</note> regarding the termination of the Financial Agreement between
                    the Governments of the United States and Haiti, signed on September 13,
                        1941,<note n="29" xml:id="d647fn2">Department of State Executive Agreement
                        Series No. 220, or 55 Stat. (pt. 2) 1348; for documentation on this subject,
                        see <ref target="frus1941v07#pg_322">
                            <hi rend="italic">Foreign Relations</hi>, 1941, vol. <hi rend="smallcaps">vii</hi>, pp. 322</ref> ff.</note> I have the honor
                    to transmit herewith a copy of the Note which was left with the Minister of
                    Foreign Affairs on October 1, formally stating that the Government <pb facs="0749" n="733" xml:id="pg_733"/> of the United States considered the
                    agreement automatically to have ceased to have effect.<note n="30" xml:id="d647fn3">For Understanding Between the United States and Haiti
                        Respecting Haitian Finances, effected by exchange of notes signed at
                        Port-au-Prince October 1, 1947, see TIAS No. 1862, or 61 Stat. (pt. 4)
                        4111.</note>
                </p>
                <p>Respectfully yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert</hi> H. <hi rend="smallcaps">McBride</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
