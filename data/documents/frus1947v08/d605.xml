                subtype="historical-document" type="document" xml:id="d605">
                <note rend="inline" type="source">822.01/9–1947: Circular telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">Diplomatic Representatives in the American
                            Republics</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">restricted</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1947-09-19T02:00:00-04:00"
                            >September 19, 1947—2 a.m.</date>
                    </dateline>
                </opener>
                <p>Please inform Govt to which you are accredited that US Govt is instructing US
                        <gloss target="#t_Amb1">Amb</gloss> at Quito to enter into normal relations
                    with new Govt of Ecuador on Monday, Sept 22.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lovett</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
