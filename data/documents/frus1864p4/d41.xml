    <text>
        <body>
            <div frus:doc-dateTime-max="1864-05-30T23:59:59-05:00" frus:doc-dateTime-min="1864-05-30T00:00:00-05:00" n="41" subtype="historical-document" type="document" xml:id="d41">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Koerner</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 99.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1864-05-30">
                            <hi rend="italic">May</hi> 30, 1864</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have received your despatch of May 7,
                            No. 94, and I appreciate very highly the account you have given me of
                            domestic affairs in Spain.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Gustavus Koerner</hi>, Esq., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic">c</hi>.<hi rend="italic">, Madrid.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
