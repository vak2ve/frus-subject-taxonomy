    <text>
        <body>
            <div frus:doc-dateTime-max="1864-09-24T23:59:59-05:00" frus:doc-dateTime-min="1864-09-24T00:00:00-05:00" n="417" subtype="historical-document" type="document" xml:id="d417">
                <head>
                    <persName type="from">Mr. F. W. Seward</persName> to <persName type="to">Mr. Fogg</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 59.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1864-09-24">
                            <hi rend="italic">September</hi> 24, 1864</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi>Your despatch No. 67, under date of August
                            26, has been received, and your proceedings in the case of Jean Zweifel
                            are approved.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>F. W. SEWARD, <hi rend="italic">Acting
                            Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">George G. Fogg</hi>, Esq., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic">c</hi>., <hi rend="italic">Berne</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
