    <text>
        <body>
            <div frus:doc-dateTime-max="1864-06-03T23:59:59-05:00"
                frus:doc-dateTime-min="1864-06-03T00:00:00-05:00" n="43"
                subtype="historical-document" type="document" xml:id="d43">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Koerner</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 102.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1864-06-03">
                            <hi rend="italic">June</hi> 3, 1864</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi>Your interesting despatch of May 15, No. 96, has
                    been received, and your proceedings therein mentioned are approved.</p>
                <p>This government has no interest or other motive for urging upon the government of
                    her Catholic Majesty any diligence in regard to the treaty for the settlement of
                    the limits of the maritime jurisdiction of Spain in the waters of Cuba.</p>
                <p>We are sincerely hoping for a peaceful solution of the controversy which has
                    arisen between Spain and Peru.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Gustavus Koerner</hi>, Esq., &amp;<hi rend="italic"
                            >c</hi>., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic"
                            >c</hi>.<hi rend="italic">, Madrid.</hi>
                    </p>
                </postscript>
            </div>
        </body>
