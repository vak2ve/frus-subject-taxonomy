    <text>
        <body>
            <div frus:doc-dateTime-max="1863-12-27T23:59:59-05:00"
                frus:doc-dateTime-min="1863-12-27T00:00:00-05:00" n="267"
                subtype="historical-document" type="document" xml:id="d267">
                <head>
                    <persName type="from">Mr. Harvey</persName> to <persName type="to">Mr.
                        Seward</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 246.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>, <hi
                                rend="italic">Lisbon</hi>
                        </placeName>, <date calendar="gregorian" when="1863-12-27">
                            <hi rend="italic">December</hi> 27, 1863</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I transmit with this despatch the copy of a
                    letter from the United States consul at Funchal, giving information concerning
                    various suspected vessels, which will doubtless be communicated to the Navy
                    Department.</p>
                <p>I have the honor to be, sir, your obedient servant,</p>
                <closer>
                    <signed>JAMES E. HARVEY.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">Secretary
                            of State,</hi> &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic"
                            >c</hi>., &amp;<hi rend="italic">c</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
