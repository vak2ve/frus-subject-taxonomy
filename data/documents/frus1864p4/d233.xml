    <text>
        <body>
            <div frus:doc-dateTime-max="1863-11-23T23:59:59-05:00" frus:doc-dateTime-min="1863-11-23T00:00:00-05:00" n="233" subtype="historical-document" type="document" xml:id="d233">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Harvey</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 121.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1863-11-23">
                            <hi rend="italic">November</hi> 23, 1863</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi>Tour despatch of the 29th ultimo, No. 237,
                            has been received and has been submitted for perusal to the Secretary of
                            the Navy.</p>
                <p>Your proceedings in relation to the movements of the rebel cruiser
                            Georgia are approved.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">James E. Harvey</hi>, Esq., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic">c</hi>.<hi rend="italic">, Lisbon</hi>.</p>
                </postscript>
            </div>
        </body>
