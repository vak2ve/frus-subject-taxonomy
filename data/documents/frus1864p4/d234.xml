    <text>
        <body>
            <div frus:doc-dateTime-max="1863-11-30T23:59:59-05:00"
                frus:doc-dateTime-min="1863-11-30T00:00:00-05:00" n="234"
                subtype="historical-document" type="document" xml:id="d234">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Harvey</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 123.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1863-11-30">
                            <hi rend="italic">November</hi> 30, 1863</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi>Your despatch, No. 238, of the 4th instant has
                    been received and will be submitted for perusal to the Secretary of the
                    Navy.</p>
                <p>Your vigilance in watching the movements of rebel cruisers, and your exertions to
                    prevent their depredations upon our commerce, are cordially commended.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">James E. Harvey</hi>, Esq., &amp;<hi rend="italic"
                            >c</hi>., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic"
                            >c</hi>.<hi rend="italic">, Lisbon.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
