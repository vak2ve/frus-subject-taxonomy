<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1864-08-25T23:59:59-05:00" frus:doc-dateTime-min="1864-08-25T00:00:00-05:00" n="452" subtype="historical-document" type="document" xml:id="d452">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                McMath</persName>.</head>
                        <opener>
                            <seg rendition="#left">No. 13.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1864-08-25"><hi rend="italic">August</hi> 25, 1864</date>.</dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> Your despatch of the 1st ultimo, No. 22,
                            announcing the removal of certain restrictions on trade in the interior
                            markets of Morocco, has been received, and has been read with
                            satisfaction. Due publicity will be given to the information you have
                            communicated.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Jesse H. McMath</hi>, Esq., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic">c</hi>.<hi rend="italic">, Tangier.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>