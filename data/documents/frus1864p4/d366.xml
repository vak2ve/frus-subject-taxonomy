    <text>
        <body>
            <div frus:doc-dateTime-max="1863-10-05T23:59:59-05:00"
                frus:doc-dateTime-min="1863-10-05T00:00:00-05:00" n="366"
                subtype="historical-document" type="document" xml:id="d366">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Haldeman</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 32.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1863-10-05">
                            <hi rend="italic">October</hi> 5, 1863</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have received your despatch of the 12th of last
                    month, No. 34, and have carefully read the very interesting information which it
                    communicates relative to the action of the German Bund concerning the Danish
                    question and its probable results.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Jacob S. Haldeman</hi>, Esq., &amp;<hi rend="italic"
                            >c</hi>., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic"
                            >c</hi>.<hi rend="italic">, Stockholm.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
