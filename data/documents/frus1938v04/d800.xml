                subtype="historical-document" type="document" xml:id="d800">
                <note rend="inline" type="source">894.00/793: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1938-06-03T19:00:00+09:00"
                            >June 3, 1938—7 p.m.</date>
                        <lb/>[Received June 3—7:13 a.m.]</dateline>
                </opener>
                <p>352. Our 332, May 26, 8 p.m. It was announced this afternoon that General Itagaki
                    is appointed Minister of War vice General Sugiyama, resigned.</p>
                <p>Repeated to Shanghai for Hankow and Peiping.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
