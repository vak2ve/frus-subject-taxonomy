<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1938-05-05T15:00:00-05:00" frus:doc-dateTime-min="1938-05-05T15:00:00-05:00" n="410" subtype="historical-document" type="document" xml:id="d410">
                        <note rend="inline" type="source">893.512/1515: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in China</hi> (<persName type="to"><hi rend="italic">Johnson</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1938-05-05T16:00:00-04:00">May 5, 1938—4
                                p.m.</date></dateline>
                        </opener>
                        <p>141. Your 234, May 4, 11 a.m. The Department perceives no objection to
                            your proposed instruction to Tientsin.</p>
                        <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                    </div>
