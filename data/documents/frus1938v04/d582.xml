                subtype="historical-document" type="document" xml:id="d582">
                <note rend="inline" type="source">393.1115/3494: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Tsingtao</hi> (<persName type="from">
                        <hi rend="italic">Sokobin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tsingtao</hi>
                        </placeName>, <date calendar="gregorian" when="1938-08-06T10:00:00+08:00"
                            >August 6, 1938—10 a.m.</date>
                        <lb/>[Received 11 p.m.]</dateline>
                </opener>
                <p>Referring to my August 2, 6 p.m. [<hi rend="italic">midnight</hi>]. Permission
                    has been granted by the Japanese authorities to one American missionary lady to
                    travel by rail from Tsingtao to Weihsien. Other foreigners are still unable to
                    secure permission to proceed on the railroad to the interior.</p>
                <p>Sent to Peiping, Chungking.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sokobin</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
