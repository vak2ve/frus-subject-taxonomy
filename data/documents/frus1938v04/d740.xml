<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1938-11-23T20:00:00-05:00" frus:doc-dateTime-min="1938-11-23T20:00:00-05:00" n="740" subtype="historical-document" type="document" xml:id="d740">
                        <note rend="inline" type="source">893.70/49: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Consul General at Shanghai</hi> (<persName type="to"><hi rend="italic">Gauss</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1938-11-23T20:00:00-05:00">November 23, 1938—8
                                p.m.</date></dateline>
                        </opener>
                        <p>631. Your 1416, November 16, 8 p.m. Proposed action as outlined in
                            paragraph 2 of your telegram is approved. Please advise Department <pb facs="0549" n="545" xml:id="pg_545"/> if and when reply is sent to
                            Japanese authorities by your British and Danish colleagues and
                            yourself.</p>
                        <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                    </div>
                    </body></text></TEI>