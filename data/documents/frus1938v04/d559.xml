                subtype="historical-document" type="document" xml:id="d559">
                <note rend="inline" type="source">394.1153 Smith Company, Werner G./35:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Hankow</hi> (<persName type="from">
                        <hi rend="italic">Josselyn</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Hankow</hi>
                        </placeName>, <date calendar="gregorian" when="1938-07-25T16:00:00+08:00"
                            >July 25, 1938—4 p.m.</date>
                        <lb/>[Received July 25—12:43 p.m.]</dateline>
                </opener>
                <p>Department’s July 23, 3 p.m.,<note n="33" xml:id="d559fn33">Not printed.</note>
                    Werner G. Smith Company state that, owing to probability losses through leakage
                    in case oil transferred to godown, company desires that American authorities
                    continue efforts to obtain unconditional release of wood oil.</p>
                <p>Repeated to Shanghai, Nanking. Shanghai please repeat to Tokyo. Copy to the
                    Embassy, Hankow.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Josselyn</hi>
                    </signed>
                </closer>
            </div>
        </body>
