    <text>
        <body>
            <div frus:doc-dateTime-max="1938-08-29T23:00:00-05:00"
                frus:doc-dateTime-min="1938-08-29T23:00:00-05:00" n="212"
                subtype="historical-document" type="document" xml:id="d212">
                <note rend="inline" type="source">893.811/1006: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1938-08-30T13:00:00+09:00"
                            >August 30, 1938—1 p.m.</date>
                        <lb/>[Received August 30—6:44 a.m.]</dateline>
                </opener>
                <p>566. Embassy’s 557, August 26, noon,<note n="34" xml:id="d212fn34">Not
                        printed.</note> Whangpoo Conservancy. Separate but similar signed notes
                    substantially embodying the text mentioned in paragraph 1 of Shanghai’s 1152,
                    August 22, 7 p.m., have been submitted to the Foreign Minister by the British,
                    French and American Embassies under date of August 29.</p>
                <p>Repeated to Shanghai.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
