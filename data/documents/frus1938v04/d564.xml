                subtype="historical-document" type="document" xml:id="d564">
                <note rend="inline" type="source">393.1115/3440: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Johnson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1938-07-26T15:00:00-04:00"
                            >July 26, 1938—3 p.m.</date>
                    </dateline>
                </opener>
                <p>216. Shanghai’s 1026, July 22, 4 p.m., and 1031, July 23, 9 p.m., in regard to
                    trains between Hankow and Canton. The Department assumes that you have brought
                    or are bringing this matter appropriately to the attention of the Chinese
                    Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
