    <text>
        <body>
            <div frus:doc-dateTime-max="1937-03-25T13:00:00-05:00"
                frus:doc-dateTime-min="1937-03-25T13:00:00-05:00" n="903"
                subtype="historical-document" type="document" xml:id="d903">
                <note rend="inline" type="source">856D.6176/407: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in the United Kingdom</hi> (<persName
                        type="from">
                        <hi rend="italic">Bingham</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1937-03-25T18:00:00+00:00"
                            >March 25, 1937—6 p.m.</date>
                        <lb/>[Received March 25—2:02 p.m.]</dateline>
                </opener>
                <p>171. Foreign Office has asked Atherton<note n="31" xml:id="d903fn31">Ray
                        Atherton, Counselor of Embassy.</note> and Butterworth<note n="32"
                        xml:id="d903fn32">William W. Butterworth, Jr., Second Secretary of
                        Embassy.</note> to meet with Colonial and Foreign Office representatives
                    under chairmanship of Assistant Secretary of State on Tuesday, March 30, at 3
                    o’clock to discuss rubber situation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bingham</hi>
                    </signed>
                </closer>
            </div>
        </body>
