                subtype="historical-document" type="document" xml:id="d896">
                <note rend="inline" type="source">856D.6176/391: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in the United Kingdom</hi> (<persName type="from">
                        <hi rend="italic">Atherton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1937-02-16T13:00:00+00:00"
                            >February 16, 1937—1 p.m.</date>
                        <lb/>[Received February 16—9:20 a.m.]</dateline>
                </opener>
                <p>68. Department’s 43, February 11, 2 p.m. I called upon Lord Halifax, the Acting
                    Foreign Secretary, this morning and in delivering the note<note n="21"
                        xml:id="d896fn21">Dated February 16.</note> took occasion to outline the
                    American position.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Atherton</hi>
                    </signed>
                </closer>
            </div>
        </body>
