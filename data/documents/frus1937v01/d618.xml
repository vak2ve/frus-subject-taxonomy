                subtype="historical-document" type="document" xml:id="d618">
                <note rend="inline" type="source">852.3300 Motomar/43: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Mexico</hi> (<persName type="from">
                        <hi rend="italic">Daniels</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico City</hi>
                        </placeName>, <date calendar="gregorian" when="1937-12-22T17:00:00-06:00"
                            >December 22, 1937—5 p.m.</date>
                        <lb/>[Received 8:35 p.m.]</dateline>
                </opener>
                <p>325. Your 248, December 21, 7 p.m. Boal spoke to Beteta yesterday morning and
                    today regarding this question and was assured that the Spanish Embassy planes
                    which have been stored in the sanitary warehouse at Vera Cruz were not being
                    sent out of Mexico.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Daniels</hi>
                    </signed>
                </closer>
            </div>
        </body>
