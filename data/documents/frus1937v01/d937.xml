    <text>
        <body>
            <div frus:doc-dateTime-max="1937-05-01T23:00:00-05:00"
                frus:doc-dateTime-min="1937-05-01T23:00:00-05:00" n="937"
                subtype="historical-document" type="document" xml:id="d937">
                <note rend="inline" type="source">561.35E1/352: Telegram</note>
                <head>
                    <hi rend="italic">The Chairman of the American Delegation</hi> (<persName
                        type="from">
                        <hi rend="italic">Davis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1937-05-02T05:00:00+01:00"
                            >May 2, 1937—5 a.m.</date>
                        <lb/>[Received 10 a.m.]</dateline>
                </opener>
                <p>31. The Drafting Committee circulated at midnight a complete draft agreement
                    together with a draft protocol not subject to ratifications designed to be
                    signed simultaneously with the agreement.</p>
                <p rend="flushleft">signature.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
