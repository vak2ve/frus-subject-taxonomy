                <note rend="inline" type="source">352.1115/3956: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Seville</hi> (<persName type="to">
                        <hi rend="italic">Bay</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1937-08-13">August 13,
                            1937</date>.</dateline>
                </opener>
                <p>U. S. S. <hi rend="italic">Kane</hi> leaving St. Jean de Luz, France, Sunday
                    morning for Santander and Gijon to evacuate American nationals. Please inform
                    appropriate insurgent authorities.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
