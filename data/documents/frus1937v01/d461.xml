    <text>
        <body>
            <div frus:doc-dateTime-max="1937-05-11T05:00:00-05:00"
                frus:doc-dateTime-min="1937-05-11T05:00:00-05:00" n="461"
                subtype="historical-document" type="document" xml:id="d461">
                <note rend="inline" type="source">852.2221/401: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Bordeaux</hi> (<persName type="from">
                        <hi rend="italic">George</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bordeaux</hi>
                        </placeName>, <date calendar="gregorian" when="1937-05-11T11:00:00+01:00"
                            >May 11, 1937—11 a.m.</date>
                        <lb/>[Received May 11—6:30 a.m.]</dateline>
                </opener>
                <p>My telegram of April 7, 11 a.m.<note n="66" xml:id="d461fn66">Not printed.</note>
                    Twenty-five Americans held at Toulouse sentenced 40 days imprisonment and will
                    probably be deported. Passports have been delivered to me.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">George</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
