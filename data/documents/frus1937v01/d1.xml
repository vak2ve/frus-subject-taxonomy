<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1937-01-26T12:00:00-05:00" frus:doc-dateTime-min="1937-01-26T12:00:00-05:00" n="1" subtype="historical-document" type="document" xml:id="d1">
                    <note rend="inline" type="source">500.A15A4 Steering Committee/502:
                        Telegram</note>
                    <head><hi rend="italic">The Minister in Switzerland</hi> (<persName type="from"><hi rend="italic">Wilson</hi></persName>) <hi rend="italic">to the
                                <gloss type="to">Secretary of State</gloss></hi></head>
                    <opener>
                        <dateline rendition="#right"><placeName><hi rend="smallcaps">Bern</hi></placeName>, <date calendar="gregorian" when="1937-01-26T18:00:00+01:00">January 26, 1937—6
                            p.m.</date><lb/>[Received January 26—2 p.m.]</dateline>
                    </opener>
                    <p>11. In this afternoon’s session the Council fixed May 6th for the meeting of
                        the Bureau of the Disarmament Conference.</p>
                    <closer><signed><hi rend="smallcaps">Wilson</hi></signed></closer>
                </div>
                </body></text></TEI>