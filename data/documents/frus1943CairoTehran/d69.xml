<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-10-29T23:59:59-05:00" frus:doc-dateTime-min="1943-10-29T00:00:00-05:00" n="69" subtype="historical-document" type="document" xml:id="d69">
                        <note rend="inline" type="source"><persName corresp="#p_RFD1">Roosevelt</persName> Papers: Telegram</note>
                        <head><hi rend="italic">Prime Minister <persName corresp="#p_CC2" type="from">Churchill</persName> to President <persName corresp="#p_RE1" type="to">Roosevelt</persName></hi><note n="1" xml:id="d69fn1">Apparently sent via military channels.</note></head>
                        <opener>
                            <seg rendition="#left"><hi rend="smallcaps">secret</hi></seg>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1943-10-29">29 October 1943</date>.</dateline>
                        </opener>
                        <p><gloss target="#t_FormerNavalPerson1">Former Naval Person</gloss> to
                            President <persName corresp="#p_RFD1">Roosevelt</persName>. Personal and
                            most secret. Nr. 478.</p>
                        <p>My immediately preceding telegram. <gloss target="#t_Sextant1"><hi rend="smallcaps">Sextant</hi></gloss>.</p>
                    </div>
