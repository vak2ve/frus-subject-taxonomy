                subtype="historical-document" type="document" xml:id="d295">
                <note rend="inline" type="source">
                    <persName corresp="#p_RFD1">Roosevelt</persName> Papers: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">President</gloss>
                    </hi>
                    <note n="1" xml:id="d295fn1">Sent by the White House Map Room, via military
                        channels. The message from <persName corresp="#p_SIV1">Stalin</persName> had
                        been incorporated in a note dated November 22, 1943, from <persName
                            corresp="#p_MVM1">Molotov</persName> to <persName corresp="#p_HMM1"
                            >Hamilton</persName>, who transmitted it the same day to the Department
                        in telegram 2013, signed <persName corresp="#p_HWA2">Harriman</persName>
                        (811.001 <persName corresp="#p_RFD1">Roosevelt, F.
                        D.</persName>/9551½).</note>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1943-11-23">November 23,
                            1943</date>.</dateline>
                </opener>
                <p>For the President from Secretary <persName corresp="#p_HC1">Hull</persName>
                </p>
                <p>Marshal <persName corresp="#p_SIV1">Stalin</persName>, who is at the front,
                    states that he will arrive not later than the 28th or 29th at the appointed
                        place.<note n="2" xml:id="d295fn2">i. e., Tehran.</note>
                </p>
            </div>
        </body>
