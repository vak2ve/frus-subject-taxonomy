    <text>
        <body>
            <div frus:doc-dateTime-max="1943-09-10T23:59:59-05:00"
                frus:doc-dateTime-min="1943-09-10T00:00:00-05:00" n="32"
                subtype="historical-document" type="document" xml:id="d32">
                <note rend="inline" type="source">740.0011 <gloss target="#t_EW1">EW</gloss>
                    1939/31080: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Egypt</hi> (<persName corresp="#p_KAC1"
                        type="from">
                        <hi rend="italic">Kirk</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Cairo</hi>
                        </placeName>, <date calendar="gregorian" when="1943-09-10">September 10,
                            1943</date>.</dateline>
                </opener>
                <p>1638. Today’s <hi rend="italic">Egyptian Mail</hi> carries a summary of interview
                    of <persName corresp="#p_NMaP1">Nahas Pasha</persName> with London <hi
                        rend="italic">News Chronicle</hi> reporting <hi rend="italic">inter
                        alia</hi> he would welcome holding conference between Great Britain, United
                    States and Russia in Cairo and would be pleased to provide facilities.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_KAC1">
                            <hi rend="smallcaps">Kirk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
