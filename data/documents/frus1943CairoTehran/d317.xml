                subtype="historical-document" type="document" xml:id="d317">
                <note rend="inline" type="source">
                    <persName corresp="#p_RFD1">Roosevelt</persName> Papers: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">President</gloss>
                    </hi>
                    <note n="1" xml:id="d317fn1">Sent by the White House Map Room, via military
                        channels.</note>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-11-25">November 25,
                            1943</date>.]</dateline>
                </opener>
                <p>For the President from the Secretary of State</p>
                <p>Lisbon’s cable no. 2835 of November 23, 1943<note n="2" xml:id="d317fn2">Not
                        printed herein.</note> announces the departure on the preceding day of the
                    group of Army and Navy technicians from Horta for Terceira Island, and adds that
                    the early departure of these American technicians was thanks to British
                    cooperation in Horta.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HC1">C[<hi rend="smallcaps">ordell</hi>] H[<hi
                                rend="smallcaps">ull</hi>]</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
