<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-11-25T23:59:59-05:00" frus:doc-dateTime-min="1943-11-25T00:00:00-05:00" n="315" subtype="historical-document" type="document" xml:id="d315">
                            <note rend="inline" type="source"><persName corresp="#p_RFD1">Roosevelt</persName> Papers: Telegram</note>
                            <head><hi rend="italic">Marshal <persName corresp="#p_SIV1" type="from">Stalin</persName> to President <persName corresp="#p_RE1" type="to">Roosevelt</persName></hi><note n="1" xml:id="d315fn1">Sent by <persName corresp="#p_SSP1">Spalding</persName> at Moscow to <persName corresp="#p_HK1">Harriman</persName> at Cairo, via Navy
                                channels.</note></head>
                            <opener>
                                <seg rendition="#left"><hi rend="smallcaps">secret</hi>
                                    <lb/>
                                    <hi rend="smallcaps">urgent</hi></seg>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Moscow</hi></placeName>, <date calendar="gregorian" when="1943-11-25">November 25, 1943.</date></dateline>
                            </opener>
                            <p>Personal and strictly secret from Premier <persName corresp="#p_SIV1">Stalin</persName> to President <persName corresp="#p_RFD1">Roosevelt</persName>. Your message from Cairo<note n="2" xml:id="d315fn2">Telegram of November 22, 1943, <hi rend="italic">ante</hi>, <ref target="#pg_373">p.
                                    373</ref>.</note> received. I will be at your service in Teheran
                                the evening of November twenty-eighth.</p>
                        </div>
                        </body></text></TEI>