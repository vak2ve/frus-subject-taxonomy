    <text>
        <body>
            <div frus:doc-dateTime-max="1943-12-02T23:59:59-05:00"
                frus:doc-dateTime-min="1943-12-02T00:00:00-05:00" n="351"
                subtype="historical-document" type="document" xml:id="d351">
                <note rend="inline" type="source">
                    <persName corresp="#p_RFD1">Roosevelt</persName> Papers: Telegram</note>
                <head>
                    <hi rend="italic">The President’s Special Assistant</hi> (<persName
                        corresp="#p_HHL1" type="from">
                        <hi rend="italic">Hopkins</hi>
                    </persName>) <hi rend="italic">to the Presidents Secretary</hi> (<persName
                        corresp="#p_ES1" type="to">
                        <hi rend="italic">Early</hi>
                    </persName>)<note n="1" xml:id="d351fn1">Sent via military channels.</note>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Tehran</hi>
                        </placeName>,] <date calendar="gregorian" when="1943-12-02">2 December
                            1943.</date>
                    </dateline>
                </opener>
                <p>For Mr. <persName corresp="#p_ES1">Early</persName> from Mr. <persName
                        corresp="#p_HHL1">Hopkins</persName>
                </p>
                <p>Text of Teheran Communiqué<note n="2" xml:id="d351fn2">
                        <hi rend="italic">Post</hi>, <ref target="#pg_639">p. 639</ref>.</note> will
                    be released for publication 1300 hours Washington time, 2000 hours Moscow time,
                    December 6th. Details of release will be sent later. Please send report
                    concerning treatment of Chinese communiqué including any violations release date
                    or unauthorized premature publication facts concerning Cairo or Teheran
                    Conferences and your suggestions.</p>
            </div>
        </body>
    </text>
