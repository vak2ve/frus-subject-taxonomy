    <text>
        <body>
            <div frus:doc-dateTime-max="1943-11-20T23:59:59-05:00"
                frus:doc-dateTime-min="1943-11-20T00:00:00-05:00" n="150"
                subtype="historical-document" type="document" xml:id="d150">
                <note rend="inline" type="source">Defense Files: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Joint Chiefs of Staff</gloss> to the
                        Ambassador in the Soviet Union</hi> (<persName corresp="#p_HWA2" type="to">
                        <hi rend="italic">Harriman</hi>
                    </persName>)<note n="1" xml:id="d150fn1">Sent to the War Department, apparently
                        via Navy channels, as telegram 36, for forwarding to the United States
                        Military Attaché, Moscow.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Oran</hi>
                        </placeName>,] <date calendar="gregorian" when="1943-11-20">20 November
                            1943</date>.</dateline>
                </opener>
                <p>(For Ambassador <persName corresp="#p_HWA2">Harriman</persName>)</p>
                <p>The Joint Chiefs of Staff have been directed by the President to inform you<note
                        n="2" xml:id="d150fn2">See <hi rend="italic">ante</hi>, <ref target="#pg_87"
                            >p. 87</ref>.</note> that he desires your presence at Cairo about 22
                    November (to Chief United States Military Mission to USSR from Joint Chiefs of
                    Staff) accompanied by General <persName corresp="#p_DJR1">Deane</persName>,
                    Mister <persName corresp="#p_BCE2">Bohlen</persName>, General <persName
                        corresp="#p_VHS1">Vandenberg</persName>, and Commodore [<hi rend="italic"
                        >Rear Admiral</hi>] <persName corresp="#p_OCE1">Olsen</persName>.</p>
            </div>
        </body>
    </text>
