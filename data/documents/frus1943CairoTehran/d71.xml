    <text>
        <body>
            <div frus:doc-dateTime-max="1943-10-29T23:59:59-05:00"
                frus:doc-dateTime-min="1943-10-29T00:00:00-05:00" n="71"
                subtype="historical-document" type="document" xml:id="d71">
                <note rend="inline" type="source">
                    <persName corresp="#p_RFD1">Roosevelt</persName> Papers: Telegram</note>
                <head>
                    <hi rend="italic">President <persName corresp="#p_RFD1" type="from"
                            >Roosevelt</persName> to Prime Minister <persName corresp="#p_CC2"
                            type="to">Churchill</persName>
                    </hi>
                    <note n="1" xml:id="d71fn1">Sent to the United States Naval Attaché, London, via
                        Navy channels.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                        <lb/>
                        <hi rend="smallcaps">priority</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1943-10-29">29 October
                            1943</date>.</dateline>
                </opener>
                <p>To the <gloss target="#t_FormerNavalPerson1">Former Naval Person</gloss> from the
                    President, Number 401. Secret and personal.</p>
                <p>My immediately preceding message. Code word <gloss target="#t_Sextant1">
                        <hi rend="smallcaps">Sextant</hi>
                    </gloss> is accepted.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_RFD1">
                            <hi rend="smallcaps">Roosevelt</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
