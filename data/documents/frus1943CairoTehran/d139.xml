<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-11-18T23:59:59-05:00" frus:doc-dateTime-min="1943-11-18T00:00:00-05:00" n="139" subtype="historical-document" type="document" xml:id="d139">
                        <note rend="inline" type="source"><persName corresp="#p_RFD1">Roosevelt</persName> Papers: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">President</gloss></hi><note n="1" xml:id="d139fn1">Sent by the White House Map Room to <persName corresp="#p_GDW1">Greer</persName> at Oran, apparently via
                                military channels, November 19, 1943.</note></head>
                        <opener>
                            <seg rendition="#left"><hi rend="smallcaps">secret</hi></seg>
                            <dateline rendition="#right">[<placeName><hi rend="smallcaps">Washington</hi></placeName>,] <date calendar="gregorian" when="1943-11-18">November 18, 1943</date>.</dateline>
                        </opener>
                        <p>For the President from Secretary <persName corresp="#p_HC1">Hull</persName>.</p>
                        <p><persName corresp="#p_KAC1">Kirk</persName> thinks<note n="2" xml:id="d139fn2">Telegram 2116, November 17, 1943, from the Legation
                                at Cairo; not printed herein.</note> it would be appropriate for you
                            to send message to King <persName corresp="#p_FI1">Farouk</persName> to
                            wish him recovery from recent motor accident which resulted in slight
                            injury to pelvis and minor bruises.<note n="3" xml:id="d139fn3">For
                                    <persName corresp="#p_RFD1">Roosevelt</persName>’s message of
                                November 20, 1943, to <persName corresp="#p_FI1">Farouk</persName>,
                                based on this suggestion, see <hi rend="italic">post</hi>, <ref target="#pg_101">p. 101</ref>.</note></p>
                    </div>
                    </body></text></TEI>