    <text>
        <body>
            <div frus:doc-dateTime-max="1943-11-19T16:59:59-05:00"
                frus:doc-dateTime-min="1943-11-14T23:00:00-05:00" n="236"
                subtype="historical-document" type="document" xml:id="d236">
                <note rend="inline" type="source">
                    <persName corresp="#p_RFD1">Roosevelt</persName> Papers</note>
                <head>
                    <hi rend="italic">Paper Prepared by the Joint Staff Planners</hi>
                    <note n="1" xml:id="d236fn1">For <persName corresp="#p_RFD1"
                            >Roosevelt</persName>’s request for a paper of this kind, see <hi
                            rend="italic">ante</hi>, <ref target="#pg_190">p. 190</ref>. The paper
                        apparently was submitted directly to the President. It was not considered or
                        approved by the Joint Chiefs of Staff.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Aboard the</hi> U. S. S. “<hi rend="smallcaps"
                                >Iowa</hi>”</placeName>, <date
                            ana="#date_undated-inferred-from-document-content" calendar="gregorian"
                            notAfter="1943-11-19T23:59:59+02:00"
                            notBefore="1943-11-15T00:00:00-04:00">undated</date>.<note n="2"
                            xml:id="d236fn2">Prepared between November 15 and 19,
                        1943.</note>]</dateline>
                </opener>
                <p rend="center">Enclosure “B”<note n="3" xml:id="d236fn3">No covering paper has
                        been found.</note>
                </p>
                <p rend="center">
                    <hi rend="smallcaps">Proposed Agenda</hi>
                </p>
                <p rend="center">For the First Meeting of the President of the United States and the
                    Prime Minister of Great Britain</p>
                <list>
                    <label>1.</label>
                    <item>Command Arrangements: <list>
                            <label>
                                <hi rend="italic">a</hi>.</label>
                            <item>Urgency of Installing Over-All Commander</item>
                            <label>
                                <hi rend="italic">b</hi>.</label>
                            <item>Commander for “<gloss target="#t_Overlord1">
                                    <hi rend="smallcaps">Overlord</hi>
                                </gloss>”</item>
                            <pb facs="0339" n="247" xml:id="pg_247"/>
                            <label>
                                <hi rend="italic">c</hi>.</label>
                            <item>Commander for the Mediterranean</item>
                            <label>
                                <hi rend="italic">d</hi>.</label>
                            <item>Necessity for Unified Strategic Bomber Command European
                                Theater</item>
                        </list>
                    </item>
                    <label>2.</label>
                    <item>Spheres of Responsibility for “<gloss target="#t_Rankin1">
                            <hi rend="smallcaps">Rankin</hi>
                        </gloss>” (North Europe versus Southern Europe)</item>
                    <label>3.</label>
                    <item>U. S. Policy on U. S. Non-Participation in Operations in the Eastern
                        Mediterranean-Balkan Area</item>
                    <label>4.</label>
                    <item>Soviet Collaboration <list>
                            <label>
                                <hi rend="italic">a</hi>.</label>
                            <item>Strategic Bombing Including Bases for U. S. Forces</item>
                            <label>
                                <hi rend="italic">b</hi>.</label>
                            <item>Coordinating Ground Operations</item>
                            <label>
                                <hi rend="italic">c</hi>.</label>
                            <item>Turkey and Sweden</item>
                            <label>
                                <hi rend="italic">d</hi>.</label>
                            <item>Against Japan</item>
                        </list>
                    </item>
                    <label>5.</label>
                    <item>U.S. Facilities in the Azores</item>
                </list>
            </div>
        </body>
    </text>
