    <text>
        <body>
            <div frus:doc-dateTime-max="1943-11-04T23:59:59-05:00"
                frus:doc-dateTime-min="1943-11-04T00:00:00-05:00" n="188"
                subtype="historical-document" type="document" xml:id="d188">
                <note rend="inline" type="source">
                    <persName corresp="#p_RFD1">Roosevelt</persName> Papers: Telegram</note>
                <head>
                    <hi rend="italic">President <persName corresp="#p_RFD1" type="from"
                            >Roosevelt</persName> to Prime Minister <persName corresp="#p_CC2"
                            type="to">Churchill</persName>
                    </hi>
                    <note n="1" xml:id="d188fn1">Channel of transmission not indicated. A paraphrase
                        of this message was sent to <persName corresp="#p_HWA2">Harriman</persName>
                        at Moscow on the same date, via Navy channels.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1943-11-04">November 4,
                            1943</date>.</dateline>
                </opener>
                <p>#407 President to Prime</p>
                <p>This government agrees to join Great Britain and Soviet in making immediate
                    demand on Turkey for use of air bases and later pressing Turkey to enter the war
                    before the end of the year<note n="2" xml:id="d188fn2">See <persName
                            corresp="#p_HC1">Hull</persName>’s telegram of November 1, 1943, to
                            <persName corresp="#p_RFD1">Roosevelt</persName>, <hi rend="italic"
                            >ante</hi>, <ref target="#pg_144">p. 144</ref>.</note> subject to the
                    following: No British or American resources will be committed to the Eastern
                    Mediterranean area which in the opinion of the commanders responsible are
                    necessary for <gloss target="#t_Overlord1">
                        <hi rend="smallcaps">Overlord</hi>
                    </gloss> or for operations in Italy.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_RFD1">
                            <hi rend="smallcaps">Roosevelt</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
