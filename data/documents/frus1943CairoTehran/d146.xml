    <text>
        <body>
            <div frus:doc-dateTime-max="1943-11-20T16:00:00-05:00"
                frus:doc-dateTime-min="1943-11-20T16:00:00-05:00" n="146"
                subtype="historical-document" type="document" xml:id="d146">
                <note rend="inline" type="source">123 <persName corresp="#p_SLA1">Steinhardt,
                        Laurence A.</persName>/576: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Turkey</hi> (<persName corresp="#p_SLA1" type="to">
                        <hi rend="italic">Steinhardt</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">u. s. urgent</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-11-20T17:00:00-04:00"
                            >November 20, 1943—5 p.m.</date>
                    </dateline>
                </opener>
                <p>903. Secret and personal for the Ambassador.</p>
                <p>By direction of the President<note n="1" xml:id="d146fn1">See <hi rend="italic"
                            >ante</hi>, <ref target="#pg_66">p. 66</ref>.</note> you are requested
                    to report immediately in Cairo and there await further instructions.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HC1">
                            <hi rend="smallcaps">Hull</hi>
                        </persName>
                        <lb/>
                        <persName corresp="#p_GCW1">C[<hi rend="smallcaps">ecil</hi>] W. G[<hi
                                rend="smallcaps">eay</hi>]</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
