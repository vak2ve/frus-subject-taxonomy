<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-09-09T23:59:59-05:00" frus:doc-dateTime-min="1943-09-09T00:00:00-05:00" n="416" subtype="historical-document" type="document" xml:id="d416">
                        <note rend="inline" type="source">835.00/1802: Telegram</note>
                        <head><hi rend="italic">The Chargé in Argentina</hi> (<persName type="from"><hi rend="italic">Reed</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Buenos
                                        Aires</hi></placeName>, <date calendar="gregorian" when="1943-09-09">September 9, 1943</date>.<lb/>[Received
                                September 9—8:54 p.m.]</dateline>
                        </opener>
                        <p>2083. It is officially announced that resignation of Foreign Minister
                            Storni has been presented and accepted.</p>
                        <closer><signed><hi rend="smallcaps">Reed</hi></signed></closer>
                    </div>
                    </body></text></TEI>