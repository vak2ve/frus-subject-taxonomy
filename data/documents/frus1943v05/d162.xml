                            <cell role="num">10,275</cell>
                        </row>
                        <row>
                            <cell>February</cell>
                            <cell rendition="#nowrap" role="num">“  “  </cell>
                            <cell role="num">15,185</cell>
                        </row>
                        <row>
                            <cell>March</cell>
                            <cell rendition="#nowrap" role="num">“  “  </cell>
