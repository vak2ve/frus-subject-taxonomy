    <text>
        <body>
            <div frus:doc-dateTime-max="1943-03-04T23:59:59-05:00"
                frus:doc-dateTime-min="1943-03-04T00:00:00-05:00" n="778"
                subtype="historical-document" type="document" xml:id="d778">
                <note rend="inline" type="source">825.796/141</note>
                <head>
                    <hi rend="italic">Memorandum by the Chief of the Division of the American
                        Republics</hi> (<persName type="from">
                        <hi rend="italic">Bonsal</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1943-03-04">March 4,
                            1943</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Berle</hi>: No further action on the four Lockheed
                    Lodestars for the Chilean Air Line<note n="50" xml:id="d778fn50">See airgram No.
                        A–42, January 9, from the Ambassador in Chile, <ref target="#pg_811">p.
                            811</ref>.</note> is indicated at this time, since the Munitions
                    Assignments Board on March 3, 1943 approved schedule of delivery for April, May,
                    October, and November, 1943.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Philip W. Bonsal</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
