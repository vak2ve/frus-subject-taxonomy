<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-03-28T15:15:00-05:00" frus:doc-dateTime-min="1943-03-28T15:15:00-05:00" n="168" subtype="historical-document" type="document" xml:id="d168">
                            <note rend="inline" type="source">821.24/444: Telegram</note>
                            <head><hi rend="italic">The Ambassador in Colombia</hi> (<persName type="from"><hi rend="italic">Lane</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1943-03-28T15:15:00-05:00">March 28, 1943—3:15
                                        p.m.</date><lb/>[Received 10:28 p.m.]</dateline>
                            </opener>
                            <p>554. Reference copy of time schedule enclosed with instruction no.
                                1123 of March 22<note n="8" xml:id="d168fn8">Not printed.</note> on
                                Decentralization Plan. Deadline of May 15 for Import Recommendations
                                covering various materials thought impracticable with May 1
                                initiation of Plan “A”.<note n="9" xml:id="d168fn9">Decentralization
                                    Plan A; for an outline of the plan, see circular airgram of
                                    January 19, 8 p.m., <ref target="#pg_106">p. 106</ref>.</note>
                                Should deadline not be June 15?</p>
                            <closer><signed><hi rend="smallcaps">Lane</hi></signed></closer>
                        </div>
                        </body></text></TEI>