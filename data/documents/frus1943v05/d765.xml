<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-05-18T21:00:00-05:00" frus:doc-dateTime-min="1943-05-18T21:00:00-05:00" n="765" subtype="historical-document" type="document" xml:id="d765">
                        <note rend="inline" type="source">740.0011 European War 1939/29434:
                            Telegram</note>
                        <head><hi rend="italic">The Ambassador in Chile</hi> (<persName type="from"><hi rend="italic">Bowers</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Santiago</hi></placeName>, <date calendar="gregorian" when="1943-05-18T22:00:00-04:00">May 18, 1943—10
                                p.m.</date><lb/>[Received 11 p.m.]</dateline>
                        </opener>
                        <p>916. The Foreign Minister has just informed me that the Chilean
                            Government is immediately issuing a decree severing diplomatic relations
                            with Bulgaria, Rumania, Hungary and Vichy France.</p>
                        <closer><signed><hi rend="smallcaps">Bowers</hi></signed></closer>
                    </div>
                    </body></text></TEI>