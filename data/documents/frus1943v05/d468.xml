                subtype="historical-document" type="document" xml:id="d468">
                <note rend="inline" type="source">835.741/34: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Argentina</hi> (<persName type="from">
                        <hi rend="italic">Armour</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1943-06-10T19:00:00-03:00"
                            >June 10, 1943—7 p.m.</date>
                        <lb/>[Received June 10—6:20 p.m.]</dateline>
                </opener>
                <p>1284. I am reliably informed that President Ramírez has just signed a decree
                    suspending the use of code language in all international radiotelephonic and
                    radiotelegraphic communications.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Armour</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
