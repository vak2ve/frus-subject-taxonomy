<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-03-13T09:30:00-05:00" frus:doc-dateTime-min="1943-03-13T09:30:00-05:00" n="284" subtype="historical-document" type="document" xml:id="d284">
                            <note rend="inline" type="source">831.24/604: Telegram</note>
                            <head><hi rend="italic">The Ambassador in Venezuela</hi> (<persName type="from"><hi rend="italic">Corrigan</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Caracas</hi></placeName>, <date calendar="gregorian" when="1943-03-13T10:00:00-04:30">March 13, 1943—10
                                        a.m.</date><lb/>[Received March 13—1:48 a.m.]</dateline>
                            </opener>
                            <p>273. Embassy’s 263, March 11, 11 a.m.<note n="10" xml:id="d284fn10">Not printed.</note> Cabinet yesterday confirmed April 1, for
                                application Decentralization Plan.</p>
                            <closer><signed><hi rend="smallcaps">Corrigan</hi></signed></closer>
                        </div>
