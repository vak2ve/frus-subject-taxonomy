    <text>
        <body>
            <div frus:doc-dateTime-max="1939-10-02T23:00:00-05:00"
                frus:doc-dateTime-min="1939-10-02T23:00:00-05:00" n="659"
                subtype="historical-document" type="document" xml:id="d659">
                <note rend="inline" type="source">811.111 Quota/2272: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the United Kingdom</hi> (<persName type="to">
                        <hi rend="italic">Kennedy</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1939-10-02T23:00:00-05:00"
                            >October 2, 1939—11 p.m.</date>
                    </dateline>
                </opener>
                <p>1139. Your 1331, August 31, 3 p.m.<note n="36" xml:id="d659fn36">Not
                        printed.</note> The Department would appreciate receiving your
                    recommendation with respect to desirability or need for continuing suspension of
                    issuance of quota immigration visas into October.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
