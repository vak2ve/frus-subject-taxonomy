<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-09-01T09:00:00-05:00" frus:doc-dateTime-min="1939-09-01T09:00:00-05:00" n="626" subtype="historical-document" type="document" xml:id="d626">
                        <note rend="inline" type="source">811.111 Quota/2272: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in the United Kingdom</hi> (<persName type="to"><hi rend="italic">Kennedy</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1939-09-01T10:00:00-04:00">September
                                    1, 1939—10 a.m.</date>
                            </dateline>
                        </opener>
                        <p>746. Your 1331, August 31, 3 p.m.<note n="12" xml:id="d626fn12">Not
                                printed.</note> In view of the need for steamship accommodations for
                            American citizens and in order that the Embassy staff may devote its
                            attention to the needs of Americans in England, consuls are authorized
                            to suspend the issuance of quota immigration visas during September so
                            long as emergency continues.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>