<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-09-19T06:00:00-05:00" frus:doc-dateTime-min="1939-09-19T06:00:00-05:00" n="647" subtype="historical-document" type="document" xml:id="d647">
                        <note rend="inline" type="source">340.1115A/24: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in Frame</hi> (<persName type="from"><hi rend="italic">Bullitt</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1939-09-19T12:00:00+01:00">September
                                    19, 1939—noon</date>.<lb/>[Received September 19—9
                                a.m.]</dateline>
                        </opener>
                        <p>2048.Your 982, September 18, 7 p.m. I take your telegram under reference
                            to mean that you have given appropriate instructions to the United
                            States Lines.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bullitt</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>