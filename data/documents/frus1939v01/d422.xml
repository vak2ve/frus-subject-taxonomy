                subtype="historical-document" type="document" xml:id="d422">
                <note rend="inline" type="source">740.0011 European War, 1939/95: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Germany</hi> (<persName type="from">
                        <hi rend="italic">Kirk</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1939-09-03T12:00:00+01:00"
                            >September 3, 1939—noon</date>.<lb/>[Received 3:57 p.m.]</dateline>
                </opener>
                <p>1030. My 1029, September 3, noon.<note n="27" xml:id="d422fn27">Not printed; it
                        reported that Ribbentrop had sent for the British Ambassador at 11:14 a.m.
                        (740.0011 European War, 1939/94).</note> Ribbentrop delivered to Henderson a
                    lengthy note refusing the British demands.<note n="28" xml:id="d422fn28">British
                        Cmd. 6106, Misc. No. 9 (1939), doc. No. 119, p. 175.</note> The note <pb
                        facs="0428" n="416" xml:id="pg_416"/> which has not yet been translated
                    places the blame entirely on British shoulders and contains a lengthy
                    justification of the German position.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kirk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
