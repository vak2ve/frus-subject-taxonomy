<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-09-17T09:00:00-05:00" frus:doc-dateTime-min="1939-09-17T09:00:00-05:00" n="734" subtype="historical-document" type="document" xml:id="d734">
                        <note rend="inline" type="source">740.00111A Armed Merchantmen/1:
                            Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in France</hi> (<persName type="from"><hi rend="italic">Bullitt</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1939-09-17T15:00:00+01:00">September
                                    17, 1939—3 p.m.</date>
                                <lb/> [Received September 17—10:24 a.m.]</dateline>
                        </opener>
                        <p>2017. Ministry of Navy inquires of our Naval Attaché whether it is
                            permissible for French merchant vessels which are armed for defensive
                            purposes to enter American ports.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bullitt</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>