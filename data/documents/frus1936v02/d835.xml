                subtype="historical-document" type="document" xml:id="d835">
                <note rend="inline" type="source">852.00/4061: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Portugal</hi> (<persName type="from">
                        <hi rend="italic">Caldwell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lisbon</hi>
                        </placeName>, <date calendar="gregorian" when="1936-12-11T11:00:00+00:00"
                            >December 11, 1936—11 a.m.</date>
                        <lb/>[Received December 11—8:20 a.m.]</dateline>
                </opener>
                <p>74. Note just received from Spanish insurgent representative here states that
                    vessels navigating at night without lights in Spanish waters will be considered
                    enemy vessels.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caldwell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
