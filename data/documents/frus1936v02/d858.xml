                subtype="historical-document" type="document" xml:id="d858">
                <note rend="inline" type="source">611.5431/300</note>
                <head>
                    <hi rend="italic">The Swiss Minister</hi> (<persName type="from">
                        <hi rend="italic">Peter</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-01-09">January 9,
                            1936</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of January 9, 1936, relating to the laws to which the last sentence of
                    Article II of the Trade Agreement signed to-day is referring, and to inform you
                    that its contents have been duly noted.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Marc Peter</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
