<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-11-27T15:00:00-05:00" frus:doc-dateTime-min="1936-11-27T15:00:00-05:00" n="829" subtype="historical-document" type="document" xml:id="d829">
                            <note rend="inline" type="source">852.00/3905: Telegram</note>
                            <head><hi rend="italic">The Minister in Portugal</hi> (<persName type="from"><hi rend="italic">Caldwell</hi></persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                                        State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Lisbon</hi></placeName>, <date calendar="gregorian" when="1936-11-27T20:00:00+00:00">November 27, 1936—8
                                        p.m.</date><lb/>[Received November 27—3:38 p.m.]</dateline>
                            </opener>
                            <p>69. Note received today from Amoedo, Burgos representative in Lisbon,
                                designates by degrees and minutes neutral zones in ports of
                                Tarragona, Valencia, Alicante, Cartagena and Barcelona. Full details
                                can be sent by telegraph if desired.</p>
                            <closer><signed><hi rend="smallcaps">Caldwell</hi></signed></closer>
                        </div>
                        </body></text></TEI>