<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-08-12T08:00:00-05:00" frus:doc-dateTime-min="1936-08-12T08:00:00-05:00" n="404" subtype="historical-document" type="document" xml:id="d404">
                            <note rend="inline" type="source">852.00/2549: Telegram</note>
                            <head><hi rend="italic">The Third Secretary of Embassy in Spain</hi>
                                    (<persName type="from"><hi rend="italic">Wendelin</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Madrid</hi></placeName>, <date calendar="gregorian" when="1936-08-12T13:00:00+00:00">August 12, 1936—1
                                        p.m.</date><lb/>[Received August 12—11:45 a.m.]</dateline>
                            </opener>
                            <p>X–48. Competent representative of French Government here confirms
                                arrival of French planes at Madrid for use Spanish Government.
                                Believed to be about 20 Potez and Breguet planes with French
                                pilots.</p>
                            <closer><signed><hi rend="smallcaps">Wendelin</hi></signed></closer>
                        </div>
                        </body></text></TEI>