                <note rend="inline" type="source">611.5431/288</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the Swiss
                        Minister</hi> (<persName type="to">
                        <hi rend="italic">Peter</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-01-09">January 9,
                            1936</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of January 9, 1936, and to inform you that the declarations of the
                    Swiss Government pertaining to the importation into Switzerland of lard as well
                    as of trucks and their chassis from the United States have been duly noted.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cordell Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
