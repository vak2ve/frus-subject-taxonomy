<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-07-25T14:00:00-05:00" frus:doc-dateTime-min="1936-07-25T14:00:00-05:00" n="604" subtype="historical-document" type="document" xml:id="d604">
                            <note rend="inline" type="source">852.00/2272: Telegram</note>
                            <head><hi rend="italic">The Consul at Barcelona</hi> (<persName type="from"><hi rend="italic">Franklin</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Barcelona</hi></placeName>, <date calendar="gregorian" when="1936-07-25T19:00:00+00:00">July 25, 1936—7
                                    p.m.</date><lb/>[Received July 26—3:25 a.m.]</dateline>
                            </opener>
                            <p>Please send USS <hi rend="italic">Quincy</hi> which I understand is
                                at Gibraltar to Barcelona as all communication threatened.</p>
                            <closer><signed><hi rend="smallcaps">Franklin</hi></signed></closer>
                        </div>
                        </body></text></TEI>