                subtype="historical-document" type="document" xml:id="d864">
                <note rend="inline" type="source">611.5431/525: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Switzerland</hi> (<persName type="to">
                        <hi rend="italic">Wilson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-12-02T19:00:00-05:00"
                            >December 2, 1936—7 p.m.</date>
                    </dateline>
                </opener>
                <p>83. Your 91, December 2, 4 p.m. The Department is most unwilling to invoke escape
                    clause and does not contemplate so doing at this time. No further consideration
                    will be given this matter until the receipt of your statement forwarded by <hi
                        rend="italic">Bremen</hi>.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Moore</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
