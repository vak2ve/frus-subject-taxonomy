                subtype="historical-document" type="document" xml:id="d605">
                <note rend="inline" type="source">852.00/2272: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Barcelona</hi> (<persName type="to">
                        <hi rend="italic">Franklin</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-07-26T12:00:00-04:00"
                            >July 26, 1936—noon</date>.</dateline>
                </opener>
                <p>Your July 25, 7 p.m. This message has been transmitted to the Commander of the
                        <hi rend="italic">Quincy</hi> with instructions to investigate the
                    situation. In view of the fact that the Commander of the <hi rend="italic"
                        >Quincy</hi> will be in constant contact with Washington, and points along
                    the Spanish coast, it is felt that the movement of the <hi rend="italic"
                        >Quincy</hi> should be left to the discretion of its Commander.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
