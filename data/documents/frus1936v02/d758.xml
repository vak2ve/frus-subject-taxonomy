                <note rend="inline" type="source">352.115/115: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at Barcelona</hi> (<persName type="to">
                        <hi rend="italic">Perkins</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-10-10T14:00:00-05:00"
                            >October 10, 1936—2 p.m.</date>
                    </dateline>
                </opener>
                <p>Your October 8, 8 p.m., and October 9, noon. Your action heartily approved.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
