<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-11-14T13:00:00-05:00" frus:doc-dateTime-min="1936-11-14T13:00:00-05:00" n="799" subtype="historical-document" type="document" xml:id="d799">
                            <note rend="inline" type="source">852.00/3763: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Third Secretary of Embassy in
                                    Spain</hi> (<persName type="to"><hi rend="italic">Wendelin</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1936-11-14T13:00:00-05:00">November 14, 1936—1
                                        p.m.</date></dateline>
                            </opener>
                            <p>191. Your X–311, November 13, 10 p.m. Please keep us informed as to
                                action British may take in order that we may be in a position to act
                                promptly in the event that similar action on our part seems
                                advisable.</p>
                            <closer><signed><hi rend="smallcaps">Moore</hi></signed></closer>
                        </div>
                        </body></text></TEI>