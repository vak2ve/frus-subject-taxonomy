<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-07-18T07:00:00-05:00" frus:doc-dateTime-min="1936-07-18T07:00:00-05:00" n="356" subtype="historical-document" type="document" xml:id="d356">
                            <note rend="inline" type="source">852.00/2174: Telegram</note>
                            <head><hi rend="italic">The Ambassador in Spain</hi> (<persName type="from"><hi rend="italic">Bowers</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">San
                                            Sebastián</hi></placeName>, <date calendar="gregorian" when="1936-07-18T12:00:00+00:00">July 18,
                                    1936—noon</date>.<lb/>[Received July 18—9:35 a.m.]</dateline>
                            </opener>
                            <p>45. Wendelin in Madrid telephones by special permission <hi rend="italic">coup d’état</hi> planned for noon today.
                                Telegraphic and telephone communications closed. Will wire when
                                information more definite.</p>
                            <closer><signed><hi rend="smallcaps">Bowers</hi></signed></closer>
                        </div>
                        </body></text></TEI>