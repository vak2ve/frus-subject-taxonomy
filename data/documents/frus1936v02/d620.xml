                subtype="historical-document" type="document" xml:id="d620">
                <note rend="inline" type="source">352.115/4: Telegram</note>
                <head>
                    <hi rend="italic">The Third Secretary of Embassy in Spain</hi> (<persName
                        type="from">
                        <hi rend="italic">Wendelin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1936-07-29T20:00:00+00:00"
                            >July 29, 1936—8 p.m.</date>
                        <lb/>[Received July 29—7:55 p.m.]</dateline>
                </opener>
                <p>X–9. Reports in American press that Government has confiscated much American
                    property as yet unfounded. Some private automobiles of American citizens have
                    been requisitioned for war purposes. No confiscation of bank deposits but
                    moratorium on loans and limitation of withdrawal.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wendelin</hi>
                    </signed>
                </closer>
            </div>
        </body>
