                subtype="historical-document" type="document" xml:id="d217">
                <note rend="inline" type="source">362.1121 Simpson, Lawrence/147: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at Berlin</hi> (<persName type="to">
                        <hi rend="italic">Jenkins</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-04-28T18:00:00-04:00"
                            >April 28, 1936—6 p.m.</date>
                    </dateline>
                </opener>
                <p>Your despatch 888.<note n="11" xml:id="d217fn11">Not printed.</note> Department
                    approves your action in seeking to expedite Simpson proceedings and requests
                    that you continue to press for an early trial.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
