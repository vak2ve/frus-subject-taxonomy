                subtype="historical-document" type="document" xml:id="d355">
                <note rend="inline" type="source">740.0011 European War 1939/15728: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Bulgaria</hi> (<persName type="from">
                        <hi rend="italic">Earle</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Sofia</hi>
                        </placeName>, <date calendar="gregorian" when="1941-10-08T17:00:00+02:00"
                            >October 8, 1941—5 p.m.</date>
                        <lb/> [Received October 9—7:23 a.m.]</dateline>
                </opener>
                <p>410. My 394, September 24. The director of the press informs us that every effort
                    is being made to keep out of the Bulgarian press all articles unfavorable to our
                    country.</p>
                <p>No such articles have now appeared for some time.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Earle</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
