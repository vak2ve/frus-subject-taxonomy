    <text>
        <body>
            <div frus:doc-dateTime-max="1941-03-03T12:00:00-05:00"
                frus:doc-dateTime-min="1941-03-03T12:00:00-05:00" n="309"
                subtype="historical-document" type="document" xml:id="d309">
                <note rend="inline" type="source">870.811/234: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Rumania</hi> (<persName type="from">
                        <hi rend="italic">Gunther</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bucharest</hi>
                        </placeName>, <date calendar="gregorian" when="1941-03-03T19:00:00+02:00"
                            >March 3, 1941—7 p.m.</date>
                        <lb/> [Received March 4—3:06 a.m.]</dateline>
                </opener>
                <p>220. My 174, February 22, noon.<note n="58" xml:id="d309fn58">Not printed.</note>
                    The Secretary General of the Foreign Office informs me that the only important
                    development at the recent Vienna Danubian meeting was the admission of Russia on
                    the commission which hereafter will deal with the Upper Danube.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gunther</hi>
                    </signed>
                </closer>
            </div>
        </body>
