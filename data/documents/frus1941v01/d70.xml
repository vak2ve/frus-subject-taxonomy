                subtype="historical-document" type="document" xml:id="d70">
                <note rend="inline" type="source">811.20 (D) Regulations/5514</note>
                <head>
                    <hi rend="italic">Memorandum by the Acting Chief of the Division of European
                        Affairs</hi> (<persName type="from">
                        <hi rend="italic">Atherton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Division of
                            Controls</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1941-08-21">August 21,
                            1941</date>.</dateline>
                </opener>
                <p rend="center">
                    <hi rend="smallcaps">Recommended Policy With Respect To The Issuance Of Export
                        Licenses Covering Products Destined For Finland</hi>
                </p>
                <p>Until further notice it is recommended that applications for licenses covering
                    products destined for Finland be rejected.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Ray Atherton</hi>
                    </signed>
                </closer>
            </div>
        </body>
