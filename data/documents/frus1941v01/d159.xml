<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-06-24T18:00:00-05:00" frus:doc-dateTime-min="1941-06-24T18:00:00-05:00" n="159" subtype="historical-document" type="document" xml:id="d159">
                            <note rend="inline" type="source">740.0011 European War 1939/12433b:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Ambassador in the Soviet Union</hi>
                                    (<persName type="to"><hi rend="italic">Steinhardt</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1941-06-24T19:00:00-04:00">June
                                        24, 1941—7 p.m.</date>
                                </dateline>
                            </opener>
                            <p>840. Has the Soviet Union issued a formal proclamation of war against
                                Germany or against Italy? If so, please telegraph text and date.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Welles</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>