                subtype="historical-document" type="document" xml:id="d649">
                <note rend="inline" type="source">701.6111/1053: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the Soviet Union</hi> (<persName type="to">
                        <hi rend="italic">Steinhardt</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1941-11-01T17:00:00-05:00"
                            >November 1, 1941—5 p.m.</date>
                    </dateline>
                </opener>
                <p>1175. You are requested to inform the Foreign Office that the appointment of
                    Maxim Litvinov as Soviet Ambassador to Washington is most agreeable to this
                        Government.<note n="24" xml:id="d649fn24">Under Secretary of State Welles
                        noted on this telegram that it was “approved by the President by telephone
                        Nov. 1, 10:15 a.m.” The contents of the telegram were given to Assistant
                        People’s Commissar for Foreign Affairs Vyshinsky on November 4, 1941.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
