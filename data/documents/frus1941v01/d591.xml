<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-12-13T23:59:59-05:00" frus:doc-dateTime-min="1941-12-13T00:00:00-05:00" n="591" subtype="historical-document" type="document" xml:id="d591">
                        <note rend="inline" type="source">740.0011 European War 1939/17497:
                            Telegram</note>
                        <head>
                            <hi rend="italic">The Minister in Hungary</hi> (<persName type="from"><hi rend="italic">Pell</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Budapest</hi></placeName>, <date calendar="gregorian" when="1941-12-13">December 13,
                                1941</date>.<lb/>[Received December 13—2:36 p.m.]</dateline>
                        </opener>
                        <p>710. The Prime Minister informed me at 5:30 this afternoon that Hungary
                            considers war to exist between Hungary and United States. All codes
                            destroyed.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Pell</hi>
                            </signed>
                        </closer>
                    </div>
                </body></text></TEI>