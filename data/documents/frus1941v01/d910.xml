<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-03-22T18:00:00-05:00" frus:doc-dateTime-min="1941-03-22T18:00:00-05:00" n="910" subtype="historical-document" type="document" xml:id="d910">
                        <note rend="inline" type="source">361.1121 Pyk, Irena Teodozja/7:
                            Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Ambassador in the Soviet Union</hi>
                                (<persName type="to"><hi rend="italic">Steinhardt</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1941-03-22T18:00:00-05:00">March 22,
                                    1941—6 p.m.</date>
                            </dateline>
                        </opener>
                        <p>349. Your 550, March 20, 9 p.m.</p>
                        <list>
                            <label>1.</label>
                            <item>Gorin released today and planning to depart at once for Soviet
                                Union. You may therefore proceed as outlined in my 342, March 21, 8
                                p.m.</item>
                            <label>2.</label>
                            <item>Please endeavor to ascertain either direct or through Soviet
                                authorities whether Irene Pyk has relatives or friends in the United
                                States willing or able to pay her transportation expenses to this
                                country.</item>
                        </list>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Welles</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>