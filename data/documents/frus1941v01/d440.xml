<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-03-24T23:59:59-05:00" frus:doc-dateTime-min="1941-03-24T00:00:00-05:00" n="440" subtype="historical-document" type="document" xml:id="d440">
                        <note rend="inline" type="source">840.48 Refugees/2490: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Ambassador in the United Kingdom</hi>
                                (<persName type="to"><hi rend="italic">Winant</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1941-03-24">March 24,
                                1941</date>.</dateline>
                        </opener>
                        <p>1000. For Achilles.<note n="8" xml:id="d440fn8">Theodore C. Achilles,
                                Third Secretary of Embassy.</note> Mr. Myron Taylor<note n="9" xml:id="d440fn9">Chairman of the American Delegation to the
                                Intergovernmental Committee on Political Refugees.</note> wishes you
                            to inform Lord Winterton and Sir Herbert Emerson<note n="10" xml:id="d440fn10">Director of the Intergovernmental
                                Committee.</note> that the Secretary of State has designated Mr.
                            Edward S. Maney, a Foreign Service officer,<note n="11" xml:id="d440fn11">Assigned to the Division of European
                                Affairs.</note> as Secretary of the Intergovernmental Committee,
                            succeeding Mr. Alfred Wagg who resigned on March 1, 1941.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Welles</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>