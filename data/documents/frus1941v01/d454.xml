<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-12-16T14:00:00-05:00" frus:doc-dateTime-min="1941-12-16T14:00:00-05:00" n="454" subtype="historical-document" type="document" xml:id="d454">
                        <note rend="inline" type="source">851.00/2567: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador to the Polish Government in Exile</hi>
                                (<persName type="from"><hi rend="italic">Biddle</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1941-12-16T20:00:00+01:00">December
                                    16, 1941—8 p.m.</date>
                                <lb/> [Received December 16—2 p.m.]</dateline>
                        </opener>
                        <p>Polish Series 55. My 54, December 15, 7 p.m. Polish Foreign Office now
                            states Russians have consented to take part in proposed conference.</p>
                        <closer>
                            <signed>[<hi rend="smallcaps">Biddle</hi>]</signed>
                        </closer>
                    </div>
                    </body></text></TEI>