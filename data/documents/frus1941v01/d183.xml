                subtype="historical-document" type="document" xml:id="d183">
                <note rend="inline" type="source">701.4161/43: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in the Soviet Union</hi> (<persName type="from">
                        <hi rend="italic">Steinhardt</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Moscow</hi>
                        </placeName>, <date calendar="gregorian" when="1941-06-14T13:00:00+03:00"
                            >June 14, 1941—1 p.m.</date>
                        <lb/> [Received June 14—12:15 p.m.]</dateline>
                </opener>
                <p>1145. I learn that the British Embassy yesterday received instructions from
                    London to evacuate all women and children in the Embassy from the Soviet
                    Union.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Steinhardt</hi>
                    </signed>
                </closer>
            </div>
        </body>
