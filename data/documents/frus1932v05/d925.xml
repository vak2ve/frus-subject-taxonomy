                subtype="historical-document" type="document" xml:id="d925">
                <note rend="inline" type="source">823.00 Revolutions/323: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Peru</hi> (<persName corresp="#p_BWC1"
                        type="from">
                        <hi rend="italic">Burdett</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1932-07-07T14:00:00-05:00"
                            >July 7, 1932—2 p.m.</date>
                        <lb/> [Received 3:45 p.m.]</dateline>
                </opener>
                <p>96. Radical uprising occurred <persName corresp="#p_TMGRL1">Trujillo</persName>
                    early today. Military activities in Lima but no disorder.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWC1">
                            <hi rend="smallcaps">Burdett</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
