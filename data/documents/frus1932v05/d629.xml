                subtype="historical-document" type="document" xml:id="d629">
                <note rend="inline" type="source">816.00/839: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in El Salvador</hi> (<persName corresp="#p_MWJ1"
                        type="from">
                        <hi rend="italic">McCafferty</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Salvador</hi>
                        </placeName>, <date calendar="gregorian" when="1932-02-05T09:00:00-06:00"
                            >February 5, 1932—9 a.m.</date>
                        <lb/> [Received 1:36 p.m.]</dateline>
                </opener>
                <p>30. Yesterday the Legislative Assembly declared General <persName
                        corresp="#p_MH1">Martínez</persName> Constitutional President. The decree
                    approved by Congress states that the treaty of 1923 can in no way affect the
                    functions of the present government.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MWJ1">
                            <hi rend="smallcaps">McCafferty</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
