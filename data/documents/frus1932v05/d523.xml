                subtype="historical-document" type="document" xml:id="d523">
                <note rend="inline" type="source">825.01/67: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Chile</hi> (<persName corresp="#p_CWS1" type="to">
                        <hi rend="italic">Culbertson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-07-19T18:00:00-04:00"
                            >July 19, 1932—6 p.m.</date>
                    </dateline>
                </opener>
                <p>51. You are authorized in accordance with the suggestion contained in your
                    telegram No. 136, July 18, 4 p.m., to make acknowledgment to the note of the
                    Minister for Foreign Affairs. You will be guided in this connection by the
                    penultimate paragraph of the Department’s telegraphic instruction No. 25, June
                    6, 1932.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
