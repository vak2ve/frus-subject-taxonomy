<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-06-07T16:00:00-05:00" frus:doc-dateTime-min="1932-06-07T16:00:00-05:00" n="743" subtype="historical-document" type="document" xml:id="d743">
                        <note rend="inline" type="source">838.105/410: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Haiti</hi> (<persName corresp="#p_MDG1" type="to"><hi rend="italic">Munro</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1932-06-07T17:00:00-04:00">June 7,
                                    1932—5 p.m.</date>
                            </dateline>
                        </opener>
                        <p>31. Your 61, June 6, noon. The Department approves proposed text and
                            authorizes you to sign.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_SHL1">
                                    <hi rend="smallcaps">Stimson</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>