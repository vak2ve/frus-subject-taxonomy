                subtype="historical-document" type="document" xml:id="d575">
                <note rend="inline" type="source">818.00/1325: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Costa Rica</hi> (<persName type="to">
                        <hi rend="italic">Eberhardt</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-02-15T17:00:00-05:00"
                            >February 15, 1932—5 p.m.</date>
                    </dateline>
                </opener>
                <p>9. Your 12, February 15, 7 a.m. Please keep Department promptly and fully
                    informed of all developments by cable.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
