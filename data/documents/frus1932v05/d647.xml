<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-03-12T14:00:00-05:00" frus:doc-dateTime-min="1932-03-12T14:00:00-05:00" n="647" subtype="historical-document" type="document" xml:id="d647">
                        <note rend="inline" type="source">816.00/856: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in El Salvador</hi> (<persName corresp="#p_MWJ1" type="to"><hi rend="italic">McCafferty</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1932-03-12T14:00:00-05:00">March 12,
                                    1932—2 p.m.</date>
                            </dateline>
                        </opener>
                        <p>36. Your 58, March 11, 2 p.m. Department thoroughly approves the position
                            you took in your discussion with the Guatemalan Minister.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_SHL1">
                                    <hi rend="smallcaps">Stimson</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>