                subtype="historical-document" type="document" xml:id="d249">
                <note rend="inline" type="source">724.3415/2480: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Acting Chairman of the American Delegation to the General Disarmament
                        Conference (<persName type="to">Gibson</persName>)</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-11-02T17:00:00-05:00"
                            >November 2, 1932—5 p.m.</date>
                    </dateline>
                </opener>
                <p>28. For <persName corresp="#p_WHR1">Wilson</persName>. Your 32, November 2, 10
                    a.m. Commission of Neutrals will send a telegram to the President of the
                    Council. Please advise when the Committee will meet so that the telegram may be
                    sent at that time.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Carr</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
