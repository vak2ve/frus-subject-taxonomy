<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-12-20T12:00:00-05:00" frus:doc-dateTime-min="1932-12-20T12:00:00-05:00" n="220" subtype="historical-document" type="document" xml:id="d220">
                            <note rend="inline" type="source">724.3415/2666: Telegram</note>
                            <head>
                                <hi rend="italic">The Ambassador in Brazil (<persName corresp="#p_MEV1" type="from">Morgan</persName>) to the
                                        <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Rio de Janeiro</hi></placeName>, <date calendar="gregorian" when="1932-12-20T15:00:00-02:00">December 20, 1932—3 p.m.</date>
                                    <lb/> [Received December 20—1:10 p.m.]</dateline>
                            </opener>
                            <p>128. Department’s telegram 97.<note n="81" xml:id="d220fn81">December
                                    19, 6 p.m.</note> Brazilian Government telegraphed Bolivian,
                                Paraguayan Foreign Ministers Saturday, December 17, in the sense you
                                desired.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_MEV1">
                                        <hi rend="smallcaps">Morgan</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>