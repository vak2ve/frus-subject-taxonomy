<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-09-27T14:00:00-05:00" frus:doc-dateTime-min="1932-09-27T14:00:00-05:00" n="456" subtype="historical-document" type="document" xml:id="d456">
                        <note rend="inline" type="source">832.00 Revolutions/387: Telegram</note>
                        <head>
                            <hi rend="italic">The Consul General at São Paulo</hi> (<persName corresp="#p_CCR1" type="from"><hi rend="italic">Cameron</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">São Paulo</hi></placeName>, <date calendar="gregorian" when="1932-09-27T16:00:00-03:00">September
                                    27, 1932—4 p.m.</date>
                                <lb/> [Received, September 27—2:40 p.m.]</dateline>
                        </opener>
                        <p>With reference to my telegram September 27, noon, British warship is now
                            anchored at San Sebastian 75 miles from Santos.</p>
                        <p>Repeated to Embassy at Rio de Janeiro.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_CCR1">
                                    <hi rend="smallcaps">Cameron</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>