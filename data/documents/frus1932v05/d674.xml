                subtype="historical-document" type="document" xml:id="d674">
                <note rend="inline" type="source">816.01/237: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName corresp="#p_MEV1"
                        type="from">
                        <hi rend="italic">Morgan</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1932-09-20T11:00:00-03:00"
                            >September 20, 1932—11 a.m.</date>
                        <lb/> [Received September 20—10:35 a.m.]</dateline>
                </opener>
                <p>109. Foreign Minister states that Argentina wishes Brazil to recognize in
                    immediate future on same day and hour <hi rend="italic">de facto</hi> government
                    Salvador.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MEV1">
                            <hi rend="smallcaps">Morgan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
