    <text>
        <body>
            <div frus:doc-dateTime-max="1932-06-21T11:45:00-05:00"
                frus:doc-dateTime-min="1932-06-21T11:45:00-05:00" n="828"
                subtype="historical-document" type="document" xml:id="d828">
                <note rend="inline" type="source">817.00 <persName corresp="#p_WRACH1"
                        >Woodward</persName> Electoral Mission/91</note>
                <head>
                    <hi rend="italic">The Minister in Nicaragua</hi> (<persName corresp="#p_HME1"
                        type="from">
                        <hi rend="italic">Hanna</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1932-06-21T11:00:00-05:45"
                            >June 21, 1932—11 a.m.</date>
                        <lb/> [Received 2:45 p.m.]</dateline>
                </opener>
                <p>97. <persName corresp="#p_WRACH1">Admiral Woodward</persName> arrived here
                    yesterday accompanied by Mrs. <persName corresp="#p_WRACH1"
                    >Woodward</persName>.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HME1">
                            <hi rend="smallcaps">Hanna</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
