                <note rend="inline" type="source">838.51 A/213: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Haiti</hi> (<persName corresp="#p_MDG1" type="to">
                        <hi rend="italic">Munro</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1931-10-23T18:00:00-05:00"
                            >October 23, 1931—6 p.m.</date>
                    </dateline>
                </opener>
                <p>79. Your 124, October 22, 10 a.m. The Department approves your proposed
                    reply.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
