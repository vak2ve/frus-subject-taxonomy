    <text>
        <body>
            <div frus:doc-dateTime-max="1932-09-27T14:00:00-05:00"
                frus:doc-dateTime-min="1932-09-27T14:00:00-05:00" n="235"
                subtype="historical-document" type="document" xml:id="d235">
                <note rend="inline" type="source">724.3415/2339: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Geneva (<persName corresp="#p_GPB1" type="to"
                        >Gilbert</persName>)</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-09-27T14:00:00-05:00"
                            >September 27, 1932—2 p.m.</date>
                    </dateline>
                </opener>
                <p>141. Your 269, September 26, 5 p.m. <persName corresp="#p_WHR1">Wilson</persName>
                    has been informed<note n="15" xml:id="d235fn15">See <hi rend="italic"
                            >supra.</hi>
                    </note> regarding Chaco developments. Please advise him of <persName
                        corresp="#p_DVE1">De Valera</persName>’s conversation with you.<note n="16"
                        xml:id="d235fn16">As set forth in telegram No. 269, September 26, 5 p.m.,
                        from the Consul at Geneva, <ref target="#pg_232">p. 232</ref>.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
