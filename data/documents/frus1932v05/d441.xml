<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-08-15T07:00:00-05:00" frus:doc-dateTime-min="1932-08-15T07:00:00-05:00" n="441" subtype="historical-document" type="document" xml:id="d441">
                        <note rend="inline" type="source">123M82/252: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in Brazil</hi> (<persName corresp="#p_MEV1" type="from"><hi rend="italic">Morgan</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Rio de Janeiro</hi></placeName>, <date calendar="gregorian" when="1932-08-15T09:00:00-03:00">August 15,
                                    1932—9 a.m.</date>
                                <lb/> [Received 10:45 a.m.]</dateline>
                        </opener>
                        <p>88. Assumed charge today.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_MEV1">
                                    <hi rend="smallcaps">Morgan</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>