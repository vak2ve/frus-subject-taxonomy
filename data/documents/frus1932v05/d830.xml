<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-06-23T12:45:00-05:00" frus:doc-dateTime-min="1932-06-23T12:45:00-05:00" n="830" subtype="historical-document" type="document" xml:id="d830">
                        <note rend="inline" type="source">817.00 <persName corresp="#p_WRACH1">Woodward</persName> Electoral Mission/93: Telegram</note>
                        <head>
                            <hi rend="italic">The Minister in Nicaragua</hi> (<persName corresp="#p_HME1" type="from"><hi rend="italic">Hanna</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Managua</hi></placeName>, <date calendar="gregorian" when="1932-06-23T12:00:00-05:45">June 23,
                                    1932—noon</date>.<lb/>[Received 9:54 p.m.]</dateline>
                        </opener>
                        <p>98. <persName corresp="#p_WRACH1">Admiral Woodward</persName> took oath
                            of office as President of the National Board of Elections before the
                            Supreme Court of Justice at 11:30 this morning.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_HME1">
                                    <hi rend="smallcaps">Hanna</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>