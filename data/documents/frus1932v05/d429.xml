                subtype="historical-document" type="document" xml:id="d429">
                <note rend="inline" type="source">123M82/247: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName corresp="#p_MEV1"
                        type="from">
                        <hi rend="italic">Morgan</hi>
                    </persName>), <hi rend="italic">Temporarily at Paris, to the <gloss type="to"
                            >Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName> [<date
                            ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                            calendar="gregorian" notAfter="1932-07-21T10:35:00+02:00"
                            notBefore="1932-07-19T20:00:00+02:00">undated</date>].<lb/>[Received
                        July 21, 1932—4:35 a.m.]</dateline>
                </opener>
                <p>Sailing Brazil first available steamer.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MEV1">
                            <hi rend="smallcaps">Morgan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
