                subtype="historical-document" type="document" xml:id="d772">
                <note rend="inline" type="source">815.00 Revolutions/398: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Honduras</hi> (<persName corresp="#p_LJG1" type="to">
                        <hi rend="italic">Lay</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-12-13T18:00:00-05:00"
                            >December 13, 1932—6 p.m.</date>
                    </dateline>
                </opener>
                <p>57. Your 110, December 11, 4 p.m. Department approves your statement to the
                    President and feels that the situation as at present reported does not warrant
                    the dispatch of a war vessel to Amapala.</p>
                <p>Please keep Department fully advised of developments at Amapala.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
