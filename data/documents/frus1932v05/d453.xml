<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-09-26T19:00:00-05:00" frus:doc-dateTime-min="1932-09-26T19:00:00-05:00" n="453" subtype="historical-document" type="document" xml:id="d453">
                        <note rend="inline" type="source">832.00 Revolutions/385: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Brazil</hi> (<persName corresp="#p_MEV1" type="to"><hi rend="italic">Morgan</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1932-09-26T19:00:00-05:00">September
                                    26, 1932—7 p.m.</date>
                            </dateline>
                        </opener>
                        <p>83. The Department fully approves the actions reported in your 110,
                            September 21, 7 p.m., and 111, September 22, 10 a.m.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_SHL1">
                                    <hi rend="smallcaps">Stimson</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>