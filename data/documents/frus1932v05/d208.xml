                subtype="historical-document" type="document" xml:id="d208">
                <note rend="inline" type="source">724.3415/2280: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil (<persName corresp="#p_MEV1"
                            type="from">Morgan</persName>) to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1932-09-14T15:00:00-03:00"
                            >September 14, 1932—3 p.m.</date>
                        <lb/> [Received 3:30 p.m.]</dateline>
                </opener>
                <p>106. Department’s circular September 12 [<hi rend="italic">13</hi>], 6 p.m.
                    Foreign Minister cordially approves Neutrals’ memorandum and will instruct
                    Brazilian Ambassador to agree to and work under its terms.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MEV1">
                            <hi rend="smallcaps">Morgan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
