<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-07-19T13:00:00-05:00" frus:doc-dateTime-min="1932-07-19T13:00:00-05:00" n="428" subtype="historical-document" type="document" xml:id="d428">
                        <note rend="inline" type="source">123M82/245: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Great Britain</hi> (<persName type="to"><hi rend="italic">Mellon</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1932-07-19T14:00:00-04:00">July 19,
                                    1932—2 p.m.</date>
                            </dateline>
                        </opener>
                        <p>197. For Ambassador <persName corresp="#p_MEV1">Morgan</persName>. In
                            view of most recent reports from Brazil please return there as soon as
                            possible.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_SHL1">
                                    <hi rend="smallcaps">Stimson</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>