                subtype="historical-document" type="document" xml:id="d686">
                <note rend="inline" type="source">816.00B/45: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in El Salvador</hi> (<persName corresp="#p_MWJ1"
                        type="from">
                        <hi rend="italic">McCafferty</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Salvador</hi>
                        </placeName>, <date calendar="gregorian" when="1932-01-21T10:00:00-06:00"
                            >January 21, 1932—10 a.m.</date>
                        <lb/> [Received 1 p.m.]</dateline>
                </opener>
                <p>10. Referring to my telegram No. 9, January 20, 3 p.m., because of communistic
                    disturbances martial law has been declared in the six departments of Ahuachapán,
                    Santa Ana, Sonsonate, La Libertad, San Salvador and Chalatenango.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MWJ1">
                            <hi rend="smallcaps">McCafferty</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
