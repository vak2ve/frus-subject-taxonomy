                <note rend="inline" type="source">816.01/244: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Brazil</hi> (<persName corresp="#p_MEV1" type="to">
                        <hi rend="italic">Morgan</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-10-01T14:00:00-05:00"
                            >October 1, 1932—2 p.m.</date>
                    </dateline>
                </opener>
                <p>86. Your 117, September 28, 3 p.m. Please express appreciation to the
                    Minister.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
