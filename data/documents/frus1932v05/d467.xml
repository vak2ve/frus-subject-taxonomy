                subtype="historical-document" type="document" xml:id="d467">
                <note rend="inline" type="source">832.00 Revolutions/401: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName corresp="#p_MEV1"
                        type="from">
                        <hi rend="italic">Morgan</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1932-10-03T12:00:00-02:00"
                            >October 3, 1932—noon</date>.<lb/>[Received October 3—10
                        a.m.]</dateline>
                </opener>
                <p>118. Provisional Government states that armistice has been arranged. All São
                    Paulo military equipment will be surrendered.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MEV1">
                            <hi rend="smallcaps">Morgan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
