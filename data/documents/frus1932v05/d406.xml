<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-07-10T14:00:00-05:00" frus:doc-dateTime-min="1932-07-10T14:00:00-05:00" n="406" subtype="historical-document" type="document" xml:id="d406">
                        <note rend="inline" type="source">832.00 Revolutions/238: Telegram</note>
                        <head>
                            <hi rend="italic">The Chargé in Brazil</hi> (<persName type="from"><hi rend="italic">Thurston</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Rio de Janeiro</hi></placeName>, <date calendar="gregorian" when="1932-07-10T16:00:00-03:00">July 10,
                                    1932—4 p.m.</date>
                                <lb/> [Received 5:49 p.m.]</dateline>
                        </opener>
                        <p>51. Consul General <persName corresp="#p_CCR1">Cameron</persName>’s July
                            10, 11 a.m. Unconfirmed reports indicate movement involves in addition
                            to São Paulo the three southern States and Minas Geraes. Rio quiet.</p>
                        <closer>
                            <signed>
                                <persName>
                                    <hi rend="smallcaps">Thurston</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>