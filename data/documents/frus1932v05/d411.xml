                subtype="historical-document" type="document" xml:id="d411">
                <note rend="inline" type="source">832.00 Revolutions/246: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at São Paulo</hi> (<persName corresp="#p_CCR1" type="to">
                        <hi rend="italic">Cameron</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-07-12T18:00:00-04:00"
                            >July 12, 1932—6 p.m.</date>
                    </dateline>
                </opener>
                <p>Your telegram July 12, noon. Your telegrams July 10, 11 a.m. and July 11, noon,
                    have been received. Your reports are most helpful. Please continue to telegraph
                    all important facts.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
