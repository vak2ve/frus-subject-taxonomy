    <text>
        <body>
            <div frus:doc-dateTime-max="1932-07-15T23:59:59-05:00"
                frus:doc-dateTime-min="1932-07-15T00:00:00-05:00" n="939"
                subtype="historical-document" type="document" xml:id="d939">
                <note rend="inline" type="source">823.00 Revolutions/345</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Peruvian Ambassador</hi> (<persName corresp="#p_FSMd1" type="to">
                        <hi rend="italic">Freyre</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-07-15">July 15,
                            1932</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to acknowledge the
                    receipt of Your Excellency’s courteous communications of July 9 and 12,
                        1932,<note n="6" xml:id="d939fn6">Communication of July 9 not
                        printed.</note> inquiring under instructions from your Government regarding
                    the possibility of the sale to it by the United States of 300 explosive bombs
                    for bombing airplanes to be delivered at the Canal Zone. My Government has given
                    careful consideration to this request and regrets that the War Department finds
                    it impossible to deplete its reserve stock of bombs at the present time.</p>
                <p>Accept [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <persName corresp="#p_WF1">
                            <hi rend="smallcaps">Francis White</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
