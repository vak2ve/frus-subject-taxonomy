<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-12-22T23:59:59-05:00" frus:doc-dateTime-min="1932-12-22T00:00:00-05:00" n="129" subtype="historical-document" type="document" xml:id="d129">
                            <note rend="inline" type="source">724.3415/2681: Telegram</note>
                            <head>
                                <hi rend="italic">The Paraguayan Minister for Foreign Affairs
                                        (<persName corresp="#p_BJP1" type="from">Benítez</persName>)
                                    to the Chairman of the Commission of Neutrals (<persName corresp="#p_WF1" type="to">White</persName>)</hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Translation]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Asunción</hi></placeName>, <date calendar="gregorian" when="1932-12-22">December 22,
                                        1932</date>.<lb/>[Received 10:30 a.m.]</dateline>
                            </opener>
                            <p>Reply cablegram yesterday<note n="93" xml:id="d129fn93">Not printed;
                                    it requested authorization for the continued stay of Dr.
                                        <persName corresp="#p_SJJ1">Soler</persName>, Paraguayan
                                    delegate.</note> I must state to Your Excellency that President
                                    <persName corresp="#p_AE3">Ayala</persName> expressed American
                                Minister absolute opposition conditions proposed and advised they
                                would be immediately refused because they could not serve as basis
                                of any negotiation.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_BJP1">
                                        <hi rend="smallcaps">Justo Pastor Benítez</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>