                subtype="historical-document" type="document" xml:id="d219">
                <note rend="inline" type="source">724.3415/2668: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Honduras (<persName corresp="#p_LJG1"
                            type="from">Lay</persName>) to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1932-12-20T10:00:00-06:00"
                            >December 20, 1932—10 a.m.</date>
                        <lb/> [Received 2:40 p.m.]</dateline>
                </opener>
                <p>114. Minister of Foreign Affairs told me yesterday he had telegraphed Paraguayan
                    and Bolivian Governments supporting proposal of Commission of Neutrals and would
                    telegraph to Mr. <persName corresp="#p_WF1">White</persName> accordingly.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LJG1">
                            <hi rend="smallcaps">Lay</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
