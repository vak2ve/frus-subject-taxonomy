                subtype="historical-document" type="document" xml:id="d679">
                <note rend="inline" type="source">816.01/244: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName corresp="#p_MEV1"
                        type="from">
                        <hi rend="italic">Morgan</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1932-09-28T15:00:00-03:00"
                            >September 28, 1932—3 p.m.</date>
                        <lb/> [Received September 28—1:40 p.m.]</dateline>
                </opener>
                <p>117. Department’s 79, September 22, 11 a.m. Brazilian Government prefers to
                    follow practice of the United States and has informed Argentine Government that
                    it does not intend to recognize present government of Salvador.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MEV1">
                            <hi rend="smallcaps">Morgan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
