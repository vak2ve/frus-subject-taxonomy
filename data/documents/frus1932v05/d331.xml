<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-07-16T12:30:00-05:00" frus:doc-dateTime-min="1932-07-16T12:30:00-05:00" n="331" subtype="historical-document" type="document" xml:id="d331">
                        <note rend="inline" type="source">733.35/20: Telegram</note>
                        <head>
                            <hi rend="italic">The Minister in Uruguay (<persName type="from">Wright</persName>) to the <gloss type="to">Secretary of
                                    State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Montevideo</hi></placeName>, <date calendar="gregorian" when="1932-07-16T14:00:00-03:30">July 16,
                                    1932—2 p.m.</date>
                                <lb/> [Received 1:45 p.m.]</dateline>
                        </opener>
                        <p>40. Your 13, July 15, 4 p.m. Minister for Foreign Affairs states
                            Uruguayan Government will be happy to accept good offices of the United
                            States.</p>
                        <p>Repeated to Buenos Aires.</p>
                        <closer>
                            <signed>
                                <persName>
                                    <hi rend="smallcaps">Wright</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>