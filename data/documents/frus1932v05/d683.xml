<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-12-06T15:00:00-05:00" frus:doc-dateTime-min="1932-12-06T15:00:00-05:00" n="683" subtype="historical-document" type="document" xml:id="d683">
                        <note rend="inline" type="source">816.01/272: Telegram</note>
                        <head>
                            <hi rend="italic">The Chargé in El Salvador</hi> (<persName corresp="#p_MWJ1" type="from"><hi rend="italic">McCafferty</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">San Salvador</hi></placeName>, <date calendar="gregorian" when="1932-12-06T14:00:00-06:00">December
                                    6, 1932—2 p.m.</date>
                                <lb/> [Received 8:35 p.m.]</dateline>
                        </opener>
                        <p>107. German Government has recognized <persName corresp="#p_MH1">Martínez</persName> regime.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_MWJ1">
                                    <hi rend="smallcaps">McCafferty</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>