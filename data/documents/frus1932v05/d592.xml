                <note rend="inline" type="source">818.001J56/10: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Costa Rica</hi> (<persName type="to">
                        <hi rend="italic">Eberhardt</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-05-05T17:00:00-04:00"
                            >May 5, 1932—5 p.m.</date>
                    </dateline>
                </opener>
                <p>20. Your 37, May 4, 11 a.m. You are authorized to participate in inaugural
                    ceremonies.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_CWR1">
                            <hi rend="smallcaps">Castle</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
