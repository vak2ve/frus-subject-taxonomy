<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-07-13T16:00:00-05:00" frus:doc-dateTime-min="1932-07-13T16:00:00-05:00" n="937" subtype="historical-document" type="document" xml:id="d937">
                        <note rend="inline" type="source">823.00 Revolutions/336: Telegram</note>
                        <head>
                            <hi rend="italic">The Chargé in Peru</hi> (<persName corresp="#p_BWC1" type="from"><hi rend="italic">Burdett</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Lima</hi></placeName>, <date calendar="gregorian" when="1932-07-13T16:00:00-05:00">July 13,
                                    1932—4 p.m.</date>
                                <lb/> [Received 4:45 p.m.]</dateline>
                        </opener>
                        <p>107. Following telegram from <persName corresp="#p_WN1">Whyte</persName>:
                                <quote rend="blockquote">
                                <p>“July 13, 11 a.m. All Americans <persName corresp="#p_TMGRL1">Trujillo</persName> well”.</p>
                            </quote>
                        </p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BWC1">
                                    <hi rend="smallcaps">Burdett</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>