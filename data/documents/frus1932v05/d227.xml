                <note rend="inline" type="source">724.3415/2282: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Switzerland (<persName corresp="#p_WHR1" type="to"
                            >Wilson</persName>)</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-09-15T11:00:00-04:00"
                            >September 15, 1932—11 a.m.</date>
                    </dateline>
                </opener>
                <p>62. Department approves suggestion made by you in last paragraph of your 81,
                    September 14, 1 p.m. If this action should be taken it would help very
                    materially.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
