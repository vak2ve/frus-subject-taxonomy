<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-02-06T13:00:00-05:00" frus:doc-dateTime-min="1932-02-06T13:00:00-05:00" n="703" subtype="historical-document" type="document" xml:id="d703">
                        <note rend="inline" type="source">816.00 Revolutions/135: Telegram</note>
                        <head>
                            <hi rend="italic">The Chargé in El Salvador</hi> (<persName corresp="#p_MWJ1" type="from"><hi rend="italic">McCafferty</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">San Salvador</hi></placeName>, <date calendar="gregorian" when="1932-02-06T12:00:00-06:00">February
                                    6, 1932—noon</date>.<lb/>[Received 2:55 p.m.]</dateline>
                        </opener>
                        <p>32. Your 18, February 1, 5 p.m. In view of the further improvements in
                            the situation in San Salvador I do not think it is any longer necessary
                            for the destroyers to stand by in Corinto.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_MWJ1">
                                    <hi rend="smallcaps">McCafferty</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                </body></text></TEI>