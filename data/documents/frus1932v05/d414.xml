                subtype="historical-document" type="document" xml:id="d414">
                <note rend="inline" type="source">123M82/242: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Mellon</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1932-07-13T12:00:00+01:00"
                            >July 13, 1932—noon</date>.<lb/>[Received July 13—6:46 a.m.]</dateline>
                </opener>
                <p>220. From Ambassador <persName corresp="#p_MEV1">Morgan</persName>. Watching
                    Brazilian situation closely. Prepared to sail for Brazil July 19th if you
                    desire. Please reply American Embassy, London.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Mellon</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
