    <text>
        <body>
            <div frus:doc-dateTime-max="1932-06-06T23:59:59-05:00"
                frus:doc-dateTime-min="1932-06-06T00:00:00-05:00" n="572"
                subtype="historical-document" type="document" xml:id="d572">
                <note rend="inline" type="source">825.6363/129: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Chile</hi> (<persName corresp="#p_CWS1"
                        type="from">
                        <hi rend="italic">Culbertson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 1172</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santiago</hi>
                        </placeName>, <date calendar="gregorian" when="1932-06-06">June 6,
                            1932</date>.<lb/>[Received June 16.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to report that, in accordance
                    with the Department’s telegram No. 24 of May 28, 2 p.m., I submitted on June 3,
                    to the Minister for Foreign Affairs, a formal note on the proposed oil monopoly.
                    A copy is enclosed herewith.<note n="67" xml:id="d572fn67">Not printed.</note>
                </p>
                <p>Respectfully yours,</p>
                <closer>
                    <signed>
                        <persName corresp="#p_CWS1">
                            <hi rend="smallcaps">W. S. Culbertson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
