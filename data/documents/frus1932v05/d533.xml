<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-08-02T10:00:00-05:00" frus:doc-dateTime-min="1932-08-02T10:00:00-05:00" n="533" subtype="historical-document" type="document" xml:id="d533">
                        <note rend="inline" type="source">825.00 Revolutions/176: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in Chile</hi> (<persName corresp="#p_CWS1" type="from"><hi rend="italic">Culbertson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Santiago</hi></placeName>, <date calendar="gregorian" when="1932-08-02T10:00:00-05:00">August 2,
                                    1932—10 a.m.</date>
                                <lb/> [Received 10:45 a.m.]</dateline>
                        </opener>
                        <p>159. Peña Villalón, Minister of the Interior and Minister of Lands and
                            Colonization; <persName corresp="#p_SRC1">Soto Rengifo</persName>,
                            Minister of Education; and <persName corresp="#p_TI1">Toro</persName>,
                            Minister of Labor, resigned yesterday. New appointments are: <persName corresp="#p_FJ1">Josephus Fernandez</persName>, Minister of
                            Interior; <persName corresp="#p_COLD1">Luis David Cruz
                            Ocampo</persName>, Minister of Education; <persName corresp="#p_RJB1">Juan B. Rossetti</persName>, Minister of Labor. These changes are
                            away from the Left.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_CWS1">
                                    <hi rend="smallcaps">Culbertson</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>