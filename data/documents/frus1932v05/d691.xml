<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-01-23T16:00:00-05:00" frus:doc-dateTime-min="1932-01-23T16:00:00-05:00" n="691" subtype="historical-document" type="document" xml:id="d691">
                        <note rend="inline" type="source">816.00 Revolutions/58: Telegram</note>
                        <head>
                            <hi rend="italic">The Chargé in El Salvador</hi> (<persName corresp="#p_MWJ1" type="from"><hi rend="italic">McCafferty</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">San Salvador</hi></placeName>, <date calendar="gregorian" when="1932-01-23T15:00:00-06:00">January
                                    23, 1932—3 p.m.</date>
                                <lb/> [Received January 23—2:55 p.m.]</dateline>
                        </opener>
                        <p>16. Two British destroyers arrived today at Acajutla.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_MWJ1">
                                    <hi rend="smallcaps">McCafferty</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>