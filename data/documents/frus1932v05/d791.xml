                subtype="historical-document" type="document" xml:id="d791">
                <note rend="inline" type="source">812.001C13/125: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Nuevo Laredo</hi> (<persName type="from">
                        <hi rend="italic">Wormuth</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nuevo Laredo</hi>
                        </placeName>, <date calendar="gregorian" when="1932-06-17T20:00:00-06:00"
                            >June 17, 1932—8 p.m.</date>
                        <lb/> [Received 10:45 p.m.]</dateline>
                </opener>
                <p>Your telegram reference General <persName corresp="#p_CPE1">Calles</persName>.
                    Entire party passed border without difficulty. Report follows.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Wormuth</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
