                <note rend="inline" type="source">724.3415/2090: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Paraguay (<persName type="to">Wheeler</persName>)</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-08-18T14:00:00-04:00"
                            >August 18, 1932—2 p.m.</date>
                    </dateline>
                </opener>
                <p>34. Your 89, August 17, 7 p.m. Please cable alternative suggestion referred to as
                    quickly as possible.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_CWR1">
                            <hi rend="smallcaps">Castle</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
