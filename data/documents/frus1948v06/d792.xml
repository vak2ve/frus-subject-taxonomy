<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Political Adviser in Korea (
                        Jacobs
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1948v06</bibl><bibl type="frus-document-id">d792</bibl><bibl type="frus-document-number">792</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1948-04-30T00:00:00-05:00" notAfter="1948-04-30T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1948-04-30T23:59:59-05:00" frus:doc-dateTime-min="1948-04-30T00:00:00-05:00" n="792" subtype="historical-document" type="document" xml:id="d792">
                <note rend="inline" type="source">501.BB Korea/4–3048: Telegram</note>
                <head>
                    <hi rend="italic">The Political Adviser in Korea</hi> (<persName type="from">
                        <hi rend="italic">Jacobs</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">restricted</hi>
                        <lb/>
                        <hi rend="smallcaps">priority</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Seoul</hi>
                        </placeName>, <date calendar="gregorian" when="1948-04-30">April 30,
                            1948</date>.</dateline>
                </opener>
                <p>292. Cite <gloss target="#t_Zpol1">Zpol</gloss> 4558. After lengthy afternoon
                    session <gloss target="#t_UNTCOK1">UNTCOK</gloss> today adopted resolution of
                    which following is concluding paragraph (cannot get full text tonight).<note n="1" xml:id="d792fn1">The remainder of the text was quoted in telegram 298,
                        May 1, from Seoul, not printed. The resolution was printed as doc.
                        A/AC.19/69, April 30.</note>
                </p>
                <quote rend="blockquote">
                    <p>“Resolved that it proceed from Seoul to Tokyo on 15 May 1948 for the purpose
                        of preparing its report on the work covered so far; that it returns to Seoul
                        during first week of June and that during the period of its absence, liaison
                        groups of its representatives remain in Seoul to receive all necessary
                        information”.</p>
                </quote>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Jacobs</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
