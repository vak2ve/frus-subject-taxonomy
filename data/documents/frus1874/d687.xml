                <head>No. 685.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Fish</persName> to General <persName
                            type="to">Sickles</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1873-12-20">
                            <hi rend="italic">December</hi> 20, 1873</date>. (Sent 11.20
                        a.m.)</dateline>
                </opener>
                <p>Official advices received of surrender of survivors from Virginius.</p>
                <closer>
                    <signed>FISH.</signed>
                </closer>
            </div>
