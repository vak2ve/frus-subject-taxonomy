<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1873-11-19T23:59:59-05:00" frus:doc-dateTime-min="1873-11-19T00:00:00-05:00" n="632" subtype="historical-document" type="document" xml:id="d632">
                            <head>No. 630.<lb/><hi rend="italic">General <persName type="from">Sickles</persName> to Mr. <persName type="to">Fish</persName>.</hi></head>
                            <opener><seg rendition="#center">[Telegram.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Madrid</hi></placeName>, <date calendar="gregorian" when="1873-11-19"><hi rend="italic">November</hi> 19,
                                        1873</date>.</dateline></opener>
                            <p>Sent you three dispatches by cable yesterday. No reply received. I
                                wait instructions.</p>
                            <closer><signed>SICKLES.</signed></closer>
                        </div>
                        </body></text></TEI>