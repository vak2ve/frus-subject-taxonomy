                <head>No. 2.<lb/>Circular No 53.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1874-02-25">
                            <hi rend="italic">February</hi> 25, 1874</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="italic">To the Diplomatic and Consular Officers of the United
                        States:</hi>
                </p>
                <p>
                    <hi rend="smallcaps">Gentlemen</hi>: Hereafter passports issued to a citizen of
                    the United States from this Department are to be regarded as valid for two years
                    from their respectives dates, but not longer.</p>
                <p>I am, gentlemen, your obedient servant,</p>
                <closer>
                    <signed>HAMILTON FISH.</signed>
                </closer>
            </div>
        </body>
