<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1874-02-25T23:59:59-05:00" frus:doc-dateTime-min="1874-02-25T00:00:00-05:00" n="4" subtype="historical-document" type="document" xml:id="d4">
                    <head>No. 2.<lb/>Circular No 53.</head>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department
                                    of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1874-02-25"><hi rend="italic">February</hi> 25,
                            1874</date>.</dateline></opener>
                    <p rend="flushleft"><hi rend="italic">To the Diplomatic and Consular Officers of
                            the United States:</hi></p>
                    <p><hi rend="smallcaps">Gentlemen</hi>: Hereafter passports issued to a citizen
                        of the United States from this Department are to be regarded as valid for
                        two years from their respectives dates, but not longer.</p>
                    <p>I am, gentlemen, your obedient servant,</p>
                    <closer><signed>HAMILTON FISH.</signed></closer>
                </div>
            </body></text></TEI>