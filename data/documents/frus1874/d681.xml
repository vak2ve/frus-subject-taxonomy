        <body>
            <div frus:doc-dateTime-max="1873-12-16T23:59:59-05:00" frus:doc-dateTime-min="1873-12-16T00:00:00-05:00" n="681" subtype="historical-document" type="document" xml:id="d681">
                <head>No. 679.<lb/>
                    <hi rend="italic">General <persName type="from">Sickles</persName> to Mr. <persName type="to">Fish</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1873-12-16">
                            <hi rend="italic">December</hi> 16,
                                        1873</date>. (Received late p.m.)</dateline>
                </opener>
                <p>I respectfully request that my telegram of 6th instant tendering my
                                resignation, and your reply of same date, may be now published.</p>
                <closer>
                    <signed>SICKLES.</signed>
                </closer>
            </div>
        </body>
