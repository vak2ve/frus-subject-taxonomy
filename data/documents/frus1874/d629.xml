    <text>
        <body>
            <div frus:doc-dateTime-max="1873-11-18T23:59:59-05:00" frus:doc-dateTime-min="1873-11-18T00:00:00-05:00" n="629" subtype="historical-document" type="document" xml:id="d629">
                <head>No. 627.<lb/>
                    <hi rend="italic">General <persName type="from">Sickles</persName> to Mr. <persName type="to">Fish</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1873-11-18">
                            <hi rend="italic">November</hi> 18,
                                        1873</date>.</dateline>
                </opener>
                <p>If my departure forthwith is approved, please cause orders to be
                                cabled to Admiral Case, at Nice, to come to Valencia at once and
                                convey me and my family to a port in France.</p>
                <closer>
                    <signed>SICKLES.</signed>
                </closer>
            </div>
        </body>
