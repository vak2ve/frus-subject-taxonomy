<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1873-12-19T20:14:00-05:00" frus:doc-dateTime-min="1873-12-19T20:14:00-05:00" n="684" subtype="historical-document" type="document" xml:id="d684">
                            <head>No. 682.<lb/><hi rend="italic">General <persName type="from">Sickles</persName> to Mr. <persName type="to">Fish</persName>.</hi></head>
                            <opener><seg rendition="#center">[Telegram.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Madrid</hi></placeName>, <date calendar="gregorian" when="1873-12-20T01:00:00-00:14"><hi rend="italic">December</hi> 20, 1873—1
                                a.m.</date></dateline></opener>
                            <p>I respectfully renew the tender of my resignation, which I trust may
                                be accepted now without interfering with the prospects of an
                                accommodation.</p>
                            <closer><signed>SICKLES.</signed></closer>
                        </div>
                        </body></text></TEI>