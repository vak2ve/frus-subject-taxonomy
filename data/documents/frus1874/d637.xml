<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1873-11-19T23:59:59-05:00" frus:doc-dateTime-min="1873-11-19T00:00:00-05:00" n="637" subtype="historical-document" type="document" xml:id="d637">
                            <head>No. 635.<lb/><hi rend="italic">Mr. <persName type="from">Fish</persName> to General <persName type="to">Sickles</persName>.</hi></head>
                            <opener><seg rendition="#center">[Telegram.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1873-11-19"><hi rend="italic">November</hi> 19,
                                        1873</date>.</dateline></opener>
                            <p>Your telegrams of last evening received. An instruction will be sent
                                immediately.</p>
                            <closer><signed>FISH.</signed></closer>
                        </div>
                        </body></text></TEI>