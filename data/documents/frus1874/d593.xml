                <head>No. 591.<lb/>
                    <hi rend="italic">General <persName type="from">Sickles</persName> to Mr.
                            <persName type="to">Fish</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1873-11-11">
                            <hi rend="italic">November</hi> 11, 1873</date>.</dateline>
                </opener>
                <p>Have requested that orders be sent permitting our consul to see and freely confer
                    with American citizens in custody of authorities at Santiago de Cuba.</p>
                <closer>
                    <signed>SICKLES.</signed>
                </closer>
            </div>
        </body>
