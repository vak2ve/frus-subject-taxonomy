<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-10-26T17:00:00-05:00" frus:doc-dateTime-min="1949-10-26T17:00:00-05:00" n="1139" subtype="historical-document" type="document" xml:id="d1139">
                    <note rend="inline" type="source">125.351/10–2649: Circular telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                <gloss type="to">Certain Diplomatic and Consular Offices in
                                China</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1949-10-26T17:00:00-05:00">October 26,
                                1949—5 p. m.</date>
                        </dateline>
                    </opener>
                    <p>Consulate Dairen closed Oct 21. All Amer personnel departed.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Acheson</hi>
                        </signed>
                    </closer>
                </div>
            </body></text></TEI>