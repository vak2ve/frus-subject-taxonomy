    <teiHeader><fileDesc><titleStmt><title>The Consul General at Peiping (
                        Clubb
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1949v08</bibl><bibl type="frus-document-id">d945</bibl><bibl type="frus-document-number">945</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1949-07-20T20:00:00-05:00" notAfter="1949-07-20T20:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1949-07-20T20:00:00-05:00" frus:doc-dateTime-min="1949-07-20T20:00:00-05:00" n="945" subtype="historical-document" type="document" xml:id="d945">
                <note rend="inline" type="source">123 Stuart, J. Leighton: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Peiping</hi> (<persName type="from">
                        <hi rend="italic">Clubb</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1949-07-21T09:00:00+08:00">July 21, 1949—9 a. m.</date>
                        <lb/> [Received July 21—5:42 a. m.]</dateline>
                </opener>
                <p>1204. [To Nanking:] July 20, 2 p.m. ReContel 843, July 18.<note n="25" xml:id="d945fn25">Same as telegram No. 1189 from Peiping, <ref target="#pg_790">p. 790</ref>.</note> Joseph Chang informed me by phone
                    last night message delivered July 18; action unknown.</p>
                <pb facs="0805" n="795" xml:id="pg_795"/>
                <p>Sent Nanking 853; repeated Department, Shanghai 813.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Clubb</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
