        <body>
            <div frus:doc-dateTime-max="1949-08-26T07:00:00-05:00" frus:doc-dateTime-min="1949-08-26T07:00:00-05:00" n="830" subtype="historical-document" type="document" xml:id="d830">
                <note rend="inline" type="source">123 Strong, Robert C.: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName type="from">
                        <hi rend="italic">Strong</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Canton</hi>
                        </placeName>, <date calendar="gregorian" when="1949-08-26T20:00:00+08:00">August 26, 1949—8 p. m.</date>
                        <lb/> [Received August 26—4:07 p. m.]</dateline>
                </opener>
                <p>Cantel 1027. ReCantel 1014, August 23 [<hi rend="italic">24</hi>].<note n="74" xml:id="d830fn74">Not printed.</note> Clark departed this afternoon. I
                    assumed charge as of cob<note n="75" xml:id="d830fn75">Close of business.</note>
                    August 25.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Strong</hi>
                    </signed>
                </closer>
            </div>
