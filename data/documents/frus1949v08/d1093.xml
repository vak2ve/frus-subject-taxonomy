<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Counselor of Embassy in China (
                        Jones
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1949v08</bibl><bibl type="frus-document-id">d1093</bibl><bibl type="frus-document-number">1093</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1949-08-04T00:00:00-05:00" notAfter="1949-08-04T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1949-08-04T23:59:59-05:00" frus:doc-dateTime-min="1949-08-04T00:00:00-05:00" n="1093" subtype="historical-document" type="document" xml:id="d1093">
                <note rend="inline" type="source">123 Bacon, Leonard Lee: Telegram</note>
                <head>
                    <hi rend="italic">The Counselor of Embassy in China</hi> (<persName type="from">
                        <hi rend="italic">Jones</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1949-08-04">August 4,
                            1949</date>.<lb/>[Received August 4—4:27 p. m.]</dateline>
                </opener>
                <p>1712. Re Deptel 479, July 23 [<hi rend="italic">22</hi>]<note n="48" xml:id="d1093fn48">Not printed.</note>. Bacon’s application exit permit via
                    Tientsin, destination Dairen by way of Tokyo, filed August 3. Application
                    received for consideration only. Statement made that foreigners travel
                    Nanking-Tientsin not yet authorized. Similar statement made to AMilAt<note n="49" xml:id="d1093fn49">Office of Military Attaché in China.</note> Beebe
                    August 1.</p>
                <p>Sent Department 1712 repeated Peiping 317 Dairen 46.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Jones</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
