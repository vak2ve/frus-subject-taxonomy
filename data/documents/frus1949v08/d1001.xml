        <body>
            <div frus:doc-dateTime-max="1949-09-25T23:59:59-05:00" frus:doc-dateTime-min="1949-09-25T00:00:00-05:00" n="1001" subtype="historical-document" type="document" xml:id="d1001">
                <note rend="inline" type="source">123 Jones, J. Wesley: Telegram</note>
                <head>
                    <hi rend="italic">The Counselor of Embassy in China</hi> (<persName type="from">
                        <hi rend="italic">Jones</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1949-09-25">September 25,
                            1949</date>.<lb/>[Received September 30—1:30 a. m.]</dateline>
                </opener>
                <p>2172. China Post Circular. Embassy cirtel September 20, repeated Department
                        2140.<note n="89" xml:id="d1001fn89">Not printed.</note> Relinquished charge
                    office Embassy Nanking to Bacon today September 25, and depart China.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Jones</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
