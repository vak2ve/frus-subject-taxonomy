        <body>
            <div frus:doc-dateTime-max="1949-07-10T23:00:00-05:00" frus:doc-dateTime-min="1949-07-10T23:00:00-05:00" n="921" subtype="historical-document" type="document" xml:id="d921">
                <note rend="inline" type="source">123 Clark, Lewis: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Stuart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1949-07-11T12:00:00+08:00">July 11, 1949—noon</date>.<lb/>[Received July 11—2:11 a. m.]</dateline>
                </opener>
                <p>1472 I would appreciate if Department would instruct Lewis Clark to meet me
                    Okinawa for consultation on or about July 18.</p>
                <p>Sent Department; repeated OffEmb Canton 617.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stuart</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
