<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-07-16T23:59:59-05:00" frus:doc-dateTime-min="1949-07-16T00:00:00-05:00" n="1569" subtype="historical-document" type="document" xml:id="d1569">
                        <note rend="inline" type="source">123 Cabot, John M.: Telegram</note>
                        <head>
                            <hi rend="italic">The Consul at Shanghai</hi> (<persName type="from"><hi rend="italic">McConaughy</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Shanghai</hi></placeName>, <date calendar="gregorian" when="1949-07-16">July 16, 1949.</date>
                                <lb/> [Received July 16—2:45 a. m.]</dateline>
                        </opener>
                        <p>2798. Cabot, William Olive, Marie Olive, Mason, Kinkoff and one Chinese
                            employee left Shanghai for Nanking by train 10:45 last night. Arrived
                            Nanking 7:15.</p>
                        <p>Sent Department; repeated Nanking.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">McConaughy</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>