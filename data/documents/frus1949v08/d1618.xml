        <body>
            <div frus:doc-dateTime-max="1949-08-05T04:00:00-05:00" frus:doc-dateTime-min="1949-08-05T04:00:00-05:00" n="1618" subtype="historical-document" type="document" xml:id="d1618">
                <note rend="inline" type="source">893.918/8–549: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Peiping</hi> (<persName type="from">
                        <hi rend="italic">Clubb</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1949-08-05T17:00:00+08:00">August 5, 1949—5 p. m.</date>
                        <lb/> [Received August 17—11:09 a. m.]</dateline>
                </opener>
                <p>1307. ReDeptel 499, July 28. Appropriate letter sent headquarters PLA under date
                    August 4.</p>
                <p>Copy by post.<note n="45" xml:id="d1618fn45">Despatch No. 103, August 5, not
                        printed.</note>
                </p>
                <p>Sent Department, repeated Nanking 933, Shanghai 859.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Clubb</hi>
                    </signed>
                </closer>
            </div>
        </body>
