        <body>
            <div frus:doc-dateTime-max="1949-12-06T23:59:59-05:00" frus:doc-dateTime-min="1949-12-06T00:00:00-05:00" n="1290" subtype="historical-document" type="document" xml:id="d1290">
                <note rend="inline" type="source">123 Ward, Angus I.: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Peiping</hi> (<persName type="from">
                        <hi rend="italic">Clubb</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1949-12-06">December 6,
                            1949</date>.<lb/>[Received December 5—10:03 p. m.]</dateline>
                </opener>
                <p>2208. Mukden informed by phone today Ward party scheduled leave Mukden 0345 hours
                    December 7.</p>
                <p>Sent Department 2208, repeated AmPolAd Tokyo, Shanghai 1271, Nanking 1218, Taipei
                    48, Tientsin by phone and mail.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Clubb</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
