<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-07-26T22:00:00-05:00" frus:doc-dateTime-min="1949-07-26T22:00:00-05:00" n="957" subtype="historical-document" type="document" xml:id="d957">
                        <note rend="inline" type="source">123 Stuart, J. Leighton: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in China</hi> (<persName type="from"><hi rend="italic">Stuart</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Nanking</hi></placeName>, <date calendar="gregorian" when="1949-07-27T11:00:00+08:00">July 27,
                                    1949—11 a. m.</date>
                                <lb/> [Received July 27—12:03 a. m.]</dateline>
                        </opener>
                        <p>1629. Unless Embassy has reply to its telegram 1603, July 24, within 24
                            hours, is doubtful that it will be possible to complete all arrangements
                                <pb facs="0813" n="803" xml:id="pg_803"/> for departure of
                            Ambassador and party prior to deadline established in Deptel 875, July
                            23, repeated Canton telCan 490.<note n="36" xml:id="d957fn36">Not
                                printed; the deadline was August 1.</note>
                        </p>
                        <p>Sent Department; repeated OffEmb Canton 682.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Stuart</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>