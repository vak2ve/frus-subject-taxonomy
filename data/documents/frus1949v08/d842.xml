                subtype="historical-document" type="document" xml:id="d842">
                <note rend="inline" type="source">123 Rinden, Robert W.: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName type="from">
                        <hi rend="italic">Strong</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            state</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chungking</hi>
                        </placeName>, <date calendar="gregorian" when="1949-10-18">October 18,
                            1949</date>.<lb/>[Received October 18—3:45 a. m.]</dateline>
                </opener>
                <p>Cantel 1210. Rinden,<note n="83" xml:id="d842fn83">Robert W. Rinden, appointed
                        Consul at Batavia, on temporary detail to Chungking.</note> Norton<note
                        n="84" xml:id="d842fn84">Lawrence H. Norton, communications supervisor of
                        the Embassy Office in China.</note> and Strong arrived Chungking October 17,
                    recommencing office functions today.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Strong</hi>
                    </signed>
                </closer>
            </div>
        </body>
