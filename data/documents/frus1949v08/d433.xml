    <text>
        <body>
            <div frus:doc-dateTime-max="1949-06-03T23:00:00-05:00"
                frus:doc-dateTime-min="1949-06-03T23:00:00-05:00" n="433"
                subtype="historical-document" type="document" xml:id="d433">
                <note rend="inline" type="source">893.00/6–449: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Hankow</hi> (<persName type="from">
                        <hi rend="italic">Callanan</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Hankow</hi>
                        </placeName>, <date calendar="gregorian" when="1949-06-04T12:00:00+08:00"
                            >June 4, 1949—noon</date>.<lb/>[Received June 4—4:57 a. m.]</dateline>
                </opener>
                <p>171. Changsha reported evacuated by General Pai<note n="87" xml:id="d433fn87">Pai
                        Clung-hsi, Military and Political Affairs Director for Central China.</note>
                    June 2.</p>
                <p>Sent Department, repeated Nanking 131, OffEmb Canton 78.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Callanan</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
