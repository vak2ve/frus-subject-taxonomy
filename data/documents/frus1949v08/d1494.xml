            <div frus:doc-dateTime-max="1949-06-22T17:00:00-05:00" frus:doc-dateTime-min="1949-06-22T17:00:00-05:00" n="1494" subtype="historical-document" type="document" xml:id="d1494">
                <note rend="inline" type="source">123 [Colling, Guy Thomas]: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at Shanghai</hi> (<persName type="to">
                        <hi rend="italic">Cabot</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1949-06-22T18:00:00-04:00">June 22, 1949—6 p. m.</date>
                    </dateline>
                </opener>
                <p>1258. Reurtel 2408, June 22. Colling shld not appear before commissioners.
                    Instructions follow immediately.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Acheson</hi>
                    </signed>
                </closer>
            </div>
