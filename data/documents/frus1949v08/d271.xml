            <div frus:doc-dateTime-max="1949-04-05T23:59:59-05:00" frus:doc-dateTime-min="1949-04-05T00:00:00-05:00" n="271" subtype="historical-document" type="document" xml:id="d271">
                <note rend="inline" type="source">893.00/4–549: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Stuart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1949-04-05">April 5,
                            1949</date>.<lb/>[Received April 4—10:46 p. m.]</dateline>
                </opener>
                <p>699. North Shensi broadcast April 1 announces appointment Nieh Jung-chen sixth
                    Communist peace delegate and Chi Yi-ming Secretary General Communist
                    delegation.</p>
                <p>Sent Department 699, repeated Shanghai 327, OffEmb Canton unnumbered.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stuart</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
