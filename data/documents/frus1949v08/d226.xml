<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Consul General at Shanghai (
                        Cabot
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1949v08</bibl><bibl type="frus-document-id">d226</bibl><bibl type="frus-document-number">226</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1949-03-22T00:00:00-05:00" notAfter="1949-03-22T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1949-03-22T23:59:59-05:00" frus:doc-dateTime-min="1949-03-22T00:00:00-05:00" n="226" subtype="historical-document" type="document" xml:id="d226">
                <note rend="inline" type="source">893.00/3–2249: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from">
                        <hi rend="italic">Cabot</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1949-03-22">March 22,
                            1949</date>.<lb/>[Received March 22—3:37 a. m.]</dateline>
                </opener>
                <p>965. Local press 21 and 22 features story on bombing of <hi rend="italic">Chungking</hi>
                    <note n="31" xml:id="d226fn31">Chinese cruiser which deserted to
                        Communists.</note> at Hulutao by Nationalist planes [March] 18 and 19,
                    publishing today’s issue official AF photo showing ship, alleged to be <hi rend="italic">Chungking</hi>, lying on side.</p>
                <p>Sent Nanking 566; repeated Department 965, Canton 189.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cabot</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
