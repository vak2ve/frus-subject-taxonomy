<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-07-12T17:00:00-05:00" frus:doc-dateTime-min="1949-07-12T17:00:00-05:00" n="924" subtype="historical-document" type="document" xml:id="d924">
                        <note rend="inline" type="source">123 Stuart, J. Leighton: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in China</hi> (<persName type="to"><hi rend="italic">Stuart</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1949-07-12T18:00:00-04:00">July 12,
                                    1949—6 p. m.</date>
                            </dateline>
                        </opener>
                        <p>819. In accordance urtel 1475 Jul 11, you are authorized depart from
                            Nanking on Jul 18.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Acheson</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>