<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-04-29T22:00:00-05:00" frus:doc-dateTime-min="1949-04-29T22:00:00-05:00" n="1171" subtype="historical-document" type="document" xml:id="d1171">
                        <note rend="inline" type="source">125.0093/4–3049: Telegram</note>
                        <head>
                            <hi rend="italic">The Consul General at Peiping</hi> (<persName type="from"><hi rend="italic">Clubb</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Peiping</hi></placeName>, <date calendar="gregorian" when="1949-04-30T11:00:00+08:00">April 30,
                                    1949—11 a. m.</date>
                                <lb/> [Received April 30—9 a. m.]</dateline>
                        </opener>
                        <p>735. ReDeptel 212, April 15, Contel 654, April 19. Registered letter sent
                            express today to Peiping General Headquarters, People’s Liberation Army,
                            along lines indicated Department’s reference telegram.</p>
                        <p>Passed Nanking 468, Canton 90, Shanghai 498.</p>
                        <closer>[<signed>
                                <hi rend="smallcaps">Clubb</hi>
                            </signed>]</closer>
                    </div>
                    </body></text></TEI>