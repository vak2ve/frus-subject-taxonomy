<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-08-02T23:59:59-05:00" frus:doc-dateTime-min="1949-08-02T00:00:00-05:00" n="970" subtype="historical-document" type="document" xml:id="d970">
                        <note rend="inline" type="source">123 Jones, J. Wesley: Telegram</note>
                        <head>
                            <hi rend="italic">The Counselor of Embassy in China</hi> (<persName type="from"><hi rend="italic">Jones</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Nanking</hi></placeName>, <date calendar="gregorian" when="1949-08-02">August 2,
                                1949</date>.<lb/>[Received August 2—1:24 a. m.]</dateline>
                        </opener>
                        <p>1680. I have assumed charge of the office of the American Embassy at
                            Nanking as of today, August 2, 1949.</p>
                        <p>Sent Department, repeated circular to all China posts.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Jones</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>