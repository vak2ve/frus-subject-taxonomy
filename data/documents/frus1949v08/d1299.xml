<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-12-13T23:59:59-05:00" frus:doc-dateTime-min="1949-12-13T00:00:00-05:00" n="1299" subtype="historical-document" type="document" xml:id="d1299">
                        <note rend="inline" type="source">125.633/12–1349: Telegram</note>
                        <head>
                            <hi rend="italic">The Consul at Tientsin</hi> (<persName type="from"><hi rend="italic">Wellborn</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Tientsin</hi></placeName>, <date calendar="gregorian" when="1949-12-13">December 13,
                                1949</date>.<lb/>[Received December 15—12:44 a. m.]</dateline>
                        </opener>
                        <p>1047. From Ward. “Consulate General Mukden declared closed on December 8
                            at 0800 hours upon my departure from Consular District through
                            Shanhaikuan.”</p>
                        <p>Sent Department 1047; repeated Peiping by mail 332. [Ward.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Wellborn</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>