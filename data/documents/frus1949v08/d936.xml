    <teiHeader><fileDesc><titleStmt><title>The Consul at Taipei (
                        Edgar
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1949v08</bibl><bibl type="frus-document-id">d936</bibl><bibl type="frus-document-number">936</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1949-07-17T21:00:00-05:00" notAfter="1949-07-17T21:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1949-07-17T21:00:00-05:00" frus:doc-dateTime-min="1949-07-17T21:00:00-05:00" n="936" subtype="historical-document" type="document" xml:id="d936">
                <note rend="inline" type="source">123 Stuart, J. Leighton: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Taipei</hi> (<persName type="from">
                        <hi rend="italic">Edgar</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Taipei</hi>
                        </placeName>, <date calendar="gregorian" when="1949-07-18T11:00:00+09:00">July 18, 1949—11 a. m.</date>
                        <lb/> [Received July 17—11:04 p. m.]</dateline>
                </opener>
                <p>294. Information on Ambassador flight given personally [to] General Chou
                        Chi-jou<note n="15" xml:id="d936fn15">Commanding the Chinese Air
                        Force.</note> who assures me appropriate orders would be issued at once.
                    Please advise if 19th schedule postponed.</p>
                <p>Sent Nanking 183; repeated Department 294; Canton 128.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edgar</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
