                <note rend="inline" type="source">125.351/10–349: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Consul at Dairen</hi> (<persName type="to">
                        <hi rend="italic">Paddock</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1949-10-03T18:00:00-05:00"
                            >October 3, 1949—6 p. m.</date>
                    </dateline>
                </opener>
                <p>164. Assume you answering Hong Kong’s 788 to Dept Oct 3 re assurances
                    requested.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Webb</hi>
                    </signed>
                </closer>
            </div>
        </body>
