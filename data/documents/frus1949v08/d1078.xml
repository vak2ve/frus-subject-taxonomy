<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-06-09T09:00:00-05:00" frus:doc-dateTime-min="1949-06-09T09:00:00-05:00" n="1078" subtype="historical-document" type="document" xml:id="d1078">
                    <note rend="inline" type="source">123 Gleysteen, Culver: Telegram</note>
                    <head>
                        <hi rend="italic">The Chargé in the Soviet Union</hi> (<persName type="from"><hi rend="italic">Kohler</hi></persName>) <hi rend="italic">to the
                                <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Moscow</hi></placeName>, <date calendar="gregorian" when="1949-06-09T17:00:00+03:00">June 9, 1949—5
                                p. m.</date>
                            <lb/> [Received June 9—11:28 a. m.]</dateline>
                    </opener>
                    <p>1490. Note sent Foreign Office today re Gleysteen arrest accordance
                        Department instructions Deptel 409, June 2.</p>
                    <p>Sent Departzment 1490, repeated Dairen 26, Nanking 65, Canton 31.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Kohler</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>