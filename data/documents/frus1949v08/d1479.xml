<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-06-10T22:00:00-05:00" frus:doc-dateTime-min="1949-06-10T22:00:00-05:00" n="1479" subtype="historical-document" type="document" xml:id="d1479">
                        <note rend="inline" type="source">102.22/6–1049: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Consul General at Shanghai</hi> (<persName type="to"><hi rend="italic">Cabot</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1949-06-10T23:00:00-04:00">June 10,
                                    1949—11 p. m.</date>
                            </dateline>
                        </opener>
                        <p>1172. Urtels 2153 June 8, 2205 Jun 10 sent by Navy to ComNavWesPac for
                            action.</p>
                        <p>Keep Dept informed.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Webb</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>