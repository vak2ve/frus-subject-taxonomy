                subtype="historical-document" type="document" xml:id="d291">
                <note rend="inline" type="source">893.00/4–1649: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Stuart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1949-04-16T12:00:00+08:00"
                            >April 16, 1949—noon</date>.<lb/>[Received April 16—3:08 a.
                        m.]</dateline>
                </opener>
                <p>772. Acting President has invited me to conference Monday afternoon with my
                    British, French, Italian colleagues. He wants to discuss current Chinese
                    situation with us all and asked that meeting be kept confidential as
                    possible.</p>
                <p>Sent Department; repeated OffEmb Canton 256.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stuart</hi>
                    </signed>
                </closer>
            </div>
        </body>
