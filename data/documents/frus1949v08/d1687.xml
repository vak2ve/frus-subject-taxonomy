<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-10-03T01:00:00-05:00" frus:doc-dateTime-min="1949-10-03T01:00:00-05:00" n="1687" subtype="historical-document" type="document" xml:id="d1687">
                    <note rend="inline" type="source">125.937D/10–349: Circular telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss>
                            to <gloss type="to">Certain Diplomatic and Consular Offices</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1949-10-03T01:00:00-05:00">October 3,
                                1949—1 a. m.</date>
                        </dateline>
                    </opener>
                    <p>Consulate Tihwa closed. All Amer personnel departed.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Webb</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>