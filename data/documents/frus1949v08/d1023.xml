<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-11-15T12:00:00-05:00" frus:doc-dateTime-min="1949-11-15T12:00:00-05:00" n="1023" subtype="historical-document" type="document" xml:id="d1023">
                        <note rend="inline" type="source">121.5493/11–1449: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Consul General at Peiping</hi> (<persName type="to"><hi rend="italic">Clubb</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>Washington,</placeName>
                                <date calendar="gregorian" when="1949-11-15T12:00:00-05:00">November
                                    15, 1949—noon</date>.</dateline>
                        </opener>
                        <p>793. Re Embtel 396, Nov 14.<note n="15" xml:id="d1023fn15">Same as
                                telegram No. 2413 from Nanking, <ref target="#pg_849">p.
                                849</ref>.</note> If you perceive no objection Pls file
                            supplementary protest suggested Embtel 395, Nov 14.<note n="16" xml:id="d1023fn16">Same as telegram No. 2412 from Nanking, <ref target="#pg_848">p. 848</ref>.</note>
                        </p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Webb</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>