                subtype="historical-document" type="document" xml:id="d964">
                <note rend="inline" type="source">123 Stuart, J. Leighton: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Taipei</hi> (<persName type="from">
                        <hi rend="italic">Macdonald</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Taipei</hi>
                        </placeName>, <date calendar="gregorian" when="1949-07-30T09:00:00+09:00"
                            >July 30, 1949—9 a. m.</date>
                        <lb/> [Received 10:31 a. m.]</dateline>
                </opener>
                <p>335. Information urtel 70, July 29<note n="44" xml:id="d964fn44">Same as telegram
                        No. 1644 from Nanking, <ref target="#pg_804">p. 804</ref>.</note> given
                    personally General Chou Chi-jou who is issuing orders.</p>
                <p>Sent Nanking 190, repeated Department 335, Canton 146.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Macdonald</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
