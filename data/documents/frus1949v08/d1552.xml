                subtype="historical-document" type="document" xml:id="d1552">
                <note rend="inline" type="source">123 Olive, William M.: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from">
                        <hi rend="italic">Cabot</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1949-07-12T15:00:00+08:00"
                            >July 12, 1949—3 p. m.</date>
                        <lb/> [Received July 12—4:53 a. m.]</dateline>
                </opener>
                <p>2715. Deptel 1382, July 11, 5 p. m., Olive case. Before lodging further protest,
                    would appreciate urgent reply mytel 2684, July 10, 4 p. m., suggesting
                    possibility joint protest by Consular body.</p>
                <p>Sent Department, repeated Nanking 1521, Peiping 201.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cabot</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
