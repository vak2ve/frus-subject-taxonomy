            <div frus:doc-dateTime-max="1949-11-19T23:59:59-05:00" frus:doc-dateTime-min="1949-11-19T00:00:00-05:00" n="1694" subtype="historical-document" type="document" xml:id="d1694">
                <note rend="inline" type="source">125.313/11–1949: Telegram</note>
                <head>
                    <hi rend="italic">The Vice Consul at Chungking</hi> (<persName type="from">
                        <hi rend="italic">Rozier</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chungking</hi>
                        </placeName>, <date calendar="gregorian" when="1949-11-19">November 19,
                            1949.</date>
                        <lb/> [Received November 19—6:43 a. m.]</dateline>
                </opener>
                <p>Consulate and radio closed. Last despatch number 62 [<hi rend="italic">66</hi>],
                    last telegram number 246.<note n="70" xml:id="d1694fn70">Neither printed.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Rozier</hi>
                    </signed>
                </closer>
            </div>
