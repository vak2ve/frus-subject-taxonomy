<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-07-08T19:00:00-05:00" frus:doc-dateTime-min="1949-07-08T19:00:00-05:00" n="1542" subtype="historical-document" type="document" xml:id="d1542">
                        <note rend="inline" type="source">123 Cabot, John M.: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Consul General at Shanghai</hi> (<persName type="to"><hi rend="italic">Cabot</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1949-07-08T20:00:00-04:00">July 8,
                                    1949—8 p. m.</date>
                            </dateline>
                        </opener>
                        <p>1374. Fol consideration urtel 2660, July 8, Dept approves ur return
                            Washington on consultation returning US on Attaché plane with Amb.
                            Authorization this travel contained Deptel 1355, July 7.<note n="6" xml:id="d1542fn6">Not printed.</note>
                        </p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Acheson</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>