        <body>
            <div frus:doc-dateTime-max="1949-10-12T23:59:59-05:00" frus:doc-dateTime-min="1949-10-12T00:00:00-05:00" n="841" subtype="historical-document" type="document" xml:id="d841">
                <note rend="inline" type="source">124.93/10–1249: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName type="from">
                        <hi rend="italic">Strong</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Hong Kong</hi>
                        </placeName>, <date calendar="gregorian" when="1949-10-12">October 12,
                            1949</date>.<lb/>[Received October 12—6:03 a. m.]</dateline>
                </opener>
                <p>Cantel 1192. All Embassy staff safely out of Canton and now at Hong Kong.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Strong</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
