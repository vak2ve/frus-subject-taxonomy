<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-01-22T23:59:59-05:00" frus:doc-dateTime-min="1949-01-22T00:00:00-05:00" n="84" subtype="historical-document" type="document" xml:id="d84">
                        <note rend="inline" type="source">893.00/1–2249: Telegram</note>
                        <head>
                            <hi rend="italic">The Consul General at Peiping</hi> (<persName type="from"><hi rend="italic">Clubb</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Peiping</hi></placeName>, <date calendar="gregorian" when="1949-01-22">January 22,
                                1949</date>.<lb/>[Received January 22—1:08 a. m.]</dateline>
                        </opener>
                        <p>85. Certain units Nationalist forces have begun to move out Peiping in
                            implementation reputed turnover arrangement.</p>
                        <p>Sent Department, Nanking 75, Shanghai 74, Tientsin 27.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Clubb</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>