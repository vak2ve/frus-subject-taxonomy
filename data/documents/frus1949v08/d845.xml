<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-11-17T03:00:00-05:00" frus:doc-dateTime-min="1949-11-17T03:00:00-05:00" n="845" subtype="historical-document" type="document" xml:id="d845">
                    <note rend="inline" type="source">124.93/11–1749: Telegram</note>
                    <head>
                        <hi rend="italic">The Chargé in China</hi> (<persName type="from"><hi rend="italic">Strong</hi></persName>) <hi rend="italic">to the
                                <gloss type="to">Secretary of state</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Chungking</hi></placeName>, <date calendar="gregorian" when="1949-11-17T15:00:00+07:00">November 17,
                                1949—3 p. m.</date>
                            <lb/> [Received November 17—6:56 a. m.]</dateline>
                    </opener>
                    <p>Cantel 1288. We are planning notify Foreign Office Friday November 18 of our
                        intention leave within next few days, destination depending on Chinese
                        Government, decisions and ensuing developments. Shall also advise foreign
                        press same day.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Strong</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>