                subtype="historical-document" type="document" xml:id="d876">
                <note rend="inline" type="source">124.936/5–349: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Stuart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1949-05-03T14:00:00+08:00"
                            >May 3, 1949—2 p. m.</date>
                        <lb/> [Received May 3—4:13 a. m.]</dateline>
                </opener>
                <p>923. Canadian Ambassador has asked that our recent telegrams on situation
                    Nanking, particularly with respect restrictions, attitude toward Diplomatic
                    Corps by new authorities, be shown to Canadian Embassy, Washington, for info his
                    Government.</p>
                <p>Sent Department 923; repeated Ottawa 1.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stuart</hi>
                    </signed>
                </closer>
            </div>
        </body>
