                subtype="historical-document" type="document" xml:id="d374">
                <note rend="inline" type="source">793.94 Commission/572: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Geneva (<persName corresp="frus1932v03#p_VSRG1"
                            type="from">Gilbert</persName>) to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Geneva</hi>
                        </placeName>, <date calendar="gregorian" when="1932-11-29T14:00:00+01:00"
                            >November 29, 1932—2 p.m.</date>
                        <lb/>[Received November 29—9:20 a.m.]</dateline>
                </opener>
                <p>344. <persName corresp="frus1932v03#p_MMGFR1">General McCoy</persName> informs me
                    that <persName corresp="frus1932v03#p_LERB1">Lytton</persName> has asked him to
                    remain in Geneva, subject to call, in connection with the forthcoming <pb
                        facs="0473" n="375" xml:id="pg_375"/> meetings of the Assembly, and that he
                    is complying with this request of the Chairman of the Commission of Inquiry.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1932v03#p_VSRG1">
                            <hi rend="smallcaps">Gilbert</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
