                subtype="historical-document" type="document" xml:id="d83">
                <note rend="inline" type="source">793.94/5324: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Shanghai (<persName
                            corresp="frus1932v03#p_CES1" type="from">Cunningham</persName>) to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1932-06-10T17:00:00+08:00"
                            >June 10, 1932—5 p.m.</date>
                        <lb/>[Received June 10—10:55 a.m.]</dateline>
                </opener>
                <p>288. Referring to my telegram of January 28, noon, state of emergency has been
                    withdrawn to become effective on the morning of June 13th. The withdrawal of the
                    state of emergency will in my opinion facilitate the evacuation of Japanese
                    troops from Hongkew district under agreement of May 5, 1932.</p>
                <p>Repeated to the Legation.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1932v03#p_CES1">
                            <hi rend="smallcaps">Cunningham</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
