                subtype="historical-document" type="document" xml:id="d578">
                <note rend="inline" type="source">893.00/12185: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China (<persName corresp="frus1932v03#p_JNT1"
                            type="from">Johnson</persName>) to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1932-10-28T11:00:00+08:00"
                            >October 28, 1932—11 a.m.</date>
                        <lb/>[Received October 28—2:35 a.m.]</dateline>
                </opener>
                <p>1217. Following from American Vice Consul at Foochow: <quote rend="blockquote">
                        <p>“October 27, noon. My telegram of October 24, 10 a.m. It is reliably
                            estimated that the invasion of Northwestern Fukien by the Kiangsi
                            Communists totals 20,000 men. The Provincial Government confirms the
                            capture of Shaowu by the Reds. Americans at Kienningfu and Yenping have
                            been advised to withdraw to Foochow.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <persName corresp="frus1932v03#p_JNT1">
                            <hi rend="smallcaps">Johnson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
