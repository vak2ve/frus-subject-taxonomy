                subtype="historical-document" type="document" xml:id="d499">
                <note rend="inline" type="source">393.11/1492: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Hankow (<persName
                            corresp="frus1932v03#p_AWA1" type="from">Adams</persName>) to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Hankow</hi>
                        </placeName>, <date calendar="gregorian" when="1932-03-14T12:00:00+08:00"
                            >March 14, 1932—noon</date>.<lb/>[Received March 14—3 a.m.]</dateline>
                </opener>
                <p>42. My number 37, February 26, 3 p.m.<note n="18" xml:id="d499fn18">Not
                        printed.</note> The communist attack upon Kwangchow has been defeated and
                    the danger to that city removed for the time being. The Americans residing in
                    Kwangchow are unharmed.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1932v03#p_AWA1">
                            <hi rend="smallcaps">Adams</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
