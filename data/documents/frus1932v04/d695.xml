                subtype="historical-document" type="document" xml:id="d695">
                <note rend="inline" type="source">493.11/1641: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in China (<persName corresp="frus1932v03#p_JNT1" type="to"
                            >Johnson</persName>)</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-07-08T14:00:00-04:00"
                            >July 8, 1932—2 p.m.</date>
                    </dateline>
                </opener>
                <p>199. Your 774, July 6, 1 p.m. Assurance given by, and understanding of, Ministry
                    of Foreign Affairs, as indicated in the quoted portion of its note to you under
                    date April 27, appear to Department acceptable and you are authorized to
                    confirm.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1932v03#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
