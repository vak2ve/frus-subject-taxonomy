                subtype="historical-document" type="document" xml:id="d60">
                <note rend="inline" type="source">793.94 Commission/232: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China (<persName corresp="frus1932v03#p_JNT1"
                            type="from">Johnson</persName>) to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1932-06-02T16:00:00+08:00"
                            >June 2, 1932—4 p.m.</date>
                        <lb/>[Received June 2—7:35 a.m.]</dateline>
                </opener>
                <p>596. Following from Mukden: <quote rend="blockquote">
                        <p>“League Commission will leave Mukden on the morning of June 4th and
                            arrive at Peiping the evening of the following day.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <persName corresp="frus1932v03#p_JNT1">
                            <hi rend="smallcaps">Johnson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
