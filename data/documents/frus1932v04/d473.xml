                subtype="historical-document" type="document" xml:id="d473">
                <note rend="inline" type="source">393.1111 <persName corresp="frus1932v03#p_BCC1"
                        >Baker, Charles</persName>/8: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in China (<persName corresp="frus1932v03#p_JNT1" type="to"
                            >Johnson</persName>)</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-01-25T13:00:00-05:00"
                            >January 25, 1932—1 p.m.</date>
                    </dateline>
                </opener>
                <p>23. Your 110, January 22, 6 p.m., in reference to capture of <persName
                        corresp="frus1932v03#p_BCC1">Charles Baker</persName>.</p>
                <p>Department desires that Legation press this case with the Chinese authorities and
                    that <persName>Peck</persName> be directed to continue to urge upon the Ministry
                    of Foreign Affairs, as under instruction from the Department, the need for
                    prompt and effective action to effect the release of <persName
                        corresp="frus1932v03#p_BCC1">Baker</persName>.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1932v03#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
