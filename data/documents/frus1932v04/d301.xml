    <text>
        <body>
            <div frus:doc-dateTime-max="1932-10-04T16:00:00-05:00"
                frus:doc-dateTime-min="1932-10-04T16:00:00-05:00" n="301"
                subtype="historical-document" type="document" xml:id="d301">
                <note rend="inline" type="source">793.94 Commission/521a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Acting Chairman of the American Delegation to the General Disarmament
                        Conference (<persName corresp="frus1932v03#p_GHS1" type="to"
                            >Gibson</persName>)</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-10-04T16:00:00-05:00"
                            >October 4, 1932—4 p.m.</date>
                    </dateline>
                </opener>
                <p>18. For <persName corresp="frus1932v03#p_WHR1">Wilson</persName>. Please give
                        <persName corresp="frus1932v03#p_MMGFR1">General McCoy</persName> the
                    following personal and confidential message from me: <quote rend="blockquote">
                        <p>“I congratulate you deeply on the successful termination of your labor
                            and the production of an unanimous report which is so comprehensive and
                            intelligent in treatment and so judicial in tone. It is a magnificent
                            achievement.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <persName corresp="frus1932v03#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
