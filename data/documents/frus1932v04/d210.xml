                subtype="historical-document" type="document" xml:id="d210">
                <note rend="inline" type="source">893.00/12099: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China (<persName corresp="frus1932v03#p_JNT1"
                            type="from">Johnson</persName>) to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1932-08-09T19:00:00+08:00"
                            >August 9, 1932—7 p.m.</date>
                        <lb/>[Received August 9—8:25 a.m.]</dateline>
                </opener>
                <p>924. Following from American Consul General at Nanking: <quote rend="blockquote">
                        <p>“August 8, noon. I learn from apparently reliable sources that <persName
                                corresp="frus1932v03#p_LW1">Lo Wen-kan</persName> is still attending
                            his office as concurrent Minister for Foreign Affairs and that <persName
                                corresp="frus1932v03#p_HS2">Huang Shao-hsiung</persName>, Minister
                            of the Interior, will return from Shanghai tonight and will be in
                            temporary charge of the office of the President of the Executive
                            Yuan.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <persName corresp="frus1932v03#p_JNT1">
                            <hi rend="smallcaps">Johnson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
