                subtype="historical-document" type="document" xml:id="d484">
                <note rend="inline" type="source">793.94/3918: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in China (<persName corresp="frus1932v03#p_JNT1" type="to"
                            >Johnson</persName>)</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-02-08T17:00:00-05:00"
                            >February 8, 1932—5 p.m.</date>
                    </dateline>
                </opener>
                <p>46. Your 184, February 3, 11 a.m., and 210, February 8, 3 p.m., in regard to the
                    situation at Hankow.</p>
                <list>
                    <label>1.</label>
                    <item>Department approves the instructions which have been sent to Hankow by the
                        Legation and by the Minister as reported in your 210, February 8, 3
                        p.m.</item>
                    <label>2.</label>
                    <item>Keep Department informed in regard to developments. Repeat to
                        Minister.</item>
                </list>
                <closer>
                    <signed>
                        <persName corresp="frus1932v03#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
