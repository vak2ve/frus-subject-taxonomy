<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-03-26T23:59:59-05:00" frus:doc-dateTime-min="1913-03-26T00:00:00-05:00" n="397" subtype="historical-document" type="document" xml:id="d397">
                        <note rend="inline" type="source">File No. 839.00/816.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Chargé
                                    d’Affaires</gloss> to the <gloss type="to">Secretary of
                                    State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegrams—Paraphrases.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Santo Domingo</hi></placeName>, <date calendar="gregorian" when="1913-03-26">
                                    <hi rend="italic">March 26, 1913</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="italic">Algonquin</hi> established radio communication with
                                <hi rend="italic">Wheeling</hi> today. Consul at Puerto Plata
                            requested to inform commander of <hi rend="italic">Algonquin</hi> in
                            case the telegraph lines across the island are cut, and to ask him to
                            communicate immediately with the <hi rend="italic">Wheeling.</hi>
                        </p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Curtis</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>