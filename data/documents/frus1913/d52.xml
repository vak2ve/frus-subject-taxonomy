<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-12-23T23:59:59-05:00" frus:doc-dateTime-min="1912-12-23T00:00:00-05:00" n="52" subtype="historical-document" type="document" xml:id="d52">
                        <note rend="inline" type="source">File No. 832.61333/123.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the <gloss type="to">American
                                    Ambassador</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1912-12-23">
                                    <hi rend="italic">December 23, 1912</hi></date>.</dateline>
                        </opener>
                        <p>Sielcken has ceased to press for a hearing. Sales should now proceed as
                            agreed.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Wilson</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>