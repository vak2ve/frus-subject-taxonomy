<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-02-13T23:59:59-05:00" frus:doc-dateTime-min="1913-02-13T00:00:00-05:00" n="1651" subtype="historical-document" type="document" xml:id="d1651">
                        <note rend="inline" type="source">File No. 816.001Ar1/5.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">President of Salvador</gloss>
                                to the <gloss type="to">President</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">San Salvador</hi></placeName>, <date calendar="gregorian" when="1913-02-13">
                                    <hi rend="italic">February 13, 1913</hi></date>.</dateline>
                        </opener>
                        <p>May Your Excellency deign to accept the expression of cordial sincere
                            gratitude of the Government and people of Salvador for your noble
                            evidence of sympathy at this time of so great sorrow to our country.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Presidente Meléndez</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>