<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-10-22T23:59:59-05:00" frus:doc-dateTime-min="1913-10-22T00:00:00-05:00" n="1067" subtype="historical-document" type="document" xml:id="d1067">
                        <note rend="inline" type="source">File No. 812.00/9311.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Ambassador to
                                    Italy</gloss> to the <gloss type="to">Secretary of
                                State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                                    <hi rend="italic">Rome</hi></placeName>, <date calendar="gregorian" when="1913-10-22">
                                    <hi rend="italic">October 22, 1913</hi></date>.</dateline>
                        </opener>
                        <p>Department’s October 14, 7 p.m. The Government is endeavoring to
                            ascertain the attitude of other European powers.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Nelson Page.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>