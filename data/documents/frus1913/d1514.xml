<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-07-24T23:59:59-05:00" frus:doc-dateTime-min="1913-07-24T00:00:00-05:00" n="1514" subtype="historical-document" type="document" xml:id="d1514">
                        <note rend="inline" type="source">File No. 722.2315/596.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Chargé d’Affaires of
                                    Brazil</gloss> to the <gloss type="to">Counselor of the
                                    Department of State</gloss>.</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Embassy of Brazil</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1913-07-24">
                                    <hi rend="italic">July 24, 1913</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Dear Mr. Moore</hi>: Many thanks for your personal
                            letter of July 22nd, contents of which I cabled to my Government. As
                            soon as I receive an answer on the subject I will communicate with
                            you.</p>
                        <p>Thanking you again [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">E. L. Chermont</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>