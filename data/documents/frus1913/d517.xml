<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-01-16T23:59:59-05:00" frus:doc-dateTime-min="1913-01-16T00:00:00-05:00" n="517" subtype="historical-document" type="document" xml:id="d517">
                        <note rend="inline" type="source">File No. 422.11 G 93/573.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Chargé
                                    d’Affaires</gloss> to the <gloss type="to">Secretary of
                                    State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#left">No. 175.]</seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Quito</hi></placeName>, <date calendar="gregorian" when="1913-01-16">
                                    <hi rend="italic">January 16, 1913</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to report that Mr. Henry
                            L. Janes, American Arbitrator for the settlement of claims between the
                            Government of Ecuador and the Guayaquil and Quito Railroad Company,
                            arrived in Quito January 11, 1913.</p>
                        <p>I have [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Rutherfurd Bingham</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>