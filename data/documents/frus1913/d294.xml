<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-03-18T16:00:00-05:00" frus:doc-dateTime-min="1913-03-18T16:00:00-05:00" n="294" subtype="historical-document" type="document" xml:id="d294">
                        <note rend="inline" type="source">File No, 837.13/16.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the <gloss type="to">American
                                Minister</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1913-03-18T16:00:00-05:00">
                                    <hi rend="italic">March 18, 1913—4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>You will not further press objections to amnesty bill.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Huntington Wilson</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>