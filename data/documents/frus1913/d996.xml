<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-06-01T23:36:00-05:00" frus:doc-dateTime-min="1913-06-01T23:36:00-05:00" n="996" subtype="historical-document" type="document" xml:id="d996">
                        <note rend="inline" type="source">File No. 812.00/7664.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Ambassador</gloss> to
                                the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                                    <hi rend="italic">Mexico</hi></placeName>, <date calendar="gregorian" when="1913-06-01T22:00:00-06:36">
                                    <hi rend="italic">June 1, 1913—10 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>265. Russia has officially recognized the present Provisional Government
                            of Mexico.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Henry Lane Wilson</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>