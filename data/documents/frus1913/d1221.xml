<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-03-11T23:59:59-05:00" frus:doc-dateTime-min="1913-03-11T00:00:00-05:00" n="1221" subtype="historical-document" type="document" xml:id="d1221">
                        <note rend="inline" type="source">File No. 812.00/6681.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">American Ambassador</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1913-03-11">
                                    <hi rend="italic">March 11, 1913</hi></date>.</dateline>
                        </opener>
                        <p>109. Please telegraph text of the proposed Mexican commitments.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi>.</signed>
                        </closer>
                    </div>
