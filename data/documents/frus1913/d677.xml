    <text>
        <body>
            <div frus:doc-dateTime-max="1913-03-22T23:59:59-05:00"
                frus:doc-dateTime-min="1913-03-22T00:00:00-05:00" n="677"
                subtype="historical-document" type="document" xml:id="d677">
                <note rend="inline" type="source">File No. 815.001 B 64/10.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Minister of Honduras</gloss> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Honduras</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1913-03-22">
                            <hi rend="italic">March 22, 1913</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary</hi>: With profound sorrow I discharge the
                    duty of informing your excellency that, on the 21st instant, General Don Manuel
                    Bonilla, President of the Republic of Honduras, died at Tegucigalpa.</p>
                <p>I renew [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alberto Membreño</hi>.</signed>
                </closer>
            </div>
        </body>
