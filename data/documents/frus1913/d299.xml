                subtype="historical-document" type="document" xml:id="d299">
                <note rend="inline" type="source">File No. 837.13/20.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">American Minister</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1913-05-01">
                            <hi rend="italic">May 1, 1913</hi>
                        </date>.</dateline>
                </opener>
                <p>How does the new bill differ from that of the last session?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Moore</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
