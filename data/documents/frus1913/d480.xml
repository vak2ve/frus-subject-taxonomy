<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-12-31T23:59:59-05:00" frus:doc-dateTime-min="1912-12-31T00:00:00-05:00" n="480" subtype="historical-document" type="document" xml:id="d480">
                        <note rend="inline" type="source">File No. 839.51/919.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">American Minister</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1912-12-31">
                                    <hi rend="italic">December 31, 1912</hi></date>.</dateline>
                        </opener>
                        <p>The Department hopes to cable you soon a contract form now in
                            preparation.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Knox</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>