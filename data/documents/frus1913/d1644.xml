<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-02-07T23:59:59-05:00" frus:doc-dateTime-min="1913-02-07T00:00:00-05:00" n="1644" subtype="historical-document" type="document" xml:id="d1644">
                        <note rend="inline" type="source">File No. 816.001Ar1/1.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">President of Salvador</gloss>
                                to the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Translation.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">San Salvador</hi></placeName>, <date calendar="gregorian" when="1913-02-07">
                                    <hi rend="italic">February 7, 1913</hi></date>.</dateline>
                        </opener>
                        <p>I express to you my gratitude. On road to recovery. Greetings to your
                            excellency and your wife. [Your] friend,</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Presidente Araújo</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>