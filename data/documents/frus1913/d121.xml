<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-10-08T23:59:59-05:00" frus:doc-dateTime-min="1913-10-08T00:00:00-05:00" n="121" subtype="historical-document" type="document" xml:id="d121">
                        <note rend="inline" type="source">File No. 893.001Y9/4.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Chinese Chargé
                                    d’Affaires</gloss> to the <gloss type="to">Acting Secretary of
                                    State</gloss>.</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Legation of China</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1913-10-08">
                                    <hi rend="italic">October 8, 1913</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that the
                            Legation is in receipt of a telegram from the Foreign Office stating
                            that the National Assembly has elected General Li Yuan Hung the Vice
                            President of the Republic of China.</p>
                        <p>Accept [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Chang Kang-jen</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>