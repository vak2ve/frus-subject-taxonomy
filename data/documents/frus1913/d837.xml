<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-02-18T23:59:59-05:00" frus:doc-dateTime-min="1913-02-18T00:00:00-05:00" n="837" subtype="historical-document" type="document" xml:id="d837">
                        <note rend="inline" type="source">File No. 812.00/6250.</note>
                        <head>
                            <hi rend="italic">General <persName type="from">Huerta</persName> to the
                                    <gloss type="to">President</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Mexico</hi></placeName>, <date calendar="gregorian" when="1913-02-18">
                                    <hi rend="italic">February 18, 1913</hi></date>.</dateline>
                        </opener>
                        <p>I have the honor to inform you that I have overthrown this Government.
                            The forces are with me, and from now on peace and prosperity will
                            reign.</p>
                        <p>Your obedient servant,</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Victoriano Huerta</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>