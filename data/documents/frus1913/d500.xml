                subtype="historical-document" type="document" xml:id="d500">
                <note rend="inline" type="source">File No. 738.3915/188.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Minister of the Dominican Republic</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1913-02-11">
                            <hi rend="italic">February 11, 1913</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 31st ultimo enclosing a copy of a note [etc.]</p>
                <p>In reply I have the honor to inform you that your note and its enclosure will
                    receive the Department’s consideration.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">P. C. Knox</hi>.</signed>
                </closer>
            </div>
        </body>
