<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-04-07T23:59:59-05:00" frus:doc-dateTime-min="1913-04-07T00:00:00-05:00" n="963" subtype="historical-document" type="document" xml:id="d963">
                        <note rend="inline" type="source">File No. 812.00/7392.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Mexican Chargé
                                    d’Affaires</gloss> to the <gloss type="to">Secretary of
                                    State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Translation.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1913-04-07">
                                    <hi rend="italic">April 7, 1913</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Excellency</hi>: In compliance with instructions
                            received from my Government, I have the honor to apply to your
                            excellency with a request that you be pleased to use your good offices
                            to the end that every possible facility be extended to a Mexican
                            Commission composed of eight persons and headed by Licenciado don Ramon
                            Gonzalez Suárez which will go to El Paso, Texas, via Brownsville or
                            Laredo, for the purpose of holding peace conferences there.</p>
                        <p>I have pleasure [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Arturo de la Cueva</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>