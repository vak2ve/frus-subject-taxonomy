<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-12-15T23:59:59-05:00" frus:doc-dateTime-min="1912-12-15T00:00:00-05:00" n="1600" subtype="historical-document" type="document" xml:id="d1600">
                        <note rend="inline" type="source">File No. 723.2515/283.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Minister to
                                    Peru</gloss> to the <gloss type="to">Secretary of
                                State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegrams.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Lima</hi></placeName>, <date calendar="gregorian" when="1912-12-15">
                                    <hi rend="italic">Dec. 15, 1912</hi></date>.</dateline>
                        </opener>
                        <p>Your December 14. No action. Congress convened yesterday in extraordinary
                            session.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Howard</hi>.</signed>
                        </closer>
                    </div>
