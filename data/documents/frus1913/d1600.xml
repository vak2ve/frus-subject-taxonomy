                subtype="historical-document" type="document" xml:id="d1600">
                <note rend="inline" type="source">File No. 723.2515/283.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Minister to Peru</gloss> to
                        the <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegrams.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1912-12-15">
                            <hi rend="italic">Dec. 15, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>Your December 14. No action. Congress convened yesterday in extraordinary
                    session.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Howard</hi>.</signed>
                </closer>
            </div>
        </body>
