                subtype="historical-document" type="document" xml:id="d416">
                <note rend="inline" type="source">File No. 839.00/868.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Vice Consul at Puerto Plata</gloss> to
                        the <gloss type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Puerto Plata</hi>
                        </placeName>, <date calendar="gregorian" when="1913-09-12">
                            <hi rend="italic">September 12, 1913</hi>
                        </date>.</dateline>
                </opener>
                <p>Your instruction of September 10 has been complied with, jointly with Commander
                    Long. We notified Céspedes and Vásquez.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Esteva</hi>.</signed>
                </closer>
            </div>
        </body>
