<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-02-28T23:59:59-05:00" frus:doc-dateTime-min="1913-02-28T00:00:00-05:00" n="890" subtype="historical-document" type="document" xml:id="d890">
                        <note rend="inline" type="source">File No. 812.00/6436.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Vice Consul at
                                    Nogales</gloss> to the <gloss type="to">Secretary of
                                    State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Nogales</hi></placeName>, <date calendar="gregorian" when="1913-02-28">
                                    <hi rend="italic">February 28, 1913</hi></date>.</dateline>
                        </opener>
                        <p>Consular agent at Cananea, Sonora, telegraphs: <quote rend="blockquote">
                                <p>The present state of affairs is very unfavorable. Revolution has
                                    broken out. Troops wanted.</p>
                            </quote>
                        </p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Simpich</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>