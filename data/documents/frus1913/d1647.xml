                <note rend="inline" type="source">File No. 816.001Ar1/2.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to <gloss
                            type="to">Señora de Araújo</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1913-02-10">
                            <hi rend="italic">February 10, 1913</hi>
                        </date>.</dateline>
                </opener>
                <p>Mrs. Knox and I join in extending to you our heartfelt sympathy in this great
                    loss which you have been called upon to suffer in the lamentable death of your
                    distinguished husband.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">P. C. Knox</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
