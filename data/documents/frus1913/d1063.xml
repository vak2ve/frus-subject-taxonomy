<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-10-21T23:59:59-05:00" frus:doc-dateTime-min="1913-10-21T00:00:00-05:00" n="1063" subtype="historical-document" type="document" xml:id="d1063">
                        <note rend="inline" type="source">File No. 812.00/9305.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Minister to
                                    Argentina</gloss> to the <gloss type="to">Secretary of
                                    State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Buenos Aires</hi></placeName>, <date calendar="gregorian" when="1913-10-21">
                                    <hi rend="italic">October 21, 1913</hi></date>.</dateline>
                        </opener>
                        <p>Your October 14, 7 p.m. The Acting President expresses sympathy in the
                            difficult situation but carefully refrains from making any comment.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Garrett</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>