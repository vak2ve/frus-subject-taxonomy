<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-03-21T23:59:59-05:00" frus:doc-dateTime-min="1913-03-21T00:00:00-05:00" n="607" subtype="historical-document" type="document" xml:id="d607">
                        <note rend="inline" type="source">File No. 868.001 G 29/5.</note>
                        <head>
                            <hi rend="italic">
                                <persName type="from">Queen Olga</persName> to the <gloss type="to">President</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Saloniki</hi></placeName>, <date calendar="gregorian" when="1913-03-21">
                                    <hi rend="italic">March 21, 1913</hi></date>.</dateline>
                        </opener>
                        <p>I beg you to accept and transmit to the Government and people of the
                            United States the Greek nation’s, my family’s and my own sincerest
                            thanks for your heartfelt sympathy in our most crushing grief.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Olga</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>