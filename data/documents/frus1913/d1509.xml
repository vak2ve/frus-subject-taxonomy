                subtype="historical-document" type="document" xml:id="d1509">
                <note rend="inline" type="source">File No. 722.2315/591.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">American Minister to Peru</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1913-07-11">
                            <hi rend="italic">July 11, 1913</hi>
                        </date>.</dateline>
                </opener>
                <p>Your July 9. Ecuador is preparing a proposition which we are informed will be
                    ready shortly. We are glad to do anything in our power to bring about a
                    settlement.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bryan</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
