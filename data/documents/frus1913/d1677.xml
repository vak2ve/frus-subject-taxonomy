<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1912-06-26T23:59:59-05:00" frus:doc-dateTime-min="1912-06-26T00:00:00-05:00" n="1677" subtype="historical-document" type="document" xml:id="d1677">
                        <note rend="inline" type="source">File No. 367.114M69/141.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Consul General at
                                    Smyrna</gloss> to the <gloss type="to">Secretary of
                                    State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate General</hi>, <lb/>
                                    <hi rend="italic">Smyrna</hi></placeName>, <date calendar="gregorian" when="1912-06-26">
                                    <hi rend="italic">June 26, 1912</hi></date>.</dateline>
                        </opener>
                        <p>The Captain of the <hi rend="italic">Texas</hi> has been removed from the
                            hospital prison and thrown into the common prison of condemned
                            criminals.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Horton</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>