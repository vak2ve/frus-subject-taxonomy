<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-02-14T23:59:59-05:00" frus:doc-dateTime-min="1913-02-14T00:00:00-05:00" n="505" subtype="historical-document" type="document" xml:id="d505">
                        <note rend="inline" type="source">File No. 123.R911/79.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">American Minister</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1913-02-14">
                                    <hi rend="italic">February 14, 1913</hi></date>.</dateline>
                        </opener>
                        <p>If you feel disposed to act as arbitrator without compensation, you are
                            authorized to do so.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Knox</hi>.</signed>
                        </closer>
                    </div>
                </body></text></TEI>