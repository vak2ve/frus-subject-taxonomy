    <text>
        <body>
            <div frus:doc-dateTime-max="1913-11-09T10:06:00-05:00"
                frus:doc-dateTime-min="1913-11-09T10:06:00-05:00" n="1093"
                subtype="historical-document" type="document" xml:id="d1093">
                <note rend="inline" type="source">File No. 812.00/9632.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Ambassador to Brazil</gloss>
                        to the <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1913-11-09T12:00:00-03:06">
                            <hi rend="italic">Nov. 9, 1913—noon</hi>
                        </date>.</dateline>
                </opener>
                <p>Department’s November 8, 11 p.m.<note n="1" xml:id="d1093fn1">See footnote to the
                        telegram of November 7, 10 p.m.</note> The Brazilian Minister to Mexico has
                    been instructed by telegraph as you suggest.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Morgan</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
