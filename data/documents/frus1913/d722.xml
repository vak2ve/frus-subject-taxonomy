                subtype="historical-document" type="document" xml:id="d722">
                <note rend="inline" type="source">File No. 711.942/76.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Japanese Ambassador</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1911-02-21">
                            <hi rend="italic">February 21, 1911</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to acknowledge the
                    receipt of your excellency’s note of this date on the subject of landownership
                    in Japan and Korea.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">P. C. Knox</hi>.</signed>
                </closer>
            </div>
        </body>
