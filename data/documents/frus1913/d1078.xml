<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-10-27T23:59:59-05:00" frus:doc-dateTime-min="1913-10-27T00:00:00-05:00" n="1078" subtype="historical-document" type="document" xml:id="d1078">
                        <note rend="inline" type="source">File No. 812.00/9361.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">American Ambassador to Great
                                Britain</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1913-10-27">
                                    <hi rend="italic">October 27, 1913</hi></date>.</dateline>
                        </opener>
                        <p>Your October 24, 8 p.m., is sufficiently covered for the present by your
                            October 27, 2 p.m.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>