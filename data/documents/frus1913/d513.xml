    <text>
        <body>
            <div frus:doc-dateTime-max="1912-12-14T23:59:59-05:00"
                frus:doc-dateTime-min="1912-12-14T00:00:00-05:00" n="513"
                subtype="historical-document" type="document" xml:id="d513">
                <note rend="inline" type="source">File No. 422.11G93/555b.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                            <persName type="to">Henry L. Janes</persName>, American Arbitrator.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1912-12-14">
                            <hi rend="italic">December 14, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In accordance with your personal request, I
                    enclose herewith for your information a copy and paraphrase of telegraphic
                    instructions <pb facs="0578" n="474" xml:id="pg_474"/> transmitted to the
                    American Legation at Quito in connection with the arbitration of the claims of
                    the Guayaquil and Quito Railroad and of the Government of Ecuador, and your
                    designation as arbitrator under the terms of the contract.<note n="1"
                        xml:id="d513fn1">Printed in <ref target="frus1912#pg_421">For. Rel. 1912, p.
                            421</ref>.</note>
                </p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Huntington Wilson</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
