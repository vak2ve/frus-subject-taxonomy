<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-07-16T23:59:59-05:00" frus:doc-dateTime-min="1913-07-16T00:00:00-05:00" n="66" subtype="historical-document" type="document" xml:id="d66">
                        <note rend="inline" type="source">File No. 033.3211/57.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Brazilian Minister for Foreign
                                    Affairs, on Special Mission</gloss> to the <gloss type="to">President</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">New York</hi></placeName>, <date calendar="gregorian" when="1913-07-16">
                                    <hi rend="italic">July 16, 1913</hi></date>.</dateline>
                        </opener>
                        <p>Will Your Excellency allow me the honor of conveying to you my most
                            respectful and grateful compliments on my leaving this great
                            republic.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lauro Müller</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>