    <text>
        <body>
            <div frus:doc-dateTime-max="1913-10-27T23:59:59-05:00"
                frus:doc-dateTime-min="1913-10-27T00:00:00-05:00" n="1080"
                subtype="historical-document" type="document" xml:id="d1080">
                <note rend="inline" type="source">File No. 812.00/9402.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Ambassador to Japan</gloss> to
                        the <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Tokio</hi>
                        </placeName>, <date calendar="gregorian" when="1913-10-27">
                            <hi rend="italic">October 27, 1913</hi>
                        </date>.</dateline>
                </opener>
                <p>Your October 24, 6 p.m. The Minister for Foreign Affairs would like to receive as
                    soon as possible a statement of our Government’s position.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Guthrie</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
