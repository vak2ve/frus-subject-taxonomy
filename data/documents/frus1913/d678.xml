                subtype="historical-document" type="document" xml:id="d678">
                <note rend="inline" type="source">File No. 815.001 B 64/9.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">President</gloss> to the <gloss
                            type="to">President of Honduras</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The White House</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1913-03-22">
                            <hi rend="italic">March 22, 1913</hi>
                        </date>.</dateline>
                </opener>
                <p>The Government and people of the United States of America join me in offering
                    heartfelt condolences in the great loss which has been sustained by the Republic
                    of Honduras in the lamented death of His Excellency, President Bonilla.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Woodrow Wilson</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
