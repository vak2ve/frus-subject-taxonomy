    <text>
        <body>
            <div frus:doc-dateTime-max="1912-11-25T23:59:59-05:00"
                frus:doc-dateTime-min="1912-11-25T00:00:00-05:00" n="583"
                subtype="historical-document" type="document" xml:id="d583">
                <note rend="inline" type="source">File No. 731.51/40.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Chargé d’Affaires at
                            Caracas</gloss> to the <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 101.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Caracas</hi>
                        </placeName>, <date calendar="gregorian" when="1912-11-25">
                            <hi rend="italic">November 25, 1912</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: With reference to the Department’s instruction
                    No. 24 of August 31, 1912, regarding the relations between France and Venezuela,
                    I have the honor now to enclose herewith copy and translation in duplicate of
                    the note<note n="1" xml:id="d583fn1">Not printed.</note> and projected
                        protocol<note n="2" xml:id="d583fn2">Not printed. See the text as signed;
                        inclosure to despatch No. 165, of March 25, 1913, post.</note> received on
                    November 19, 1912, from the Venezuelan Foreign Minister.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Jefferson Caffery</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
