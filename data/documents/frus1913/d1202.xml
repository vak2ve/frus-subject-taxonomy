<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-11-03T23:59:59-05:00" frus:doc-dateTime-min="1913-11-03T00:00:00-05:00" n="1202" subtype="historical-document" type="document" xml:id="d1202">
                        <note rend="inline" type="source">File No. 312.93/53.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">American Consul General at
                                Monterey</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1913-11-03">
                                    <hi rend="italic">November 3, 1913</hi></date>.</dateline>
                        </opener>
                        <p>Chinese Legation here requests that you give such assistance as may be
                            necessary to destitute Chinese. Please comply, keeping separate account
                            of such expenditures in order that a bill may be submitted to Chinese
                            Legation for reimbursement.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bryan</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>