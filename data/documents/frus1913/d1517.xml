<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-09-10T23:59:59-05:00" frus:doc-dateTime-min="1913-09-10T00:00:00-05:00" n="1517" subtype="historical-document" type="document" xml:id="d1517">
                        <note rend="inline" type="source">File No. 722.2315/601.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the <gloss type="to">Minister of
                                Peru</gloss>.</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1913-09-10">
                                    <hi rend="italic">September 10, 1913</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your esteemed note dated August 10, with which you enclose a
                            confidential memorandum together with four enclosures and a map with
                            reference to the boundary dispute between Peru and Ecuador. These have
                            been read with much interest.</p>
                        <p>Accept [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">John E. Osborne</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>