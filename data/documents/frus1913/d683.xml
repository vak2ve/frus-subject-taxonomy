    <text>
        <body>
            <div frus:doc-dateTime-max="1913-05-06T23:59:59-05:00"
                frus:doc-dateTime-min="1913-05-06T00:00:00-05:00" n="683"
                subtype="historical-document" type="document" xml:id="d683">
                <note rend="inline" type="source">File No, 815.001 B 46/2.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Minister of Honduras</gloss> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Honduras</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1913-05-06">
                            <hi rend="italic">May 6, 1913</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary</hi>: I have the honor to transmit to your
                    excellency a copy of the autograph letter by which His Excellency Señor Doctor
                        <pb facs="0698" n="594" xml:id="pg_594"/> Francisco Bertrand announces his
                    elevation to the Presidency of the Republic of Honduras to His Excellency the
                    President of the United States.<note n="1" xml:id="d683fn1">Not printed.</note>
                </p>
                <p>I beg your excellency to be pleased, if you deem it expedient, to arrange the
                    manner in which I may have the said letter reach its high destination.</p>
                <p>I renew [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alberto Membreño</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
