<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-09-16T23:59:59-05:00" frus:doc-dateTime-min="1913-09-16T00:00:00-05:00" n="419" subtype="historical-document" type="document" xml:id="d419">
                        <note rend="inline" type="source">File No. 839.00/875.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Vice Consul at Puerto
                                    Plata</gloss> to the <gloss type="to">Secretary of
                                State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="italic">Puerto Plata</hi></placeName>, <date calendar="gregorian" when="1913-09-16">
                                    <hi rend="italic">September 16, 1913</hi></date>.</dateline>
                        </opener>
                        <p>Engagement at Navarrete reported in favor of revolutionists who are now
                            attacking Las Lagunas.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Esteva</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>