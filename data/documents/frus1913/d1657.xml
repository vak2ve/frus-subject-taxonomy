<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-09-30T23:59:59-05:00" frus:doc-dateTime-min="1913-09-30T00:00:00-05:00" n="1657" subtype="historical-document" type="document" xml:id="d1657">
                        <head>
                            <hi rend="italic">The <gloss type="from">American Chargé
                                    d’Affaires</gloss> to the <gloss type="to">Secretary of
                                    State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Theeapia</hi></placeName>, <date calendar="gregorian" when="1913-09-30">
                                    <hi rend="italic">September 30, 1913</hi></date>.</dateline>
                        </opener>
                        <p>Peace between Turkey and Bulgaria was signed here yesterday evening.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Philip</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>