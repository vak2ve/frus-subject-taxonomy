<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-12-10T23:59:59-05:00" frus:doc-dateTime-min="1913-12-10T00:00:00-05:00" n="230" subtype="historical-document" type="document" xml:id="d230">
                        <note rend="inline" type="source">File No. 511.4A1/1438.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Minister</gloss> to
                                the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#left">No. 16.]</seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">The Hague</hi></placeName>, <date calendar="gregorian" when="1913-12-10">
                                    <hi rend="italic">December 10, 1913</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to report that I have
                            received the instrument of ratification of the Convention for the
                            suppression of the use of opium and other deleterious drugs signed at
                            The Hague on January 23, 1912, referred to in the Department’s
                            instruction No. 7 of the 25th ultimo,<note n="1" xml:id="d230fn1">Not
                                printed.</note> and that I have this day deposited this instrument
                            of ratification with the Government of The Netherlands.</p>
                        <p>I have [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Henry Van Dyke</hi>.</signed>
                        </closer>
                    </div>
                </body></text></TEI>