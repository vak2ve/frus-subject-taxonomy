    <text>
        <body>
            <div frus:doc-dateTime-max="1913-06-03T23:59:59-05:00"
                frus:doc-dateTime-min="1913-06-03T00:00:00-05:00" n="649"
                subtype="historical-document" type="document" xml:id="d649">
                <note rend="inline" type="source">File No. 838.001 Or 3.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Minister of Haiti</gloss> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Haiti</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1913-06-03">
                            <hi rend="italic">June 3, 1913</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: I have the honor to transmit
                    herewith, with office copy, an autographic letter<note n="1" xml:id="d649fn1"
                        >Not printed.</note> by which Mr. Michel Oreste <pb facs="0679" n="575"
                        xml:id="pg_575"/> informs the President of the United States of America of
                    his election to the Presidency of the Republic of Haiti.</p>
                <p>Requesting you to kindly forward this letter to its high destination I take
                    [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Solon Ménos</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
