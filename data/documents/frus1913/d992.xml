                subtype="historical-document" type="document" xml:id="d992">
                <head>
                    <hi rend="italic">The <gloss type="from">American Ambassador</gloss> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegrams—Paraphrases.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1913-05-21T17:00:00-06:36">
                            <hi rend="italic">May 21, 1913—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>245. The Provisional Government of Mexico has today been formally recognized by
                    the Governments of Belgium and Guatemala.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Henry Lane Wilson</hi>.</signed>
                </closer>
            </div>
        </body>
