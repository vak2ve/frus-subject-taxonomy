<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-03-07T23:59:59-05:00" frus:doc-dateTime-min="1913-03-07T00:00:00-05:00" n="1411" subtype="historical-document" type="document" xml:id="d1411">
                        <note rend="inline" type="source">File No. 819.77/158.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">Secretary of War</gloss>.</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1913-03-07">
                                    <hi rend="italic">March 7, 1913</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your Department’s letter of February 26 last enclosing a
                            memorandum from the Chief of Staff in regard to the proposed Duncan
                            Concession for a railroad in the Republic of Panama.</p>
                        <p>Copies of your letter and its enclosure have been forwarded to the
                            American Minister at Panama.</p>
                        <p>I am [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">W. J. Bryan</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>