    <text>
        <body>
            <div frus:doc-dateTime-max="1913-04-03T23:59:59-05:00"
                frus:doc-dateTime-min="1913-04-03T00:00:00-05:00" n="208"
                subtype="historical-document" type="document" xml:id="d208">
                <note rend="inline" type="source">File No. 893.51/1365.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">American Group</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1913-04-03">
                            <hi rend="italic">April 3, 1913</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sirs</hi>: I have to acknowledge the receipt of your letter
                    of March 31 on the subject of loans made to the Chinese Government for the
                    education of Chinese students in the United States under the arrangement made
                    following the remission of the Boxer indemnity and in reply to state that the
                    matter will be given due consideration by the Department.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. J. Bryan</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
