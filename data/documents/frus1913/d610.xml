    <text>
        <body>
            <div frus:doc-dateTime-max="1913-03-24T23:59:59-05:00"
                frus:doc-dateTime-min="1913-03-24T00:00:00-05:00" n="610"
                subtype="historical-document" type="document" xml:id="d610">
                <note rend="inline" type="source">File No. 868.001 G 29/9.</note>
                <head>
                    <hi rend="italic">
                        <persName type="from">King Constantine</persName> to the <gloss type="to"
                            >President</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Saloniki</hi>
                        </placeName>, <date calendar="gregorian" when="1913-03-24">
                            <hi rend="italic">March 24, 1913</hi>
                        </date>.</dateline>
                </opener>
                <p>Deeply touched by your kind sympathy and good wishes. Send sincere and heartfelt
                    thanks.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Constantine</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
