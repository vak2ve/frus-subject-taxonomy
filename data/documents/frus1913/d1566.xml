<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1910-11-21T23:59:59-05:00" frus:doc-dateTime-min="1910-11-21T00:00:00-05:00" n="1566" subtype="historical-document" type="document" xml:id="d1566">
                        <note rend="inline" type="source">File No. 723.2515/196.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Minister to
                                    Peru</gloss> to the <gloss type="to">Secretary of
                                State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Lima</hi></placeName>, <date calendar="gregorian" when="1910-11-21">
                                    <hi rend="italic">November 21, 1910</hi></date>.</dateline>
                        </opener>
                        <p>Argentine Minister at Lima gave me the information cabled November 19;
                            afterwards the Minister for Foreign Affairs of Peru gave me it direct as
                            to Chilean agent negotiation.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Combs</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>