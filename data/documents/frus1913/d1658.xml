<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-11-14T23:59:59-05:00" frus:doc-dateTime-min="1913-11-14T00:00:00-05:00" n="1658" subtype="historical-document" type="document" xml:id="d1658">
                        <note rend="inline" type="source">File No. 767.70/430.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Charge d’Affaires at
                                    Athens</gloss> to the <gloss type="to">Secretary of
                                    State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Athens</hi></placeName>, <date calendar="gregorian" when="1913-11-14">
                                    <hi rend="italic">November 14, 1913</hi>.</date>
                            </dateline>
                        </opener>
                        <p>Turkish-Greek treaty signed today.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">De Billier</hi>.</signed>
                        </closer>
                    </div>
                </body></text></TEI>