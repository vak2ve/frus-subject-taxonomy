<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-01-22T23:59:59-05:00" frus:doc-dateTime-min="1913-01-22T00:00:00-05:00" n="483" subtype="historical-document" type="document" xml:id="d483">
                        <note rend="inline" type="source">File No. 839.51/937.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">American Minister</gloss> to
                                the <gloss type="to">Secretary of State</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Santo Domingo</hi></placeName>, <date calendar="gregorian" when="1913-01-22">
                                    <hi rend="italic">January 22, 1913</hi></date>.</dateline>
                        </opener>
                        <p>The National City Bank’s loan proposition has been accepted by the
                            Dominican Government on exactly the terms given in your telegram of the
                            7th instant, except 97½ instead of 96½.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Russell</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>