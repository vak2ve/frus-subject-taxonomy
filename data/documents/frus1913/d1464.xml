                subtype="historical-document" type="document" xml:id="d1464">
                <note rend="inline" type="source">File No. 819.55/32.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Chinese Chargé d’Affaires</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1913-11-14">
                            <hi rend="italic">November 14, 1913</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Chargé</hi>: I have the honor to enclose
                    herewith, for your information and for transmission to your Government, a
                    paraphrase <pb facs="1236" n="1132" xml:id="pg_1132"/> of a telegram, dated
                    November 13, just received, from the American Chargé d’Affaires at Panama
                    regarding Chinese interests in that country.</p>
                <p>I am [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <hi rend="smallcaps">J. B. Moore</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
