<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1913-02-17T17:00:00-05:00" frus:doc-dateTime-min="1913-02-17T17:00:00-05:00" n="168" subtype="historical-document" type="document" xml:id="d168">
                        <note rend="inline" type="source">File No. 893.51/1301.</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">American Ambassador to Russia</gloss>.</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1913-02-17T17:00:00-05:00">
                                    <hi rend="italic">February 17, 1913—5 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>You need not raise the question you suggest in your February 15, 4
                            p.m.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Knox</hi>.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>