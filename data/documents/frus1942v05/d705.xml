<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1942-07-21T23:00:00-05:00" frus:doc-dateTime-min="1942-07-21T23:00:00-05:00" n="705" subtype="historical-document" type="document" xml:id="d705">
                        <note rend="inline" type="source">800.8830 Brazil/64a: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Brazil</hi> (<persName type="to"><hi rend="italic">Caffery</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1942-07-22T00:00:00-04:00">July 22,
                                1942—midnight</date>.</dateline>
                        </opener>
                        <p>1999. Up to July 22, bookings have been arranged on ships sailing in July
                            for 2,875 tons of newsprint destined to Brazil.</p>
                        <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                    </div>
                    </body></text></TEI>