                subtype="historical-document" type="document" xml:id="d430">
                <note rend="inline" type="source">811.20(D) E.D.B./1789: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Argentina</hi> (<persName type="to">
                        <hi rend="italic">Armour</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1942-10-07T17:00:00-04:00"
                            >October 7, 1942—5 p.m.</date>
                    </dateline>
                </opener>
                <p>1503. Embassy’s A–196, September 16. The Department is informed that six drums
                    are being shipped for the Standard Oil Company of New Jersey.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Welles</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
