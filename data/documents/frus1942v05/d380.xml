                <note rend="inline" type="source">835.34/607: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Argentina</hi> (<persName type="to">
                        <hi rend="italic">Armour</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1942-06-01T23:00:00-04:00"
                            >June 1, 1942—11 p.m.</date>
                    </dateline>
                </opener>
                <p>785. Your 978, May 26, 5 p.m. Please present the Department’s note.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
