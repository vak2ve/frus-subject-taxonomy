<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-06-04T15:00:00-05:00" frus:doc-dateTime-min="1918-06-04T15:00:00-05:00" n="539" subtype="historical-document" type="document" xml:id="d539">
                            <note rend="inline" type="source">File No. 861.00/1933</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Minister in Switzerland</hi> (<persName corresp="#p_SPA1" type="to"><hi rend="italic">Stovall</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-06-04T16:00:00-04:00">
                                        <hi rend="italic">June 4, 1918, 4 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>2030. Your 3535, June 1, 11 a.m. Department prefers that you have no
                                relations whatever with Bolshevik representatives. This Government
                                does not recognize the Bolshevik authorities, either <hi rend="italic">de facto</hi> or <hi rend="italic">de jure.</hi>
                            </p>
                            <closer>
                                <signed>
                                    <persName>
                                        <hi rend="smallcaps">Phillips</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                    </body></text></TEI>