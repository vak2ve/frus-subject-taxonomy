    <text>
        <body>
            <div frus:doc-dateTime-max="1918-03-25T23:59:59-05:00"
                frus:doc-dateTime-min="1918-03-25T00:00:00-05:00" n="440"
                subtype="historical-document" type="document" xml:id="d440">
                <note rend="inline" type="source">File No. 763.72119/1505</note>
                <head>
                    <hi rend="italic">The Minister in Sweden</hi> (<persName corresp="#p_MIN1"
                        type="from">
                        <hi rend="italic">Morris</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Stockholm</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-25">
                            <hi rend="italic">March 25, 1918</hi>
                        </date>. <lb/> [<hi rend="italic">Received 9 p.m.</hi>]</dateline>
                </opener>
                <p>1762. Swedish press reports from Berlin:</p>
                <p>In consequence of Ambassador <persName corresp="#p_FDR1">Francis</persName>’s
                    declaration concerning his attitude as circulated by Petrograd’s telegram bureau
                    regarding ratification Russo-German peace,<note n="1" xml:id="d440fn1">
                        <hi rend="italic">Post</hi>, <ref target="#pg_440">p. 440</ref>.</note> the
                    German Government has sent Russian Government the following wireless: <quote
                        rend="blockquote">
                        <p>Imperial German Government confident Russian Government will give reply
                            in accordance with peace treaty concluded between Russia–Central powers
                            to this declaration which constitutes public invitation to resume war
                            against Germany.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_MIN1">
                            <hi rend="smallcaps">Morris</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
