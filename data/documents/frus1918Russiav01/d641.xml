    <text>
        <body>
            <div frus:doc-dateTime-max="1918-09-25T11:00:00-05:00"
                frus:doc-dateTime-min="1918-09-25T11:00:00-05:00" n="641"
                subtype="historical-document" type="document" xml:id="d641">
                <note rend="inline" type="source">File No. 861.00/2815a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Switzerland</hi> (<persName corresp="#p_SPA1" type="to">
                        <hi rend="italic">Stovall</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-09-25T12:00:00-04:00">
                            <hi rend="italic">September 25, 1918, noon</hi>
                        </date>.</dateline>
                </opener>
                <p>Please deliver copy Department’s circular 20th regarding Russian massacres to
                    Bulgarian Minister for transmission to <persName>Murphy</persName>,<note n="1"
                        xml:id="d641fn1">
                        <persName>Dominic I. Murphy</persName>, Consul General at Sofia.</note>
                    instructing latter to present matter to Bulgarian Government.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
