<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-06-13T23:59:59-05:00" frus:doc-dateTime-min="1917-06-13T00:00:00-05:00" n="90" subtype="historical-document" type="document" xml:id="d90">
                            <note rend="inline" type="source">File No. 763.72/5328</note>
                            <head>
                                <hi rend="italic">The Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="from"><hi rend="italic">Francis</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Petrograd</hi></placeName>, <date calendar="gregorian" when="1917-06-13">
                                        <hi rend="italic">June 13, 1917</hi></date>. <lb/> [<hi rend="italic">Received June 16, 7 a.m.</hi>]</dateline>
                            </opener>
                            <p>1391. Diplomatic Commission arrived. All well. Much pleased with
                                experience thus far. Had long conference with Railway Commission
                                which taking hold earnestly, working wisely, diplomatically and will
                                accomplish much if Government permits.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_FDR1">
                                        <hi rend="smallcaps">Francis</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>