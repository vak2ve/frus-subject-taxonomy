                subtype="historical-document" type="document" xml:id="d309">
                <note rend="inline" type="source">File No. 861.01/9a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Diplomatic Representatives in European Countries,
                            Japan, China, and Siam</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Circular telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-12-15T20:00:00-05:00">
                            <hi rend="italic">December 15, 1917, 8 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Pending further instructions you should have no official relations with Russian
                    diplomatic officers who recognize or who are appointed by Bolshevik
                    government.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
