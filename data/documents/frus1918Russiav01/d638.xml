<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-09-24T18:00:00-05:00" frus:doc-dateTime-min="1918-09-24T18:00:00-05:00" n="638" subtype="historical-document" type="document" xml:id="d638">
                            <note rend="inline" type="source">File No. 861.00/2763a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Consul at Vladivostok</hi> (<persName corresp="#p_CJK1" type="to"><hi rend="italic">Caldwell</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-09-24T19:00:00-04:00">
                                        <hi rend="italic">September 24, 1918, 7 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Your 158, September 21, 3 p.m. You will please not concur in British
                                proposal and will await Department’s circular telegram on the
                                general subject being repeated to you from Tokyo.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>