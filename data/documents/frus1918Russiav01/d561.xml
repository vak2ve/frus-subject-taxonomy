<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-06-27T23:59:59-05:00" frus:doc-dateTime-min="1918-06-27T00:00:00-05:00" n="561" subtype="historical-document" type="document" xml:id="d561">
                            <note rend="inline" type="source">File No. 861.00/2143a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-06-27">
                                        <hi rend="italic">June 27, 1918</hi></date>.</dateline>
                            </opener>
                            <p>8459. This Government believes it is inadvisable for <persName corresp="#p_KAF1">Kerensky</persName> to come to America at the
                                present time. Lord <persName corresp="#p_RERDI1">Reading</persName>
                                is aware of this fact and has so advised the Foreign Office.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>