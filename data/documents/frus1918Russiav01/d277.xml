<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-12-04T10:41:00-05:00" frus:doc-dateTime-min="1917-12-04T10:41:00-05:00" n="277" subtype="historical-document" type="document" xml:id="d277">
                            <note rend="inline" type="source">File No. 861.00/752</note>
                            <head>
                                <hi rend="italic">The Minister in the Netherlands</hi> (<persName corresp="#p_GJW1" type="from"><hi rend="italic">Garrett</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram—Extract]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">The Hague</hi></placeName>, <date calendar="gregorian" when="1917-12-04T16:00:00+00:19">
                                        <hi rend="italic">December 4, 1917, 4 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 11.20 p.m.</hi>]</dateline>
                            </opener>
                            <p>1723. Minister of Foreign Affairs in conversation confirms the report
                                that Dutch Minister at Petrograd refused to receive communication
                                from Maximalist government. Loudon has notified him of this
                                Government’s approval. …</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_GJW1">
                                        <hi rend="smallcaps">Garrett</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>