                subtype="historical-document" type="document" xml:id="d451">
                <note rend="inline" type="source">File No. 701.7161/1</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to">
                        <hi rend="italic">Francis</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-01-18T16:00:00-05:00">
                            <hi rend="italic">January 18, 1918, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1999. Your 2233, January 14, 11 p.m., just received. Press reports show your
                    efforts successful. Department approves your course thoroughly.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
