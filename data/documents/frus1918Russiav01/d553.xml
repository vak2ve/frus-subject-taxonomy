<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-06-13T16:00:00-05:00" frus:doc-dateTime-min="1918-06-13T16:00:00-05:00" n="553" subtype="historical-document" type="document" xml:id="d553">
                            <note rend="inline" type="source">File No. 701.6111/221</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-06-13T17:00:00-04:00">
                                        <hi rend="italic">June 13, 1918, 5 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>181. Your 1 and 2, June 5, Petrograd.<note n="2" xml:id="d553fn2">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_551">pp. 551</ref>
                                    and <ref target="#pg_552">552</ref>.</note> Make no answer for
                                the present or without consulting Department.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>