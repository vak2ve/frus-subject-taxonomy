    <text>
        <body>
            <div frus:doc-dateTime-max="1917-12-27T19:00:00-05:00"
                frus:doc-dateTime-min="1917-12-27T19:00:00-05:00" n="324"
                subtype="historical-document" type="document" xml:id="d324">
                <note rend="inline" type="source">File No. 861.00/808</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to">
                        <hi rend="italic">Francis</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-12-27T19:00:00-05:00">
                            <hi rend="italic">December 27, 1917, 7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1938. Referring Department’s 1906, December 15, 6 p.m.,<note n="1"
                        xml:id="d324fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_316">p. 316</ref>.</note> and
                    your 2133<note n="2" xml:id="d324fn2">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_322">p. 322</ref>.</note>
                    Department thoroughly realizes chaotic conditions may arise, appreciates your
                    purpose to remain and hopes you may judge it practicable to do so.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
