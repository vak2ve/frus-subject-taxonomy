                subtype="historical-document" type="document" xml:id="d491">
                <note rend="inline" type="source">File No. 861.00/1669</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to">
                        <hi rend="italic">Francis</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-04-30T19:00:00-04:00">
                            <hi rend="italic">April 30, 1918, 7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>99. Your 126, April 26, 2 p.m. Department knows nothing whatever of conference to
                    promote improved relations between Allies and Soviet government.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
