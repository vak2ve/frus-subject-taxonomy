<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-12-01T15:00:00-05:00" frus:doc-dateTime-min="1917-12-01T15:00:00-05:00" n="238" subtype="historical-document" type="document" xml:id="d238">
                        <note rend="inline" type="source">File No. 763.72119/967</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-12-01T15:00:00-05:00">
                                    <hi rend="italic">December 1, 1917, 3 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>1875. Your 2034, November 27; 2039, November 28; and 2040, November 29.
                            You are to make no reply to communications mentioned in these telegrams
                            and are informed that this Government awaits further developments. The
                            President has made no statement.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>