<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-12-20T13:00:00-05:00" frus:doc-dateTime-min="1917-12-20T13:00:00-05:00" n="313" subtype="historical-document" type="document" xml:id="d313">
                            <note rend="inline" type="source">File No. 861.00/823</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-12-20T13:00:00-05:00">
                                        <hi rend="italic">December 20, 1917, 1 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>1917. Your 2091, December 12, 8 p.m., last sentence.<note n="1" xml:id="d313fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_301">p.
                                    301</ref>.</note> Red Cross members in uniform certainly
                                included in instructions Department’s 1883, December 6.<note n="2" xml:id="d313fn2">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_289">p.
                                    289</ref>.</note> Red Cross is so advising <persName corresp="#p_RLCR1">Robins</persName>.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>