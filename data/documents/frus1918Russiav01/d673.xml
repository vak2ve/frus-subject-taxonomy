    <text>
        <body>
            <div frus:doc-dateTime-max="1918-10-22T09:00:00-05:00"
                frus:doc-dateTime-min="1918-10-22T09:00:00-05:00" n="673"
                subtype="historical-document" type="document" xml:id="d673">
                <note rend="inline" type="source">File No. 861.00/3016</note>
                <head>
                    <hi rend="italic">The Chargé in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Laughlin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1918-10-22T14:00:00+00:00">
                            <hi rend="italic">October 22, 1918, 2 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 12.50 p.m.</hi>]</dateline>
                </opener>
                <p>2986. My 2399, October 2, 11 a.m.<note n="1" xml:id="d673fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_699">p. 699</ref>.</note>
                    Foreign Office has instructed British Chargé d’Affaires to inform you that the
                    majority of Allied subjects having now been released from Russia, British
                    Government will be glad to join United States Government in taking the proposed
                    action.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Laughlin</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
