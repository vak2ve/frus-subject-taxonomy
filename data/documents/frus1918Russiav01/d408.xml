<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-03-19T15:00:00-05:00" frus:doc-dateTime-min="1918-03-19T15:00:00-05:00" n="408" subtype="historical-document" type="document" xml:id="d408">
                            <note rend="inline" type="source">File No. 861.00/1302</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-03-19T15:00:00-05:00">
                                        <hi rend="italic">March 19, 1918, 3 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>13. Your 7, March 12, 5 p.m. Department considers President’s message
                                to Russian people and address to Congress adequate answer.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>