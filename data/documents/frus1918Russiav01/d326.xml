<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-12-29T14:00:00-05:00" frus:doc-dateTime-min="1917-12-29T14:00:00-05:00" n="326" subtype="historical-document" type="document" xml:id="d326">
                            <note rend="inline" type="source">File No. 861.00/864</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-12-29T14:00:00-05:00">
                                        <hi rend="italic">December 29, 1917, 2 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>1946. Your 2138, December 24, 11 p.m. Department desires you to
                                continue the course you have pursued in the past and which it has
                                approved. Department relies on your good judgment to persevere in
                                difficult situation.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>