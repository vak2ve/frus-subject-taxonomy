<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-09-29T23:59:59-05:00" frus:doc-dateTime-min="1917-09-29T00:00:00-05:00" n="165" subtype="historical-document" type="document" xml:id="d165">
                            <note rend="inline" type="source">File No. 861.00/564</note>
                            <head>
                                <hi rend="italic">The Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="from"><hi rend="italic">Francis</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Petrograd</hi></placeName>, <date calendar="gregorian" when="1917-09-29">
                                        <hi rend="italic">September 29, 1917</hi></date>. <lb/> [<hi rend="italic">Received October 3, 12 noon.</hi>]</dateline>
                            </opener>
                            <p>1822. Following is being placarded about the city: <pb facs="0274" n="200" xml:id="pg_200"/>
                                <quote rend="blockquote">
                                    <p rend="center">
                                        <hi rend="smallcaps">protest meeting</hi>
                                    </p>
                                    <p>“Free “America wants to execute a Russian emigrant,
                                        revolutionist <persName>Alexander Berkman</persName>. All
                                        the soldiers and workers of Petrograd must attend a mass
                                        meeting which will be held in Cirque Moderne on Sunday,
                                        September 17 [/30] at 7 p.m. to find out how this “free”
                                        country deals with its revolutionists. Admittance free.</p>
                                </quote>
                            </p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_FDR1">
                                        <hi rend="smallcaps">Francis</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>