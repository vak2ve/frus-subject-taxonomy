                subtype="historical-document" type="document" xml:id="d698">
                <note rend="inline" type="source">File No. 861.00/3284</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Sweden</hi> (<persName corresp="#p_MIN1" type="to">
                        <hi rend="italic">Morris</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-12-02T14:00:00-05:00">
                            <hi rend="italic">December 2, 1918, 2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1331. Your 3233, November 27, 5 p.m. Repeat to Embassy at London and to Paris for
                    Colonel <persName corresp="#p_HEM1">House</persName>. Follow same procedure all
                    similar reports to Department regarding Bolshevik activities. Please
                    acknowledge.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
