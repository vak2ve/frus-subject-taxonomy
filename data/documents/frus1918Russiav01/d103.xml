                subtype="historical-document" type="document" xml:id="d103">
                <note rend="inline" type="source">File No. 763.72/5425</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to">
                        <hi rend="italic">Francis</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-07-07T17:00:00-05:00">
                            <hi rend="italic">July 7, 1917, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3. For Mr. <persName corresp="#p_RE1">Root</persName>:</p>
                <p>Referring your 8, June 17, 8 p.m.<note n="1" xml:id="d103fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_120">p. 120</ref>.</note> In
                    view of disturbed conditions in the Far East Department considers it inadvisable
                    for you to visit China or Japan, and will be glad to have you return to the
                    United States direct via Vladivostok.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
