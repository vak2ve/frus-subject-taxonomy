<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-10-01T23:59:59-05:00" frus:doc-dateTime-min="1917-10-01T00:00:00-05:00" n="168" subtype="historical-document" type="document" xml:id="d168">
                            <note rend="inline" type="source">File No. 861.00/559</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-10-01">
                                        <hi rend="italic">October 1, 1917</hi></date>.</dateline>
                            </opener>
                            <p>1754. Your 1808, September 27, received late night of 30th. The
                                matter will be taken up and reply given at earliest moment.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_PFL1">
                                        <hi rend="smallcaps">Polk</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>