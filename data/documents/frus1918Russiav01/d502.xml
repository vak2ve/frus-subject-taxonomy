                subtype="historical-document" type="document" xml:id="d502">
                <note rend="inline" type="source">File No. 861.00/1970</note>
                <head>
                    <hi rend="italic">The Military Attaché in Russia</hi> (<persName
                        corresp="#p_RLCJA1" type="from">
                        <hi rend="italic">Ruggles</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">War Department</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vologda</hi>
                        </placeName>, <date calendar="gregorian" when="1918-05-03">
                            <hi rend="italic">May 3, 1918</hi>
                        </date>. <lb/> [<hi rend="italic">Copy received from War Department May
                            23.</hi>]</dateline>
                </opener>
                <p>23. The Russian Government has forbidden the sending of coded telegrams without
                    the approval of the Commissary Foreign Affairs each case.</p>
                <p>This applies to all the Allies.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_RLCJA1">
                            <hi rend="smallcaps">Ruggles</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
