    <text>
        <body>
            <div frus:doc-dateTime-max="1918-09-24T17:00:00-05:00"
                frus:doc-dateTime-min="1918-09-24T17:00:00-05:00" n="618"
                subtype="historical-document" type="document" xml:id="d618">
                <note rend="inline" type="source">File No. 861.00/2744</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-09-24T18:00:00-04:00">
                            <hi rend="italic">September 24, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1581. Department understands important confidential mail report regarding
                    conditions in Petrograd cabled British Foreign Office from Christiania September
                    17 and originated with Netherland Minister to Russia. Department understands
                    Foreign Office might consent to furnishing copy. If so please forward by mail
                    soon as possible.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
