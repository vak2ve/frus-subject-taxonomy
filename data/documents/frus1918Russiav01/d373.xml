    <text>
        <body>
            <div frus:doc-dateTime-max="1918-02-11T16:00:00-05:00"
                frus:doc-dateTime-min="1918-02-11T16:00:00-05:00" n="373"
                subtype="historical-document" type="document" xml:id="d373">
                <note rend="inline" type="source">File No. 861.00/1049</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName corresp="#p_SWG1" type="to">
                        <hi rend="italic">Sharp</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-02-11T16:00:00-05:00">
                            <hi rend="italic">February 11, 1918, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3165. Please repeat your 3138, February 3, 10 p.m.,<note n="1" xml:id="d373fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_366">p. 366</ref>.</note> to
                    London with Department’s instructions to bring views reported therein to
                    attention of British Foreign Office.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
