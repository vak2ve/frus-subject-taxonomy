<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-11-30T19:00:00-05:00" frus:doc-dateTime-min="1917-11-30T19:00:00-05:00" n="260" subtype="historical-document" type="document" xml:id="d260">
                            <note rend="inline" type="source">File No. 861.00/703</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-11-30T19:00:00-05:00">
                                        <hi rend="italic">November 30, 1917, 7 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>1874. Referring your 2001, November 20, 10 p.m.<note n="2" xml:id="d260fn2">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_238">p.
                                    238</ref>.</note> Department believes conference impracticable
                                such as you indicate first paragraph and does not desire you to
                                participate therein.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>