<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-06-19T15:00:00-05:00" frus:doc-dateTime-min="1918-06-19T15:00:00-05:00" n="555" subtype="historical-document" type="document" xml:id="d555">
                            <note rend="inline" type="source">File No. 861.00/1906</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-06-19T16:00:00-04:00">
                                        <hi rend="italic">June 19, 1918, 4 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>193. Your 182, May 18, 10 p.m.<note n="2" xml:id="d555fn2">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_536">p.
                                    536</ref>.</note> Grant visa <persName corresp="#p_KAF1">Kerensky</persName> if he applies for it.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>