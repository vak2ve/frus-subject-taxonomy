<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-07-03T17:00:00-05:00" frus:doc-dateTime-min="1917-07-03T17:00:00-05:00" n="74" subtype="historical-document" type="document" xml:id="d74">
                            <note rend="inline" type="source">File No. 763.72/5638</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-07-03T17:00:00-05:00">
                                        <hi rend="italic">July 3, 1917, 5 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>1531. Your 1453, June 30. Impossible to supply information regarding
                                munitions furnished to Russia or time shipped because purchase made
                                by Russian agents and shipment arranged by them.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>