    <text>
        <body>
            <div frus:doc-dateTime-max="1918-02-19T23:59:59-05:00"
                frus:doc-dateTime-min="1918-02-19T00:00:00-05:00" n="380"
                subtype="historical-document" type="document" xml:id="d380">
                <note rend="inline" type="source">File No. 861.00/1125</note>
                <head>
                    <hi rend="italic">The Assistant Secretary of State</hi> (<persName type="from">
                        <hi rend="italic">Phillips</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                    <note n="1" xml:id="d380fn1">Notes in the margin of MS.: “This is out of the
                        question. <persName corresp="#p_LR1">R[obert] L[ansing]</persName>.
                        Submitted to Pres[iden]t who says the same thing. <persName corresp="#p_LR1"
                            >R[obert] L[ansing]</persName> 2/19/18”</note>
                </head>
                <opener>
                    <seg rendition="#center">[Memorandum]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-02-19">
                            <hi rend="italic">February 19, 1918</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <persName>De Laboulaye</persName>
                    <note n="2" xml:id="d380fn2">Second Secretary of the French Embassy.</note>
                    informs me that the French Government has instructed the French Ambassador in
                    Petrograd to inform <persName corresp="#p_CGV1">Chicherin</persName> (associated
                    with <persName corresp="#p_TLDB1">Trotsky</persName>) indirectly that if the
                    Bolsheviki resist the German menace and defend Russia against the German
                    aggression, France is ready to give the Bolsheviki help in money and material.
                    The French Government now inquire whether the United States will give similar
                    instructions to the American Ambassador in Petrograd.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Wm. Phillips</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
