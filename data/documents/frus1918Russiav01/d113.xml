<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-05-28T18:00:00-05:00" frus:doc-dateTime-min="1917-05-28T18:00:00-05:00" n="113" subtype="historical-document" type="document" xml:id="d113">
                            <note rend="inline" type="source">File No. 763.72/5078d</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in Japan</hi> (<persName corresp="#p_WP1" type="to"><hi rend="italic">Wheeler</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-05-28T18:00:00-05:00">
                                        <hi rend="italic">May 28, 1917, 6 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Russian commission to United States reported intending to sail
                                Yokohama for Seattle June 1. Please advise of departure, personnel
                                of commission and port of destination.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>