<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-12-11T15:00:00-05:00" frus:doc-dateTime-min="1917-12-11T15:00:00-05:00" n="293" subtype="historical-document" type="document" xml:id="d293">
                            <note rend="inline" type="source">File No. 861.00/804d</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)<note n="1" xml:id="d293fn1">The same, <hi rend="italic">mutatis mutandis</hi>, on the same date, to
                                    the Ambassador in France (No. 2944).</note>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-12-11T15:00:00-05:00">
                                        <hi rend="italic">December 11, 1917, 3 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>6009. Department has received no information regarding the policy
                                which the British Government proposes to adopt in the present
                                Russian situation. Please inquire informally and cable immediate
                                report. Keep Department advised.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>