<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-06-01T15:00:00-05:00" frus:doc-dateTime-min="1918-06-01T15:00:00-05:00" n="536" subtype="historical-document" type="document" xml:id="d536">
                            <note rend="inline" type="source">File No. 861.00/1899</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-06-01T16:00:00-04:00">
                                        <hi rend="italic">June 1, 1918, 4 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>152. Your 210, May 27, 6 a.m.<note n="1" xml:id="d536fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_543">p.
                                    543</ref>.</note> Red Cross has ordered <persName corresp="#p_RLCR1">Robins</persName> to-day to continue journey
                                home.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>