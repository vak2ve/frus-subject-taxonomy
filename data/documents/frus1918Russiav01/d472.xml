                subtype="historical-document" type="document" xml:id="d472">
                <note rend="inline" type="source">File No. 861.00/1426</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-04-06T16:00:00-04:00">
                            <hi rend="italic">April 6, 1918, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>7159. Your 9351 does not answer inquiry in Department’s 7128. Department desires
                    to know why British Government is suppressing telegrams in code between Russian
                    Embassy here and the Russian Embassy in Paris.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
