    <text>
        <body>
            <div frus:doc-dateTime-max="1918-09-14T18:00:00-05:00"
                frus:doc-dateTime-min="1918-09-14T18:00:00-05:00" n="615"
                subtype="historical-document" type="document" xml:id="d615">
                <note rend="inline" type="source">File No. 123 P 78/48b</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName corresp="#p_SWG1" type="to">
                        <hi rend="italic">Sharp</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-09-14T19:00:00-04:00">
                            <hi rend="italic">September 14, 1918, 7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>5623. Please forward following telegram for <persName corresp="#p_PDC1"
                        >Poole</persName> at Moscow immediately by any route available: <quote
                        rend="blockquote">
                        <p>Department has approved your remaining at Moscow but now desires you to
                            proceed immediately Stockholm, Archangel or Omsk whichever you can
                            arrange and report from there. Any Americans remaining should accompany
                            you if possible.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
