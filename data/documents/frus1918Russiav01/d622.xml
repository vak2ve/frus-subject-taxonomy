    <text>
        <body>
            <div frus:doc-dateTime-max="1918-10-07T06:00:00-05:00"
                frus:doc-dateTime-min="1918-10-07T06:00:00-05:00" n="622"
                subtype="historical-document" type="document" xml:id="d622">
                <note rend="inline" type="source">File No. 861.00/2900</note>
                <head>
                    <hi rend="italic">The Chargé in Norway</hi> (<persName type="from">
                        <hi rend="italic">Schoenfeld</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Christiania</hi>
                        </placeName>, <date calendar="gregorian" when="1918-10-07T12:00:00+01:00">
                            <hi rend="italic">October 7, 1918, noon</hi>
                        </date>. <lb/> [<hi rend="italic">Received 10 p.m.</hi>]</dateline>
                </opener>
                <p>1216. <hi rend="italic">Note verbale</hi> from the Foreign Office dated October 4
                    states that a telegram from Norwegian Legation, Petrograd, under date of October
                    3 reports that the British and French citizens who had sought asylum in the
                    American Consulate General, Moscow, had left and that Norwegian
                    extraterritoriality had not been violated.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Schoenfeld</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
