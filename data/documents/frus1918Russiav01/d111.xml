    <text>
        <body>
            <div frus:doc-dateTime-max="1917-05-01T16:00:00-05:00"
                frus:doc-dateTime-min="1917-05-01T16:00:00-05:00" n="111"
                subtype="historical-document" type="document" xml:id="d111">
                <note rend="inline" type="source">File No. 763.72/4137</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to">
                        <hi rend="italic">Francis</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-05-01T16:00:00-05:00">
                            <hi rend="italic">May 1, 1917—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1367. Your 1231, April 28. Please say to <persName corresp="#p_MPN1"
                        >Milyukov</persName> that this Government will be delighted to receive
                    commission from Russia, and that it is believed that good results would follow
                    from the visit of the commission at as early a date as possible.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
