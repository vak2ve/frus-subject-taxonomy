<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-11-30T18:00:00-05:00" frus:doc-dateTime-min="1917-11-30T18:00:00-05:00" n="259" subtype="historical-document" type="document" xml:id="d259">
                            <note rend="inline" type="source">File No. 861.00/721</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-11-30T18:00:00-05:00">
                                        <hi rend="italic">November 30, 1917, 6 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>1873. Your 2027, November 25, 8 p.m.<note n="1" xml:id="d259fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_267">p.
                                    267</ref>.</note> Referring last sentence Department believes it
                                would be most unwise to interfere in any way or take any sort of
                                initiative such as you suggest.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>