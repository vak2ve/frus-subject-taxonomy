<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-04-02T17:00:00-05:00" frus:doc-dateTime-min="1918-04-02T17:00:00-05:00" n="466" subtype="historical-document" type="document" xml:id="d466">
                            <note rend="inline" type="source">File No. 360d.1121 R 25/18</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-04-02T18:00:00-04:00">
                                        <hi rend="italic">April 2, 1918, 6 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>41. Your unnumbered March 29, 9 p.m. Ask <persName corresp="#p_SM1">Summers</persName> source of statement Moscow press. Not
                                authorized by Department.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>