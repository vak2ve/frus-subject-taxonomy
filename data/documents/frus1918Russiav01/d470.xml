<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-04-05T12:00:00-05:00" frus:doc-dateTime-min="1918-04-05T12:00:00-05:00" n="470" subtype="historical-document" type="document" xml:id="d470">
                            <note rend="inline" type="source">File No. 861.00/1416</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-04-05T13:00:00-04:00">
                                        <hi rend="italic">April 5, 1918, 1 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>48. Your 52, April 1, 2 p.m. As already explained in my 21, March 23,
                                7 p.m.,<note n="1" xml:id="d470fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_487">p.
                                    487</ref>.</note> Department relies on your discretion and
                                judgment to remain in Russia so long as you can reflect friendly
                                purpose and sympathy of this Government for Russian people without
                                imperiling self and staff.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>