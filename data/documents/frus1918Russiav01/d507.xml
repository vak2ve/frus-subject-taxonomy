<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-05-09T16:00:00-05:00" frus:doc-dateTime-min="1918-05-09T16:00:00-05:00" n="507" subtype="historical-document" type="document" xml:id="d507">
                            <note rend="inline" type="source">File No. 811.142/3335f</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)<note n="1" xml:id="d507fn1">Also to the Consul at Moscow, No. 29, May
                                    9.</note>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-05-09T17:00:00-04:00">
                                        <hi rend="italic">May 9, 1918, 5 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>115. For <persName corresp="#p_RLCR1">Robins</persName>: <quote rend="blockquote">
                                    <p>Reconsidered our 10095.<note n="2" xml:id="d507fn2">Department’s No. 22, May 7, to the Consul at Moscow,
                                                <hi rend="italic">ante</hi>, <ref target="#pg_523">p. 523</ref>.</note> Now considered desirable that
                                        you remain in Russia for three weeks longer awaiting further
                                        advices. <persName corresp="#p_DHP1">Davison</persName>.</p>
                                </quote>
                            </p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>