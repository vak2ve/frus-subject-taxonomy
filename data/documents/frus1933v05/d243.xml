<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-05-07T18:00:00-05:00" frus:doc-dateTime-min="1933-05-07T18:00:00-05:00" n="243" subtype="historical-document" type="document" xml:id="d243">
                            <note rend="inline" type="source">123C11/317: Telegram</note>
                            <head><hi rend="italic">The Minister in Colombia</hi> (<persName type="from"><hi rend="italic">Caffery</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1933-05-07T18:00:00-05:00">May 7, 1933—6
                                    p.m.</date><lb/>[Received 9:50 p.m.]</dateline>
                            </opener>
                            <p>48. Department’s 44, May 6, 3 p.m. For Phillips from Caffery. I
                                should be happy to be appointed Ambassador to Cuba on the
                                termination of Sumner Welles’ period and in the meantime fill the
                                vacancy of Assistant Secretary of State.<note n="17" xml:id="d243fn17">Mr. Caffery entered upon his duties as
                                    Assistant Secretary of State, July 12, 1933.</note> Thank
                                you.</p>
                            <closer><signed><hi rend="smallcaps">Caffery</hi></signed></closer>
                        </div>
                        </body></text></TEI>