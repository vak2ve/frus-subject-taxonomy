<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-11-27T12:00:00-05:00" frus:doc-dateTime-min="1933-11-27T12:00:00-05:00" n="506" subtype="historical-document" type="document" xml:id="d506">
                            <note rend="inline" type="source">837.01/47: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the <gloss type="to">Acting Secretary of
                                        State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName>S. S. “<hi rend="smallcaps">American Legion</hi>”</placeName>, <date calendar="gregorian" when="1933-11-27T12:00:00">November 27,
                                        1933—noon</date>.<lb/>[Received 7:50 p.m.]</dateline>
                            </opener>
                            <p>13. For the Acting Secretary and Caffery. Please telegraph me at
                                Montevideo the controlling facts and conditions to date against
                                recognition of the Grau San Martín regime in Cuba.</p>
                            <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                        </div>
                        </body></text></TEI>