<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-12-13T17:00:00-05:00" frus:doc-dateTime-min="1933-12-13T17:00:00-05:00" n="75" subtype="historical-document" type="document" xml:id="d75">
                        <note rend="inline" type="source">832.5151/202: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Ambassador in Brazil</hi> (<persName type="to"><hi rend="italic">Gibson</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1933-12-13T17:00:00-05:00">December 13, 1933—5
                                p.m.</date></dateline>
                        </opener>
                        <p>106. Your 121, December 11, 3 p.m., from Commercial Attaché for Commerce.
                            This Department would appreciate comment and recommendations from
                            you.</p>
                        <closer><signed><hi rend="smallcaps">Phillips</hi></signed></closer>
                    </div>
                    </body></text></TEI>