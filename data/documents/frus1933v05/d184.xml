<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-08-02T18:00:00-05:00" frus:doc-dateTime-min="1933-08-02T18:00:00-05:00" n="184" subtype="historical-document" type="document" xml:id="d184">
                        <note rend="inline" type="source">611.2131/35: Telegram</note>
                        <head><hi rend="italic">The Chargé in Colombia</hi> (<persName type="from"><hi rend="italic">Dawson</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Acting Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1933-08-02T18:00:00-05:00">August 2, 1933—6
                                p.m.</date><lb/>[Received 8:10 p.m.]</dateline>
                        </opener>
                        <p>69. Legation’s 66, July 21, 6 p.m. Pomponio Guzmán<note n="7" xml:id="d184fn7">Former Minister of Finance.</note> and an official
                            of Ministry of Finance, not yet designated, will assist Lozano. Will
                            arrive Washington in about 2 weeks.</p>
                        <closer><signed><hi rend="smallcaps">Dawson</hi></signed></closer>
                    </div>
                    </body></text></TEI>