                subtype="historical-document" type="document" xml:id="d111">
                <note rend="inline" type="source">611.2531/57</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Chile</hi> (<persName type="to">
                        <hi rend="italic">Culbertson</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">No. 1483</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1933-04-03">April 3,
                            1933</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The receipt is acknowledged of your despatch No.
                    1401, dated March 8, 1933, in which you set forth your views and report the
                    representations <pb facs="0208" n="120" xml:id="pg_120"/> made by the Embassy
                    with a view to obtaining equivalent treatment for American interests to that
                    granted to other foreign nations by Chile’s various compensation agreements.</p>
                <p>The Department appreciates the Embassy’s constructive interest in this matter and
                    hereby approves the views which you have conveyed to the Minister for Foreign
                    Affairs in your notes of February 23 and March 3, 1933.<note n="17"
                        xml:id="d111fn17">Neither printed.</note>
                </p>
                <p>Very truly yours,</p>
                <closer>For the Secretary of State:<lb/>
                    <signed>
                        <hi rend="smallcaps">Francis White</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
