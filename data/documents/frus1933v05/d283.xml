<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-07-19T17:00:00-05:00" frus:doc-dateTime-min="1933-07-19T17:00:00-05:00" n="283" subtype="historical-document" type="document" xml:id="d283">
                            <note rend="inline" type="source">837.00/3580: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Ambassador in Cuba</hi> (<persName type="to"><hi rend="italic">Welles</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1933-07-19T18:00:00-04:00">July 19, 1933—6
                                    p.m.</date></dateline>
                            </opener>
                            <p>58. You are authorized to state that the Department is fully in
                                accord with the statement you intend to make to President Machado,
                                as set out by you.<note n="28" xml:id="d283fn28">See <hi rend="italic">supra.</hi></note></p>
                            <closer><signed><hi rend="smallcaps">Phillips</hi></signed></closer>
                        </div>
                        </body></text></TEI>