                <note rend="inline" type="source">123W451/103: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Cuba</hi> (<persName type="from">
                        <hi rend="italic">Welles</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1933-05-11T11:00:00-05:00"
                            >May 11, 1933—11 a.m.</date>
                        <lb/>[Received 12:30 p.m.]</dateline>
                </opener>
                <p>39. Presented letter of credence this morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Welles</hi>
                    </signed>
                </closer>
            </div>
