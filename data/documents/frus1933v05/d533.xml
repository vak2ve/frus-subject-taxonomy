<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-12-26T17:00:00-05:00" frus:doc-dateTime-min="1933-12-26T17:00:00-05:00" n="533" subtype="historical-document" type="document" xml:id="d533">
                            <note rend="inline" type="source">837.00/4558: Telegram</note>
                            <head><hi rend="italic">The Personal Representative of the
                                    President</hi> (<persName type="from"><hi rend="italic">Caffery</hi></persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Habana</hi></placeName>, <date calendar="gregorian" when="1933-12-26T17:00:00-05:00">December 26, 1933—5
                                        p.m.</date><lb/>[Received 6 p.m.]</dateline>
                            </opener>
                            <p>530. I am endeavoring to explore situation thoroughly and hope to
                                have some definite suggestions to make next week.</p>
                            <closer><signed><hi rend="smallcaps">Caffery</hi></signed></closer>
                        </div>
                        </body></text></TEI>