                subtype="historical-document" type="document" xml:id="d320">
                <note rend="inline" type="source">837.00/3645: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Cuba</hi> (<persName type="from">
                        <hi rend="italic">Welles</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1933-08-13T14:00:00-05:00"
                            >August 13, 1933—2 p.m.</date>
                        <lb/>[Received 4:25 p.m.]</dateline>
                </opener>
                <p>154. For Caffery. Please express to the Secretary my deep appreciation of his
                    generous message.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Welles</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
