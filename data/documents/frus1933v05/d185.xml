<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-08-14T17:00:00-05:00" frus:doc-dateTime-min="1933-08-14T17:00:00-05:00" n="185" subtype="historical-document" type="document" xml:id="d185">
                        <note rend="inline" type="source">611.2131/40: Telegram</note>
                        <head><hi rend="italic">The Chargé in Colombia</hi> (<persName type="from"><hi rend="italic">Dawson</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Acting Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1933-08-14T17:00:00-05:00">August 14, 1933—5
                                p.m.</date><lb/>[Received 8:25 p.m.]</dateline>
                        </opener>
                        <p>73. Legation’s 72, August 14, 11 a.m.<note n="6" xml:id="d185fn6">Not
                                printed.</note> Lozano authorized today to enter into exploratory
                            conversations pending arrival advisers.</p>
                        <closer><signed><hi rend="smallcaps">Dawson</hi></signed></closer>
                    </div>
