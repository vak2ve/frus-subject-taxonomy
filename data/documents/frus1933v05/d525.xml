                subtype="historical-document" type="document" xml:id="d525">
                <note rend="inline" type="source">123 W 451/164: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Cuba</hi> (<persName type="from">
                        <hi rend="italic">Matthews</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1933-12-13T15:00:00-05:00"
                            >December 13, 1933—3 p.m.</date>
                        <lb/>[Received 4:20 p.m.]</dateline>
                </opener>
                <p>515. Ambassador Welles departed by airplane this afternoon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Matthews</hi>
                    </signed>
                </closer>
            </div>
        </body>
