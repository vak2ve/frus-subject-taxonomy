<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-08-13T08:00:00-05:00" frus:doc-dateTime-min="1933-08-13T08:00:00-05:00" n="319" subtype="historical-document" type="document" xml:id="d319">
                            <note rend="inline" type="source">837.00/3644: Telegram</note>
                            <head><hi rend="italic">The Consul at Nassau</hi> (<persName type="from"><hi rend="italic">Hurley</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Nassau</hi></placeName>, <date calendar="gregorian" when="1933-08-13T08:00:00-05:00">August 13, 1933—8
                                        a.m.</date><lb/>[Received 9:50 a.m.]</dateline>
                            </opener>
                            <p>Ex-President Machado arrived here at daylight this morning.</p>
                            <closer><signed><hi rend="smallcaps">Hurley</hi></signed></closer>
                        </div>
                        </body></text></TEI>