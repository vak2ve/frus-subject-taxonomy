                subtype="historical-document" type="document" xml:id="d391">
                <note rend="inline" type="source">837.00/3871: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Cuba</hi> (<persName type="to">
                        <hi rend="italic">Welles</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1933-09-14T19:00:00-04:00"
                            >September 14, 1933—7 p.m.</date>
                    </dateline>
                </opener>
                <p>100. Your telegram 249, September 14. I talked this afternoon with the French
                    Ambassador regarding this matter, and have also telegraphed the Embassy at Paris
                    to take it up immediately with the Foreign Office.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
