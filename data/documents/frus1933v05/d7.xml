                subtype="historical-document" type="document" xml:id="d7">
                <note rend="inline" type="source">824.512/56: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Bolivia</hi> (<persName type="from">
                        <hi rend="italic">Feely</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">La Paz</hi>
                        </placeName>, <date calendar="gregorian" when="1932-10-13T11:00:00-04:00"
                            >October 13, 1932—11 a.m.</date>
                        <lb/>[Received 12:29 p.m.]</dateline>
                </opener>
                <p>101. Referring to the proposed levy on capital for war purposes, the Minister of
                    Foreign Affairs informed me yesterday that in his opinion foreign individuals
                    and corporations would be exempt under the terms of the treaties.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Feely</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
