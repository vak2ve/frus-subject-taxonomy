    <text>
        <body>
            <div frus:doc-dateTime-max="1933-07-01T23:59:59-05:00"
                frus:doc-dateTime-min="1933-07-01T00:00:00-05:00" n="759"
                subtype="historical-document" type="document" xml:id="d759">
                <note rend="inline" type="source">812.504/1406</note>
                <head>
                    <hi rend="italic">The Ambassador in Mexico</hi> (<persName type="from">
                        <hi rend="italic">Daniels</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 311</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1933-07-01">July 1,
                            1933</date>.<lb/>[Received July 10.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to refer to my despatch number
                    272 dated June 23, 1933, regarding the illegal entry of Chinese nationals into
                    the United States from Mexico and to enclose herewith a copy and translation of
                    note number 11958 dated June 20, 1933, from the Foreign Office<note n="63"
                        xml:id="d759fn63">Not printed.</note> in which it is stated that the
                    Ministry of Gobernación has advised that it has issued definitive instructions
                    to the Migration offices on the border to prevent this illegality. This note was
                    received at the Embassy on June 29, 1933.</p>
                <p>Respectfully yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Josephus Daniels</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
