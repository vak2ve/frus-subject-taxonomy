<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-08-27T15:00:00-05:00" frus:doc-dateTime-min="1933-08-27T15:00:00-05:00" n="333" subtype="historical-document" type="document" xml:id="d333">
                            <note rend="inline" type="source">837.00/3721: Telegram</note>
                            <head><hi rend="italic">The Consul at Nassau</hi> (<persName type="from"><hi rend="italic">Hurley</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Nassau</hi></placeName>, <date calendar="gregorian" when="1933-08-27T15:00:00-05:00">August 27, 1933—3
                                        p.m.</date><lb/>[Received 4:50 p.m.]</dateline>
                            </opener>
                            <p>Machado and party left by the steamship <hi rend="italic">Lady
                                    Rodney</hi> last night, destination Montreal via Bermuda.</p>
                            <closer><signed><hi rend="smallcaps">Hurley</hi></signed></closer>
                        </div>
                        </body></text></TEI>