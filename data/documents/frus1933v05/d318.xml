                subtype="historical-document" type="document" xml:id="d318">
                <note rend="inline" type="source">837.00/3653a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Cuba</hi> (<persName type="to">
                        <hi rend="italic">Welles</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1933-08-12T20:00:00-04:00"
                            >August 12, 1933—8 p.m.</date>
                    </dateline>
                </opener>
                <p>73. From Caffery. The President and Secretary have asked me to express their warm
                    congratulations to you and their appreciation of what you have done.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
