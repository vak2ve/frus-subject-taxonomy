    <text>
        <body>
            <div frus:doc-dateTime-max="1945-11-23T23:59:59-05:00"
                frus:doc-dateTime-min="1945-11-23T00:00:00-05:00" n="741"
                subtype="historical-document" type="document" xml:id="d741">
                <note rend="inline" type="source">740.00119 Control (Japan)/11–1345</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chinese Ambassador</hi> (<persName type="to">
                        <hi rend="italic">Wei</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1945-11-23">November 23,
                            1945</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to acknowledge the
                    receipt of your note of November 13, 1945, in regard to the question of the
                    disposal of the Japanese naval fleet. Consideration will be given to the
                    request, contained in your note, in regard to the allotment to China of Japanese
                    vessels, after which I shall expect to send you a further reply.</p>
                <p>Accept [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <hi rend="smallcaps">Dean Acheson</hi>
                    </signed>
                    <note n="61" xml:id="d741fn1">Under Secretary of State.</note>
                </closer>
            </div>
        </body>
    </text>
