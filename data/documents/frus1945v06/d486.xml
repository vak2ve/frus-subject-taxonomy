        <body>
            <div frus:doc-dateTime-max="1945-08-31T02:00:00-05:00" frus:doc-dateTime-min="1945-08-31T02:00:00-05:00" n="486" subtype="historical-document" type="document" xml:id="d486">
                <note rend="inline" type="source">740.00119 FEAC/8–3145: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Hurley</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chungking</hi>
                        </placeName>, <date calendar="gregorian" when="1945-08-31T14:00:00+07:00">August 31, 1945—2 p.m.</date>
                        <lb/> [Received August 31—11:11 a.m.]</dateline>
                </opener>
                <p>1486, bis. Dept’s 1296, August 21<note n="54" xml:id="d486fn1">See footnote 28,
                            <ref target="#pg_683">p. 683</ref>.</note> and Embassy’s 1449, August
                        25.<note n="55" xml:id="d486fn2">Not printed here.</note> By formal note
                    dated August 30, Foreign Office informed Embassy that proposal for establishment
                    of Far Eastern Advisory Commission meets with approval of Chinese
                    Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hurley</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
