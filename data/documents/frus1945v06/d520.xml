<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Acting Political Adviser in Japan (
                        Atcheson
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945v06</bibl><bibl type="frus-document-id">d520</bibl><bibl type="frus-document-number">520</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-10-05T00:00:00-05:00" notAfter="1945-10-05T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-10-05T23:59:59-05:00" frus:doc-dateTime-min="1945-10-05T00:00:00-05:00" n="520" subtype="historical-document" type="document" xml:id="d520">
                <note rend="inline" type="source">740.00119 Control (Japan)/10–545: Telegram</note>
                <head>
                    <hi rend="italic">The Acting Political Adviser in Japan</hi> (<persName type="from">
                        <hi rend="italic">Atcheson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1945-10-05">October 5,
                            1945</date>.<lb/>[Received October 9—12:05 p.m.]</dateline>
                </opener>
                <p>24. ReDeptel 13, undated.<note n="18" xml:id="d520fn1">October 3, 11 a.m., <ref target="#pg_734">p. 734</ref>.</note> General MacArthur issued October 4
                    directive to Japanese Government ordering removal of restrictions on political,
                    civil and religious liberties and release of political prisoners. Understand
                    press has radioed details. Copy of directive will go forward by mail.<note n="19" xml:id="d520fn2">For text, see Department of State <hi rend="italic">Bulletin</hi>, November 4, 1945, p. 730; see also addendum, November
                        25, 1945, p. 874.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Atcheson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
