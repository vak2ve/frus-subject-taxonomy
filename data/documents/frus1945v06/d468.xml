<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-08-21T23:59:59-05:00" frus:doc-dateTime-min="1945-08-21T00:00:00-05:00" n="468" subtype="historical-document" type="document" xml:id="d468">
                                <note rend="inline" type="source">740.00119 P.W./8–2145:
                                    Telegram</note>
                                <head>
                                    <hi rend="italic">The Ambassador in the Soviet Union</hi>
                                        (<persName type="from"><hi rend="italic">Harriman</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                    </hi>
                                </head>
                                <opener>
                                    <dateline rendition="#right">
                                        <placeName>
                                            <hi rend="smallcaps">Moscow</hi></placeName>, <date calendar="gregorian" when="1945-08-21">August 21,
                                            1945</date>.<lb/>[Received August 21—10:30
                                        p.m.]</dateline>
                                </opener>
                                <p>2985. Press, August 21, announced appointment of Lt. Gen.
                                        Derevyanko<note n="29a" xml:id="d468fn1">Lt. Gen. Kuzma
                                        Nikolayevich Derevyanko, field observer in the Pacific
                                        theater in 1945.</note> as representative of Soviet Forces
                                    to General MacArthur.</p>
                                <p>Sent Dept, repeated American Embassy, Chungking, 100.</p>
                                <closer>[<signed>
                                        <hi rend="smallcaps">Harriman</hi>
                                    </signed>]</closer>
                            </div>
                            </body></text></TEI>