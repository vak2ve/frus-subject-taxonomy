                subtype="historical-document" type="document" xml:id="d342">
                <note rend="inline" type="source">740.00119 PW/2–2345: Telegram</note>
                <head>
                    <hi rend="italic">The Personal Representative of President <persName type="from"
                            >Roosevelt</persName> to <persName>Pope Pius XII</persName>
                    </hi> (<persName type="to">
                        <hi rend="italic">Taylor</hi>
                    </persName>) <hi rend="italic">to the Secretary of State</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vatican City</hi>
                        </placeName>, <date calendar="gregorian" when="1945-02-23T11:00:00+01:00"
                            >February 23, 1945—11 a.m.</date>
                        <lb/> [Received February 23—9:05 a.m.]</dateline>
                </opener>
                <p>45. Re Department’s 23, February 21, 1 p.m. We have not seen Ken Harada, much
                    less talked with him.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Taylor</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
