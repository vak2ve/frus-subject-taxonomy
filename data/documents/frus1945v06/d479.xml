<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-08-26T12:00:00-05:00" frus:doc-dateTime-min="1945-08-26T12:00:00-05:00" n="479" subtype="historical-document" type="document" xml:id="d479">
                                <note rend="inline" type="source">740.00119 PW/8–2645:
                                    Telegram</note>
                                <head>
                                    <hi rend="italic">The <gloss type="from">Secretary of
                                            State</gloss> to the Ambassador in the Soviet Union</hi>
                                        (<persName type="to"><hi rend="italic">Harriman</hi></persName>)</head>
                                <opener>
                                    <dateline rendition="#right">
                                        <placeName>
                                            <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1945-08-26T13:00:00-04:00">August 26, 1945—1 p.m.</date>
                                    </dateline>
                                </opener>
                                <p>1916. Your 3061, August 25, midnight. You are authorized to
                                    confirm the fact that General Order No. 1 has been amended to
                                    provide for surrender of Japanese forces in the Kuriles to be
                                    accepted by the Soviet Command.</p>
                                <closer>
                                    <signed>
                                        <hi rend="smallcaps">Byrnes</hi>
                                    </signed>
                                </closer>
                            </div>
                            </body></text></TEI>