                subtype="historical-document" type="document" xml:id="d279">
                <note rend="inline" type="source">862.20/1132: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName type="from">
                        <hi rend="italic">Dodd</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1936-10-12T17:00:00+01:00"
                            >October 12, 1936—5 p.m.</date>
                        <lb/> [Received October 12—12:05 p.m.]</dateline>
                </opener>
                <p>301. Embassy’s telegram 294, September 28, 6 p.m. The military action outlined
                    went into effect on October 11th according to the Military Attaché but will not
                    be publicly announced.</p>
                <p>Copies to London, Rome, Paris.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dodd</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
