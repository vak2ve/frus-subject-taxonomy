    <text>
        <body>
            <div frus:doc-dateTime-max="1936-12-28T23:59:59-05:00"
                frus:doc-dateTime-min="1936-12-28T00:00:00-05:00" n="140"
                subtype="historical-document" type="document" xml:id="d140">
                <note rend="inline" type="source">500.A15A3/1861</note>
                <head>
                    <hi rend="italic">The Japanese Ambassador</hi> (<persName type="from">
                        <hi rend="italic">Saito</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 284</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-12-28">December 28,
                            1936</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor, under instructions from my
                    Government, to communicate to you the following: <quote rend="blockquote">
                        <p>The Government of Japan, perceiving that, in view of the present
                            international situation, the requirements of the national security of
                            Japan has made it necessary to retain 15,598 tons of submarines in
                            excess of the maximum tonnage which is permitted in Article 16, Clause 1
                            of the London Naval Treaty of 1930, has decided to invoke Article 21 of
                            that Treaty to retain the excess tonnage above referred to.</p>
                    </quote>
                </p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hirosi Saito</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
