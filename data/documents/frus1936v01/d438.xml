                subtype="historical-document" type="document" xml:id="d438">
                <note rend="inline" type="source">561.35E1/146: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the United Kingdom</hi> (<persName type="to">
                        <hi rend="italic">Bingham</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-05-19T19:00:00-04:00"
                            >May 19, 1936—7 p.m.</date>
                    </dateline>
                </opener>
                <p>168. Reference Department’s instruction 1236 of May 11, 1936. In presenting a
                    copy of the memorandum you may state orally that the <pb facs="0613" n="533"
                        xml:id="pg_533"/> Philippine Government has indicated that it will
                    participate in the proposed International Sugar Conference through
                    representation on the American Delegation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
