<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-03-13T13:00:00-05:00" frus:doc-dateTime-min="1936-03-13T13:00:00-05:00" n="205" subtype="historical-document" type="document" xml:id="d205">
                        <note rend="inline" type="source">740.0011 Mutual Guarantee (Locarno)/431:
                            Telegram</note>
                        <head>
                            <hi rend="italic">The Chargé in the United Kingdom</hi> (<persName type="from"><hi rend="italic">Atherton</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1936-03-13T18:00:00+00:00">March 13,
                                    1936—6 p.m.</date>
                                <lb/> [Received March 13—2:55 p.m.]</dateline>
                        </opener>
                        <p>117. Aghnides<note n="93" xml:id="d205fn93">Thanassis Aghnides, director
                                In the office of the Secretary-General, League of Nations
                                Secretariat.</note> has offered me visitors ticket for Council
                            meeting tomorrow morning to give me the same facilities that Minister
                            Wilson has in Geneva on similar occasions. Are there any objections to
                            my attending?</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Atherton</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>