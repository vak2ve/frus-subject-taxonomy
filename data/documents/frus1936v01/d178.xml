<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-03-07T15:00:00-05:00" frus:doc-dateTime-min="1936-03-07T15:00:00-05:00" n="178" subtype="historical-document" type="document" xml:id="d178">
                        <note rend="inline" type="source">740.0011 Mutual Guarantee (Locarno)/394a:
                            Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in France</hi> (<persName type="to"><hi rend="italic">Straus</hi></persName>)<note n="51" xml:id="d178fn51">Also sent
                                to the American Embassies in the United Kingdom and Germany as
                                Department’s telegrams Nos. 75 and 20, respectively.</note>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1936-03-07T15:00:00-05:00">March 7,
                                    1936—3 p.m.</date>
                            </dateline>
                        </opener>
                        <p>67. Please keep us closely informed, hourly if necessary, of all
                            important developments in situation arising out of German action of
                            today.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>