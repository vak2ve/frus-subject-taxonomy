<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-11-06T09:00:00-05:00" frus:doc-dateTime-min="1936-11-06T09:00:00-05:00" n="153" subtype="historical-document" type="document" xml:id="d153">
                        <note rend="inline" type="source">500.A15A3/1838: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in the United Kingdom</hi> (<persName type="from"><hi rend="italic">Bingham</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1936-11-06T14:00:00+00:00">November
                                    6, 1936—2 p.m.</date>
                                <lb/> [Received November 6—11:25 a.m.]</dateline>
                        </opener>
                        <p>515. Department’s instruction 1454, October 8.<note n="8" xml:id="d153fn8">Not printed; see Department’s telegram No. 367,
                                October 8, 8 p.m., <hi rend="italic">supra</hi>.</note> I signed
                            submarine procès-verbal at the F[oreign] O[ffice] at noon today.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bingham</hi>
                            </signed>
                        </closer>
                        <postscript>
                            <p>[Text of the procès-verbal signed at London, November 6, 1936, is
                                printed in Department of State, <hi rend="italic">Treaty
                                    Information</hi>, Bulletin No. 86, November 30, 1936, page 35,
                                and in British Cmd. 5302; see also statement issued by the
                                Department of State, September 30, 1941, <ref target="frus1930v01#pg_130">
                                    <hi rend="italic">Foreign Relations</hi>, 1930, volume I, page
                                    130</ref>.]</p>
                        </postscript>
                    </div>
                </body></text></TEI>