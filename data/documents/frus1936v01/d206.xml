<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-03-13T19:00:00-05:00" frus:doc-dateTime-min="1936-03-13T19:00:00-05:00" n="206" subtype="historical-document" type="document" xml:id="d206">
                        <note rend="inline" type="source">740.0011 Mutual Guarantee (Locarno)/431:
                            Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Chargé in the United Kingdom</hi>
                                (<persName type="to"><hi rend="italic">Atherton</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1936-03-13T19:00:00-05:00">March 13,
                                    1936—7 p.m.</date>
                            </dateline>
                        </opener>
                        <p>80. Your 117, March 13, 6 p.m. Considering all the circumstances we think
                            it would be preferable for you not to attend.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Phillips</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>