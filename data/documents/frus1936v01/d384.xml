                subtype="historical-document" type="document" xml:id="d384">
                <note rend="inline" type="source">500.C1199/242: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Geneva</hi> (<persName type="from">
                        <hi rend="italic">Gilbert</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Geneva</hi>
                        </placeName>, <date calendar="gregorian" when="1936-10-02T17:00:00+01:00"
                            >October 2, 1936—5 p.m.</date>
                        <lb/> [Received October 2—1:05 p.m.]</dateline>
                </opener>
                <p>386. Have conveyed to Saavedra Lamas the contents of your 113, October 1, 6 p.m.,
                    and in the course of our conversation he expressed agreement with the points
                    covered therein and his appreciation for your message.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gilbert</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
