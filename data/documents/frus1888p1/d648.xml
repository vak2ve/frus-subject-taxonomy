    <text>
        <body>
            <div frus:doc-dateTime-max="1888-08-10T23:59:59-05:00" frus:doc-dateTime-min="1888-08-10T00:00:00-05:00" n="648" subtype="historical-document" type="document" xml:id="d648">
                <head>No. 648.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Thompson</persName> to Mr. <persName type="to">Bayard</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mole St.
                                    Nicholas</hi>
                        </placeName>, <date calendar="gregorian" when="1888-08-10">
                            <hi rend="italic">August</hi> 10,
                            1888</date>.</dateline>
                </opener>
                <p>Your 114 urgent. Two immediately. One pass Cape Haytien. Reply. Details 18th
                        instant.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Thompson.</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
