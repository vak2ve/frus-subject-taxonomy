    <text>
        <body>
            <div frus:doc-dateTime-max="1888-07-31T23:59:59-05:00" frus:doc-dateTime-min="1888-07-31T00:00:00-05:00" n="646" subtype="historical-document" type="document" xml:id="d646">
                <head>No. 646.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName>
                            to Mr. <persName type="to">Thompson</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1888-07-31">
                            <hi rend="italic">July</hi> 31,
                            1888</date>.</dateline>
                    <seg rendition="#left">No. 115.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Your No. 194, of the 16th instant, reporting
                        the unsettled condition of affairs at Port au Prince, has been received.</p>
                <p>Your strict abstention from interference in the internal affairs of Hayti is
                        approved.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">T. F.
                            Bayard.</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
