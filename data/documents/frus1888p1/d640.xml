                <head>No. 640.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Thompson</persName> to Mr. <persName type="to">Bayard</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Jamaica</hi>
                        </placeName>, <date calendar="gregorian" when="1888-07-09">
                            <hi rend="italic">July</hi> 9, 1888</date>. (Received 2.41
                        p.m.)</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">State Department</hi>,<lb/>
                    <hi rend="italic">Washington:</hi>
                </p>
                <p>Send war vessel. Political incendiarism. Situation critical.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Thompson</hi>,<lb/>
                            <hi rend="italic">Hayti.</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
