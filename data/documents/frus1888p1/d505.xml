<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1888-02-02T23:59:59-05:00" frus:doc-dateTime-min="1888-02-02T00:00:00-05:00" n="505" subtype="historical-document" type="document" xml:id="d505">
                    <head>No. 505.<lb/><hi rend="italic">Mr. <persName type="from">Bayard</persName>
                            to Mr. <persName type="to">Phelps</persName>.</hi></head>
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department
                                    of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1888-02-02"><hi rend="italic">February</hi> 2,
                            1888</date>.</dateline></opener>
                    <p rend="flushleft"><hi rend="smallcaps">Phelps</hi>,<lb/><hi rend="italic">Minister, London:</hi></p>
                    <p>You are directed to express the satisfaction of the Department at the
                        instructions given to the collector of the port of Halifax to allow the fish
                        to be landed and sold on the payment of duty.</p>
                    <closer><signed><persName><hi rend="smallcaps">Bayard.</hi></persName></signed></closer>
                </div>
                </body></text></TEI>