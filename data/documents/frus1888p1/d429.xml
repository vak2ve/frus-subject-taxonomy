            <div frus:doc-dateTime-max="1887-11-15T23:59:59-05:00" frus:doc-dateTime-min="1887-11-15T00:00:00-05:00" n="429" subtype="historical-document" type="document" xml:id="d429">
                <head>No. 429.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName> to Mr. <persName type="to">Pendleton</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1887-11-15">
                            <hi rend="italic">November</hi> 15, 1887</date>.</dateline>
                </opener>
                <p>The President expresses the sentiments of the people of the United States in
                    offering his sincere sympathy to the Emperor in his grief on account of the
                    Crown Prince’s serious illness.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Bayard.</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
