                subtype="historical-document" type="document" xml:id="d234">
                <head>No. 234.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Denby</persName> to Mr. <persName
                            type="to">Bayard</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1888-09-05">
                            <hi rend="italic">September</hi> 5, 1888</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Bayard</hi>,<lb/>
                    <hi rend="italic">Washington:</hi>
                </p>
                <p>Believe treaty has been rejected. Have demanded from foreign office positive
                    information some days since. No information has yet been received.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Denby.</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
