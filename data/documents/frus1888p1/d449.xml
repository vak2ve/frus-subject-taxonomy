    <text>
        <body>
            <div frus:doc-dateTime-max="1888-03-09T23:59:59-05:00" frus:doc-dateTime-min="1888-03-09T00:00:00-05:00" n="449" subtype="historical-document" type="document" xml:id="d449">
                <head>No. 449.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName>
                            to Mr. <persName type="to">Pendleton</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1888-03-09">
                            <hi rend="italic">March</hi> 9,
                            1888</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Pendleton</hi>,<lb/>
                    <hi rend="italic">Minister, Berlin:</hi>
                </p>
                <p>The President desires you to make known through the foreign office that the
                        death of the illustrious and venerable Emperor of Germany has deeply aroused
                        the sorrow and sympathy of the people of the United States and their
                        Government.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Bayard.</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
