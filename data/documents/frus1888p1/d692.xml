            <div frus:doc-dateTime-max="1888-12-03T23:59:59-05:00" frus:doc-dateTime-min="1888-12-03T00:00:00-05:00" n="692" subtype="historical-document" type="document" xml:id="d692">
                <head>No. 690.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Rives</persName> to Mr. <persName type="to">Thompson</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1888-12-03">
                            <hi rend="italic">December</hi> 3, 1888</date>.</dateline>
                    <seg rendition="#left">No. 57.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                    dispatch of the 19th ultimo, No. 116, and to approve your action, reported
                    therein, in sending home the crew of the captured steamer <hi rend="italic">Haytian Republic</hi>.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">G. L. Rives</hi>,<lb/>
                            <hi rend="italic">Assistant Secretary.</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
