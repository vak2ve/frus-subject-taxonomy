    <text>
        <body>
            <div frus:doc-dateTime-max="1888-08-18T23:59:59-05:00" frus:doc-dateTime-min="1888-08-18T00:00:00-05:00" n="230" subtype="historical-document" type="document" xml:id="d230">
                <head>No. 230.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName>
                            to Mr. <persName type="to">Denby</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1888-08-18">
                            <hi rend="italic">August</hi> 18,
                            1888</date>.</dateline>
                    <seg rendition="#left">No. 343.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I herewith transmit, for your information, a
                        copy of my note<note n="*" xml:id="d230fn1">Mr. Bayard to Count Arco Valley,
                            August 17, 1888, with inclosures, printed as Doc. No. 497 <hi rend="italic">post</hi>, <ref target="#pg_683">page
                            683</ref>.</note> to the minister of Germany at this capital, dated the
                        17th instant, accompanied <pb facs="0482" n="348" xml:id="pg_348"/> by a
                        memorandum embodying the Department’s views touching the validity of
                        marriages in China between subjects of that Empire and foreigners.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">T. F.
                            Bayard.</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
