            <div frus:doc-dateTime-max="1888-10-29T23:59:59-05:00" frus:doc-dateTime-min="1888-10-29T00:00:00-05:00" n="668" subtype="historical-document" type="document" xml:id="d668">
                <head>No. 668.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName> to Mr. <persName type="to">Thompson</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1888-10-29">
                            <hi rend="italic">October</hi> 29, 1888</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Thompson</hi>, <hi rend="italic">Minister, Port au
                        Prince:</hi>
                </p>
                <p>Protest instantly against action of Haytian authorities. Man-of-war ordered.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Bayard.</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
