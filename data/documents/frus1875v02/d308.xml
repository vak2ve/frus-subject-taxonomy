    <text>
        <body>
            <div frus:doc-dateTime-max="1875-05-05T23:59:59-05:00" frus:doc-dateTime-min="1875-05-05T00:00:00-05:00" n="308" subtype="historical-document" type="document" xml:id="d308">
                <head>No. 600.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Cushing</persName> to Mr. <persName type="to">Fish</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1875-05-05">
                            <hi rend="italic">May</hi> 5,
                                1875</date>.</dateline>
                </opener>
                <p>I have obtained payment to-day of balance of indemnity money, 175,000
                            pesetas, which will be remitted conformably to existing
                            instructions.</p>
                <closer>
                    <signed>CUSHING.</signed>
                </closer>
            </div>
        </body>
