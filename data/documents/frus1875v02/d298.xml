                <head>No. 590.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Cushing</persName> to Mr. <persName
                            type="to">Fish</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1875-03-09">
                            <hi rend="italic">March</hi> 9, 1875</date>.</dateline>
                </opener>
                <p>Officious agreement has been signed, substantially as telegraphed on the 2d.
                    Credentials to be presented on the 10th.</p>
                <closer>
                    <signed>CUSHING.</signed>
                </closer>
            </div>
        </body>
