<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1875-08-16T23:59:59-05:00" frus:doc-dateTime-min="1875-08-16T00:00:00-05:00" n="341" subtype="historical-document" type="document" xml:id="d341">
                        <head>No. 633.<lb/><hi rend="italic">Mr. <persName type="from">Maynard</persName> to Mr. <persName type="to">Fish</persName></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Constantinople</hi></placeName>, <date calendar="gregorian" when="1875-08-16"><hi rend="italic">August</hi> 16, 1875</date>.
                                (Received August 16.)</dateline></opener>
                        <p rend="flushleft"><hi rend="smallcaps">Fish</hi>, Washington:</p>
                        <p>Saturday, Porte, informed by Aristarchi, telegraphed governor, ordering
                            reparation made American consul before Hartford reaches Tripoli.</p>
                        <closer><signed>MAYNARD.</signed></closer>
                    </div>
                    </body></text></TEI>