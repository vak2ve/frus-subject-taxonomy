    <text>
        <body>
            <div frus:doc-dateTime-max="1875-06-18T23:59:59-05:00" frus:doc-dateTime-min="1875-06-18T00:00:00-05:00" n="211" subtype="historical-document" type="document" xml:id="d211">
                <head>No. 510.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Fish</persName>
                            to Mr. <persName type="to">Schuyler</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1875-06-18">
                            <hi rend="italic">May</hi> 18,
                            1875</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Schuyler</hi>,<lb/>
                    <hi rend="italic">Chargé d’Affaires, St. Petersburg:</hi>
                </p>
                <p>Attend the telegraphic convention and report results without committing this
                        Government.</p>
                <closer>
                    <signed>FISH, <hi rend="italic">Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
