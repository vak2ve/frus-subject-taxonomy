    <text>
        <body>
            <div frus:doc-dateTime-max="1874-12-18T23:59:59-05:00" frus:doc-dateTime-min="1874-12-18T00:00:00-05:00" n="278" subtype="historical-document" type="document" xml:id="d278">
                <head>No. 7.<lb/>
                    <hi rend="italic">The <gloss type="from">Earl of
                                    Derby</gloss> to Mr. <persName type="to">Comyn</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Foreign
                                        Office</hi>
                        </placeName>, <date calendar="gregorian" when="1874-12-18">
                            <hi rend="italic">December</hi> 18,
                                    1874</date>.</dateline>
                </opener>
                <p>M. <hi rend="smallcaps">le Ministre</hi>: I have the honor to acknowledge
                            the receipt of your letter of the 14th instant, inclosing a check on
                            Messrs. Huth &amp; Co., of this city, to my order, for the sum of
                            £6,700, on account of the claims of the families of the British subjects
                            taken on board the Virginius and executed at Santiago de Cuba in
                            November, 1873.</p>
                <p>I have, &amp;c.,</p>
                <closer>
                    <signed>DERBY.</signed>
                </closer>
            </div>
        </body>
