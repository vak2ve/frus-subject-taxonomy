                <head>No. 584.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Cushing</persName> to Mr. <persName
                            type="to">Fish</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1875-02-16">
                            <hi rend="italic">February</hi> 16, 1875</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Fish</hi>, <hi rend="italic">Secretary of State,
                        Washington:</hi>
                </p>
                <p>Negotiation rests on my note of eleventh to Castro, mailed same day. His reply
                    sent to-day.</p>
                <p rend="center">* * * * * * *</p>
                <closer>
                    <signed>CUSHING.</signed>
                </closer>
            </div>
        </body>
