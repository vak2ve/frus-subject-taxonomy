    <text>
        <body>
            <div frus:doc-dateTime-max="1874-11-30T23:59:59-05:00" frus:doc-dateTime-min="1874-11-30T00:00:00-05:00" n="283" subtype="historical-document" type="document" xml:id="d283">
                <head>No. 575.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Cushing</persName> to Mr. <persName type="to">Fish</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1874-11-30">
                            <hi rend="italic">November</hi> 30,
                                    1874</date>. (Received 12.30 p.m., Nov. 30.)</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Fish</hi>, <hi rend="italic">Secretary of State,
                                Washington:</hi>
                </p>
                <p>Instruction of twenty-eighth received, and will be punctually obeyed.</p>
                <closer>
                    <signed>CUSHING.</signed>
                </closer>
            </div>
        </body>
