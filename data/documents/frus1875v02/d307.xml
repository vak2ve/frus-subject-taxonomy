<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1875-04-23T23:59:59-05:00" frus:doc-dateTime-min="1875-04-23T00:00:00-05:00" n="307" subtype="historical-document" type="document" xml:id="d307">
                        <head>No. 599.<lb/><hi rend="italic">Mr. <persName type="from">Fish</persName> to Mr. <persName type="to">Cushing</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1875-04-23"><hi rend="italic">April</hi> 23,
                                1875</date>.</dateline></opener>
                        <p>Anticipated payment taken as evidence of friendly dispositions, and
                            strengthens hope of speedy adjustment of all outstanding questions.</p>
                        <closer><signed>FISH.</signed></closer>
                    </div>
                    </body></text></TEI>