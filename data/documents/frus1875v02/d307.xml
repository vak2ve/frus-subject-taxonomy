                <head>No. 599.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Fish</persName> to Mr. <persName
                            type="to">Cushing</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1875-04-23">
                            <hi rend="italic">April</hi> 23, 1875</date>.</dateline>
                </opener>
                <p>Anticipated payment taken as evidence of friendly dispositions, and strengthens
                    hope of speedy adjustment of all outstanding questions.</p>
                <closer>
                    <signed>FISH.</signed>
                </closer>
            </div>
        </body>
