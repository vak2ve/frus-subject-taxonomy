                <head>No. 595.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Cushing</persName> to Mr. <persName
                            type="to">Fish</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1875-04-17">
                            <hi rend="italic">April</hi> 17, 1875</date>.</dateline>
                </opener>
                <p>Payments anticipated. Forty-five thousand dollars to be delivered to-day.</p>
                <p rend="center">* * * * * * *</p>
                <closer>
                    <signed>CUSHING.</signed>
                </closer>
            </div>
