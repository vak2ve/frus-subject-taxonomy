                subtype="historical-document" type="document" xml:id="d111">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Sutter</persName> to Mr. <persName
                            type="to">Foster</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Acapulco</hi>
                        </placeName>, <date calendar="gregorian" when="1875-01-27">
                            <hi rend="italic">January</hi> 27</date>.</dateline>
                </opener>
                <p rend="center">[Received in Mexico 27th, 9.40 p.m.]</p>
                <p rend="flushleft">
                    <hi rend="smallcaps">Minister of the United States</hi>:</p>
                <p>Mr. Hutchinson with servants aboard American frigate T. Batilly. He will sail by
                    steamer for Panama.</p>
                <closer>
                    <signed>SUTTER, <hi rend="italic">Consul.</hi>
                    </signed>
                </closer>
            </div>
        </body>
