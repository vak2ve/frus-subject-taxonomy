    <text>
        <body>
            <div frus:doc-dateTime-max="1875-10-05T23:59:59-05:00" frus:doc-dateTime-min="1875-10-05T00:00:00-05:00" n="31" subtype="historical-document" type="document" xml:id="d31">
                <head>No. 335.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Bassett</persName> to Mr. <persName type="to">Fish</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Hayti</hi>
                        </placeName>, <date calendar="gregorian" when="1875-10-05">
                            <hi rend="italic">October</hi> 5, 1875</date>.
                            (Received October 15.)</dateline>
                </opener>
                <p>Refugees amicably embarked and soldiers withdrawn from around my premises
                        yesterday.</p>
                <closer>
                    <signed>BASSETT.</signed>
                </closer>
            </div>
        </body>
