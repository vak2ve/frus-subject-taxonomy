                <head>No. 583.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Cushing</persName> to Mr. <persName
                            type="to">Fish</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1875-02-10">
                            <hi rend="italic">February</hi> 10, 1875</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Fish</hi>, <hi rend="italic">Secretary of State,
                        Washington:</hi>
                </p>
                <p>Interview to-day with Castro.</p>
                <p rend="center">* * * * * * *</p>
                <p>Satisfactory sum of indemnity free from condition of accountability required of
                    England to be stipulated by immediate further interchange of officious
                    notes.</p>
                <closer>
                    <signed>CUSHING.</signed>
                </closer>
            </div>
        </body>
