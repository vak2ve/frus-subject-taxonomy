<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1875-02-10T23:59:59-05:00" frus:doc-dateTime-min="1875-02-10T00:00:00-05:00" n="291" subtype="historical-document" type="document" xml:id="d291">
                        <head>No. 583.<lb/><hi rend="italic">Mr. <persName type="from">Cushing</persName> to Mr. <persName type="to">Fish</persName></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Madrid</hi></placeName>, <date calendar="gregorian" when="1875-02-10"><hi rend="italic">February</hi> 10,
                                    1875</date>.</dateline></opener>
                        <p rend="flushleft"><hi rend="smallcaps">Fish</hi>, <hi rend="italic">Secretary of State, Washington:</hi></p>
                        <p>Interview to-day with Castro.</p>
                        <p rend="center">* * * * * * *</p>
                        <p>Satisfactory sum of indemnity free from condition of accountability
                            required of England to be stipulated by immediate further interchange of
                            officious notes.</p>
                        <closer><signed>CUSHING.</signed></closer>
                    </div>
                    </body></text></TEI>