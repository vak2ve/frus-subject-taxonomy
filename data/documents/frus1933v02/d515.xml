<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-07-01T14:00:00-05:00" frus:doc-dateTime-min="1933-07-01T14:00:00-05:00" n="515" subtype="historical-document" type="document" xml:id="d515">
                            <note rend="inline" type="source">352.1121 Blodgett, Walton/10:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Ambassador in Spain (<persName type="to">Bowers</persName>)</hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1933-07-01T15:00:00-04:00">July
                                        1, 1933—3 p.m.</date>
                                </dateline>
                            </opener>
                            <p>29. Friends telegraph no relief given five prisoners Palma and
                                situation serious. Urge release be expedited.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Phillips</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>