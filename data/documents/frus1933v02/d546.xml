<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-08-29T06:00:00-05:00" frus:doc-dateTime-min="1933-08-29T06:00:00-05:00" n="546" subtype="historical-document" type="document" xml:id="d546">
                            <note rend="inline" type="source">458.11 Dexter and Carpenter/179:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The Minister in Sweden (<persName type="from">Steinhardt</persName>) to the <gloss type="to">Secretary of
                                        State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Stockholm</hi></placeName>, <date calendar="gregorian" when="1933-08-29T12:00:00+01:00">August
                                        29, 1933—noon</date>.<lb/>[Received August 29—10:50
                                    a.m.]</dateline>
                            </opener>
                            <p>23. With reference to Department’s telegram August 28, 4 p.m.,<note n="15" xml:id="d546fn15">Not printed.</note> settlement agreed
                                upon for $150,000. Payment promised September 18th, in no event
                                later than October 1st. Please advise Haight.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Steinhardt</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>