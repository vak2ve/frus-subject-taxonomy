                subtype="historical-document" type="document" xml:id="d507">
                <note rend="inline" type="source">652.116/27: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Spain (<persName type="from"
                            >Bowers</persName>) to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1933-06-10T12:00:00+00:00"
                            >June 10, 1933—noon</date>.<lb/>[Received June 10—11:30 a.m.]</dateline>
                </opener>
                <p>33. Embassy’s despatch number 1189, May 17. Commercial Attaché<note n="26"
                        xml:id="d507fn26">Charles A. Livengood.</note> unofficially informed that
                    Spain is seriously considering granting “benefits” of 30 percent to French
                    automobiles under decree of May 9th.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bowers</hi>
                    </signed>
                </closer>
            </div>
        </body>
