<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-04-19T17:00:00-05:00" frus:doc-dateTime-min="1933-04-19T17:00:00-05:00" n="41" subtype="historical-document" type="document" xml:id="d41">
                            <note rend="inline" type="source">711.4215 Air Pollution/414:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in Canada (<persName type="from">Boal</persName>)</hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1933-04-19T17:00:00-05:00">April
                                        19, 1933—5 p.m.</date>
                                </dateline>
                            </opener>
                            <p>15. Endeavor obtain from Canadian Government answer to inquiry stated
                                in Department’s telegram No. 9 of March 7, 6 p.m., 1933, Trail
                                Smelter.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>