<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-01-04T07:00:00-05:00" frus:doc-dateTime-min="1933-01-04T07:00:00-05:00" n="472" subtype="historical-document" type="document" xml:id="d472">
                            <note rend="inline" type="source">853.116/114: Telegram</note>
                            <head>
                                <hi rend="italic">The Minister in Portugal (<persName type="from">South</persName>) to the <gloss type="to">Secretary of
                                        State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Lisbon</hi></placeName>, <date calendar="gregorian" when="1933-01-04T12:00:00+00:00">January 4, 1933—noon</date>.<lb/>[Received January 4—11:10
                                    a.m.]</dateline>
                            </opener>
                            <p>1. My despatch No. 718, of September 29. Reductions in discriminatory
                                duties of 2 and 4 percent, respectively, conceded by decree of
                                January 2nd, effective that day.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">South</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>