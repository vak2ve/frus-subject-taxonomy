<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-06-21T16:00:00-05:00" frus:doc-dateTime-min="1933-06-21T16:00:00-05:00" n="249" subtype="historical-document" type="document" xml:id="d249">
                            <note rend="inline" type="source">123 Dodd, William Edward/10:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Chargé in Germany (<persName type="from">Gordon</persName>)</hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1933-06-21T17:00:00-04:00">June
                                        21, 1933—5 p.m.</date>
                                </dateline>
                            </opener>
                            <p>73. Ambassador Dodd plans to sail July 5.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Phillips</hi>
                                </signed>
                            </closer>
                        </div>
