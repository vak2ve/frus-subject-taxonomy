<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-12-14T15:00:00-05:00" frus:doc-dateTime-min="1933-12-14T15:00:00-05:00" n="730" subtype="historical-document" type="document" xml:id="d730">
                            <note rend="inline" type="source">882.01 Foreign Control/742:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Chargé in Liberia (<persName type="to">Werlich</persName>)</hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1933-12-14T15:00:00-05:00">December 14, 1933—3 p.m.</date>
                                </dateline>
                            </opener>
                            <p>63. Your telegram No. 97, December 12, noon. We believe that our
                                position has been made so abundantly clear that for the present no
                                further action need be taken.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Phillips</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>