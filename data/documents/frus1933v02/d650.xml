                <note rend="inline" type="source">884.6481 Tsana Dam/369: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Ethiopia (<persName type="to">Southard</persName>)</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-12-22T12:00:00-05:00"
                            >December 22, 1932—noon</date>.</dateline>
                </opener>
                <p>23. Following from White Engineering Corporation: <quote rend="blockquote">
                        <p>“Please accept Emperor’s invitation. Lardner will arrive Addis Ababa
                            January 27th.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
