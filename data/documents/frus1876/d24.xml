        <body>
            <div frus:doc-dateTime-max="1876-07-04T23:59:59-05:00" frus:doc-dateTime-min="1876-07-04T00:00:00-05:00" n="24" subtype="historical-document" type="document" xml:id="d24">
                <head>No. 24.<lb/>
                    <hi rend="italic">The <gloss type="from">Princess Imperial,
                                Regent of Brazil</gloss>, to the <gloss type="to">President</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.—Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de
                                    Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1876-07-04">
                            <hi rend="italic">July</hi> 4, 1876</date>.
                            (Received July 4.)</dateline>
                </opener>
                <p>The Princess Imperial, Regent of Brazil, congratulates herself and the
                        President of the United States of America on the occasion of the centenary
                        of the independence of those States, for whose prosperity she offers sincere
                        prayers.</p>
                <closer>THE PRINCESS IMPERIAL, REGENT.</closer>
            </div>
