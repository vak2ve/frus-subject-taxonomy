    <text>
        <body>
            <div frus:doc-dateTime-max="1875-08-23T23:59:59-05:00" frus:doc-dateTime-min="1875-08-23T00:00:00-05:00" n="287" subtype="historical-document" type="document" xml:id="d287">
                <head>No. 277.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Cushing</persName> to Mr. <persName type="to">Fish</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1875-08-23">
                            <hi rend="italic">August</hi> 23,
                                1875</date>.</dateline>
                </opener>
                <p rend="center">* * * * * * *</p>
                <p>Matter of Burriel is under discussion between minister of state and
                            myself. Copy of note and report of several personal interviews by
                            mail.</p>
                <closer>
                    <signed>CUSHING.</signed>
                </closer>
            </div>
        </body>
