        <body>
            <div frus:doc-dateTime-max="1876-02-17T23:59:59-05:00" frus:doc-dateTime-min="1876-02-17T00:00:00-05:00" n="112" subtype="historical-document" type="document" xml:id="d112">
                <head>No. 102.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Fish</persName> to General <persName type="to">Schenck</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1876-02-17">
                            <hi rend="italic">February</hi> 17,
                                    1876</date>.</dateline>
                </opener>
                <p>Officer, with papers for Winslow’s extradition, sails Saturday.</p>
                <closer>
                    <signed>FISH,<lb/>
                        <hi rend="italic">Secretary</hi>.</signed>
                </closer>
            </div>
        </body>
