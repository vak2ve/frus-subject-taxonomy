    <text>
        <body>
            <div frus:doc-dateTime-max="1876-06-11T23:59:59-05:00"
                frus:doc-dateTime-min="1876-06-11T00:00:00-05:00" n="31"
                subtype="historical-document" type="document" xml:id="d31">
                <head>No. 31.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Gonzalez Errazuriz</persName> to Mr.
                            <persName type="to">Fish</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Chili</hi>,<lb/>
                            <hi rend="italic">Philadelphia</hi>
                        </placeName>, <date calendar="gregorian" when="1876-06-11">
                            <hi rend="italic">June</hi> 11, 1876</date>. (Received June
                        13.)</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor, in the name of the minister, to
                    acknowledge the receipt of your excellency’s communication of the 5th instant,
                    and, in accordance with your desire expressed therein, to inform you that wool,
                    both carded and uncarded, is exempt from all customs duties in Chili, and is
                    imported and exported freely.</p>
                <p>I avail, &amp;c.,</p>
                <closer>
                    <signed>FRANCISCO GONZALEZ ERRAZURIZ.</signed>
                </closer>
            </div>
        </body>
