                <head>No. 281.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Fish</persName> to Mr. <persName
                            type="to">Cushing</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1875-09-22">
                            <hi rend="italic">September</hi> 22, 1875</date>.</dateline>
                    <seg rendition="#left">No. 238]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>:</p>
                <p rend="center">* * * * * * *</p>
                <p>Your proceedings, as set forth in your No. 492, of the 25th ultimo, in regard to
                    the promotion of General Burriel, are approved by this Department.</p>
                <p>I am, &amp;c.,</p>
                <closer>
                    <signed>HAMILTON FISH.</signed>
                </closer>
            </div>
        </body>
