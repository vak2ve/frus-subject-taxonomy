<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1875-11-16T23:59:59-05:00" frus:doc-dateTime-min="1875-11-16T00:00:00-05:00" n="299" subtype="historical-document" type="document" xml:id="d299">
                        <head>No. 289.<lb/><hi rend="italic">Mr. <persName type="from">Cushing</persName> to Mr. <persName type="to">Fish</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Madrid</hi></placeName>, <date calendar="gregorian" when="1875-11-16"><hi rend="italic">November</hi> 16,
                                    1875</date>.</dateline></opener>
                        <p rend="flushleft"><hi rend="smallcaps">Fish</hi>, <hi rend="italic">Secretary, Washington:</hi></p>
                        <p>Spanish note has come in.</p>
                        <p rend="center">* * * * * * *</p>
                        <p>It repeats assurance of trial of Burriel. * * *</p>
                        <p rend="center">* * * * * * *</p>
                        <closer><signed>CUSHING.</signed></closer>
                    </div>
                    </body></text></TEI>