                <head>No. 139.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Hoffman</persName> to Mr. <persName type="to">Fish</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1876-06-01">
                            <hi rend="italic">June</hi> 1,
                                1876</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Fish</hi>, <hi rend="italic">Washington:</hi>
                </p>
                <p>Notified by Lord Derby Winslow case finally adjourned until fifteenth
                            instant.</p>
                <closer>
                    <signed>HOFFMAN.</signed>
                </closer>
            </div>
