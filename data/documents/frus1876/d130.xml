                <head>No. 120.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Fish</persName> to Mr. <persName
                            type="to">Hoffman</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1876-05-02">
                            <hi rend="italic">May</hi> 2, 1876</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Hoffman</hi>, <hi rend="italic">Chargé, London:</hi>
                </p>
                <p>You were not instructed or authorized to make the request stated in your telegram
                    of first.</p>
                <closer>
                    <signed>FISH, <hi rend="italic">Secretary</hi>.</signed>
                </closer>
            </div>
        </body>
