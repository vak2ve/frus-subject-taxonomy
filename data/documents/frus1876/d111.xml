                <head>No. 101.<lb/>
                    <hi rend="italic">General <persName type="from">Schenck</persName> to Mr.
                            <persName type="to">Fish</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1876-02-15">
                            <hi rend="italic">February</hi> 15, 1876</date>.</dateline>
                </opener>
                <p>Winslow arrested. Send charge with proof at once.</p>
                <closer>
                    <signed>SCHENCK.</signed>
                </closer>
            </div>
        </body>
