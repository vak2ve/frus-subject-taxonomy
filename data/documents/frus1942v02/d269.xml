<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1942-04-16T15:00:00-05:00" frus:doc-dateTime-min="1942-04-16T15:00:00-05:00" n="269" subtype="historical-document" type="document" xml:id="d269">
                            <note rend="inline" type="source">740.0011 European War 1939/21085a:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Consul General at Algiers (<persName type="to">Cole</persName>)</hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1942-04-16T16:00:00-04:00">April
                                        16, 1942—4 p.m.</date>
                                </dateline>
                            </opener>
                            <p>104. For Murphy. I am giving consideration to your air mail letter of
                                March 14 which I have just received, and will telegraph you again as
                                soon as possible.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Welles</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>