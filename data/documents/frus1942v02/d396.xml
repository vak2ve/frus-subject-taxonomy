                <note rend="inline" type="source">740.0011 European War 1939/25114: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in France (<persName type="to">Tuck</persName>)</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1942-10-17">October 17,
                            1942</date>.</dateline>
                </opener>
                <p>It is desired that you have no contacts or negotiations with General Giraud.</p>
                <closer>
                    <signed>[<hi rend="smallcaps">Welles</hi>]</signed>
                </closer>
            </div>
        </body>
