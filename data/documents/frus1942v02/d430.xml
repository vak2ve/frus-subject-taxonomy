<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1942-11-09T23:59:59-05:00" frus:doc-dateTime-min="1942-11-09T00:00:00-05:00" n="430" subtype="historical-document" type="document" xml:id="d430">
                            <note rend="inline" type="source">125.1333/326: Telegram</note>
                            <head>
                                <hi rend="italic">The Consul General at Algiers (<persName type="from">Cole</persName>) to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Algiers</hi></placeName>, <date calendar="gregorian" when="1942-11-09">November 9,
                                        1942</date>.<lb/>[Received December 5—7:41 a.m.]</dateline>
                            </opener>
                            <p>3. Entire staff of Consulate General at Algiers safe and well.
                                Individual inquiries indicate all American residents of whom
                                Consulate General has record also safe and well.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Cole</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>