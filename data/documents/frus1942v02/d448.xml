                subtype="historical-document" type="document" xml:id="d448">
                <note rend="inline" type="source">851.01/784: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in the United Kingdom (<persName type="from"
                            >Winant</persName>) to the <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1942-11-18T22:00:00+01:00"
                            >November 18, 1942—10 p.m.</date>
                        <lb/> [Received November 18—9:44 p.m.]</dateline>
                </opener>
                <p>6494. Personal to the Secretary. Re my 6451, November 17, 3 p.m.,<note n="74"
                        xml:id="d448fn74">Not printed.</note> the President’s statement<note n="75"
                        xml:id="d448fn75">For statement released to the press by the White House
                        November 17, 1942, see Department of State <hi rend="italic">Bulletin</hi>,
                        November 21, 1942, p. 935.</note> has cleared the Darlan situation here.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Winant</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
