<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1909-02-25T23:59:59-05:00" frus:doc-dateTime-min="1909-02-25T00:00:00-05:00" n="27" subtype="historical-document" type="document" xml:id="d27">
                            <note rend="inline" type="source">File No. 14040/29.</note>
                            <head><hi rend="italic">Chargé <persName type="from">Wilson</persName>
                                    to the <gloss type="to">Secretary of State</gloss>.</hi></head>
                            <opener><seg rendition="#center">[Telegram—Paraphrase.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Buenos
                                            Aires</hi></placeName> (<hi rend="italic">Received</hi>
                                    <date calendar="gregorian" when="1909-02-25"><hi rend="italic">February 25, 1909</hi></date>).</dateline></opener>
                            <p>Reports that the supreme court has granted the unconditional
                                extradition of Damiano, and that agent and prisoner leave on March
                                10 on steamship <hi rend="italic">Verdi.</hi></p>
                        </div>
                        </body></text></TEI>