                        <note rend="inline" type="source">File No. 534/105.</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Minister <persName type="to">Stutesman.</persName></hi></head>
                        <opener><seg rendition="#center">[Telegram—Pharaphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1909-09-16"><hi rend="italic">September 16,
                                    1909</hi></date>.</dateline></opener>
