    <text>
        <body>
            <div frus:doc-dateTime-max="1909-05-01T23:59:59-05:00"
                frus:doc-dateTime-min="1909-05-01T00:00:00-05:00" n="548"
                subtype="historical-document" type="document" xml:id="d548">
                <note rend="inline" type="source">File No. 10044/157.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Chargé <persName type="to">Carter</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1909-05-01">
                            <hi rend="italic">May 1, 1909</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 984.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The department desires you to make appropriate
                    formal expression of thanks to the British Government, on the part of this
                    Government, for the friendly action of His Majesty’s Government in instructing
                    British naval vessels in Turkish waters to afford the same protection to
                    American citizens as to British subjects in the disturbed regions of Asiatic
                    Turkey, pending the arrival of the armored cruisers which this Government has
                    dispatched to Alexandretta and Mersine.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Huntington Wilson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
