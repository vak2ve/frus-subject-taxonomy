                subtype="historical-document" type="document" xml:id="d345">
                <note rend="inline" type="source">File No. 6775/622.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Secretary of the First Central American
                            Conference</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1909-01-04">
                            <hi rend="italic">January 4, 1909</hi>
                        </date>.</dateline>
                </opener>
                <p>Accept my greetings and good wishes for yourself and members of the
                    conference.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Elihu Root.</hi>
                    </signed>
                </closer>
            </div>
        </body>
