    <text>
        <body>
            <div frus:doc-dateTime-max="1909-04-30T23:59:59-05:00"
                frus:doc-dateTime-min="1909-04-30T00:00:00-05:00" n="512"
                subtype="historical-document" type="document" xml:id="d512">
                <note rend="inline" type="source">File No. 48/93A.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Ide</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1909-04-30">
                            <hi rend="italic">April 30, 1909</hi>
                        </date>.</dateline>
                </opener>
                <p>For your information and for immediate communication to the Spanish Government I
                    quote the following letter of notification addressed to-day to the Spanish
                    minister here:<note n="1" xml:id="d512fn1">Supra.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wilson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
