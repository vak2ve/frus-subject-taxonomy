<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1909-04-18T23:59:59-05:00" frus:doc-dateTime-min="1909-04-18T00:00:00-05:00" n="609" subtype="historical-document" type="document" xml:id="d609">
                        <note rend="inline" type="source">File No. 14457/69.</note>
                        <head><hi rend="italic">Minister <persName type="from">Russell</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram—Extract.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Caracas</hi></placeName>, <date calendar="gregorian" when="1909-04-18"><hi rend="italic">April 18,
                                1909</hi></date>.</dateline></opener>
                        <p>Minister for foreign affairs informs me that diplomatic relations have
                            been resumed with the Netherlands.</p>
                        <closer><signed><hi rend="smallcaps">Russell.</hi></signed></closer>
                    </div>
                    </body></text></TEI>