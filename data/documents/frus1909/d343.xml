                subtype="historical-document" type="document" xml:id="d343">
                <note rend="inline" type="source">File No. 6775/619.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Honduranean Minister for Foreign
                            Affairs</gloss> to the <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1909-01-02">
                            <hi rend="italic">January 2, 1909</hi>
                        </date>.</dateline>
                </opener>
                <p>Respectfully greeting your excellency on this day, I have the honor to inform you
                    of opening First Central American Conference this day.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">E. Constantino Fiallos.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
