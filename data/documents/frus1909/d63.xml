    <text>
        <body>
            <div frus:doc-dateTime-max="1909-05-19T23:59:59-05:00"
                frus:doc-dateTime-min="1909-05-19T00:00:00-05:00" n="63"
                subtype="historical-document" type="document" xml:id="d63">
                <note rend="inline" type="source">File No. 5072/42.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Turkish Ambassador</gloss> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Imperial Ottoman Embassy</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1909-05-19">
                            <hi rend="italic">May 19, 1909</hi>
                        </date>.</dateline>
                </opener>
                <p>Mr. <hi rend="smallcaps">Secretary of State</hi>: I have the honor to advise your
                    excellency that His Excellency Rifaat Pasha, minister of foreign affairs,
                    exchanged to-day with the Bulgarian delegate the protocol by which we recognize
                    the new political State of Bulgaria.</p>
                <p>Be pleased, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">H. Kiazim.</hi>
                    </signed>
                </closer>
            </div>
        </body>
