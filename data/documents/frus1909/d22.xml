                <note rend="inline" type="source">File No. 14040/11.</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Eddy</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1908-09-24">
                            <hi rend="italic">September 24, 1908</hi>
                        </date>.</dateline>
                </opener>
                <p>Damiano extradition granted. Agent expects to leave October 10, steamship <hi
                        rend="italic">Velasquez.</hi>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Eddy.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
