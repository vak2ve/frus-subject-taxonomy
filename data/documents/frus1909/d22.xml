<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1908-09-24T23:59:59-05:00" frus:doc-dateTime-min="1908-09-24T00:00:00-05:00" n="22" subtype="historical-document" type="document" xml:id="d22">
                            <note rend="inline" type="source">File No. 14040/11.</note>
                            <head><hi rend="italic">Minister <persName type="from">Eddy</persName>
                                    to the <gloss type="to">Secretary of State</gloss>.</hi></head>
                            <opener><seg rendition="#center">[Telegram.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Buenos
                                            Aires</hi></placeName>, <date calendar="gregorian" when="1908-09-24"><hi rend="italic">September 24,
                                        1908</hi></date>.</dateline></opener>
                            <p>Damiano extradition granted. Agent expects to leave October 10,
                                steamship <hi rend="italic">Velasquez.</hi></p>
                            <closer><signed><hi rend="smallcaps">Eddy.</hi></signed></closer>
                        </div>
                        </body></text></TEI>