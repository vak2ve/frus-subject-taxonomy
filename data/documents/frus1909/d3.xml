                subtype="historical-document" type="document" xml:id="d3">
                <note rend="inline" type="source">File No. 19632.</note>
                <head>[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1909-06-21">
                            <hi rend="italic">June 21, 1909</hi>
                        </date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="italic">To the diplomatic and consular officers of the United
                        States.</hi>
                </p>
                <p>
                    <hi rend="smallcaps">Gentlemen</hi>: Kef erring to the circular instruction of
                    April 19, 1907, in regard to the registration of American citizens, you are
                    hereby instructed to insert in both the register and the certificate of
                    registration the local address of the person registering and the name and
                    address of the nearest relative in America with whom it would be necessary to
                    communicate in the event of any serious accident to or death of the person
                    registered.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Huntington Wilson</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
