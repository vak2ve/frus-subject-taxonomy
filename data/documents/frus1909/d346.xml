                subtype="historical-document" type="document" xml:id="d346">
                <note rend="inline" type="source">File No. 6775/626.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of the First Central American
                            Conference</gloss> to the <gloss type="to">Secretary of
                        State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1909-01-13">
                            <hi rend="italic">January 13, 1909</hi>
                        </date>.</dateline>
                </opener>
                <p>Delegates Tegucigalpa Conference thankfully acknowedge your excellency’s good
                    offices and take pleasure in announcing to you that they are continuing their
                    labors.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Aguirre Munoz.</hi>
                    </signed>
                </closer>
            </div>
        </body>
