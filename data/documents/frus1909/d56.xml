                <note rend="inline" type="source">File No. 2372/30.</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Dudley</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">Rio</hi>
                        </placeName>, <date calendar="gregorian" when="1909-06-14">
                            <hi rend="italic">June 14, 1909</hi>
                        </date>.</dateline>
                </opener>
                <p>President Penna died this morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dudley.</hi>
                    </signed>
                </closer>
            </div>
        </body>
