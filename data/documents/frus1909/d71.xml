    <text>
        <body>
            <div frus:doc-dateTime-max="1909-02-13T23:59:59-05:00"
                frus:doc-dateTime-min="1909-02-13T00:00:00-05:00" n="71"
                subtype="historical-document" type="document" xml:id="d71">
                <note rend="inline" type="source">File No. 15077/58.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Minister <persName type="to">Hicks.</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1909-02-13">
                            <hi rend="italic">February 13, 1909</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 152.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: There is inclosed herewith a copy of a note<note
                        n="1" xml:id="d71fn1">Supra.</note> received by the department from the
                    Chinese minister, expressing the appreciation of his Government of the
                    arrangements made in Chile and other countries for the protection of Chinese
                    subjects by American diplomatic and consular officers.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Bacon.</hi>
                    </signed>
                </closer>
            </div>
        </body>
