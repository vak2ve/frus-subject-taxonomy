            <div frus:doc-dateTime-max="1947-08-08T09:00:00-05:00" frus:doc-dateTime-min="1947-08-08T09:00:00-05:00" n="345" subtype="historical-document" type="document" xml:id="d345">
                <note rend="inline" type="source">740.0011 EW (Peace)/8–847: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Hungary</hi> (<persName type="from">
                        <hi rend="italic">Chapin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">confidential</hi>
                        <lb/>
                        <hi rend="smallcaps">priority</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Budapest</hi>
                        </placeName>, <date calendar="gregorian" when="1947-08-08T16:00:00+02:00">August 8, 1947—4 p. m.</date>
                    </dateline>
                </opener>
                <p>1332. President Tildy signed legislation ratifying peace treaty August 7.</p>
                <p>Sent Department, repeated London 139, Moscow 131.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Chapin</hi>
                    </signed>
                </closer>
            </div>
