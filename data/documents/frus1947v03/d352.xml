            <div frus:doc-dateTime-max="1947-08-26T23:59:59-05:00" frus:doc-dateTime-min="1947-08-26T00:00:00-05:00" n="352" subtype="historical-document" type="document" xml:id="d352">
                <note rend="inline" type="source">740.0011 EW (Peace)/8–2647: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Yugoslavia</hi> (<persName type="from">
                        <hi rend="italic">Cannon</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Belgrade</hi>
                        </placeName>, <date calendar="gregorian" when="1947-08-26">August 26,
                            1947</date>.</dateline>
                </opener>
                <p>977. Tanjug officially announces ratification by praesidium of Peace Treaties
                    with Italy, Bulgaria and Hungary.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cannon</hi>
                    </signed>
                </closer>
            </div>
        </body>
