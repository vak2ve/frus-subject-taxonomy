    <teiHeader><fileDesc><titleStmt><title>The Ambassador in France (
                        Caffery
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1947v03</bibl><bibl type="frus-document-id">d159</bibl><bibl type="frus-document-number">159</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1947-06-23T05:00:00-05:00" notAfter="1947-06-23T05:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1947-06-23T05:00:00-05:00" frus:doc-dateTime-min="1947-06-23T05:00:00-05:00" n="159" subtype="historical-document" type="document" xml:id="d159">
                <note rend="inline" type="source">840.00/6–2347: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Caffery</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                        <lb/>
                        <hi rend="smallcaps">urgent</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1947-06-23T11:00:00+01:00">June 23, 1947—11 a. m.</date>
                    </dateline>
                </opener>
                <p>2481. Chauvel<note n="1" xml:id="d159fn1">Jean Chauvel, Secretary General of the
                        French Foreign Office.</note> informs me that Molotov has accepted
                    invitation of Bidault and Bevin to discuss the proposals set forth in
                    Secretary’s Harvard speech and that he will come to Paris next Friday, June 27,
                    for discussions.</p>
                <p>Sent to Department as 2481; repeated London 468, Moscow 379.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caffery</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
