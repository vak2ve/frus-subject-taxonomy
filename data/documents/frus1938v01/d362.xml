                subtype="historical-document" type="document" xml:id="d362">
                <note rend="inline" type="source">711.00111 Unlawful Shipments/211: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Turkey</hi> (<persName type="to">
                        <hi rend="italic">MacMurray</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1938-06-23T19:00:00-04:00"
                            >June 23, 1938—7 p.m.</date>
                    </dateline>
                </opener>
                <p>63. Your No. 26, June 20, 10 a.m. There is no objection to the publication of the
                    documents.</p>
                <pb facs="0361" n="353" xml:id="pg_353"/>
                <p>Our records indicate that the planes mentioned as having been found by the
                    insurgents on a Norwegian vessel could not have been shipped from this
                    country.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
