                subtype="historical-document" type="document" xml:id="d265">
                <note rend="inline" type="source">138 Spain/932: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Counselor of Embassy in Spain</hi> (<persName type="to">
                        <hi rend="italic">Thurston</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1938-05-17T19:00:00-04:00"
                            >May 17, 1938—7 p.m.</date>
                    </dateline>
                </opener>
                <p>442. Consulate’s 16th re passports. You are authorized in your discretion take up
                    matter with Ministry of State and to take any other action which might result in
                    recovery of any of passports.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
