<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1938-09-12T04:00:00-05:00" frus:doc-dateTime-min="1938-09-12T04:00:00-05:00" n="861" subtype="historical-document" type="document" xml:id="d861">
                    <note rend="inline" type="source">500.C111/1068: Telegram</note>
                    <head><hi rend="italic">The Minister in Switzerland</hi> (<persName type="from"><hi rend="italic">Harrison</hi></persName>) <hi rend="italic">to
                            the <gloss type="to">Secretary of State</gloss></hi></head>
                    <opener>
                        <dateline rendition="#right"><placeName><hi rend="smallcaps">Geneva</hi></placeName>, <date calendar="gregorian" when="1938-09-12T10:00:00+01:00">September 12, 1938—10
                            a.m.</date><lb/>[Received September 12—6:35 a.m.]</dateline>
                    </opener>
                    <p>1092. Avenol<note n="5" xml:id="d861fn5">Joseph Avenol, Secretary General of
                            the League of Nations.</note> informs me in confidence that as now
                        planned and in order to avoid embarrassment item 27 on the agenda concerning
                            <pb facs="0897" n="889" xml:id="pg_889"/> bombing from the air will be
                        referred to the Bureau of Disarmament conference.</p>
                    <closer><signed><hi rend="smallcaps">Harrison</hi></signed></closer>
                </div>
                </body></text></TEI>