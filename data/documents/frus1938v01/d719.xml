                subtype="historical-document" type="document" xml:id="d719">
                <note rend="inline" type="source">840.48 Refugees/227: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from">
                        <hi rend="italic">Phillips</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1938-05-11T18:00:00+01:00"
                            >May 11, 1938—6 p.m.</date>
                        <lb/>[Received May 11—2:25 p.m.]</dateline>
                </opener>
                <p>105. Myron Taylor<note n="8" xml:id="d719fn8">Mr. Taylor had sailed for Europe on
                        April 30.</note> asks me to say that he awaits further information and
                    instructions.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
