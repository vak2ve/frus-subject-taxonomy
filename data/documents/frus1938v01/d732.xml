                subtype="historical-document" type="document" xml:id="d732">
                <note rend="inline" type="source">840.48 Refugees/445: Telegram (part air)</note>
                <head>
                    <hi rend="italic">The Minister in Denmark</hi> (<persName type="from">
                        <hi rend="italic">Owsley</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Copenhagen</hi>
                        </placeName>, <date calendar="gregorian" when="1938-07-02T13:00:00+01:00"
                            >July 2, 1938—1 p.m.</date>
                        <lb/>[Received July 4—6:28 a.m.]</dateline>
                </opener>
                <p>24. My telegram No. 14, April 5, noon.<note n="19" xml:id="d732fn19">Not
                        printed.</note> Government of Iceland regrets that it cannot participate in
                    the conference regarding political refugees. Embassy at Paris informed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Owsley</hi>
                    </signed>
                </closer>
            </div>
        </body>
