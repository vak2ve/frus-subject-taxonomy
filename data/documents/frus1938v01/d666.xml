                subtype="historical-document" type="document" xml:id="d666">
                <note rend="inline" type="source">760F.62/1199: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Bullitt</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1938-09-28T16:00:00+01:00"
                            >September 28, 1938—4 p.m.</date>
                        <lb/>[Received September 28—11:15 a.m.]</dateline>
                </opener>
                <p>1626. I am informed by the Foreign Office that Mussolini has invited Hitler,
                    Daladier and Chamberlain to meet him in Munich.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bullitt</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
