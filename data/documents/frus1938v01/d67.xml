                subtype="historical-document" type="document" xml:id="d67">
                <note rend="inline" type="source">751.62/500: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in France</hi> (<persName type="from">
                        <hi rend="italic">Wilson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1938-11-26T13:00:00+00:00"
                            >November 26, 1938—1 p.m.</date>
                        <lb/>[Received November 26—10:30 a.m.]</dateline>
                </opener>
                <p>2001. Personal for the Under Secretary. Reference to my telegram No. 1994,
                    November 25, 7 p.m. Bonnet asked me to send you a personal word of his hope that
                    you would understand and sympathize with the reasons which moved him to conclude
                    the declaration with Germany.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wilson</hi>
                    </signed>
                </closer>
            </div>
        </body>
