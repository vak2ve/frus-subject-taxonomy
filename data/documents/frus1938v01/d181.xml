                subtype="historical-document" type="document" xml:id="d181">
                <note rend="inline" type="source">852.00/8215: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from">
                        <hi rend="italic">Phillips</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1938-07-07T19:00:00+01:00"
                            >July 7, 1938—7 p.m.</date>
                        <lb/>[Received July 7—4 p.m.]</dateline>
                </opener>
                <p>169. My telegram 160, June 29, noon. The British Ambassador informs me he has
                    received a telegram from his Government stating that since his representations
                    to Ciano on June 28 there have been no attacks whatsoever on British ships by
                    Franco’s forces.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
