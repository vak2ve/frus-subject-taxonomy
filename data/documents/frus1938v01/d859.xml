<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1938-05-11T13:00:00-05:00" frus:doc-dateTime-min="1938-05-11T13:00:00-05:00" n="859" subtype="historical-document" type="document" xml:id="d859">
                    <note rend="inline" type="source">500.C112/1345: Telegram</note>
                    <head><hi rend="italic">The Minister in Switzerland</hi> (<persName type="from"><hi rend="italic">Harrison</hi></persName>) <hi rend="italic">to
                            the <gloss type="to">Secretary of State</gloss></hi></head>
                    <opener>
                        <dateline rendition="#right"><placeName><hi rend="smallcaps">Geneva</hi></placeName>, <date calendar="gregorian" when="1938-05-11T19:00:00+01:00">May 11, 1938—7
                            p.m.</date><lb/>[Received May 11—2:45 p.m.]</dateline>
                    </opener>
                    <p>1091. Reference 1090, January 29, 11 a.m. The Council today decided that the
                        Bureau should meet during the session of the Assembly in September, the
                        exact date to be fixed by the Secretary General.</p>
                    <closer><signed><hi rend="smallcaps">Harrison</hi></signed></closer>
                </div>
                </body></text></TEI>