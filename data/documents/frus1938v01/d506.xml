                subtype="historical-document" type="document" xml:id="d506">
                <note rend="inline" type="source">760F.62/265: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Bullitt</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1938-05-17T13:00:00+01:00"
                            >May 17, 1938—1 p.m.</date>
                        <lb/>[Received May 17—8:10 a.m.]</dateline>
                </opener>
                <p>777. Personal for the Secretary. The Czechoslovakian situation is so critical
                    that while I will concede there is an excellent chance of a peaceful settlement,
                    I nevertheless believe the Department should be prepared to face a major
                    European war before August 15.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bullitt</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
