    <text>
        <body>
            <div frus:doc-dateTime-max="1938-07-01T03:00:00-05:00"
                frus:doc-dateTime-min="1938-07-01T03:00:00-05:00" n="368"
                subtype="historical-document" type="document" xml:id="d368">
                <note rend="inline" type="source">711.00111 Unlawful Shipments/223: Telegram</note>
                <head>
                    <hi rend="italic">The Counselor of Embassy in Spain</hi> (<persName type="from">
                        <hi rend="italic">Thurston</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Barcelona</hi>
                        </placeName>, <date calendar="gregorian" when="1938-07-01T10:00:00+02:00"
                            >July 1, 1938—10 a.m.</date>
                        <lb/>[Received July 1—8:35 a.m.]</dateline>
                </opener>
                <p>996. My 986.<note n="30" xml:id="d368fn30">June 23, 5 p.m., <ref target="#pg_352"
                            >p. 352</ref>.</note> Mr. Krieger<note n="31" xml:id="d368fn31">William
                        Krieger, clerk in the American Embassy in Spain.</note> has ascertained from
                    a member of the Spanish Air Force that about 40 Grumman planes are now here.
                    Also that an [unknown?] number of Northrop monoplanes of a new model have just
                    arrived.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Thurston</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
