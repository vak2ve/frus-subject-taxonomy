                subtype="historical-document" type="document" xml:id="d864">
                <note rend="inline" type="source">500.A15A4 Steering Committee/592: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Switzerland</hi> (<persName type="from">
                        <hi rend="italic">Harrison</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Geneva</hi>
                        </placeName>, <date calendar="gregorian" when="1938-09-30T18:00:00+01:00"
                            >September 30, 1938—6 p.m.</date>
                        <lb/>[Received September 30—2:50 p.m.]</dateline>
                </opener>
                <p>1101. Reference my 1098, September 27, 5 p.m. second paragraph. Council in
                    private meeting this afternoon authorized Secretary General to call meeting of
                    the Bureau at a more propitious time.<note n="9" xml:id="d864fn9">No further
                        meeting of the Bureau of the Disarmament Conference was called.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Harrison</hi>
                    </signed>
                </closer>
            </div>
        </body>
