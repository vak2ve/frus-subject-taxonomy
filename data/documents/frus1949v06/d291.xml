<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-04-21T23:59:59-05:00" frus:doc-dateTime-min="1949-04-21T00:00:00-05:00" n="291" subtype="historical-document" type="document" xml:id="d291">
                            <note rend="inline" type="source">891.032/4–2149: Telegram</note>
                            <head>
                                <hi rend="italic">The Ambassador in Iran</hi> (<persName type="from"><hi rend="italic">Wiley</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <dateline>
                                <placeName>
                                    <hi rend="smallcaps">Tehran</hi></placeName>, <date calendar="gregorian" when="1949-04-21">April 21,
                                1949</date>.</dateline>
                            <p>539. Constituent Assembly was convened today by Shah with brief
                                opening address.<note n="1" xml:id="d291fn1">The Majlis passed
                                    legislation creating a Senate by a voice vote on May 4 (telegram
                                    607, May 5, from Tehran, 891.032/5–549).</note>
                            </p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Wiley</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>