                    <term ref="reczUgzr2M4lUGdR7" type="topic" category="foreign-economic-policy" subcategory="economic-sanctions" subject="embargo" lcsh-uri="http://id.loc.gov/authorities/subjects/sh85042665" lcsh-match="exact">Embargo</term>
