                <note rend="inline" type="source">393.1123 Winterle/7: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Johnson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1935-09-27T14:00:00-04:00"
                            >September 27, 1935—2 p.m.</date>
                    </dateline>
                </opener>
                <p>7. Your 17, September 26, 3 p.m. Department suggests for consideration that you
                    repeat to Chefoo the last paragraph of your telegram under reference.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
