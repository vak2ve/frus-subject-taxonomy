    <text>
        <body>
            <div frus:doc-dateTime-max="1935-05-04T02:00:00-05:00"
                frus:doc-dateTime-min="1935-05-04T02:00:00-05:00" n="115"
                subtype="historical-document" type="document" xml:id="d115">
                <note rend="inline" type="source">661.9331/23: Telegram</note>
                <head>
                    <hi rend="italic">The Second Secretary of Legation in China</hi> (<persName
                        type="from">
                        <hi rend="italic">Atcheson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1935-05-04T15:00:00+08:00"
                            >May 4, 1935—3 p.m.</date>
                        <lb/>[Received May 4—11:41 a.m.]</dateline>
                </opener>
                <p>95. Nanking office understands that Soviet Ambassador recently returned to China
                    from Moscow will next week begin discussions with <pb facs="0267" n="155"
                        xml:id="pg_155"/> Chinese Foreign Office looking to new commercial and
                    possibly a nonaggression treaty with China.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Atcheson</hi>
                    </signed>
                </closer>
            </div>
        </body>
