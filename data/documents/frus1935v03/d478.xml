                subtype="historical-document" type="document" xml:id="d478">
                <note rend="inline" type="source">701.9493/88: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Japan</hi> (<persName type="to">
                        <hi rend="italic">Grew</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1935-05-14T19:00:00-04:00"
                            >May 14, 1935—7 p.m.</date>
                    </dateline>
                </opener>
                <p>80. Your 101, May 9, noon.</p>
                <list>
                    <label>1.</label>
                    <item>Please inform the Ministry of Foreign Affairs orally and informally that
                        the American Government is proceeding to exchange views on the question of
                        raising the status of diplomatic missions in China with other governments
                        which have been informed by the Japanese Government of its decision in the
                        matter; that the American Government, upon completion of its consideration
                        of the matter, will expect to communicate further with the Japanese
                        Government and that the American Government appreciates the courtesy of the
                            <pb facs="0624" n="512" xml:id="pg_512"/> Japanese Government in giving
                        advance notice of its decision and in affording opportunity for simultaneous
                        action.</item>
                    <label>2.</label>
                    <item>For your information, reports appeared in the American press under Tokyo
                        date line May 11 in regard to the Japanese Government’s decision.</item>
                    <label>3.</label>
                    <item>Repeat to Peiping as Department’s No. 130.</item>
                </list>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
