                subtype="historical-document" type="document" xml:id="d677">
                <note rend="inline" type="source">393.1111 Bush, Henry J./1: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Swatow</hi> (<persName type="from">
                        <hi rend="italic">Hinke</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Swatow</hi>
                        </placeName>, <date calendar="gregorian" when="1935-05-10T12:00:00+08:00"
                            >May 10, 1935—noon</date>.<lb/>[Received 5:55 p.m.]</dateline>
                </opener>
                <p>The following to the Legation: <quote rend="blockquote">
                        <p>I have been informed of the disappearance of Father Henry James Bush,
                            American Catholic priest of Maryknoll, New York, Mission while traveling
                            out of Kaying, Kwangtung. Representations have been made to the local
                            authorities and the mission will keep me informed. He is thought to be
                            in the hands of bandits; Father Hilbert investigating on behalf of the
                            mission.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hinke</hi>
                    </signed>
                </closer>
            </div>
        </body>
