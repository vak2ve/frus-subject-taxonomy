                subtype="historical-document" type="document" xml:id="d862">
                <note rend="inline" type="source">893.6363 Manchuria/139: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Japan</hi> (<persName type="to">
                        <hi rend="italic">Grew</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1935-02-23T13:00:00-05:00"
                            >February 23, 1935—1 p.m.</date>
                    </dateline>
                </opener>
                <p>23. Your 36, February 21, 7 p.m. Following message (paraphrased by the
                    Department) for special representative of American oil company.</p>
                <quote rend="blockquote">
                    <p>“Your views have the support of all parties concerned. Dundas.”</p>
                </quote>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
