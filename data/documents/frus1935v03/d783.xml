<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-02-21T18:00:00-05:00" frus:doc-dateTime-min="1935-02-21T18:00:00-05:00" n="783" subtype="historical-document" type="document" xml:id="d783">
                        <note rend="inline" type="source">893.6359 Antimony/15: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Counselor of Legation in China</hi> (<persName type="to"><hi rend="italic">Gauss</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1935-02-21T18:00:00-05:00">February 21, 1935—6
                                p.m.</date></dateline>
                        </opener>
                        <p>46. Your 75, February 15, 9 a.m.</p>
                        <list>
                            <label>1.</label>
                            <item>Department assumes that as opportunity offers the Legation will
                                continue in its endeavors to follow the suggestion outlined in the
                                Department’s telegram 24 of January 25, 7 p.m.</item>
                            <label>2.</label>
                            <item>Department also assumes that the Legation has acted in accordance
                                with the suggestion made in paragraph 2 of the Department’s telegram
                                37 of February 6, 5 p.m., and that when practicable the Legation
                                will telegraph the result of its action.</item>
                        </list>
                        <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                    </div>
                    </body></text></TEI>