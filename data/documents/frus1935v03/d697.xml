                subtype="historical-document" type="document" xml:id="d697">
                <note rend="inline" type="source">893.00/13244: Telegram</note>
                <head>
                    <hi rend="italic">The Counselor of Embassy in China</hi> (<persName type="from">
                        <hi rend="italic">Lockhart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1935-10-29T12:00:00+08:00"
                            >October 29, 1935—noon</date>.<lb/>[Received October 29—9:15
                        a.m.]</dateline>
                </opener>
                <p>101. Following telegram has been received from the Ambassador at Shanghai.</p>
                <quote rend="blockquote">
                    <p>“October 28, 4 p.m. Reference Hankow’s October 26, noon, and October 27, 11
                        a.m. regarding condition in Tatsienlu. I have today addressed note to
                        Foreign Office requesting protection of Americans in area.”</p>
                </quote>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lockhart</hi>
                    </signed>
                </closer>
            </div>
        </body>
