                subtype="historical-document" type="document" xml:id="d418">
                <note rend="inline" type="source">793.94/7456: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1935-11-30T16:00:00+08:00"
                            >November 30, 1935—4 p.m.</date>
                        <lb/>[Received November 30—6:51 a.m.]</dateline>
                </opener>
                <p>189. According to American military authorities, 10 trains of Japanese troops
                    arrived at Shanhaikwan this morning from the north.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
