    <text>
        <body>
            <div frus:doc-dateTime-max="1935-11-01T17:00:00-05:00"
                frus:doc-dateTime-min="1935-11-01T17:00:00-05:00" n="343"
                subtype="historical-document" type="document" xml:id="d343">
                <note rend="inline" type="source">893.00/13248: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Second Secretary of Embassy in China</hi> (<persName type="to">
                        <hi rend="italic">Atcheson</hi>
                    </persName>), <hi rend="italic">at Nanking</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1935-11-01T17:00:00-05:00"
                            >November 1, 1935—5 p.m.</date>
                    </dateline>
                </opener>
                <p>15. Your 45, November 1, noon.</p>
                <list>
                    <label>1.</label>
                    <item>Please convey to the Acting Minister for Foreign Affairs a message from
                        the Acting Secretary of State as follows: <quote rend="blockquote">
                            <p>“I have been shocked by the reports of the attempt upon your life and
                                upon the lives of other officials of the Chinese Government, and
                                extend an expression of my sympathy and of my hope for your and
                                their early and complete recovery.”</p>
                        </quote>
                    </item>
                    <label>2.</label>
                    <item>Department assumes that the Embassy has already expressed to the Chinese
                        Foreign Office in appropriate terms and without referring to the authorship
                        of the outrage its sympathy.</item>
                </list>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
