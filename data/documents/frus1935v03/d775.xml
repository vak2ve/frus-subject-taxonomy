                subtype="historical-document" type="document" xml:id="d775">
                <note rend="inline" type="source">893.6359 Antimony/11: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in China</hi> (<persName type="to">
                        <hi rend="italic">Johnson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1935-01-21T14:00:00-05:00"
                            >January 21, 1935—2 p.m.</date>
                    </dateline>
                </opener>
                <p>14. Your despatch 3195, December 17.<note n="53" xml:id="d775fn53">See footnote
                        48, <ref target="#pg_767">p. 767</ref>.</note>
                </p>
                <list>
                    <label>1.</label>
                    <item>Please report existing situation in regard to Hunan antimony
                        monopoly.</item>
                    <label>2.</label>
                    <item>If Foreign Office has failed to reply adequately to Legation’s note of
                        December 12, Department suggests that matter again be pressed.</item>
                </list>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
