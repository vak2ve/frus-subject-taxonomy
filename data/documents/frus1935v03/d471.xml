    <text>
        <body>
            <div frus:doc-dateTime-max="1935-12-27T04:00:00-05:00"
                frus:doc-dateTime-min="1935-12-27T04:00:00-05:00" n="471"
                subtype="historical-document" type="document" xml:id="d471">
                <note rend="inline" type="source">793.94/7578: Telegram</note>
                <head>
                    <hi rend="italic">The Second Secretary of Embassy in China</hi> (<persName
                        type="from">
                        <hi rend="italic">Atcheson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1935-12-27T17:00:00+08:00"
                            >December 27, 1935—5 p.m.</date>
                        <lb/>[Received December 27—12:35 p.m.]</dateline>
                </opener>
                <p>157. My 155, December 27, 3 p.m.<note n="87" xml:id="d471fn87">Not
                        printed.</note> I am reliably informed that after discussions with the
                    Government representatives the Shanghai students at Wusih entrained for Shanghai
                    at 3 o’clock this afternoon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Atcheson</hi>
                    </signed>
                </closer>
            </div>
        </body>
