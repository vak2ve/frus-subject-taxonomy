    <text>
        <body>
            <div frus:doc-dateTime-max="1935-10-14T08:00:00-05:00"
                frus:doc-dateTime-min="1935-10-14T08:00:00-05:00" n="692"
                subtype="historical-document" type="document" xml:id="d692">
                <note rend="inline" type="source">893.512/1431: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1935-10-14T21:00:00+08:00"
                            >October 14, 1935—9 p.m.</date>
                        <lb/>[Received October 14—10:30 a.m.]</dateline>
                </opener>
                <p>58. Embassy’s 55, October 14 noon. U. S. S. <hi rend="italic">Asheville</hi> at
                    Canton has been ordered to proceed immediately to Swatow and should arrive at
                    Swatow tomorrow morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
