                subtype="historical-document" type="document" xml:id="d755">
                <note rend="inline" type="source">893.114 Narcotics/1240: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1935-08-09T17:00:00+08:00"
                            >August 9, 1935—5 p.m.</date>
                        <lb/>[Received August 9—10:12 a.m.]</dateline>
                </opener>
                <p>409. Department’s 230, August 1, 2 p.m. Nanking reports that an official of the
                    Department of International Affairs of the Ministry of Foreign Affairs states
                    that the new system of import permits for narcotic drugs became effective June
                    4, 1935.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
