                subtype="historical-document" type="document" xml:id="d636">
                <note rend="inline" type="source">711.62114A/9–1444: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Sweden</hi> (<persName type="to">
                        <hi rend="italic">Johnson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1944-09-14T12:00:00-04:00"
                            >September 14, 1944—noon.</date>
                    </dateline>
                </opener>
                <p>1834. Please inform Boheman<note n="63" xml:id="d636fn1">Erik C. Boheman,
                        Secretary General of the Swedish Ministry for Foreign Affairs.</note> that
                    this Government expects the immediate release from internment of one American
                    airman for each German soldier offered the choice either of remaining in Sweden
                    or returning to Germany (third paragraph your 3566, September 8, 10 PM<note
                        n="64" xml:id="d636fn2">Not printed.</note>).</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
