                subtype="historical-document" type="document" xml:id="d399">
                <note rend="inline" type="source">740.0011 European War 1939/34391: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Spain</hi> (<persName type="to">
                        <hi rend="italic">Hayes</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1944-05-30T19:00:00-04:00"
                            >May 30, 1944—7 p.m.</date>
                    </dateline>
                </opener>
                <p>1549. Algiers 1744, May 27, 4 p.m., repeated by courier to Madrid and Tangier.
                    Please concert action with your British colleague<note n="34" xml:id="d399fn1"
                        >Sir Samuel Hoare.</note> and make firm representations urgently.</p>
                <p>Sent to Madrid, repeated to Algiers and Tangier.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
