                subtype="historical-document" type="document" xml:id="d577">
                <note rend="inline" type="source">740.00112 European War 1939/8–2144:
                    Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Sweden</hi> (<persName type="to">
                        <hi rend="italic">Johnson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1944-08-22T13:00:00-04:00"
                            >August 22, 1944—1 p.m.</date>
                    </dateline>
                </opener>
                <p>1676. Your 3217, August 21. Provided British concur we agree to Madame
                    Kollontay’s suggested amendment to joint message.</p>
                <p>Sent to Stockholm, repeated to London as No. 6671 of August 22, 1 p.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
