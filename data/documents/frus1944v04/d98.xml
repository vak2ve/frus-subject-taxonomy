                subtype="historical-document" type="document" xml:id="d98">
                <note rend="inline" type="source">811.20 Defense (M) Portugal/1434a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Portugal</hi> (<persName type="to">
                        <hi rend="italic">Norweb</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1944-02-24T11:00:00-04:00"
                            >February 24, 1944—11 a.m.</date>
                    </dateline>
                </opener>
                <p>539. Department and FEA indorse your suggestion that in company with your British
                    colleague you now approach Salazar with a request for a temporary embargo on
                    wolfram exports.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stettinius</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
