<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-06-15T03:30:00-05:00" frus:doc-dateTime-min="1943-06-15T03:30:00-05:00" n="248" subtype="historical-document" type="document" xml:id="d248">
                        <note rend="inline" type="source">845.00/1981: Telegram</note>
                        <head>
                            <hi rend="italic">The Officer in Charge at New Delhi</hi> (<persName type="from"><hi rend="italic">Merrell</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">New Delhi</hi></placeName>, <date calendar="gregorian" when="1943-06-15T15:00:00+06:30">June 15,
                                    1943—3 p.m.</date>
                                <lb/> [Received June 16—3:42 a.m.]</dateline>
                        </opener>
                        <p>403. Nehru’s sister, Mrs. Pandit, and his daughter Mrs. Indira Gandhi who
                            were ill are reported to have been released unconditionally from
                            jail.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Merrell</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>