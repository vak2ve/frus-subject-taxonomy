<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-07-26T04:54:00-05:00" frus:doc-dateTime-min="1943-07-26T04:54:00-05:00" n="927" subtype="historical-document" type="document" xml:id="d927">
                        <note rend="inline" type="source">890F.515/21: Telegram</note>
                        <head>
                            <hi rend="italic">The Minister Resident in Saudi Arabia</hi> (<persName type="from"><hi rend="italic">Moose</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Jidda</hi></placeName>, <date calendar="gregorian" when="1943-07-26T13:00:00+03:06">July 26,
                                    1943—1 p.m.</date>
                                <lb/> [Received 6:08 p.m.]</dateline>
                        </opener>
                        <p>73. My 66, July 14, 6 p.m. Saudi Government agreed on July 21 to accept
                            from oil company rupee equivalent of $500,000.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Moose</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>