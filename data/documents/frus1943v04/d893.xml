<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-02-18T23:59:59-05:00" frus:doc-dateTime-min="1943-02-18T00:00:00-05:00" n="893" subtype="historical-document" type="document" xml:id="d893">
                        <note rend="inline" type="source">890F.24/32</note>
                        <head>
                            <hi rend="italic">President <persName type="from">Roosevelt</persName>
                                to the Lend-Lease Administrator</hi> (<persName type="to"><hi rend="italic">Stettinius</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1943-02-18">February 18,
                                1943</date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Stettinius</hi>: For purposes of
                            implementing the authority conferred upon you as Lend-Lease
                            Administrator by Executive Order No. 8926, dated October 28, 1941, and
                            in order to enable you to arrange for Lend-Lease aid to the Government
                            of Saudi Arabia, I hereby find that the defense of Saudi Arabia is vital
                            to the defense of the United States.</p>
                        <p>Sincerely yours,</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Franklin</hi> D. <hi rend="smallcaps">Roosevelt</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>