    <text>
        <body>
            <div frus:doc-dateTime-max="1943-02-02T23:59:59-05:00"
                frus:doc-dateTime-min="1943-02-02T00:00:00-05:00" n="1119"
                subtype="historical-document" type="document" xml:id="d1119">
                <note rend="inline" type="source">740.0011 European War 1939/27976</note>
                <head>
                    <hi rend="italic">The President of Turkey</hi> (<persName type="from">
                        <hi rend="italic">Inönü</hi>
                    </persName>) <hi rend="italic">to President <persName type="to"
                            >Roosevelt</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation]<note n="9" xml:id="d1119fn9">Supplied by
                            the editors.</note>
                    </seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Ankara</hi>
                        </placeName>, <date calendar="gregorian" when="1943-02-02">February 2,
                            1943</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">The President</hi>: Mr. Winston Churchill has been good
                    enough to transmit to me, Mr. President, the friendly personal message you so
                    thoughtfully extended to me. My great pleasure in talking with the British Prime
                    Minister was heightened by the evidence of your moral support.</p>
                <p>Please accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Ismet Inönü</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
