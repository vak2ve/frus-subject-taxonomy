<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-11-04T00:35:00-05:00" frus:doc-dateTime-min="1943-11-04T00:35:00-05:00" n="418" subtype="historical-document" type="document" xml:id="d418">
                        <note rend="inline" type="source">123 D 82/566: Telegram</note>
                        <head>
                            <hi rend="italic">The Minister in Iran</hi> (<persName type="from"><hi rend="italic">Dreyfus</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Tehran</hi></placeName>, <date calendar="gregorian" when="1943-11-04T09:00:00+03:25">November
                                    4, 1943—9 a.m.</date>
                                <lb/> [Received 11:32 a.m.]</dateline>
                        </opener>
                        <p>1045. Relinquished charge and departed today for the United States with
                            Secretary’s party.<note n="41" xml:id="d418fn41">Secretary of State
                                Cordell Hull was returning from the Tripartite Conference of Foreign
                                Ministers held at Moscow. Richard Ford was left as Chargé in
                                Iran.</note>
                        </p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Dreyfus</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>