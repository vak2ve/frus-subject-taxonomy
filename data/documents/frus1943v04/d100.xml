                subtype="historical-document" type="document" xml:id="d100">
                <note rend="inline" type="source">884.24/95½: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Asmara</hi> (<persName type="to">
                        <hi rend="italic">Smith</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-02-06T22:00:00-04:00"
                            >February 6, 1943—10 p.m.</date>
                    </dateline>
                </opener>
                <p>24. Your no. 13, February 1, 10 a.m. You are authorized to accompany General
                    Maxwell and Colonel Clark to Addis Ababa.</p>
                <p rend="center">. . . . . . . . . . . . . .</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
