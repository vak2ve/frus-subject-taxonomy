<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-10-13T11:00:00-05:00" frus:doc-dateTime-min="1943-10-13T11:00:00-05:00" n="51" subtype="historical-document" type="document" xml:id="d51">
                        <note rend="inline" type="source">894.20290H/14: Telegram</note>
                        <head>
                            <hi rend="italic">The Minister in Afghanistan</hi> (<persName type="from"><hi rend="italic">Engert</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Kabul</hi></placeName>, <date calendar="gregorian" when="1943-10-13T20:00:00+04:00">October
                                    13, 1943—8 p.m.</date>
                                <lb/> [Received October 15—10:23 a.m.]</dateline>
                        </opener>
                        <p>179. Four Japanese engineers mentioned in my despatch 228, July 10,<note n="65" xml:id="d51fn65">Not printed.</note> left Kabul for Japan via
                            Russia September 24 and crossed Russian frontier at Termez September 29.
                            Please inform Moscow.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Engert</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>