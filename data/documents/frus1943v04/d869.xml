                <note rend="inline" type="source">123 Moose, James S./431: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Saudi Arabia</hi> (<persName type="from">
                        <hi rend="italic">Moose</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Jidda</hi>
                        </placeName>, <date calendar="gregorian" when="1943-05-19T12:00:00+03:06"
                            >May 19, 1943—noon</date>.<lb/>[Received 4:46 p.m.]</dateline>
                </opener>
                <p>42. Arrived and assumed charge today. Please advise Mrs. Moose.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Moose</hi>
                    </signed>
                </closer>
            </div>
        </body>
