                subtype="historical-document" type="document" xml:id="d783">
                <note rend="inline" type="source">851R.00/143: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Spain</hi> (<persName type="to">
                        <hi rend="italic">Hayes</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-01-07T16:00:00-04:00"
                            >January 7, 1943—4 p.m.</date>
                    </dateline>
                </opener>
                <p>32. Legation at Tangier reports that there may be a move on the part of the Vichy
                    authorities to send consular representatives to Tangier in Spanish Morocco. For
                    obvious reasons this would be undesirable and you are requested to mention to
                    the Spanish Foreign Office that it would be inopportune at this time to
                    recognize a Vichy Consul in Spanish North Africa.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
