<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-01-08T23:59:59-05:00" frus:doc-dateTime-min="1943-01-08T00:00:00-05:00" n="193" subtype="historical-document" type="document" xml:id="d193">
                        <note rend="inline" type="source">123 P 54/569: Telegram</note>
                        <head>
                            <hi rend="italic">Mr. <persName type="from">William Phillips</persName>,
                                Personal Representative of President Roosevelt in India, to the
                                    <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">New Delhi</hi></placeName>, <date calendar="gregorian" when="1943-01-08">January 8,
                                1943</date>.<lb/>[Received January 8—3:59 p.m.]</dateline>
                        </opener>
                        <p>12. Arrived today, assumed charge.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Phillips</hi>
                            </signed>
                        </closer>
                    </div>
