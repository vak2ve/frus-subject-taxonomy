<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-07-12T19:00:00-05:00" frus:doc-dateTime-min="1943-07-12T19:00:00-05:00" n="1173" subtype="historical-document" type="document" xml:id="d1173">
                        <note rend="inline" type="source">867.24/663: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Turkey</hi> (<persName type="to"><hi rend="italic">Steinhardt</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1943-07-12T20:00:00-04:00">July 12,
                                    1943—8 p.m.</date>
                            </dateline>
                        </opener>
                        <p>600. Your telegram no. 646, April 5, 3 p.m. Please report any further
                            reaction to our proposal you may have received from the Turks.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>