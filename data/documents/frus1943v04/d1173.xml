                <note rend="inline" type="source">867.24/663: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Turkey</hi> (<persName type="to">
                        <hi rend="italic">Steinhardt</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-07-12T20:00:00-04:00"
                            >July 12, 1943—8 p.m.</date>
                    </dateline>
                </opener>
                <p>600. Your telegram no. 646, April 5, 3 p.m. Please report any further reaction to
                    our proposal you may have received from the Turks.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
