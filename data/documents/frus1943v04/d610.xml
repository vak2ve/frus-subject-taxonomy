<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-04-19T16:00:00-05:00" frus:doc-dateTime-min="1943-04-19T16:00:00-05:00" n="610" subtype="historical-document" type="document" xml:id="d610">
                        <note rend="inline" type="source">891.515/95: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Iran</hi> (<persName type="to"><hi rend="italic">Dreyfus</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1943-04-19T17:00:00-04:00">April 19,
                                    1943—5 p.m.</date>
                            </dateline>
                        </opener>
                        <p>189. Your 334, April 1. Shipping costs of $500,000 in small gold bars
                            from the United States to Iran by air would be approximately as follows: <list>
                                <label>1.</label>
                                <item>Packing and trucking $50.</item>
                                <label>2.</label>
                                <item>Insurance 4 percent ad valorem, expenses may be included in
                                    value.</item>
                                <label>3.</label>
                                <item>Freight costs cannot be estimated until transport priority and
                                    route are determined.</item>
                            </list>
                        </p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>