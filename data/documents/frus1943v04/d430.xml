<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-11-25T23:00:00-05:00" frus:doc-dateTime-min="1943-11-25T23:00:00-05:00" n="430" subtype="historical-document" type="document" xml:id="d430">
                        <note rend="inline" type="source">123 Hurley, Patrick J./125:
                            Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Iran</hi> (<persName type="to"><hi rend="italic">Dreyfus</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1943-11-26T00:00:00-04:00">November
                                    26, 1943—midnight</date>.</dateline>
                        </opener>
                        <p>598. For General Hurley. Please give Dreyfus the substance of the
                            Department’s telegram no. 1777 of November 19 sent to Cairo for you.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>