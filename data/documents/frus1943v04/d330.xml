                subtype="historical-document" type="document" xml:id="d330">
                <note rend="inline" type="source">811.71245/22: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the United Kingdom</hi> (<persName type="to">
                        <hi rend="italic">Winant</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-06-10T22:00:00-04:00"
                            >June 10, 1943—10 p.m.</date>
                    </dateline>
                </opener>
                <p>3621. Contents of your 3874, June 8, have been duly noted and communicated to
                    United Press.</p>
                <p>Please continue to impress upon British authorities importance which this
                    Government attaches to United Press obtaining adequate teletype service in
                    India.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
