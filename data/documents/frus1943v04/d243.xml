<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-04-29T00:30:00-05:00" frus:doc-dateTime-min="1943-04-29T00:30:00-05:00" n="243" subtype="historical-document" type="document" xml:id="d243">
                        <note rend="inline" type="source">123 P 54/597: Telegram</note>
                        <head>
                            <hi rend="italic">The Officer in Charge at New Delhi</hi> (<persName type="from"><hi rend="italic">Merrell</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">New Delhi</hi></placeName>, <date calendar="gregorian" when="1943-04-29T12:00:00+06:30">April 29,
                                    1943—noon</date>.<lb/>[Received 8 p.m.]</dateline>
                        </opener>
                        <p>318. Mr. Phillips accompanied by Major Heppner<note n="45" xml:id="d243fn45">Maj. Richard Heppner, personal assistant to
                                Ambassador Phillips.</note> and Berry<note n="46" xml:id="d243fn46">James Lampton Berry, Secretary in the American Mission at New
                                Delhi.</note> departed by air this morning for Karachi en route to
                            the United States. I have assumed Charge.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Merrell</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>