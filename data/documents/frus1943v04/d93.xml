                subtype="historical-document" type="document" xml:id="d93">
                <note rend="inline" type="source">811.203/242: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Egypt</hi> (<persName type="from">
                        <hi rend="italic">Kirk</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Cairo</hi>
                        </placeName>, <date calendar="gregorian" when="1943-02-23T10:00:00+02:00"
                            >February 23, 1943—10 a.m.</date>
                        <lb/> [Received 11:37 a.m.]</dateline>
                </opener>
                <p>404. Department’s 286, February 19, 5 p.m. Signing of notes regarding military
                    jurisdiction is being delayed on account of illness of Prime Minister and
                    resulting impossibility of convening Council of Ministers to approve
                    arrangement.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kirk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
