                subtype="historical-document" type="document" xml:id="d260">
                <note rend="inline" type="source">845.001/85: Telegram</note>
                <head>
                    <hi rend="italic">The Officer in Charge at New Delhi</hi> (<persName type="from">
                        <hi rend="italic">Merrell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">New Delhi</hi>
                        </placeName>, <date calendar="gregorian" when="1943-10-19T18:00:00+06:30"
                            >October 19, 1943—6 p.m.</date>
                        <lb/> [Received 8:03 p.m.]</dateline>
                </opener>
                <p>765. Linlithgow departed by air this morning and Wavell takes oath as Viceroy
                    tomorrow morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Merrell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
