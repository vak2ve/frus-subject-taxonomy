                subtype="historical-document" type="document" xml:id="d911">
                <note rend="inline" type="source">890F.51/52a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Egypt</hi> (<persName type="to">
                        <hi rend="italic">Kirk</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-05-17T20:00:00-04:00"
                            >May 17, 1943—8 p.m.</date>
                    </dateline>
                </opener>
                <p>680. The Department has been informed that a meeting is scheduled to take place
                    in Cairo in the near future for the purpose of considering Saudi Arabian
                    financial problems. If such a meeting is about to be held, you may, if you
                    consider it advisable, authorize Moose to remain in Cairo to attend, together
                    with any other member of your staff whom you may wish to select.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
