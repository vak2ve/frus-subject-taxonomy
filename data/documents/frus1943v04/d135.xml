                subtype="historical-document" type="document" xml:id="d135">
                <note rend="inline" type="source">868.01/328: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Egypt</hi> (<persName type="from">
                        <hi rend="italic">Kirk</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Cairo</hi>
                        </placeName>, <date calendar="gregorian" when="1943-03-15T11:00:00+02:00"
                            >March 15, 1943—11 a.m.</date>
                        <lb/> [Received March 15—9:04 a.m.]</dateline>
                </opener>
                <p>508. My 505, March 13, 6 p.m. The King of Greece arrived this morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kirk</hi>
                    </signed>
                </closer>
            </div>
        </body>
