<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-10-05T19:00:00-05:00" frus:doc-dateTime-min="1943-10-05T19:00:00-05:00" n="1050" subtype="historical-document" type="document" xml:id="d1050">
                        <note rend="inline" type="source">890D.01/707: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Diplomatic Agent and Consul General at Beirut</hi> (<persName type="to"><hi rend="italic">Wadsworth</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1943-10-05T20:00:00-04:00">October 5,
                                    1943—8 p.m.</date>
                            </dateline>
                        </opener>
                        <p>254. Your 285, October 2, 2 p.m. Your remarks to Syrian President and
                            Foreign Minister and suggestion contained in antepenultimate paragraph
                            are approved.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                </body></text></TEI>