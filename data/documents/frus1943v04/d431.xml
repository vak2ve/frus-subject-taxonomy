    <text>
        <body>
            <div frus:doc-dateTime-max="1943-11-29T01:35:00-05:00"
                frus:doc-dateTime-min="1943-11-29T01:35:00-05:00" n="431"
                subtype="historical-document" type="document" xml:id="d431">
                <note rend="inline" type="source">123 Hurley, Patrick J./126: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Iran</hi> (<persName type="from">
                        <hi rend="italic">Dreyfus</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tehran</hi>
                        </placeName>, <date calendar="gregorian" when="1943-11-29T10:00:00+03:25"
                            >November 29, 1943—10 a.m.</date>
                        <lb/> [Received 10:07 a.m.]</dateline>
                </opener>
                <p>1075. Department’s 598, November 26. Following from Hurley: <quote
                        rend="blockquote">
                        <p>“We understand orders perfectly and getting along splendidly.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dreyfus</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
