<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-06-24T07:54:00-05:00" frus:doc-dateTime-min="1943-06-24T07:54:00-05:00" n="917" subtype="historical-document" type="document" xml:id="d917">
                        <note rend="inline" type="source">890F.515/16: Telegram</note>
                        <head>
                            <hi rend="italic">The Appointed Minister Resident in Saudi Arabia</hi>
                                (<persName type="from"><hi rend="italic">Moose</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Jidda</hi></placeName>, <date calendar="gregorian" when="1943-06-24T16:00:00+03:06">June 24,
                                    1943—4 p.m.</date>
                                <lb/> [Received 8:34 p.m.]</dateline>
                        </opener>
                        <p>58. My 55, June 22, 5 p.m. Today a sovereign costing $21 will purchase
                            only 38½ riyals making riyal value 54.54 cents. No new gold has yet
                            arrived.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Moose</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>