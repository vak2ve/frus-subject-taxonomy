                subtype="historical-document" type="document" xml:id="d130">
                <note rend="inline" type="source">884.01A/59: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Ethiopia</hi> (<persName type="to">
                        <hi rend="italic">Caldwell</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-12-13T23:00:00-04:00"
                            >December 13, 1943—11 p.m.</date>
                    </dateline>
                </opener>
                <p>58. Please inform the Ethiopian Government that the agricultural, engineering and
                    mining missions have been consolidated into one unit including 11 experts and
                    that the mission plans to leave the United States about the end of January.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
