<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-12-04T10:44:00-05:00" frus:doc-dateTime-min="1943-12-04T10:44:00-05:00" n="729" subtype="historical-document" type="document" xml:id="d729">
                        <note rend="inline" type="source">882.1561/25: Telegram</note>
                        <head>
                            <hi rend="italic">The Minister in Liberia</hi> (<persName type="from"><hi rend="italic">Walton</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Monrovia</hi></placeName>, <date calendar="gregorian" when="1943-12-04T15:00:00-00:44">December
                                    4, 1943—3 p.m.</date>
                                <lb/> [Received December 6—5:20 a.m.]</dateline>
                        </opener>
                        <p>202. Cabinet Friday favorably considered port project. Agreement is
                            likely to be concluded and signed week of December 13.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Walton</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>