    <text>
        <body>
            <div frus:doc-dateTime-max="1943-02-03T18:00:00-05:00"
                frus:doc-dateTime-min="1943-02-03T18:00:00-05:00" n="781"
                subtype="historical-document" type="document" xml:id="d781">
                <note rend="inline" type="source">740.00114A European War 1939/242: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Spain</hi> (<persName type="from">
                        <hi rend="italic">Hayes</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1943-02-04T00:00:00+01:00"
                            >February 4, 1943—midnight</date>.<lb/>[Received February 5—9:54
                        p.m.]</dateline>
                </opener>
                <p>291. My 124, January 18, 6 p.m.<note n="23" xml:id="d781fn23">Not printed.</note>
                    Air Ministry has agreed to release all remaining American aviation personnel in
                    Spain and Spanish Morocco, latter to be released to Gibraltar without necessity
                    of coming to Madrid.</p>
                <p>Repeated to Tangier.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hayes</hi>
                    </signed>
                </closer>
            </div>
        </body>
