                subtype="historical-document" type="document" xml:id="d1056">
                <note rend="inline" type="source">890E.01/205: Telegram</note>
                <head>
                    <hi rend="italic">The Diplomatic Agent and Consul General at Beirut</hi>
                        (<persName type="from">
                        <hi rend="italic">Wadsworth</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Beirut</hi>
                        </placeName>, <date calendar="gregorian" when="1943-11-08T17:00:00+02:00"
                            >November 8, 1943—5 p.m.</date>
                        <lb/> [Received November 8—3:35 p.m.]</dateline>
                </opener>
                <p>305. Reference my 302, November 5, 8 p.m. Lebanese Chamber today voted
                    unanimously Government’s bill amending constitution.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wadsworth</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
