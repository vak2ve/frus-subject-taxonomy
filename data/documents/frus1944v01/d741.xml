<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1944-09-22T23:59:59-05:00" frus:doc-dateTime-min="1944-09-22T00:00:00-05:00" n="741" subtype="historical-document" type="document" xml:id="d741">
                    <note rend="inline" type="source">340.1115A/9–2244: Telegram</note>
                    <head>
                        <hi rend="italic">The Minister in Switzerland</hi> (<persName type="from"><hi rend="italic">Harrison</hi></persName>) <hi rend="italic">to
                            the <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Bern</hi></placeName>, <date calendar="gregorian" when="1944-09-22">September 22,
                            1944</date>.<lb/>[Received September 22—11:55 p.m.]</dateline>
                    </opener>
                    <p>6296. American Interests—Baltic Countries. Legation’s 4991, August 3,
                        Department’s 2852, August 19.<note n="59" xml:id="d741fn59">Neither
                            printed.</note>
                    </p>
                    <p>Swiss Legation Berlin reports September 15 no recipients financial assistance
                        Baltic countries.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Harrison</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>