    <text>
        <body>
            <div frus:doc-dateTime-max="1944-05-06T10:00:00-05:00"
                frus:doc-dateTime-min="1944-05-06T10:00:00-05:00" n="836"
                subtype="historical-document" type="document" xml:id="d836">
                <note rend="inline" type="source">740.00116 European War 1939/1428: Airgram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from">
                        <hi rend="italic">Caffery</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1944-05-06T12:00:00-03:00"
                            >May 6, 1944—noon</date>.<lb/>[Received May 13—4 p.m.]</dateline>
                </opener>
                <p>A–820. The Minister for Foreign Affairs and the Secretary General of the Foreign
                    Office both disclaim any knowledge in connection with the report set out in the
                    Department’s secret instruction No. 5884 of April 29, 1944,<note n="47"
                        xml:id="d836fn47">Not printed.</note> to the effect that the Brazilian
                    Ambassador at London had approached the British Government regarding the
                    question of Brazilian membership on the War Crimes Commission.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caffery</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
