                subtype="historical-document" type="document" xml:id="d759">
                <note rend="inline" type="source">703.5451/12–144: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Caffery</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1944-12-01">December 1,
                            1944</date>.<lb/>[Received December 1—6:55 p.m.]</dateline>
                </opener>
                <p>747. American interests taken back today from Swiss in all of France except Lyon
                    district. Embassy and Consulates in Marseille, Nice and Cherbourg officially
                    open to the public.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caffery</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
