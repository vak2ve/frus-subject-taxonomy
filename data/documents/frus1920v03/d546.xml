                subtype="historical-document" type="document" xml:id="d546">
                <note rend="inline" type="source">861.00/6095: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Japan</hi> (<persName type="to">
                        <hi rend="italic">Morris</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-01-10T15:00:00-05:00">
                            <hi rend="italic">January 10, 1920—3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>10. Your 6, January 9, noon. See Department’s January 9, 4 p.m. No announcement
                    previous to this authorized or made so far as the Department is aware. Consul
                    had of course no information from this Department which was not furnished to
                    you.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
