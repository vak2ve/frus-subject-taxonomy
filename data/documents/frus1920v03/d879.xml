                <note rend="inline" type="source">661.1115/85: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Consul General at London</hi> (<persName type="to">
                        <hi rend="italic">Skinner</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-06-25T14:00:00-04:00">
                            <hi rend="italic">June 25, 1920—2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your June 25, 9 a.m. Do not attend.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
