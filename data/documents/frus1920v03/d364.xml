<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-12-16T12:45:00-05:00" frus:doc-dateTime-min="1920-12-16T12:45:00-05:00" n="364" subtype="historical-document" type="document" xml:id="d364">
                            <note rend="inline" type="source">817.00/2746: Telegram</note>
                            <head><hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from"><hi rend="italic">Jefferson</hi></persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                                        State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Managua</hi></placeName>, <date calendar="gregorian" when="1920-12-16T12:00:00-05:45"><hi rend="italic">December
                                            16, 1920—noon</hi></date>.<lb/>[Received 9:30
                                    p.m.]</dateline></opener>
                            <p>65. José Estéban González, Coalition presidential candidate, died
                                suddenly early this morning, apoplexy reported cause of death.</p>
                            <closer><signed><hi rend="smallcaps">Jefferson</hi></signed></closer>
                        </div>
                        </body></text></TEI>