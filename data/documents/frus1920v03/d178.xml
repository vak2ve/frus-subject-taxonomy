                subtype="historical-document" type="document" xml:id="d178">
                <note rend="inline" type="source">812.00/24405: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Mexicali</hi> (<persName type="to">
                        <hi rend="italic">Boyle</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-07-30T20:00:00-04:00">
                            <hi rend="italic">July 30, 1920—8 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your telegram 29th. Military Intelligence Officer, Calexico, instructed to confer
                    with you concerning aviators. Render him every possible facility to prevent them
                    violating neutrality laws.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
