                subtype="historical-document" type="document" xml:id="d51">
                <note rend="inline" type="source">882.51/1126a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Liberia</hi> (<persName type="to">
                        <hi rend="italic">Johnson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-05-20T17:00:00-04:00">
                            <hi rend="italic">May 20, 1920—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>22. And for attention of Worley.</p>
                <p>Navy Department advises U.S.S. <hi rend="italic">Chattanooga</hi> enroute to
                    United States from Europe. Will arrive Monrovia about May 29 making courtesy
                    call remaining week or ten days.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
