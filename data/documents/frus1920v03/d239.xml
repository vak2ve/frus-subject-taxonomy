<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-10-27T23:59:59-05:00" frus:doc-dateTime-min="1920-10-27T00:00:00-05:00" n="239" subtype="historical-document" type="document" xml:id="d239">
                            <note rend="inline" type="source">812.00/24760</note>
                            <head><hi rend="italic">The Chargé in Mexico</hi> (<persName type="from"><hi rend="italic">Hanna</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Mexico</hi></placeName>, <date calendar="gregorian" when="1920-10-27"><hi rend="italic">October 27,
                                        1920</hi></date>.<lb/>[Received November 5.]</dateline>
                                <seg rendition="#left">No. 3442</seg></opener>
                            <p><hi rend="smallcaps">Sir</hi>: I have the honor to enclose herewith a
                                translation of an autograph letter of the President of
                                    Guatemala<note n="32" xml:id="d239fn32">Not printed.</note> in
                                reply to the autograph letter of Mr. de la Huerta announcing that he
                                had been elected Substitute President of Mexico.</p>
                            <p>I have [etc.]</p>
                            <closer><signed><hi rend="smallcaps">Matthew E.
                                Hanna</hi></signed></closer>
                        </div>
                        </body></text></TEI>