<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-10-06T16:36:00-05:00" frus:doc-dateTime-min="1920-10-06T16:36:00-05:00" n="233" subtype="historical-document" type="document" xml:id="d233">
                            <note rend="inline" type="source">812.00/24669: Telegram</note>
                            <head><hi rend="italic">The Chargé in Mexico</hi> (<persName type="from"><hi rend="italic">Hanna</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Mexico</hi></placeName>, <date calendar="gregorian" when="1920-10-06T15:00:00-06:36"><hi rend="italic">October
                                            6, 1920—3 p.m.</hi></date><lb/>[Received 11:07
                                    p.m.]</dateline></opener>
                            <p>410. Foreign Office confirms local press reports of today that
                                Honduras and Salvador have recognized the Mexican Government.</p>
                            <closer><signed><hi rend="smallcaps">Hanna</hi></signed></closer>
                        </div>
                        </body></text></TEI>