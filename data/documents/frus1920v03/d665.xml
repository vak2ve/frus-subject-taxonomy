    <text>
        <body>
            <div frus:doc-dateTime-max="1920-01-08T04:00:00-05:00"
                frus:doc-dateTime-min="1920-01-08T04:00:00-05:00" n="665"
                subtype="historical-document" type="document" xml:id="d665">
                <note rend="inline" type="source">661.00/6097: Telegram</note>
                <head>
                    <hi rend="italic">The High Commissioner at Constantinople</hi> (<persName
                        type="from">
                        <hi rend="italic">Bristol</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Constantinople</hi>
                        </placeName>, <date calendar="gregorian" when="1920-01-08T11:00:00+02:00">
                            <hi rend="italic">January 8, 1920—11 a.m.</hi>
                        </date>
                        <lb/>[Received January 9—7:10 a.m.]</dateline>
                </opener>
                <p>14. My 6, January 7, 11 a.m. I am informed that British Admiralty will supply
                    necessary coal.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bristol</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
