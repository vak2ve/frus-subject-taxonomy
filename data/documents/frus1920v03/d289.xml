                <note rend="inline" type="source">612.119/2846: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Monterey</hi> (<persName type="to">
                        <hi rend="italic">Bowman</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-05-04T16:00:00-04:00">
                            <hi rend="italic">May 4, 1920—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your May 1, noon.</p>
                <p>Department approves your suggestion to Governor on question of munitions.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
