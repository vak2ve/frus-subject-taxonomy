<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-12-04T15:00:00-05:00" frus:doc-dateTime-min="1920-12-04T15:00:00-05:00" n="739" subtype="historical-document" type="document" xml:id="d739">
                            <note rend="inline" type="source">861.48/1275: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the High Commissioner at
                                    Constantinople</hi> (<persName type="to"><hi rend="italic">Bristol</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1920-12-04T15:00:00-05:00"><hi rend="italic">December
                                            4, 1920—3 p.m.</hi></date></dateline></opener>
                            <p>104. Your 587, undated.<note n="38" xml:id="d739fn38">Not
                                    printed.</note> Department informed Red Cross has now made
                                available for relief of Russian refugees in Constantinople district,
                                approximately $800,000.</p>
                            <closer><signed><hi rend="smallcaps">Davis</hi></signed></closer>
                        </div>
                        </body></text></TEI>