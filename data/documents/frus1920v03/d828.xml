<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-10-14T09:24:00-05:00" frus:doc-dateTime-min="1920-10-14T09:24:00-05:00" n="828" subtype="historical-document" type="document" xml:id="d828">
                            <note rend="inline" type="source">361.11/3544: Telegram</note>
                            <head><hi rend="italic">The Commissioner at Riga</hi> (<persName type="from"><hi rend="italic">Young</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Riga</hi></placeName>, <date calendar="gregorian" when="1920-10-14T16:00:00+01:36"><hi rend="italic">October
                                            14, 1920—4 p.m.</hi></date><lb/>[Received 5:48
                                    p.m.]</dateline></opener>
                            <p>220. Have reason to believe that should Department so desire
                                immediate release of all Americans now in Soviet Russia can be
                                obtained in exchange for the Russian children who have been in care
                                American Red Cross and who have recently arrived Finland.<note n="76" xml:id="d828fn76">Transported from
                                Vladivostok.</note></p>
                            <closer><signed><hi rend="smallcaps">Young</hi></signed></closer>
                        </div>
                        </body></text></TEI>