    <text>
        <body>
            <div frus:doc-dateTime-max="1919-12-28T11:44:00-05:00"
                frus:doc-dateTime-min="1919-12-28T11:44:00-05:00" n="39"
                subtype="historical-document" type="document" xml:id="d39">
                <note rend="inline" type="source">882.51/1036: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Liberia</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1919-12-28T16:00:00-00:44">
                            <hi rend="italic">December 28, 1919—4 p.m.</hi>
                        </date>
                        <lb/>[Received 7:33 p.m.]</dateline>
                </opener>
                <p>Communicated Department’s December 10 [<hi rend="italic">20</hi>], 2 p.m. to
                    Liberian Government. In reply Legation advised that it is agreeable to Liberian
                    Government that National City Bank act as Fiscal Agent of Liberia for advances
                    which may be made the Republic from the United States Treasury and that Liberian
                    Government would be pleased to have Department approach bank on this matter in
                    its behalf.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
