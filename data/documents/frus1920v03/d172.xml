                subtype="historical-document" type="document" xml:id="d172">
                <note rend="inline" type="source">812.00/24225a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Mexico</hi> (<persName type="to">
                        <hi rend="italic">Summerlin</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-06-19T13:00:00-04:00">
                            <hi rend="italic">June 19, 1920—1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>173. Navy Department has ordered withdrawal of all naval units in Mexican
                    territorial waters, except cruiser <hi rend="italic">Des Moines</hi> and two
                    destroyers in Gulf, and one destroyer on west coast.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
