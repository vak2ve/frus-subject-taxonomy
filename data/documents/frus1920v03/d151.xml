                subtype="historical-document" type="document" xml:id="d151">
                <note rend="inline" type="source">812.00/23734: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Mexico</hi> (<persName type="to">
                        <hi rend="italic">Hanna</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-04-28T14:00:00-04:00">
                            <hi rend="italic">April 28, 1920—2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>126. Consul Acapulco reports<note n="9" xml:id="d151fn9">Telegram not
                        printed.</note> having received information that Obregón has gone to Iguala,
                    and is proceeding toward Mexico City with force of nine to ten thousand men.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
