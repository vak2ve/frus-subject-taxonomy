    <text>
        <body>
            <div frus:doc-dateTime-max="1920-12-11T13:36:00-05:00"
                frus:doc-dateTime-min="1920-12-11T13:36:00-05:00" n="254"
                subtype="historical-document" type="document" xml:id="d254">
                <note rend="inline" type="source">812.00/24809: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Mexico</hi> (<persName type="from">
                        <hi rend="italic">Summerlin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1920-12-11T12:00:00-06:36">
                            <hi rend="italic">December 11, 1920—12 noon</hi>
                        </date>.<lb/>[Received 6:30 p.m.]</dateline>
                </opener>
                <p>473. Foreign Office confirms press reports published here today that the
                    Netherlands Government has recognized the Mexican Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Summerlin</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
