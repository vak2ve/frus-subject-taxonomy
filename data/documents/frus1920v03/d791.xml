<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-09-23T17:00:00-05:00" frus:doc-dateTime-min="1920-09-23T17:00:00-05:00" n="791" subtype="historical-document" type="document" xml:id="d791">
                            <note rend="inline" type="source">702.60i11/1: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Commissioner at Riga</hi> (<persName type="to"><hi rend="italic">Young</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1920-09-23T18:00:00-04:00"><hi rend="italic">September
                                            23, 1920—6 p.m.</hi></date></dateline></opener>
                            <p>57. Your 152, September 13, 4 p.m.</p>
                            <p>You may inform the Esthonian authorities that the United States
                                Government would have no objection to their sending to this country
                                an unofficial agent with the same status as those of Latvia and
                                Lithuania.</p>
                            <closer><signed><hi rend="smallcaps">Colbt</hi></signed></closer>
                        </div>
                        </body></text></TEI>