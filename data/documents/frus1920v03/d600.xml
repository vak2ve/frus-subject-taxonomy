<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-01-21T23:34:00-05:00" frus:doc-dateTime-min="1920-01-21T23:34:00-05:00" n="600" subtype="historical-document" type="document" xml:id="d600">
                            <note rend="inline" type="source">861.00/6197: Telegram</note>
                            <head><hi rend="italic">The Consul at Harbin</hi> (<persName type="from"><hi rend="italic">Jenkins</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Harbin</hi></placeName>, <date calendar="gregorian" when="1920-01-22T13:00:00+08:26"><hi rend="italic">January
                                            22, 1920—1 p.m.</hi></date><lb/>[Received January
                                    23—9:54 a.m.]</dateline></opener>
                            <p>Semenoff has published an order alleged to be signed by Koichak
                                appointing Semenoff to full governmental authority over Eastern
                                Siberia.</p>
                            <closer><signed><hi rend="smallcaps">Jenkins</hi></signed></closer>
                        </div>
                        </body></text></TEI>