                subtype="historical-document" type="document" xml:id="d243">
                <note rend="inline" type="source">812.00/24768: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Mexico</hi> (<persName type="from">
                        <hi rend="italic">Summerlin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1920-11-11T16:00:00-06:36">
                            <hi rend="italic">November 11, 1920—4 p.m.</hi>
                        </date>
                        <lb/>[Received 10:06 p.m.]</dateline>
                </opener>
                <p>444. Foreign Office has confirmed the local press report that Colombia has
                    recognized the present Mexican régime.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Summerlin</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
