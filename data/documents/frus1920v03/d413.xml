<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-04-27T15:00:00-05:00" frus:doc-dateTime-min="1920-04-27T15:00:00-05:00" n="413" subtype="historical-document" type="document" xml:id="d413">
                        <note rend="inline" type="source">123.G58/111: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Peru</hi> (<persName type="from"><hi rend="italic">Gonzales</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Lima</hi></placeName>, <date calendar="gregorian" when="1920-04-27T15:00:00-05:00"><hi rend="italic">April 27,
                                        1920—3 p.m.</hi></date><lb/>[Received 8:40
                            p.m.]</dateline></opener>
                        <p>72. Presented my credentials Saturday; took charge today.</p>
                        <closer><signed><hi rend="smallcaps">Gonzales</hi></signed></closer>
                    </div>
