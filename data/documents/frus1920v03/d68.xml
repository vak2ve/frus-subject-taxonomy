<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-08-25T15:00:00-05:00" frus:doc-dateTime-min="1920-08-25T15:00:00-05:00" n="68" subtype="historical-document" type="document" xml:id="d68">
                        <note rend="inline" type="source">882.00/664: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in France</hi> (<persName type="to"><hi rend="italic">Wallace</hi></persName>)</head>
                        <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1920-08-25T16:00:00-04:00"><hi rend="italic">August 25,
                                        1920—4 p.m.</hi></date></dateline></opener>
                        <p>1398. Your 1557 [<hi rend="italic">1567</hi>], August 17, 7 p.m.</p>
                        <p>Discover if possible from Foreign Office the precise orders its
                            representative received.</p>
                        <closer><signed><hi rend="smallcaps">Colby</hi></signed></closer>
                    </div>
                    </body></text></TEI>