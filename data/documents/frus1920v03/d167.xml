                subtype="historical-document" type="document" xml:id="d167">
                <note rend="inline" type="source">$12.00/23987: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Frontera</hi> (<persName type="to">
                        <hi rend="italic">Blohm</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-05-18T17:00:00-04:00">
                            <hi rend="italic">May 18, 1920—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your May 12, 1 P.M.<note n="17" xml:id="d167fn17">Not printed.</note>
                </p>
                <p>Navy Department has been requested to send light draft vessel to Frontera and
                    Carmen.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
