<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-02-09T05:24:00-05:00" frus:doc-dateTime-min="1920-02-09T05:24:00-05:00" n="756" subtype="historical-document" type="document" xml:id="d756">
                            <note rend="inline" type="source">861.00/6315: Telegram</note>
                            <head><hi rend="italic">The Commissioner at Riga</hi> (<persName type="from"><hi rend="italic">Gade</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Riga</hi></placeName>, <date calendar="gregorian" when="1920-02-09T12:00:00+01:36"><hi rend="italic">February
                                            9, 1920—noon</hi></date>.<lb/>[Received 3:21
                                    p.m.]</dateline></opener>
                            <p>89. Information received from unofficial sources that the Latvian
                                Government signed armistice with the Bolsheviks January 29th in
                                Moscow.</p>
                            <closer><signed><hi rend="smallcaps">Gade</hi></signed></closer>
                        </div>
                        </body></text></TEI>