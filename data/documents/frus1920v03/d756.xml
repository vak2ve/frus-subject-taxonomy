                subtype="historical-document" type="document" xml:id="d756">
                <note rend="inline" type="source">861.00/6315: Telegram</note>
                <head>
                    <hi rend="italic">The Commissioner at Riga</hi> (<persName type="from">
                        <hi rend="italic">Gade</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Riga</hi>
                        </placeName>, <date calendar="gregorian" when="1920-02-09T12:00:00+01:36">
                            <hi rend="italic">February 9, 1920—noon</hi>
                        </date>.<lb/>[Received 3:21 p.m.]</dateline>
                </opener>
                <p>89. Information received from unofficial sources that the Latvian Government
                    signed armistice with the Bolsheviks January 29th in Moscow.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gade</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
