                subtype="historical-document" type="document" xml:id="d415">
                <note rend="inline" type="source">823.032/28: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Peru</hi> (<persName type="to">
                        <hi rend="italic">Smith</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-01-03T14:00:00-05:00">
                            <hi rend="italic">January 3, 1920—2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1. Your December 30, 3 p.m.<note n="9" xml:id="d415fn9">Not printed.</note>
                </p>
                <p>Seek another opportunity to informally discuss with President the Confiscation
                    Bill and intimate to him that in the opinion of this Government the passing of
                    such a Bill would be a grave error of judgment.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
