<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-05-04T09:45:00-05:00" frus:doc-dateTime-min="1920-05-04T09:45:00-05:00" n="343" subtype="historical-document" type="document" xml:id="d343">
                            <note rend="inline" type="source">817.00/2638: Telegram</note>
                            <head><hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from"><hi rend="italic">Jefferson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Managua</hi></placeName>, <date calendar="gregorian" when="1920-05-04T09:00:00-05:45"><hi rend="italic">May 4,
                                            1920—9 a.m.</hi></date><lb/>[Received 3:25
                                    p.m.]</dateline></opener>
                            <p>14. Yesterday Diego M. Chamorro was nominated by the Conservative
                                Party as presidential candidate.</p>
                            <closer><signed><hi rend="smallcaps">Jefferson</hi></signed></closer>
                        </div>
