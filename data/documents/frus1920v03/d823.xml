<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-08-28T08:00:00-05:00" frus:doc-dateTime-min="1920-08-28T08:00:00-05:00" n="823" subtype="historical-document" type="document" xml:id="d823">
                            <note rend="inline" type="source">361.11/3508: Telegram</note>
                            <head><hi rend="italic">The Chargé in Great Britain</hi> (<persName type="from"><hi rend="italic">Wright</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1920-08-28T14:00:00+01:00"><hi rend="italic">August
                                            28, 1920—2 p.m.</hi></date><lb/>[Received August
                                    28—11:30 a.m.]</dateline></opener>
                            <p>1310. Hansen has replied by telegraph to Moscow conveying substance
                                of message contained in your 894, August 21, 5 p.m. Nansen leaves
                                for Christiania today and can be reached care of American Legation
                                there.</p>
                            <closer><signed><hi rend="smallcaps">Wright</hi></signed></closer>
                        </div>
                        </body></text></TEI>