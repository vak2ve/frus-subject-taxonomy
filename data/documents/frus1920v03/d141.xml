                subtype="historical-document" type="document" xml:id="d141">
                <note rend="inline" type="source">812.00/23598: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Mazatlan</hi> (<persName type="to">
                        <hi rend="italic">Chapman</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-04-21T17:00:00-04:00">
                            <hi rend="italic">April 21, 1920—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your April 16, 3 P.M.</p>
                <p>I have suggested to Navy Department that it send war vessel to Mazatlán and
                    Topolobampo.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
