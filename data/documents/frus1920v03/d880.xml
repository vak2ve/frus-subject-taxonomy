    <text>
        <body>
            <div frus:doc-dateTime-max="1920-07-01T11:00:00-05:00"
                frus:doc-dateTime-min="1920-07-01T11:00:00-05:00" n="880"
                subtype="historical-document" type="document" xml:id="d880">
                <note rend="inline" type="source">661.1115/91: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Da/vis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1920-07-01T17:00:00+01:00">
                            <hi rend="italic">July 1, 1920—5 p.m.</hi>
                        </date>
                        <lb/>[Received July 1—1:07 p.m.]</dateline>
                </opener>
                <p>1011. My 1007, June 30, 6 p.m.<note n="5" xml:id="d880fn5">Not printed.</note>
                    Krassin returns to Moscow today. It seems as though present trade negotiations
                    would probably be unsuccessful.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
