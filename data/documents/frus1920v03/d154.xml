                subtype="historical-document" type="document" xml:id="d154">
                <note rend="inline" type="source">812.00/23766: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Vera Cruz</hi> (<persName type="from">
                        <hi rend="italic">Foster</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vera Cruz</hi>
                        </placeName>, <date calendar="gregorian" when="1920-04-29T12:00:00-06:36">
                            <hi rend="italic">April 29, 1920—noon</hi>
                        </date>.<lb/>[Received 7:16 p.m.]</dateline>
                </opener>
                <p>British consul requests to be informed as to whether or not American warships are
                    to be sent to Vera Cruz, for the information of British Admiralty.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Foster</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
