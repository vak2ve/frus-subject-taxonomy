    <text>
        <body>
            <div frus:doc-dateTime-max="1920-09-25T23:59:59-05:00"
                frus:doc-dateTime-min="1920-09-25T00:00:00-05:00" n="231"
                subtype="historical-document" type="document" xml:id="d231">
                <note rend="inline" type="source">812.00/24673</note>
                <head>
                    <hi rend="italic">The Chargé in Meixco</hi> (<persName type="from">
                        <hi rend="italic">Hanna</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1920-09-25">
                            <hi rend="italic">September 25, 1920</hi>
                        </date>.<lb/>[Received October 7.]</dateline>
                    <seg rendition="#left">No. 3390</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to report that the local press
                    of today, states that the Foreign Office has received an autograph letter from
                    the President of the Republic of Costa Rica in reply to Mr. de la Huerta’s
                    letter stating that he had been elected Substitute President of Mexico.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Matthew E. Hanna</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
