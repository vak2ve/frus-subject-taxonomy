                subtype="historical-document" type="document" xml:id="d769">
                <note rend="inline" type="source">760m.61/2: Telegram</note>
                <head>
                    <hi rend="italic">The Commissioner at Riga</hi> (<persName type="from">
                        <hi rend="italic">Young</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Riga</hi>
                        </placeName>, <date calendar="gregorian" when="1920-06-26T18:00:00+01:36">
                            <hi rend="italic">June 26, 1920—6 p.m.</hi>
                        </date>
                        <lb/>[Received June 27—3:15 a.m.]</dateline>
                </opener>
                <p>46. Department’s June 18, 7 p.m. Lithuania has informed British representatives
                    that she will remain neutral.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Young</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
