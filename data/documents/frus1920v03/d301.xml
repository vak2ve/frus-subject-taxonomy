                subtype="historical-document" type="document" xml:id="d301">
                <note rend="inline" type="source">125.61383 J 41/36a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Mexico</hi> (<persName type="to">
                        <hi rend="italic">Summerlin</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-01-24T16:00:00-05:00">
                            <hi rend="italic">January 24, 1920—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>23. News item appearing in local press January 22nd with Mexico City date line
                    quotes Sub-secretary of Foreign Relations as having announced the Jenkins’ case
                    satisfactorily settled. Investigate and report by telegraph.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Polk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
