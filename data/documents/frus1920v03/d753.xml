                <note rend="inline" type="source">7601.61/–: Telegram</note>
                <head>
                    <hi rend="italic">The Commissioner at Riga</hi> (<persName type="from">
                        <hi rend="italic">Gade</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Riga</hi>
                        </placeName>, <date calendar="gregorian" when="1920-02-02T17:00:00+01:36">
                            <hi rend="italic">February 2, 1920—5 p.m.</hi>
                        </date>
                        <lb/>[Received February 3—12:18 a.m.]</dateline>
                </opener>
                <p>85. Peace has been signed between Esthonia and Soviet Russia.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gade</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
