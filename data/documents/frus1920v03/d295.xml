                subtype="historical-document" type="document" xml:id="d295">
                <note rend="inline" type="source">312.119/2932: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Mexicali</hi> (<persName type="to">
                        <hi rend="italic">Boyle</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-08-02">
                            <hi rend="italic">August 2, 1920</hi>
                        </date>.</dateline>
                </opener>
                <p>Your July 31st.</p>
                <p>Pending settlement present controversy, no more shipments explosives to your
                    district will be licensed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
