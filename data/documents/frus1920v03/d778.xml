    <text>
        <body>
            <div frus:doc-dateTime-max="1920-08-11T12:24:00-05:00"
                frus:doc-dateTime-min="1920-08-11T12:24:00-05:00" n="778"
                subtype="historical-document" type="document" xml:id="d778">
                <note rend="inline" type="source">760p.61/5: Telegram</note>
                <head>
                    <hi rend="italic">The Commissioner at Riga</hi> (<persName type="from">
                        <hi rend="italic">Young</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Riga</hi>
                        </placeName>, <date calendar="gregorian" when="1920-08-11T19:00:00+01:36">
                            <hi rend="italic">August 11, 1920—7 p.m.</hi>
                        </date>
                        <lb/>[Received 8:27 p.m.]</dateline>
                </opener>
                <p>104. Latvian-Bolshevik peace treaty signed to-day. Will telegraph summary and
                    mail copy.<note n="44" xml:id="d778fn44">Not printed.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Young</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
