<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-06-04T16:00:00-05:00" frus:doc-dateTime-min="1920-06-04T16:00:00-05:00" n="207" subtype="historical-document" type="document" xml:id="d207">
                            <note rend="inline" type="source">812.00/24177a: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Chargé in Mexico</hi> (<persName type="to"><hi rend="italic">Summerlin</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1920-06-04T17:00:00-04:00"><hi rend="italic">June 4,
                                            1920—5 p.m.</hi></date></dateline></opener>
                            <p>165. Telegraph what governments, if any, have formally recognized
                                present Administration. Report also whether such recognition [be]
                                provisional or otherwise and keep Department fully advised on
                                subject.</p>
                            <closer><signed><hi rend="smallcaps">Colby</hi></signed></closer>
                        </div>
                        </body></text></TEI>