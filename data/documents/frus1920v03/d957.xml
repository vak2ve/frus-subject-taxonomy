<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-12-17T14:00:00-05:00" frus:doc-dateTime-min="1920-12-17T14:00:00-05:00" n="957" subtype="historical-document" type="document" xml:id="d957">
                            <note rend="inline" type="source">760j.6715/70: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Ambassador in France</hi> (<persName type="to"><hi rend="italic">Wallace</hi></persName>)</head>
                            <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1920-12-17T14:00:00-05:00"><hi rend="italic">December
                                            17, 1920—2 p.m.</hi></date></dateline></opener>
                            <p>1707. Referring to your 2015 of December 16. Complying with Foreign
                                Office request, Department will not for the present make public the
                                President’s decision.</p>
                            <closer><signed><hi rend="smallcaps">Davis</hi></signed></closer>
                        </div>
                        </body></text></TEI>