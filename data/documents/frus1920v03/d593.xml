<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-10-20T13:00:00-05:00" frus:doc-dateTime-min="1920-10-20T13:00:00-05:00" n="593" subtype="historical-document" type="document" xml:id="d593">
                            <note rend="inline" type="source">861.00/7512: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Consul at Vladivostok</hi> (<persName type="to"><hi rend="italic">Macgowan</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1920-10-20T14:00:00-04:00"><hi rend="italic">October
                                            20, 1920—2 p.m.</hi></date></dateline></opener>
                            <p>Your 53, October 12, 4 p.m. Refrain from requesting Japanese
                                protection, either jointly with the other members of the Consular
                                Corps or singly as American Consul.</p>
                            <closer><signed><hi rend="smallcaps">Colby</hi></signed></closer>
                        </div>
                    </body></text></TEI>