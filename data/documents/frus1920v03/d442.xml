    <text>
        <body>
            <div frus:doc-dateTime-max="1920-03-27T12:00:00-05:00"
                frus:doc-dateTime-min="1920-03-27T12:00:00-05:00" n="442"
                subtype="historical-document" type="document" xml:id="d442">
                <note rend="inline" type="source">760c.61/37: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Poland</hi> (<persName type="from">
                        <hi rend="italic">Gibson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Warsaw</hi>
                        </placeName>, <date calendar="gregorian" when="1920-03-27T19:00:00+02:00">
                            <hi rend="italic">March 27, 1920—7 p.m.</hi>
                        </date>
                        <lb/>[Received March 29—3:18 a.m.]</dateline>
                </opener>
                <p>173. My No. 170.<note n="6" xml:id="d442fn6">Not printed.</note> Polish
                    Government has sent the representatives [<hi rend="italic">sent radio</hi>] to
                    Moscow declaring its readiness to enter upon peace negotiations beginning April
                    10. Place indicated by Polish Government for these negotiations is Bobruisk [or]
                    Borysow.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gibson</hi>
                    </signed>
                </closer>
            </div>
        </body>
