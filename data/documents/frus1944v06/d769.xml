<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1944-09-19T18:00:00-05:00" frus:doc-dateTime-min="1944-09-19T18:00:00-05:00" n="769" subtype="historical-document" type="document" xml:id="d769">
                    <note rend="inline" type="source">711.9321/9–2044: Telegram</note>
                    <head>
                        <hi rend="italic">The Ambassador in China</hi> (<persName type="from"><hi rend="italic">Gauss</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Chungking</hi></placeName>, <date calendar="gregorian" when="1944-09-20T06:00:00+07:00">September 20,
                                1944—6 a.m.</date>
                            <lb/> [Received 10:15 a.m.]</dateline>
                    </opener>
                    <p>1588. We have given draft further study but have no additional comments (your
                        1173, September 5) and propose to present it to Foreign Office week hence,
                        September 26.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Gauss</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>