                subtype="historical-document" type="document" xml:id="d878">
                <note rend="inline" type="source">493.11/9–2044: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Gauss</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chungking</hi>
                        </placeName>, <date calendar="gregorian" when="1944-09-20T09:00:00+07:00"
                            >September 20, 1944—9 a.m.</date>
                        <lb/> [Received 10:18 a.m.]</dateline>
                </opener>
                <p>1583. Director of the China Foundation informs us Foundation has received formal
                    notification dated September 15 from Executive Yuan to effect that, by order of
                    the National Government, all indemnity administrations are to be abolished
                    before the end of the current year and that the Ministries of Foreign Affairs,
                    Education and Finance are to arrange the procedure for closing the work of the
                    indemnity administrations.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gauss</hi>
                    </signed>
                </closer>
            </div>
        </body>
