                subtype="historical-document" type="document" xml:id="d758">
                <note rend="inline" type="source">711.932/16: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Gauss</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chungking</hi>
                        </placeName>, <date calendar="gregorian" when="1944-05-04T21:00:00+07:00"
                            >May 4, 1944—9 p.m. [<hi rend="italic">a.m.?</hi>]</date>
                        <lb/> [Received May 4—7:36 a.m.]</dateline>
                </opener>
                <p>772. Foreign Minister in response to my approach, as instructed by your 568,
                    April 27, 8 p.m., expressed view that it would be more convenient <pb
                        facs="1033" n="1019" xml:id="pg_1019"/> to Chinese side if conversations on
                    commercial treaty could be held in Chungking. I told him this would be entirely
                    acceptable to us.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gauss</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
