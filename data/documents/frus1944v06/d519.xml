<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1944-12-05T23:59:59-05:00" frus:doc-dateTime-min="1944-12-05T00:00:00-05:00" n="519" subtype="historical-document" type="document" xml:id="d519">
                    <note rend="inline" type="source">893.00/12–544: Telegram</note>
                    <head>
                        <hi rend="italic">The Chargé in China</hi> (<persName type="from"><hi rend="italic">Atcheson</hi></persName>) <hi rend="italic">to the
                                <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Chungking</hi></placeName>, <date calendar="gregorian" when="1944-12-05">December 5,
                            1944</date>.<lb/>[Received 8:41 a.m.]</dateline>
                    </opener>
                    <p>1954. T. V. Soong appointed<note n="89" xml:id="d519fn89">December 4.</note>
                        concurrently Acting President of Executive Yuan.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Atcheson</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>