<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1944-08-29T11:00:00-05:00" frus:doc-dateTime-min="1944-08-29T11:00:00-05:00" n="767" subtype="historical-document" type="document" xml:id="d767">
                    <note rend="inline" type="source">711.9321/8–2444: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            Ambassador in China</hi> (<persName type="to"><hi rend="italic">Gauss</hi></persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1944-08-29T12:00:00-04:00">August 29,
                                1944—noon</date>.</dateline>
                    </opener>
                    <p>1142. Department is giving consideration to points raised in your 1453,
                        August 24, 4 p.m. Please defer presentation of draft Consular Convention to
                        Foreign Office.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Hull</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>