    <text>
        <body>
            <div frus:doc-dateTime-max="1941-04-30T23:59:59-05:00"
                frus:doc-dateTime-min="1941-04-30T00:00:00-05:00" n="737"
                subtype="historical-document" type="document" xml:id="d737">
                <note rend="inline" type="source">740.0011 European War 1939/10467: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Germany</hi> (<persName type="from">
                        <hi rend="italic">Morris</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1941-04-30">April 30,
                            1941</date>.<lb/>[Received April 30—11:48 a.m.]</dateline>
                </opener>
                <p>1660. Following is translation of German text of telegram to Department from
                        MacVeagh<note n="19a" xml:id="d737fn19a">Lincoln MacVeagh, American Minister
                        in Greece.</note> transmitted orally by Foreign Office: <pb facs="0746"
                        n="734" xml:id="pg_734"/>
                    <quote rend="blockquote">
                        <p>“298, April 29. All Americans in Athens are safe. Occupation of city
                            carried out in orderly and peaceful manner. German Legation very helpful
                            in assuring respect for property.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Morris</hi>
                    </signed>
                </closer>
            </div>
        </body>
