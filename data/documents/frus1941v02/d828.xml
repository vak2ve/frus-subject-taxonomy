                subtype="historical-document" type="document" xml:id="d828">
                <note rend="inline" type="source">856A.20/20: Telegram</note>
                <head>
                    <hi rend="italic">The Vice Consul at Paramaribo</hi> (<persName type="from">
                        <hi rend="italic">Norden</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paramaribo</hi>
                        </placeName>, <date calendar="gregorian" when="1941-11-25T18:00:00-03:40"
                            >November 25, 1941—6 p.m.</date>
                        <lb/> [Received November 26—8:25 a.m.]</dateline>
                </opener>
                <p>Colonel Parkinson and staff arrived at Zanderij 1:50 afternoon today Washington
                    time.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Norden</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
