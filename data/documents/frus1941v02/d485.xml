                subtype="historical-document" type="document" xml:id="d485">
                <note rend="inline" type="source">851A.01/15: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at St. Pierre-Miquelon</hi> (<persName type="from">
                        <hi rend="italic">Pasquet</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">St. Pierre-Miquelon</hi>
                        </placeName>, <date calendar="gregorian" when="1941-12-24T08:00:00-04:00"
                            >December 24, 1941—8 a.m.</date>
                        <lb/> [Received 3:27 p.m.]</dateline>
                </opener>
                <p>Three Free French corvettes and submarine <hi rend="italic">Surcouf</hi> under
                    the command of Admiral Muselier entered early this morning to occupy St.
                    Pierre-Miquelon. No difficulties anticipated.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Pasquet</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
