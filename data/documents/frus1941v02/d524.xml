<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-12-13T21:00:00-05:00" frus:doc-dateTime-min="1941-12-13T21:00:00-05:00" n="524" subtype="historical-document" type="document" xml:id="d524">
                        <note rend="inline" type="source">740.00118 European War 1939/867b:
                            Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Consul at Leopoldville</hi> (<persName type="to"><hi rend="italic">Mallon</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1941-12-13T21:00:00-05:00">December
                                    13, 1941—9 p.m.</date>
                            </dateline>
                        </opener>
                        <p>“From General Miles for Cunningham. Your telegram December 12 received.
                            Return to Washington by first available transportation. You are not
                            authorized to make any suggestions of military or diplomatic moves to
                            any foreign representatives.”</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>