                subtype="historical-document" type="document" xml:id="d532">
                <note rend="inline" type="source">740.0011 European War 1939/11764: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Egypt</hi> (<persName type="from">
                        <hi rend="italic">Kirk</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Cairo</hi>
                        </placeName>, <date calendar="gregorian" when="1941-06-08T15:00:00+03:00"
                            >June 8 [<hi rend="italic">7?</hi>], 1941—3 p.m.</date>
                        <lb/> [Received June 8—3:43 p.m.]</dateline>
                </opener>
                <p>671. My number 647, June 3, noon. The Legation is confidentially advised that the
                    letter which Wavell proposed addressing to the Governor of Djibouti was approved
                    in London and has probably been delivered by this time.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kirk</hi>
                    </signed>
                </closer>
            </div>
        </body>
