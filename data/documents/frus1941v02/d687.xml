<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-03-26T21:00:00-05:00" frus:doc-dateTime-min="1941-03-26T21:00:00-05:00" n="687" subtype="historical-document" type="document" xml:id="d687">
                            <note rend="inline" type="source">868.248/128: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Minister in Greece</hi> (<persName type="to"><hi rend="italic">MacVeagh</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1941-03-26T21:00:00-05:00">March
                                        26, 1941—9 p.m.</date>
                                </dateline>
                            </opener>
                            <p>112. Your 163, March 24, 6 p.m. The Department has the matter of
                                airplanes for Greece under urgent consideration and it is hoped that
                                a solution satisfactory to Greece will be reached in the near
                                future.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Welles</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>