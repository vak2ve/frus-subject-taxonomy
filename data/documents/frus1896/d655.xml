                subtype="historical-document" type="document" xml:id="d655">
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr. <persName
                            type="to">Williams</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-05-07">
                            <hi rend="italic">May 7, 1896</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="italic">Competitor</hi> case. Informed officially that only one
                    American citizen was taken and is now under arrest. If possible, report by
                    cable, who and where he is, on what charges held and how treated.</p>
            </div>
        </body>
