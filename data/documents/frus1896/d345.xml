    <text>
        <body>
            <div frus:doc-dateTime-max="1896-11-14T23:59:59-05:00"
                frus:doc-dateTime-min="1896-11-14T00:00:00-05:00" n="345"
                subtype="historical-document" type="document" xml:id="d345">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr. <persName
                            type="to">Dun</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-11-14">
                            <hi rend="italic">November 14, 1896</hi>
                        </date>.</dateline>
                </opener>
                <p>Your wire 13th instant received. Negotiate trade-marks convention, putting in
                    force Article XVI of new treaty. Same to be enforced by United States courts in
                    Japan.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Olney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
