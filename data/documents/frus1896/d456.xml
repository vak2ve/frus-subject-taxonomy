                subtype="historical-document" type="document" xml:id="d456">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Manion</persName> to Mr. <persName
                            type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Johannesburg</hi>
                        </placeName>, <date calendar="gregorian" when="1896-01-13">
                            <hi rend="italic">January 13, 1896</hi>
                        </date>. (Received Feb. 17.)</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I am in receipt of your cable of January 12,
                    1896. To this I have cabled reply.</p>
                <p>I have every reason to believe that President Kruger and his Government will take
                    a fair and honorable attitude to all aliens in the Transvaal. I will keep you
                    fully and promptly advised of the progress of all matters affecting American
                    citizens.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">J. C. Manion</hi>,<lb/>
                        <hi rend="italic">United States Consular Agent.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
