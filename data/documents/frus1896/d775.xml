                subtype="historical-document" type="document" xml:id="d775">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Rockhill</persName> to Mr. <persName
                            type="to">Lee</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-11-12">
                            <hi rend="italic">November 12, 1896</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 161.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring further to your dispatch, No. 169, of
                    the 9th ultimo, I inclose for your information a copy of a dispatch from our
                    minister to Spain, in which he reports that the Spanish minister of state
                    informed him that the recommendation for amelioration of the condition of Julio
                    Sanguily, pending his new trial, has been made.</p>
                <p>I am, sir, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. W. Rockhill.</hi>
                    </signed>
                </closer>
            </div>
        </body>
