                subtype="historical-document" type="document" xml:id="d454">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Manion</persName> to Mr. <persName
                            type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Johannesburg</hi>
                        </placeName>, <date calendar="gregorian" when="1896-01-13">
                            <hi rend="italic">January 13, 1896</hi>
                        </date>.</dateline>
                </opener>
                <p>Cable re John Hays Hammond received. Orders being obeyed. Other Americans in
                    trouble. Please cable me direct instructions, so that I may act officially in
                    their behalf.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Manion</hi>, <hi rend="italic">Consular Agent.</hi>
                    </signed>
                </closer>
            </div>
        </body>
