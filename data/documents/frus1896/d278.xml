    <text>
        <body>
            <div frus:doc-dateTime-max="1896-03-24T23:59:59-05:00"
                frus:doc-dateTime-min="1896-03-24T00:00:00-05:00" n="278"
                subtype="historical-document" type="document" xml:id="d278">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName> to Mr. <persName
                            type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Embassy of the United States</hi>,<lb/>
                            <hi rend="italic">London</hi>
                        </placeName>, <date calendar="gregorian" when="1896-03-24">
                            <hi rend="italic">March 24, 1896</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 637.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inclose herewith, for the
                    information of your colleague, the Secretary of the Treasury, clippings from
                    to-day’s Times, giving the report of a debate in the House of Commons on the
                    “Diseases of animals bill,” together with two copies of a public document having
                    relation thereto.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">T. F. Bayard.</hi>
                    </signed>
                </closer>
            </div>
        </body>
