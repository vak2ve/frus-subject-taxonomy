    <text>
        <body>
            <div frus:doc-dateTime-max="1896-07-10T23:59:59-05:00"
                frus:doc-dateTime-min="1896-07-10T00:00:00-05:00" n="532"
                subtype="historical-document" type="document" xml:id="d532">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Taylor</persName> to Mr. <persName
                            type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1896-07-10">
                            <hi rend="italic">July 10, 1896</hi>
                        </date>. (Received July 25.)</dateline>
                    <seg rendition="#left">No. 540.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your No. 527, of the 24th ultimo, and to report that I have duly communicated to
                    the Spanish Government the further evidence therein contained relative to the
                    case of the brothers Glean.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hannis Taylor.</hi>
                    </signed>
                </closer>
            </div>
        </body>
