<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1896-08-21T23:59:59-05:00" frus:doc-dateTime-min="1896-08-21T00:00:00-05:00" n="878" subtype="historical-document" type="document" xml:id="d878">
                        <head><hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr.
                                    <persName type="to">Terrell</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1896-08-21"><hi rend="italic">August 21,
                                1896</hi></date>.</dateline></opener>
                        <p>Referring to your 939, Sarkis Balaian, born 1871, emigrated 1888,
                            naturalized, Boston, January 10, 1895; passport No. 19174, issued
                            January 12, 1895.</p>
                        <closer><signed><hi rend="smallcaps">Adee</hi>, <hi rend="italic">Acting.</hi></signed></closer>
                    </div>
                    </body></text></TEI>