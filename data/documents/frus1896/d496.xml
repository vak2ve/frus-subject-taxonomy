                subtype="historical-document" type="document" xml:id="d496">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Knight</persName> to Mr. <persName
                            type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Cape Town</hi>
                        </placeName>, <date calendar="gregorian" when="1896-04-29">
                            <hi rend="italic">April 29, 1896</hi>
                        </date>.</dateline>
                </opener>
                <p>Have been officially informed sentence death commuted. Further particulars will
                    be wired.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Knight.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
