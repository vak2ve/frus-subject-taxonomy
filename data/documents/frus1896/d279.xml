<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1896-05-05T23:59:59-05:00" frus:doc-dateTime-min="1896-05-05T00:00:00-05:00" n="279" subtype="historical-document" type="document" xml:id="d279">
                        <head><hi rend="italic">Mr. <persName type="from">Bayard</persName> to Mr.
                                    <persName type="to">Olney</persName>.</hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Embassy
                                        of the United States</hi>,<lb/><hi rend="italic">London</hi></placeName>, <date calendar="gregorian" when="1896-05-05"><hi rend="italic">May 5,
                                1896</hi></date>.</dateline>
                            <seg rendition="#left">No. 669.]</seg></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have the honor to transmit herewith, for
                            transmission to your colleague, the Secretary of Agriculture, clippings
                            from the Times of yesterday’s date relating to the Canadian cattle
                            trade.</p>
                        <p>I have, etc.,</p>
                        <closer><signed><hi rend="smallcaps">T. F. Bayard.</hi></signed></closer>
                    </div>
                    </body></text></TEI>