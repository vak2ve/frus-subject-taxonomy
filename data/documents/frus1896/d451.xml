<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1896-01-12T23:59:59-05:00" frus:doc-dateTime-min="1896-01-12T00:00:00-05:00" n="451" subtype="historical-document" type="document" xml:id="d451">
                        <head><hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Manion</persName>, United States Consular
                                Agent at Johannesburg.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1896-01-12"><hi rend="italic">January 12,
                                1896</hi></date>.</dateline></opener>
                        <p>Take instant measures to secure John Hays Hammond protection and fair
                            play.</p>
                        <closer><signed><hi rend="smallcaps">Olney.</hi></signed></closer>
                    </div>
                    </body></text></TEI>