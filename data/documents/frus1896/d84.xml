    <text>
        <body>
            <div frus:doc-dateTime-max="1896-11-03T23:59:59-05:00"
                frus:doc-dateTime-min="1896-11-03T00:00:00-05:00" n="84"
                subtype="historical-document" type="document" xml:id="d84">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr. <persName
                            type="to">Tillman</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-11-03">
                            <hi rend="italic">November 3, 1896</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 82.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has been gratified to receive your
                    No. 90, of the 13th ultimo, inclosing the award of Mr. St. John in the Santos
                    matter.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Richard Olney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
