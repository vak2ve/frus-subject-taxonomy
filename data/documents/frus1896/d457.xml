<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1896-01-15T23:59:59-05:00" frus:doc-dateTime-min="1896-01-15T00:00:00-05:00" n="457" subtype="historical-document" type="document" xml:id="d457">
                        <head><hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Bayard</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1896-01-15"><hi rend="italic">January 15,
                                1896</hi></date>.</dateline></opener>
                        <p>Express to foreign office sincere thanks of this Government for prompt
                            use of kindly offices in aid of American citizens in the Transvaal.</p>
                        <closer><signed><hi rend="smallcaps">Olney.</hi></signed></closer>
                    </div>
                    </body></text></TEI>