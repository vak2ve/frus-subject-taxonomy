                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr. <persName
                            type="to">Manion</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-01-21">
                            <hi rend="italic">January 21, 1896</hi>
                        </date>.</dateline>
                </opener>
                <p>Report on present situation of Hammond and other American citizens arrested.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Olney.</hi>
                    </signed>
                </closer>
            </div>
