    <text>
        <body>
            <div frus:doc-dateTime-max="1895-07-08T23:59:59-05:00"
                frus:doc-dateTime-min="1895-07-08T00:00:00-05:00" n="721"
                subtype="historical-document" type="document" xml:id="d721">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr. <persName
                            type="to">Williams</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-07-08">
                            <hi rend="italic">July 8, 1895</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 1100.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Your dispatch No. 2521, of the 21st ultimo,
                    relative to the cases of Sanguily and Aguirre, has been received.</p>
                <p>The contents of the dispatch have been communicated to Manuel Sanguily and Gen.
                    N. L. Jeffries.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alvey A. Adee.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
