    <text>
        <body>
            <div frus:doc-dateTime-max="1896-10-30T23:59:59-05:00"
                frus:doc-dateTime-min="1896-10-30T00:00:00-05:00" n="608"
                subtype="historical-document" type="document" xml:id="d608">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Taylor</persName> to Mr. <persName
                            type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1896-10-30">
                            <hi rend="italic">October 30, 1896</hi>
                        </date>. (Received November 13.)</dateline>
                    <seg rendition="#left">No. 592.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your No. of 581, the 2d instant, and No. 583, of the 6th instant, relative to
                    the evidence as to exportations made by the firm Bauriedel &amp; Co., for
                    American importers of Cuban tobaccos, and to report that I have fully submitted
                    this evidence to the Spanish minister of State.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hannis Taylor.</hi>
                    </signed>
                </closer>
            </div>
        </body>
