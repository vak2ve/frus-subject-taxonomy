<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1897-01-28T23:59:59-05:00" frus:doc-dateTime-min="1897-01-28T00:00:00-05:00" n="782" subtype="historical-document" type="document" xml:id="d782">
                        <head><hi rend="italic">Mr. <persName type="from">Lee</persName> to Mr.
                                    <persName type="to">Olney</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Habana</hi></placeName>, <date calendar="gregorian" when="1897-01-28"><hi rend="italic">January 28,
                                    1897</hi>.</date></dateline></opener>
                        <p>Sanguily signed personal pledge to me that he will faithfully observe
                            terms already mailed. Recommend case be considered on said terms.</p>
                        <closer><signed><hi rend="smallcaps">Lee.</hi></signed></closer>
                    </div>
                    </body></text></TEI>