    <text>
        <body>
            <div frus:doc-dateTime-max="1896-08-21T23:59:59-05:00" frus:doc-dateTime-min="1896-08-21T00:00:00-05:00" n="144" subtype="historical-document" type="document" xml:id="d144">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr.
                                    <persName type="to">Uhl</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-08-21">
                            <hi rend="italic">August 21,
                                1896</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 143.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                            No. 101, of the 5th instant, inclosing a copy of your note of the same
                            date to the imperial German foreign office recalling its attention to
                            the applications of the Mutual Life Insurance Company, of New York, and
                            of the New York Life Insurance Company for permission to resume business
                            in Prussia.</p>
                <p>Your course in regard to the matter is fully approved by the
                            Department.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alvey A. Adee</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
