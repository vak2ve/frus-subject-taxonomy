    <text>
        <body>
            <div frus:doc-dateTime-max="1896-12-30T23:59:59-05:00"
                frus:doc-dateTime-min="1896-12-30T00:00:00-05:00" n="779"
                subtype="historical-document" type="document" xml:id="d779">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Lee</persName> to Mr. <persName
                            type="to">Rockhill</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">United States Consulate-General</hi>,<lb/>
                            <hi rend="italic">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1896-12-30">
                            <hi rend="italic">December 30, 1896</hi>
                        </date>. (Received January 2, 1897.)</dateline>
                    <seg rendition="#left">No. 275.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: With reference to the trial of Julio Sanguily,
                    reported by Mr. Springer in dispatch No. 271, of the 24th instant, I have to
                    confirm my telegram of the 28th instant, as follows: <quote rend="blockquote">
                        <p rend="flushleft">
                            <hi rend="italic">Assistant Secretary of State, Washington:</hi>
                        </p>
                        <p>Sanguily sentenced life imprisonment. Appeal to be taken.</p>
                        <p rend="right">
                            <hi rend="smallcaps">Lee.</hi>
                        </p>
                    </quote>
                </p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Fitzhugh Lee</hi>,<lb/>
                        <hi rend="italic">Consul-General.</hi>
                    </signed>
                </closer>
            </div>
        </body>
