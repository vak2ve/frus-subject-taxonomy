                subtype="historical-document" type="document" xml:id="d566">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Brice</persName> to Mr. <persName
                            type="to">Rockhill</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Consulate of the United States</hi>,<lb/>
                            <hi rend="italic">Matanzas</hi>
                        </placeName>, <date calendar="gregorian" when="1897-01-15">
                            <hi rend="italic">January 15, 1897</hi>
                        </date>. (Received January 21.)</dateline>
                    <seg rendition="#left">No. 76.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to report the following,
                    viz:</p>
                <p>Oscar Cespedes, American citizen confined in prison since last September in
                    Matanzas, has been transferred to Habana January 11, 1897. I visited him
                    frequently while here, and the encouragement given him has very materially
                    improved his health. I sincerely trust he will soon be released.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">A. C. Brice</hi>,<lb/>
                        <hi rend="italic">United States Consul.</hi>
                    </signed>
                </closer>
            </div>
        </body>
