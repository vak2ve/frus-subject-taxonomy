                subtype="historical-document" type="document" xml:id="d825">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Terrell</persName> to Mr. <persName
                            type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Constantinople</hi>
                        </placeName>, <date calendar="gregorian" when="1897-01-11">
                            <hi rend="italic">January 11, 1897</hi>
                        </date>.</dateline>
                </opener>
                <p>I have obtained telegraphic orders to withdraw the guard at Bitlis on request of
                    missionaries there.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Terrell.</hi>
                    </signed>
                </closer>
            </div>
        </body>
