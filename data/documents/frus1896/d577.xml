    <text>
        <body>
            <div frus:doc-dateTime-max="1896-03-14T23:59:59-05:00"
                frus:doc-dateTime-min="1896-03-14T00:00:00-05:00" n="577"
                subtype="historical-document" type="document" xml:id="d577">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Dupuy de Lôme</persName> to Mr.
                            <persName type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Spain</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-03-14">
                            <hi rend="italic">March 14, 1896</hi>
                        </date>.</dateline>
                </opener>
                <p>Mr. <hi rend="smallcaps">Secretary</hi>: I have the honor to state to your
                    excellency that your note No. 100, of the 13th instant, has reached my hands,
                    with the copy you send me of the letter which Messrs. C. Atkins &amp; Co., of
                    Boston, addressed to you, giving an account of the destruction of certain cane
                    fields.</p>
                <p>I avail, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">E. Dupuy de Lôme.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
