<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1896-11-28T23:59:59-05:00" frus:doc-dateTime-min="1896-11-28T00:00:00-05:00" n="562" subtype="historical-document" type="document" xml:id="d562">
                        <head><hi rend="italic">Mr. <persName type="from">Brice</persName> to Mr.
                                    <persName type="to">Olney</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Matanzas</hi></placeName>, <date calendar="gregorian" when="1896-11-28"><hi rend="italic">November 28,
                                    1896</hi></date>.</dateline></opener>
                        <p>Report Cespedes case mailed yesterday. Interview governor no definite
                            reasons given. Have protested.</p>
                        <closer><signed><hi rend="smallcaps">Brice.</hi></signed></closer>
                    </div>
                    </body></text></TEI>