<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1896-02-29T23:59:59-05:00" frus:doc-dateTime-min="1896-02-29T00:00:00-05:00" n="615" subtype="historical-document" type="document" xml:id="d615">
                        <head><hi rend="italic">Mr. <persName type="from">Dupuy de Lôme</persName>
                                to Mr. <persName type="to">Olney</persName>.</hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Legation of Spain at Washington</hi></placeName>,<lb/><date calendar="gregorian" when="1896-02-29"><hi rend="italic">February 29, 1896</hi></date>.</dateline></opener>
                        <p>Mr. <hi rend="smallcaps">Secretary</hi>: I have the honor to acknowledge
                            the receipt of your excellency’s note No. 89 of the 26th instant,
                            inclosing copy of a letter and various documents relative to Messrs. E.
                            Atkins &amp; Co.</p>
                        <p>I avail, etc.,</p>
                        <closer><signed><hi rend="smallcaps">E. Dupuy de
                            Lôme.</hi></signed></closer>
                    </div>
                </body></text></TEI>