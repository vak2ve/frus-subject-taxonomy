    <text>
        <body>
            <div frus:doc-dateTime-max="1896-07-25T23:59:59-05:00" frus:doc-dateTime-min="1896-07-25T00:00:00-05:00" n="105" subtype="historical-document" type="document" xml:id="d105">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Rockhill</persName> to Mr.
                                    <persName type="to">Patenôtre</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-07-25">
                            <hi rend="italic">July 25,
                                1896</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 69.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to acknowledge the
                            receipt of your note of the 22d instant, stating that Madagascar has
                            been declared a French colony by a law which implies the abrogation of
                            the treaties signed by the Hova Government, and substitutes for those
                            the conventions existing between the United States and France.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. W. Rockhill</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
