                subtype="historical-document" type="document" xml:id="d626">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Rockhill</persName> to Mr. <persName
                            type="to">Lee</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>
                        </placeName>,<lb/>
                        <date calendar="gregorian" when="1896-08-18">
                            <hi rend="italic">August 18, 1896</hi>
                        </date>.</dateline>
                </opener>
                <p>Newspaper advices from Key West of 16th state that Charles Govin, an American
                    citizen and correspondent, was captured near Jaruco by Spanish troops and put to
                    death. Investigate and report by cable.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Rockhill</hi>, <hi rend="italic">Acting.</hi>
                    </signed>
                </closer>
            </div>
        </body>
