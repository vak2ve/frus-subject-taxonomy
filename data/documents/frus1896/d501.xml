                <head>
                    <hi rend="italic">Mr. <persName type="from">Knight</persName> to Mr. <persName
                            type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Cape Town</hi>
                        </placeName>, <date calendar="gregorian" when="1896-06-11">
                            <hi rend="italic">June 11, 1896</hi>
                        </date>.</dateline>
                </opener>
                <p>Reform leaders released. Fined £25,000. No banishment.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Knight.</hi>
                    </signed>
                </closer>
            </div>
        </body>
