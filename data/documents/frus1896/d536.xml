                subtype="historical-document" type="document" xml:id="d536">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Taylor</persName> to Mr. <persName
                            type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">San Sebastian</hi>
                        </placeName>, <date calendar="gregorian" when="1896-10-11">
                            <hi rend="italic">October 11, 1896</hi>
                        </date>. (Received Oct. 26.)</dateline>
                    <seg rendition="#left">No. 572.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that I have
                    received from the minister of state a note dated the 8th ultimo, informing me
                    that on the 17th of July last the military authorities of the Island of Cuba
                    transferred the proceedings against the American citizen Francis J. Larrieu to
                    the ordinary or civil jurisdiction.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hannis Taylor.</hi>
                    </signed>
                </closer>
            </div>
        </body>
