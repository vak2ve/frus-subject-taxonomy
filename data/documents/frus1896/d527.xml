    <text>
        <body>
            <div frus:doc-dateTime-max="1896-06-02T23:59:59-05:00"
                frus:doc-dateTime-min="1896-06-02T00:00:00-05:00" n="527"
                subtype="historical-document" type="document" xml:id="d527">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Armstrong</persName> to Mr.
                            <persName type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1896-06-02">
                            <hi rend="italic">June 2, 1896</hi>
                        </date>. (Received June 15.)</dateline>
                    <seg rendition="#left">No. 527.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your No. 506, of the 13th ultimo, to Minister Taylor, relative to the detention
                    of George Calvar and Peter Duarte, citizens of the United States, by the Spanish
                    military authorities in Cuba in violation of the treaty of 1795 and the protocol
                    of January 12, 1877, and to inform you that the case has been duly presented to
                    the Spanish Government.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">H. Clay Armstrong</hi>, Jr.,<lb/>
                        <hi rend="italic">Chargé d’Affaires ad interim.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
