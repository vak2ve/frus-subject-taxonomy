                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr. <persName
                            type="to">Williams</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-05-11">
                            <hi rend="italic">May 11, 1896</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="italic">Competitor</hi> case. Execution of death sentences upon
                    American citizens suspended pending diplomatic consideration of their rights
                    under treaty and protocol.</p>
            </div>
        </body>
