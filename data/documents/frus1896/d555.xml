                subtype="historical-document" type="document" xml:id="d555">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Rockhill</persName> to Mr. <persName
                            type="to">Delgado</persName>, United States vice-consul in charge.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-09-11">
                            <hi rend="italic">September 11, 1896</hi>
                        </date>.</dateline>
                </opener>
                <p>Reported to Department Oscar Cespedes, confined in Matanzas castle, is American
                    citizen. Investigate and report by cable.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Rockhill.</hi>
                    </signed>
                </closer>
            </div>
        </body>
