                subtype="historical-document" type="document" xml:id="d631">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Rockhill</persName> to Mr. <persName
                            type="to">Lee</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-09-05">
                            <hi rend="italic">September 5, 1896</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has received your dispatch No.
                    106, of the 29th ultimo, with inclosures, relative to the fate of Charles Govin,
                    a citizen of the United States, and in reply you are instructed to press
                    unremittingly for a full investigation and a report in this matter.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. W. Rockhill</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
