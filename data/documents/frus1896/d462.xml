<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1896-01-18T23:59:59-05:00" frus:doc-dateTime-min="1896-01-18T00:00:00-05:00" n="462" subtype="historical-document" type="document" xml:id="d462">
                        <head><hi rend="italic">Mr. <persName type="from">Knight</persName> to Mr.
                                    <persName type="to">Olney</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Cape
                                        Town</hi></placeName>, <date calendar="gregorian" when="1896-01-18"><hi rend="italic">January 18,
                                1896</hi></date>.</dateline></opener>
                        <p>Authorize me proceed Pretoria, seat of Government; not Johannesburg, Also
                            take legal adviser.</p>
                        <closer><signed><hi rend="smallcaps">Knight.</hi></signed></closer>
                    </div>
                    </body></text></TEI>