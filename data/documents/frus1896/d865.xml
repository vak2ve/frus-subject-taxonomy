<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1896-04-25T23:59:59-05:00" frus:doc-dateTime-min="1896-04-25T00:00:00-05:00" n="865" subtype="historical-document" type="document" xml:id="d865">
                        <head><hi rend="italic">Mr. <persName type="from">Riddle</persName> to Mr.
                                    <persName type="to">Olney</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Pera</hi></placeName>, <date calendar="gregorian" when="1896-04-25"><hi rend="italic">April 25,
                                1896</hi>.</date></dateline></opener>
                        <p>Knapp was this morning delivered by Turkish authorities to American
                            consular agent at Alexandretta.</p>
                        <closer><signed><hi rend="smallcaps">Riddle.</hi></signed></closer>
                    </div>
