                <head>
                    <hi rend="italic">Mr. <persName type="from">Riddle</persName> to Mr. <persName
                            type="to">Olney</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Pera</hi>
                        </placeName>, <date calendar="gregorian" when="1896-04-25">
                            <hi rend="italic">April 25, 1896</hi>.</date>
                    </dateline>
                </opener>
                <p>Knapp was this morning delivered by Turkish authorities to American consular
                    agent at Alexandretta.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Riddle.</hi>
                    </signed>
                </closer>
            </div>
        </body>
