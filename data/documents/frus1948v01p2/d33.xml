<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Secretary of Defense (
                        Forrestal
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1948v01p2</bibl><bibl type="frus-document-id">d33</bibl><bibl type="frus-document-number">33</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1948-08-07T00:00:00-05:00" notAfter="1948-08-07T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1948-08-07T23:59:59-05:00" frus:doc-dateTime-min="1948-08-07T00:00:00-05:00" n="33" subtype="historical-document" type="document" xml:id="d33">
                <note rend="inline" type="source">811.24500/8–748</note>
                <head>
                    <hi rend="italic">The Secretary of Defense</hi> (<persName type="from">
                        <hi rend="italic">Forrestal</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1948-08-07">7 August
                            1948</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Secretary</hi>: In response to your suggestion
                    that a review of the negotiations for base rights at this time would be
                        appropriate,<note n="1" xml:id="d33fn1">The suggestion under reference has
                        not been further identified.</note> I referred the matter to the Joint
                    Chiefs of Staff for comment and recommendation.</p>
                <p>The views of the Joint Chiefs of Staff are set forth in the enclosure which
                    incorporates the changes contained in recent planning.</p>
                <p>Sincerely yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Forrestal</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
