                        <cell>1989</cell>
                        <cell>1990</cell>
                    </row>
                    <row>
                        <cell/>
                        <cell cols="4">(dollars in thousands)</cell>
                    </row>
                    <row>
                        <cell>
                            <gloss target="#t_CIA_1">CIA</gloss> Program</cell>
                        <cell>9,937<note n="4" xml:id="d46fn4">[<hi rend="italic">footnote not
                                    declassified</hi>]</note>
                        </cell>
                        <cell>8,971</cell>
                        <cell>9,558</cell>
                        <cell>9,965</cell>
                    </row>
                    <row>
                        <cell>Reprogramming</cell>
                        <cell>1,000</cell>
                        <cell>—</cell>
                        <cell>—</cell>
                        <cell>—</cell>
                    </row>
                    <row>
                        <cell>Reserve</cell>
                        <cell>—</cell>
                        <cell>3,000</cell>
                        <cell/>
                        <cell>—</cell>
                    </row>
                    <row>
                        <cell>Adjustment to <gloss target="#t_FY_1">FY</gloss> 1989–<gloss target="#t_FY_1">FY</gloss> 1990 Program</cell>
                        <cell/>
                        <cell/>
