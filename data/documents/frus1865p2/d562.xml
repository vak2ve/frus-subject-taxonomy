                        </row>
                        <row>
                            <cell cols="3">Out of which we have paid—</cell>
                        </row>
                        <row>
                            <cell>To claimants</cell>
                            <cell rendition="#nowrap #bottom" role="num">$489,694 78</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell>M. Rooney’s claim</cell>
