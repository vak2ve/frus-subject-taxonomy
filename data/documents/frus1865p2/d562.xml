                            <cell rendition="#nowrap #bottom" role="num">18,508 01</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell>And deposited in the Oriental Bank Corporation, at Hong Kong, as
                                per accompanying memorandum of receipts, marked A.</cell>
                            <cell rendition="#nowrap #bottom #border-bottom" role="num">220,000
                                00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell/>
                            <cell/>
