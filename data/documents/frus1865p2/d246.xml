    <text>
        <body>
            <div frus:doc-dateTime-max="1865-05-16T23:59:59-05:00"
                frus:doc-dateTime-min="1865-05-16T00:00:00-05:00" n="246"
                subtype="historical-document" type="document" xml:id="d246">
                <head>
                    <persName type="from">Sir F. Bruce</persName> to <persName type="to">Mr.
                        Hunter</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-05-16">
                            <hi rend="italic">May</hi> 16, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I am instructed to forward the enclosed
                        letter,<note n="*" xml:id="d246fn1">Transmitted to Mrs. Lincoln.</note>
                    addressed by her Majesty the Queen to the honorable Mrs. Lincoln, and I shall
                    feel obliged if you will cause it to be delivered to that lady without
                    delay.</p>
                <p>I have the honor to be, with the highest consideration, sir, your most obedient,
                    humble servant,</p>
                <closer>
                    <signed>FREDERICK W. A. BRUCE.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William Hunter,</hi>
                        <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
