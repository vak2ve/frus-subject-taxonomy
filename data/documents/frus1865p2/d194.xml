    <text>
        <body>
            <div frus:doc-dateTime-max="1865-03-29T23:59:59-05:00" frus:doc-dateTime-min="1865-03-29T00:00:00-05:00" n="194" subtype="historical-document" type="document" xml:id="d194">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Burnley</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-03-29">
                            <hi rend="italic">March</hi> 29, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have the honor to acknowledge the
                            receipt of your note of the 27th instant, announcing to me that you had
                            communicated to Earl Russell a copy of my note of the 8th ultimo,
                            relative to the reported organization at Cape Vincent for the purpose of
                            marauding upon Canadian territory.</p>
                <p>I have the honor to be, with the highest consideration, sir, your
                            obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>J. <hi rend="smallcaps">Hume Burnley,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
