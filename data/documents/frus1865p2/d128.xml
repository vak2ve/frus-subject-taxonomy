<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-02-17T23:59:59-05:00" frus:doc-dateTime-min="1865-02-17T00:00:00-05:00" n="128" subtype="historical-document" type="document" xml:id="d128">
                        <head><persName type="from">Mr. Burnley</persName> to <persName type="to">Mr. Seward</persName></head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">British Legation,</hi></placeName>
                                <date calendar="gregorian" when="1865-02-17"><hi rend="italic">February</hi> 17, 1865.</date></dateline></opener>
                        <p><hi rend="smallcaps">My Dear Sir</hi>: The lieutenant governor of New
                            Brunswick telegraphs this morning that “Linus Seely, one of the
                            Chesapeake captors, has been arrested at St. John.”</p>
                        <p>Very faithfully yours,</p>
                        <closer>
                            <signed>J. HUME BURNLEY.</signed></closer>
                        <postscript>
                            <p>Hon. <hi rend="smallcaps">William H. Seward,</hi>
                                <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                        </postscript>
                    </div>
                    </body></text></TEI>