    <text>
        <body>
            <div frus:doc-dateTime-max="1865-06-01T23:59:59-05:00"
                frus:doc-dateTime-min="1865-06-01T00:00:00-05:00" n="271"
                subtype="historical-document" type="document" xml:id="d271">
                <head>
                    <persName type="from">Sir F. Bruce</persName> to <persName type="to">Mr.
                        Hunter</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-06-01">
                            <hi rend="italic">June</hi> 1, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: At the request of the mayor of South port,
                    Lancashire, England, I have the honor to forward to you, for the United States
                    government and for Mrs. Lincoln, copies of resolutions<note n="*"
                        xml:id="d271fn1">See Appendix, separate volume.</note> passed at a public
                    meeting of the inhabitants of that town, expressive of the deep regret and
                    indignation which the recent lamentable events in the United States have
                    occasioned.</p>
                <p>I have the honor to be, with the highest consideration, sir, your most obedient,
                    humble servant,</p>
                <closer>
                    <signed>FREDERICK W. A. BRUCE.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">W. Hunter,</hi>
                        <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
