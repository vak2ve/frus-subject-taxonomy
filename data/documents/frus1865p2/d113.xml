<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-02-08T23:59:59-05:00" frus:doc-dateTime-min="1865-02-08T00:00:00-05:00" n="113" subtype="historical-document" type="document" xml:id="d113">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Burnley</persName></head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1865-02-08"><hi rend="italic">February</hi> 8, 1865.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have had the honor to receive your
                            communication of the 4th instant, relative to the extradition of Bennet
                            Gr. Burley.</p>
                        <p>I have the honor to be, sir, with the highest consideration, your
                            obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p>J. <hi rend="smallcaps">Hume Burnley,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                        </postscript>
                    </div>
                    </body></text></TEI>