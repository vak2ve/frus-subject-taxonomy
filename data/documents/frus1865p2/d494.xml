<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-06-05T23:59:59-05:00" frus:doc-dateTime-min="1865-06-05T00:00:00-05:00" n="494" subtype="historical-document" type="document" xml:id="d494">
                        <head><persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                                Clay</persName></head>
                        <opener>
                            <seg rendition="#left">No. 159.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of
                                    State,Washington,</hi></placeName>
                                <date calendar="gregorian" when="1865-06-05"><hi rend="italic">June</hi> 5, 1865.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> I have received your despatch of the 12th
                            ultimo, No. 80, relative to the death of Abraham Lincoln, and the
                            circumstances under which President Johnson occupies the presidential
                            chair.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>W. HUNTER, <hi rend="italic">Acting
                            Secretary.</hi></signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Cassius M. Clay,</hi> Esq., <hi rend="italic">&amp;c.,&amp;c.,&amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>