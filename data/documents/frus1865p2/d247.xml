<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-05-16T23:59:59-05:00" frus:doc-dateTime-min="1865-05-16T00:00:00-05:00" n="247" subtype="historical-document" type="document" xml:id="d247">
                        <head><persName type="from">Mr. Hunter</persName> to <persName type="to">Sir
                                F. Bruce</persName></head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1865-05-16"><hi rend="italic">May</hi> 16, 1865.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your note of this date, and of the letter addressed by her
                            Majesty the Queen to the honorable Mrs. Lincoln, enclosed therein, and
                            to inform you that, in compliance with your request, it has been
                            delivered to Mrs. Lincoln.</p>
                        <p>I have the honor to be, with the highest consideration, sir, your
                            obedient servant,</p>
                        <closer>
                            <signed>W. HUNTER, <hi rend="italic">Acting
                            Secretary.</hi></signed></closer>
                        <postscript>
                            <p>Hon. <hi rend="smallcaps">Sir Frederick W. A. Bruce,</hi>
                                <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                        </postscript>
                    </div>
                    </body></text></TEI>