    <text>
        <body>
            <div frus:doc-dateTime-max="1865-06-05T23:59:59-05:00"
                frus:doc-dateTime-min="1865-06-05T00:00:00-05:00" n="422"
                subtype="historical-document" type="document" xml:id="d422">
                <head>
                    <persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                        Bigelow</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 162.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-06-05">
                            <hi rend="italic">June</hi> 5, 1865,</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Tour despatch No. 91, of the 11th ultimo, with
                    its accompanying copy of a note which you addressed to Mr. Drouyu de Lhuys,
                    relative to the policy of France in according to the insurgents belligerent
                    rights, has been received, and, in reply, I have to inform you that the manner
                    in which you treated the subject in your communication is approved.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>W. HUNTER, <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">John Bigelow,</hi> Esq., <hi rend="italic">&amp;c.,
                            &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
