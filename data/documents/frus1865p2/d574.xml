<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-08-25T23:59:59-05:00" frus:doc-dateTime-min="1865-08-25T00:00:00-05:00" n="574" subtype="historical-document" type="document" xml:id="d574">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Williams</persName></head>
                        <opener>
                            <seg rendition="#left">No. 1.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1865-08-25"><hi rend="italic">August</hi> 25, 1865.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> Your interesting despatch of the 25th of
                            May, No. 1, has been received, and your proceedings therein mentioned
                            are approved.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H SEWARD.</signed>
                            <signed>S. <hi rend="smallcaps">Wells Williams,</hi> Esq., <hi rend="italic">&amp;c.,&amp;c.,&amp;c</hi></signed>
                        </closer>
                    </div>
                    </body></text></TEI>