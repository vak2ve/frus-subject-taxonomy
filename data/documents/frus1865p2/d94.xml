<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-01-25T23:59:59-05:00" frus:doc-dateTime-min="1865-01-25T00:00:00-05:00" n="94" subtype="historical-document" type="document" xml:id="d94">
                        <head><persName type="from">Mr. Burnley</persName> to <persName type="to">Mr. Seward</persName></head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1865-01-25"><hi rend="italic">January</hi> 25, 1865.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge receipt of
                            your note of the 23d instant, and inform you that a copy of it shall be
                            communicated to the proper authorities.</p>
                        <p>I have the honor to be, with the highest consideration, sir, your most
                            obedient, humble servant,</p>
                        <closer>
                            <signed>J. HUME BURNLEY.</signed></closer>
                        <postscript>
                            <p>Hon. <hi rend="smallcaps">William H. Seward,</hi>
                                <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                        </postscript>
                    </div>
                    </body></text></TEI>