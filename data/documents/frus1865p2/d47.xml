    <text>
        <body>
            <div frus:doc-dateTime-max="1864-12-28T23:59:59-05:00" frus:doc-dateTime-min="1864-12-28T00:00:00-05:00" n="47" subtype="historical-document" type="document" xml:id="d47">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Burnley</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1864-12-28">
                            <hi rend="italic">December</hi> 28, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your note of the 13th instant, submitting for consideration a
                            proposition to bring the vessel James Douglas to New York, in order that
                            a settlement may be effected with the owners, and, in reply, to inform
                            you that I have invited the attention of the Secretary of the Navy to
                            the matter.</p>
                <p>Accept the assurances of my high consideration.</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>J. <hi rend="smallcaps">Hume Burnley,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
