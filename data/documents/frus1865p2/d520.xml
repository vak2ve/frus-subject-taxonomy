    <text>
        <body>
            <div frus:doc-dateTime-max="1865-06-03T23:59:59-05:00"
                frus:doc-dateTime-min="1865-06-03T00:00:00-05:00" n="520"
                subtype="historical-document" type="document" xml:id="d520">
                <head>
                    <persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                        Pike</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 241.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-06-03">
                            <hi rend="italic">June</hi> 3,1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have received your despatch of the 17th ultimo,
                    No. 166, together with a copy of a note which you addressed to the minister of
                    foreign affairs on the reception of the news of the surrender of the remaining
                    military forces of the insurgents, and it is fully approved by this
                    department.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>W. HUNTER, <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">James</hi> S. <hi rend="smallcaps">Pike,</hi> Esq., <hi
                            rend="italic">&amp;c.,&amp;c.,&amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
