    <text>
        <body>
            <div frus:doc-dateTime-max="1865-02-11T23:59:59-05:00" frus:doc-dateTime-min="1865-02-11T00:00:00-05:00" n="120" subtype="historical-document" type="document" xml:id="d120">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Burnley</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-02-11">
                            <hi rend="italic">February</hi> 11, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that it is
                            considered desirable that the labors of the fishery commission,
                            organized under the 1st article of the treaty of the 5th of June, 1854,
                            be brought to a close at as early a season as may be convenient.</p>
                <p>I have the honor to be, with the highest consideration, sir, your
                            obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>J. <hi rend="smallcaps">Hume Burnley,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                </postscript>
            </div>
        </body>
