    <text>
        <body>
            <div frus:doc-dateTime-max="1865-05-16T23:59:59-05:00"
                frus:doc-dateTime-min="1865-05-16T00:00:00-05:00" n="514"
                subtype="historical-document" type="document" xml:id="d514">
                <head>
                    <hi rend="italic">
                        <persName>Mr. Hunter</persName> to <persName>Mr. Pike</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 236.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-05-16">
                            <hi rend="italic">May</hi> 16, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have received your despatch of the 27th ultimo,
                    No. 163, and felicitate myself upon being able to inform you of the improved
                    health of both the Secretary of State and his son, the Assistant Secretary.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>W. HUNTER, <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">James</hi> S. <hi rend="smallcaps">Pike,</hi> Esq., <hi
                            rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
