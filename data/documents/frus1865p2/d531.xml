    <text>
        <body>
            <div frus:doc-dateTime-max="1865-11-06T23:59:59-05:00" frus:doc-dateTime-min="1865-11-06T00:00:00-05:00" n="531" subtype="historical-document" type="document" xml:id="d531">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Pike</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 257.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-11-06">
                            <hi rend="italic">November</hi> 6, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir: You</hi> will excuse my delay in acknowledging
                            your despatch of May 31, No. 168. Your proceedings therein referred to
                            are approved, and your obser vations upon the European sentiment towards
                            the United States are appreciated.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">James</hi> S. <hi rend="smallcaps">Pike,</hi>
                                Esq., <hi rend="italic">&amp;c.,&amp;c.,&amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
