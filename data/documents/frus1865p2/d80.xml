    <text>
        <body>
            <div frus:doc-dateTime-max="1865-01-17T23:59:59-05:00"
                frus:doc-dateTime-min="1865-01-17T00:00:00-05:00" n="80"
                subtype="historical-document" type="document" xml:id="d80">
                <head>
                    <persName type="from">Mr. Burnley</persName> to <persName type="to">Mr.
                        Seward</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-01-17">
                            <hi rend="italic">January</hi> 17, 1865,</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have the honor to acknowledge the receipt of
                    your letter of the 14th instant, and to inform you, in reply, that copies of it
                    shall be forwarded to her Majesty’s government and to the lieutenant governor of
                    Bermuda.</p>
                <p>I have the honor to be, with the highest respect, sir, your most obedient, humble
                    servant,</p>
                <closer>
                    <signed>J, HUME BURNLEY.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William H. Seward,</hi>
                        <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
