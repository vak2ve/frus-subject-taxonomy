    <text>
        <body>
            <div frus:doc-dateTime-max="1865-03-07T23:59:59-05:00" frus:doc-dateTime-min="1865-03-07T00:00:00-05:00" n="373" subtype="historical-document" type="document" xml:id="d373">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Bigelow</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 60.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-03-07">
                            <hi rend="italic">March</hi> 7, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have to acknowledge the receipt of your
                            very interesting despatch of the 9th ultimo, No. 24, informing me of the
                            opinion entertained by Prince Murat of the sudden departure of the King
                            of Italy from Turin for Florence.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">John Bigelow,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
