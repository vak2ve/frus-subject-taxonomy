<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-05-22T23:59:59-05:00" frus:doc-dateTime-min="1865-05-22T00:00:00-05:00" n="411" subtype="historical-document" type="document" xml:id="d411">
                        <head><persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                                Bigelow</persName></head>
                        <opener>
                            <seg rendition="#left">No. 154]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1865-05-22"><hi rend="italic">May</hi> 22, 1865.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> I transmit herewith, for your information,
                            a copy of a note of this date,<note n="*" xml:id="d411fn1">See
                                correspondence with the Spanish legation.</note> addressed to Mr.
                            Tassara, the Spanish minister, relative to the proceedings of the
                            piratical cruiser Stonewall.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>W. HUNTER, <hi rend="italic">Acting
                            Secretary.</hi></signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">John Bigelow,</hi> Esq. <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>