    <text>
        <body>
            <div frus:doc-dateTime-max="1865-07-03T23:59:59-05:00"
                frus:doc-dateTime-min="1865-07-03T00:00:00-05:00" n="430"
                subtype="historical-document" type="document" xml:id="d430">
                <head>
                    <persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                        Bigelow</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 189.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-07-03">
                            <hi rend="italic">July</hi> 3, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I enclose for your information a copy of a letter
                    of the 22d ultimo,<note n="*" xml:id="d430fn1">See enclosure to instructions No.
                        1473 to Mr. Adams.</note> addressed by the Secretary of the Navy to
                    Rear-Admiral Groldsborough, upon the subject of the withdrawal from the
                    insurgents of the character of belligerents, and the proceedings of the Navy
                    Department in view thereof.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>W. HUNTER, <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">John Bigelow,</hi> Esq., <hi rend="italic">&amp;c.,
                            &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
