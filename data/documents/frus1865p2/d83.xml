    <text>
        <body>
            <div frus:doc-dateTime-max="1865-01-19T23:59:59-05:00" frus:doc-dateTime-min="1865-01-19T00:00:00-05:00" n="83" subtype="historical-document" type="document" xml:id="d83">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Burnley</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-01-19">
                            <hi rend="italic">January</hi> 19,1865.</date>
                    </dateline>
                </opener>
                <p>My <hi rend="smallcaps">Dear Sir</hi>: I give you, herewith, for your
                            information, a copy of a despatch which, on the 16th instant, I
                            addressed to Mr. Adams at London.<note n="*" xml:id="d83fn1">See
                                despatch No. 1237 to Mr. Adams, current series.</note>
                </p>
                <p>Believe me to be, my dear sir, very faithfully yours,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>J. <hi rend="smallcaps">Hume Burnley,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
