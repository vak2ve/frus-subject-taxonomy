<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-04-20T23:59:59-05:00" frus:doc-dateTime-min="1865-04-20T00:00:00-05:00" n="398" subtype="historical-document" type="document" xml:id="d398">
                        <head><persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                                Bigelow</persName></head>
                        <opener>
                            <seg rendition="#left">No. 115.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1865-04-20"><hi rend="italic">April</hi> 20, 1865.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> I have to acknowledge the receipt of your
                            despatch of the 4th instant, No. 67, including copies of certain
                            documents which you have received from Mr. Wood, our minister at
                            Copenhagen, relative to the delivery of the steamer Stonewall, alias
                            Olinde, to officers of the insurgent navy.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>W. HUNTER, <hi rend="italic">Acting
                            Secretary.</hi></signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">John Bigelow,</hi> Esq., <hi rend="italic">&amp;c.,&amp;c.,&amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>