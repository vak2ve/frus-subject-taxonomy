                <note rend="inline" type="source">123 C 12/140: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName type="from">
                        <hi rend="italic">Warren</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1921-11-04T10:00:00+09:00">
                            <hi rend="italic">November 4, 1921—10 a.m.</hi>
                        </date>
                        <lb/>[Received November 4—3:41 a.m.]</dateline>
                </opener>
                <p>369. My 367, November 1, 10 a.m.<note n="55" xml:id="d710fn55">Not
                        printed.</note> Caldwell arrived Chita November 2.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Warren</hi>
                    </signed>
                </closer>
            </div>
        </body>
