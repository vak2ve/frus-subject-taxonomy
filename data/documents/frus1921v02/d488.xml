<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1921-09-02T16:00:00-05:00" frus:doc-dateTime-min="1921-09-02T16:00:00-05:00" n="488" subtype="historical-document" type="document" xml:id="d488">
                        <note rend="inline" type="source">817.00/2804: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Vice Consul in Charge at Blue fields</hi> (<persName type="to"><hi rend="italic">Waters</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1921-09-02T17:00:00-04:00"><hi rend="italic">September 2,
                                        1921—5 p.m.</hi></date></dateline></opener>
                        <p>Your August 31, 9 a.m. U.S.S. <hi rend="italic">Asheville</hi> due to
                            arrive Bluefields September 3d.</p>
                        <closer><signed><hi rend="smallcaps">Hughes</hi></signed></closer>
                    </div>
                    </body></text></TEI>