<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1921-07-29T16:00:00-05:00" frus:doc-dateTime-min="1921-07-29T16:00:00-05:00" n="143" subtype="historical-document" type="document" xml:id="d143">
                        <note rend="inline" type="source">667.003/132: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Consul General at Smyrna</hi> (<persName type="to"><hi rend="italic">Horton</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1921-07-29T17:00:00-04:00"><hi rend="italic">July 29,
                                        1921—5 p.m.</hi></date></dateline></opener>
                        <p>Your July 23rd, 8 a.m. Your action approved. Keep the Department
                            informed.</p>
                        <closer><signed><hi rend="smallcaps">Hughes</hi></signed></closer>
                    </div>
