                subtype="historical-document" type="document" xml:id="d338">
                <note rend="inline" type="source">882.51/1345b: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Liberia</hi> (<persName type="to">
                        <hi rend="italic">Johnson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1921-11-14T13:00:00-05:00">
                            <hi rend="italic">November 14, 1921—1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>28. President King and other members of the Plenary Commission are returning to
                    Liberia sailing November 15th from Boston on U.S.S. <hi rend="italic"
                        >Denver</hi> in command of Captain Kautz. The cruiser has been detailed for
                    this purpose by United States Government and should be about 16 days <hi
                        rend="italic">en route</hi>. You may make this public.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
