                <note rend="inline" type="source">701.6411/orig.: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Commissioner at Budapest</hi> (<persName type="to">
                        <hi rend="italic">Grant-Smith</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1921-12-23T15:00:00-05:00">
                            <hi rend="italic">December 23, 1921—3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>355. Your 355, December 17, 8 p.m.</p>
                <p>Szechenyi acceptable as Minister to this Government.<note n="7" xml:id="d256fn7"
                        >Count Széchényi presented his letters of credence Jan. 11, 1922.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
