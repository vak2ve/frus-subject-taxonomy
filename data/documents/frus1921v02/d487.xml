                subtype="historical-document" type="document" xml:id="d487">
                <note rend="inline" type="source">817.00/2804: Telegram</note>
                <head>
                    <hi rend="italic">The Vice Consul in Chargé at Bluefields</hi> (<persName
                        type="from">
                        <hi rend="italic">Waters</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bluefields</hi>
                        </placeName>, <date calendar="gregorian" when="1921-08-31T09:00:00-05:45">
                            <hi rend="italic">August 31, 1921—9 a.m.</hi>
                        </date>
                        <lb/>[Received September 1—noon.]</dateline>
                </opener>
                <p>War condition Atlantic coast such Nicaraguan Government officials suggest sending
                    war vessels here to protect American interests to avoid trouble.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Waters</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
