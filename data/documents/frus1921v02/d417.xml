    <text>
        <body>
            <div frus:doc-dateTime-max="1921-09-12T12:36:00-05:00"
                frus:doc-dateTime-min="1921-09-12T12:36:00-05:00" n="417"
                subtype="historical-document" type="document" xml:id="d417">
                <note rend="inline" type="source">812.52/724: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Mexico</hi> (<persName type="from">
                        <hi rend="italic">Summerlin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1921-09-12T11:00:00-06:36">
                            <hi rend="italic">September 12, 1921—11 a.m.</hi>
                        </date>
                        <lb/>[Received 3:06 p.m.]</dateline>
                </opener>
                <p>179. Your telegram number 123, September 10, 5 p.m.<note n="99" xml:id="d417fn99"
                        >Not printed.</note> The Foreign Office has not even acknowledged receipt of
                    Embassy’s representations concerning Durango and other agrarian laws.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Summerlin</hi>
                    </signed>
                </closer>
            </div>
        </body>
