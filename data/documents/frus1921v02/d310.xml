                subtype="historical-document" type="document" xml:id="d310">
                <note rend="inline" type="source">894c.111/19: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in China</hi> (<persName type="to">
                        <hi rend="italic">Crane</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1921-01-08T16:00:00-05:00">
                            <hi rend="italic">January 8, 1921—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>10. Statements quoted in last sentence of your telegram 8, January 6, 5 p.m.,
                    refer to Shantung and Antung Railways.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
