                <note rend="inline" type="source">661.1115/277: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Reval</hi> (<persName type="to">
                        <hi rend="italic">Albrecht</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1921-04-02T16:00:00-05:00">
                            <hi rend="italic">April 2, 1921—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your March 27, 2 p.m.</p>
                <p>You may receive informally and without comment any communication it is desired to
                    transmit.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
