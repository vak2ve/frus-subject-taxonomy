<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1921-12-17T14:00:00-05:00" frus:doc-dateTime-min="1921-12-17T14:00:00-05:00" n="254" subtype="historical-document" type="document" xml:id="d254">
                        <note rend="inline" type="source">701.6411/orig.; Telegram</note>
                        <head><hi rend="italic">The Commissioner at Budapest</hi> (<persName type="from"><hi rend="italic">Grant-Smith</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Budapest</hi></placeName>, <date calendar="gregorian" when="1921-12-17T20:00:00+01:00"><hi rend="italic">December 17,
                                        1921—8 p.m.</hi></date><lb/>[Received December 18—6:58
                                a.m.]</dateline></opener>
                        <p>355. Hungarian Minister for Foreign Affairs asks <hi rend="italic">agrément</hi> to Count Laszlo Szechenyi as Minister to the United
                            States.</p>
                        <closer><signed><hi rend="smallcaps">Grant-Smith</hi></signed></closer>
