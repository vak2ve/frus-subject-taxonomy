<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1921-04-16T14:00:00-05:00" frus:doc-dateTime-min="1921-04-16T14:00:00-05:00" n="628" subtype="historical-document" type="document" xml:id="d628">
                        <note rend="inline" type="source">423.11 L 23/318: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Peru</hi> (<persName type="to"><hi rend="italic">Gonzales</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1921-04-16T14:00:00-05:00"><hi rend="italic">April 16,
                                        1921—2 p.m.</hi></date></dateline></opener>
                        <p>23. Your 27, April 9, 9 a.m.</p>
                        <p>Department agrees to amendment Landreau protocol to provide for
                            Commission sitting in country third member or president of board.</p>
                        <closer><signed><hi rend="smallcaps">Hughes</hi></signed></closer>
                    </div>
                    </body></text></TEI>