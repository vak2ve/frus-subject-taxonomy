                subtype="historical-document" type="document" xml:id="d200">
                <note rend="inline" type="source">838.51/1073: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Haiti</hi> (<persName type="from">
                        <hi rend="italic">Bailly-Blanchard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1921-02-11T15:00:00-05:00">
                            <hi rend="italic">February 11, 1921—3 p.m.</hi>
                        </date>
                        <lb/>[Received 10:40 p.m.]</dateline>
                </opener>
                <p>11. Department’s 7, January 25th, 7 p.m. Customs receipts for January amount to
                    $272,000.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blanchard</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
