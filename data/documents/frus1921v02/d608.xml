                subtype="historical-document" type="document" xml:id="d608">
                <note rend="inline" type="source">823.51/191: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Peru</hi> (<persName type="from">
                        <hi rend="italic">Gonzales</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1921-09-23T14:00:00-05:00">
                            <hi rend="italic">September 23, 1921—2 p.m.</hi>
                        </date>
                        <lb/>[Received 5:15 p.m.]</dateline>
                </opener>
                <p>71. Your 48, September 22, 6 p.m. Cable instructions to Peruvian Ambassador to
                    sign contract going forward tomorrow.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gonzales</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
