                subtype="historical-document" type="document" xml:id="d631">
                <note rend="inline" type="source">423.11 L 23/329: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Peru</hi> (<persName type="from">
                        <hi rend="italic">Gonzales</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1921-06-21T15:00:00-05:00">
                            <hi rend="italic">June 21, 1921—3 p.m.</hi>
                        </date>
                        <lb/>[Received June 22—9:25 a.m.]</dateline>
                </opener>
                <p>50. Department’s 33, June 20, 4 p.m. Peruvian Government has appointed Señor
                    Carlos Prevost Commissioner in Landreau arbitration.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gonzales</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
