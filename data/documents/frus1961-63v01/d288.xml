    <text>
        <body>
            <div frus:doc-dateTime-max="1961-11-28T19:37:00-05:00"
                frus:doc-dateTime-min="1961-11-28T19:37:00-05:00" n="288"
                subtype="historical-document" type="document" xml:id="d288">
                <head>288. Telegram From the <gloss type="from">Department of State</gloss> to the
                        <gloss type="to">Embassy in Vietnam</gloss>
                    <note n="1" type="source" xml:id="d288fn1">Source: Department of State, Central
                        Files, 751K.00/11-2861. Confidential; Niact. Drafted by <persName
                            corresp="#p_TRW1">Tubby</persName>; cleared by <persName
                            corresp="#p_TRW1">Tubby</persName> with Sylvester (Defense), <persName
                            corresp="#p_WD1">Wilson</persName> (<gloss target="#t_USIA1"
                            >USIA</gloss>), <persName corresp="#p_SP1">Salinger</persName> (White
                        House), and Heavner; and signed by <persName corresp="#p_TRW1"
                            >Tubby</persName> for the Secretary.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <hi rend="italic">
                            <placeName>Washington</placeName>, <date calendar="gregorian"
                                when="1961-11-28T19:37:00-05:00">November 28, 1961, 7:37 p.m.</date>
                        </hi>
                    </dateline>
                </opener>
                <p>698. State-Defense-<gloss target="#t_USIA1">USIA</gloss>. Supersedes all previous
                    messages.</p>
                <p>Do not give other than routine cooperation to correspondents on coverage current
                    military activities in Vietnam. No comment at all on classified activities.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_RD1">
                            <hi rend="strong">Rusk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
