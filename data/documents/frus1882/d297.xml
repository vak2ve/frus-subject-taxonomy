    <text>
        <body>
            <div frus:doc-dateTime-max="1882-05-11T23:59:59-05:00" frus:doc-dateTime-min="1882-05-11T00:00:00-05:00" n="297" subtype="historical-document" type="document" xml:id="d297">
                <head>
                    <hi rend="italic">Señor <persName type="from">Mariscal</persName> to
                                Señor <persName type="to">Romero</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Translation.—Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">City of
                                        Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1882-05-11">
                            <hi rend="italic">May</hi> 11,
                                1882</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">To Mexican Minister</hi>,<lb/>
                    <hi rend="italic">Washington:</hi>
                </p>
                <p>The Senate has authorized the Executive to allow crossing of troops on
                            conditions communicated United States Government in November, 1880.</p>
                <closer>
                    <signed>MARISCAL.</signed>
                </closer>
            </div>
        </body>
    </text>
