                subtype="historical-document" type="document" xml:id="d382">
                <head>No. 318.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Frelinghuysen</persName> to Mr.
                            <persName type="to">Wallace</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1882-06-29">
                            <hi rend="italic">June</hi> 29, 1882</date>.</dateline>
                    <seg rendition="#left">No. 68.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Your dispatch No. 96, of the 6th instant,
                    inclosing copy of your protest in reply to the note verbal of the Ottoman
                    Government, prohibiting the importation therein of American salt meats, has been
                    received, and your timely action is approved.</p>
                <p>I am, &amp;c.,</p>
                <closer>
                    <signed>FRED’K T. FRELINGHUYSEN.</signed>
                </closer>
            </div>
        </body>
