    <text>
        <body>
            <div frus:doc-dateTime-max="1882-08-18T23:59:59-05:00"
                frus:doc-dateTime-min="1882-08-18T00:00:00-05:00" n="400"
                subtype="historical-document" type="document" xml:id="d400">
                <head>No. 336.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Davis</persName> to Mr. <persName
                            type="to">Baker</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Extract.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1882-08-18">
                            <hi rend="italic">August</hi> 18, 1882</date>.</dateline>
                    <seg rendition="#left">No. 179.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                    dispatch No. 522, of the 31st ultimo, and to approve your representations to the
                    Venezuelan Government in the matter of the additional duty, which the Department
                    would be gratified to learn had been satisfactorily adjusted.</p>
                <p rend="center">* * * * * * *</p>
                <p>I am, &amp;c.,</p>
                <closer>
                    <signed>JOHN DAVIS,<lb/>
                        <hi rend="italic">Acting Secretary</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
