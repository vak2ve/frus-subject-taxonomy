<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1882-03-28T23:59:59-05:00" frus:doc-dateTime-min="1882-03-28T00:00:00-05:00" n="169" subtype="historical-document" type="document" xml:id="d169">
                    <head>No. 44.<lb/><hi rend="italic">Mr. <persName type="from">West</persName> to
                            Earl <persName type="to">Granville</persName>.</hi></head>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1882-03-28"><hi rend="italic">March</hi> 28, 1882</date>.
                            (Received April 10.)</dateline></opener>
                    <p><hi rend="smallcaps">My Lord</hi>: I have the honor to inclose herewith to
                        your lordship printed copies of the message of the President to the Senate,
                        transmitting papers relating to the imprisonment of Daniel McSweeney in
                        Ireland.</p>
                    <p>I have, &amp;c.,</p>
                    <closer><signed>L. S. SACKVILLE WEST.</signed></closer>
                    <pb facs="0331" n="259" xml:id="pg_259"/>
                    <frus:attachment>
                        <opener><seg rendition="#center">[Inclosure in No. 44.—Ex. Doc. No.
                                139.]</seg></opener>
                        <head><hi rend="smallcaps">Forty-seventh Congress, First session,
                                Senate.</hi></head>
                        <p rend="flushleft"><hi rend="italic">Message from the President of the
                                United States, transmitting, in response to Senate resolution of the
                                9th instant, a report from the Secretary of State, with accompanying
                                papers, relating to the alleged imprisonment by the British
                                Government of Daniel McSweeney, a citizen of the United
                            States.</hi></p>
                        <p rend="center">(Omitted.)</p>
                    </frus:attachment>
                </div>
                </body></text></TEI>