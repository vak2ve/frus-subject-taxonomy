                subtype="historical-document" type="document" xml:id="d136">
                <head>No. 11.<lb/>
                    <hi rend="italic">Earl <persName type="from">Granville</persName> to Mr.
                            <persName type="to">Drummond</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Foreign Office</hi>
                        </placeName>, <date calendar="gregorian" when="1881-07-09">
                            <hi rend="italic">July</hi> 9, 1881</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: With reference to my dispatch to Sir E. Thornton
                    of the 1st instant, I transmit, for your information, copies of a further
                    correspondence which has passed between Mr. Lowell and this department relative
                    to the arrest of Mr. Joseph B. Walsh.<note n="*" xml:id="d136fn1">Nos. 9 and
                        10.</note>
                </p>
                <p>I am, &amp;c.,</p>
                <closer>
                    <signed>GRANVILLE.</signed>
                </closer>
            </div>
        </body>
    </text>
