                <head>No. 35.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Frelinghuysen</persName> to Mr.
                            <persName type="to">Trescot</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1882-01-03">
                            <hi rend="italic">January</hi> 3, 1882</date>.</dateline>
                </opener>
                <p>Exert pacific influence. Avoid any issue leading to your withdrawal from
                    Chili.</p>
                <closer>
                    <signed>FRELINGHUYSEN.</signed>
                </closer>
            </div>
        </body>
