                subtype="historical-document" type="document" xml:id="d377">
                <head>No. 313.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Frelinghuysen</persName> to Mr.
                            <persName type="to">Wallace</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1882-05-12">
                            <hi rend="italic">May</hi> 12, 1882</date>.</dateline>
                    <seg rendition="#left">No. 56.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Acknowledging the receipt of your dispatch, No.
                    74, of March 21 last, I have to approve your therein reported action in
                    addressing to the Turkish Government a further note in relation to the excessive
                    collections of duty upon American alcohol.</p>
                <p>I am, &amp;c.,</p>
                <closer>
                    <signed>FRED’K T. FRELINGHUYSEN.</signed>
                </closer>
            </div>
        </body>
