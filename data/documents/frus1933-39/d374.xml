<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1937-07-14T01:00:00-05:00" frus:doc-dateTime-min="1937-07-14T01:00:00-05:00" n="374" subtype="historical-document" type="document" xml:id="d374">
                        <note rend="inline" type="source">611.6131/454: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in the Soviet Union</hi> (<persName corresp="#p_DJE1" type="from"><hi rend="italic">Davies</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Moscow</hi></placeName>, <date calendar="gregorian" when="1937-07-14T09:00:00+03:00">July 14,
                                    1937—9 a.m.</date>
                                <lb/> [Received July 14—5:32 a.m.]</dateline>
                        </opener>
                        <p>171. Department’s No. 90, July 12, 7 p.m. Reference made to Department’s
                            numbered sections.</p>
                        <list>
                            <label>1.</label>
                            <item>Text approved by Soviet officials.</item>
                            <label>2.</label>
                            <item>Changes acceptable to Soviet side.</item>
                            <label>3.</label>
                            <item>The word was telegraphed from Moscow.</item>
                            <label>4.</label>
                            <item>It was explained that agreement could enter into effect only on
                                the date of proclamation.</item>
                        </list>
                        <closer>
                            <signed>
                                <persName corresp="#p_DJE1">
                                    <hi rend="smallcaps">Davies</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>