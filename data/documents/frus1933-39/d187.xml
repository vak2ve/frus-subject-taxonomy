<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-02-06T13:00:00-05:00" frus:doc-dateTime-min="1935-02-06T13:00:00-05:00" n="187" subtype="historical-document" type="document" xml:id="d187">
                        <note rend="inline" type="source">121.5561/22a: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in the Soviet Union</hi> (<persName corresp="#p_WJC1" type="to"><hi rend="italic">Wiley</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1935-02-06T13:00:00-05:00">February
                                    6, 1935—1 p.m.</date>
                            </dateline>
                        </opener>
                        <p>26. The following announcement will be made to the press at 12:30 p.m.
                            today: <quote rend="blockquote">
                                <p>“The following changes in our representation in Moscow have been
                                    ordered:</p>
                                <p>The Naval Attaché will be withdrawn.</p>
                                <p>The Air Attaché will be withdrawn.</p>
                                <p>The Consulate General will be abolished.</p>
                                <p>Reductions will be made in the personnel of the Embassy.”</p>
                            </quote>
                        </p>
                        <p>Inform <persName corresp="#p_NDR1">Nimmer</persName> and <persName corresp="#p_WTD1">White</persName>.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_HC1">
                                    <hi rend="smallcaps">Hull</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>