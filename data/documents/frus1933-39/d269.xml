                subtype="historical-document" type="document" xml:id="d269">
                <note rend="inline" type="source">861.00 Congress, Communist International, VII/96:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in the Soviet Union</hi> (<persName
                        corresp="#p_BWC1" type="from">
                        <hi rend="italic">Bullitt</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Moscow</hi>
                        </placeName>, <date calendar="gregorian" when="1935-08-30T13:00:00+03:00"
                            >August 30, 1935—1 p.m.</date>
                        <lb/> [Received August 30—9:15 a.m.]</dateline>
                </opener>
                <p>401. The full resolutions of the Congress of the Communist International were
                    published yesterday by <hi rend="italic">Pravda</hi>. There is no important
                    reference to the United States. The resolution on <persName corresp="#p_DG1"
                        >Dimitrov</persName>’s report contains a full general program for world
                    revolution.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BWC1">
                            <hi rend="smallcaps">Bullitt</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
