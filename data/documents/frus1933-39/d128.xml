                subtype="historical-document" type="document" xml:id="d128">
                <note rend="inline" type="source">800.51W89 U.S.S.R./85a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the Soviet Union</hi> (<persName corresp="#p_BWC1" type="to">
                        <hi rend="italic">Bullitt</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-07-21T16:00:00-04:00"
                            >July 21, 1934—4 p.m.</date>
                    </dateline>
                </opener>
                <p>170. <persName corresp="#p_TAA1">Troyanovsky</persName> called at the Department
                    today and arrangements were made for a meeting at the Department on Wednesday
                    for a general discussion of the question of settlement of debts and claims.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HC1">
                            <hi rend="smallcaps">Hull</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
