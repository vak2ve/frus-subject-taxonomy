                <note rend="inline" type="source">801.00 Congress, Communist International, VII/53:
                    Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the Soviet Union</hi> (<persName corresp="#p_BWC1" type="to">
                        <hi rend="italic">Bullitt</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1935-08-19T18:00:00-04:00"
                            >August 19, 1935—6 p.m.</date>
                    </dateline>
                </opener>
                <p>188. Telegraph names and positions of officials of Soviet Government attending or
                    speaking at Congress of Communist International. Supplement by mail giving
                    published source in each instance.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HC1">
                            <hi rend="smallcaps">Hull</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
