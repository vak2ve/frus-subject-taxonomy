                subtype="historical-document" type="document" xml:id="d507">
                <note rend="inline" type="source">661.11241/15: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in the Soviet Union</hi> (<persName corresp="#p_DJE1"
                        type="to">
                        <hi rend="italic">Davies</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1938-04-29T20:00:00-04:00"
                            >April 29, 1938—8 p.m.</date>
                    </dateline>
                </opener>
                <p>63. Your despatch No. 1152, April 12, 1938.<note n="63" xml:id="d507fn63">Not
                        printed, but see Embassy’s telegram No. 89, March 28, 1938, 9 p.m., <ref
                            target="#pg_644">p. 644</ref>.</note> The Embassy may, in your
                    discretion, participate in the contemplated protest provided that the
                    representatives of all the great powers join in it.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WS1">
                            <hi rend="smallcaps">Welles</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
