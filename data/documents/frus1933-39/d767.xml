                subtype="historical-document" type="document" xml:id="d767">
                <note rend="inline" type="source">760p.6111/48: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in the Soviet Union</hi> (<persName
                        corresp="#p_SLA1" type="from">
                        <hi rend="italic">Steinhardt</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Moscow</hi>
                        </placeName>, <date calendar="gregorian" when="1939-10-05T21:00:00+03:00"
                            >October 5, 1939—9 p.m.</date>
                        <lb/> [Received October 5—6 p.m.]</dateline>
                </opener>
                <p>687. The Soviet-Latvian pact was signed this afternoon. Following a dinner at the
                    Kremlin the Latvian Foreign Minister left this evening by train for Riga. The
                    text of the pact is not yet available but is expected to be released tonight by
                    Tass.</p>
                <p>Repeated to Riga.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SLA1">
                            <hi rend="smallcaps">Steinhardt</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
