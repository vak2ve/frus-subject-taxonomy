<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-02-07T09:00:00-05:00" frus:doc-dateTime-min="1935-02-07T09:00:00-05:00" n="190" subtype="historical-document" type="document" xml:id="d190">
                        <note rend="inline" type="source">125.631/23: Telegram</note>
                        <head>
                            <hi rend="italic">The Chargé in the Soviet Union</hi> (<persName corresp="#p_WJC1" type="from"><hi rend="italic">Wiley</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Moscow</hi></placeName>, <date calendar="gregorian" when="1935-02-07T17:00:00+03:00">February
                                    7, 1935—5 p.m.</date>
                                <lb/> [Received February 7—11:30 a.m.]</dateline>
                        </opener>
                        <p>53. In compliance with your 27, February 6, 2 p.m., the Consulate General
                            has been abolished as of February 6, 1935, and Consular Section has been
                            opened as of February 7th, 1935.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_WJC1">
                                    <hi rend="smallcaps">Wiley</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>