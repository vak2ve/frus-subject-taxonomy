<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-04-12T13:00:00-05:00" frus:doc-dateTime-min="1934-04-12T13:00:00-05:00" n="78" subtype="historical-document" type="document" xml:id="d78">
                        <note rend="inline" type="source">800.51W89 U.S.S.R./31: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in the Soviet Union</hi> (<persName corresp="#p_BWC1" type="to"><hi rend="italic">Bullitt</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1934-04-12T13:00:00-05:00">April 12,
                                    1934—1 p.m.</date>
                            </dateline>
                        </opener>
                        <p>42. Your 50, April 10, 9 p.m. Customs courtesies are being arranged for
                                <persName corresp="#p_REV1">Rubinin</persName>. Department would
                            like to know the purpose of his visit to the United States.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_HC1">
                                    <hi rend="smallcaps">Hull</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>