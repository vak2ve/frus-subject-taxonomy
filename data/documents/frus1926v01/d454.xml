                <note rend="inline" type="source">893.00/7397: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in China</hi> (<persName type="to">
                        <hi rend="italic">MacMurray</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1926-05-17T15:00:00-04:00">
                            <hi rend="italic">May 17, 1926—3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>99. Authority requested in Paragraph 3 of your No. 208, May 14, 7 p.m.
                    granted.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
