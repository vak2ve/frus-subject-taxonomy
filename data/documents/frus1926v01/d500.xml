<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1926-10-05T20:00:00-05:00" frus:doc-dateTime-min="1926-10-05T20:00:00-05:00" n="500" subtype="historical-document" type="document" xml:id="d500">
                        <note rend="inline" type="source">393.1163/62: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of the
                                    State</gloss> to the Chargé in China</hi> (<persName type="to"><hi rend="italic">Mayer</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1926-10-05T20:00:00-05:00"><hi rend="italic">October 5,
                                        1926—8 p.m.</hi></date></dateline></opener>
                        <p>218. Tour 453, October 5, 10 a.m. Your recommendation approved. Five
                            hundred dollars allowance granted. Draw on Secretary of State. Render
                            separate account.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>