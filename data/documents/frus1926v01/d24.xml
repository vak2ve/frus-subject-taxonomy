                subtype="historical-document" type="document" xml:id="d24">
                <note rend="inline" type="source">500.C114/445j</note>
                <head>
                    <hi rend="italic">The Dominican Chargé</hi> (<persName type="from">
                        <hi rend="italic">Vasquez</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation<note n="26" xml:id="d24fn26">File
                            translation revised.</note>]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1926-08-30">
                            <hi rend="italic">August 30, 1926</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: In reply to your note of
                    February 12, last, I have the honor to inform Your Excellency that by a telegram
                    received <pb facs="0149" n="17" xml:id="pg_17"/> on this date I am instructed to
                    advise your Department that the Dominican Government will vote for the adhesion
                    of the United States to the Protocol of Signature and Bylaws of the Court of
                    International Justice, with the five reservations adopted in the Senate
                    resolution, and that instructions to that effect have been sent to the Dominican
                    delegate in the Assembly of the League of Nations.</p>
                <p>I avail myself [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">M. L. Vasquez</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
