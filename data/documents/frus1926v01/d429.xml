                subtype="historical-document" type="document" xml:id="d429">
                <note rend="inline" type="source">893.00/7166: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in China</hi> (<persName type="to">
                        <hi rend="italic">MacMurray</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1926-03-10T14:00:00-05:00">
                            <hi rend="italic">March 10, 1926—2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>57. Your telegram No. 119, March 9, 9 p.m. Attitude proposed by you in paragraph
                    3 is approved.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
