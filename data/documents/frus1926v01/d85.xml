                        <note rend="inline" type="source">500.A15/369: Telegram</note>
                        <head><hi rend="italic">The American Delegate on the Preparatory
                                Commission</hi> (<persName type="from"><hi rend="italic">Gibson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Geneva</hi></placeName>, <date calendar="gregorian" when="1926-09-20T11:00:00+01:00"><hi rend="italic">September 20,
                                        1926—11 a.m.</hi></date><lb/>[Received 2:05 a.m.
                                (p.m.?)]</dateline></opener>
                        <p>105. My 103, September 17, 10 a.m.<note n="1" xml:id="d85fn1"><hi rend="italic">Not printed.</hi></note> Preparatory Commission
                            summoned to meet September 22, 10 a.m.</p>
                        <closer><signed><hi rend="smallcaps">Gibson</hi></signed></closer>
