<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1926-10-04T14:00:00-05:00" frus:doc-dateTime-min="1926-10-04T14:00:00-05:00" n="376" subtype="historical-document" type="document" xml:id="d376">
                            <note rend="inline" type="source">721.2315/319: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in Peru</hi> (<persName type="to"><hi rend="italic">Poindexter</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1926-10-04T14:00:00-05:00"><hi rend="italic">October
                                            4, 1926—2 p.m.</hi></date></dateline></opener>
                            <p>71. Your 84, October 2, 4 p.m. I agree with you and leave the whole
                                matter to your discretion.</p>
                            <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                        </div>
                    </body></text></TEI>