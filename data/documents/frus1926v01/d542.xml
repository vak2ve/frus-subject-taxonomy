<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1926-10-01T17:00:00-05:00" frus:doc-dateTime-min="1926-10-01T17:00:00-05:00" n="542" subtype="historical-document" type="document" xml:id="d542">
                        <note rend="inline" type="source">151.096/128: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in China</hi> (<persName type="to"><hi rend="italic">MacMurray</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1926-10-01T17:00:00-05:00"><hi rend="italic">October 1,
                                        1926—5 p.m.</hi></date></dateline></opener>
                        <p>211. Your 377, September 8, 9 a.m. Inform Jenkins that arrangement is
                            acceptable to Labor Department and is approved.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
