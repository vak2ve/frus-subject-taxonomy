<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1926-04-15T07:00:00-05:00" frus:doc-dateTime-min="1926-04-15T07:00:00-05:00" n="448" subtype="historical-document" type="document" xml:id="d448">
                        <note rend="inline" type="source">893.00/7328: Telegram</note>
                        <head><hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">MacMurray</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1926-04-15T20:00:00+08:00"><hi rend="italic">April 15,
                                        1926—8 p.m.</hi></date><lb/>[Received April 15—11:10
                                a.m.]</dateline></opener>
                        <p>178. My telegram number 177, April 15, 2 p.m.</p>
                        <list>
                            <label>1.</label>
                            <item>Tungchow was occupied this morning by Fengtien troops. Kuominchun
                                is withdrawing from Peking and has turned over control of police to
                                committee of safety.</item>
                            <label>2.</label>
                            <item>Repeated to Tokyo.</item>
                        </list>
                        <closer><signed><hi rend="smallcaps">MacMurray</hi></signed></closer>
                    </div>
                    </body></text></TEI>