                subtype="historical-document" type="document" xml:id="d821">
                <note rend="inline" type="source">893.74/672: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Japan</hi> (<persName type="to">
                        <hi rend="italic">MacVeagh</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1926-04-07T16:00:00-05:00">
                            <hi rend="italic">April 7, 1926—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>28. Page 4 of your despatch number 73, March 13, 1926.<note n="52"
                        xml:id="d821fn52">Not printed.</note> Department prefers, in view of status
                    of Federal wireless contract in Peking at present, that discussions of the
                    question should not at the present time be initiated at Tokyo.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
