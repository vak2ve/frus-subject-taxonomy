                subtype="historical-document" type="document" xml:id="d96">
                <note rend="inline" type="source">462.00 R 29/4138: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Herrick</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1927-02-01T14:00:00+00:00">
                            <hi rend="italic">February 1, 1927—2 p.m.</hi>
                        </date>
                        <lb/>[Received February 1—9:13 a.m.]</dateline>
                </opener>
                <p>42. Reparation 1. Wilson has taken over reparation work from Hill as of
                        today.<note n="15" xml:id="d96fn15">The transfer of the office to the
                        Embassy was effected February 28.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Herrick</hi>
                    </signed>
                </closer>
            </div>
        </body>
