                subtype="historical-document" type="document" xml:id="d474">
                <note rend="inline" type="source">893.00/7623: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName type="from">
                        <hi rend="italic">Mayer</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1926-09-11T12:00:00+08:00">
                            <hi rend="italic">September 11, 1926—noon</hi>
                        </date>.<lb/>[Received September 11—7:55 a.m.]</dateline>
                </opener>
                <p>388. My 386, September 10, noon. Commander in chief has instructed commander of
                    South China [<hi rend="italic">Yangtze?</hi>] Patrol to give necessary
                    protection and assistance to British subjects at Chungking in the absence of
                    British business interests [<hi rend="italic">naval vessel?</hi>] there.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Mayer</hi>
                    </signed>
                </closer>
            </div>
        </body>
