    <text>
        <body>
            <div frus:doc-dateTime-max="1926-02-12T23:59:59-05:00"
                frus:doc-dateTime-min="1926-02-12T00:00:00-05:00" n="4"
                subtype="historical-document" type="document" xml:id="d4">
                <note rend="inline" type="source">500.C114/445b</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Albania</hi> (<persName type="to">
                        <hi rend="italic">Hart</hi>
                    </persName>)<note n="8" xml:id="d4fn8">Same, <hi rend="italic">mutatis
                            mutandis</hi>, on the same date, to the American Chargé in Liberia as
                        Department’s No. 270.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1926-02-12">
                            <hi rend="italic">February 12, 1926</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 25</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: You should address the following note to the
                    Minister of Foreign Affairs:</p>
                <p>[Here follows the text of the note, which is the same as the note of February 12
                    to the Austrian Minister, printed <hi rend="italic">supra</hi>.]</p>
                <p>Upon the receipt of a reply from the Albanian Government you will communicate a
                    brief resume by telegram and a certified true copy of the note by mail.</p>
                <p>I am [etc.]</p>
                <closer>[<signed>
                        <hi rend="smallcaps">Frank B. Kellogg</hi>
                    </signed>]</closer>
            </div>
        </body>
    </text>
