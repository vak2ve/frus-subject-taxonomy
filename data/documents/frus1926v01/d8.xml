                subtype="historical-document" type="document" xml:id="d8">
                <note rend="inline" type="source">500.C114/445aa</note>
                <head>
                    <hi rend="italic">The Cuban Chargé</hi> (<persName type="from">
                        <hi rend="italic">Barón</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1926-03-17">
                            <hi rend="italic">March 17, 1926</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to inform you that my
                    Government, upon reading the resolution of the Senate of the United States of
                    America of January 27, 1926, by which it gave its advice and consent to the
                    adhesion of the United States to the protocol of signature of the statute for
                    the Permanent Court of International Justice dated December 16, 1920, and the
                    appended statute for the Permanent Court of International Justice, authorizes me
                    to accept, as I hereby do, in its name, the conditions, reservations and
                    understandings contained in the said resolution as part and condition of the
                    adhesion of the United States to the said protocol and statutes.</p>
                <p>I avail myself [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">José T. Barón</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
