    <text>
        <body>
            <div frus:doc-dateTime-max="1926-08-20T23:59:59-05:00"
                frus:doc-dateTime-min="1926-08-20T00:00:00-05:00" n="22"
                subtype="historical-document" type="document" xml:id="d22">
                <note rend="inline" type="source">500.C114/445b</note>
                <head>
                    <hi rend="italic">The Albanian Minister</hi> (<persName type="from">
                        <hi rend="italic">Konitza</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1926-08-20">
                            <hi rend="italic">August 20, 1926</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to confirm that my Government
                    has approved the United States reservations for adherence to the Permanent Court
                    of International Justice. The Albanian delegate to the League of Nations has
                    received instructions in accordance with this decision.</p>
                <p>I beg [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Faik Konitza</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
