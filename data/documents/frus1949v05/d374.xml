                subtype="historical-document" type="document" xml:id="d374">
                <note rend="inline" type="source">123 Kirk, Alan G.: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in the Soviet Union</hi> (<persName type="from">
                        <hi rend="italic">Kirk</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Moscow</hi>
                        </placeName>, <date calendar="gregorian" when="1949-08-13T18:00:00+03:00"
                            >August 13, 1949—6 p. m.</date>
                    </dateline>
                </opener>
                <p>2039. <gloss target="#t_Embtel1">Embtel</gloss> 1975, August 8.<note n="1"
                        xml:id="d374fn1">Not printed. Ambassador Kirk informed the Department that
                        he had made the request for an appointment with Stalin during a visit with
                        Vyshinsky. (123 Kirk, Alan G.)</note> Appointment made for Monday, 15th, 10
                    p. m. Am informing British, French colleagues.</p>
                <p>Upon conclusion, visit intend reply anticipated queries American press
                    representatives substantially as follow: interview at my request to pay courtesy
                    visit on Generalissimo Stalin with only general conversation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kirk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
