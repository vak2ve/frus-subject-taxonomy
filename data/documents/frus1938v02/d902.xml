<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1938-09-24T14:00:00-05:00" frus:doc-dateTime-min="1938-09-24T14:00:00-05:00" n="902" subtype="historical-document" type="document" xml:id="d902">
                            <note rend="inline" type="source">390D.11/158a: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in Turkey</hi> (<persName type="to"><hi rend="italic">MacMurray</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1938-09-24T15:00:00-04:00">September 24, 1938—3
                                        p.m.</date></dateline>
                            </opener>
                            <p>96. Department’s mail instruction No. 279 of July 21. Please
                                telegraph briefly present status of negotiations.</p>
                            <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                        </div>
                        </body></text></TEI>