                subtype="historical-document" type="document" xml:id="d637">
                <note rend="inline" type="source">711.90G2/37: Telegram</note>
                <head>
                    <hi rend="italic">The Minister Resident in Iraq</hi> (<persName type="from">
                        <hi rend="italic">Knabenshue</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Baghdad</hi>
                        </placeName>, <date calendar="gregorian" when="1938-12-03T13:00:00+03:00"
                            >December 3, 1938—1 p.m.</date>
                        <lb/>[Received December 3—9:22 a.m.]</dateline>
                </opener>
                <p>50. The Minister for Foreign Affairs Towfiq Suwaidi and I signed the Treaty of
                    Commerce and Navigation at noon today.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Knabenshue</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>[For text of treaty, see Department of State Treaty Series No. 960, or 54
                        Stat. 1790.]</p>
                </postscript>
            </div>
        </body>
    </text>
