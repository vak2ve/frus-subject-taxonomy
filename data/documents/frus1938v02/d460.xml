                subtype="historical-document" type="document" xml:id="d460">
                <note rend="inline" type="source">865.42/37: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from">
                        <hi rend="italic">Phillips</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1938-08-03T17:00:00+01:00"
                            >August 3, 1938—5 p.m.</date>
                        <lb/>[Received August 3—2:30 p.m.]</dateline>
                </opener>
                <p>192. The following announcement was published in the press today: <quote
                        rend="blockquote">
                        <p>“Beginning with the 1938–39 scholastic year the admission to Italian
                            schools of all grades of foreign Jewish pupils even of those domiciled
                            in Italy is prohibited.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
