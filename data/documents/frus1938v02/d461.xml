                subtype="historical-document" type="document" xml:id="d461">
                <note rend="inline" type="source">865.42/39: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from">
                        <hi rend="italic">Phillips</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1938-08-19T18:00:00+01:00"
                            >August 19, 1938—6 p.m.</date>
                        <lb/>[Received August 19—2:45 p.m.]</dateline>
                </opener>
                <p>207. My 192, August 3, 5 p.m. In reply to my oral inquiries made on their behalf,
                    I am informed by the Foreign Office that Jewish American students who have
                    already resided in Italy for 1 year will be free to continue and complete their
                    university studies.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
