    <text>
        <body>
            <div frus:doc-dateTime-max="1938-07-09T05:44:00-05:00"
                frus:doc-dateTime-min="1938-07-09T05:44:00-05:00" n="714"
                subtype="historical-document" type="document" xml:id="d714">
                <note rend="inline" type="source">711.822/19: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Liberia</hi> (<persName type="from">
                        <hi rend="italic">Walton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1938-07-09T10:00:00-00:44"
                            >July 9, 1938—10 a.m.</date>
                        <lb/>[Received July 9—9 a.m.]</dateline>
                </opener>
                <p>48. Your 27, July 7, 10 a.m. [<hi rend="italic">6 p.m.</hi>] Liberian Government
                    agreeable to engrossing final text with all changes as referred to by the
                    Department.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Walton</hi>
                    </signed>
                </closer>
                <pb facs="0853" n="845" xml:id="pg_845"/>
                <postscript>
                    <p>[For text of treaty signed August 8, 1938, see Department of State Treaty
                        Series No. 956, or 54 Stat, 1739.]</p>
                </postscript>
            </div>
        </body>
    </text>
