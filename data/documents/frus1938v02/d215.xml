                subtype="historical-document" type="document" xml:id="d215">
                <note rend="inline" type="source">851.5151/1763a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in France</hi> (<persName type="to">
                        <hi rend="italic">Wilson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1938-03-14T14:00:00-05:00"
                            >March 14, 1938—2 p.m.</date>
                    </dateline>
                </opener>
                <p>148. The Secretary of the Treasury is going to ask Cochran to see Blum in his
                    role as Minister of Finance, as promptly as possible under instructions that
                    will be given on the telephone this afternoon. Would you kindly arrange this
                    appointment for Cochran when he requests it?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
