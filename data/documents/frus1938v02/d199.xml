<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1938-05-20T12:00:00-05:00" frus:doc-dateTime-min="1938-05-20T12:00:00-05:00" n="199" subtype="historical-document" type="document" xml:id="d199">
                            <note rend="inline" type="source">611.60i31/103: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Chargé in Estonia</hi> (<persName type="to"><hi rend="italic">Leonard</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Extract]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1938-05-20T13:00:00-04:00">May 20, 1938—1
                                    p.m.</date></dateline>
                            </opener>
                            <p>10. Your no. 13, May 14, noon. Note of Estonian Foreign Office of May
                                14 and your acknowledgment thereof are acceptable.</p>
                            <p rend="center">. . . . . . . . . . . . . .</p>
                            <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                        </div>
