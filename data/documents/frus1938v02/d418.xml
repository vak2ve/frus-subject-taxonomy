                subtype="historical-document" type="document" xml:id="d418">
                <note rend="inline" type="source">611.6831/192: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Greece</hi> (<persName type="from">
                        <hi rend="italic">MacVeagh</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Athens</hi>
                        </placeName>, <date calendar="gregorian" when="1938-04-01T13:00:00+02:00"
                            >April 1, 1938—1 p.m.</date>
                        <lb/>[Received April 1—9:30 a.m.]</dateline>
                </opener>
                <p>21. Department’s instruction No. 445, March 8th. I handed note to Prime Minister
                    this morning emphasizing Department’s desire for a prompt reply.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">MacVeagh</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
