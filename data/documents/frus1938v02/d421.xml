                subtype="historical-document" type="document" xml:id="d421">
                <note rend="inline" type="source">611.6831/197: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Greece</hi> (<persName type="from">
                        <hi rend="italic">MacVeagh</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Athens</hi>
                        </placeName>, <date calendar="gregorian" when="1938-04-28T12:00:00+02:00"
                            >April 28, 1938—noon</date>.<lb/>[Received April 28—9:25
                        a.m.]</dateline>
                </opener>
                <p>29. Department’s instruction No. 454, April 13. New <hi rend="italic">modus
                        vivendi</hi> submitted this morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">MacVeagh</hi>
                    </signed>
                </closer>
            </div>
        </body>
