                subtype="historical-document" type="document" xml:id="d252">
                <note rend="inline" type="source">811.31/47a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Japan</hi> (<persName type="to">
                        <hi rend="italic">Grew</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-12-31T19:00:00-05:00"
                            >December 31, 1934—7 p.m.</date>
                    </dateline>
                </opener>
                <p>219. For your information and use in discretion: It is understood that the naval
                    manoeuvers announced by Navy for May consist only of defensive exercises in area
                    between Hawaii and Aleutian Islands, and are in continuance of exercises last
                    made around Hawaii.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
