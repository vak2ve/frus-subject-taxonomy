<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-09-29T12:00:00-05:00" frus:doc-dateTime-min="1934-09-29T12:00:00-05:00" n="221" subtype="historical-document" type="document" xml:id="d221">
                        <note rend="inline" type="source">702.4193 Manchuria/11: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in Japan</hi> (<persName type="to"><hi rend="italic">Neville</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1934-09-29T13:00:00-04:00">September 29, 1934—1
                                    p.m.</date></dateline>
                        </opener>
                        <p>168. Your 216, September 28, 2 p.m., paragraphs 4 and 5. You are so
                            authorized.</p>
                        <p>Inform Peiping.</p>
                        <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
