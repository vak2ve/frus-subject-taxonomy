                subtype="historical-document" type="document" xml:id="d257">
                <note rend="inline" type="source">500.C1197/717: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName type="to">
                        <hi rend="italic">Bingham</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-05-04T17:00:00-04:00"
                            >May 4, 1934—5 p.m.</date>
                    </dateline>
                </opener>
                <p>179. Your 223, May 4, noon. For your confidential information and for that of
                    Fuller.</p>
                <list>
                    <label>1.</label>
                    <item>The Department perceives no objection to the course of action outlined in
                        paragraphs 1 and 2 of your telegram under reference provided the British
                        Government also follows this course.</item>
                    <label>2.</label>
                    <item>Upon the receipt of definite information that the British Government has
                        replied to the League in the vein indicated, please telegraph the Department
                        and, in your discretion, inform the Foreign <pb facs="0446" n="356"
                            xml:id="pg_356"/> Office that the American Government is forwarding a
                        similar reply to the League.</item>
                </list>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
