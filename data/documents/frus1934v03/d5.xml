                subtype="historical-document" type="document" xml:id="d5">
                <note rend="inline" type="source">893.01 Manchuria/984: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1934-01-17T10:00:00+08:00"
                            >January 17, 1934—10 a.m.</date>
                        <lb/>[Received January 17—4:25 a.m.]</dateline>
                </opener>
                <p>42. The following telegram has been received from the Consul General at Harbin:
                        <quote rend="blockquote">
                        <p>“January 16, 11 a.m. Japanese Consul General confirms report that Pu Yi
                            will be made Emperor on March 1st.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
