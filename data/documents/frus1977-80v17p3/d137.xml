        <body>
            <head>137. Summary of Conclusions of a Mini-<orgName corresp="recjcU0Z1i6KGSbuD">Special Coordination Committee</orgName> Meeting<note n="1" place="foot" type="source" xml:id="d137fn1">Source: Carter Library,
                    National Security Affairs, Staff Material, Office, Unfiled Files, Box 141,
                    Luncheon Meetings: MBB: 8–9/80. Secret.</note>
            </head>
            <opener>
                <dateline rendition="#right">
                    <placeName>Washington</placeName>, <date calendar="gregorian" from="1980-09-18T15:00:00-04:00" to="1980-09-18T16:00:00-04:00">September
                        18, 1980, 3–4 p.m.</date>
                </dateline>
            </opener>
            <list type="subject">
                <head>SUBJECT</head>
                <item>
                    <placeName corresp="recHYRQHh3kc1bSkH">Libyan</placeName> Actions Directed Against U.S. <rs type="topic" corresp="reccKWZw7wcZPbjV8">Reconnaissance Aircraft</rs> and U.S. <rs type="topic" corresp="recQZHNztoaX0AXIm">Exercise</rs>
                    Plans</item>
            </list>
