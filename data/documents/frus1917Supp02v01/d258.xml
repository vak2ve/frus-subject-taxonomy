                subtype="historical-document" type="document" xml:id="d258">
                <note rend="inline" type="source">File No. 763.72119/830</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName corresp="#p_PTN1"
                        type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1917-09-11T11:00:00+02:00">
                            <hi rend="italic">September 11, 1917, 11 a.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 2.25 p.m.</hi>]</dateline>
                </opener>
                <p>1076. Learn from Vatican sources that Pope expects still good results from his
                    note, also that England has made certain inquiries on points which he has
                    referred to Central Empires’ Governments, and has notified England that the
                    reply will be made next week.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PTN1">
                            <hi rend="smallcaps">Nelson Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
