    <text>
        <body>
            <div frus:doc-dateTime-max="1917-05-29T12:00:00-05:00"
                frus:doc-dateTime-min="1917-05-29T12:00:00-05:00" n="107"
                subtype="historical-document" type="document" xml:id="d107">
                <note rend="inline" type="source">File No. 763.72/4978</note>
                <head>
                    <hi rend="italic">The Minister in Belgium</hi> (<persName corresp="#p_WB1"
                        type="from">
                        <hi rend="italic">Whitlock</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Havre</hi>
                        </placeName>, <date calendar="gregorian" when="1917-05-29T18:00:00+01:00">
                            <hi rend="italic">May 29, 1917, 6 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received May 29, 5.50 p.m.</hi>]</dateline>
                </opener>
                <p>69. Belgian mission, composed of <persName>Baron Moncheur</persName>, General
                        <persName>Leclercq</persName>, Hector Carrier, Major
                        <persName>Osterrieth</persName>, and Lieutenant Count <persName>Louis
                        d’Ursel</persName>, sails for America June 3 from Cadiz.<note n="2"
                        xml:id="d107fn2">This mission arrived June 16. See footnote 1, <hi
                            rend="italic">ante</hi>, <ref target="#pg_20">p. 20</ref>.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_WB1">
                            <hi rend="smallcaps">Whitlock</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
