<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-11-16T17:00:00-05:00" frus:doc-dateTime-min="1917-11-16T17:00:00-05:00" n="345" subtype="historical-document" type="document" xml:id="d345">
                            <note rend="inline" type="source">File No. 763.72/7761</note>
                            <head>
                                <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_SWG1" type="from"><hi rend="italic">Sharp</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1917-11-16T22:00:00+00:00">
                                        <hi rend="italic">November 16, 1917, 10 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received November 17, 3.15
                                    p.m.</hi>]</dateline>
                            </opener>
                            <p>2754. Your 2798, 12th [<hi rend="italic">10th</hi>].<note n="2" xml:id="d345fn2">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_301">p.
                                    301</ref>.</note> Foreign Office replies that the smaller powers
                                have been invited to assist at the military session of the
                                Inter-Allied Conference of Paris and that they have reserved for
                                decision at that time what will be the working procedure to be
                                followed subsequently.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_SWG1">
                                        <hi rend="smallcaps">Sharp</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>