<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-07-02T23:59:59-05:00" frus:doc-dateTime-min="1917-07-02T00:00:00-05:00" n="165" subtype="historical-document" type="document" xml:id="d165">
                            <note rend="inline" type="source">File No. 763.72/5670</note>
                            <head>
                                <hi rend="italic">The Minister in Greece</hi> (<persName corresp="#p_DG1" type="from"><hi rend="italic">Droppers</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Athens</hi></placeName>, <date calendar="gregorian" when="1917-07-02">
                                        <hi rend="italic">July 2, 1917</hi></date>. <lb/> [<hi rend="italic">Received July 3, 1.30 a.m.</hi>]</dateline>
                            </opener>
                            <p>372. Minister of Foreign Affairs informs me Greece at war Germany,
                                Bulgaria. Relations broken off other Central powers.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_DG1">
                                        <hi rend="smallcaps">Droppers</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>