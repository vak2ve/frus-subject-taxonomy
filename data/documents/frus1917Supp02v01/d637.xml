<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-01-03T14:00:00-05:00" frus:doc-dateTime-min="1918-01-03T14:00:00-05:00" n="637" subtype="historical-document" type="document" xml:id="d637">
                            <note rend="inline" type="source">File No. 763.72115/3237</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in China</hi> (<persName corresp="#p_RPS1" type="to"><hi rend="italic">Reinsch</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-01-03T14:00:00-05:00">
                                        <hi rend="italic">January 3, 1918, 2 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Your December 27, 11 p.m.<note n="1" xml:id="d637fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_713">p.
                                    713</ref>.</note> You may support Allied representatives on the
                                ground that this measure alone will adequately safeguard interests
                                of China and her allies.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                    </body></text></TEI>