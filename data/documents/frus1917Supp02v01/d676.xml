                subtype="historical-document" type="document" xml:id="d676">
                <note rend="inline" type="source">File No. 763.72119/693b</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-07-28T17:00:00-05:00">
                            <hi rend="italic">July 28, 1917, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>5222. Department assumes that your reference to “Stockholm conference” was
                    intended for “Petrograd conference.”</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
