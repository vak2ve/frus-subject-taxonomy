    <text>
        <body>
            <div frus:doc-dateTime-max="1917-08-30T11:00:00-05:00"
                frus:doc-dateTime-min="1917-08-30T11:00:00-05:00" n="689"
                subtype="historical-document" type="document" xml:id="d689">
                <note rend="inline" type="source">File No. 763.72119/786</note>
                <head>
                    <hi rend="italic">The Minister in Sweden</hi> (<persName corresp="#p_MIN1"
                        type="from">
                        <hi rend="italic">Morris</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Stockholm</hi>
                        </placeName>, <date calendar="gregorian" when="1917-08-30T17:00:00+01:00">
                            <hi rend="italic">August 30, 1917, 5 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received August 31, 2.15 a.m.</hi>]</dateline>
                </opener>
                <p>697. My 672.<note n="1" xml:id="d689fn1">Not printed.</note>
                    <persName>Axelrod</persName>, leader of Internationalist section of Mensheviki
                    and one of the Russian leaders of the Stockholm Socialists’ Conference, has said
                    in part: <quote rend="blockquote">
                        <p>America is endangering future of humane culture by preventing peace. If
                            the President does not permit American delegates come to Stockholm he
                            will indicate that his country is more reactionary than despotic
                            Germany.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_MIN1">
                            <hi rend="smallcaps">Morris</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
