<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-06-09T15:00:00-05:00" frus:doc-dateTime-min="1917-06-09T15:00:00-05:00" n="127" subtype="historical-document" type="document" xml:id="d127">
                            <note rend="inline" type="source">File No. 868.00/112</note>
                            <head>
                                <hi rend="italic">The Minister in Greece</hi> (<persName corresp="#p_DG1" type="from"><hi rend="italic">Droppers</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Athens</hi></placeName>, <date calendar="gregorian" when="1917-06-09T22:00:00+02:00">
                                        <hi rend="italic">June 9, 1917, 10 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received June 10, 11.15
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>348. Colleague informs Entente’s plan contemplates removal of King,
                                one member of Royal Family substituted as regent with French High
                                Commissioner in control, French forces to occupy Thessaly.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_DG1">
                                        <hi rend="smallcaps">Droppers</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>