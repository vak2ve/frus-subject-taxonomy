<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-05-07T19:00:00-05:00" frus:doc-dateTime-min="1917-05-07T19:00:00-05:00" n="80" subtype="historical-document" type="document" xml:id="d80">
                            <note rend="inline" type="source">File No. 763.72/4127</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Italy</hi> (<persName corresp="#p_PTN1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-05-07T19:00:00-05:00">
                                        <hi rend="italic">May 7, 1917, 7 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>799. Your 937, April 28, 2 p.m.<note n="1" xml:id="d80fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_47">p.
                                    47</ref>.</note> Inform Italian Government of this Government’s
                                pleasure in receiving distinguished members of Italian
                                    commission.<note n="2" xml:id="d80fn2">This mission arrived in
                                    New York May 10. See footnote 1, <hi rend="italic">ante</hi>,
                                        <ref target="#pg_20">p. 20</ref>.</note>
                            </p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>