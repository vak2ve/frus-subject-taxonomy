    <text>
        <body>
            <div frus:doc-dateTime-max="1917-07-20T23:59:59-05:00"
                frus:doc-dateTime-min="1917-07-20T00:00:00-05:00" n="455"
                subtype="historical-document" type="document" xml:id="d455">
                <note rend="inline" type="source">File No. 841.51/70</note>
                <head>
                    <hi rend="italic">The Assistant Secretary of the Treasury</hi> (<persName
                        corresp="#p_COT1" type="from">
                        <hi rend="italic">Crosby</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-07-20">
                            <hi rend="italic">July 20, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: On behalf of the Secretary of the Treasury, I beg
                    to advise you that an advance of $85,000,000 has to-day been made to the British
                    Government. This brings the total loaned to that Government to date to
                    $770,000,000.</p>
                <p>Very sincerely yours,</p>
                <closer>
                    <signed>
                        <persName corresp="#p_COT1">
                            <hi rend="smallcaps">Oscar T. Crosby</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
