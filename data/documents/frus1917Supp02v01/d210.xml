                subtype="historical-document" type="document" xml:id="d210">
                <note rend="inline" type="source">File No. 763.72/6195</note>
                <head>
                    <hi rend="italic">The Chargé in Rumania</hi> (<persName corresp="#p_AWW1"
                        type="from">
                        <hi rend="italic">Andrews</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Jassy</hi>
                        </placeName>, <date
                            ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                            calendar="gregorian" notAfter="1917-08-04T23:25:00-05:00"
                            notBefore="1917-08-02T19:00:00+01:00">
                            <hi rend="italic">undated</hi>
                        </date>. <lb/> [<hi rend="italic">Received August 4, 1917, 11.25
                        p.m.</hi>]</dateline>
                </opener>
                <p>In order to save Roumania a great pressure must be brought by the American
                    Government as already has been done by the other Allies on the Russian
                    Government to send energetic orders to the Russian Army here. Soon it will be
                    too late.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_AWW1">
                            <hi rend="smallcaps">Andrews</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
