                subtype="historical-document" type="document" xml:id="d680">
                <note rend="inline" type="source">File No. 763.72119/703a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)<note n="1" xml:id="d680fn1">The same, <hi rend="italic">mutatis
                            mutandis</hi>, on the same date, to the Ambassador in France (No.
                        2514).</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-08-03T17:00:00-05:00">
                            <hi rend="italic">August 3, 1917, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>5251. Please advise Department immediately of the policy of the British
                    Government in permitting Socialists to attend Stockholm conference.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
