                subtype="historical-document" type="document" xml:id="d694">
                <note rend="inline" type="source">File No. 763.72111N39/132</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName corresp="#p_PTN1"
                        type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1917-11-30T12:00:00+01:00">
                            <hi rend="italic">November 30, 1917, noon</hi>
                        </date>. <lb/> [<hi rend="italic">Received 4.06 p.m.</hi>]</dateline>
                </opener>
                <p>Department’s 984, November 24, 3 p.m.<note n="1" xml:id="d694fn1">See telegram
                        No. 5895 of that date to the Ambassador in Great Britain, <hi rend="italic"
                            >ante</hi>, <ref target="#pg_756">p. 756</ref>.</note> Foreign Office
                    informs me verbally, <persName corresp="#p_SBS1">Baron Sonnino</persName> to
                    whom matter was directed, telegraphs <pb facs="0832" n="758" xml:id="pg_758"/>
                    to-day from Paris that he sees no objection to United States making desired
                    declaration to Swiss Government. Foreign Office promises written
                    confirmation.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PTN1">
                            <hi rend="smallcaps">Nelson Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
