    <text>
        <body>
            <div frus:doc-dateTime-max="1918-01-03T23:59:59-05:00"
                frus:doc-dateTime-min="1918-01-03T00:00:00-05:00" n="500"
                subtype="historical-document" type="document" xml:id="d500">
                <note rend="inline" type="source">File No. 800.51/26</note>
                <head>
                    <hi rend="italic">The Assistant Secretary of the Treasury</hi> (<persName
                        type="from">
                        <hi rend="italic">Leffingwell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-01-03">
                            <hi rend="italic">January 3, 1918</hi>
                        </date>.</dateline>
                </opener>
                <p>The total of loans and credits to date is now as follows:</p>
                <p rend="center">
                    <hi rend="smallcaps">Loans to Foreign Governments</hi>
                </p>
                <p rend="center">Acts of April 24, 1917, and September 24, 1917</p>
                <table cols="4" rend="bordered" rows="8">
                    <row>
                        <cell>Country</cell>
                        <cell>Loans and credits agreed upon</cell>
                        <cell>Loans made</cell>
                        <cell>Balances under established credits</cell>
                    </row>
                    <row>
                        <cell>Great Britain</cell>
                        <cell role="num">$2,045,000,000</cell>
                        <cell role="num">$1,860,000,000</cell>
                        <cell role="num">$185,000,000</cell>
                    </row>
                    <row>
                        <cell>France</cell>
                        <cell role="num">1,285,000,000</cell>
                        <cell role="num">1,165,000,000</cell>
                        <cell role="num">120,000,000</cell>
                    </row>
                    <row>
                        <cell>Italy</cell>
                        <cell role="num">500,00,00</cell>
                        <cell role="num">400,00,00</cell>
                        <cell role="num">100,00,00</cell>
                    </row>
                    <row>
                        <cell>Russia</cell>
                        <cell role="num">325,000,000</cell>
                        <cell role="num">187,729,750</cell>
                        <cell role="num">137,270,250</cell>
                    </row>
                    <row>
                        <cell>Belgium</cell>
                        <cell role="num">77,400,000</cell>
                        <cell role="num">75,400,000</cell>
                        <cell role="num">2,000,000</cell>
                    </row>
                    <row>
                        <cell>Serbia</cell>
                        <cell role="num">4,000,000</cell>
                        <cell role="num">3,200,000</cell>
                        <cell role="num">800,000</cell>
                    </row>
                    <row>
                        <cell rendition="#right">Totals</cell>
                        <cell role="num">4,236,400,000</cell>
                        <cell role="num">3,691,329,750</cell>
                        <cell role="num">545,070,250</cell>
                    </row>
                </table>
                <closer>
                    <signed> [<persName>
                            <hi rend="smallcaps">R. C. Leffingwell</hi>
                        </persName>] </signed>
                </closer>
            </div>
        </body>
    </text>
