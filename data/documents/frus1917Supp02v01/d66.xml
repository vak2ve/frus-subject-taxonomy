<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-04-28T16:00:00-05:00" frus:doc-dateTime-min="1917-04-28T16:00:00-05:00" n="66" subtype="historical-document" type="document" xml:id="d66">
                            <note rend="inline" type="source">File No. 868.00/102</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in Greece</hi> (<persName corresp="#p_DG1" type="to"><hi rend="italic">Droppers</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-04-28T16:00:00-05:00">
                                        <hi rend="italic">April 28, 1917, 4 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>270. Your 300, April 17,<note n="1" xml:id="d66fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_28">p.
                                    28</ref>.</note> does not answer questions Department’s
                                    247,<note n="2" xml:id="d66fn2">
                                    <ref target="frus1917Supp01v01#pg_77">Supplement 1, p.
                                    77</ref>.</note> April 4, relative to parliamentary elections
                                and dissolution Parliament.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>