    <text>
        <body>
            <div frus:doc-dateTime-max="1917-03-27T18:00:00-05:00"
                frus:doc-dateTime-min="1917-03-27T18:00:00-05:00" n="9"
                subtype="historical-document" type="document" xml:id="d9">
                <note rend="inline" type="source">File No. 763.72/3579</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-03-27T18:00:00-05:00">
                            <hi rend="italic">March 27, 1917, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>4599. Your 5880, March 23, 7 p.m. Admiral will be sent as soon as possible.<note
                        n="1" xml:id="d9fn1">
                        <persName corresp="#p_SAWS1">Admiral W. S. Sims</persName> sailed Mar.
                        31.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
