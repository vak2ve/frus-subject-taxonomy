<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-10-30T23:59:59-05:00" frus:doc-dateTime-min="1917-10-30T00:00:00-05:00" n="310" subtype="historical-document" type="document" xml:id="d310">
                            <note rend="inline" type="source">File No. 763.72/7605</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the French Ambassador</hi> (<persName corresp="#p_JJJ2" type="to"><hi rend="italic">Jusserand</hi></persName>)</head>
                            <opener>
                                <seg rendition="#left">No. 1983</seg>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-10-30">
                                        <hi rend="italic">October 30, 1917</hi></date>.</dateline>
                            </opener>
                            <p>
                                <hi rend="smallcaps">Excellency</hi>: I have the honor to enclose
                                herewith, for transmission to Your Excellency’s Government, a copy
                                of a note dated October 26, 1917,<note n="1" xml:id="d310fn1">The
                                    original note printed <hi rend="italic">ante</hi>, <ref target="#pg_280">p. 280</ref>.</note> from the Minister of
                                Serbia at this Capital, relative to the conference of the Allied
                                powers to be held at Paris next month.</p>
                            <p>Accept [etc.]</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Robert Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>