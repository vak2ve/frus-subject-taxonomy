<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-11-30T16:00:00-05:00" frus:doc-dateTime-min="1917-11-30T16:00:00-05:00" n="362" subtype="historical-document" type="document" xml:id="d362">
                            <note rend="inline" type="source">File No. 761.00/11a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in Sweden</hi> (<persName corresp="#p_MIN1" type="to"><hi rend="italic">Morris</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-11-30T16:00:00-05:00">
                                        <hi rend="italic">November 30, 1917, 4 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>427. Department informed secret treaties are being published by
                                Bolsheviki government in Petrograd but their publication here held
                                up by Allies’ censor. Please telegraph substance of all treaties so
                                far published.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>