<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-12-07T23:59:59-05:00" frus:doc-dateTime-min="1917-12-07T00:00:00-05:00" n="381" subtype="historical-document" type="document" xml:id="d381">
                            <note rend="inline" type="source">File No. 763.72/8023a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to <gloss type="to">All Diplomatic Officers</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Circular telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-12-07">
                                        <hi rend="italic">December 7, 1917</hi></date>.</dateline>
                            </opener>
                            <p>Congress to-day passed and President signed joint resolution
                                declaring war on Austria-Hungary. Inform Consuls.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>