                subtype="historical-document" type="document" xml:id="d6">
                <note rend="inline" type="source">File No. 763.72112/4103a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-03-24T18:00:00-05:00">
                            <hi rend="italic">March 24, 1917</hi> [<hi rend="italic">6
                            p.m.</hi>]</date>
                    </dateline>
                </opener>
                <p>4586. It has been suggested that it would be desirable for you to get in touch
                    informally with Foreign Trade Bureau, British Government, with the idea of
                    getting their views as to possibility cooperation. If in your judgment it can be
                    properly done at this time suggest you have interview with proper officials
                    apparently on your own initiative and cable result.<note n="1" xml:id="d6fn1"
                        >Telegraphic replies not printed; for British suggestions see <ref
                            target="frus1917Supp02v02#pg_808">Vol. II, p. 808</ref>.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
