                subtype="historical-document" type="document" xml:id="d712">
                <note rend="inline" type="source">File No. 860c.01/44</note>
                <head>
                    <hi rend="italic">The Ambassador in Russia</hi> (<persName corresp="#p_FDR1"
                        type="from">
                        <hi rend="italic">Francis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Petrograd</hi>
                        </placeName>, <date calendar="gregorian" when="1917-10-24T23:00:00+03:31">
                            <hi rend="italic">October 24, 1917, 11 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received October 27, 2.15 p.m.</hi>]</dateline>
                </opener>
                <p>1907. Further answering your 1778. Minister for Foreign Affairs cabled yesterday
                    Russian Ambassadors, Washington, London, Paris, Rome, stating formal position
                    concerning Polish committees. Says recognizing Polish National Committee. All
                    Poles here admire United States and desire best terms with Embassy.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_FDR1">
                            <hi rend="smallcaps">Francis</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
