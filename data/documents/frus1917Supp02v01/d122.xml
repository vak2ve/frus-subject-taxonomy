<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-06-07T07:00:00-05:00" frus:doc-dateTime-min="1917-06-07T07:00:00-05:00" n="122" subtype="historical-document" type="document" xml:id="d122">
                            <note rend="inline" type="source">File No. 763.72/5194</note>
                            <head>
                                <hi rend="italic">The Minister in Greece</hi> (<persName corresp="#p_DG1" type="from"><hi rend="italic">Droppers</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Athens</hi></placeName>, <date calendar="gregorian" when="1917-06-07T14:00:00+02:00">
                                        <hi rend="italic">June 7, 1917, 2 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received June 8, 7
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>347. England, France, Russia having reached an agreement in regard to
                                Greek affairs French Senator <persName corresp="#p_JCC1">Jonnart</persName> proceeding Salonica then Athens as special
                                emissary and exponent of joint policy of three powers.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_DG1">
                                        <hi rend="smallcaps">Droppers</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>