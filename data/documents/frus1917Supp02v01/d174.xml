<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-07-11T17:00:00-05:00" frus:doc-dateTime-min="1917-07-11T17:00:00-05:00" n="174" subtype="historical-document" type="document" xml:id="d174">
                            <note rend="inline" type="source">File No. 763.72/5646</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Ambassador in Great Britain</hi>
                                    (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-07-11T17:00:00-05:00">
                                        <hi rend="italic">July 11, 1917, 5 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>5129. Your 6599<note n="2" xml:id="d174fn2">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_114">p.
                                    114</ref>.</note> has been referred to the President and the
                                decision reached that, while Mr. <persName corresp="#p_BAJ1">Balfour</persName>’s cordial invitation is <pb facs="0198" n="124" xml:id="pg_124"/> greatly appreciated, this Government
                                is not ready at the present time to take part in the inter-Allied
                                war conferences.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_PFL1">
                                        <hi rend="smallcaps">Polk</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>