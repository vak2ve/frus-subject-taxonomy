                subtype="historical-document" type="document" xml:id="d636">
                <note rend="inline" type="source">File No. 763.72115/3239</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName corresp="#p_RPS1"
                        type="from">
                        <hi rend="italic">Reinsch</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1917-12-31T18:00:00+08:00">
                            <hi rend="italic">December 31, 1917, 6 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received December 31, 4.15 p.m.</hi>]</dateline>
                </opener>
                <p>Your December 29, 3 p.m. Inquiry was intended to inform you that the action of
                    the Allied representatives contemplated deportation to Australia of all enemy
                    subjects to the exclusion of the alternative of deporting only suspected
                    persons.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_RPS1">
                            <hi rend="smallcaps">Reinsch</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
