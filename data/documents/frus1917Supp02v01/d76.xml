<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-05-04T06:00:00-05:00" frus:doc-dateTime-min="1917-05-04T06:00:00-05:00" n="76" subtype="historical-document" type="document" xml:id="d76">
                            <note rend="inline" type="source">File No. 868.00/107</note>
                            <head>
                                <hi rend="italic">The Minister in Greece</hi> (<persName corresp="#p_DG1" type="from"><hi rend="italic">Droppers</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Athens</hi></placeName>, <date calendar="gregorian" when="1917-05-04T13:00:00+02:00">
                                        <hi rend="italic">May 4, 1917, 1 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 12 p.m.</hi>]</dateline>
                            </opener>
                            <p>322. <persName corresp="#p_ZA1">Zaimis</persName> has consented to
                                form a new ministry. It is hoped that he will improve Greco-Entente
                                relations.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_DG1">
                                        <hi rend="smallcaps">Droppers</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>