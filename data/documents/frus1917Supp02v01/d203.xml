    <text>
        <body>
            <div frus:doc-dateTime-max="1917-07-31T12:00:00-05:00"
                frus:doc-dateTime-min="1917-07-31T12:00:00-05:00" n="203"
                subtype="historical-document" type="document" xml:id="d203">
                <note rend="inline" type="source">File No. 763.72/6064</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1917-07-31T18:00:00+01:00">
                            <hi rend="italic">July 31, 1917, 6 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 7.35 p.m.</hi>]</dateline>
                </opener>
                <p>6861. Your 5221, July 28, 4 p.m. Mr. <persName corresp="#p_BAJ1"
                        >Balfour</persName> heartily welcomes the suggestion. When you call such a
                    conference the British Government will respond favorably.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
