<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-06-09T17:00:00-05:00" frus:doc-dateTime-min="1917-06-09T17:00:00-05:00" n="126" subtype="historical-document" type="document" xml:id="d126">
                            <note rend="inline" type="source">File No. 763.72/5194</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in Greece</hi> (<persName corresp="#p_DG1" type="to"><hi rend="italic">Droppers</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-06-09T17:00:00-05:00">
                                        <hi rend="italic">June 9, 1917, 5 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>294. Your 347, June 7, 2 p.m. Please notify Department details
                                agreement between England, France, Russia, relative Greek affairs.
                                Inform Department more frequently and more fully concerning
                                conditions in Greece.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>