<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-10-20T23:59:59-05:00" frus:doc-dateTime-min="1917-10-20T00:00:00-05:00" n="602" subtype="historical-document" type="document" xml:id="d602">
                            <note rend="inline" type="source">File No. 862.85/195a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in Siam</hi> (<persName corresp="#p_IGP1" type="to"><hi rend="italic">Ingersoll</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-10-20">
                                        <hi rend="italic">October 20, 1917</hi></date>.</dateline>
                            </opener>
                            <p>Your September 17, 11 a.m.<note n="2" xml:id="d602fn2">Not
                                    printed.</note> This Government has agreed to following
                                apportionment of steamers taken over by Siamese Government: <pb facs="0769" n="695" xml:id="pg_695"/> 25 per cent each to Great
                                Britain, France, Japan, and the United States. Embassy at Tokyo has
                                been instructed accordingly.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>