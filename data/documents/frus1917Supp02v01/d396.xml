<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-12-15T15:00:00-05:00" frus:doc-dateTime-min="1917-12-15T15:00:00-05:00" n="396" subtype="historical-document" type="document" xml:id="d396">
                            <note rend="inline" type="source">File No. 867n.01/2a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-12-15T15:00:00-05:00">
                                        <hi rend="italic">December 15, 1917, 3 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>6041. Investigate discreetly and report fully and promptly to
                                Department reasons for <persName corresp="#p_BAJ1">Balfour</persName>’s recent statement relative Jewish state in
                                    Palestine.<note n="1" xml:id="d396fn1">See footnote 1, <hi rend="italic">ante</hi>, <ref target="#pg_317">p.
                                    317</ref>.</note>
                            </p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>