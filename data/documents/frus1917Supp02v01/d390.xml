    <text>
        <body>
            <div frus:doc-dateTime-max="1917-12-11T23:59:59-05:00"
                frus:doc-dateTime-min="1917-12-11T00:00:00-05:00" n="390"
                subtype="historical-document" type="document" xml:id="d390">
                <note rend="inline" type="source">File No. 763.72/8101a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Diplomatic Officers in All Countries except
                            Spain</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Circular telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-12-11">
                            <hi rend="italic">December 11, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>Supplementing Department’s circular 7th.<note n="2" xml:id="d390fn2">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_459">p. 459</ref>.</note>
                    Inform Foreign Office that, “The United States Congress has passed a resolution,
                    approved by the President December 7, declaring that a state of war exists
                    between the Austro-Hungarian Government and the people of the United
                    States.”</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
