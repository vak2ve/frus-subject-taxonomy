                subtype="historical-document" type="document" xml:id="d683">
                <note rend="inline" type="source">File No. 763.72119/709a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)<note n="1" xml:id="d683fn1">The same, on the same date, to the
                        Ambassador in France (No. 2523).</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-08-07T17:00:00-05:00">
                            <hi rend="italic">August 7, 1917, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>5267. Department notified <persName>Morris Hillquit</persName>, Socialist
                    delegate to Copenhagen [<hi rend="italic">Stockholm</hi>] conference, would not
                    be given passport.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
