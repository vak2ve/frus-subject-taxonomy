<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-11-09T23:00:00-05:00" frus:doc-dateTime-min="1917-11-09T23:00:00-05:00" n="610" subtype="historical-document" type="document" xml:id="d610">
                            <note rend="inline" type="source">File No. 763.72112/5450</note>
                            <head>
                                <hi rend="italic">The Minister in China</hi> (<persName corresp="#p_RPS1" type="from"><hi rend="italic">Reinsch</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1917-11-10T12:00:00+08:00">
                                        <hi rend="italic">November 10, 1917, 12 noon</hi></date>.
                                    <lb/> [<hi rend="italic">Received November 10, 11.20
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>British and French representatives have received instructions to
                                invite Chinese Government to cooperate in economic blockade of the
                                Central powers. They assume that I have similar instructions. Your
                                instructions are requested.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_RPS1">
                                        <hi rend="smallcaps">Reinsch</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>