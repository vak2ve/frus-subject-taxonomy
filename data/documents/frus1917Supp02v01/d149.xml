                subtype="historical-document" type="document" xml:id="d149">
                <note rend="inline" type="source">File No. 763.72119/654</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1917-06-21T18:00:00+01:00">
                            <hi rend="italic">June 21, 1917, 6 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received June 21, 6 p.m.</hi>]</dateline>
                </opener>
                <p>6509. Confidential to Secretary and President:</p>
                <p>The Prime Minister asked me to breakfast this morning to discuss the desirability
                    of trying to induce Austria and especially Bulgaria to make separate peace, but
                    his conclusion is that under present conditions any effort would be premature in
                    this matter. Coming events in Russia play so large a part that it seems better
                    to wait and see whether Russia will again show important military activity.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
