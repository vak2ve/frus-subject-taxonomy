    <text>
        <body>
            <div frus:doc-dateTime-max="1917-10-20T23:59:59-05:00"
                frus:doc-dateTime-min="1917-10-20T00:00:00-05:00" n="476"
                subtype="historical-document" type="document" xml:id="d476">
                <note rend="inline" type="source">File No. 800.51/23</note>
                <head>
                    <hi rend="italic">The Acting Secretary of the Treasury</hi> (<persName
                        corresp="#p_COT1" type="from">
                        <hi rend="italic">Crosby</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-10-20">
                            <hi rend="italic">October 20, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>The total of loans and credits to date is now as follows:</p>
                <p rend="center">
                    <hi rend="smallcaps">Loans to Foreign Governments</hi>
                </p>
                <p rend="center">(Acts of April 24, 1917, and September 24, 1917)</p>
                <table cols="4" rend="bordered" rows="13">
                    <row>
                        <cell>Country</cell>
                        <cell>Loans and credits agreed upon</cell>
                        <cell>Loans made</cell>
                        <cell>Balances under established credits</cell>
                    </row>
                    <row>
                        <cell>Great Britain</cell>
                        <cell role="num">$1,345,000,000</cell>
                        <cell role="num">$1,345,000,000</cell>
                        <cell/>
                    </row>
                    <row>
                        <cell>France</cell>
                        <cell role="num">770,000,000</cell>
                        <cell role="num">770,000,000</cell>
                        <cell/>
                    </row>
                    <row>
                        <cell>Italy</cell>
                        <cell role="num">255,000,000</cell>
                        <cell role="num">255,000,000</cell>
                        <cell/>
                    </row>
                    <row>
                        <cell>Russia</cell>
                        <cell role="num">100,000,000</cell>
                        <cell role="num">40,000,000</cell>
                        <cell role="num">$60,000,000</cell>
                    </row>
                    <row>
                        <cell>Russia</cell>
                        <cell role="num">75,000,000</cell>
                        <cell role="num">50,000,000</cell>
                        <cell role="num">25,000,000</cell>
                    </row>
                    <row>
                        <cell>Russia</cell>
                        <cell role="num">100,000,000</cell>
                        <cell role="num">64,700,000</cell>
                        <cell role="num">35,300,000</cell>
                    </row>
                    <row>
                        <cell>Russia</cell>
                        <cell role="num">50,00,000</cell>
                        <cell role="num">50,00,000</cell>
                        <cell role="num">50,00,000</cell>
                    </row>
                    <row>
                        <cell>Belgium</cell>
                        <cell role="num">45,000,000</cell>
                        <cell role="num">37,500,000</cell>
                        <cell role="num">7,500,000</cell>
                    </row>
                    <row>
                        <cell>Belgium</cell>
                        <cell role="num">10,500,000</cell>
                        <cell role="num">9,500,000</cell>
                        <cell role="num">1,000,000</cell>
                    </row>
                    <row>
                        <cell>Belgium</cell>
                        <cell role="num">2,900,000</cell>
                        <cell/>
                        <cell role="num">2,900,000</cell>
                    </row>
                    <row>
                        <cell>Serbia</cell>
                        <cell role="num">3,000,000</cell>
                        <cell role="num">1,500,000</cell>
                        <cell role="num">1,500,000</cell>
                    </row>
                    <row>
                        <cell>Totals</cell>
                        <cell role="num">2,756,400,000</cell>
                        <cell role="num">2,573,200,000</cell>
                        <cell role="num">183,200,000</cell>
                    </row>
                </table>
                <closer>[<signed>
                        <persName corresp="#p_COT1">
                            <hi rend="smallcaps">Oscar T. Crosby</hi>
                        </persName>
                    </signed>]</closer>
            </div>
