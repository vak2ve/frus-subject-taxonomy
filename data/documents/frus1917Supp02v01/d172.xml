    <text>
        <body>
            <div frus:doc-dateTime-max="1917-07-10T18:00:00-05:00"
                frus:doc-dateTime-min="1917-07-10T18:00:00-05:00" n="172"
                subtype="historical-document" type="document" xml:id="d172">
                <note rend="inline" type="source">File No. 763.72/5352</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to">
                        <hi rend="italic">Francis</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-07-10T18:00:00-05:00">
                            <hi rend="italic">July 10, 1917, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1556. Your 1394, June 14, 5 p.m.<note n="1" xml:id="d172fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_101">p. 101</ref>.</note> Navy
                    Department regrets that it cannot send division of destroyers, as suggested. The
                    service of American destroyers in British waters has enabled Great Britain to
                    send British destroyers to White Sea.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
