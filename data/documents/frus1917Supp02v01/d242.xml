                subtype="historical-document" type="document" xml:id="d242">
                <note rend="inline" type="source">File No. 763.72119/799</note>
                <head>
                    <hi rend="italic">The Ambassador in Russia</hi> (<persName corresp="#p_FDR1"
                        type="from">
                        <hi rend="italic">Francis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Petrograd</hi>
                        </placeName>, <date calendar="gregorian" when="1917-08-30T20:00:00+03:31">
                            <hi rend="italic">August 30, 1917, 8 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received September 2, 12 noon.</hi>]</dateline>
                </opener>
                <p>1684. Petrograd telegram agency prints telegram from Zurich dated 29th that
                    President <persName corresp="#p_WW1">Wilson</persName> will state objects of war
                    by Allies and make last attempt for conciliation and, if fails, markets of the
                    world will be closed to Germany for ten years after war by Allies and America.
                    What foundation?<note n="1" xml:id="d242fn1">Answered Sept. 7, No. 1685: “No
                        foundation whatever for report.”</note> Such reports harmful in Russia if
                    untrue.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_FDR1">
                            <hi rend="smallcaps">Francis</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
