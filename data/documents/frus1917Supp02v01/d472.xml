    <text>
        <body>
            <div frus:doc-dateTime-max="1917-09-21T10:00:00-05:00"
                frus:doc-dateTime-min="1917-09-21T10:00:00-05:00" n="472"
                subtype="historical-document" type="document" xml:id="d472">
                <note rend="inline" type="source">File No. 763.72/6939</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1917-09-21T15:00:00+00:00">
                            <hi rend="italic">September 21, 1917, 3 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 3.30 p.m.</hi>]</dateline>
                </opener>
                <p>7218. Your 5396, September 8, 2 p.m. British Government are proceeding with all
                    speed nomination of their delegates to Inter-Ally Council and hope very shortly
                    to announce their names.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
