                subtype="historical-document" type="document" xml:id="d677">
                <note rend="inline" type="source">File No. 763.72119/694</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1917-07-30T14:00:00+01:00">
                            <hi rend="italic">July 30, 1917, 2 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 7.28 p.m.</hi>]</dateline>
                </opener>
                <p>6848. Your 5222, undated [<hi rend="italic">July 28, 5 p.m.</hi>]. No. The
                    reference to Stockholm conference is correct, for that is where it is to be
                    held. Information contained in my 6826, July 27, 1 p.m., obtained from Mr.
                        <persName corresp="#p_HA1">Arthur Henderson</persName>. No definite decision
                    has yet been arrived at by British Government as to the attitude which will be
                    finally adopted towards this conference. Shall keep you informed of
                    developments.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
