    <text>
        <body>
            <div frus:doc-dateTime-max="1917-08-24T09:00:00-05:00"
                frus:doc-dateTime-min="1917-08-24T09:00:00-05:00" n="231"
                subtype="historical-document" type="document" xml:id="d231">
                <note rend="inline" type="source">File No. 763.72/6592</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1917-08-24T15:00:00+01:00">
                            <hi rend="italic">August 24, 1917, 3 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 5.15 p.m.</hi>]</dateline>
                </opener>
                <p>7021. Your 5307, August 15.<note n="1" xml:id="d231fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_161">p. 161</ref>.</note>
                    Foreign Office informs me the date on which it is suggested that the conference
                    should meet is September 4.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
