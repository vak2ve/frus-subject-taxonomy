                subtype="historical-document" type="document" xml:id="d662">
                <note rend="inline" type="source">File No. 763.72119/607a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)<note n="1" xml:id="d662fn1">Sent also to the Ambassadors in France,
                        Italy, Russia, and Spain and the Ministers in Belgium, Denmark, the
                        Netherlands, Norway, Sweden, and Switzerland.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Circular telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-05-22T18:00:00-05:00">
                            <hi rend="italic">May 22, 1917, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>For your information, under the direction of the President no passports will be
                    issued to Socialists intending to attend the Stockholm conference.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
