                <note rend="inline" type="source">123 B 632/602: Circular telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Diplomatic Representatives in the American Republics
                            Except Bolivia</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1944-01-22T20:00:00-04:00"
                            >January 22, 1944—8 p.m.</date>
                    </dateline>
                </opener>
                <p>Ambassador Boal has been instructed to return to the United States as soon as
                    possible after my statement on the Bolivian question.<note n="41"
                        xml:id="d397fn41">See <hi rend="italic">infra.</hi>
                    </note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
