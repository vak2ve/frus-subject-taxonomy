                subtype="historical-document" type="document" xml:id="d256">
                <note rend="inline" type="source">835.01/202: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Argentina</hi> (<persName type="from">
                        <hi rend="italic">Armour</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1944-03-08">March 8,
                            1944</date>.<lb/>[Received March 8—5:38 p.m.]</dateline>
                </opener>
                <p>675. Foreign Office announces that Paraguayan Ambassador informed Acting Minister
                    of Foreign Affairs<note n="82" xml:id="d256fn82">Gen. Diego I. Mason.</note>
                    this morning that relations of his Government with Argentine Government were
                    continuing without interruption since there was no reason to consider that they
                    had ever been suspended.</p>
                <p>Repeated to Asunción.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Armour</hi>
                    </signed>
                </closer>
            </div>
        </body>
