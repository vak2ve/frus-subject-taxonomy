    <text>
        <body>
            <div frus:doc-dateTime-max="1944-10-07T20:00:00-05:00"
                frus:doc-dateTime-min="1944-10-07T20:00:00-05:00" n="856"
                subtype="historical-document" type="document" xml:id="d856">
                <note rend="inline" type="source">810.5051/10–744: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Colombia</hi> (<persName type="from">
                        <hi rend="italic">Lane</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bogotá</hi>
                        </placeName>, <date calendar="gregorian" when="1944-10-07T20:00:00-05:00"
                            >October 7, 1944—8 p.m.</date>
                        <lb/> [Received October 8—12:40 a.m.]</dateline>
                </opener>
                <p>1725. Rubber Development Corporation has been informed by local bank that embargo
                    of 1000 pesos has been lifted. Reference Embassy’s despatch 4229, August
                        14.<note n="68" xml:id="d856fn68">Not printed.</note> Direct settlement now
                    possible.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lane</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
