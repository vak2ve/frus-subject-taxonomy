                subtype="historical-document" type="document" xml:id="d1498">
                <note rend="inline" type="source">833.24/8–144: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Uruguay</hi> (<persName type="from">
                        <hi rend="italic">Dawson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Montevideo</hi>
                        </placeName>, <date calendar="gregorian" when="1944-08-01T18:00:00-03:00"
                            >August 1, 1944—6 p.m.</date>
                        <lb/> [Received August 1—5:52 p.m.]</dateline>
                </opener>
                <p>739. PC<note n="37" xml:id="d1498fn37">Patrol vessel, submarine chaser.</note>
                    boat furnished Uruguay under lend-lease arrived Montevideo yesterday after
                    uneventful trip. Naval Attaché states President going aboard this afternoon,
                    Uruguayan authorities very pleased, and officers and crew of vessel delighted
                    with training and treatment in United States.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dawson</hi>
                    </signed>
                </closer>
            </div>
        </body>
