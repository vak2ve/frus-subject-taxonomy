                <note rend="inline" type="source">825.24/1865a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Chile</hi> (<persName type="to">
                        <hi rend="italic">Bowers</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1944-06-14">June 14,
                            1944</date>.</dateline>
                </opener>
                <p>692. Please reply immediately if Chile can be included in rollback
                    decentralization announcement along with other countries on June 15.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
