                subtype="historical-document" type="document" xml:id="d1065">
                <note rend="inline" type="source">816.00/1222: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in El Salvador</hi> (<persName type="from">
                        <hi rend="italic">Thurston</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Salvador</hi>
                        </placeName> [<date ana="#date_undated-inferred-from-document-content"
                            calendar="gregorian" notAfter="1944-04-02T20:55:00-06:00"
                            notBefore="1944-04-02T00:00:00-06:00">undated</date>].<lb/>[Received
                        April 2, 1944—8:55 p.m.]</dateline>
                </opener>
                <p>Revolutionary movement began San Salvador 4 o’clock this afternoon April 2.
                    Captain Massey<note n="1" xml:id="d1065fn1">Capt. G. B. Massey, Acting Military
                        Attaché.</note> requests War Department be informed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Thurston</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
