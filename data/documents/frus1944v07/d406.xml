<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1944-02-02T19:00:00-05:00" frus:doc-dateTime-min="1944-02-02T19:00:00-05:00" n="406" subtype="historical-document" type="document" xml:id="d406">
                        <note rend="inline" type="source">824.01/515: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Bolivia</hi> (<persName type="to"><hi rend="italic">Boal</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1944-02-02T20:00:00-04:00">February
                                    2, 1944—8 p.m.</date>
                            </dateline>
                        </opener>
                        <p>164. Reference is made to your 392 of February l.<note n="58" xml:id="d406fn58">Not printed.</note> The Department perceives no
                            reason why you should avoid an informal, unofficial meeting with
                            Villarroel but make no commitments.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>