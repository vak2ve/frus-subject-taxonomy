    <text>
        <body>
            <div frus:doc-dateTime-max="1944-07-31T10:00:00-05:00"
                frus:doc-dateTime-min="1944-07-31T10:00:00-05:00" n="849"
                subtype="historical-document" type="document" xml:id="d849">
                <note rend="inline" type="source">810.5051/7–2244: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Colombia</hi> (<persName type="to">
                        <hi rend="italic">Lane</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1944-07-31T11:00:00-04:00"
                            >July 31, 1944—11 a.m.</date>
                    </dateline>
                </opener>
                <p>942. Your 1301 July 22.<note n="62" xml:id="d849fn62">Not printed.</note> Urge
                    Foreign Minister to take action to have embargo removed on the ground that the
                    funds of the Rubber Development Corporation, an agency of this Government,
                    should be regarded as immune.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stettinius</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
