<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1944-03-17T22:00:00-05:00" frus:doc-dateTime-min="1944-03-17T22:00:00-05:00" n="357" subtype="historical-document" type="document" xml:id="d357">
                        <note rend="inline" type="source">811.91235/66a: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Argentina</hi> (<persName type="to"><hi rend="italic">Armour</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1944-03-17T23:00:00-04:00">March 17,
                                    1944—11 p.m.</date>
                            </dateline>
                        </opener>
                        <p>442. UP reports that Argentine Government has placed ban on all incoming
                            or outgoing messages and has instructed telephone and radio companies
                            not to accept UP messages. Please investigate and report by urgent
                            telegram.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>