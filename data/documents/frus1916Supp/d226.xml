                subtype="historical-document" type="document" xml:id="d226">
                <note rend="inline" type="source">File No. 763.72/2399</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1916-02-11T18:00:00+01:00">
                            <hi rend="italic">February 11, 1916, 6 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received February 12, 1 p. m.</hi>]</dateline>
                </opener>
                <p>3479. One of the two high officials in Foreign Office told friend of mine, with
                    evident intention that conversation should be repeated to me, that if forced by
                    United States, Germany would make an alliance with Russia and Japan against
                    America. I send this for what it is worth.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
