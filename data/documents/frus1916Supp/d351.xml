<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-05-13T04:00:00-05:00" frus:doc-dateTime-min="1916-05-13T04:00:00-05:00" n="351" subtype="historical-document" type="document" xml:id="d351">
                            <note rend="inline" type="source">File No. 763.72/2691</note>
                            <head>
                                <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="from"><hi rend="italic">Gerard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Berlin</hi></placeName>, <date calendar="gregorian" when="1916-05-13T11:00:00+02:00">
                                        <hi rend="italic">May 13, 1916, 11 a. m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 11.55 p. m.</hi>]</dateline>
                            </opener>
                            <p>3886. Chancellor said he thought he would not answer last American
                                note and asked me what I thought. I said that I agreed with him.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_GJW1">
                                        <hi rend="smallcaps">Gerard</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>