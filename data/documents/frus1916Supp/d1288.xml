                <note rend="inline" type="source">File No. 763.72112/2290</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)<note n="1" xml:id="d1288fn1">The same, <hi rend="italic">mutatis
                            mutandis</hi>, to the Ambassador in France, No. 1280.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-12-27">
                            <hi rend="italic">December 27, 1915</hi>
                        </date>.</dateline>
                </opener>
                <p>2639. Ascertain and report promptly whether British Government will permit
                    transportation of milk from this country to Germany and Austria, to be
                    distributed to babies in these countries under direction of American Red
                    Cross.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
