    <text>
        <body>
            <div frus:doc-dateTime-max="1916-10-13T23:59:59-05:00"
                frus:doc-dateTime-min="1916-10-13T00:00:00-05:00" n="573"
                subtype="historical-document" type="document" xml:id="d573">
                <note rend="inline" type="source">File No. 611.419/938</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-10-13">
                            <hi rend="italic">October 13, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>3936. Department’s 3945, July 26.<note n="1" xml:id="d573fn1">Not printed.</note>
                    Merck and Company report that drugs specified are badly needed. Make endeavor to
                    hasten consideration, if license not definitely refused. Firm says they have
                    heard it stated that shipments to other firms have been licensed.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
