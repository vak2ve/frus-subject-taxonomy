    <text>
        <body>
            <div frus:doc-dateTime-max="1916-12-05T12:00:00-05:00"
                frus:doc-dateTime-min="1916-12-05T12:00:00-05:00" n="424"
                subtype="historical-document" type="document" xml:id="d424">
                <note rend="inline" type="source">File No. 841.857/244</note>
                <head>
                    <hi rend="italic">The Chargé in Germany</hi> (<persName corresp="#p_GJC1"
                        type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1916-12-05T18:00:00+01:00">
                            <hi rend="italic">December 5, 1916, 6 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received December 6, 11.45 p. m.</hi>]</dateline>
                </opener>
                <p>4691. Foreign Office requests me to transmit through the Department to <persName
                        corresp="#p_BJHACV1">Count Bernstorff</persName> the following cipher
                    telegram which is said to relate to the case of the <hi rend="italic"
                        >Arabia</hi> and to contain instructions to <persName corresp="#p_BJHACV1"
                        >Count Bernstorff</persName> to endeavor to settle the matter by
                    conversations in Washington.</p>
                <p>[German cipher.<note n="3" xml:id="d424fn3">Not printed.</note>]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJC1">
                            <hi rend="smallcaps">Grew</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
