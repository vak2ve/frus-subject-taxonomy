    <text>
        <body>
            <div frus:doc-dateTime-max="1916-10-19T23:59:59-05:00"
                frus:doc-dateTime-min="1916-10-19T00:00:00-05:00" n="578"
                subtype="historical-document" type="document" xml:id="d578">
                <note rend="inline" type="source">File No. 300.115/10373</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1916-10-19">
                            <hi rend="italic">October 19, 1916</hi>
                        </date>.<lb/>[<hi rend="italic">Received 8.55 p. m.</hi>]</dateline>
                </opener>
                <p>5049. Your 3913,<note n="1" xml:id="d578fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_455">p. 455</ref>.</note>
                    October 10. Foreign Office informs that on receipt of Embassy’s note the British
                    Government was at once requested to authorize the granting of bunkers to the S.
                    S. <hi rend="italic">Pathfinder</hi>.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
