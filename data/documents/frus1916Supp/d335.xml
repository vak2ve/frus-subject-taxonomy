                subtype="historical-document" type="document" xml:id="d335">
                <note rend="inline" type="source">File No. 763.72/2630</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="to">
                        <hi rend="italic">Gerard</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-05-05T15:00:00-05:00">
                            <hi rend="italic">May 5, 1916, 3 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>2975. Please telegraph me what use, if any, has been made of memorandum quoted in
                    my 2951, April 28, and whether it was made known to the German Government before
                    the dispatch of its note on submarine warfare which you are now forwarding.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
