                subtype="historical-document" type="document" xml:id="d280">
                <note rend="inline" type="source">File No. 851.857Su8/13</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1916-03-28T13:00:00+00:00">
                            <hi rend="italic">March 28, 1916, 1 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 12.45 p. m.</hi>]</dateline>
                </opener>
                <p>4044. Your 3098, March 27, 1 p. m. In reply to my inquiry, the British Admiralty
                    state categorically that <hi rend="italic">Sussex</hi> was not armed, and
                    further that it is not customary for cross-channel passenger steamers to be
                    armed.</p>
                <closer>
                    <hi rend="smallcaps">American Embassy</hi>
                </closer>
            </div>
        </body>
