    <text>
        <body>
            <div frus:doc-dateTime-max="1916-12-09T18:00:00-05:00"
                frus:doc-dateTime-min="1916-12-09T18:00:00-05:00" n="428"
                subtype="historical-document" type="document" xml:id="d428">
                <note rend="inline" type="source">File No. 841.857/240</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Germany</hi> (<persName corresp="#p_GJC1" type="to">
                        <hi rend="italic">Grew</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-12-09T18:00:00-05:00">
                            <hi rend="italic">December 9, 1916, 6 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3652. Department advised that British <persName>S. S. <hi rend="italic"
                            >Barbara</hi>
                    </persName>, with Americans on board, was sunk by a German submarine in the
                    British Channel October 20. The vessel was carrying cargo of coal from
                    Philadelphia to Hartlepool.</p>
                <p>Please request the Foreign Minister for prompt investigation and report.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
