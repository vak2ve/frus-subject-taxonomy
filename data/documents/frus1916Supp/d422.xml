<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-12-05T13:00:00-05:00" frus:doc-dateTime-min="1916-12-05T13:00:00-05:00" n="422" subtype="historical-document" type="document" xml:id="d422">
                            <note rend="inline" type="source">File No. 841.857/243</note>
                            <head>
                                <hi rend="italic">The Chargé in Germany</hi> (<persName corresp="#p_GJC1" type="from"><hi rend="italic">Grew</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Berlin</hi></placeName>, <date calendar="gregorian" when="1916-12-05T19:00:00+01:00">
                                        <hi rend="italic">December 5, 1916, 7 p. m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received December 6, 4 p.
                                    m.</hi>]</dateline>
                            </opener>
                            <p>4692. Foreign Office requests me to say that the confidential and
                                oral statement cabled in my 4655,<note n="2" xml:id="d422fn2">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_313">p.
                                    313</ref>.</note> November 27, 3 p. m., regarding the <hi rend="italic">Marina</hi> applies equally to the case of the <hi rend="italic">Arabia</hi>.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_GJC1">
                                        <hi rend="smallcaps">Grew</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>