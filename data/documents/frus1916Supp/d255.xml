<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-03-06T10:00:00-05:00" frus:doc-dateTime-min="1916-03-06T10:00:00-05:00" n="255" subtype="historical-document" type="document" xml:id="d255">
                            <note rend="inline" type="source">File No. 763.72/2466</note>
                            <head>
                                <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="from"><hi rend="italic">Gerard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Berlin</hi></placeName>, <date calendar="gregorian" when="1916-03-06T16:00:00+01:00">
                                        <hi rend="italic">March 6, 1916, 4 p. m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received March 7, 11.15 a.
                                    m.</hi>]</dateline>
                            </opener>
                            <p>3579. Learn fair authority <persName corresp="#p_TAPFV1">Von
                                    Tirpitz</persName> proposal for unlimited submarine blockade of
                                England rejected in grand council war at Charleville.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_GJW1">
                                        <hi rend="smallcaps">Gerard</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>