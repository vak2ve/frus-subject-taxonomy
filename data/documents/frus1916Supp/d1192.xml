<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-01-21T23:59:59-05:00" frus:doc-dateTime-min="1916-01-21T00:00:00-05:00" n="1192" subtype="historical-document" type="document" xml:id="d1192">
                            <note rend="inline" type="source">File No. 872.48/24</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="to"><hi rend="italic">Gerard</hi></persName>)<note n="1" xml:id="d1192fn1">The same, <hi rend="italic">mutatis
                                        mutandis</hi>, to the Ambassador in Austria-Hungary (No.
                                    1093) and the Chargé in Bulgaria (No. 21).</note>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-01-21">
                                        <hi rend="italic">January 21, 1916</hi>
                                    </date>.</dateline>
                            </opener>
                            <p>2619. Red Cross desires to transport relief supplies by land from
                                Holland to Serbia. Ascertain and report attitude German Government
                                relative to such shipments.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>