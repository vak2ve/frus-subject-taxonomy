<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-02-12T23:59:59-05:00" frus:doc-dateTime-min="1917-02-12T00:00:00-05:00" n="775" subtype="historical-document" type="document" xml:id="d775">
                            <note rend="inline" type="source">File No. 300.115/11569a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-02-12">
                                        <hi rend="italic">February 12, 1917</hi>
                                    </date>.</dateline>
                            </opener>
                            <p>4432. Department’s 4330, January 24. Press for prompt consideration
                                as hosiery and underwear industry in most urgent need of needles now
                                held at Rotterdam and Copenhagen. Emphasize injurious consequences
                                of further delay.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>