<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-01-13T23:59:59-05:00" frus:doc-dateTime-min="1916-01-13T00:00:00-05:00" n="710" subtype="historical-document" type="document" xml:id="d710">
                            <note rend="inline" type="source">File No. 165.102/747</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-01-13">
                                        <hi rend="italic">January 13, 1916</hi>
                                    </date>.</dateline>
                            </opener>
                            <p>2709. Department’s 2644, December 28. Urge Foreign Office for early
                                reply in view pressing industrial need dyestuff in United
                                States.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>