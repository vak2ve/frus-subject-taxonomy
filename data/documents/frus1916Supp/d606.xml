<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-05-23T23:59:59-05:00" frus:doc-dateTime-min="1916-05-23T00:00:00-05:00" n="606" subtype="historical-document" type="document" xml:id="d606">
                            <note rend="inline" type="source">File No. 763.72112/3415</note>
                            <head>
                                <hi rend="italic">The Commercial Adviser of the British Embassy</hi>
                                    (<persName corresp="#p_CSRF1" type="from"><hi rend="italic">Crawford</hi></persName>) <hi rend="italic">to the Foreign
                                    Trade Adviser of the Department of State</hi> (<persName corresp="#p_HCA1" type="to"><hi rend="italic">Holder</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-05-23">
                                        <hi rend="italic">May 23, 1916</hi>
                                    </date>.<lb/>[<hi rend="italic">Received May
                                    24</hi>.]</dateline>
                            </opener>
                            <p>
                                <hi rend="smallcaps">My Dear Doctor <persName corresp="#p_HCA1">Holder</persName></hi>: In reply to your letter of the
                                20th, the matter to which you call our attention had already come
                                before us, and we are in communication with the Foreign Office with
                                regard to it.</p>
                            <p>Yours very truly,</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_CSRF1">
                                        <hi rend="smallcaps">R. Crawford</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>