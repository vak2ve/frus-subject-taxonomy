<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-12-10T14:00:00-05:00" frus:doc-dateTime-min="1915-12-10T14:00:00-05:00" n="703" subtype="historical-document" type="document" xml:id="d703">
                            <note rend="inline" type="source">File No. 165.102/708a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="to"><hi rend="italic">Gerard</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-12-10T14:00:00-05:00">
                                        <hi rend="italic">December 10, 1915, 2 p. m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>2489. Department desires to have as promptly as possible full and
                                exact restatement of present attitude of German Government as to
                                exportation of dyestuffs to United States and other countries.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>