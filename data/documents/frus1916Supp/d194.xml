                subtype="historical-document" type="document" xml:id="d194">
                <note rend="inline" type="source">File No. 841.857P43/22</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1916-01-17T22:00:00+01:00">
                            <hi rend="italic">January 17, 1916, 10 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received January 18, 2 p. m.</hi>]</dateline>
                </opener>
                <p>3360. Undersecretary <persName corresp="#p_ZAFM1">Zimmermann</persName> informed
                    me to-day that reports are now in from all German submarines and that sinking of
                        <hi rend="italic">Persia</hi> was not caused by a German submarine.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
