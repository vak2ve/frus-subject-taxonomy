<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-07-15T06:00:00-05:00" frus:doc-dateTime-min="1916-07-15T06:00:00-05:00" n="1004" subtype="historical-document" type="document" xml:id="d1004">
                        <note rend="inline" type="source">File No. 763.72111D48/13</note>
                        <head>
                            <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="from"><hi rend="italic">Gerard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Berlin</hi></placeName>, <date calendar="gregorian" when="1916-07-15T13:00:00+02:00">
                                    <hi rend="italic">July 15, 1916, 1 p. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received July 16, 8 p. m.</hi>]</dateline>
                        </opener>
                        <p>4123. Will <hi rend="italic">Deutschland</hi> be recognized as merchant
                            vessel? Germans much interested.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_GJW1">
                                    <hi rend="smallcaps">Gerard</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>