<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-03-16T06:00:00-05:00" frus:doc-dateTime-min="1916-03-16T06:00:00-05:00" n="13" subtype="historical-document" type="document" xml:id="d13">
                        <note rend="inline" type="source">File No. 763.72/2499</note>
                        <head>
                            <hi rend="italic">The Minister in Portugal</hi> (<persName corresp="#p_BTH1" type="from"><hi rend="italic">Birch</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Lisbon</hi></placeName>, <date calendar="gregorian" when="1916-03-16T11:00:00+00:00">
                                    <hi rend="italic">March 16, 1916, 11 a. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received 5 p. m.</hi>]</dateline>
                        </opener>
                        <p>36. Diplomatic relations broken off between Portugal and Austria-Hungary.
                            No declaration of war. Austro-Hungarian Minister leaving to-day.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_BTH1">
                                    <hi rend="smallcaps">Birch</hi>
                                </persName>
                            </signed>
                        </closer>
                        <postscript>
                            <p>[For statements regarding peace terms and the possibility of
                                mediation made by the Chancellor in a conversation with the
                                Ambassador, see telegram No. 3640, March 18, 1916, received March
                                19, from the Ambassador in Germany, <hi rend="italic">post</hi>,
                                    <ref target="#pg_207">page 207</ref>.]</p>
                        </postscript>
                    </div>
                    </body></text></TEI>