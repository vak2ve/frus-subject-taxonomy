                subtype="historical-document" type="document" xml:id="d326">
                <note rend="inline" type="source">File No. 763.72/2635</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1916-04-27T14:00:00+01:00">
                            <hi rend="italic">April 27, 1916, 2 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received April 28, 8.30 a. m.</hi>]</dateline>
                </opener>
                <p>3816. <persName corresp="#p_JGEGV1">Von Jagow</persName> called early this
                    morning and asked me to go to Great Headquarters to-night. I am in dark as to
                    object of this and did not ask any audience. Suppose it is either for the
                    purpose of helping persuade Emperor to Chancellor’s views or to gain time for
                    answering your note.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
