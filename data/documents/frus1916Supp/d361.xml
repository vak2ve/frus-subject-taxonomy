<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-06-13T17:00:00-05:00" frus:doc-dateTime-min="1916-06-13T17:00:00-05:00" n="361" subtype="historical-document" type="document" xml:id="d361">
                            <note rend="inline" type="source">File No. 341.622a/150</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="to"><hi rend="italic">Gerard</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-06-13T17:00:00-05:00">
                                        <hi rend="italic">June 13, 1916, 5 p. m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>3086. Your 3978, June 9, noon. <hi rend="italic">China</hi>
                                correspondence will be made public as soon as believed
                                    expedient.<note n="1" xml:id="d361fn1">It was excluded from the
                                    volume, <hi rend="italic">European War No. 3, Diplomatic
                                        Correspondence with Belligerent Governments relating to
                                        Neutral Rights and Duties</hi>, printed and distributed by
                                    the Department of State in August 1916, and remained
                                    unpublished, with the exception of the telegraphic instructions
                                    of February 23, 1916, to the Ambassador in Great Britain and the
                                    British note of March 16, 1916 (<hi rend="italic">post</hi>,
                                        <ref target="#pg_632">pp. 632</ref>, <ref target="#pg_633">633</ref>), which had already been released in
                                    April.</note>
                            </p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>