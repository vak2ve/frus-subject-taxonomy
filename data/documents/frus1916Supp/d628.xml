                subtype="historical-document" type="document" xml:id="d628">
                <note rend="inline" type="source">File No. 763.72112/2679</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1916-06-29">
                            <hi rend="italic">June 29, 1916</hi>
                        </date>.<lb/>[<hi rend="italic">Received 5.30 p. m.</hi>]</dateline>
                </opener>
                <p>4507. My 3281,<note n="2" xml:id="d628fn2">
                        <ref target="frus1915Supp#pg_206">
                            <hi rend="italic">Foreign Relations</hi>, 1915, Supplement, p.
                        206</ref>.</note> November 25 and 2713,<note n="1" xml:id="d628fn1">Not
                        printed.</note> December 20, <hi rend="italic">re</hi> shipment tobacco to
                    neutral consignees in neutral countries. Am to-day in receipt circular from
                    Foreign Office stating British Government unable continue policy of permitting
                    unrestricted importation tobacco into enemy countries and cannot guarantee
                    future continuance noninterference which they have hitherto extended to such
                    shipments. Copy circular follows in next pouch.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
