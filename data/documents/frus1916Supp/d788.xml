                <note rend="inline" type="source">File No. 763/72112/2556</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in the Netherlands</hi> (<persName corresp="#p_VDH1" type="to">
                        <hi rend="italic">Van Dyke</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-06-08T16:00:00-05:00">
                            <hi rend="italic">June 8, 1916, 4 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>323. Referring your despatch 472 of May 16, officially request clear statement
                    and definition of the relation of the Netherlands Government to the Oversea
                    Trust and cable reply if possible.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
