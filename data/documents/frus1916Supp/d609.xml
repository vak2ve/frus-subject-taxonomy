                <note rend="inline" type="source">File No. 763.72112/2696</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Consul at Saloniki</hi> (<persName corresp="#p_KJE1" type="to">
                        <hi rend="italic">Kehl</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-07-08">
                            <hi rend="italic">July 8, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>Department has not given its approval to arrangements for issuance [of] letters
                    of assurance by British Embassy, Washington. American consuls in Greece should
                    have nothing to do with requests of this character.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
