                subtype="historical-document" type="document" xml:id="d1119">
                <note rend="inline" type="source">File No. 867.48/420</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Turkey</hi> (<persName corresp="#p_PH1" type="to">
                        <hi rend="italic">Philip</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-09-22T16:00:00-05:00">
                            <hi rend="italic">September 22, 1916, 4 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>2978. Your confidential 2073, September 7, 9 a. m.<note n="1" xml:id="d1119fn1"
                        >Not printed.</note> Report further details this matter. What if any action
                    by Department in your opinion would alleviate conditions?</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
