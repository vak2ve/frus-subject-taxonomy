                subtype="historical-document" type="document" xml:id="d1236">
                <note rend="inline" type="source">File No. 867.48/312</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Turkey</hi> (<persName corresp="#p_PH1" type="to">
                        <hi rend="italic">Philip</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-06-24T17:00:00-05:00">
                            <hi rend="italic">June 24, 1916, 5 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>2784. Your 1896, June 20.<note n="1" xml:id="d1236fn1">Not printed.</note> If
                    Turkish Government is not attempting to starve inhabitants of Lebanon, what are
                    its objections, if any, to sending relief supplies to Syria and Lebanon? Prompt
                    reply desired. Great interest in this question in United States.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
