    <text>
        <body>
            <div frus:doc-dateTime-max="1916-04-27T23:59:59-05:00"
                frus:doc-dateTime-min="1916-04-27T00:00:00-05:00" n="1228"
                subtype="historical-document" type="document" xml:id="d1228">
                <note rend="inline" type="source">File No. 811.142/1542</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName corresp="#p_SWG1" type="to">
                        <hi rend="italic">Sharp</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-04-27">
                            <hi rend="italic">April 27, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>1486. Your 1344, April 4.<note n="2" xml:id="d1228fn2">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_927">p. 927</ref>.</note>
                    Inquire if French Government would permit boat to come out of port of Jaffa
                    under proper safeguards to meet American ship and receive medical supplies.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
