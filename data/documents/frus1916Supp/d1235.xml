<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-06-23T16:00:00-05:00" frus:doc-dateTime-min="1916-06-23T16:00:00-05:00" n="1235" subtype="historical-document" type="document" xml:id="d1235">
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in Turkey</hi> (<persName corresp="#p_PH1" type="to"><hi rend="italic">Philip</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-06-23T16:00:00-05:00">
                                        <hi rend="italic">June 23, 1916, 4 p. m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>2779. Your 1889, June 17. Do not cease to urge the Ottoman Government
                                to grant permission for sending relief supplies to Syria. Keep
                                Department fully and promptly informed.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>