<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-08-30T10:00:00-05:00" frus:doc-dateTime-min="1916-08-30T10:00:00-05:00" n="65" subtype="historical-document" type="document" xml:id="d65">
                        <note rend="inline" type="source">File No. 763.72/2843</note>
                        <head>
                            <hi rend="italic">The Chargé in Turkey</hi> (<persName corresp="#p_PH1" type="from"><hi rend="italic">Philip</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Constantinople</hi></placeName>, <date calendar="gregorian" when="1916-08-30T18:00:00+03:00">
                                    <hi rend="italic">August 30, 1916, 6 p. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received September 2, 7 p.
                                m.</hi>]</dateline>
                        </opener>
                        <p>2053. Ottoman Council of Ministers yesterday adopted decision
                            subsequently sanctioned by Imperial decree by which Turkey in common
                            action with Germany and Bulgaria declares war on Roumania.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_PH1">
                                    <hi rend="smallcaps">Philip</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>