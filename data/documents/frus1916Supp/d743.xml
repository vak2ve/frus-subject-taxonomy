<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-03-14T09:00:00-05:00" frus:doc-dateTime-min="1916-03-14T09:00:00-05:00" n="743" subtype="historical-document" type="document" xml:id="d743">
                            <note rend="inline" type="source">File No. 165.102/888</note>
                            <head>
                                <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1916-03-14T14:00:00+00:00">
                                        <hi rend="italic">March 14, 1916, 2 p. m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 1 p. m.</hi>]</dateline>
                            </opener>
                            <p>3949. Your 3023, March 10, 5 p. m. brought to personal attention of
                                    <persName corresp="#p_GSE1">Sir Edward Grey</persName> who
                                promised me that he would give the matter his further consideration
                                and send definite reply at an early date.</p>
                            <closer>
                                <hi rend="smallcaps">American Embassy</hi>
                            </closer>
                        </div>
                        </body></text></TEI>