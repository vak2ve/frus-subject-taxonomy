    <text>
        <body>
            <div frus:doc-dateTime-max="1916-11-15T09:00:00-05:00"
                frus:doc-dateTime-min="1916-11-15T09:00:00-05:00" n="884"
                subtype="historical-document" type="document" xml:id="d884">
                <note rend="inline" type="source">File No. 341.622a/266</note>
                <head>
                    <hi rend="italic">The Consul General at Shanghai</hi> (<persName
                        corresp="#p_ST1" type="from">
                        <hi rend="italic">Sammons</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1916-11-15T22:00:00+08:00">
                            <hi rend="italic">November 15, 1916, 10 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 11.10 a. m.</hi>]</dateline>
                </opener>
                <p>Your November 14, 5 p. m.<note n="1" xml:id="d884fn1">Not printed.</note> Men
                    seized from S. S. <hi rend="italic">China</hi> arrived Shanghai by S. S. <hi
                        rend="italic">Malta</hi> yesterday, transshipped Hongkong.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_ST1">
                            <hi rend="smallcaps">Sammons</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
