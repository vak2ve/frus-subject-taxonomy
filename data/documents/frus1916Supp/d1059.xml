<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-12-18T16:00:00-05:00" frus:doc-dateTime-min="1916-12-18T16:00:00-05:00" n="1059" subtype="historical-document" type="document" xml:id="d1059">
                        <note rend="inline" type="source">File No. 701.6311/251</note>
                        <head>
                            <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_SWG1" type="from"><hi rend="italic">Sharp</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1916-12-18T21:00:00+00:00">
                                    <hi rend="italic">December 18, 1916, 9 p. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received December 19, 9.15 a.
                                m.</hi>]</dateline>
                        </opener>
                        <p>1749. My 1744, December 14, 3 p. m.<note n="2" xml:id="d1059fn2">Not
                                printed.</note> Have just learned at Foreign Office that the French
                            Government will accord safe-conduct for Count
                                <persName>Tarnowski</persName> and suite.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_SWG1">
                                    <hi rend="smallcaps">Sharp</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>