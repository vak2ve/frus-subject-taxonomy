    <text>
        <body>
            <div frus:doc-dateTime-max="1916-11-20T13:00:00-05:00"
                frus:doc-dateTime-min="1916-11-20T13:00:00-05:00" n="85"
                subtype="historical-document" type="document" xml:id="d85">
                <note rend="inline" type="source">File No. 763.72119/184</note>
                <head>
                    <hi rend="italic">The Chargé in Germany</hi> (<persName corresp="#p_GJC1"
                        type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1916-11-20T19:00:00+01:00">
                            <hi rend="italic">November 20, 1916, 7 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received November 21, 4.50 p. m.</hi>]</dateline>
                </opener>
                <p>4626. Referring to my telegram 4614,<note n="1" xml:id="d85fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_64">p. 64</ref>.</note>
                    November 17. <persName>Hale</persName>’s cablegram has been unexpectedly delayed
                    owing to the Chancellor’s departure for General Headquarters but he expects to
                    be able to send it within a few days.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJC1">
                            <hi rend="smallcaps">Grew</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
