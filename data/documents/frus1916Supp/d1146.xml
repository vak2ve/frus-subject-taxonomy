<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-08-02T17:00:00-05:00" frus:doc-dateTime-min="1916-08-02T17:00:00-05:00" n="1146" subtype="historical-document" type="document" xml:id="d1146">
                        <note rend="inline" type="source">File No. 841.00/20a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-08-02T17:00:00-05:00">
                                    <hi rend="italic">August 2, 1916, 5 p. m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>3608. Department’s 3606, August 2. Please report immediately if Senate
                            resolution presented to Foreign Office, and also any further details on
                            Casement case.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_PFL1">
                                    <hi rend="smallcaps">Polk</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>