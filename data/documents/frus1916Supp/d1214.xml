<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-01-26T23:59:59-05:00" frus:doc-dateTime-min="1916-01-26T00:00:00-05:00" n="1214" subtype="historical-document" type="document" xml:id="d1214">
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Turkey</hi> (<persName corresp="#p_MH1" type="to"><hi rend="italic">Morgenthau</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-01-26">
                                        <hi rend="italic">January 26, 1916</hi>
                                    </date>.</dateline>
                            </opener>
                            <p>1758. Your 1494, 17th. Supplies are for American Red Cross hospital
                                Beirut, except small portion thereof intended American
                                community.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>