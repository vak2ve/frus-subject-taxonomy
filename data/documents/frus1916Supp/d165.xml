    <text>
        <body>
            <div frus:doc-dateTime-max="1916-12-27T15:00:00-05:00"
                frus:doc-dateTime-min="1916-12-27T15:00:00-05:00" n="165"
                subtype="historical-document" type="document" xml:id="d165">
                <note rend="inline" type="source">File No. 763.72119/240</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Spain</hi> (<persName corresp="#p_WWB1" type="to">
                        <hi rend="italic">Wilson</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-12-27T15:00:00-05:00">
                            <hi rend="italic">December 27, 1916, 3 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>200. Your 302, December 22, 8 p. m.<note n="1" xml:id="d165fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_110">p. 110</ref>.</note>
                    Department’s 197, December 20, 7 p. m.,<note n="2" xml:id="d165fn2">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_102">p. 102</ref>.</note> was
                    intended for Spanish Government alone, and has not been sent to other neutral
                    powers.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
