    <text>
        <body>
            <div frus:doc-dateTime-max="1916-05-17T23:59:59-05:00"
                frus:doc-dateTime-min="1916-05-17T00:00:00-05:00" n="898"
                subtype="historical-document" type="document" xml:id="d898">
                <note rend="inline" type="source">File No. 763.72112/2620</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName corresp="#p_GGW1"
                        type="from">
                        <hi rend="italic">Guthrie</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 516</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1916-05-17">
                            <hi rend="italic">May 17, 1916</hi>
                        </date>.<lb/>[<hi rend="italic">Received June 9</hi>.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to transmit herewith, for the
                    information of the Department, copy of instructions received from the Imperial
                    Foreign Office which have been issued by the Japanese Navy Department for the
                    guidance of its naval officers in boarding merchant vessels.<note n="1"
                        xml:id="d898fn1">Not printed; similar to those conveyed in the British
                        Ambassador’s note No, 67 of March 11, 1916, <hi rend="italic">ante</hi>,
                            <ref target="#pg_680">p. 680</ref>.</note>
                </p>
                <p>Copies of these instructions have been sent to American consular officers in this
                    Empire, as well as to the naval attaché of this Embassy.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GGW1">
                            <hi rend="smallcaps">Geo. W. Guthrie</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
