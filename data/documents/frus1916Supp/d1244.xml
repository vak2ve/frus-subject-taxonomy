<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-08-22T23:59:59-05:00" frus:doc-dateTime-min="1916-08-22T00:00:00-05:00" n="1244" subtype="historical-document" type="document" xml:id="d1244">
                            <note rend="inline" type="source">File No. 811.142/1712</note>
                            <head>
                                <hi rend="italic">The Chargé in France</hi> (<persName corresp="#p_BRW1" type="from"><hi rend="italic">Bliss</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1916-08-22">
                                        <hi rend="italic">August 22, 1916</hi>
                                    </date>.<lb/>[<hi rend="italic">Received 4 p.
                                    m.</hi>]</dateline>
                            </opener>
                            <p>1545. Department’s 1658, 15th.<note n="2" xml:id="d1244fn2">Not
                                    printed.</note> Conditions imposed are that vessel transporting
                                supplies must conform to measures prescribed by French naval
                                authorities for passage of line of blockade. Admiral de Spitz has
                                authority to make all arrangements.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_BRW1">
                                        <hi rend="smallcaps">Bliss</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>