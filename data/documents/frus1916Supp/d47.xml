                subtype="historical-document" type="document" xml:id="d47">
                <note rend="inline" type="source">File No. 862.00/32</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1916-06-29T13:00:00+02:00">
                            <hi rend="italic">June 29, 1916, 1 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received June 30, 12.40 p. m.</hi>]</dateline>
                </opener>
                <p>4071. Liebknecht sentenced to penitentiary for 2 years, 6 months, 3 days, by
                    court martial. Small disturbances in Berlin. Reported that workers in several
                    ammunition factories on strike. Streets filled with police.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
