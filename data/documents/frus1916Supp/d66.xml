                subtype="historical-document" type="document" xml:id="d66">
                <note rend="inline" type="source">File No. 763.72/2844a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Roumania</hi> (<persName corresp="#p_VCJ1" type="to">
                        <hi rend="italic">Vopicka</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-09-06T16:00:00-05:00">
                            <hi rend="italic">September 6, 1916, 4 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>304. Has war against Roumania been declared by Germany and Bulgaria or <hi
                        rend="italic">vice versa</hi>? Cable.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
