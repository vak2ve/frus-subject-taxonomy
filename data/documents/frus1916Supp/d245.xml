                subtype="historical-document" type="document" xml:id="d245">
                <note rend="inline" type="source">File No. 763.72/2441</note>
                <head>
                    <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="from">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1916-02-28T16:00:00+01:00">
                            <hi rend="italic">February 28, 1916, 4 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received February 29, 2.20 p. m.</hi>]</dateline>
                </opener>
                <p>1168. I have been reliably informed that on Saturday, the 26th, Vienna press were
                    advised by the Ministry of Foreign Affairs that the relations between Germany
                    and the United States had reached critical stage and they were instructed to
                    exercise the greatest reserve in commenting thereon.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
