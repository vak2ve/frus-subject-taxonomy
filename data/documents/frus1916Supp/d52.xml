    <text>
        <body>
            <div frus:doc-dateTime-max="1916-08-10T23:59:59-05:00"
                frus:doc-dateTime-min="1916-08-10T00:00:00-05:00" n="52"
                subtype="historical-document" type="document" xml:id="d52">
                <note rend="inline" type="source">File No. 871.6131/2</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1916-08-10">
                            <hi rend="italic">August 10, 1916</hi>
                        </date>.<lb/>[<hi rend="italic">Received August 11, 12
                        noon</hi>.]</dateline>
                </opener>
                <p>4214. New agreement between Roumania and Central powers concluded regarding sale
                    approximately 2,000 railway carloads peas at 5,600 lei each and 6,000 carloads
                    barley for brewing purposes at 4,500 lei each.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
