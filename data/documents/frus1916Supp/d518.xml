<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-07-20T23:59:59-05:00" frus:doc-dateTime-min="1916-07-20T00:00:00-05:00" n="518" subtype="historical-document" type="document" xml:id="d518">
                            <note rend="inline" type="source">File No. 763.72112/2742</note>
                            <head>
                                <hi rend="italic">The Russian Ambassador</hi> (<persName corresp="#p_BG1" type="from"><hi rend="italic">Bakhméteff</hi></persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#left">No. 523</seg>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Newport, R. I.</hi></placeName>, <date calendar="gregorian" when="1916-07-20">
                                        <hi rend="italic">July 20, 1916</hi>
                                    </date>.<lb/>[<hi rend="italic">Received July
                                    25</hi>.]</dateline>
                            </opener>
                            <p rend="center">[Translation]</p>
                            <p>
                                <hi rend="smallcaps">Mr. Acting Secretary</hi>: I am instructed to
                                inform you that the Imperial Government, desirous of acting in
                                perfect accord with its allies on questions of maritime warfare,
                                joins the English and French Governments in denouncing the
                                Declaration of London of 1909.</p>
                            <p>Begging you to make the foregoing known to the Federal Government, I
                                take this opportunity [etc.]</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_BG1">
                                        <hi rend="smallcaps">G. Bakhméteff</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>