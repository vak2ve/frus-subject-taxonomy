                subtype="historical-document" type="document" xml:id="d551">
                <note rend="inline" type="source">File No. 763.72112/2948a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Great Britain</hi> (<persName corresp="#p_LIB1" type="to">
                        <hi rend="italic">Laughlin</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-09-08T18:00:00-05:00">
                            <hi rend="italic">September 8, 1916, 6 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3806. Your 4814,<note n="1" xml:id="d551fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_439">p. 439</ref>.</note>
                    September 1, 12 noon. You will say to Foreign Office that this Government would
                    like to be informed as to conditions under which the British Government
                    subordinate the granting of bunkering facilities to neutral ships.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
