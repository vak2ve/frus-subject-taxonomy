    <text>
        <body>
            <div frus:doc-dateTime-max="1916-02-07T16:30:00-05:00"
                frus:doc-dateTime-min="1916-02-07T16:30:00-05:00" n="218"
                subtype="historical-document" type="document" xml:id="d218">
                <note rend="inline" type="source">File No. 763.72/2379</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-02-07T16:30:00-05:00">
                            <hi rend="italic">February 7, 1916 4.30. p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>2830. Your 3703,<note n="1" xml:id="d218fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_157">p. 157</ref>.</note> 3d.
                    Please investigate thoroughly cases of <hi rend="italic">Kashgar</hi> and <hi
                        rend="italic">City of Marseilles</hi> and endeavor to obtain reliable
                    information.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
