<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-10-07T17:00:00-05:00" frus:doc-dateTime-min="1916-10-07T17:00:00-05:00" n="763" subtype="historical-document" type="document" xml:id="d763">
                            <note rend="inline" type="source">File No. 300.115/10266a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Consul General at London</hi>
                                    (<persName corresp="#p_SRP1" type="to"><hi rend="italic">Skinner</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-10-07T17:00:00-05:00">
                                        <hi rend="italic">October 7, 1916, 5 p. m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Make discreet inquiries about supplies and classes knitting needles
                                available for shipment to United States and give names of dealers.
                                Confer with Embassy regarding Foreign Office note of September 4 to
                                Embassy in this matter.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_PFL1">
                                        <hi rend="smallcaps">Polk</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>