    <text>
        <body>
            <div frus:doc-dateTime-max="1916-09-30T23:59:59-05:00"
                frus:doc-dateTime-min="1916-09-30T00:00:00-05:00" n="920"
                subtype="historical-document" type="document" xml:id="d920">
                <note rend="inline" type="source">File No. 763.72111So4/16</note>
                <head>
                    <hi rend="italic">The British Ambassador</hi> (<persName corresp="#p_SRSCA1"
                        type="from">
                        <hi rend="italic">Spring Rice</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-09-30">
                            <hi rend="italic">September 30, 1916</hi>
                        </date>.<lb/>[<hi rend="italic">Received October 4</hi>.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: I beg to acknowledge with
                    thanks the receipt of your letter of the 29th instant<note n="1"
                        xml:id="d920fn1">Not printed; see letter of September 22, <hi rend="italic"
                            >ante</hi>, <ref target="#pg_704">p. 704</ref>.</note> and to inform you
                    that I have not failed to communicate to His Majesty’s Government the desire of
                    the United States Government that steps may be taken to prevent members of the
                    armed forces of the United Kingdom from entering United States ports <hi
                        rend="italic">en route</hi> to Canada after September 26.</p>
                <p>Believe me [etc.]</p>
                <closer>For the Ambassador: <lb/>
                    <signed>
                        <persName corresp="#p_BCADR1">
                            <hi rend="smallcaps">Colville Barclay</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
