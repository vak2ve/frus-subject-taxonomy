<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-08-28T19:00:00-05:00" frus:doc-dateTime-min="1916-08-28T19:00:00-05:00" n="759" subtype="historical-document" type="document" xml:id="d759">
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in Great Britain</hi> (<persName corresp="#p_LIB1" type="to"><hi rend="italic">Laughlin</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-08-28T19:00:00-05:00">
                                        <hi rend="italic">August 28, 1916, 7 p. m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>3750. Department surprised that no reply received to Department’s
                                instruction 3676, May 29, with reference to very urgent need
                                knitting needles in United States. Urge early and favorable reply in
                                matter.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>