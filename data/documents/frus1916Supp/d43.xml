<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-05-13T16:00:00-05:00" frus:doc-dateTime-min="1916-05-13T16:00:00-05:00" n="43" subtype="historical-document" type="document" xml:id="d43">
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="to"><hi rend="italic">Gerard</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-05-13T16:00:00-05:00">
                                    <hi rend="italic">June 13, 1916, 4 p. m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>3085. Your 3972, June 8. You are authorized to say that the Department
                            has given no statement whatsoever in regard to the internal economic
                            conditions of Germany.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>