<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-06-17T14:00:00-05:00" frus:doc-dateTime-min="1916-06-17T14:00:00-05:00" n="1233" subtype="historical-document" type="document" xml:id="d1233">
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in Turkey</hi> (<persName corresp="#p_PH1" type="to"><hi rend="italic">Philip</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-06-17T14:00:00-05:00">
                                        <hi rend="italic">June 17, 1916, 2 p. m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>2763. Department’s 2678, June 3. Department receiving numerous
                                inquiries relative to this matter. Prompt reply greatly desired.
                                Call attention of Turkish Government to strong sympathy in United
                                States for destitute in Syria.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>