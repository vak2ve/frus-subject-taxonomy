<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-12-11T03:00:00-05:00" frus:doc-dateTime-min="1916-12-11T03:00:00-05:00" n="114" subtype="historical-document" type="document" xml:id="d114">
                        <note rend="inline" type="source">File No. 763.72/3059</note>
                        <head>
                            <hi rend="italic">The Minister in Greece</hi> (<persName corresp="#p_DG2" type="from"><hi rend="italic">Droppers</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Athens</hi></placeName>, <date calendar="gregorian" when="1916-12-11T10:00:00+02:00">
                                    <hi rend="italic">December 11, 1916, 10 a. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received December 12, 9 a.
                                m.</hi>]</dateline>
                        </opener>
                        <p>199. Greek Minister for Foreign Affairs, in protest against blockade to
                            neutral legations as contrary to international law, draws attention to
                            peaceful relations subsisting between Greece and Allies and their
                            failure to allege motive.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_DG2">
                                    <hi rend="smallcaps">Droppers</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>