    <text>
        <body>
            <div frus:doc-dateTime-max="1916-04-03T23:59:59-05:00"
                frus:doc-dateTime-min="1916-04-03T00:00:00-05:00" n="808"
                subtype="historical-document" type="document" xml:id="d808">
                <note rend="inline" type="source">File No. 841.711/349</note>
                <head>
                    <hi rend="italic">The British Ambassador</hi> (<persName corresp="#p_SRSCA1"
                        type="from">
                        <hi rend="italic">Spring Rice</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 85</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-04-03">
                            <hi rend="italic">April 3, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honour, by direction of <persName
                        corresp="#p_GSE1">Sir Edward Grey</persName>, His Majesty’s Principal
                    Secretary of State for Foreign Affairs, to transmit to you herewith a memorandum
                    stating the contentions of His Majesty’s Government and the French Government in
                    regard to their right to detain and examine parcels and letter mails on neutral
                        vessels.<note n="1" xml:id="d808fn1">Not printed; identical with the
                        memorandum of February 15, 1916, enclosed in the French Ambassador’s note of
                        April 3. See <hi rend="italic">ante</hi>, <ref target="#pg_599">p.
                        599</ref>.</note>
                </p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SRSCA1">
                            <hi rend="smallcaps">Cecil Spring Rice</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
