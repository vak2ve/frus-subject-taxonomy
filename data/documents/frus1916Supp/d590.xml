    <text>
        <body>
            <div frus:doc-dateTime-max="1916-11-10T23:59:59-05:00"
                frus:doc-dateTime-min="1916-11-10T00:00:00-05:00" n="590"
                subtype="historical-document" type="document" xml:id="d590">
                <note rend="inline" type="source">File No. 300.115/10757</note>
                <head>
                    <hi rend="italic">The Vice Consul at London</hi> (<persName corresp="#p_WR1"
                        type="from">
                        <hi rend="italic">Westacott</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1916-11-10">
                            <hi rend="italic">November 10, 1916</hi>
                        </date>.<lb/>[<hi rend="italic">Received November 21</hi>.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to enclose herewith, in
                    duplicate, a return of shipping detentions at Kirkwall during the month of
                    October 1916.</p>
                <p>I have [etc]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WR1">
                            <hi rend="smallcaps">Richard Westacott</hi>
                        </persName>
                    </signed>
                </closer>
                <pb facs="0771" n="485" xml:id="pg_485"/>
                <frus:attachment>
                    <opener>
                        <seg rendition="#center">[Enclosure—Extract]</seg>
                    </opener>
                    <p>Number of ships detained during: <table cols="2" rend="width: 80%"
                            rendition="#center-block" rows="10">
                            <row>
                                <cell>January, 1916</cell>
                                <cell role="num">51</cell>
                            </row>
                            <row>
                                <cell>February, 1916</cell>
                                <cell role="num">51</cell>
                            </row>
                            <row>
                                <cell>March, 1916</cell>
                                <cell role="num">53</cell>
                            </row>
                            <row>
                                <cell>April, 1916</cell>
                                <cell role="num">72</cell>
                            </row>
                            <row>
                                <cell>May, 1916</cell>
                                <cell role="num">99</cell>
                            </row>
                            <row>
                                <cell>June, 1916</cell>
                                <cell role="num">93</cell>
                            </row>
                            <row>
                                <cell>July, 1916</cell>
                                <cell role="num">115</cell>
                            </row>
                            <row>
                                <cell>August, 1916</cell>
                                <cell role="num">98</cell>
                            </row>
                            <row>
                                <cell>September, 1916</cell>
                                <cell role="num">110</cell>
                            </row>
                            <row>
                                <cell>October, 1916</cell>
                                <cell role="num">107</cell>
                            </row>
                        </table>
                    </p>
                </frus:attachment>
            </div>
