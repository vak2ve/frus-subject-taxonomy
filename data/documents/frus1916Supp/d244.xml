    <text>
        <body>
            <div frus:doc-dateTime-max="1916-02-28T23:59:59-05:00"
                frus:doc-dateTime-min="1916-02-28T00:00:00-05:00" n="244"
                subtype="historical-document" type="document" xml:id="d244">
                <note rend="inline" type="source">File No. 763.72/2741</note>
                <head>
                    <hi rend="italic">The Austro-Hungarian Chargé</hi> (<persName corresp="#p_ZBE1"
                        type="from">
                        <hi rend="italic">Zwiedinek</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <date ana="#date_undated-inferred-from-document-content"
                            calendar="gregorian" when="1916-02-28">February 28, 1916</date>
                        <lb/> [<hi rend="italic">Read to the Secretary by the<lb/>Chargé, February
                            28, 1916</hi>.]</dateline>
                </opener>
                <p>The Chargé d’Affaires of Austria-Hungary has been instructed to inform his
                    excellency the Secretary of State that the Imperial and Royal Austro-Hungarian
                    Government takes the same position in the question of the treatment of armed
                    enemy merchantmen as the Imperial German Government.</p>
                <closer>
                    <dateline rendition="#left">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-02-28">
                            <hi rend="italic">February 28, 1916</hi>
                        </date>.</dateline>
                </closer>
            </div>
        </body>
    </text>
