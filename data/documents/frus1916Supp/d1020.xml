<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-10-16T06:00:00-05:00" frus:doc-dateTime-min="1916-10-16T06:00:00-05:00" n="1020" subtype="historical-document" type="document" xml:id="d1020">
                        <note rend="inline" type="source">File No. 763.72/2951</note>
                        <head>
                            <hi rend="italic">The Minister in Sweden</hi> (<persName type="from"><hi rend="italic">Morris</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Stockholm</hi></placeName>, <date calendar="gregorian" when="1916-10-16T12:00:00+01:00">
                                    <hi rend="italic">October 16, 1916, 12 p. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received October 17, 12.35 a.
                                m.</hi>]</dateline>
                        </opener>
                        <p>144. Foreign. Office informs me Swedish attitude regarding commercial
                            submarines corresponds to attitude adopted by American Government and
                            that war submarines, with exceptions noted my 142, October 14, 6 p.
                                m.,<note n="1" xml:id="d1020fn1">
                                <hi rend="italic">Ante</hi>, <ref target="#pg_775">p.
                                775</ref>.</note> will be attacked.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">American Minister</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>