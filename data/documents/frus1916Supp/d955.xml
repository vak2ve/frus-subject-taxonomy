    <text>
        <body>
            <div frus:doc-dateTime-max="1916-02-17T23:59:59-05:00"
                frus:doc-dateTime-min="1916-02-17T00:00:00-05:00" n="955"
                subtype="historical-document" type="document" xml:id="d955">
                <note rend="inline" type="source">File No. 763.72111Ap4/33</note>
                <head>
                    <hi rend="italic">The British Ambassador</hi> (<persName corresp="#p_SRSCA1"
                        type="from">
                        <hi rend="italic">Spring Rice</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-02-17">
                            <hi rend="italic">February 17, 1916</hi>
                        </date>.<lb/>[<hi rend="italic">Received February 19</hi>.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Secretary</hi>: I have just received a telegram
                    from my Government instructing me to express the desire that the United States
                    Government should see its way to giving me an assurance that the <hi
                        rend="italic">Appam</hi> will not be allowed to leave pending a decision as
                    to her status. They also request that reasonable notice should be given of the
                    date on which such a decision will be notified, or from which it will be
                    operative.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SRSCA1">
                            <hi rend="smallcaps">Cecil Spring Rice</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
