    <text>
        <body>
            <div frus:doc-dateTime-max="1916-06-16T07:00:00-05:00"
                frus:doc-dateTime-min="1916-06-16T07:00:00-05:00" n="362"
                subtype="historical-document" type="document" xml:id="d362">
                <note rend="inline" type="source">File No. 841.711/593</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1916-06-16T14:00:00+02:00">
                            <hi rend="italic">June 16, 1916, 2 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received June 17, 4 p. m.</hi>]</dateline>
                </opener>
                <p>4007. Note to the Allies of May 24 relative to seizure and detention of the
                        mails<note n="2" xml:id="d362fn2">
                        <hi rend="italic">Post</hi>, <ref target="#pg_604">p. 604</ref>.</note>
                    published in full in the German press. It is very favorably received by the
                    moderate papers although <hi rend="italic">Frankfurter Zeitung</hi> cannot agree
                    to admit securities, checks, coupons, etc., are to be considered not as mail
                    matter but merchandise. Radical papers discount the note and claim that the time
                    has come for the threat which they consider is contained in the last paragraph
                    of the German note of May 4 to be carried into effect.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
