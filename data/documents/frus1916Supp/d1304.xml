                subtype="historical-document" type="document" xml:id="d1304">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName corresp="#p_SWG1" type="to">
                        <hi rend="italic">Sharp</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-03-10T16:00:00-05:00">
                            <hi rend="italic">March 10, 1916, 4 p. m</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1413. Department is informed from Rome that there is to be a conference at Paris
                    for closer commercial relations between the Allies, and that efforts may be made
                    to apply restrictions possibly affecting American interests. Should this
                    conference take place, endeavor to ascertain its results, using every discretion
                    in doing so.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
