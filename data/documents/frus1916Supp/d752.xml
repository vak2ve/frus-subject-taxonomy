                subtype="historical-document" type="document" xml:id="d752">
                <note rend="inline" type="source">File No. 300.115/7279</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1916-02-23T17:00:00+00:00">
                            <hi rend="italic">February 23, 1916, 5 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 5.25 p. m.</hi>]</dateline>
                </opener>
                <p>3841. Your 2912, February 21, 7 p. m. I have again approached Foreign Office
                    regarding porcelain guides. Am informed that a reconsideration is being made and
                    that I will be informed in the near future of the decision.</p>
                <closer>
                    <hi rend="smallcaps">American Embassy</hi>
                </closer>
            </div>
        </body>
