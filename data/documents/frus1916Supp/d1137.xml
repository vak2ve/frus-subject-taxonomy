<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-11-15T12:00:00-05:00" frus:doc-dateTime-min="1916-11-15T12:00:00-05:00" n="1137" subtype="historical-document" type="document" xml:id="d1137">
                        <note rend="inline" type="source">File No. 763.72115/2552</note>
                        <head>
                            <hi rend="italic">The Minister in Belgium</hi> (<persName corresp="#p_WB1" type="from"><hi rend="italic">Whitlock</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Brussels</hi></placeName>, <date calendar="gregorian" when="1916-11-15T18:00:00+01:00">
                                    <hi rend="italic">November 15, 1916, 6 p. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received November 17, 1.45 p.
                                m.</hi>]</dateline>
                        </opener>
                        <p>16. Impressment of workmen continues, but somewhat less rigorously
                            applied. Members of organization of Comité National and Commission
                            Relief Belgium now fully respected.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_WB1">
                                    <hi rend="smallcaps">Whitlock</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>