                subtype="historical-document" type="document" xml:id="d446">
                <note rend="inline" type="source">File No. 763.72112/2069</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-01-10T17:00:00-05:00">
                            <hi rend="italic">January 10, 1916, 5 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>2686. Department’s 2599, December 18.<note n="1" xml:id="d446fn1">
                        <ref target="frus1915Supp#pg_641">
                            <hi rend="italic">Foreign Relations</hi>, 1915, Supplement, p.
                        641</ref>.</note> Conditions enforced by British authorities in China are
                    causing great damage to American trade. Bring matter again to attention Foreign
                    Office and urge early reply. Further and increasingly pressing complaints are
                    being received.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
