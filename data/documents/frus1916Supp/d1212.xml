                subtype="historical-document" type="document" xml:id="d1212">
                <note rend="inline" type="source">File No. 811.142/1294b</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Turkey</hi> (<persName corresp="#p_MH1" type="to">
                        <hi rend="italic">Morgenthau</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-01-14">
                            <hi rend="italic">January 14, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>1710. Instruct <hi rend="italic">Des Moines</hi> to be at Piraeus February 6 to
                    transport American Red Cross special agent and seven other Americans, including
                    three to five ladies, together with shipment of hospital and relief supplies, to
                    Beirut, and obtain permission Turkish Government for ship to enter latter
                    port.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
