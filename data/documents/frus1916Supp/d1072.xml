                subtype="historical-document" type="document" xml:id="d1072">
                <note rend="inline" type="source">File No. 702.5167/42</note>
                <head>
                    <hi rend="italic">The Ambassador in Turkey</hi> (<persName corresp="#p_MH1"
                        type="from">
                        <hi rend="italic">Morgenthau</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Constantinople</hi>
                        </placeName>, <date calendar="gregorian" when="1915-09-29T15:00:00+03:00">
                            <hi rend="italic">September 29, 1915, 3 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received October 2, 8 a. m.</hi>]</dateline>
                </opener>
                <p>1096. For French Government. Notwithstanding my efforts here and protest of
                    Consul General at Beirut, his seals have been removed from French Consulate by
                    Turkish authorities and examination of French archives has begun.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MH1">
                            <hi rend="smallcaps">Morgenthau</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
