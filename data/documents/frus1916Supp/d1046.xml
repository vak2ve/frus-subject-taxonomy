    <text>
        <body>
            <div frus:doc-dateTime-max="1916-10-18T16:00:00-05:00"
                frus:doc-dateTime-min="1916-10-18T16:00:00-05:00" n="1046"
                subtype="historical-document" type="document" xml:id="d1046">
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Austria-Hungary</hi> (<persName corresp="#p_PFC1"
                        type="to">
                        <hi rend="italic">Penfield</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-10-18T16:00:00-05:00">
                            <hi rend="italic">October 18, 1916, 4 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1387. Before answering your 1481, Department desires to receive more information
                    regarding <persName>Count Adam Tarnowski</persName>, whether his sentiments are
                    friendly to the United States, etc.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
