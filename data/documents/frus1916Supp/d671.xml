<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-08-30T08:00:00-05:00" frus:doc-dateTime-min="1916-08-30T08:00:00-05:00" n="671" subtype="historical-document" type="document" xml:id="d671">
                            <note rend="inline" type="source">File No. 763.72112/2912</note>
                            <head>
                                <hi rend="italic">The Chargé in Great Britain</hi> (<persName corresp="#p_LIB1" type="from"><hi rend="italic">Laughlin</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1916-08-30T14:00:00+01:00">
                                        <hi rend="italic">August 30, 1916, 2 p. m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 2 p. m.</hi>]</dateline>
                            </opener>
                            <p>4793. Following from <persName>Wyvell</persName>:</p>
                            <quote rend="blockquote">
                                <p>I will complete presentation of the 30 rejected cases and
                                    canceled permits and of all pending cases I can submit next
                                    week. Decisions will in all cases be rendered through the
                                    British Embassy at Washington and I will not be informed of
                                    decisions. I would like to sail on <hi rend="italic">St.
                                            <persName>Paul</persName>
                                    </hi> leaving September 9, as there will be nothing further to
                                    do here.</p>
                            </quote>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LIB1">
                                        <hi rend="smallcaps">Laughlin</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>