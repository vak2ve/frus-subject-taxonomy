                subtype="historical-document" type="document" xml:id="d719">
                <note rend="inline" type="source">File No. 165.102/880a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="to">
                        <hi rend="italic">Gerard</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-03-15T12:00:00-05:00">
                            <hi rend="italic">March 15, 1916, 12 noon</hi>
                        </date>.</dateline>
                </opener>
                <p>2811. At opportune time again request German Government for permission
                    exportation two cargoes dyestuffs valued approximately $5,000,000 for
                    uninterrupted shipment of which Department has assurance non-interference from
                    British authorities. Dyestuffs consigned to Secretary Commerce on behalf of
                    Republic Trading Corporation. Department informed agents manufacturers are
                    assisting.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
