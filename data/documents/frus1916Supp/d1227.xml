<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-04-24T23:59:59-05:00" frus:doc-dateTime-min="1916-04-24T00:00:00-05:00" n="1227" subtype="historical-document" type="document" xml:id="d1227">
                            <note rend="inline" type="source">File No. 811.142/1546</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in Turkey</hi> (<persName corresp="#p_PH1" type="to"><hi rend="italic">Philip</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-04-24">
                                        <hi rend="italic">April 24, 1916</hi>
                                    </date>.</dateline>
                            </opener>
                            <p>2376. Your 1570, February 13.<note n="1" xml:id="d1227fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_925">p.
                                    925</ref>.</note> Can you suggest any method transportation Red
                                Cross supplies from Athens to Beirut?</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>