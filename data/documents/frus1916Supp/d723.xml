    <text>
        <body>
            <div frus:doc-dateTime-max="1916-04-01T23:59:59-05:00"
                frus:doc-dateTime-min="1916-04-01T00:00:00-05:00" n="723"
                subtype="historical-document" type="document" xml:id="d723">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        German Ambassador</hi> (<persName corresp="#p_BJHACV1" type="to">
                        <hi rend="italic">Bernstorff</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-04-01">
                            <hi rend="italic">April 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to acknowledge the
                    receipt of your excellency’s note of April 20, 1916, stating that your
                    Government is willing to release 15,000 tons of dyestuffs for exportation to the
                    United States.</p>
                <p>This information has been carefully noted by the Department and I thank you
                    therefor.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Robert Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
