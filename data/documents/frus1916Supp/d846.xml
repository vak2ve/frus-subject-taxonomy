    <text>
        <body>
            <div frus:doc-dateTime-max="1916-05-05T11:00:00-05:00"
                frus:doc-dateTime-min="1916-05-05T11:00:00-05:00" n="846"
                subtype="historical-document" type="document" xml:id="d846">
                <note rend="inline" type="source">File No. 341.622a/120</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1916-05-05T16:00:00+00:00">
                            <hi rend="italic">May 5, 1916, 4 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 5.40 p. m.</hi>]</dateline>
                </opener>
                <p>4252. My 4242, May; 3, 5 p. m.<note n="2" xml:id="d846fn2">Not Printed.</note>
                    <persName corresp="#p_GSE1">Sir Edward Grey</persName>, has just informed me
                    that His Majesty’s Government will release the men taken from the American
                    steamer <hi rend="italic">China</hi> by the British man-of-war <hi rend="italic"
                        >Laurentic</hi>. He added that a memorandum is in preparation which he will
                    give to me in a few days in which His Majesty’s Government explains that it
                    cannot, however, open the door through which enemy reservists in neutral
                    countries may reach their own countries.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">American Embassy</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
