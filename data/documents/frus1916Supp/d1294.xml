<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-06-15T07:00:00-05:00" frus:doc-dateTime-min="1916-06-15T07:00:00-05:00" n="1294" subtype="historical-document" type="document" xml:id="d1294">
                        <note rend="inline" type="source">File No. 763.72112/2643</note>
                        <head>
                            <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="from"><hi rend="italic">Gerard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Berlin</hi></placeName>, <date calendar="gregorian" when="1916-06-15T14:00:00+02:00">
                                    <hi rend="italic">June 15, 1916, 2 p. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received June 16, 11.30 a.
                                m.</hi>]</dateline>
                        </opener>
                        <p>4001. Your 3087, June 13, 6 p. m. See no objection to publication of
                            Doctor <persName corresp="#p_TDAE1">Taylor</persName>’s report of April
                            17.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_GJW1">
                                    <hi rend="smallcaps">Gerard</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>