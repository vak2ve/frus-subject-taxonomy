    <text>
        <body>
            <div frus:doc-dateTime-max="1916-05-03T16:00:00-05:00"
                frus:doc-dateTime-min="1916-05-03T16:00:00-05:00" n="485"
                subtype="historical-document" type="document" xml:id="d485">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-05-03T16:00:00-05:00">
                            <hi rend="italic">May 3, 1916, 4 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Deliver following to Consul General:</p>
                <quote rend="blockquote">
                    <p>Your 27th <hi rend="italic">re</hi> value merchandise in prize court. Is it
                        not possible to get reasonably close estimates particularly with reference
                        American goods?</p>
                </quote>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
