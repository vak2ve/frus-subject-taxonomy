                subtype="historical-document" type="document" xml:id="d670">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Great Britain</hi> (<persName corresp="#p_LIB1" type="to">
                        <hi rend="italic">Laughlin</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-08-11T17:00:00-05:00">
                            <hi rend="italic">August 11, 1916, 5 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3663. Your 4695 August 10, 6 p. m. You are directed to informally acquaint
                    Foreign Office that the Department will be pleased to have it grant
                        <persName>Wyvell</persName> hearings for the purpose of discussing
                    unofficially for reconsideration all individual meritorious cases in which
                    previous adverse decisions have been rendered, and in addition thereto reserving
                    the right to discuss unofficially all individual cases now pending in which no
                    decision has as yet been rendered.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
