    <text>
        <body>
            <div frus:doc-dateTime-max="1916-02-09T23:59:59-05:00"
                frus:doc-dateTime-min="1916-02-09T00:00:00-05:00" n="1197"
                subtype="historical-document" type="document" xml:id="d1197">
                <note rend="inline" type="source">File No. 872.48/34</note>
                <head>
                    <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="from">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1916-02-09">
                            <hi rend="italic">February 9, 1916</hi>
                        </date>.<lb/>[<hi rend="italic">Received February 10, 8 p.
                        m.</hi>]</dateline>
                </opener>
                <p>1140. Purport your 1093, January 21,<note n="2" xml:id="d1197fn2">See <hi
                            rend="italic">ante</hi>, <ref target="#pg_914">p. 914</ref>, footnote
                        1.</note> via Berlin, promptly communicated to Ministry. Early reply urged.
                    Ministry now acknowledges receipt agreeing in principle to shipments via Holland
                    for Serbian relief, but reserves final reply relative facilities and guarantees
                    owing consultation with other ministries.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
