<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-04-19T12:00:00-05:00" frus:doc-dateTime-min="1916-04-19T12:00:00-05:00" n="477" subtype="historical-document" type="document" xml:id="d477">
                            <note rend="inline" type="source">File No. 763.72112/2454</note>
                            <head>
                                <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1916-04-19T17:00:00+00:00">
                                        <hi rend="italic">April 19, 1916, 5 p. m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 5.30 p. m.</hi>]</dateline>
                            </opener>
                            <p>4176. <persName corresp="#p_GSE1">Sir Edward Grey</persName>
                                privately informs me that <persName corresp="#p_SRSCA1">Spring
                                    Rice</persName> and <persName corresp="#p_JJAAJ1">Jusserand</persName> report that they think the present moment
                                inopportune to present their note, but that on an intimation from
                                you they will present it at any time.</p>
                            <closer>
                                <hi rend="smallcaps">American Embassy</hi>
                            </closer>
                        </div>
                        </body></text></TEI>