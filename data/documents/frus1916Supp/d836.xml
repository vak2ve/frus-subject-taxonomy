                subtype="historical-document" type="document" xml:id="d836">
                <note rend="inline" type="source">File No. 341.622a/31</note>
                <head>
                    <hi rend="italic">The Consul at Nagasaki</hi> (<persName corresp="#p_BEC1"
                        type="from">
                        <hi rend="italic">Baker</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nagasaki</hi>
                        </placeName>, <hi rend="italic">
                            <date ana="#date_undated-inferred-from-document-content"
                                calendar="gregorian" notAfter="1916-02-23T08:15:00-05:00"
                                notBefore="1916-02-18T00:00:00+09:00">undated</date>
                        </hi>.<lb/>[<hi rend="italic">Received February 23, 1916, 8.15 a.
                        m.</hi>]</dateline>
                </opener>
                <p>British cruiser <hi rend="italic">Laurentic</hi> 18th instant, 10 miles from
                    entrance Yangtze River, fired blank and projectile shots; sent boat containing
                    heavily armed party 22. Two officers, 5 armed men boarded <hi rend="italic"
                        >China</hi>, despite captain’s protest, removing 28 Germans, 8 Austrians, 2
                    Turks, including physicians and merchants.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BEC1">
                            <hi rend="smallcaps">Baker</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
