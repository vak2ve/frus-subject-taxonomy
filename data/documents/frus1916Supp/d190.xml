    <text>
        <body>
            <div frus:doc-dateTime-max="1916-01-03T23:59:59-05:00"
                frus:doc-dateTime-min="1916-01-03T00:00:00-05:00" n="190"
                subtype="historical-document" type="document" xml:id="d190">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        German Ambassador</hi> (<persName corresp="#p_BJHACV1" type="to">
                        <hi rend="italic">Bernstorff</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-01-03">
                            <hi rend="italic">January 3, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Ambassador</hi>: In accordance with the request
                    in your note of the 3d instant, I have forwarded to Mr. <persName
                        corresp="#p_GJW1">Gerard</persName> the cipher message from you to the
                    German Foreign Office which you enclosed for that purpose.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Robert Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
