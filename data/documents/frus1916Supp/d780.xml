<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-01-05T23:59:59-05:00" frus:doc-dateTime-min="1916-01-05T00:00:00-05:00" n="780" subtype="historical-document" type="document" xml:id="d780">
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-01-05">
                                        <hi rend="italic">January 5, 1916</hi>
                                    </date>.</dateline>
                            </opener>
                            <p>2665. Your 3323, December 1. Department awaits decision regarding
                                hops. Ambassador Paris being instructed to present matter informally
                                to French Government.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>