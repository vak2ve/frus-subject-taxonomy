                subtype="historical-document" type="document" xml:id="d817">
                <note rend="inline" type="source">File No. 841.711/751</note>
                <head>
                    <hi rend="italic">The Acting <gloss type="from">Secretary of State</gloss> to
                        the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-07-24T17:00:00-05:00">
                            <hi rend="italic">July 24, 1916, 5 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3560. Your 4599. Memorandum published to-day. Please continue to urge British
                    Government to forward the reply of the Allied Governments without further
                    delay.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
