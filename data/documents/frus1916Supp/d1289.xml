<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-01-13T13:00:00-05:00" frus:doc-dateTime-min="1916-01-13T13:00:00-05:00" n="1289" subtype="historical-document" type="document" xml:id="d1289">
                        <note rend="inline" type="source">File No. 763.72112/2291</note>
                        <head>
                            <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_SWG1" type="from"><hi rend="italic">Sharp</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1916-01-13T18:00:00+00:00">
                                    <hi rend="italic">January 13, 1916, 6 p. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received 8.45 p. m.</hi>]</dateline>
                        </opener>
                        <p>1210. Department’s 1280, December 27, repeated from London. French
                            Government replies under date of January 11:</p>
                        <quote rend="blockquote">
                            <p>For military reasons, Government of the Republic is not disposed
                                authorize transit of milk from the United States to Germany and
                                Austria even under supervision of American Red Cross.</p>
                        </quote>
                        <closer>
                            <signed>
                                <persName corresp="#p_SWG1">
                                    <hi rend="smallcaps">Sharp</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>