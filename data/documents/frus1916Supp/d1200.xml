    <text>
        <body>
            <div frus:doc-dateTime-max="1916-02-29T18:00:00-05:00"
                frus:doc-dateTime-min="1916-02-29T18:00:00-05:00" n="1200"
                subtype="historical-document" type="document" xml:id="d1200">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Austria-Hungary</hi> (<persName corresp="#p_PFC1" type="to">
                        <hi rend="italic">Penfield</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-02-29T18:00:00-05:00">
                            <hi rend="italic">February 29, 1916, 6 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1148. Your 1167, February 26. Communicate to Austrian Foreign Office substance
                    telegram 83, February 25 from <persName corresp="#p_VCJ1">Vopicka</persName>,
                    and <pb facs="1204" n="918" xml:id="pg_918"/> ascertain definitely attitude
                    Austrian Government relative this matter. Prompt reply urgently desired.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
