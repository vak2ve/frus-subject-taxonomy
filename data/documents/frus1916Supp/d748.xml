    <text>
        <body>
            <div frus:doc-dateTime-max="1916-01-27T12:45:00-05:00"
                frus:doc-dateTime-min="1916-01-25T18:00:00-05:00" n="748"
                subtype="historical-document" type="document" xml:id="d748">
                <note rend="inline" type="source">File No. 300.115/6816</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <hi rend="italic">
                            <date
                                ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                                calendar="gregorian" notAfter="1916-01-27T12:45:00-05:00"
                                notBefore="1916-01-25T18:00:00-05:00">undated</date>
                        </hi>.<lb/>[<hi rend="italic">Received January 27, 1916, 12.45 p.
                        m.</hi>]</dateline>
                </opener>
                <p>3653. Your 2778, January 25, 6 p. m. Understand that Foreign Office cabled
                    British Embassy that permit had been refused.</p>
                <closer>
                    <hi rend="smallcaps">American Embassy</hi>
                </closer>
            </div>
        </body>
