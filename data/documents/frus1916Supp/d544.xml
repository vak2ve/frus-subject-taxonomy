<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-08-29T23:59:59-05:00" frus:doc-dateTime-min="1916-08-29T00:00:00-05:00" n="544" subtype="historical-document" type="document" xml:id="d544">
                            <note rend="inline" type="source">File No. 763.72112/2810</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Consul General at Guayaquil</hi> (<persName corresp="#p_GFW1" type="to"><hi rend="italic">Goding</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-08-29">
                                        <hi rend="italic">August 29, 1916, 6 p. m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p rend="center">[Telegram]</p>
                            <p>Your telegram August 9, 3 p. m.<note n="1" xml:id="d544fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_428">p.
                                    428</ref>.</note> This Department has no authority to refuse
                                bills of health on grounds stated.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>