    <text>
        <body>
            <div frus:doc-dateTime-max="1916-07-19T23:59:59-05:00"
                frus:doc-dateTime-min="1916-07-19T00:00:00-05:00" n="511"
                subtype="historical-document" type="document" xml:id="d511">
                <note rend="inline" type="source">File No. 763.72112/2731</note>
                <head>
                    <hi rend="italic">The Consul General at London</hi> (<persName corresp="#p_SRP1"
                        type="from">
                        <hi rend="italic">Skinner</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1916-07-19">
                            <hi rend="italic">July 19, 1916</hi>
                        </date>.<lb/>[<hi rend="italic">Received 8 a. m.</hi>]</dateline>
                </opener>
                <p>Proclamation published blacklisting 85 concerns domiciled in United States with
                    whom trade relations prohibited as provided in Trading with Enemy (Extension of
                    Powers) Act. List follows by mail unless otherwise ordered.<note n="1"
                        xml:id="d511fn1">Not printed.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_SRP1">
                            <hi rend="smallcaps">Skinner</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
