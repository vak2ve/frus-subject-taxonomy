<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-01-01T23:59:59-05:00" frus:doc-dateTime-min="1916-01-01T00:00:00-05:00" n="2" subtype="historical-document" type="document" xml:id="d2">
                        <note rend="inline" type="source">File No. 763.72/2330</note>
                        <head>
                            <hi rend="italic">The Ambassador in Italy</hi> (<persName corresp="#p_PTN1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Rome</hi></placeName>, <date calendar="gregorian" when="1916-01-01">
                                    <hi rend="italic">January 1, 1916</hi>
                                </date>.<lb/>[<hi rend="italic">Received 1.30 p. m.</hi>]</dateline>
                        </opener>
                        <p>521. Press reports declaration war against Austria and Bulgaria by
                                <persName corresp="#p_DP1">Essad Pasha</persName>’s <hi rend="italic">de facto</hi> government, Albania.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">American Embassy</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>