                subtype="historical-document" type="document" xml:id="d1277">
                <note rend="inline" type="source">File No. 763.72112/2659</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-07-03T18:00:00-05:00">
                            <hi rend="italic">July 3, 1916, 6 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3487. Your 4482, June 21, 3 p. m. Department regrets that you expressed yourself
                    to the Spanish Ambassador in such a way as to <pb facs="1240" n="954"
                        xml:id="pg_954"/> give him the impression that you agreed as to the
                    inutility of presenting the German reply to the British Government.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
