                subtype="historical-document" type="document" xml:id="d305">
                <note rend="inline" type="source">File No. 763.72/2567</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Spain</hi> (<persName corresp="#p_WJE1" type="to">
                        <hi rend="italic">Willard</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-04-17T16:00:00-05:00">
                            <hi rend="italic">April 17, 1916, 4 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>140. Your 225, April 12, 10 p. m. Say to Prime Minister that Department is giving
                    his suggestion sympathetic consideration but <pb facs="0517" n="231"
                        xml:id="pg_231"/> now it seems that any action by the United States would
                    have to be taken so promptly that there would be no time for discussion.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
