<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-12-26T23:59:59-05:00" frus:doc-dateTime-min="1916-12-26T00:00:00-05:00" n="888" subtype="historical-document" type="document" xml:id="d888">
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-12-26">
                                    <hi rend="italic">December 26, 1916</hi>
                                </date>.</dateline>
                        </opener>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <p>4213. My mail instruction No. 4520, December 1.<note n="1" xml:id="d888fn4">
                                <hi rend="italic">Ante</hi>, <ref target="#pg_667">p.
                                667</ref>.</note> What have you to report?</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>