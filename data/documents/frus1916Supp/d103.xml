                subtype="historical-document" type="document" xml:id="d103">
                <note rend="inline" type="source">File No. 763.72115/3101a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Germany</hi> (<persName corresp="#p_GJC1" type="to">
                        <hi rend="italic">Grew</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-12-05T17:00:00-05:00">
                            <hi rend="italic">December 5, 1916, 5 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3644. Our 3621, November 29.<note n="1" xml:id="d103fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_70">p. 70</ref>.</note> Please
                    report if message received and what action taken.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
