<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-04-01T09:00:00-05:00" frus:doc-dateTime-min="1916-04-01T09:00:00-05:00" n="1203" subtype="historical-document" type="document" xml:id="d1203">
                            <note rend="inline" type="source">File No. 811.142/1509</note>
                            <head>
                                <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName corresp="#p_PFC1" type="from"><hi rend="italic">Penfield</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Vienna</hi></placeName>, <date calendar="gregorian" when="1916-04-01T15:00:00+01:00">
                                        <hi rend="italic">April 1, 1916, 3 p. m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received April 2, 7 p.
                                    m.</hi>]</dateline>
                            </opener>
                            <p>1215. For Red Cross:</p>
                            <quote rend="blockquote">
                                <p>20. Expected note received from Government. More favorable than
                                    previous note. Proceeding Belgrade confer local authorities.</p>
                                <p rend="right">
                                    <persName corresp="#p_SE1">
                                        <hi rend="smallcaps">Stuart</hi>
                                    </persName>
                                </p>
                            </quote>
                            <closer>
                                <signed>
                                    <persName corresp="#p_PFC1">
                                        <hi rend="smallcaps">Penfield</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>