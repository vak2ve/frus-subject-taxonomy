                subtype="historical-document" type="document" xml:id="d931">
                <note rend="inline" type="source">File No. 763.72111/4231</note>
                <head>
                    <hi rend="italic">The Ambassador in Chile</hi> (<persName corresp="#p_SJH1"
                        type="from">
                        <hi rend="italic">Shea</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santiago</hi>
                        </placeName>, <date calendar="gregorian" when="1916-11-11T16:00:00-04:42">
                            <hi rend="italic">November 11, 1916, 4 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 6 p. m.</hi>]</dateline>
                </opener>
                <p>Your November 10, 2 p. m. I am reliably informed that no submarines have been
                    contracted for by Chile in Great Britain; two battleships, several destroyers,
                    and one or more tugs only.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SJH1">
                            <hi rend="smallcaps">Shea</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
