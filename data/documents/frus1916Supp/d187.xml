<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-01-01T23:59:59-05:00" frus:doc-dateTime-min="1916-01-01T00:00:00-05:00" n="187" subtype="historical-document" type="document" xml:id="d187">
                            <note rend="inline" type="source">File No. 841.857P43</note>
                            <head>
                                <hi rend="italic">The Consul General at London</hi> (<persName corresp="#p_SRP1" type="from"><hi rend="italic">Skinner</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1916-01-01">
                                        <hi rend="italic">January 1, 1916</hi>
                                    </date>.<lb/>[<hi rend="italic">Received 9 a.
                                    m.</hi>]</dateline>
                            </opener>
                            <p>P. &amp; O. liner <hi rend="italic">Persia</hi> reported sunk,
                                submarine, while approaching Alexandria. <persName corresp="#p_MRN1">Robert N. McNeely</persName>, American Consul, Aden, going to
                                post, left London as passenger. Nearly all on board perished.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_SRP1">
                                        <hi rend="smallcaps">Skinner</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>