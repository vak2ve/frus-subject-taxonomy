    <text>
        <body>
            <div frus:doc-dateTime-max="1916-08-07T23:59:59-05:00"
                frus:doc-dateTime-min="1916-08-07T00:00:00-05:00" n="1210"
                subtype="historical-document" type="document" xml:id="d1210">
                <note rend="inline" type="source">File No. 872.48/100</note>
                <head>
                    <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="from">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1916-08-07">
                            <hi rend="italic">August 7, 1916</hi>
                        </date>.<lb/>[<hi rend="italic">Received August 8, 8.20 a.
                        m.</hi>]</dateline>
                </opener>
                <p>1373. For Red Cross:</p>
                <quote rend="blockquote">
                    <p>34. Austrian Government accepts agreement 3<note n="1" xml:id="d1210fn1"
                            >Summarized in the Ambassador’s telegram No. 1300, June 13, 1916, <hi
                                rend="italic">ante</hi>, <ref target="#pg_920">p. 920</ref>.</note>
                        for shipments supplies from Roumania instead from America. Awaiting action
                        regarding Buck, <persName corresp="#p_LIB1">Laughlin</persName>.</p>
                    <p rend="right">
                        <persName corresp="#p_SE1">
                            <hi rend="smallcaps">Stuart</hi>
                        </persName>
                    </p>
                </quote>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
