    <text>
        <body>
            <div frus:doc-dateTime-max="1916-10-13T12:00:00-05:00"
                frus:doc-dateTime-min="1916-10-13T12:00:00-05:00" n="881"
                subtype="historical-document" type="document" xml:id="d881">
                <note rend="inline" type="source">File No. 351.622a/67</note>
                <head>
                    <hi rend="italic">The Chargé in France</hi> (<persName corresp="#p_BRW1"
                        type="from">
                        <hi rend="italic">Bliss</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1916-10-13T17:00:00+00:00">
                            <hi rend="italic">October 13, 1916, 5 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 10 p. m.</hi>]</dateline>
                </opener>
                <p>1646. My 1636, October 9, 6 p. m.<note n="1" xml:id="d881fn1">Not printed.</note>
                    Consul General, Marseille, reports that Miller was released on 10th instant and
                    that he has arranged for Miller’s return passage to the United States on S. S.
                        <hi rend="italic">Satsuma</hi> to sail this week.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BRW1">
                            <hi rend="smallcaps">Bliss</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
