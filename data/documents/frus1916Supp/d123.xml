<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-12-12T08:00:00-05:00" frus:doc-dateTime-min="1916-12-12T08:00:00-05:00" n="123" subtype="historical-document" type="document" xml:id="d123">
                        <note rend="inline" type="source">File No. 763.72119/201</note>
                        <head>
                            <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName corresp="#p_PFC1" type="from"><hi rend="italic">Penfield</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Vienna</hi></placeName>, <date calendar="gregorian" when="1916-12-12T14:00:00+01:00">
                                    <hi rend="italic">December 12, 1916, 2 p. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received December 14, 11 a.
                                m.</hi>]</dateline>
                        </opener>
                        <p>1573. Note No. 5915, dated December 12, 1916, from Austro-Hungarian
                            Ministry of Foreign Affairs just received.<note n="1" xml:id="d123fn1">See footnote to telegram No. 4722, December 12, from the Chargé in
                                Germany, <hi rend="italic">ante</hi>, <ref target="#pg_86">p.
                                    86</ref>. The translation sent by the Embassy in Austria-Hungary
                                is printed, as enclosure to despatch No 2308, in the publications
                                cited in footnote 1 to telegram No. 4726 from the Chargé in Germany,
                                    <hi rend="italic">post</hi>, <ref target="#pg_90">p.
                                90</ref>.</note> . . .</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_PFC1">
                                    <hi rend="smallcaps">Penfield</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>