<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-11-23T01:00:00-05:00" frus:doc-dateTime-min="1916-11-23T01:00:00-05:00" n="87" subtype="historical-document" type="document" xml:id="d87">
                        <note rend="inline" type="source">File No. 124.683/5</note>
                        <head>
                            <hi rend="italic">The Minister in Greece</hi> (<persName corresp="#p_DG2" type="from"><hi rend="italic">Droppers</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Athens</hi></placeName>, <date calendar="gregorian" when="1916-11-23T08:00:00+02:00">
                                    <hi rend="italic">November 23, 1916, 8 a. m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received 9.30 a. m.</hi>]</dateline>
                        </opener>
                        <p>186. Austro-Hungarian Minister, Bulgarian, and Turkish left today. Have
                            assumed charge their national interests in Greece. Referring to my
                            telegram 185,<note n="2" xml:id="d87fn2">Not printed.</note> after
                            examination work accountant probably not needed, but capable
                            stenographer-typewriter urgently requested.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_DG2">
                                    <hi rend="smallcaps">Droppers</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>