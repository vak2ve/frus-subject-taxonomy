                subtype="historical-document" type="document" xml:id="d1173">
                <note rend="inline" type="source">File No. 861.48/132</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1916-06-13T19:00:00+02:00">
                            <hi rend="italic">June 13, 1916, 7 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received June 14, 12.15 p. m.</hi>]</dateline>
                </opener>
                <p>3992. My 3934, May 30. I have note from Foreign Office stating German Government
                    cannot accept conditions proposed by England for the relief of Poland by
                    American committee. Foreign Office states that conditions proposed in my 3934 of
                    May 30 are entirely acceptable to German Government.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
