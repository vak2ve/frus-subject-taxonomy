                subtype="historical-document" type="document" xml:id="d1154">
                <note rend="inline" type="source">File No. 861.48/62a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-02-23T19:00:00-05:00">
                            <hi rend="italic">February 23, 1916, 7 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>2926. Transmit following message as promptly as possible to <persName
                        corresp="#p_HHC1">Hoover</persName>:</p>
                <quote rend="blockquote">
                    <p>Polish relief organizations in United States are very anxious to know as
                        promptly as possible what progress you are making towards obtaining consent
                        belligerent powers for extension work Belgian Relief Committee over
                        Poland.</p>
                </quote>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
