    <text>
        <body>
            <div frus:doc-dateTime-max="1916-04-22T18:00:00-05:00"
                frus:doc-dateTime-min="1916-04-22T18:00:00-05:00" n="479"
                subtype="historical-document" type="document" xml:id="d479">
                <note rend="inline" type="source">File No. 763.72112/2474a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at London</hi> (<persName corresp="#p_SRP1" type="to">
                        <hi rend="italic">Skinner</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-04-22T18:00:00-05:00">
                            <hi rend="italic">April 22, 1916, 6 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Referring to personal letter to <persName corresp="#p_HCA1"
                        >Holder</persName>,<note n="1" xml:id="d479fn1">Not printed.</note> can you
                    obtain total value of merchandise in prize court and approximate value of
                    American goods therein to date or up to April 1? Cable amounts if possible.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
