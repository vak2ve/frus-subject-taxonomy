    <text>
        <body>
            <div frus:doc-dateTime-max="1916-01-05T07:00:00-05:00"
                frus:doc-dateTime-min="1916-01-05T07:00:00-05:00" n="3"
                subtype="historical-document" type="document" xml:id="d3">
                <note rend="inline" type="source">File No. 763.72/2335</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName corresp="#p_GJW1"
                        type="from">
                        <hi rend="italic">Gerard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1916-01-05T13:00:00+01:00">
                            <hi rend="italic">January 5, 1916, 1 p. m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received January 6, 8 a. m.</hi>]</dateline>
                </opener>
                <p>3311. Think arrangement has been made by which Greece will permit Central powers
                    to attack Allies in Saloniki.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Gerard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
