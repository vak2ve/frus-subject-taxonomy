<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-12-08T17:00:00-05:00" frus:doc-dateTime-min="1915-12-08T17:00:00-05:00" n="702" subtype="historical-document" type="document" xml:id="d702">
                            <note rend="inline" type="source">File No. 165.102/696a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-12-08T17:00:00-05:00">
                                        <hi rend="italic">December 8, 1915, 5 p. m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>2533. We are informed that <persName>Charles H. Burr</persName> seeks
                                to have Republic Trading Corporation substituted for
                                    <persName>William A. Mitchell</persName> in connection with
                                British consent to safe passage German dyestuffs. Please assist Burr
                                to accomplish this and informally draw attention of British
                                authorities to pressing need of American industries for
                                dyestuffs.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>