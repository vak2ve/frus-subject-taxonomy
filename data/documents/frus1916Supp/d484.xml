    <text>
        <body>
            <div frus:doc-dateTime-max="1916-04-27T23:59:59-05:00"
                frus:doc-dateTime-min="1916-04-27T00:00:00-05:00" n="484"
                subtype="historical-document" type="document" xml:id="d484">
                <note rend="inline" type="source">File No. 763.72112/2475</note>
                <head>
                    <hi rend="italic">The Vice Consul at London</hi> (<persName corresp="#p_WR1"
                        type="from">
                        <hi rend="italic">Westacott</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1916-04-27">
                            <hi rend="italic">April 27, 1916</hi>
                        </date>.<lb/>[<hi rend="italic">Received 6 p. m.</hi>]</dateline>
                </opener>
                <p>Department’s 22d to Ambassador [Consul General?].<note n="1" xml:id="d484fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_367">p. 367</ref>.</note>
                    Figures showing value merchandise in prize court not available. Total goods sold
                    by prize court to March 31, £6,208,963.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WR1">
                            <hi rend="smallcaps">Westacott</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
