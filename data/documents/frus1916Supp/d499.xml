    <text>
        <body>
            <div frus:doc-dateTime-max="1916-06-06T23:59:59-05:00"
                frus:doc-dateTime-min="1916-06-06T00:00:00-05:00" n="499"
                subtype="historical-document" type="document" xml:id="d499">
                <note rend="inline" type="source">File No. 763.72112/2609</note>
                <head>
                    <hi rend="italic">The Consul General at London</hi> (<persName corresp="#p_SRP1"
                        type="from">
                        <hi rend="italic">Skinner</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1916-06-06">
                            <hi rend="italic">June 6, 1916</hi>
                        </date>.<lb/>[<hi rend="italic">Received 2 p. m.</hi>]</dateline>
                </opener>
                <p>Department’s May 3.<note n="1" xml:id="d499fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_383">p. 383</ref>.</note> Only
                    information available <hi rend="italic">re</hi> value of detained cargo is
                    statement that on June 2 “estimated value such cargo so far as can be gauged
                    amounts approximately to four million pounds.”</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SRP1">
                            <hi rend="smallcaps">Skinner</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
