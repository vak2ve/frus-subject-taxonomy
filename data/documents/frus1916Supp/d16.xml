    <text>
        <body>
            <div frus:doc-dateTime-max="1916-03-25T23:59:59-05:00"
                frus:doc-dateTime-min="1916-03-25T00:00:00-05:00" n="16"
                subtype="historical-document" type="document" xml:id="d16">
                <note rend="inline" type="source">File No. 763.72119/137</note>
                <head>
                    <hi rend="italic">The Minister in Switzerland</hi> (<persName corresp="#p_SPA1"
                        type="from">
                        <hi rend="italic">Stovall</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berne</hi>
                        </placeName>, <date calendar="gregorian" when="1916-03-25">
                            <hi rend="italic">March 25, 1916, noon</hi>
                        </date>.<lb/>[<hi rend="italic">Received March 26, 9 a. m.</hi>]</dateline>
                </opener>
                <p>340. Indications in diplomatic circles here suggest that Turkey is desirous of
                    making separate peace with Allies.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SPA1">
                            <hi rend="smallcaps">Stovall</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
