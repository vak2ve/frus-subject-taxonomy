    <text>
        <body>
            <div frus:doc-dateTime-max="1916-05-24T23:59:59-05:00"
                frus:doc-dateTime-min="1916-05-24T00:00:00-05:00" n="355"
                subtype="historical-document" type="document" xml:id="d355">
                <note rend="inline" type="source">File No. 300.115/8525</note>
                <head>
                    <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="from">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1916-05-24">
                            <hi rend="italic">May 24, 1916, noon</hi>
                        </date>.<lb/>[<hi rend="italic">Received May 25, 1.20 p. m.</hi>]</dateline>
                </opener>
                <p>1272. Your 1107, January 31, 4 p. m.<note n="1" xml:id="d355fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_155">p. 155</ref>.</note>
                    Following official notice dated (?) April 22 published in <hi rend="italic"
                        >Wiener Zeitung</hi> of May 19:</p>
                <quote rend="blockquote">
                    <p>By reason of destruction of Italian steamer <hi rend="italic">Ancona</hi> by
                        ship of Austro-Hungarian naval forces, undersigned Prize Investigation
                        Commission will consider prize court procedure. Parties interested herewith
                        called upon to make known their rightful claims in writing within three
                        months accompanied by legal proof.</p>
                </quote>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
