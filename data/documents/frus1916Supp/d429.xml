    <text>
        <body>
            <div frus:doc-dateTime-max="1916-12-09T19:00:00-05:00"
                frus:doc-dateTime-min="1916-12-09T19:00:00-05:00" n="429"
                subtype="historical-document" type="document" xml:id="d429">
                <note rend="inline" type="source">File No. 857.857/42</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Germany</hi> (<persName corresp="#p_GJC1" type="to">
                        <hi rend="italic">Grew</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-12-09T19:00:00-05:00">
                            <hi rend="italic">December 9, 1916, 7 p. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3653. Department advised Norwegian steamer <hi rend="italic">Trippel</hi>, with
                    American citizens on board, was sunk by German submarine November 11, 18 miles
                    off Villarica, while <hi rend="italic">en route</hi> from Baltimore to
                    Genoa.</p>
                <p>Bring to attention of Foreign Minister and request prompt investigation and
                    report.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
