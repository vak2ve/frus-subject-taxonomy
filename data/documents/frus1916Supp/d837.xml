<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-02-23T23:59:59-05:00" frus:doc-dateTime-min="1916-02-23T00:00:00-05:00" n="837" subtype="historical-document" type="document" xml:id="d837">
                        <note rend="inline" type="source">File No. 341.622a/30</note>
                        <head>
                            <hi rend="italic">The Consul General at Hongkong</hi> (<persName corresp="#p_AGE1" type="from"><hi rend="italic">Anderson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Hongkong</hi></placeName>, <date calendar="gregorian" when="1916-02-23">
                                    <hi rend="italic">Feburary 23, 1916</hi>
                                </date>.<lb/>[<hi rend="italic">Received 8.15 a. m.</hi>]</dateline>
                        </opener>
                        <p>Thirty-eight Germans taken from American steamer <hi rend="italic">China</hi> on high seas near Shanghai by British auxiliary cruiser
                                <hi rend="italic">Laurentic</hi> arrived; detained here military
                            detention barracks.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_AGE1">
                                    <hi rend="smallcaps">Anderson</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>