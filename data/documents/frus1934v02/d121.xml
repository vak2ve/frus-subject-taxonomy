                subtype="historical-document" type="document" xml:id="d121">
                <note rend="inline" type="source">711.60d2/13</note>
                <head>
                    <hi rend="italic">Memorandum by the Under Secretary of State</hi> (<hi
                        rend="italic">Phillips</hi>)<note n="16a" xml:id="d121fn16a">Addressed to
                        the Assistant Secretary of State (Sayre) and to the Chief of the Division of
                        Eastern European Affairs (Kelley).</note>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1934-01-19">January 19,
                            1934</date>.</dateline>
                </opener>
                <p>The President authorized me today to go ahead with the proposed Treaty of
                    Friendship, Commerce, and Consular Rights with Finland. Please let me know when
                    the Treaty will be ready for signature.</p>
                <closer>
                    <signed>W[<hi rend="smallcaps">illiam</hi>] P[<hi rend="smallcaps"
                        >hillips</hi>]</signed>
                </closer>
            </div>
        </body>
    </text>
