<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-02-17T07:00:00-05:00" frus:doc-dateTime-min="1934-02-17T07:00:00-05:00" n="577" subtype="historical-document" type="document" xml:id="d577">
                            <note rend="inline" type="source">611.526 Wines/27: Telegram</note>
                            <head><hi rend="italic">The Ambassador in Spain</hi> (<persName type="from"><hi rend="italic">Bowers</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Madrid</hi></placeName>, <date calendar="gregorian" when="1934-02-17T12:00:00+00:00">February 17,
                                        1934—noon</date>.<lb/>[Received February 17—8:30
                                    a.m.]</dateline>
                            </opener>
                            <p>20. Your telegram No. 10, February 15, 7 p.m. Informed by Foreign
                                Office instructions have been cabled Spanish Ambassador to close
                                agreement.</p>
                            <closer><signed><hi rend="smallcaps">Bowers</hi></signed></closer>
                        </div>
                        </body></text></TEI>