                subtype="historical-document" type="document" xml:id="d779">
                <note rend="inline" type="source">467.11/971: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Turkey</hi> (<persName type="from">
                        <hi rend="italic">Skinner</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Istanbul</hi>
                        </placeName>, <date calendar="gregorian" when="1934-12-24T13:00:00+02:00"
                            >December 24, 1934—1 p.m.</date>
                        <lb/>[Received December 24—11:30 a.m.]</dateline>
                </opener>
                <p>82. Claims agreement ratified yesterday by Grand National Assembly.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Skinner</hi>
                    </signed>
                </closer>
            </div>
        </body>
