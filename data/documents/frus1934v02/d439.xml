<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-04-24T23:59:59-05:00" frus:doc-dateTime-min="1934-04-24T00:00:00-05:00" n="439" subtype="historical-document" type="document" xml:id="d439">
                            <note rend="inline" type="source">868.51 War Credits/664</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Greek Minister</hi> (<persName type="to"><hi rend="italic">Simopoulos</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1934-04-24">April 24, 1934</date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: I am requested by the Secretary of the
                                Treasury to transmit to you the following statement of the amount
                                due from your Government on May 10, 1934, under Part II of the Debt
                                Funding Agreement of May 10, 1929, in respect of its indebtedness to
                                the United States, and to request payment thereof, either at the
                                Treasury in Washington or at the Federal Reserve Bank of New
                                York:</p>
                            <p rend="center"><hi rend="smallcaps">Statement of Amount Due and
                                    Payable May</hi> 10, 1934 <hi rend="smallcaps">From the
                                    Government of Greece</hi></p>
                            <p rend="flushleft"><hi rend="italic">Amount due Nov. 10, 1932:</hi></p>
                            <table cols="3" rows="5">
                                <row>
                                    <cell rend="padding-left: 1.5em;">Principal of Bond No. 7</cell>
                                    <cell role="num">$227,000.00</cell>
                                    <cell/>
                                </row>
                                <row>
                                    <cell rend="padding-left: 1.5em;">Semi-annual interest due on
                                        Bonds Nos. 7 to 40</cell>
                                    <cell rendition="#border-bottom" role="num">217,920.00</cell>
                                    <cell/>
                                </row>
                                <row>
                                    <cell rend="padding-left: 4.5em;">Total due Nov. 10, 1932</cell>
                                    <cell/>
                                    <cell role="num">$444,920.00</cell>
                                </row>
                                <row>
                                    <cell rend="padding-left: 3em;">Less 30% of the semi-annual
                                        interest received Jan. 7, 1933</cell>
                                    <cell/>
                                    <cell rendition="#border-bottom" role="num">65,376.00</cell>
                                </row>
                                <row>
                                    <cell rend="padding-left: 6em;">Net amount due Nov. 10,
                                        1932</cell>
                                    <cell/>
                                    <cell role="num">$379,544.00</cell>
                                </row>
                            </table>
                            <pb facs="0640" n="540" xml:id="pg_540"/>
                            <p rend="flushleft"><hi rend="italic">Amount due May 10, 1933:</hi></p>
                            <table cols="3" rows="3">
                                <row>
                                    <cell rend="padding-left: 1.5em;">Principal of Bond No. 8</cell>
                                    <cell role="num">$231,000.00</cell>
                                    <cell/>
                                </row>
                                <row>
                                    <cell rend="padding-left: 1.5em;">Semi-annual interest due on
                                        Bonds Nos. 7 to 40</cell>
                                    <cell rendition="#border-bottom" role="num">217,920.00</cell>
                                    <cell/>
                                </row>
                                <row>
                                    <cell rend="padding-left: 3em;">Total due May 10, 1933</cell>
                                    <cell/>
                                    <cell role="num">$448,920.00</cell>
                                </row>
                            </table>
                            <p rend="flushleft"><hi rend="italic">Amount due Nov. 10, 1933:</hi></p>
                            <table cols="3" rows="4">
                                <row>
                                    <cell rend="padding-left: 1.5em;">Principal of Bond No. 9</cell>
                                    <cell role="num">$236,000.00</cell>
                                    <cell/>
                                </row>
                                <row>
                                    <cell rend="padding-left: 1.5em;">Semi-annual interest due on
                                        Bonds Nos. 7 to 40</cell>
                                    <cell role="num">217,920.00</cell>
                                    <cell/>
                                </row>
                                <row>
                                    <cell rend="padding-left: 1.5em;">Semi-annual installment due
                                        Nov. 10, 1933 under paragraph I (<hi rend="italic">b</hi>)
                                        of the Moratorium Agreement of May 24, 1932,<note n="8" xml:id="d439fn8"><hi rend="italic">Annual Report of the
                                                Secretary of the Treasury … 1932</hi>, p.
                                            291.</note> as authorized by the Joint Resolution of the
                                        Congress of the United States, approved December 23,
                                        1931</cell>
                                    <cell rendition="#border-bottom" role="num">53,967.93</cell>
                                    <cell/>
                                </row>
                                <row>
                                    <cell rend="padding-left: 3em;">Total due November 10,
                                        1933</cell>
                                    <cell/>
                                    <cell role="num">507,887.93</cell>
                                </row>
                            </table>
                            <p rend="flushleft"><hi rend="italic">Amount due May 10, 1934:</hi></p>
                            <table cols="3" rows="5">
                                <row>
                                    <cell rend="padding-left: 1.5em;">Principal of Bond No.
                                        10</cell>
                                    <cell role="num">$240,000.00</cell>
                                    <cell/>
                                </row>
                                <row>
                                    <cell rend="padding-left: 1.5em;">Semi-annual interest due on
                                        Bonds Nos. 7 to 40</cell>
                                    <cell role="num">217,920.00</cell>
                                    <cell/>
                                </row>
                                <row>
                                    <cell rend="padding-left: 1.5em;">Semi-annual installment due
                                        May 10, 1934 under Moratorium Agreement May 24, 1932</cell>
                                    <cell rendition="#border-bottom" role="num">53,967.93</cell>
                                    <cell/>
                                </row>
                                <row>
                                    <cell rend="padding-left: 3em;">Total due May 10, 1934</cell>
                                    <cell/>
                                    <cell rendition="#border-bottom" role="num">511,887.93</cell>
                                </row>
                                <row>
                                    <cell rend="padding-left: 4.5em;">Total amount due and payable
                                        May 10, 1934.</cell>
                                    <cell/>
                                    <cell role="num">$1,848,239.86</cell>
                                </row>
                            </table>
                            <p>Accept [etc.]</p>
                            <closer>For the Secretary of State:<lb/><signed><hi rend="smallcaps">William Phillips</hi></signed></closer>
                        </div>
                        </body></text></TEI>