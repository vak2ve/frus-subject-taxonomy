                subtype="historical-document" type="document" xml:id="d573">
                <note rend="inline" type="source">701.7111/288</note>
                <head>
                    <hi rend="italic">Mr. <persName type="from">Charles W. Hill</persName> of the
                        Executive Department of the State of Rhode Island to the <gloss type="to"
                            >Acting Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Providence</hi>
                        </placeName>, <date calendar="gregorian" when="1934-12-31">December 31,
                            1934</date>.<lb/>[Received January 2, 1935.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Phillips</hi>: With reference to your letter of
                    October 23 at the request of Governor Green I am sending to you the enclosed
                    check for $26 to reimburse Albert A. Amiaud, chauffeur to the Rumanian Minister
                    in Washington, for fine and costs paid by him to the third District Court of
                    this state.</p>
                <p>Trusting this is a satisfactory adjustment of this matter I am,</p>
                <p>Yours very truly</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Charles W. Hill</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
