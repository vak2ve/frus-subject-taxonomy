    <text>
        <body>
            <div frus:doc-dateTime-max="1934-11-08T23:59:59-05:00"
                frus:doc-dateTime-min="1934-11-08T00:00:00-05:00" n="445"
                subtype="historical-document" type="document" xml:id="d445">
                <note rend="inline" type="source">868.51 War Credits/678</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Greek Minister</hi> (<persName type="to">
                        <hi rend="italic">Simopoulos</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-11-08">November 8,
                            1934</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I am requested by the Secretary of the Treasury
                    to transmit to you the attached statement showing the amounts due and payable on
                    November 10, 1932, May 10, 1933, November 10, 1933, May 10, 1934, and November
                    10, 1934, from the Government of Greece pursuant to the terms of Part II of the
                    Debt Agreement of May 10, 1929, and the Moratorium Agreement of May 24,
                    1932.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William Phillips</hi>
                    </signed>
                </closer>
                <frus:attachment>
                    <opener>
                        <seg rendition="#center">[Enclosure]</seg>
                    </opener>
                    <head>
                        <hi rend="smallcaps">Statement of Amounts Due From the Government of Greece
                            November</hi> 10, 1932; <hi rend="smallcaps">May</hi> 10, 1933; <hi
                            rend="smallcaps">November</hi> 10, 1933; <hi rend="smallcaps">May</hi>
                        10, 1934; <hi rend="smallcaps">and November</hi> 10. 1934</head>
                    <p rend="flushleft">
                        <hi rend="italic">Amount due Nov. 10, 1932:</hi>
                    </p>
                    <table cols="3" rows="5">
                        <row>
                            <cell rend="padding-left: 1.5em;">Principal of Bond No. 7</cell>
                            <cell rendition="#bottom" role="num">$227,000.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 1.5em;">Semiannual interest due on Bonds Nos.
                                7 to 40</cell>
                            <cell rendition="#bottom #border-bottom" role="num">217,920.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 4.5em;">Total due Nov. 10, 1932</cell>
                            <cell rendition="#bottom" role="num">$444,920.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 3em;">Less 30% of the semiannual interest
                                received Jan. 7, 1933</cell>
                            <cell rendition="#bottom" role="num">65,376.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 6em;">Net amount due Nov. 10, 1932</cell>
                            <cell/>
                            <cell rendition="#bottom" role="num">$379,544.00</cell>
                        </row>
                    </table>
                    <p rend="flushleft">
                        <hi rend="italic">Amount due May 10, 1933:</hi>
                    </p>
                    <table cols="3" rows="5">
                        <row>
                            <cell rend="padding-left: 1.5em;">Principal of Bond No. 8</cell>
                            <cell rendition="#bottom" role="num">$231,000.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 1.5em;">Semiannual interest due on Bonds Nos.
                                7 to 40</cell>
                            <cell rendition="#bottom #border-bottom" role="num">217,920.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 4.5em;">Total due May 10, 1933</cell>
                            <cell rendition="#bottom" role="num">$448,920.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 3em;">Less 27½% of the semiannual interest
                                received July 6, 1934</cell>
                            <cell rendition="#bottom" role="num">59,928.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 6em;">Net amount due May 10, 1933</cell>
                            <cell/>
                            <cell rendition="#bottom" role="num">388,992.00</cell>
                        </row>
                    </table>
                    <pb facs="0645" n="545" xml:id="pg_545"/>
                    <p rend="flushleft">
                        <hi rend="italic">Amount due Nov. 10, 1933:</hi>
                    </p>
                    <table cols="3" rows="6">
                        <row>
                            <cell rend="padding-left: 1.5em;">Principal of Bond No. 9</cell>
                            <cell rendition="#bottom" role="num">$236,000.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 1.5em;">Semiannual interest due on Bonds Nos.
                                7 to 40</cell>
                            <cell rendition="#bottom" role="num">217,920.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell>Semiannual installment due Nov. 10, 1933 under paragraph I (<hi
                                    rend="italic">b</hi>) of the Moratorium Agreement of May 24,
                                1932, as authorized by the Joint Resolution of the Congress of the
                                United States, approved December 23, 1931</cell>
                            <cell rendition="#bottom #border-bottom" role="num">53,967.93</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 4.5em;">Total due November 10, 1933</cell>
                            <cell rendition="#bottom" role="num">$507,887.93</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 3em;">Less 27½% of the semiannual interest
                                received July 6, 1934</cell>
                            <cell rendition="#bottom #border-bottom" role="num">59,938.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 6em;">Net amount due November 10, 1933</cell>
                            <cell/>
                            <cell rendition="#bottom" role="num">$447,959.93</cell>
                        </row>
                    </table>
                    <p rend="flushleft">
                        <hi rend="italic">Amount due May 10, 1934:</hi>
                    </p>
                    <table cols="3" rows="6">
                        <row>
                            <cell rend="padding-left: 1.5em;">Principal of Bond No. 10</cell>
                            <cell rendition="#bottom" role="num">$240,000.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 1.5em;">Semiannual interest due on Bonds Nos.
                                7 to 40</cell>
                            <cell rendition="#bottom" role="num">217,920.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 1.5em;">Semiannual installment due May 10,
                                1934 under Moratorium Agreement May 24, 1932</cell>
                            <cell rendition="#bottom #border-bottom" role="num">53,967.93</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 4.5em;">Total due May 10, 1934</cell>
                            <cell rendition="#bottom" role="num">511,887.93</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 3em;">Less 35% of the semiannual interest
                                received July 6, 1934</cell>
                            <cell rendition="#bottom #border-bottom" role="num">76,272.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 6em;">Net amount due May 10, 1934</cell>
                            <cell/>
                            <cell rendition="#bottom" role="num">435,615.93</cell>
                        </row>
                    </table>
                    <p rend="flushleft">
                        <hi rend="italic">Amount due November 10, 1934:</hi>
                    </p>
                    <table cols="3" rows="4">
                        <row>
                            <cell rend="padding-left: 1.5em;">Principal of Bond No. 11</cell>
                            <cell rendition="#bottom" role="num">$245,000.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 1.5em;">Semiannual interest due on Bonds Nos.
                                7 to 40</cell>
                            <cell rendition="#bottom" role="num">217,920.00</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 1.5em;">Semiannual installment due Nov. 10,
                                1934 under Moratorium Agreement May 24, 1932</cell>
                            <cell rendition="#bottom #border-bottom" role="num">53,967.93</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell rend="padding-left: 3em;">Total due November 10, 1934</cell>
                            <cell/>
                            <cell rendition="#bottom" role="num">516,887.93</cell>
                        </row>
                    </table>
                </frus:attachment>
            </div>
        </body>
    </text>
