                subtype="historical-document" type="document" xml:id="d501">
                <note rend="inline" type="source">251.11 Insull, Samuel/612: Telegram</note>
                <head>
                    <hi rend="italic">The Third Secretary of Embassy in Turkey</hi> (<persName
                        type="from">
                        <hi rend="italic">Berry</hi>
                    </persName>), <hi rend="italic">Temporarily in the United States, to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chicago, Illinois</hi>
                        </placeName>, <date calendar="gregorian" when="1934-05-08">May 8,
                            1934</date>.<lb/>[Received 10:50 a.m.]</dateline>
                </opener>
                <p>Department’s May 3.<note n="50" xml:id="d501fn50">Not printed.</note> Delivered
                    Mr. Samuel Insull safely to the United States Marshal for the Northern District
                    of Illinois at the Federal Building in Chicago at 8:20 o’clock this morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Berry</hi>
                    </signed>
                </closer>
            </div>
        </body>
