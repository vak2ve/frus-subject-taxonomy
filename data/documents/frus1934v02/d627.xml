<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-10-20T06:00:00-05:00" frus:doc-dateTime-min="1934-10-20T06:00:00-05:00" n="627" subtype="historical-document" type="document" xml:id="d627">
                            <note rend="inline" type="source">611.5431/80: Telegram</note>
                            <head><hi rend="italic">The Chargé in Switzerland</hi> (<persName type="from"><hi rend="italic">Williamson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Berne</hi></placeName>, <date calendar="gregorian" when="1934-10-20T12:00:00+01:00">October 20,
                                        1934—noon</date>.<lb/>[Received October 20—8:20
                                    a.m.]</dateline>
                            </opener>
                            <p>41. Department’s 61, October 19, 6 p.m. Swiss Government has no
                                objection to plan.</p>
                            <closer><signed><hi rend="smallcaps">Williamson</hi></signed></closer>
                        </div>
