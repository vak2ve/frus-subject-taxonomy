                subtype="historical-document" type="document" xml:id="d93">
                <note rend="inline" type="source">874.00/481</note>
                <head>
                    <hi rend="italic">The Bulgarian Chargé</hi> (<persName type="from">
                        <hi rend="italic">Petroff Tchomakoff</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 158</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-05-21">May 21,
                            1934</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I am instructed to bring to your knowledge that
                    the new Bulgarian Government will continue the policy of cooperation with the
                    League of Nations, of friendly relations with all powers and understanding with
                    the neighboring states.</p>
                <p>Please accept [etc.]</p>
                <closer>
                    <signed>S. W. <hi rend="smallcaps">Petroff</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
