                subtype="historical-document" type="document" xml:id="d484">
                <note rend="inline" type="source">251.11 Insull, Samuel/372: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Egypt</hi> (<persName type="from">
                        <hi rend="italic">Fish</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Cairo</hi>
                        </placeName>, <date calendar="gregorian" when="1934-03-18T18:00:00+02:00"
                            >March 18, 1934—6 p.m.</date>
                        <lb/>[Received March 18—3:40 p.m.]</dateline>
                </opener>
                <p>5. Legation assumes Athens has advised Department of Insull’s recent movement. I
                    am orally but officially informed that the Egyptian Government will not permit
                    him to land anywhere in Egypt.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Fish</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
