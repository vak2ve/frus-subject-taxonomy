                subtype="historical-document" type="document" xml:id="d597">
                <note rend="inline" type="source">611.5231/825: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Spain</hi> (<persName type="from">
                        <hi rend="italic">Bowers</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1934-09-15T12:00:00+00:00"
                            >September 15, 1934—noon</date>.<lb/>[Received September 15—8:35
                        a.m.]</dateline>
                </opener>
                <p>60. Your No. 50, September 13, 6 p.m. Spanish Government agreeable and will make
                    announcement to press here Monday evening.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bowers</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
