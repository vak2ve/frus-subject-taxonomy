                subtype="historical-document" type="document" xml:id="d518">
                <note rend="inline" type="source">211.65/103: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Italy</hi> (<persName type="to">
                        <hi rend="italic">Long</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-04-10T16:00:00-05:00"
                            >April 10, 1934—4 p.m.</date>
                    </dateline>
                </opener>
                <p>27. Your 56, April 9, Noon. Pending receipt of further instructions following
                    arrival of Italian draft treaty you may withhold action on Department’s 24,
                    April 5, 1 P.M.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
