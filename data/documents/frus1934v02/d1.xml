                subtype="historical-document" type="document" xml:id="d1">
                <note rend="inline" type="source">123 Earle, George H./31: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Austria</hi> (<persName type="from">
                        <hi rend="italic">Earle</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1933-10-28T13:00:00+01:00"
                            >October 28, 1933—1 p.m.</date>
                        <lb/>[Received October 28—11:10 a.m.]</dateline>
                </opener>
                <p>60. I am leaving tomorrow, Sunday, with Kliefoth<note n="1" xml:id="d1fn1">Alfred
                        W. Kliefoth, First Secretary of Legation.</note> and Military Attaché<note
                        n="2" xml:id="d1fn2">Lt. Col. Martin C. Shallenberger.</note> for 14 days
                    trip of observation through 9 Austrian provincial capitals calling on governors
                    and officials. Austrian Foreign Office pleased with this trip. Will have
                    frequent telephonic communication with Swift at Legation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Earle</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
