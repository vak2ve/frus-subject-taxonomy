                subtype="historical-document" type="document" xml:id="d497">
                <note rend="inline" type="source">251.11 Insull, Samuel/511: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Turkey</hi> (<persName type="from">
                        <hi rend="italic">Skinner</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Ankara</hi>
                        </placeName>, <date calendar="gregorian" when="1934-04-07T11:00:00+02:00"
                            >April 7, 1934—11 a.m.</date>
                        <lb/>[Received April 7—9:10 a.m.]</dateline>
                </opener>
                <p>34. Department’s 20, April 6, 1 p.m.<note n="42" xml:id="d497fn42">Not
                        printed.</note> Export Line accepts reservations on steamer sailing from
                    Izmir declaring steamer will call at that port thence after calling at Marmaris
                    proceeding directly to New York arriving about May 10.</p>
                <p>Send further telegrams to Istanbul as I am returning tonight. Arrangements here
                    completed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Skinner</hi>
                    </signed>
                </closer>
            </div>
        </body>
