    <text>
        <body>
            <div frus:doc-dateTime-max="1934-03-27T23:59:59-05:00"
                frus:doc-dateTime-min="1934-03-27T00:00:00-05:00" n="244"
                subtype="historical-document" type="document" xml:id="d244">
                <note rend="inline" type="source">548.D1/113</note>
                <head>
                    <hi rend="italic">The Consul at Geneva</hi> (<persName type="from">
                        <hi rend="italic">Gilbert</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 855 Political</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Geneva</hi>
                        </placeName>, <date calendar="gregorian" when="1934-03-27">March 27,
                            1934</date>.<lb/>[Received April 4.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to transmit the original of a
                    communication addressed to the Secretary of State under date of March 22, 1934
                    from the Secretary-General of the High Commission for Refugees coming from
                        Germany,<note n="5" xml:id="d244fn5">Not printed.</note> stating that the
                    next meeting of the Governing Body of the High Commission will be held in London
                    on May 2 and 3, 1934.</p>
                <p>This communication also encloses a copy of a letter<note n="5" xml:id="d244fn6"
                        >Not printed.</note> addressed by the Secretary-General of the Commission to
                    Professor Joseph P. Chamberlain, setting forth the agenda of the meeting in
                    question.</p>
                <p>Respectfully yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Prentiss B. Gilbert</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
