                subtype="historical-document" type="document" xml:id="d66">
                <note rend="inline" type="source">663.116/60: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Austria</hi> (<persName type="from">
                        <hi rend="italic">Kliefoth</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1934-04-21T13:00:00+01:00"
                            >April 21, 1934—1 p.m.</date>
                        <lb/>[Received April 21—8:20 a.m.]</dateline>
                </opener>
                <p>56. Your telegram No. 22, April 20, 1 p.m. Have taken matter up with Foreign
                    Office this morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kliefoth</hi>
                    </signed>
                </closer>
            </div>
        </body>
