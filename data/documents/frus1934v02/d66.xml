                            <note rend="inline" type="source">663.116/60: Telegram</note>
                            <head><hi rend="italic">The Chargé in Austria</hi> (<persName type="from"><hi rend="italic">Kliefoth</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Vienna</hi></placeName>, <date calendar="gregorian" when="1934-04-21T13:00:00+01:00">April 21, 1934—1
