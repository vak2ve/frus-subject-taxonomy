                subtype="historical-document" type="document" xml:id="d206">
                <note rend="inline" type="source">862.001H58/37: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName type="from">
                        <hi rend="italic">Dodd</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1934-08-02T10:00:00+01:00"
                            >August 2, 1934—10 a.m.</date>
                        <lb/>[Received August 2—9:10 a.m.]</dateline>
                </opener>
                <p>160. President Hindenburg died at 9 this morning. Cabinet in session.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dodd</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
