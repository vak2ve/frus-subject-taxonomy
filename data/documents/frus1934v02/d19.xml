<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-02-15T11:00:00-05:00" frus:doc-dateTime-min="1934-02-15T11:00:00-05:00" n="19" subtype="historical-document" type="document" xml:id="d19">
                            <note rend="inline" type="source">863.00/866a: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Chargé in Austria</hi> (<persName type="to"><hi rend="italic">Kliefoth</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1934-02-15T11:00:00-05:00">February 15, 1934—11
                                        a.m.</date></dateline>
                            </opener>
                            <p>7. Please report more frequently during this crisis including
                                pertinent information on the welfare of Americans in Austria.</p>
                            <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                        </div>
                        </body></text></TEI>