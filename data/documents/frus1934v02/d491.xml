                subtype="historical-document" type="document" xml:id="d491">
                <note rend="inline" type="source">251.11 Insull, Samuel/462: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Turkey</hi> (<persName type="from">
                        <hi rend="italic">Skinner</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Ankara</hi>
                        </placeName>, <date calendar="gregorian" when="1934-03-31T16:00:00+02:00"
                            >March 31, 1934—4 p.m.</date>
                        <lb/>[Received March 31—11:10 a.m.]</dateline>
                </opener>
                <p>24. Documents Insull case received and delivered before noon. I hope for
                    favorable court action but there may be some delay. Meantime Insull is being
                    detained.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Skinner</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
