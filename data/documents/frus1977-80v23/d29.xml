                <head>29. Summary of Conclusions of a Special Coordination Committee Meeting<note
                        n="1" type="source" xml:id="d29fn1">Source: Carter Library, National
                        Security Council, Institutional Files, 1977–1981, Box 184, SCC 068 Horn of
                        Africa, Cuba’s role in Africa, 3/27/78. Secret; Sensitive. Drafted by
                            <persName corresp="#p_HPB_2">Henze</persName>. The meeting was held in
                        the White House Situation Room.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            from="1978-03-27T16:00:00-05:00" to="1978-03-27T17:45:00-05:00">March
                            27, 1978, 4:00–5:45 p.m.</date>
                    </dateline>
                </opener>
                <list type="subject">
                    <head>SUBJECT</head>
                    <item>Horn of Africa</item>
                </list>
                <list type="participants">
                    <head>PARTICIPANTS</head>
                    <item>
                        <list>
                            <head>
                                <hi rend="italic">State</hi>
                            </head>
                            <item>
                                <persName corresp="#p_VCR_1">Cyrus Vance</persName>
                            </item>
                            <item>Richard M. Moose, Jr. (Ass’t. Sec./African Affairs)</item>
                            <item>
                                <persName corresp="#p_MDF_1">Donald McHenry</persName> (<gloss
                                    target="#t_USUN_1">USUN</gloss>)</item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <head>
                                <hi rend="italic">Defense</hi>
                            </head>
                            <item>
                                <persName corresp="#p_BH_2">Harold Brown</persName>
                            </item>
                            <item>
                                <persName corresp="#p_DC_2">Charles W. Duncan, Jr.</persName>
                                (Deputy Secretary of Defense)</item>
                            <item>
                                <persName corresp="#p_MDE_1">David E. McGiffert</persName> (Ass’t.
                                Secretary/ISA)</item>
                            <item>
                                <hi rend="italic">
                                    <gloss target="#t_JCS_1">JCS</gloss>
                                </hi>
                            </item>
                            <item>General David C. <persName corresp="#p_JJW_1">Jones</persName>
                                (Acting Chairman, <gloss target="#t_JCS_1">JCS</gloss>)</item>
                            <item>LTG William Y. Smith (Assistant to Chairman, <gloss
                                    target="#t_JCS_1">JCS</gloss>)</item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <head>
                                <hi rend="italic">
                                    <gloss target="#t_CIA_1">CIA</gloss>
                                </hi>
                            </head>
                            <item>
                                <persName corresp="#p_CFC_1">Frank Carlucci</persName> (Acting
                                    <gloss target="#t_DCI_1">DCI</gloss>)</item>
