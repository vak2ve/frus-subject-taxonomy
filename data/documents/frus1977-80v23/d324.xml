                <head>324. Summary of Conclusions of a Special Coordination Committee Meeting<note
                        n="1" type="source" xml:id="d324fn1">Source: Carter Library, National
                        Security Affairs, Staff Material, Office File, Box 17, SCC Meeting #172 Held
                        6/26/79, 6/79. Top Secret.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            from="1979-06-26T09:00:00-04:00" to="1979-06-26T09:55:00-04:00">June 26,
                            1979, 9:00–9:55 a.m.</date>
                    </dateline>
                </opener>
                <list type="subject">
                    <head>SUBJECT</head>
                    <item>Afghanistan and Grenada (S)</item>
                </list>
