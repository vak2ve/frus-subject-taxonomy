<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1944-10-17T23:59:59-05:00" frus:doc-dateTime-min="1944-10-17T00:00:00-05:00" n="10" subtype="historical-document" type="document" xml:id="d10">
                        <note rend="inline" type="source">Roosevelt Papers: Telegram</note>
                        <head>
                            <hi rend="italic">The Commanding General, United States Military Mission
                                in the Soviet Union</hi> (<persName corresp="#p_D1" type="from"><hi rend="italic">Deane</hi></persName>), <hi rend="italic">to the
                                    <gloss type="to">Joint Chiefs of Staff</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Excerpt]<note n="1" xml:id="d10fn1">Printed in
                                    full <hi rend="italic">post</hi>, <ref target="#pg_371">pp.
                                        371</ref>–<ref target="#pg_374">374</ref>.</note>
                            </seg>
                        </opener>
                        <opener>
                            <seg rendition="#left">
                                <hi rend="smallcaps">top secret</hi>
                                <lb/>
                                <hi rend="smallcaps">priority</hi>
                                <lb/>
                                <hi rend="smallcaps">eyes only</hi>
                            </seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Moscow</hi></placeName>, <date calendar="gregorian" when="1944-10-17">17 October
                                1944</date>.</dateline>
                        </opener>
                        <p rend="flushleft">M 21412.</p>
                        <p rend="center">. . . . . . . . . . . . . .</p>
                        <p>. . . <persName corresp="#p_S16">Stalin</persName> then said that Mr.
                                <persName corresp="#p_HHL1">Hopkins</persName>, with the approval of
                            the President, had talked with Mr. <persName corresp="#p_GML1">Gromyko</persName> and he had indicated that the President was
                            anxious to meet with Marshal <persName corresp="#p_S16">Stalin</persName> somewhere in the Black Sea area. He said
                            unequivocally that he would be <pb facs="0091" n="9" xml:id="pg_9"/>
                            delighted to meet the President and was prepared to so do toward the end
                            of November. . . .</p>
                        <p rend="center">. . . . . . . . . . . . . .</p>
                    </div>
                    </body></text></TEI>