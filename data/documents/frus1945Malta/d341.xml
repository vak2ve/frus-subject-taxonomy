    <text>
        <body>
            <div frus:doc-dateTime-max="1945-02-05T23:59:59-05:00"
                frus:doc-dateTime-min="1945-02-05T00:00:00-05:00" n="341"
                subtype="historical-document" type="document" xml:id="d341">
                <note rend="inline" type="source">Hopkins Papers</note>
                <head>
                    <hi rend="italic">The President’s Special Assistant</hi> (<persName
                        corresp="#p_HHL1" type="from">
                        <hi rend="italic">Hopkins</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">President</gloss>
                    </hi>
                    <note n="1" xml:id="d341fn1">See <hi rend="italic">ante</hi>, <ref
                            target="#pg_620">p. 620</ref>.</note>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Yalta</hi>
                        </placeName>, <date calendar="gregorian" when="1945-02-05">February 5,
                            1945.</date>]</dateline>
                </opener>
                <p rend="flushleft">Could you ask him</p>
                <p>1. Why not take all <gloss target="#t_Gestapo1">Gestapo</gloss>-Storm Troopers
                    and other Nazi criminals.</p>
            </div>
        </body>
    </text>
