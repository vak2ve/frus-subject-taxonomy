<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The President’s Special Assistant (
                        Hopkins
                    ) to the President</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Malta</bibl><bibl type="frus-document-id">d397</bibl><bibl type="frus-document-number">397</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-02-08T00:00:00-05:00" notAfter="1945-02-08T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-02-08T23:59:59-05:00" frus:doc-dateTime-min="1945-02-08T00:00:00-05:00" n="397" subtype="historical-document" type="document" xml:id="d397">
                <note rend="inline" type="source">Hopkins Papers</note>
                <head>
                    <hi rend="italic">The President’s Special Assistant</hi> (<persName corresp="#p_HHL1" type="from">
                        <hi rend="italic">Hopkins</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">President</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Yalta</hi>
                        </placeName>, <date calendar="gregorian" when="1945-02-08">February 8,
                            1945</date>.]<note n="1" xml:id="d397fn1">This note is undated but is
                            assumed to have been passed to the President at the plenary session on
                            February 8 in connection with the President’s reference to <persName corresp="#p_WS2">Welles</persName> and the reasons why certain South
                            American states had not declared war. See <hi rend="italic">ante</hi>,
                                <ref target="#pg_773">p. 773</ref>.</note>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. President</hi>:—The Joint Chiefs of Staff told
                        <persName corresp="#p_WS2">Welles</persName>
                    <note n="2" xml:id="d397fn2">The Department of Defense states that there is no
                        evidence in the files of the Joint Chiefs of Staff to substantiate this
                        statement.</note> that it would be difficult for us to defend their coasts
                    against Japan. That is <persName corresp="#p_WS2">Welles</persName> excuse.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HHL1">
                            <hi rend="smallcaps">Harry</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
