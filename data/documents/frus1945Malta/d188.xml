    <text>
        <body>
            <div frus:doc-dateTime-max="1944-12-09T23:59:59-05:00"
                frus:doc-dateTime-min="1944-12-09T00:00:00-05:00" n="188"
                subtype="historical-document" type="document" xml:id="d188">
                <note rend="inline" type="source">865.01/12–944</note>
                <head>
                    <hi rend="italic">The British Ambassador</hi> (<persName corresp="#p_H1"
                        type="from">
                        <hi rend="italic">Halifax</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1944-12-09">December 9,
                            1944</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Ed</hi>: I have just received a telegram asking me
                    to convey to you the enclosed personal message from Anthony, in reply to yours
                    of December 7th.</p>
                <p>Yours ever,</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SERJ1">
                            <hi rend="smallcaps">Edward</hi>
                        </persName>
                    </signed>
                </closer>
                <frus:attachment>
                    <opener>
                        <seg rendition="#center">[Enclosure]</seg>
                    </opener>
                    <p rend="center">
                        <hi rend="smallcaps">Personal Message From Mr. <persName corresp="#p_EA1"
                                >Eden</persName> to Mr. <persName corresp="#p_SERJ1"
                                >Stettinius</persName>
                        </hi>
                    </p>
                    <p>Thank you so much for your helpful and understanding message which I received
                        through <persName corresp="#p_WJG1">Winant</persName>. It is my keen desire
                        that we should work close together.<note n="1" xml:id="d188fn1">Copies of
                            the <persName corresp="#p_SERJ1">Stettinius</persName>-<persName
                                corresp="#p_EA1">Eden</persName> messages were sent to the President
                            on December 10, 1944.</note>
                    </p>
                </frus:attachment>
            </div>
        </body>
    </text>
