    <teiHeader><fileDesc><titleStmt><title>The President’s Special Assistant (
                        Hopkins
                    ) to the President
                    
                    The relationship of this note to the Fourth Plenary
                        Meeting appears from internal evidence and from Sherwood, pp. 855–856. See
                            ante, p. 713.</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Malta</bibl><bibl type="frus-document-id">d378</bibl><bibl type="frus-document-number">378</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-02-07T00:00:00-05:00" notAfter="1945-02-07T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-02-07T23:59:59-05:00" frus:doc-dateTime-min="1945-02-07T00:00:00-05:00" n="378" subtype="historical-document" type="document" xml:id="d378">
                <note rend="inline" type="source">Hopkins Papers</note>
                <head>
                    <hi rend="italic">The President’s Special Assistant</hi> (<persName corresp="#p_HHL1" type="from">
                        <hi rend="italic">Hopkins</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">President</gloss>
                    </hi>
                    <note n="1" xml:id="d378fn1">The relationship of this note to the Fourth Plenary
                        Meeting appears from internal evidence and from Sherwood, pp. 855–856. See
                            <hi rend="italic">ante</hi>, <ref target="#pg_713">p. 713</ref>.</note>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Yalta</hi>
                        </placeName>, <date calendar="gregorian" when="1945-02-07">February 7,
                            1945</date>.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. President</hi> I think you should try to get this
                    referred to Foreign ministers before there is trouble.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HHL1">
                            <hi rend="smallcaps">Harry</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
