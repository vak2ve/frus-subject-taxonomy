<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-02-10T08:30:00-05:00" frus:doc-dateTime-min="1945-02-10T06:00:00-05:00" n="450" subtype="historical-document" type="document" xml:id="d450">
                                    <note rend="inline" type="source">Bohlen Collection</note>
                                    <head>
                                        <hi rend="italic">
                                            <persName corresp="#p_HK1">Harriman</persName>
                                            Memorandum of Conversations</hi><note n="1" xml:id="d450fn1">The document is labeled “copy” and a
                                            typewritten note at the bottom of the first page says:
                                            “Dictated by Mr. <persName corresp="#p_HK1">Harriman</persName>”.</note>
                                    </head>
                                    <dateline>
                                        <placeName>Leningrad</placeName>, <date ana="#date_undated-inferred-from-document-content" calendar="gregorian" from="1945-02-10T14:00:00+03:00" to="1945-02-10T16:30:00+03:00" type="conversation-or-meeting-date">February 10, 1945,
                                            2:00 p.m. to 4:30 p.m.</date>
                                    </dateline>
