                                            </cell>
                                            <cell>Time:</cell>
                                            <cell>4:30 PM</cell>
                                        </row>
                                        <row>
                                            <cell/>
                                            <cell>Marshal <persName corresp="#p_S16">Stalin</persName>
                                            </cell>
                                            <cell>Place:</cell>
                                            <cell>Livadia Palace</cell>
