<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>President Roosevelt to Prime Minister Churchill
                    
                    Sent to the United States Naval Attaché, London, via
                        Navy channels.</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Malta</bibl><bibl type="frus-document-id">d63</bibl><bibl type="frus-document-number">63</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-01-22T00:00:00-05:00" notAfter="1945-01-22T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-01-22T23:59:59-05:00" frus:doc-dateTime-min="1945-01-22T00:00:00-05:00" n="63" subtype="historical-document" type="document" xml:id="d63">
                <note rend="inline" type="source">Roosevelt Papers: Telegram</note>
                <head>
                    <hi rend="italic">President <persName corresp="#p_RFD1" type="from">Roosevelt</persName> to Prime Minister <persName corresp="#p_CWS1" type="to">Churchill</persName>
                    </hi>
                    <note n="1" xml:id="d63fn1">Sent to the United States Naval Attaché, London, via
                        Navy channels.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                        <lb/>
                        <hi rend="smallcaps">priority</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1945-01-22">22 January
                            1945</date>.</dateline>
                </opener>
                <p>Number 704, Personal and Top Secret, for the Prime Minister from the
                    President.</p>
                <p>I am in full agreement with the suggestion regarding press representatives and
                    photographers made in your 891.<note n="2" xml:id="d63fn2">
                        <persName corresp="#p_CWS1">Churchill</persName> replied, in his telegram
                        No. 892, “Please tell U. J.” (Roosevelt Papers).</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_RFD1">
                            <hi rend="smallcaps">Roosevelt</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
