<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-02-05T23:59:59-05:00" frus:doc-dateTime-min="1945-02-05T00:00:00-05:00" n="340" subtype="historical-document" type="document" xml:id="d340">
                                <note rend="inline" type="source">Hopkins Papers</note>
                                <head>
                                    <hi rend="italic">The President’s Special Assistant</hi>
                                        (<persName corresp="#p_HHL1" type="from"><hi rend="italic">Hopkins</hi></persName>) <hi rend="italic">to the
                                            <gloss type="to">President</gloss>
                                    </hi><note n="1" xml:id="d340fn1">See preceding footnote. See
                                        also <hi rend="italic">ante</hi>, <ref target="#pg_619">p.
                                            619</ref>.</note>
                                </head>
                                <opener>
                                    <dateline rendition="#right">[<placeName><hi rend="smallcaps">Yalta</hi></placeName>, <date calendar="gregorian" when="1945-02-05">February 5, 1945.</date>]</dateline>
                                </opener>
                                <p>
                                    <del rend="strikethrough">Why</del>
                                    <del rend="strikethrough">not</del>
                                    <del rend="strikethrough">agree</del>
                                    <del rend="strikethrough">to</del>
                                    <del rend="strikethrough">a</del>
                                    <del rend="strikethrough">French</del>
                                    <del rend="strikethrough">zone</del>
                                    <del rend="strikethrough">and</del>
                                    <del rend="strikethrough">consider</del>
                                    <del rend="strikethrough">later</del>
                                    <del rend="strikethrough">the</del>
                                    <del rend="strikethrough">question</del>
                                    <del rend="strikethrough">of</del>
                                    <del rend="strikethrough">putting</del>
                                    <del rend="strikethrough">them</del>
                                    <del rend="strikethrough">on</del>
                                    <del rend="strikethrough">control</del>
                                    <del rend="strikethrough">commission</del>
                                    <del rend="strikethrough">for</del>
                                    <del rend="strikethrough">Germany?</del>
                                    <del rend="strikethrough">or</del>
                                    <del rend="strikethrough">not</del>—</p>
                                <p>Could you not add that French participation on Control Commission
                                    might be considered later?</p>
                            </div>
                            </body></text></TEI>