<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-01-11T23:59:59-05:00" frus:doc-dateTime-min="1945-01-11T00:00:00-05:00" n="51" subtype="historical-document" type="document" xml:id="d51">
                        <note rend="inline" type="source">Roosevelt Papers: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in the Soviet Union</hi> (<persName corresp="#p_HWA1" type="from"><hi rend="italic">Harriman</hi></persName>) <hi rend="italic">to the <gloss type="to">President</gloss>
                            </hi><note n="1" xml:id="d51fn1">Sent by the United States Naval
                                Attaché, Moscow, via Navy channels.</note>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Moscow</hi></placeName>, <date calendar="gregorian" when="1945-01-11">11 January
                                1945</date>.</dateline>
                        </opener>
                        <p>Personal and Top Secret for the President from <persName corresp="#p_HWA1">Harriman</persName>.</p>
                        <p>
                            <persName corresp="#p_MVM1">Molotov</persName> advises me that Marshal
                                <persName corresp="#p_S16">Stalin</persName> has accepted the code
                            name Argonaut and has so advised Mr. <persName corresp="#p_CWS1">Churchill</persName>. This is in reply to your <persName corresp="#p_WHD1">White</persName> House 160 Jan 7.<note n="2" xml:id="d51fn2">See <hi rend="italic">ante</hi>, <ref target="#pg_30">p. 30</ref>, footnote 3.</note>
                        </p>
                    </div>
                    </body></text></TEI>