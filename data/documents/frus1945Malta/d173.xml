<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Secretary of State to the
                            President</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Malta</bibl><bibl type="frus-document-id">d173</bibl><bibl type="frus-document-number">173</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1944-12-01T00:00:00-05:00" notAfter="1944-12-01T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1944-12-01T23:59:59-05:00" frus:doc-dateTime-min="1944-12-01T00:00:00-05:00" n="173" subtype="historical-document" type="document" xml:id="d173">
                <note rend="inline" type="source">865.01/12–144</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">President</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washingon</hi>
                        </placeName>,] <date calendar="gregorian" when="1944-12-01">December 1,
                            1944</date>.</dateline>
                </opener>
                <p rend="center">
                    <hi rend="smallcaps">Special Information for the President</hi>
                </p>
                <p rend="center">[Excerpts]<note n="1" xml:id="d173fn1">For other excerpts from this
                        memorandum, see <hi rend="italic">ante</hi>, <ref target="#pg_213">p.
                            213</ref>, and <hi rend="italic">post</hi>, <ref target="#pg_266">pp.
                            266</ref>, <ref target="#pg_430">430</ref>.</note>
                </p>
                <p>These international developments of the past two or three days will be of
                    especial interest to you:</p>
                <p>· · · · · · · · · · · · · ·</p>
                <p>
                    <persName corresp="#p_TM2">
                        <hi rend="italic">Tito</hi>
                    </persName>-<hi rend="italic">
                        <persName corresp="#p_SI2">Subasic</persName> Agreement</hi>. <persName corresp="#p_MBFH1">Brigadier MacLean</persName> has told Ambassador
                        <persName corresp="#p_KAC1">Kirk</persName> that Mr. <persName corresp="#p_CWS1">Churchill</persName> is expected to urge King <persName corresp="#p_PII1">Peter</persName> to accept the agreement recently
                    formulated by <persName corresp="#p_TM2">Tito</persName> and the Yugoslav
                    Premier and to send a British Ambassador to Belgrade as soon as the agreement
                    becomes effective.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SERJ1">E. R. <hi rend="smallcaps">Stettinius,
                            Jr</hi>.</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
