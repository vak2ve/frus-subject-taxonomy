    <text>
        <body>
            <div frus:doc-dateTime-max="1881-11-25T23:59:59-05:00" frus:doc-dateTime-min="1881-11-25T00:00:00-05:00" n="268" subtype="historical-document" type="document" xml:id="d268">
                <head>No. 264.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Morton</persName>
                            to Mr. <persName type="to">Blaine</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1881-11-25">
                            <hi rend="italic">November</hi> 25,
                            1881</date>.</dateline>
                </opener>
                <p>Informed chairman committee of Chamber; says bill for microscopic examination
                        pork will be withdrawn. The training of microscopic inspectors has been
                        suspended.</p>
                <closer>
                    <signed>MORTON.</signed>
                </closer>
            </div>
        </body>
