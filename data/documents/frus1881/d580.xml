    <text>
        <body>
            <div frus:doc-dateTime-max="1881-10-31T23:59:59-05:00" frus:doc-dateTime-min="1881-10-31T00:00:00-05:00" n="580" subtype="historical-document" type="document" xml:id="d580">
                <head>No. 576.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName>
                            to Mr. <persName type="to">Hurlburt</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1881-10-31">
                            <hi rend="italic">October</hi> 31,
                            1881</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Hurlbut</hi>, <hi rend="italic">Minister, Lima:</hi>
                </p>
                <p>Continue to recognize Calderon government until otherwise specially
                        instructed.</p>
                <p>Acknowledge receipt.</p>
                <closer>
                    <signed>BLAINE.</signed>
                </closer>
            </div>
        </body>
    </text>
