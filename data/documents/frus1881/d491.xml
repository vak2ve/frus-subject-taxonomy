                subtype="historical-document" type="document" xml:id="d491">
                <head>No. 487.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Evarts</persName> to Señor <persName
                            type="to">Navarro</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1880-12-06">
                            <hi rend="italic">December</hi> 6, 1880</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 30th ultimo, in which, by direction of your government, you
                    have informed me that it is the desire of Mexico that the treaty of navigation
                    and commerce of the 5th of April, 1831, between it and the United States, shall
                    be terminated after the 30th day of November, 1881.</p>
                <p>Taking due note of such circumstances, I offer to you, &amp;c.,</p>
                <closer>
                    <signed>WM. M. EVARTS.</signed>
                </closer>
            </div>
        </body>
    </text>
