                <head>No. 425.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr. <persName
                            type="to">Bingham</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1881-03-22">
                            <hi rend="italic">March</hi> 22, 1881</date>.</dateline>
                    <seg rendition="#left">No. 576.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                    dispatch No. 1250 of the 7th ultimo, and to approve your action reported
                    therein, in respect of the order amending the consular court regulations as to
                    the punishment for crimes and offenses against the laws of the United
                    States.</p>
                <p>I am, &amp;c.,</p>
                <closer>
                    <signed>JAMES G. BLAINE.</signed>
                </closer>
            </div>
        </body>
