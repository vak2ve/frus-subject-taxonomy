                subtype="historical-document" type="document" xml:id="d585">
                <head>No. 581.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr. <persName
                            type="to">Hurlbut</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1881-11-26">
                            <hi rend="italic">November</hi> 26, 1881</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Hurlbut</hi>, <hi rend="italic">Minister, Lima:</hi>
                </p>
                <p>Special envoy extraordinary leaves Washington for Peru immediately. Continue
                    recognition of Calderon government.</p>
                <closer>
                    <signed>BLAINE.</signed>
                </closer>
            </div>
        </body>
