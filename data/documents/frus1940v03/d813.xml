                <note rend="inline" type="source">740.0011 European War 1939/4174d: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at Beirut</hi> (<persName type="to">
                        <hi rend="italic">Palmer</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-06-24T13:00:00-04:00"
                            >June 24, 1940—1 p.m.</date>
                    </dateline>
                </opener>
                <p>31. Please report regarding attitude of Allied army in Near East and of the
                    French authorities in your area concerning present situation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
