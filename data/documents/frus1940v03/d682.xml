                subtype="historical-document" type="document" xml:id="d682">
                <note rend="inline" type="source">811.3340/1043: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Liberia</hi> (<persName type="to">
                        <hi rend="italic">Wharton</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-10-01T17:00:00-05:00"
                            >October 1, 1940—5 p.m.</date>
                    </dateline>
                </opener>
                <p>37. Please request permission for the U.S.S. <hi rend="italic">Omaha</hi>,
                    Flagship of Rear Admiral David M. LeBreton, commanded by Captain L. A. Davidson,
                    to visit Monrovia informally from October 9 to 11, inclusive.</p>
                <p>Telegraph reply.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
