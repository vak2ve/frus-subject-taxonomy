<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-10-15T10:00:00-05:00" frus:doc-dateTime-min="1940-10-15T10:00:00-05:00" n="890" subtype="historical-document" type="document" xml:id="d890">
                            <note rend="inline" type="source">811.20 Defense (M)/489:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The Ambassador in Turkey</hi> (<persName type="from"><hi rend="italic">MacMurray</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Ankara</hi></placeName>, <date calendar="gregorian" when="1940-10-15T17:00:00+02:00">October 15, 1940—5 p.m.</date>
                                    <lb/> [Received 7:58 p.m.]</dateline>
                            </opener>
                            <p>169. Embassy’s 166, October 9, 5 p.m. The British Embassy received
                                today the written consent of the Turkish Government to the resale of
                                Turkish chrome to us by Great Britain.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">MacMurray</hi>
                                </signed>
                            </closer>
                        </div>
                    </body></text></TEI>