                subtype="historical-document" type="document" xml:id="d423">
                <note rend="inline" type="source">740.0011 European War 1939/6181: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Italy</hi> (<persName type="from">
                        <hi rend="italic">Reed</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1940-10-22T10:00:00+02:00"
                            >October 22, 1940—10 a.m.</date>
                        <lb/> [Received October 22—8:35 a.m.]</dateline>
                </opener>
                <p>1004. My 1001, October 21, 9 p.m. Substantially identical information has been
                    given one of our correspondents by a high German Embassy official who intimated
                    that Italian attack this week would be on a relatively small scale for purpose
                    of testing Greek temper and resistance.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Reed</hi>
                    </signed>
                </closer>
            </div>
        </body>
