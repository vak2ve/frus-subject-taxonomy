                subtype="historical-document" type="document" xml:id="d777">
                <note rend="inline" type="source">840.48 Refugees/2307: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in the United Kingdom</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1940-11-19T17:00:00+01:00"
                            >November 19, 1940—5 p.m.</date>
                        <lb/> [Received 12:10 p.m.]</dateline>
                </opener>
                <p>3784. Your 3510, November 16, 7 p.m. Am advised by Foreign Office that British
                    Government intends hereafter to refuse admission into Palestine to all illegal
                    immigrants. Accommodation for such persons is to be arranged elsewhere. An
                    announcement of the foregoing is to be made tomorrow in Palestine. British
                    Embassy in Washington has been fully advised of details and instructed to advise
                    you.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
