                <note rend="inline" type="source">340.1115A/700: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at Jerusalem</hi> (<persName type="to">
                        <hi rend="italic">Wadsworth</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-05-28">May 28,
                            1940</date>.</dateline>
                </opener>
                <p>Your 36, May 25, 6 p.m. Your position approved.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
