<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-12-10T15:00:00-05:00" frus:doc-dateTime-min="1940-12-10T15:00:00-05:00" n="732" subtype="historical-document" type="document" xml:id="d732">
                            <note rend="inline" type="source">881.00/1793a: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in the United Kingdom</hi> (<persName type="to"><hi rend="italic">Johnson</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1940-12-10T15:00:00-05:00">December 10, 1940—3 p.m.</date>
                                </dateline>
                            </opener>
                            <p>3736. Please forward Department by telegraph text of statement made
                                in House of Commons by Butler on December 4 regarding Tangier and
                                send copy to Tangier by mail.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>