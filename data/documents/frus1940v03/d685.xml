                subtype="historical-document" type="document" xml:id="d685">
                <note rend="inline" type="source">811.3340/1045: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Liberia</hi> (<persName type="from">
                        <hi rend="italic">Wharton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1940-10-06T13:00:00-00:44"
                            >October 6, 1940—1 p.m.</date>
                        <lb/> [Received October 7—8:10 a.m.]</dateline>
                </opener>
                <p>59. In reply to my request for visit Simpson states his Government will be
                    pleased to receive <hi rend="italic">Omaha</hi>.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wharton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
