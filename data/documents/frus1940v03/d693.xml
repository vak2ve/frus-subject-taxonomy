                subtype="historical-document" type="document" xml:id="d693">
                <note rend="inline" type="source">752.822/4: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Liberia</hi> (<persName type="from">
                        <hi rend="italic">Wharton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1940-08-24T14:00:00-00:44"
                            >August 24, 1940—2 p.m.</date>
                        <lb/> [Received August 25—1:20 a.m.]</dateline>
                </opener>
                <p>50. In answer to your telegram 32, August 21, 6 p.m., Simpson states that no
                    action will be taken.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wharton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
