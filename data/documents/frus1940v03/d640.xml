<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-12-19T12:40:00-05:00" frus:doc-dateTime-min="1940-12-19T12:40:00-05:00" n="640" subtype="historical-document" type="document" xml:id="d640">
                            <note rend="inline" type="source">391.1164/167: Telegram</note>
                            <head>
                                <hi rend="italic">Dr. <persName type="from">J. L. Dodds</persName>
                                    of the Presbyterian Board of Foreign Missions to the Chief of
                                    the Division of Near Eastern Affairs</hi> (<persName type="to"><hi rend="italic">Murray</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">New York</hi></placeName>, <date calendar="gregorian" when="1940-12-19T12:40:00-05:00">December 19, 1940—12:40 p.m.</date>
                                    <lb/> [Received 3:22 p.m.]</dateline>
                            </opener>
                            <p>First payment 100,000 received this morning from Iran.</p>
                            <closer>
                                <signed>J. L. <hi rend="smallcaps">Dodds</hi>
                                </signed>
                            </closer>
                            <postscript>
                                <p>[For statement on this subject released to the press January 9,
                                    1941, see Department of State <hi rend="italic">Bulletin</hi>,
                                    January 11, 1941, page 61.]</p>
                            </postscript>
                        </div>
                    </body></text></TEI>