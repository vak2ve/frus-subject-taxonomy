<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-12-26T21:00:00-05:00" frus:doc-dateTime-min="1940-12-26T21:00:00-05:00" n="367" subtype="historical-document" type="document" xml:id="d367">
                            <note rend="inline" type="source">740.0011 European War 1939/7304a:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in Egypt</hi> (<persName type="to"><hi rend="italic">Fish</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1940-12-26T21:00:00-05:00">December 26, 1940—9 p.m.</date>
                                </dateline>
                            </opener>
                            <p>162. Please report whether or not combat operations of any kind have
                                recently taken place on or over the Red Sea, the Gulf of Aden, and
                                the Straits of Bab el Mandeb.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>