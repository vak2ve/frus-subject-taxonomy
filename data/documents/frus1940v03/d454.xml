                <note rend="inline" type="source">740.0011 European War 1939/6621a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Greece</hi> (<persName type="to">
                        <hi rend="italic">MacVeagh</hi>
                    </persName>)<note n="47" xml:id="d454fn47">The same, <hi rend="italic">mutatis
                            mutandis</hi>, as telegram No. 536, November 7, 7 p.m., to the Chargé in
                        Italy.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-11-07T18:00:00-05:00"
                            >November 7, 1940—6 p.m.</date>
                    </dateline>
                </opener>
                <p>248. You are instructed to inquire of the Greek Government whether it considers a
                    state of war exists between Greece and Italy.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
