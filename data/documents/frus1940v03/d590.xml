<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-01-20T11:00:00-05:00" frus:doc-dateTime-min="1940-01-20T11:00:00-05:00" n="590" subtype="historical-document" type="document" xml:id="d590">
                            <note rend="inline" type="source">891.6363 Standard Oil/428:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in Iran</hi> (<persName type="to"><hi rend="italic">Engert</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1940-01-20T11:00:00-05:00">January 20, 1940—11 a.m.</date>
                                </dateline>
                            </opener>
                            <p>8. The substance of your 11, January 17, 11 a.m., has been
                                transmitted to the Standard Oil Company of New Jersey.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>