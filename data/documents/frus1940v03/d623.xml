<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-12-05T05:35:00-05:00" frus:doc-dateTime-min="1940-12-05T05:35:00-05:00" n="623" subtype="historical-document" type="document" xml:id="d623">
                            <note rend="inline" type="source">611.9131/136: Telegram</note>
                            <head>
                                <hi rend="italic">The Chargé in Iran</hi> (<persName type="from"><hi rend="italic">Engert</hi></persName>) <hi rend="italic">to
                                    the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Tehran</hi></placeName>, <date calendar="gregorian" when="1940-12-05T14:00:00+03:25">December 5, 1940—2 p.m.</date>
                                    <lb/> [Received December 6—1:05 a.m.]</dateline>
                            </opener>
                            <p>265. The Prime Minister asked me this morning whether I had any reply
                                to my telegram 257, November 25, 2 p.m.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Engert</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>