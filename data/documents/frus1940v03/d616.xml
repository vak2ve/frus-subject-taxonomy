<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-10-09T03:35:00-05:00" frus:doc-dateTime-min="1940-10-09T03:35:00-05:00" n="616" subtype="historical-document" type="document" xml:id="d616">
                            <note rend="inline" type="source">611.9131/123: Telegram</note>
                            <head>
                                <hi rend="italic">The Chargé in Iran</hi> (<persName type="from"><hi rend="italic">Engert</hi></persName>) <hi rend="italic">to
                                    the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Tehran</hi></placeName>, <date calendar="gregorian" when="1940-10-09T12:00:00+03:25">October 9, 1940—noon</date>.<lb/>[Received 12:05
                                    p.m.]</dateline>
                            </opener>
                            <p>221. I should like if possible to communicate to the Prime Minister
                                some sort of reply with regard to the matter referred to in my 194,
                                August 26, 10 a.m.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Engert</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>