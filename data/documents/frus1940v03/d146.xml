                subtype="historical-document" type="document" xml:id="d146">
                <note rend="inline" type="source">345.1121 Benz, Heinrich/18: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Calcutta</hi> (<persName type="from">
                        <hi rend="italic">Groth</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Calcutta</hi>
                        </placeName>, <date calendar="gregorian" when="1941-02-10T09:00:00+05:53"
                            >February 10, 1941—9 a.m.</date>
                        <lb/> [Received 7:04 p.m.]</dateline>
                </opener>
                <p>Reference Department’s telegram of October 4, 8 p.m. Heinrich Benz departed
                    Calcutta as member of crew of SS <hi rend="italic">Explorer</hi> due at New York
                    about March 12.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Groth</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
