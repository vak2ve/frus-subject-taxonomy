                subtype="historical-document" type="document" xml:id="d585">
                <note rend="inline" type="source">891.6363 Standard Oil Co./422: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Iran</hi> (<persName type="from">
                        <hi rend="italic">Engert</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tehran</hi>
                        </placeName>, <date calendar="gregorian" when="1939-12-21T19:00:00+03:25"
                            >December 21, 1939—7 p.m.</date>
                        <lb/> [Received December 21—2:05 p.m.]</dateline>
                </opener>
                <p>170. Representative of Standard Oil Company of New Jersey, Lawrence Anderson,
                    arrived today to seek an important oil concession. He believes his company
                    advised the Department of the purpose of his coming.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Engert</hi>
                    </signed>
                </closer>
            </div>
        </body>
