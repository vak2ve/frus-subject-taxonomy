                <note rend="inline" type="source">701.8365/8: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Egypt</hi> (<persName type="to">
                        <hi rend="italic">Hare</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-06-14">June 14,
                            1940</date>.</dateline>
                </opener>
                <p>53. Your 103, 13th, noon, has been “repeated to Embassy Rome for such action as
                    may be possible in the circumstances.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
