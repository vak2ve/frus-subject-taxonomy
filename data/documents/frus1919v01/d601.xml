<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-07-07T15:00:00-05:00" frus:doc-dateTime-min="1919-07-07T15:00:00-05:00" n="601" subtype="historical-document" type="document" xml:id="d601">
                            <note rend="inline" type="source">893.811/330: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Minister in China</hi> (<persName type="to"><hi rend="italic">Reinsch</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-07-07T16:00:00-04:00"><hi rend="italic">July 7,
                                            1919, 4 p.m.</hi></date></dateline></opener>
                            <p>Following from American International Corporation: <quote rend="blockquote">
                                    <p>“Chinese Chargé having been authorized sign agreement second
                                        advance canal survey as it stands Corporation will conclude
                                        immediately. Inform Gatrell.”</p>
                                </quote></p>
                            <closer><signed><hi rend="smallcaps">Phillips</hi></signed></closer>
                        </div>
                        </body></text></TEI>