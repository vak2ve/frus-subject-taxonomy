<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-08-11T09:36:00-05:00" frus:doc-dateTime-min="1919-08-11T09:36:00-05:00" n="863" subtype="historical-document" type="document" xml:id="d863">
                            <note rend="inline" type="source">818.00/820: Telegram</note>
                            <head><hi rend="italic">The Consul at San José</hi> (<persName type="from"><hi rend="italic">Chase</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">San
                                            José</hi></placeName>, <date calendar="gregorian" when="1919-08-11T09:00:00-05:36"><hi rend="italic">August
                                            11, 1919, 9 a.m.</hi></date><lb/>[<hi rend="italic">Received August 12, 4 p.m.</hi>]</dateline></opener>
                            <p>Your August 9, 3 p.m. Joaquin Tinoco was assassinated last night.
                                Funeral takes place this morning.</p>
                            <closer><signed><hi rend="smallcaps">Chase</hi></signed></closer>
                        </div>
                        </body></text></TEI>