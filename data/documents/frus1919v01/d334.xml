<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-05-13T23:59:59-05:00" frus:doc-dateTime-min="1919-05-13T00:00:00-05:00" n="334" subtype="historical-document" type="document" xml:id="d334">
                            <note rend="inline" type="source">893.00/3099: Telegram</note>
                            <head><hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from"><hi rend="italic">Sammons</hi></persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                                        State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Shanghai</hi></placeName>, <date calendar="gregorian" when="1919-05-13"><hi rend="italic">May 13,
                                        1919</hi></date>.<lb/>[<hi rend="italic">Received May 14,
                                        8.12 a.m.</hi>]</dateline></opener>
                            <p>Internal Peace Conference disagrees; all resign.</p>
                            <closer><signed><hi rend="smallcaps">Sammons</hi></signed></closer>
                        </div>
