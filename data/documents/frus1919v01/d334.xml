                <note rend="inline" type="source">893.00/3099: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from">
                        <hi rend="italic">Sammons</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1919-05-13">
                            <hi rend="italic">May 13, 1919</hi>
                        </date>.<lb/>[<hi rend="italic">Received May 14, 8.12 a.m.</hi>]</dateline>
                </opener>
                <p>Internal Peace Conference disagrees; all resign.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sammons</hi>
                    </signed>
                </closer>
            </div>
        </body>
