<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-01-20T16:00:00-05:00" frus:doc-dateTime-min="1919-01-20T16:00:00-05:00" n="788" subtype="historical-document" type="document" xml:id="d788">
                            <note rend="inline" type="source">818.00/533: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Consul at San José</hi> (<persName type="to"><hi rend="italic">Chase</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-01-20T16:00:00-05:00"><hi rend="italic">January
                                            20, 1919, 4 p.m.</hi></date></dateline></opener>
                            <p>Your January 15, 9 p.m.</p>
                            <p>Keep Department closely informed concerning situation.</p>
                            <closer><signed><hi rend="smallcaps">Polk</hi></signed></closer>
                        </div>
