                subtype="historical-document" type="document" xml:id="d411">
                <note rend="inline" type="source">893.51/2315: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Davis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1919-07-18T19:00:00+01:00">
                            <hi rend="italic">July 18, 1919, 7 p.m.</hi>
                        </date>
                        <lb/>[<hi rend="italic">Received July 18, 5.56 p.m.</hi>]</dateline>
                </opener>
                <p>2578. Your 5644, July 11, 5 p.m.<note n="40" xml:id="d411fn40">Not
                        printed.</note> Foreign Office regards the claim of Japanese group to
                    exclude Manchuria and Mongolia from sphere of activities of consortium as
                    totally inadmissible.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
