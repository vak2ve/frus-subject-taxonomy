                subtype="historical-document" type="document" xml:id="d42">
                <note rend="inline" type="source">763.72119/8594: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName type="to">
                        <hi rend="italic">Wallace</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-01-09T10:00:00-05:00">
                            <hi rend="italic">January 9, 1920, 10 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>61. Mission. Your 57 of January 7. The Department does not object to your
                    attending unofficially and as an observer, meetings of Committee of Ambassadors,
                    provided your colleagues should request or offer no objection to your attending
                    the meetings in such capacity.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
