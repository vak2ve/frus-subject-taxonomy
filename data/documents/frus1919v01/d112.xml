    <text>
        <body>
            <div frus:doc-dateTime-max="1918-02-08T18:36:00-05:00"
                frus:doc-dateTime-min="1918-02-08T18:36:00-05:00" n="112"
                subtype="historical-document" type="document" xml:id="d112">
                <note rend="inline" type="source">714.1515/78: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Guatemala</hi> (<persName type="from">
                        <hi rend="italic">Leavell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guatemala</hi>
                        </placeName>, <date calendar="gregorian" when="1918-02-08T17:00:00-06:36">
                            <hi rend="italic">February 8, 1918, 5 p.m.</hi>
                        </date>
                        <lb/>[<hi rend="italic">Received February 9, 11 a.m.</hi>]</dateline>
                </opener>
                <p>Your January 29, 8 p.m. Foreign Office today announces that Guatemala accepts
                    with pleasure the invitation to send this special plenipotentiary to
                    [Washington]. His name and date of departure will be announced shortly.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Leavell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
