<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-08-29T13:00:00-05:00" frus:doc-dateTime-min="1919-08-29T13:00:00-05:00" n="741" subtype="historical-document" type="document" xml:id="d741">
                            <note rend="inline" type="source">711.21/482: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Minister in Colombia</hi> (<persName type="to"><hi rend="italic">Philip</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-08-29T14:00:00-04:00"><hi rend="italic">August
                                            29, 1919, 2 p.m.</hi></date></dateline></opener>
                            <p>Please take no action on Departments Aug. 28, 6 P.M. until further
                                advised.</p>
                            <closer><signed><hi rend="smallcaps">Lansing</hi></signed></closer>
                        </div>
                        </body></text></TEI>