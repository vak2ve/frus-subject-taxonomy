                subtype="historical-document" type="document" xml:id="d96">
                <note rend="inline" type="source">714.1515/56: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Guatemala</hi> (<persName type="to">
                        <hi rend="italic">Thurston</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-01-09T19:00:00-05:00">
                            <hi rend="italic">January 9, 1918, 7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your January 7, 10 a.m.</p>
                <p>Department is desirous of having both Governments conclude a boundary treaty.
                    Continue to urge desirability of this step upon Guatemalan Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
