<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-09-05T17:00:00-05:00" frus:doc-dateTime-min="1919-09-05T17:00:00-05:00" n="72" subtype="historical-document" type="document" xml:id="d72">
                            <note rend="inline" type="source">711.5221/24: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Ambassador in Spain</hi> (<persName type="to"><hi rend="italic">Willard</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-09-05T18:00:00-04:00"><hi rend="italic">September
                                            5, 1919, 6 p.m.</hi></date></dateline></opener>
                            <p>2255. Telegraph whether reply received to representations made
                                pursuant Department’s 2199, June 13, 5 p.m. If not, request
                                reply.</p>
                            <closer><signed><hi rend="smallcaps">Phillips</hi></signed></closer>
                        </div>
                        </body></text></TEI>