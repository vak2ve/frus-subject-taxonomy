                subtype="historical-document" type="document" xml:id="d236">
                <note rend="inline" type="source">835.73/112: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Argentina</hi> (<persName type="from">
                        <hi rend="italic">Stimson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of State ad
                            interim</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1920-02-21T11:00:00-04:16">
                            <hi rend="italic">February 21, 1920, 11 a.m.</hi>
                        </date>
                        <lb/>[<hi rend="italic">Received February 22, 7.15 p.m.</hi>]</dateline>
                </opener>
                <p>48. My December 19th, 10 a.m.<note n="10" xml:id="d236fn10">Not printed.</note>
                    Official notice is given that the Central and South American Telegraph Company
                    has been authorized to establish two additional cables between Buenos Aires and
                    Montevideo, under the decree of August 1, 1918.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
