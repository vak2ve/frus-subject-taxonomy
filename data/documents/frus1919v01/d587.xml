                subtype="historical-document" type="document" xml:id="d587">
                <note rend="inline" type="source">861.77/1019: Telegram</note>
                <head>
                    <hi rend="italic">The President of the Technical Board</hi> (<persName
                        type="from">
                        <hi rend="italic">Stevens</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Harbin</hi>
                        </placeName>, <date calendar="gregorian" when="1919-08-15T16:00:00+08:26">
                            <hi rend="italic">August 15, 1919, 4 p.m.</hi>
                        </date>
                        <lb/>[<hi rend="italic">Received August 15, 12 noon.</hi>]</dateline>
                </opener>
                <p>Chinese Government yesterday deposited $500,000 gold Harbin my credit for use of
                    Board.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stevens</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
