                subtype="historical-document" type="document" xml:id="d908">
                <note rend="inline" type="source">818.6363Am6/3: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Costa Rica</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San José</hi>
                        </placeName>, <date calendar="gregorian" when="1918-06-26T11:00:00-05:36">
                            <hi rend="italic">June 26, 1918, 11 a.m.</hi>
                        </date>
                        <lb/>[<hi rend="italic">Received June 27, 9.57 a.m.</hi>]</dateline>
                </opener>
                <p>Amory oil concession passed Congress and approved by Executive yesterday
                    published today, copy by mail.<note n="43" xml:id="d908fn43">Not printed.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
