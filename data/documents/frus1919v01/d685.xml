                <note rend="inline" type="source">793.94/770: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Japan</hi> (<persName type="to">
                        <hi rend="italic">MacMurray</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-03-11T16:00:00-05:00">
                            <hi rend="italic">March 11, 1919, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your March 5, 5 p.m.</p>
                <p>You may at your discretion categorically deny the reports in so far as the acts
                    and purposes of this Government are concerned.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Polk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
