                <note rend="inline" type="source">125.83381/23: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Nicaragua</hi> (<persName type="to">
                        <hi rend="italic">Jefferson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-06-04T13:00:00-04:00">
                            <hi rend="italic">June 4, 1919, 1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your urgent June 2, 4 p.m. requesting ship does not give reasons for request.
                    Keep Department fully posted.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Polk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
