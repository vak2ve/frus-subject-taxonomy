<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-05-17T23:59:59-05:00" frus:doc-dateTime-min="1918-05-17T00:00:00-05:00" n="598" subtype="historical-document" type="document" xml:id="d598">
                            <note rend="inline" type="source">893.811/301</note>
                            <head><hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">Reinsch</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1918-05-17"><hi rend="italic">May 17,
                                        1918</hi>.</date><lb/>[<hi rend="italic">Received June
                                        11.</hi>]</dateline>
                                <seg rendition="#left">No. 2051</seg></opener>
                            <p><hi rend="smallcaps">Sir</hi>: Confirming my telegram to you of May
                                17, 11 A.M.,<note n="48" xml:id="d598fn48">Not printed.</note> I
                                have the honor to enclose herewith the treasury note of the Chinese
                                Government for G. $250,000.00.</p>
                            <p>This is in conformity with the instructions contained in your
                                telegram of May 2nd, 3 P.M.</p>
                            <p>I have [etc.]</p>
                            <closer><signed><hi rend="smallcaps">Paul S.
                                Reinsch</hi></signed></closer>
                        </div>
                        </body></text></TEI>