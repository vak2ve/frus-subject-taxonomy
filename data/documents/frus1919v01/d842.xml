<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-06-20T15:00:00-05:00" frus:doc-dateTime-min="1919-06-20T15:00:00-05:00" n="842" subtype="historical-document" type="document" xml:id="d842">
                            <note rend="inline" type="source">818.00/702: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Consul at San José</hi> (<persName type="to"><hi rend="italic">Chase</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-06-20T16:00:00-04:00"><hi rend="italic">June 20,
                                            1919, 4 p.m.</hi></date></dateline></opener>
                            <p>Your June 19, 9 a.m.</p>
                            <p>You are instructed not to interest yourself in any way in matter at
                                this time.</p>
                            <closer><signed><hi rend="smallcaps">Polk</hi></signed></closer>
                        </div>
                        </body></text></TEI>