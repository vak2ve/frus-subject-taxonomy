                subtype="historical-document" type="document" xml:id="d30">
                <note rend="inline" type="source">763.72119P43/856: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Commission to Negotiate Peace</gloss>
                        to the <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1919-12-05T12:00:00+00:00">
                            <hi rend="italic">December 5, 1919, noon.</hi>
                        </date>
                        <lb/>[<hi rend="italic">Received 6 p.m.</hi>]</dateline>
                </opener>
                <p>5557. For the Secretary of State from Polk:</p>
                <p>Your 3942 [<hi rend="italic">3941</hi>], December 2, 4 p.m. Arrangements have
                    been made with General Connor for holding the <hi rend="italic">America</hi>.
                    Mission will leave Paris in accordance with your instructions on the evening of
                    the 9th and we hope to sail from Brest on the 10th. Polk.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">American Mission</hi>
                    </signed>
                </closer>
            </div>
        </body>
