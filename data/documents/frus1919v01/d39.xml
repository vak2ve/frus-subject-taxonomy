<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-12-30T15:00:00-05:00" frus:doc-dateTime-min="1919-12-30T15:00:00-05:00" n="39" subtype="historical-document" type="document" xml:id="d39">
                            <note rend="inline" type="source">763.72119/8486: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in France</hi> (<persName type="to"><hi rend="italic">Wallace</hi></persName>)</head>
                            <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-12-30T15:00:00-05:00"><hi rend="italic">December
                                            30, 1919, 3 p.m.</hi></date></dateline></opener>
                            <p>9463. Reference your 1933 of December 27, 8 p.m. Supreme Council
                                should be requested to delay all actions, resolutions, or decisions
                                which concern this Government until Department sends you
                                instructions for each matter involved.</p>
                            <closer><signed><hi rend="smallcaps">Lansing</hi></signed></closer>
                        </div>
                        </body></text></TEI>