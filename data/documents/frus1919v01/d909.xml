                subtype="historical-document" type="document" xml:id="d909">
                <note rend="inline" type="source">818.6363Am6/2: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Costa Rica</hi> (<persName type="to">
                        <hi rend="italic">Johnson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-07-01T14:00:00-04:00">
                            <hi rend="italic">July 1, 1918, 2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your June 24, noon. Department considers it most important that only approved
                    Americans should possess oil concessions in the neighborhood of Panama Canal.
                    Amory concession does not appear to meet these requirements. Use best efforts to
                    carry into effect this policy.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
