<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-01-20T19:00:00-05:00" frus:doc-dateTime-min="1919-01-20T19:00:00-05:00" n="309" subtype="historical-document" type="document" xml:id="d309">
                            <note rend="inline" type="source">893.00/2931: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Minister in China</hi> (<persName type="to"><hi rend="italic">Reinsch</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-01-20T19:00:00-05:00"><hi rend="italic">January
                                            20, 1919, 7 p.m.</hi></date></dateline></opener>
                            <p>Your January 11, 3 p.m. and January 17, 1 p.m. Your action is
                                approved.</p>
                            <closer><signed><hi rend="smallcaps">Polk</hi></signed></closer>
                        </div>
