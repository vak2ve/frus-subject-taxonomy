<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-08-12T17:36:00-05:00" frus:doc-dateTime-min="1919-08-12T17:36:00-05:00" n="864" subtype="historical-document" type="document" xml:id="d864">
                            <note rend="inline" type="source">818.00/826: Telegram</note>
                            <head><hi rend="italic">The Vice Consul at Port Limon</hi> (<persName type="from"><hi rend="italic">Montgomery</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">San
                                            José</hi> [<hi rend="smallcaps">Port
                                        Limon</hi>]</placeName>, <date calendar="gregorian" when="1919-08-12T17:00:00-05:36"><hi rend="italic">August
                                            12, 1919, 5 p.m.</hi></date><lb/>[<hi rend="italic">Received August 16, 12.48 a.m.</hi>]</dateline></opener>
                            <p>Tinoco and party of 26 men, women and children sailed from here at
                                three this afternoon for Kingston on steamer <hi rend="italic">Zacapa.</hi></p>
                            <closer><signed><hi rend="smallcaps">Montgomery</hi></signed></closer>
                        </div>
                        </body></text></TEI>