                subtype="historical-document" type="document" xml:id="d400">
                <note rend="inline" type="source">893.51/2275: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in France</hi> (<persName type="to">
                        <hi rend="italic">Wallace</hi>
                    </persName>)<note n="28" xml:id="d400fn28">The same, June 26, to the Ambassador
                        in Great Britain with instructions to advise Lamont.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-06-26T13:00:00-04:00">
                            <hi rend="italic">June 26, 1919, 1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>2429. Your No. 891, June 21, 12 p.m.<note n="29" xml:id="d400fn29">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_453">p. 453</ref>.</note>
                </p>
                <p>For Marshall: American Group is willing to proceed as outlined. Department will
                    proceed as soon as we hear from the British provided their answer is
                    favorable.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Polk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
