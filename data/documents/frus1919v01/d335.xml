<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-05-14T16:00:00-05:00" frus:doc-dateTime-min="1919-05-14T16:00:00-05:00" n="335" subtype="historical-document" type="document" xml:id="d335">
                            <note rend="inline" type="source">893.00/3099: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Consul General at Shanghai</hi>
                                    (<persName type="to"><hi rend="italic">Sammons</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-05-14T17:00:00-04:00"><hi rend="italic">May 14,
                                            1919, 5 p.m.</hi></date></dateline></opener>
                            <p>Your May 13. Please give further details Peace Conference break,
                                reason for disagreement and its bearing upon situation.</p>
                            <closer><signed><hi rend="smallcaps">Polk</hi></signed></closer>
                        </div>
                        </body></text></TEI>