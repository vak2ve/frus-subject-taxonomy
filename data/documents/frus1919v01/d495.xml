                subtype="historical-document" type="document" xml:id="d495">
                <note rend="inline" type="source">893.51/2456: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in China</hi> (<persName type="to">
                        <hi rend="italic">Tenney</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-11-07T18:00:00-05:00">
                            <hi rend="italic">November 7, 1919, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>With reference to Department’s telegram of October 10, 2 p.m.,<note n="33"
                        xml:id="d495fn33">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_524">p. 524</ref>.</note>
                    please report by telegraph present status of Currency loan option and action
                    taken by Legation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
