<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-02-09T00:00:00-05:00" frus:doc-dateTime-min="1918-02-09T00:00:00-05:00" n="632" subtype="historical-document" type="document" xml:id="d632">
                            <note rend="inline" type="source">693.003/461: Telegram</note>
                            <head><hi rend="italic">The Chairman of the American Delegation</hi>
                                    (<persName type="from"><hi rend="italic">Arnold</hi></persName>)
                                    <hi rend="italic">to the <gloss type="to">Secretary of
                                        State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Shanghai</hi></placeName>, <date calendar="gregorian" when="1918-02-09T13:00:00+08:00"><hi rend="italic">February
                                            9, 1918, 1 p.m.</hi></date><lb/>[<hi rend="italic">Received February 9, 9.10 a.m.</hi>]</dateline></opener>
                            <p>Does Department sanction American delegation joining others in
                                agreement with China for temporary surcharge of from 30 to 50 per
                                cent on present question of valuations pending final adoption of
                                revised schedule?</p>
                            <closer><signed><hi rend="smallcaps">Arnold</hi></signed></closer>
                        </div>
                        </body></text></TEI>