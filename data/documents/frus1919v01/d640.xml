                subtype="historical-document" type="document" xml:id="d640">
                <note rend="inline" type="source">693.003/528: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Consul General at Shanghai</hi> (<persName type="to">
                        <hi rend="italic">Sammons</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-12-05T18:00:00-05:00">
                            <hi rend="italic">December 5, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>For Arnold. Your telegram December 4, 11 a.m. While the question of frontier
                    tariffs is important and an understanding as to proportionate increase desirable
                    the Department understands that it is incidental to the main question under
                    discussion and not a condition precedent to our agreement.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Polk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
