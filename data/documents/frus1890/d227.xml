    <text>
        <body>
            <div frus:doc-dateTime-max="1889-12-30T23:59:59-05:00" frus:doc-dateTime-min="1889-12-30T00:00:00-05:00" n="227" subtype="historical-document" type="document" xml:id="d227">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr.
                                <persName type="to">White</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1889-12-30">
                            <hi rend="italic">December</hi> 30,
                            1889</date>.</dateline>
                </opener>
                <p>Authorizes Mr. White to confer with Lord Salisbury concerning the
                        reëstablishment of diplomatic relations between Great Britain and Venezuela
                        upon the basis suggested by the Venezuelan minister, of temporary
                        restoration of <hi rend="italic">status quo</hi>.</p>
            </div>
        </body>
