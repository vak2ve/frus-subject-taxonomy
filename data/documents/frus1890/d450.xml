    <text>
        <body>
            <div frus:doc-dateTime-max="1890-08-21T23:59:59-05:00" frus:doc-dateTime-min="1890-08-21T00:00:00-05:00" n="450" subtype="historical-document" type="document" xml:id="d450">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Wharton</persName> to Mr.
                                    <persName type="to">Grip</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1890-08-21">
                            <hi rend="italic">August</hi> 21,
                                1890</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inclose for your
                            information copy of the order<note n="*" xml:id="d450fn1">For inclosure
                                see inclosure to instructions No. 50, dated August 26, 1890, to
                                United States minister to Sweden and Norway.</note> issued by the
                            Acting Secretary of the Navy on the 18th instant, in reference to the
                            salute to the flag of Sweden to be fired on the occasion of the
                            embarkation of the remains of Captain Ericsson.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William F. Wharton</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
