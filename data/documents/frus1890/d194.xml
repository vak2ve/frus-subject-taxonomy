    <text>
        <body>
            <div frus:doc-dateTime-max="1890-05-07T23:59:59-05:00" frus:doc-dateTime-min="1890-05-07T00:00:00-05:00" n="194" subtype="historical-document" type="document" xml:id="d194">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr.
                                    <persName type="to">Hurtado</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1890-05-07">
                            <hi rend="italic">May</hi> 7,
                                1890</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to recall to your
                            attention my note of January 31 last, relating to the claim of the
                            Panama Star and Herald against the Government of Colombia.</p>
                <p>This Government earnestly desires to reach a settlement of the case, and
                            hopes it may soon receive a proposition which will lead to its
                            adjustment.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">James G. Blaine.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
