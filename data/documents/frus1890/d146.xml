                subtype="historical-document" type="document" xml:id="d146">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Wharton</persName> to Mr. <persName
                            type="to">Denby</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1890-09-25">
                            <hi rend="italic">September</hi> 25, 1890</date>.</dateline>
                    <seg rendition="#left">No. 556.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have read your No. 1140 of the 4th ultimo, and
                    approve the terms of your note of that date to the foreign office, in which you
                    express a hope that the Chinese Government will see its way clear to permit
                    foreign scientific officers to continue and complete the hydrography of the
                    ports of China.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William F. Wharton</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
