<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1946-01-17T23:59:59-05:00" frus:doc-dateTime-min="1946-01-17T00:00:00-05:00" n="733" subtype="historical-document" type="document" xml:id="d733">
