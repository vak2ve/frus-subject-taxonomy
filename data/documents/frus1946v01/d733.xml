                        <dateline rendition="#right">[<placeName><hi rend="smallcaps">Washington</hi></placeName>,] <date calendar="gregorian" when="1946-01-17">January 17, 1946</date>.</dateline>
                    </opener>
                    <p>In connection with <gloss target="#t_NAC1">NAC</gloss> Document No. 43,<note n="31" xml:id="d733fn31">
