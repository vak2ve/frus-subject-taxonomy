<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Ambassador in the United Kingdom (
                        Winant
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1946v01</bibl><bibl type="frus-document-id">d767</bibl><bibl type="frus-document-number">767</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1946-02-05T15:00:00-05:00" notAfter="1946-02-05T15:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1946-02-05T15:00:00-05:00" frus:doc-dateTime-min="1946-02-05T15:00:00-05:00" n="767" subtype="historical-document" type="document" xml:id="d767">
                <note rend="inline" type="source">841.796/2–546: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in the United Kingdom</hi> (<persName type="from">
                        <hi rend="italic">Winant</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                        <lb/>
                        <hi rend="smallcaps">us urgent</hi>
                        <lb/>
                        <gloss target="#t_Niact1">
                            <hi rend="smallcaps">niact</hi>
                        </gloss>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1946-02-05T20:00:00+00:00">February 5, 1946—8 p.m.</date>
                        <lb/>[Received February 5—5:29 p.m.]</dateline>
                </opener>
                <p>1417. Re my 1392, Feb. 5.<note n="40" xml:id="d767fn40">Not printed.</note> The
                    differences between compromise arrived at in Bermuda and the position taken by
                    the British Cabinet have been cabled to the British Embassy in Washington for
                    transmission to Under Secretary Acheson and Assistant Secretary Clayton.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Winant</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
