    <text>
        <body>
            <div frus:doc-dateTime-max="1900-09-01T23:59:59-05:00"
                frus:doc-dateTime-min="1900-09-01T00:00:00-05:00" n="9"
                subtype="historical-document" type="document" xml:id="d9">
                <head>No. 5527.—<hi rend="smallcaps">United States of America.</hi>
                </head>
                <p rend="center">
                    <hi rend="smallcaps">department of state.</hi>
                </p>
                <p rend="flushleft">
                    <hi rend="italic">To all to whom these presents shall come, greeting:</hi>
                </p>
                <p>I certify that the documents hereto annexed are true copies from the files of
                    this Department. In testimony whereof I, John Hay, Secretary of State for the
                    United States, have hereunto subscribed my name and caused the seal of the
                    Department of State to be affixed.</p>
                <closer>
                    <dateline rendition="#left">Done at the city of
                            <placeName>Washington</placeName>, <date
                            calendar="gregorian us-republic" when="1900-09-01">this 1st day of
                            September, A. D. 1900, and of the Independence of the United States of
                            America the one hundred and twenty-fifth</date>.</dateline>
                    <lb/>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                    <lb/>
                    <seg rendition="#left">[Seal of the Department of State of the United States of
                        America.]</seg>
                </closer>
                <postscript>
                    <p>(For certification of Exhibits F and G.)</p>
                </postscript>
            </div>
        </body>
    </text>
