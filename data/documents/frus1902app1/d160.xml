    <text>
        <body>
            <div frus:doc-dateTime-max="1901-08-05T23:59:59-05:00"
                frus:doc-dateTime-min="1901-08-05T00:00:00-05:00" n="160"
                subtype="historical-document" type="document" xml:id="d160">
                <head ana="#head_untitled-missing-head-in-printed-volume">[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Embassy of the United States of America</hi>,<hi
                                rend="italic">St. Petersburg</hi>.</placeName>
                    </dateline>
                </opener>
                <p>I, Herbert H. D. Peirce, secretary of the embassy of the United States of America
                    at St. Petersburg, agent and counsel for the United States, hereby certify that
                    the documents hereto annexed are true copies of the originals submitted to the
                    honorable arbitrator, Mr. T. M. C. Asser, the copy of the map hereto annexed
                    being a true copy of that part of a map published by the United States Coast
                    Survey showing the Commandorski Islands.</p>
                <closer>
                    <dateline rendition="#left">In witness whereof I have hereunto subscribed my
                        name and affixed the seal of the embassy of the United States at
                            <placeName>St. Petersburg</placeName>
                        <date calendar="gregorian" when="1901-08-05">this fifth day of August, in
                            the year one thousand nine hundred and one</date>.</dateline>
                    <lb/> (Signed) <signed>
                        <hi rend="smallcaps">Herbert H. D. Peirce.</hi>
                    </signed>
                    <lb/>
                    <seg rendition="#left">[Seal of the United States embassy at St.
                        Petersburg.]</seg>
                </closer>
            </div>
        </body>
    </text>
