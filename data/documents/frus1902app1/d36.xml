    <text>
        <body>
            <div frus:doc-dateTime-max="1892-09-30T23:59:59-05:00"
                frus:doc-dateTime-min="1892-09-30T00:00:00-05:00" n="36"
                subtype="historical-document" type="document" xml:id="d36">
                <head ana="#head_untitled-inferred-from-preceding-sibling-head">EXHIBIT V. <lb/>
                    <hi rend="smallcaps">Annex</hi> 8.</head>
                <p rend="center">Captain and owners <hi rend="italic">Cape Horn Pigeon</hi> in
                    account with the undersigned:</p>
                <p rend="center">
                    <hi rend="smallcaps">Dr</hi>.</p>
                <table cols="2" rows="7">
                    <row>
                        <cell/>
                        <cell>Roubles.</cell>
                    </row>
                    <row>
                        <cell>To bill cheap jack for expenses of officers and crew while on
                            shore</cell>
                        <cell role="num">388.88</cell>
                    </row>
                    <row>
                        <cell>To bill cheap jack for provisions</cell>
                        <cell role="num">108.27</cell>
                    </row>
                    <row>
                        <cell>To cash to captain</cell>
                        <cell role="num">520.00</cell>
                    </row>
                    <row>
                        <cell>To Ditto</cell>
                        <cell role="num">535.50</cell>
                    </row>
                    <row>
                        <cell>To telegrams</cell>
                        <cell rendition="#border-bottom" role="num">229.53</cell>
                    </row>
                    <row>
                        <cell/>
                        <cell role="num">1,482.18</cell>
                    </row>
                </table>
                <p>Roubles 1,482.18 at exchange 54 per cent = gold dollars 800.38.</p>
                <closer>
                    <dateline rendition="#left">
                        <placeName>
                            <hi rend="smallcaps">Vladivostock</hi>
                        </placeName>, <date calendar="gregorian" when="1892-09-30">
                            <hi rend="italic">September 30, 1892</hi>
                        </date>.</dateline> I certify that the above account is correct. <lb/>
                    <signed>
                        <hi rend="smallcaps">Thomas Scullun</hi>, <lb/>
                        <hi rend="italic">Master Cape Horn Pigeon.</hi>
                    </signed>
                </closer>
            </div>
        </body>
