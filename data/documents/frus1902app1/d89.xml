                        </date>.</dateline>
                </closer>
                <postscript>
                    <p>I hereby certify the above to be a true copy of the original on file in this
                        office.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">John T. Dare</hi>, <hi rend="italic">Deputy
