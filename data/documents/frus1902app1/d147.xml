<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1891-10-20T23:59:59-05:00" frus:doc-dateTime-min="1891-10-20T00:00:00-05:00" n="147" subtype="historical-document" type="document" xml:id="d147">
                                <head>EXHIBIT VII.</head>
                                <opener>
                                    <dateline rendition="#right">[<date ana="#date_undated-inferred-from-document-content-and-sibling-dates" calendar="gregorian" when="1891-10-20">October 20,
                                            1891</date>]</dateline>
                                </opener>
                                <p rend="center"><hi rend="smallcaps">Annex to the Report No</hi>.
                                    489.</p>
                                <list>
                                    <label>A.</label>
                                    <item>Point from which was sighted the schooner <hi rend="italic">James Hamilton Lewis.</hi></item>
                                    <label>B.</label>
                                    <item>Point at which the schooner <hi rend="italic">James
                                            Hamilton Lewis</hi> lay to and was overhauled by the <hi rend="italic">Aleout.</hi></item>
                                    <label>C.</label>
                                    <item>Supposed situation of the James <hi rend="italic">Hamilton
                                            Lewis</hi> when it was sighted by the schooner <hi rend="italic">Aleout.</hi></item>
                                </list>
                                <closer>(Signed) <signed>Captain of Frigate <hi rend="smallcaps">Brandt.</hi></signed></closer>
                                <postscript>
                                    <p>Certified conformedly.</p>
                                    <p><hi rend="smallcaps">J. Stebline-Kamensky</hi>,<lb/><hi rend="italic">Deputy of Jurisconsulate of Minister of
                                            Marine.</hi></p>
                                </postscript>
                            </div>
