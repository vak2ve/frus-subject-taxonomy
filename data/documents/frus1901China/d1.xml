                <head>[Untitled]</head>
                <p rend="flushleft">
                    <hi rend="italic">To the Senate and House of Representatives:</hi>
                </p>
                <p>I transmit a report from the Hon. William W. Rockhill, late commissioner to
                    China, of the results of his mission to that country, with accompanying
                    documents.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt.</hi>
                    </signed>
                    <lb/>
                    <dateline rendition="#left">
                        <hi rend="smallcaps">White House</hi>,<lb/>
                        <placeName>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-12-11">
                            <hi rend="italic">December 11, 1901</hi>
                        </date>.</dateline>
                </closer>
            </div>
        </body>
    </text>
