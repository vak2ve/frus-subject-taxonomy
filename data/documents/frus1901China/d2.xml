                subtype="historical-document" type="document" xml:id="d2">
                <head>[Untitled]</head>
                <p rend="flushleft">The <hi rend="smallcaps">President</hi>:</p>
                <p>I have the honor to submit to you, with a view of transmittal to the Congress, if
                    it meet your approval, a report from the Hon. William W. Rockhill, late
                    commissioner to China, of the results of his mission to that country, with
                    accompanying documents.</p>
                <p>Respectfully submitted.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                    <lb/>
                    <dateline rendition="#left">
                        <hi rend="smallcaps">Department of State</hi>,<lb/>
                        <placeName>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-12-05">
                            <hi rend="italic">December 5, 1901</hi>
                        </date>.</dateline>
                </closer>
            </div>
        </body>
    </text>
