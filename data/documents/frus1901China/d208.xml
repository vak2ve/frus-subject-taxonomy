<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1900-12-05T23:59:59-05:00" frus:doc-dateTime-min="1900-12-05T00:00:00-05:00" n="208" subtype="historical-document" type="document" xml:id="d208">
                    <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                <persName type="to">Conger</persName>.</hi></head>
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1900-12-05"><hi rend="italic">December 5,
                            1900</hi></date>.</dateline></opener>
                    <p>Sign joint note as transmitted. President sends cordial congratulations.</p>
                    <closer><signed><hi rend="smallcaps">Hay.</hi></signed></closer>
                </div>
