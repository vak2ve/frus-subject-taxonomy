                subtype="historical-document" type="document" xml:id="d278">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Rockhill</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1901-06-08">
                            <hi rend="italic">June 8, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Rockhill reports that he has made formal proposal to refer the whole
                    question of indemnity to the tribunal of arbitration at The Hague, by reason of
                    the indefinite delay in coming to an agreement.)</p>
            </div>
        </body>
