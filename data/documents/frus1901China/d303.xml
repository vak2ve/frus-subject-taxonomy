                <head>
                    <hi rend="italic">Mr. <persName type="from">Rockhill</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1901-08-12">
                            <hi rend="italic">August 12, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Rockhill reports formal agreement upon draft of final protocol.</p>
                <p>Rice, foreign cereals and flour, gold and silver bullion and coin are included in
                    the free list.)</p>
            </div>
