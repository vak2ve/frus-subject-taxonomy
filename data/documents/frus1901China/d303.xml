<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1901-08-12T23:59:59-05:00" frus:doc-dateTime-min="1901-08-12T00:00:00-05:00" n="303" subtype="historical-document" type="document" xml:id="d303">
                    <head><hi rend="italic">Mr. <persName type="from">Rockhill</persName> to Mr.
                                <persName type="to">Hay</persName>.</hi></head>
                    <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1901-08-12"><hi rend="italic">August 12,
                            1901</hi></date>.</dateline></opener>
                    <p>(Mr. Rockhill reports formal agreement upon draft of final protocol.</p>
                    <p>Rice, foreign cereals and flour, gold and silver bullion and coin are
                        included in the free list.)</p>
                </div>
