                subtype="historical-document" type="document" xml:id="d309">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Rockhill</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1901-09-03">
                            <hi rend="italic">September 3, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Rockhill reports that Imperial command to sign the protocol was received on
                    the 28th ultimo by the Chinese plenipotentiaries. * * *</p>
                <p>Chinese say that they are waiting for edicts on punishments and
                    examinations.)</p>
            </div>
        </body>
