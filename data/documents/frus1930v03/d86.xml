                subtype="historical-document" type="document" xml:id="d86">
                <note rend="inline" type="source">211.62/67: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName type="from">
                        <hi rend="italic">Schurman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1929-05-16T15:00:00+01:00"
                            >May 16, 1929—3 p.m.</date>
                        <lb/>[Received May 16—12:30 p.m.]</dateline>
                </opener>
                <p>89. Department’s 33, May 14, 6 p.m. German Government agrees to last of June.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schurman</hi>
                    </signed>
                </closer>
            </div>
        </body>
