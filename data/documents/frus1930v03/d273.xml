<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-06-09T16:00:00-05:00" frus:doc-dateTime-min="1930-06-09T16:00:00-05:00" n="273" subtype="historical-document" type="document" xml:id="d273">
                        <note rend="inline" type="source">882.00/826: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in Liberia</hi> (<persName type="to"><hi rend="italic">Carter</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1930-06-09T17:00:00-04:00">June 9, 1930—5
                                p.m.</date></dateline></opener>
                        <p>58. National City Bank requests full text of Liberian Department of State
                            Communication Number 286 D of June 4. Please cable for possible
                            transmission.</p>
                        <closer><signed><hi rend="smallcaps">Stimson</hi></signed></closer>
                    </div>
                    </body></text></TEI>