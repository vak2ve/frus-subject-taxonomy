<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-09-10T20:00:00-05:00" frus:doc-dateTime-min="1930-09-10T20:00:00-05:00" n="688" subtype="historical-document" type="document" xml:id="d688">
                        <note rend="inline" type="source">823.01/11: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Peru</hi> (<persName type="from"><hi rend="italic">Dearing</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Lima</hi></placeName>, <date calendar="gregorian" when="1930-09-10T20:00:00-05:00">September 10, 1930—8
                                    p.m.</date><lb/>[Received 10:30 p.m.]</dateline></opener>
                        <p>201. Informed by Papal Nuncio that Chile has accorded recognition to
                            Peruvian Government today. Expect make recommendations regarding our
                            attitude next 2 days.</p>
                        <closer><signed><hi rend="smallcaps">Dearing</hi></signed></closer>
                    </div>
                    </body></text></TEI>