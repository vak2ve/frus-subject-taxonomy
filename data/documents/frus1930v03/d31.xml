<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-07-29T07:00:00-05:00" frus:doc-dateTime-min="1930-07-29T07:00:00-05:00" n="31" subtype="historical-document" type="document" xml:id="d31">
                        <note rend="inline" type="source">195.4/208: Telegram</note>
                        <head><hi rend="italic">The Ambassador in France</hi> (<persName type="from"><hi rend="italic">Edge</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1930-07-29T13:00:00+01:00">July 29, 1930—1
                                p.m.</date><lb/>[Received July 29—9:35 a.m.]</dateline></opener>
                        <p>230. Department’s 148, July 2, 5 p.m. Informal assurances received that
                            the <hi rend="italic">President Fillmore</hi> will not be subjected to
                            the requirement in question.</p>
                        <closer><signed><hi rend="smallcaps">Edge</hi></signed></closer>
                    </div>
                    </body></text></TEI>