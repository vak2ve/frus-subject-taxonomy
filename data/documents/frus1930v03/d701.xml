                <note rend="inline" type="source">823.01/56</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Peru</hi> (<persName type="to">
                        <hi rend="italic">Dearing</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1930-09-17">September 17,
                            1930</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Dearing</hi>: Your telegram No. 207 of
                    September thirteenth has been of real assistance to me in the last few days.</p>
                <p>Sincerely yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Henry L. Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
