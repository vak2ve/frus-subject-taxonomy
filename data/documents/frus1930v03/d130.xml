                subtype="historical-document" type="document" xml:id="d130">
                <note rend="inline" type="source">814.00 Revolutions/57: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Guatemala</hi> (<persName type="from">
                        <hi rend="italic">McCafferty</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guatemala</hi>
                        </placeName>, <date calendar="gregorian" when="1930-12-16T17:00:00-07:00"
                            >December 16, 1930—5 p.m.</date>
                        <lb/>[Received 8:44 p.m.]</dateline>
                </opener>
                <p>104. A revolution apparently started at 4 p.m. today. There is firing in various
                    parts of the city. I have not yet been able to obtain any information, but I
                    believe it is a revolt of the Army against the Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">McCafferty</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
