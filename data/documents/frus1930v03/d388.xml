                subtype="historical-document" type="document" xml:id="d388">
                <note rend="inline" type="source">882.01/13: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Liberia</hi> (<persName type="to">
                        <hi rend="italic">Reber</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1930-12-20T14:00:00-05:00"
                            >December 20, 1930—2 p.m.</date>
                    </dateline>
                </opener>
                <p>118. Your 178, December 19, 8 a.m. It is felt that the Department should not be
                    called upon officially to pass upon communications between the Liberian
                    Government and the Finance Corporation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
