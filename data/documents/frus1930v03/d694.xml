                subtype="historical-document" type="document" xml:id="d694">
                <note rend="inline" type="source">823.01/21: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Peru</hi> (<persName type="from">
                        <hi rend="italic">Dearing</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1930-09-16T10:00:00-05:00"
                            >September 16, 1930—10 a.m.</date>
                        <lb/>[Received 6:17 p.m.]</dateline>
                </opener>
                <p>213. China and Austria have recognized the junta as the government of Peru.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dearing</hi>
                    </signed>
                </closer>
            </div>
        </body>
