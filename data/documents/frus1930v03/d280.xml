<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-07-02T15:00:00-05:00" frus:doc-dateTime-min="1930-07-02T15:00:00-05:00" n="280" subtype="historical-document" type="document" xml:id="d280">
                        <note rend="inline" type="source">882.00/833: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in Liberia</hi> (<persName type="to"><hi rend="italic">Hall</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1930-07-02T16:00:00-04:00">July 2, 1930—4
                                p.m.</date></dateline></opener>
                        <p>65. Your 91, July 1, 4 p.m. In your discretion you may consent to
                            publication of your note declaring documents submitted to you
                            forgeries.</p>
                        <closer><signed><hi rend="smallcaps">Stimson</hi></signed></closer>
                    </div>
                    </body></text></TEI>