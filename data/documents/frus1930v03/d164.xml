<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-03-08T23:59:59-05:00" frus:doc-dateTime-min="1930-03-08T00:00:00-05:00" n="164" subtype="historical-document" type="document" xml:id="d164">
                        <note rend="inline" type="source">838.00 Commission of Investigation/132:
                            Telegram</note>
                        <head><hi rend="italic">President <persName type="from">Hoover</persName> to
                                the Chairman of the President’s Commission</hi> (<persName type="to"><hi rend="italic">Forbes</hi></persName>)</head>
                        <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                        <opener><dateline rendition="#right">[<placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1930-03-08">March 8, 1930</date>.</dateline></opener>
                        <p>I concur entirely in the recommendation set forth in your telegram No. 1
                            of March 7.</p>
                        <closer><signed><hi rend="smallcaps">Herbert Hoover</hi></signed></closer>
                    </div>
                    </body></text></TEI>