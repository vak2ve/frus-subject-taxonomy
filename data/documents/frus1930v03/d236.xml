                <note rend="inline" type="source">890g.01/206: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName type="to">
                        <hi rend="italic">Dawes</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1929-06-21T16:00:00-04:00"
                            >June 21, 1929—4 p.m.</date>
                    </dateline>
                </opener>
                <p>151. Your mail despatch No. 3388, February 20, 1929. Please telegraph briefly
                    present status of tripartite treaty negotiations.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
