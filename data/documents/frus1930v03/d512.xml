                subtype="historical-document" type="document" xml:id="d512">
                <note rend="inline" type="source">702.1211 Laredo/54: Telegram</note>
                <head>
                    <hi rend="italic">The Governor of Texas</hi> (<persName type="from">
                        <hi rend="italic">Moody</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Austin</hi>
                        </placeName>, <date calendar="gregorian" when="1930-01-16">January 16,
                            1930</date>.<lb/>[Received 1:55 p.m.]</dateline>
                </opener>
                <p>Your wire. Consul General at San Antonio has issued statement that Consulate at
                    Laredo will be opened Friday. I want to express appreciation which I feel and
                    which the citizens of Laredo feel for your efficient assistance in this
                    matter.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dan Moody</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
