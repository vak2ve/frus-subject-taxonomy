    <text>
        <body>
            <div frus:doc-dateTime-max="1930-09-12T23:59:59-05:00"
                frus:doc-dateTime-min="1930-09-12T00:00:00-05:00" n="691"
                subtype="historical-document" type="document" xml:id="d691">
                <note rend="inline" type="source">823.01/25</note>
                <head>
                    <hi rend="italic">The Minister in Guatemala</hi> (<persName type="from">
                        <hi rend="italic">Whitehouse</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guatemala</hi>
                        </placeName>, <date calendar="gregorian" when="1930-09-12">September 12,
                            1930</date>.<lb/>[Received September 16.]</dateline>
                    <seg rendition="#left">No. 159</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to report that the Minister for
                    Foreign Affairs has asked me to let him know as soon as any decision is taken by
                    our Government in regard to the recognition of the new Peruvian Government as he
                    intends to postpone his decision until after ours.</p>
                <p>Respectfully yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sheldon Whitehouse</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
