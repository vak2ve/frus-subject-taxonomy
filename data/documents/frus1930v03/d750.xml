<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-08-04T18:16:00-05:00" frus:doc-dateTime-min="1930-08-04T18:16:00-05:00" n="750" subtype="historical-document" type="document" xml:id="d750">
                        <note rend="inline" type="source">611.7131/108: Telegram</note>
                        <head><hi rend="italic">The Minister in Rumania</hi> (<persName type="from"><hi rend="italic">Wilson</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Bucharest</hi></placeName>, <date calendar="gregorian" when="1930-08-05T01:00:00+01:44">August 5, 1930—1
                                a.m.</date><lb/>[Received 9:32 a.m.]</dateline></opener>
                        <p>30. Legation’s 29, August 4, 4 p.m., paragraph 2. Rumanian Government now
                            agrees to’ accept Department substitute subdivision (<hi rend="italic">c</hi>), article 4.</p>
                        <closer><signed><hi rend="smallcaps">Wilson</hi></signed></closer>
