<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-09-20T12:00:00-05:00" frus:doc-dateTime-min="1930-09-20T12:00:00-05:00" n="707" subtype="historical-document" type="document" xml:id="d707">
                        <note rend="inline" type="source">823.01/39: Telegram</note>
                        <head><hi rend="italic">The Chargé in Brazil</hi> (<persName type="from"><hi rend="italic">Washington</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Rio de
                                        Janeiro</hi></placeName>, <date calendar="gregorian" when="1930-09-20T14:00:00-03:00">September 20, 1930—2
                                    p.m.</date><lb/>[Received 2:40 p.m.]</dateline></opener>
                        <p>58. Embassy’s 57, September 20, noon.<note n="14" xml:id="d707fn14"><ref target="frus1930v01#pg_390">Vol. <hi rend="smallcaps">i</hi>, p.
                                    390</ref>.</note> Just been informed that Brazil will recognize
                            the Government of Peru today.</p>
                        <closer><signed><hi rend="smallcaps">Washington</hi></signed></closer>
                    </div>
                    </body></text></TEI>