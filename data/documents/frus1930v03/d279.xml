<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-07-01T11:44:00-05:00" frus:doc-dateTime-min="1930-07-01T11:44:00-05:00" n="279" subtype="historical-document" type="document" xml:id="d279">
                        <note rend="inline" type="source">882.00/833: Telegram</note>
                        <head><hi rend="italic">The Chargé in Liberia</hi> (<persName type="from"><hi rend="italic">Hall</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Monrovia</hi></placeName>, <date calendar="gregorian" when="1930-07-01T16:00:00-00:44">July 1, 1930—4
                                p.m.</date><lb/>[Received 9:41 p.m.]</dateline></opener>
                        <p>91. My 89, June 27, 11 p.m. [<hi rend="italic">a.m.</hi>] Barclay has
                            requested consent of the Legation to make public the contents of my note
                            declaring documents forgeries. Please instruct.</p>
                        <closer><signed><hi rend="smallcaps">Hall</hi></signed></closer>
                    </div>
                    </body></text></TEI>