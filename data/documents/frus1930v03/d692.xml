<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-09-13T13:00:00-05:00" frus:doc-dateTime-min="1930-09-13T13:00:00-05:00" n="692" subtype="historical-document" type="document" xml:id="d692">
                        <note rend="inline" type="source">823.01/18: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Peru</hi> (<persName type="from"><hi rend="italic">Dearing</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Lima</hi></placeName>, <date calendar="gregorian" when="1930-09-13T13:00:00-05:00">September 13, 1930—1
                                    p.m.</date><lb/>[Received 2 p.m.]</dateline></opener>
                        <p>208. The Japanese Minister informs me that his Government has recognized
                            the junta as the government of Peru.</p>
                        <closer><signed><hi rend="smallcaps">Dearing</hi></signed></closer>
                    </div>
                    </body></text></TEI>