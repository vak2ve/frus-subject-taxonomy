<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-11-17T06:00:00-05:00" frus:doc-dateTime-min="1930-11-17T06:00:00-05:00" n="47" subtype="historical-document" type="document" xml:id="d47">
                        <note rend="inline" type="source">810.79611 Pan American Airways/922:
                            Telegram</note>
                        <head><hi rend="italic">The Chargé in France</hi> (<persName type="from"><hi rend="italic">Armour</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1930-11-17T11:00:00+00:00">November 17, 1930—11
                                    a.m.</date><lb/>[Received November 17—9:25
                            a.m.]</dateline></opener>
                        <p>375. With further reference to Department’s telegram 292, November 11, 7
                                p.m.<note n="62" xml:id="d47fn62">Not printed.</note> I am today
                            orally informed that permission has been extended for another 3
                            months.</p>
                        <closer><signed><hi rend="smallcaps">Armour</hi></signed></closer>
                    </div>
                </body></text></TEI>