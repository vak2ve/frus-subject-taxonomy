    <text>
        <body>
            <div frus:doc-dateTime-max="1930-02-20T09:44:00-05:00"
                frus:doc-dateTime-min="1930-02-20T09:44:00-05:00" n="295"
                subtype="historical-document" type="document" xml:id="d295">
                <note rend="inline" type="source">882.5048/242: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Liberia</hi> (<persName type="from">
                        <hi rend="italic">Carter</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1930-02-20T14:00:00-00:44"
                            >February 20, 1930—2 p.m.</date>
                        <lb/>[Received 2:10 p.m.]</dateline>
                </opener>
                <p>25. Am confidentially informed that the Liberian Government has accepted
                    Christy.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Carter</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
