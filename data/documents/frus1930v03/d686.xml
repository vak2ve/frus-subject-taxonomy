    <text>
        <body>
            <div frus:doc-dateTime-max="1930-09-09T18:00:00-05:00"
                frus:doc-dateTime-min="1930-09-09T18:00:00-05:00" n="686"
                subtype="historical-document" type="document" xml:id="d686">
                <note rend="inline" type="source">823.30/110: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Peru</hi> (<persName type="from">
                        <hi rend="italic">Dearing</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1930-09-09T18:00:00-05:00"
                            >September 9, 1930—6 p.m.</date>
                        <lb/>[Received 7:37 p.m.]</dateline>
                </opener>
                <p>196. My 190, September 6, 7 p.m. Sutton released; returned home today. Grow
                    released; expected to arrive Lima 11th on the steamer <hi rend="italic"
                        >Rimac.</hi>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dearing</hi>
                    </signed>
                </closer>
            </div>
        </body>
