                subtype="historical-document" type="document" xml:id="d6">
                <note rend="inline" type="source">811.512351Double/19: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Edge</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1930-05-06T12:00:00+01:00"
                            >May 6, 1930—noon</date>.<lb/>[Received May 6—9 a.m.]</dateline>
                </opener>
                <p>130. Your 86, April 24, 5 p.m.<note n="9" xml:id="d6fn9">Not printed.</note>
                    Messrs. Adams, Carroll and Alvord have arrived and are now having conferences
                    which will last for several days with all the representatives of American
                    interests concerned. Informal negotiations with the appropriate French
                    authorities will probably begin on Thursday.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edge</hi>
                    </signed>
                </closer>
            </div>
        </body>
