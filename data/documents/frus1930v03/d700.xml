                subtype="historical-document" type="document" xml:id="d700">
                <note rend="inline" type="source">823.01/29: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Guatemala</hi> (<persName type="to">
                        <hi rend="italic">Whitehouse</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1930-09-17T15:00:00-04:00"
                            >September 17, 1930—3 p.m.</date>
                    </dateline>
                </opener>
                <p>65. Your despatch No. 159, September 12, was received today.</p>
                <p>You may inform the Foreign Office that the Government of the United States will
                    recognize the new Government of Peru on Thursday, September 18.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
