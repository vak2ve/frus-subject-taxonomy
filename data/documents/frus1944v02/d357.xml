    <text>
        <body>
            <div frus:doc-dateTime-max="1944-04-20T23:59:59-05:00"
                frus:doc-dateTime-min="1944-04-20T00:00:00-05:00" n="357"
                subtype="historical-document" type="document" xml:id="d357">
                <note rend="inline" type="source">800.706/747: Airgram</note>
                <head>
                    <hi rend="italic">The Ambassador in the United Kingdom</hi> (<persName
                        type="from">
                        <hi rend="italic">Winant</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1944-04-20">April 20,
                            1944</date>.<lb/>[Received April 29—3 p.m.]</dateline>
                </opener>
                <p>A–480. Reference Embassy’s 2025, March 13, 7 p.m. Jeffcock<note n="94"
                        xml:id="d357fn94">Robin J. P. Jeffcock, an official of the British Ministry
                        of Aircraft Production.</note> and Duncan<note n="95" xml:id="d357fn95"
                        >William Aver Duncan, an official of the British Air Ministry.</note> left
                    last night by sea for the United States for talks on aviation radio with members
                    of the Civil Aeronautics Administration. They expect to arrive in Washington
                    about May 1.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Winant</hi>
                    </signed>
                </closer>
            </div>
        </body>
