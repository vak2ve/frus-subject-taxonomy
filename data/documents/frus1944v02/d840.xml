                subtype="historical-document" type="document" xml:id="d840">
                <note rend="inline" type="source">800.6176/11–2544: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the United Kingdom</hi> (<persName type="to">
                        <hi rend="italic">Winant</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1944-12-18T14:00:00-04:00"
                            >December 18, 1944—2 p.m.</date>
                    </dateline>
                </opener>
                <p>10522. For Bugbee from Haley. Embassy’s 10401 of November 25. Department has not
                    been approached by the French regarding admittance to Rubber Study Group.
                    Department is opposed at this time to such admittance. [Haley.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stettinius</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
