                subtype="historical-document" type="document" xml:id="d706">
                <note rend="inline" type="source">840.70/10–2544: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in the United Kingdom</hi> (<persName type="to">
                        <hi rend="italic">Winant</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1944-10-25T00:00:00-04:00"
                            >October 25, 1944—midnight</date>.</dateline>
                </opener>
                <p>8904. For EITO Delegation from Berle. Embassy’s telegram 9167<note n="62"
                        xml:id="d706fn62">Dated October 25, <ref target="#pg_831">p.
                        831</ref>.</note> received late today. Please attempt avoid commitments on
                    controversial points until Department has an opportunity to study and comment on
                    your telegram and send you such instructions as are necessary. [Berle.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stettinius</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
