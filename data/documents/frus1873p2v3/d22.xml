                subtype="historical-document" type="document" xml:id="d22">
                <head>Appointment of secretary.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Executive Mansion</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1871-02-14">
                            <hi rend="italic">February</hi> 14, 1871</date>.</dateline>
                </opener>
                <p rend="flushleft">To <hi rend="smallcaps">J. C. Bancroft Davis</hi>, Esq.,<lb/>
                    <hi rend="italic">Assistant Secretary of State:</hi>
                </p>
                <p>You are hereby designated and directed to perform the duties of secretary of the
                    commissioners on behalf of the United States in the joint high commission, to
                    meet in Washington for the consideration of the questions pending between the
                    United States and Great Britain.</p>
                <closer>
                    <signed>U. S. GRANT.</signed>
                </closer>
            </div>
        </body>
