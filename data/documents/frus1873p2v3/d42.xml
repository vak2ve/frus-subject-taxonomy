        <body>
            <div frus:doc-dateTime-max="1871-02-09T23:59:59-05:00" frus:doc-dateTime-min="1871-02-09T00:00:00-05:00" n="42" subtype="historical-document" type="document" xml:id="d42">
                <head>No. 3.<lb/>
                    <hi rend="italic">Earl <persName type="from">Granville</persName> to the <gloss type="to">Lord High
                                        Commissioners</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Foreign
                                            Office</hi>
                        </placeName>, <date calendar="gregorian" when="1871-02-09">
                            <hi rend="italic">February</hi> 9,
                                        1871</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Lord and Gentlemen</hi>: I have to inform you
                                that Lord Tenterden has been appointed secretary of the High
                                Commission, and will proceed to Washington accordingly.</p>
                <p>I am, &amp;c.,</p>
                <closer>
                    <signed>GRANVILLE.</signed>
                </closer>
            </div>
        </body>
