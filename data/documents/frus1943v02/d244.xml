                <note rend="inline" type="source">851D.20/46: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Cayenne</hi> (<persName type="to">
                        <hi rend="italic">LaMont</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-04-06T22:00:00-04:00"
                            >April 6, 1943—10 p.m.</date>
                    </dateline>
                </opener>
                <p>23. Your 42, April 1. Please assure Governor Rapenne that we will be guided by
                    his wishes in the matter.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
