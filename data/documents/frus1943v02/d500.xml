                subtype="historical-document" type="document" xml:id="d500">
                <note rend="inline" type="source">811.34553B/5a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Portugal</hi> (<persName type="to">
                        <hi rend="italic">Kennan</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-10-19T13:00:00-04:00"
                            >October 19, 1943—1 p.m.</date>
                    </dateline>
                </opener>
                <p>1816. Your 2449, October 18, 8 p.m., has been shown to the President who has
                    directed me to state that a brief delay in opening negotiations will have no
                    damaging effect from our point of view. He sees no reason however for your
                    return here but wishes you to submit your views in full by cable.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stettinius</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
