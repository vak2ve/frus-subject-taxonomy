    <text>
        <body>
            <div frus:doc-dateTime-max="1943-05-25T23:59:59-05:00"
                frus:doc-dateTime-min="1943-05-25T00:00:00-05:00" n="92"
                subtype="historical-document" type="document" xml:id="d92">
                <note rend="inline" type="source">740.0011 European War 1939/29654a</note>
                <head>
                    <hi rend="italic">The Under Secretary of State</hi> (<persName type="from">
                        <hi rend="italic">Welles</hi>
                    </persName>) <hi rend="italic">to the British Ambassador</hi> (<persName
                        type="to">
                        <hi rend="italic">Halifax</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-05-25">May 25,
                            1943</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Lord Halifax</hi>: With reference to your secret
                    letter of May 16, 1943 I wish to inform you that the suggestions contained
                    therein have been approved by the President and Mr. Murphy has been instructed
                    to join with Mr. Macmillan in addressing identic letters to General Giraud
                    covering the amended versions of the two Anfa memoranda.</p>
                <p>Sincerely yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Welles</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
