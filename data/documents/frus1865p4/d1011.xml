                    <head>Polytechnic Scholars from the Canton of Ticino</head>
                    <note rend="inline" rendition="#center" type="source">[Translation.]</note>
                    <dateline>
                        <placeName>
                            <hi rend="smallcaps">Zurich</hi></placeName>, <date calendar="gregorian" when="1865-05-05">
                            <hi rend="italic">May</hi> 5, 1865</date>.</dateline>
                    <p>Signatures of the polytechnic scholars from the canton of Ticino, to the
                        address of sympathy and condolence to the American Union:</p>
                    <closer>
                        <signed>
                            <list>
                                <item>LEONARDO ROSSI, <hi rend="italic">of Castelrotto</hi>.</item>
                                <item>CARLO FONTANA, <hi rend="italic">of Tesserete</hi>.</item>
                                <item>OLINDO BOLETTI, <hi rend="italic">of Locarno</hi>.</item>
                                <item>IGNAZIO ZANATTA, <hi rend="italic">of Lugano</hi>.</item>
                                <item>GIOACHIMO TIODA, <hi rend="italic">of Locarno</hi>.</item>
                                <item>CAETANO FONTANA, <hi rend="italic">of Tesserete</hi>.</item>
                                <item>ACHILLE RUSCA, <hi rend="italic">of Locarno</hi>.</item>
                                <item>GIULIO GIANINI, <hi rend="italic">of Sobrio</hi>.</item>
                                <item>FEDERICO BEZZOLO, <hi rend="italic">of Cornologno</hi>.</item>
                                <item>PLINIO DELLBARCHI, <hi rend="italic">of Astano</hi>.</item>
                                <item>GIACOMO LEPORI, <hi rend="italic">of Deno</hi>.</item>
                                <item>TEODORO ANASTASIA, <hi rend="italic">of Breno</hi>.</item>
                                <item>VESPASSIORNO PALEARI, <hi rend="italic">of
                                    Mezcatte</hi>.</item>
                            </list>
                        </signed>
                    </closer>
                </div>
