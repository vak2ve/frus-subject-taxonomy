                            <cell>S. GLOOR.</cell>
                        </row>
                        <row>
                            <cell>
                                <hi rend="smallcaps">Rev</hi>. F ZIMMERLIN.</cell>
                            <cell>LUTHI FUSTER.</cell>
                        </row>
