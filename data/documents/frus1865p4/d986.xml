                <head>Riflemen’s and Private Club of Schöftland</head>
                <note rend="inline" rendition="#center" type="source">[Translation.]</note>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Schöftland, Canton of Aargau</hi>
                    </placeName>, <date calendar="gregorian" when="1865-04-27">
                        <hi rend="italic">April</hi> 27, 1865</date>.</dateline>
                <p>The subscribers heartily join in the address of sympathy to the President and
                    Vice-President of the United States on account of their recent complete
                    victories over their enemies,</p>
                <p>The Feldschütien-gesellschaft of Schöftland:</p>
                <closer>
                    <signed>ADOLPH HÜTHY, </signed>
                    <hi rend="italic">President</hi>. <lb/>
                    <signed>T. GLOOR, </signed>
                    <hi rend="italic">Secretary</hi>. <lb/>
                    <signed>A. WIRTZ, </signed>
                    <hi rend="italic">Cashier</hi>. <lb/>
                    <signed>A. DIENER,</signed>
                    <lb/>
                    <signed>SAMUEL HAURI,</signed>
                    <lb/>
                    <hi rend="italic">Directors from Hirschthal</hi>. </closer>
                <postscript>
                    <p rend="center">
                        <hi rend="italic">Members of the Association</hi>.</p>
                    <table cols="2" rows="10">
                        <row>
                            <cell>R. MULLER.</cell>
                            <cell>S. HAURI.</cell>
                        </row>
                        <row>
                            <cell>T. HUMM.</cell>
                            <cell>CHRISTIAN SCHELL.</cell>
                        </row>
                        <row>
                            <cell>F. LÜTNY.</cell>
                            <cell>JACOB MÜLLER.</cell>
                        </row>
                        <row>
                            <cell>FRIEDRICH GLOOR.</cell>
                            <cell>S. MÜLLER.</cell>
                        </row>
                        <row>
                            <cell>Z. FEHLMANN.</cell>
                            <cell>RUDOLPH HÜNZICKER.</cell>
                        </row>
                        <row>
                            <cell>T. SUTER.</cell>
                            <cell>RUDOLF WIRZ.</cell>
                        </row>
                        <row>
                            <cell>J. SÜTHI.</cell>
                            <cell>HÜTHY BASLER.</cell>
                        </row>
                        <row>
                            <cell>G. LANZ.</cell>
                            <cell>RUDOLF ZINNHARD.</cell>
                        </row>
                        <row>
                            <cell>G. WIRZ.</cell>
                            <cell>R. MATHYS.</cell>
                        </row>
                        <row>
                            <cell>HEINRICH FREY.</cell>
                            <cell>RUDOLF BOLLIGER.</cell>
                        </row>
                    </table>
                    <p rend="center">
                        <hi rend="italic">Members of the Leist-Gesellschqft of Schŏltland</hi>
                    </p>
                    <table cols="2" rows="6">
                        <row>
