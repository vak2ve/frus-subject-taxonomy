<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-05-07T23:59:59-05:00" frus:doc-dateTime-min="1865-05-07T00:00:00-05:00" n="957" subtype="historical-document" type="document" xml:id="d957">
                    <head>Singing Society of Langnau</head>
                    <note rend="inline" rendition="#center" type="source">[Translation.]</note>
                    <dateline>
                        <placeName>
                            <hi rend="smallcaps">Langnau</hi></placeName>, <date calendar="gregorian" when="1865-05-07">
                            <hi rend="italic">May</hi> 7, 1865</date>.</dateline>
                    <p rend="center">
                        <hi rend="italic">The Männerchor of Langnau to the editor of the
                        Bund</hi>.</p>
                    <p>
                        <hi rend="smallcaps">Sir</hi>: The above named society, composed of
                        five-and-twenty members, have this day resolved to unite in the address of
                        sympathy and condolence to the North American Union.</p>
                    <p>In the name of the society:</p>
                    <closer>
                        <signed>FRITZ. HOFER, </signed>
                        <hi rend="italic">President.</hi>
                        <lb/>
                        <signed>SCHAFFER, </signed>
                        <hi rend="italic">Secretary.</hi>
                    </closer>
                </div>
                </body></text></TEI>