    <text>
        <body>
            <div frus:doc-dateTime-max="1865-04-26T23:59:59-05:00"
                frus:doc-dateTime-min="1865-04-26T00:00:00-05:00" n="72"
                subtype="historical-document" type="document" xml:id="d72">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Drouyn de Lhuys</persName> to Mr.
                            <persName type="to">Bigelow</persName>
                    </hi>.</head>
                <note rend="inline" rendition="#center" type="source">[Translation]</note>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">Paris</hi>
                    </placeName>, <date calendar="gregorian" when="1865-04-26">
                        <hi rend="italic">April</hi> 26, 1865</date>.</dateline>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The telegrams published in the evening papers
                    inform me of the horrible crime of which Messieurs Lincoln and Seward have been
                    the victims. I would not delay a moment longer to express to you our profound
                    sympathy.</p>
                <p>Yours, very sincerely,</p>
                <closer>
                    <signed>DROUYN DE LHUYS.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">John Bigelow</hi>, Esq., <lb/>
                        <hi rend="italic">United States Minister, Paris</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
