<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-05-07T23:59:59-05:00" frus:doc-dateTime-min="1865-05-07T00:00:00-05:00" n="905" subtype="historical-document" type="document" xml:id="d905">
                    <head>Typographia Society</head>
                    <note rend="inline" rendition="#center" type="source">[Translation.]</note>
                    <dateline>
                        <placeName><hi rend="smallcaps">Berne</hi></placeName>, <date calendar="gregorian" when="1865-05-07">
                            <hi rend="italic">May</hi> 7, 1865</date>.</dateline>
                    <p>
                        <hi rend="smallcaps">Mr. Editor</hi>: The Berne Typographia hereby announce
                        their assent to the address of sympathy and condolence to the government of
                        the North American free States.</p>
                    <p>For the society:</p>
                    <closer>
                        <signed>
                            <list>
                                <item>KARL KÖNIG, <hi rend="italic">President</hi>.</item>
                                <item>S. MAYER, <hi rend="italic">Secretary</hi>.</item>
                            </list>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>