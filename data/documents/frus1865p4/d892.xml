                <head>Inhabitants of Aarmuhle</head>
                <note rend="inline" rendition="#center" type="source">[Translation.]</note>
                <dateline>
                    <hi rend="smallcaps">Aarmuhle</hi>, <date calendar="gregorian" when="1865-05-27">
                        <hi rend="italic">May</hi> 27, 1865</date>.</dateline>
                <p>Mr. <hi rend="smallcaps">President</hi>: At a public meeting of the citizens of
                    Aarmuhle, district of Interlachen, it was unanimously resolved to ratify the
                    Swiss address of gratulation and sympathy to the people of the North American
                    Union.</p>
                <p>Respectfully,</p>
                <closer>
                    <signed>
                        <list>
                            <item>M. WYDER, <hi rend="italic">President</hi>.</item>
                            <item>P. VORTER, <hi rend="italic">Secretary</hi>.</item>
                        </list>
                    </signed>
                </closer>
                <postscript>
                    <p>The Hon. <hi rend="smallcaps">Bundesrath</hi>
                        <lb/>
                        <hi rend="italic">of the Swiss Confederation in Berne</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
