                <head>Inhabitants of Gruyere</head>
                <dateline>
                    <placeName>Gruyere</placeName>, <date ana="#date_undated-inferred-from-volume-rules" calendar="gregorian" notAfter="1865-07-31T23:59:59+00:34" notBefore="1865-04-15T00:00:00+00:34">undated</date>
