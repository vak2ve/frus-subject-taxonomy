            <div frus:doc-dateTime-max="1865-07-31T18:25:59-05:00" frus:doc-dateTime-min="1865-04-14T18:26:00-05:00" n="1018" subtype="historical-document" type="document" xml:id="d1018">
                <head>Inhabitants of Zofingen</head>
                <dateline>
                    <placeName>Zofingen</placeName>, <date ana="#date_undated-inferred-from-volume-rules" calendar="gregorian" notAfter="1865-07-31T23:59:59+00:34" notBefore="1865-04-15T00:00:00+00:34">undated</date>
                </dateline>
                <note rend="inline" rendition="#center" type="source">[Translation.]</note>
                <p rend="center">
                    <hi rend="italic">Community of Zofingen</hi>.</p>
                <p>The undersigned citizens of the canton of Aargau, with all our heart, approve
                        of the Berne address of sympathy and condolence to the President of the
                        United States, in every part and particular.</p>
                <closer>
                    <signed>S. R. RINGIER,</signed>
                    <lb/> And 224 other names mentioned.</closer>
            </div>
