                subtype="historical-document" type="document" xml:id="d983">
                <head>Inhabitants of St. Gall</head>
                <note rend="inline" rendition="#center" type="source">[Translation.]</note>
                <dateline>
                    <placeName>
                        <hi rend="smallcaps">St. Gall</hi>
                    </placeName>, <date calendar="gregorian" when="1865-05-17">
                        <hi rend="italic">May</hi> 17, 1865</date>.</dateline>
                <p rend="center">
                    <hi rend="italic">Council of the canton of St. Gall to the honorable Swiss
                        Bundesrath in Berne</hi>.</p>
                <p>
                    <hi rend="smallcaps">Gentlemen</hi>: In accordance with the wish of the council
                    of this district, we send you an abstract<note n="*" xml:id="d983fn1">For
                        abstract referred to, see Balgach.</note> of the minutes of the popular
                    meeting held on the 7th of this mouth to ratify the address of sympathy and
                    condolence to the American Union.</p>
                <p>Aceept the assurance of our distinguished consideration.</p>
                <closer>
                    <signed>
                        <list>
                            <item>SAILER, <hi rend="italic">President</hi>.</item>
                            <item>ZINGG, <hi rend="italic">Secretary</hi>.</item>
                        </list>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
