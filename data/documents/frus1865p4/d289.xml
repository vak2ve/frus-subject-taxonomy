    <text>
        <body>
            <div frus:doc-dateTime-max="1865-05-22T23:59:59-05:00" frus:doc-dateTime-min="1865-05-22T00:00:00-05:00" n="289" subtype="historical-document" type="document" xml:id="d289">
                <head>Government Secretary</head>
                <dateline>
                    <hi rend="smallcaps">Government Secretary’s Office</hi>, <lb/>
                    <placeName>
                        <hi rend="italic">British Guiana</hi>
                    </placeName>, <date calendar="gregorian" when="1865-05-22">
                        <hi rend="italic">May</hi> 22, 1865</date>.</dateline>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The governor directs me to acknowledge the
                        receipt of your official communication of this day’s date, announcing the
                        death of his Excellency Abraham Lincoln, late President of the United States
                        of America, and I am to convey to you the expression of his very deep regret
                        on the occasion. </p>
                <p>I have the honor to be, sir, your obedient, humble servant,</p>
                <closer>
                    <signed>WALTER HOWARD WARE,</signed>
                    <lb/>
                    <hi rend="italic">Acting Government Secretary</hi>.</closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">P. W. Figgelmesy</hi>, Esq., <lb/>
                        <hi rend="italic">United States Consul, Demerara</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
