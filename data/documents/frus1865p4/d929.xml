            <div frus:doc-dateTime-max="1865-07-31T18:25:59-05:00" frus:doc-dateTime-min="1865-04-14T18:26:00-05:00" n="929" subtype="historical-document" type="document" xml:id="d929">
                <head>Singing and Musical Union of Diegten</head>
                <dateline>
                    <placeName>Diegten</placeName>, <date ana="#date_undated-inferred-from-volume-rules" calendar="gregorian" notAfter="1865-07-31T23:59:59+00:34" notBefore="1865-04-15T00:00:00+00:34">undated</date>
                </dateline>
                <note rend="inline" rendition="#center" type="source">[Translation.]</note>
                <p>
                    <hi rend="italic">The Mannerchor and Musical Union of Diegten, Canton of
                            Baselland, with fifty-four signatures and this motto:</hi>
                </p>
                <lg>
                    <l>Es blinken der Sterne so viele</l>
                    <l>In’s dunkel des Lebens hinein;</l>
                    <l>Es dringen die Vœlker zum Ziele,</l>
                    <l>Bei ihrem helleuchtenden Schein.</l>
                </lg>
                <lg>
                    <l>Many stars twinkle</l>
                    <l>In life’s weary way,</l>
                    <l>Leading us onward</l>
                    <l>To heavenly day.</l>
                </lg>
            </div>
        </body>
