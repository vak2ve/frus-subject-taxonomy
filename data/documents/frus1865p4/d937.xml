        <body>
            <div frus:doc-dateTime-max="1865-05-08T23:59:59-05:00" frus:doc-dateTime-min="1865-05-08T00:00:00-05:00" n="937" subtype="historical-document" type="document" xml:id="d937">
                <head>Thurgau Mutual Aid Society</head>
                <dateline>
                    <placeName>Thurgau</placeName>, <date ana="#date_undated-inferred-from-document-content" calendar="gregorian" when="1865-05-08">May 8, 1865</date>
                </dateline>
                <note rend="inline" rendition="#center" type="source">[Translation.]</note>
                <p rend="center">
                    <hi rend="italic">Telegram from Frauenfeld to Berne, (received May</hi> 8,
                        1865, <hi rend="italic">) to the editor of the Bund, in Berne</hi>.</p>
                <p>The Thurgau Mutual Aid Society, at a special meeting this day, has
                        unanimously declared its adhesion to the Swiss address of sympathy and
                        condolence to the people of the United States.</p>
                <closer>
                    <signed>
                        <list>
                            <item>MANN, <hi rend="italic">Actuary</hi>.</item>
                            <item>STRAHEN, <hi rend="italic">Telegraph Agent</hi>.</item>
                        </list>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
