    <teiHeader><fileDesc><titleStmt><title>The Consul General at Shanghai (
                        Cabot
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1948v07</bibl><bibl type="frus-document-id">d529</bibl><bibl type="frus-document-number">529</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1948-12-13T09:00:00-05:00" notAfter="1948-12-13T09:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1948-12-13T09:00:00-05:00" frus:doc-dateTime-min="1948-12-13T09:00:00-05:00" n="529" subtype="historical-document" type="document" xml:id="d529">
                <note rend="inline" type="source">893.00/12–1348: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from">
                        <hi rend="italic">Cabot</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1948-12-13T22:00:00+08:00">December 13, 1948—10 p. m.</date>
                        <lb/> [Received December 12—10:59 p. m.]</dateline>
                </opener>
                <p>2740. CAT<note n="12" xml:id="d529fn12">Chinese Air Transport.</note> pilot
                    arriving Shanghai 4 a. m. December 13 states all airfields Peiping closed last
                    night. Traffic on Tientsin extremely heavy. CAF reported evacuating Peiping.</p>
                <p>Sent Department 2740, repeated Nanking 2055, Peiping 268.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cabot</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
