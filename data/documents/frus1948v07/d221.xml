        <body>
            <div frus:doc-dateTime-max="1948-06-05T23:59:59-05:00" frus:doc-dateTime-min="1948-06-05T00:00:00-05:00" n="221" subtype="historical-document" type="document" xml:id="d221">
                <note rend="inline" type="source">893.00/6–548: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Tientsin</hi> (<persName type="from">
                        <hi rend="italic">Hinke</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tientsin</hi>
                        </placeName>, <date calendar="gregorian" when="1948-06-05">June 5,
                            1948</date>.<lb/>[Received June 5—8:56 a. m.]</dateline>
                </opener>
                <p>156. Peiyang University students engaged in 3-day strike against US support to
                    Japan as result petition signed by majority student body.</p>
                <pb facs="0289" n="279" xml:id="pg_279"/>
                <p>Sent Nanking as 306, repeated Department as 156, Shanghai as 262 and Peiping.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hinke</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
