                subtype="historical-document" type="document" xml:id="d62">
                <note rend="inline" type="source">893.00/1–348: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Stuart</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1948-02-06T20:00:00-05:00"
                            >February 6, 1948—8 p. m.</date>
                    </dateline>
                </opener>
                <p>201. Please submit your comments and recommendations with respect suggestions
                    contained Peiping despatch to Emb 2 January 3 that US consular officer visit
                    Communist areas north China on intelligence mission.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Marshall</hi>
                    </signed>
                </closer>
            </div>
        </body>
