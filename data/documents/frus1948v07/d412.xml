                subtype="historical-document" type="document" xml:id="d412">
                <note rend="inline" type="source">893.00/10–2748: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Tientsin</hi> (<persName type="from">
                        <hi rend="italic">Smyth</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tientsin</hi>
                        </placeName>, <date calendar="gregorian" when="1948-10-27">October 27,
                            1948</date>.<lb/>[Received October 27—3:03 a. m.]</dateline>
                </opener>
                <p>305. Local press reports faculties of Nankai and Peiyang Universities will
                    suspend class work for 3 days as “protest against present state of unbearable
                    living”.</p>
                <p>Sent Nanking 549, repeated Department 305, Shanghai 517 and Peiping.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Smyth</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
