<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1948-12-27T22:00:00-05:00" frus:doc-dateTime-min="1948-12-27T22:00:00-05:00" n="574" subtype="historical-document" type="document" xml:id="d574">
                        <note rend="inline" type="source">893.00/12–2848: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in China</hi> (<persName type="from"><hi rend="italic">Stuart</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Nanking</hi></placeName>, <date calendar="gregorian" when="1948-12-28T11:00:00+08:00">December
                                    28, 1948—11 a. m.</date>
                                <lb/> [Received December 28—2:47 a. m.]</dateline>
                        </opener>
                        <p>2632. [To Shanghai:] Suggestion of Carsun Chang contained urtel 2169,
                            December 26, 5 p. m.<note n="76" xml:id="d574fn76">Repeated to the
                                Department as telegram No. 2891, <ref target="#pg_687">p.
                                687</ref>.</note> appreciated. However, Chang Chun has access to
                            Ambassador and other Embassy officers here and trip to Shanghai for this
                            purpose unnecessary.</p>
                        <p>Sent Shanghai 1316, repeated Department.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Stuart</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>