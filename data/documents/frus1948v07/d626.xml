<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1948-11-04T23:59:59-05:00" frus:doc-dateTime-min="1948-11-04T00:00:00-05:00" n="626" subtype="historical-document" type="document" xml:id="d626">
                    <note rend="inline" type="source">893.00 Sinkiang/11–448: Telegram</note>
                    <head>
                        <hi rend="italic">The Consul at Tihwa</hi> (<persName type="from"><hi rend="italic">Paxton</hi></persName>) <hi rend="italic">to the
                                <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Tihwa</hi></placeName>, <date calendar="gregorian" when="1948-11-04">November 4,
                            1948</date>.<lb/>[Received November 5—1:51 a. m.]</dateline>
                    </opener>
                    <p>107. Sinkiang <hi rend="italic">Gazette</hi> November 3 published
                        announcement by General Chang that no election for provincial chairman would
                        be held until agreement reached with Ili group.</p>
                    <p>Sent Nanking 209, repeated Department 107.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Paxton</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>