<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1948-11-30T18:00:00-05:00" frus:doc-dateTime-min="1948-11-30T18:00:00-05:00" n="507" subtype="historical-document" type="document" xml:id="d507">
                        <note rend="inline" type="source">893.00/11–3048: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Consul General at Tsingtao</hi> (<persName type="to"><hi rend="italic">Turner</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1948-11-30T18:00:00-05:00">November
                                    30, 1948—6 p. m.</date>
                            </dateline>
                        </opener>
                        <p>173. Dept understands Chinese press reports govt forces Tsingtao
                            attacking Communists Chiaohsien area. Request info reported
                            operations.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Marshall</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>