                subtype="historical-document" type="document" xml:id="d341">
                <note rend="inline" type="source">893.00/8–3048: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Peiping</hi> (<persName type="from">
                        <hi rend="italic">Touchette</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1948-08-30">August 30,
                            1948</date>.<lb/>[Received August 30—4:52 a. m.]</dateline>
                </opener>
                <p>323. Re mytel 322, August 28. Seventy-three students now being held in jail
                    pending trial. Twenty-one others have been released on bail.</p>
                <p>Sent Nanking 477; repeated Department 323.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Touchette</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
