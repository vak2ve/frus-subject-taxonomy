<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1948-09-20T11:00:00-05:00" frus:doc-dateTime-min="1948-09-20T11:00:00-05:00" n="681" subtype="historical-document" type="document" xml:id="d681">
                    <note rend="inline" type="source">125.3516/9–2048: Telegram</note>
                    <head>
                        <hi rend="italic">The Ambassador in the Soviet Union</hi> (<persName type="from"><hi rend="italic">Smith</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Moscow</hi></placeName>, <date calendar="gregorian" when="1948-09-20T19:00:00+03:00">September 20,
                                1948—7 p. m.</date>
                            <lb/> [Received September 21—5:59 a. m.]</dateline>
                    </opener>
                    <p>2057. Have complied instruction second paragraph Deptel 1137, September 17,
                        repeated Nanking 1334, Shanghai 1634, Dairen 55. Will advise
                        developments.</p>
                    <p>Sent Dept 2057, Dept pass Nanking 27, Shanghai 30, Dairen 18.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Smith</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>