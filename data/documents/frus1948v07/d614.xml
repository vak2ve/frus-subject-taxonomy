<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1948-09-03T17:00:00-05:00" frus:doc-dateTime-min="1948-09-03T17:00:00-05:00" n="614" subtype="historical-document" type="document" xml:id="d614">
                    <note rend="inline" type="source">893.796/9–348: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            Ambassador in China</hi> (<persName type="to"><hi rend="italic">Stuart</hi></persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1948-09-03T18:00:00-04:00">September 3,
                                1948—6 p. m.</date>
                        </dateline>
                    </opener>
                    <p>1269. Request verification press reports Hollington Tong<note n="34" xml:id="d614fn34">Director of the Chinese Government Information
                            Office.</note> officially announced China notified USSR desire terminate
                        Sino-Soviet Agreement Hami-Alma Ata airline.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Marshall</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>