                subtype="historical-document" type="document" xml:id="d691">
                <note rend="inline" type="source">121.67/11–148: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Consul General at Shanghai</hi> (<persName type="to">
                        <hi rend="italic">Cabot</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1948-11-01T15:00:00-05:00"
                            >November 1, 1948—3 p. m.</date>
                    </dateline>
                </opener>
                <p>1843. Essential reestablish contact Dairen. Report feasibility two couriers
                    traveling there via Vladi. One should have made trip before. Report tentative
                    date departure Shanghai.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lovett</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
