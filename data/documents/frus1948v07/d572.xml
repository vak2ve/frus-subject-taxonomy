<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1948-12-27T23:59:59-05:00" frus:doc-dateTime-min="1948-12-27T00:00:00-05:00" n="572" subtype="historical-document" type="document" xml:id="d572">
                        <note rend="inline" type="source">893.00/12–2748: Telegram</note>
                        <head>
                            <hi rend="italic">The Chargé in the Soviet Union</hi> (<persName type="from"><hi rend="italic">Kohler</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Moscow</hi></placeName>, <date calendar="gregorian" when="1948-12-27">December 27,
                                1948</date>.<lb/>[Received December 27—10 a. m.]</dateline>
                        </opener>
                        <p>3018. <hi rend="italic">Pravda</hi> December 25 carried six-line north
                            Shensi Tass despatch reporting capture Kalgan by National Liberation
                            Army with all defending Kuomintang troops liquidated or taken
                            prisoner.</p>
                        <p>Sent Department 3018, repeated Nanking 56.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Kohler</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>