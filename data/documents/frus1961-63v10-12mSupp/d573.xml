<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1962-12-06T23:59:59-05:00" frus:doc-dateTime-min="1962-12-06T00:00:00-05:00" n="573" subtype="historical-document" type="document" xml:id="d573">
                        <head>573. Memorandum from <persName corresp="#p_SB_1">Bromley
                                Smith</persName> to members of the <gloss target="#t_NSC_1">NSC</gloss> Executive Committee, December 6, covering an <gloss target="#t_FBI_1">FBI</gloss> report on <persName corresp="#p_MAI_1">Mikoyan</persName>’s briefing of the Soviet delegation in New
                                York<note n="1" type="source" xml:id="d573fn1">Top Secret. 4 pp.
                                    <gloss target="#t_DOS_1">DOS</gloss>, <gloss target="#t_SS_1">S/S</gloss> Files: Lot 65 D 438, <gloss target="#t_NSC_1">NSC</gloss> Executive Committee.</note></head>
                        <opener><dateline rendition="#right">
                                <date ana="#date_undated-inferred-from-document-head" calendar="gregorian" when="1962-12-06">December 6, 1962</date>
                            </dateline></opener>
                        <pb facs="d573-1" n="1" type="facsimile" xml:id="d573-1"/>
                        <p>Secretary <persName corresp="#p_RD_1">Rusk</persName> referred to the
                            attached report during yesterday’s Executive Committee meeting and asked
                            that it be circulated to Committee members. Mr. Hoover has requested
                            that the existence of this report be closely held.</p>
                        <closer><signed corresp="#p_SB_1"><persName corresp="#p_SB_1">Bromley
                                    Smith</persName></signed></closer>
                        <pb facs="d573-2" n="2" type="facsimile" xml:id="d573-2"/>
                        <frus:attachment>
                            <note rend="inline" type="source">
                                <hi rend="strong">Attachment</hi>
                            </note>
                            <p>[<hi rend="italic">text not declassified</hi>]</p>
                        </frus:attachment>
                    </div>
                    </body></text></TEI>