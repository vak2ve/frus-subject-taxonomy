                subtype="historical-document" type="document" xml:id="d87">
                <note rend="inline" type="source">893.001 Chiang Kai Shek/6–2845: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Hurley</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1945-06-28T19:00:00-04:00"
                            >June 28, 1945—7 p.m.</date>
                    </dateline>
                </opener>
                <p>1010. We would appreciate receiving as soon as practicable interpretative
                        comment<note n="53" xml:id="d87fn53">Not found in Department files.</note>
                    on Chiang’s press interview of June 28th.<note n="54" xml:id="d87fn54">
                        <hi rend="italic">Supra.</hi>
                    </note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
