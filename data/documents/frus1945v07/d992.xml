                <note rend="inline" type="source">893.4061 Motion Pictures/7–1345: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Hurley</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-17T19:00:00-04:00"
                            >July 17, 1945—7 p.m.</date>
                    </dateline>
                </opener>
                <p>1111. Hays Office appreciates your efforts (Your 1161, July 13) and authorizes
                    proposal.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
