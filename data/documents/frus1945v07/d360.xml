<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The President of the Chinese Executive Yuan (
                        Soong
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945v07</bibl><bibl type="frus-document-id">d360</bibl><bibl type="frus-document-number">360</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-08-18T00:00:00-05:00" notAfter="1945-08-18T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-08-18T23:59:59-05:00" frus:doc-dateTime-min="1945-08-18T00:00:00-05:00" n="360" subtype="historical-document" type="document" xml:id="d360">
                <note rend="inline" type="source">40.00119 PW/8–1845</note>
                <head>
                    <hi rend="italic">The President of the Chinese Executive Yuan</hi> (<persName type="from">
                        <hi rend="italic">Soong</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1945-08-18">August 18,
                            1945</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Byrnes</hi>: In connection with what you told me
                    about Hongkong: Since Hongkong is in the China Theatre it seems to me perfectly
                    logical to say to the British that surrender of the Japanese there should be
                    tendered to the Supreme Commander of the China Theatre or his nominee, leaving
                    in abeyance the question as to the eventual disposition of Hongkong.</p>
                <p>With kind regards [etc.]</p>
                <closer>
                    <signed>T. V. <hi rend="smallcaps">Soong</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
