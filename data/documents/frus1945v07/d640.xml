                subtype="historical-document" type="document" xml:id="d640">
                <note rend="inline" type="source">761.93/6–2845: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in the Soviet Union</hi> (<persName type="from">
                        <hi rend="italic">Harriman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Moscow</hi>
                        </placeName>, <date calendar="gregorian" when="1945-06-28T14:00:00+03:00"
                            >June 28, 1945—2 p.m.</date>
                        <lb/> [Received June 28—11:34 a.m.]</dateline>
                </opener>
                <p>2306. Personal for Bohlen. Via Navy I have sent today message to the White House
                    regarding one of the matters Harry and I took up in Moscow. Would appreciate
                    your doing what you can to expedite answers to my questions.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Harriman</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
