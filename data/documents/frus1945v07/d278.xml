                subtype="historical-document" type="document" xml:id="d278">
                <note rend="inline" type="source">893.00/6–1145: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Hurley</hi>
                    </persName>)<note n="67" xml:id="d278fn67">Copy transmitted to President Truman
                        on June 11.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1945-06-11T16:00:00-04:00"
                            >June 11, 1945—4 p.m.</date>
                    </dateline>
                </opener>
                <p>893. We have read with interest your telegram (ReEmbs June 9) and find helpful
                    the information reported by you and by members of your staff in making our
                    estimate of developments in China.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
