    <text>
        <body>
            <div frus:doc-dateTime-max="1945-01-22T23:59:59-05:00"
                frus:doc-dateTime-min="1945-01-22T00:00:00-05:00" n="139"
                subtype="historical-document" type="document" xml:id="d139">
                <note rend="inline" type="source">893.00/1–1049</note>
                <head>
                    <hi rend="italic">Mr. <persName type="from">Mao Tse-tung</persName> to the
                        Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Hurley</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Yenan</hi>
                        </placeName>, <date calendar="gregorian" when="1945-01-22">January 22,
                            1945</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear General Hurley</hi>: Your kind letter has been
                    received. General Chow En-lai is being sent to Chungking to represent the
                    Chinese Communist Party to negotiate with the National Government.</p>
                <p>With my best wishes for your continued good health, I remain,</p>
                <p>Yours respectfully,</p>
                <closer>[Signature in Chinese] <lb/>
                    <signed>
                        <hi rend="smallcaps">Mao Tse-tung</hi>
                    </signed>
                </closer>
            </div>
        </body>
