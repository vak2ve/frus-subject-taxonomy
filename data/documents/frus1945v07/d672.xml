                subtype="historical-document" type="document" xml:id="d672">
                <note rend="inline" type="source">761.93/8–445: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in the Soviet Union</hi> (<persName type="from">
                        <hi rend="italic">Harriman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>,] <date calendar="gregorian" when="1945-08-04">4 August
                            1945</date>.</dateline>
                </opener>
                <p>040931. Am advised Soong and new Foreign Minister<note n="9" xml:id="d672fn9"
                        >Wang Shih-chieh.</note> arriving Moscow Monday August 6. I will be back in
                    Moscow by then. I request that I be instructed along the lines of my memorandum
                    to you of July 31.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Harriman</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
