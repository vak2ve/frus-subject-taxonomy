                <note rend="inline" type="source">893.4061 Motion Pictures/7–3145: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Hurley</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1945-08-09T18:00:00-04:00"
                            >August 9, 1945—6 p.m.</date>
                    </dateline>
                </opener>
                <p>1230. Hays Office now requests Emb inform U. S. film representatives Chungking
                    (Urtel 1256, July 31) results negotiations concerning remittances.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Byrnes</hi>
                    </signed>
                </closer>
            </div>
        </body>
