    <text>
        <body>
            <div frus:doc-dateTime-max="1862-09-23T23:59:59-05:00" frus:doc-dateTime-min="1862-09-23T00:00:00-05:00" n="149" subtype="historical-document" type="document" xml:id="d149">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 356.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1862-09-23">
                            <hi rend="italic">September</hi> 23, 1862.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Your despatch No. 219, of the 5th instant,
                            with the papers which accompanied it in relation to the case of the
                            steamer Oreto, has been received and communicated to the Secretary of
                            the Navy.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
