    <text>
        <body>
            <div frus:doc-dateTime-max="1862-02-10T23:59:59-05:00"
                frus:doc-dateTime-min="1862-02-10T00:00:00-05:00" n="614"
                subtype="historical-document" type="document" xml:id="d614">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Wood</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 24.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1862-02-10">
                            <hi rend="italic">February</hi> 10, 1862.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Your despatch of January 7 (No. 43) has been
                    received and read with the interest which it was calculated to excite.</p>
                <p>The improved condition of affairs at home will probably, in due time, modify the
                    adverse opinions existing abroad.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Bradford R. Wood,</hi> Esq., <hi rend="italic">&amp;c.,
                            &amp;c., Copenhagen.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
