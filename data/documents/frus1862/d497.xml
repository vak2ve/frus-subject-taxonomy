    <text>
        <body>
            <div frus:doc-dateTime-max="1862-04-26T23:59:59-05:00" frus:doc-dateTime-min="1862-04-26T00:00:00-05:00" n="497" subtype="historical-document" type="document" xml:id="d497">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Pike</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 52.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1862-04-26">
                            <hi rend="italic">April</hi> 26, 1862.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir: Y</hi>our despatch (No. 45) of the 9th instant,
                            containing the copy of a note from Mr. De Sombreff, the Netherlands
                            minister of foreign affairs, upon the subject of the treatment of
                            insurgent piratical vessels, and the concession of the rights of
                            belligerents to the States in insurrection against this government, has
                            been received.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">James S. Pike</hi>, Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
