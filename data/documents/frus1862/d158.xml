<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1862-10-10T23:59:59-05:00" frus:doc-dateTime-min="1862-10-10T00:00:00-05:00" n="158" subtype="historical-document" type="document" xml:id="d158">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName>.</head>
                        <opener>
                            <seg rendition="#left">No. 367.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1862-10-10"><hi rend="italic">October</hi> 10, 1862.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> Your despatch of September 26 (No. 227)
                            has been received, and your proceedings in relation to the armament of
                            the gunboat 290 in British waters, as there recited, are approved.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>