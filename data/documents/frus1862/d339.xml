    <text>
        <body>
            <div frus:doc-dateTime-max="1862-10-21T23:59:59-05:00"
                frus:doc-dateTime-min="1862-10-21T00:00:00-05:00" n="339"
                subtype="historical-document" type="document" xml:id="d339">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Dayton</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 240.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1862-10-21">
                            <hi rend="italic">October</hi> 21, 1862.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I enclose herewith, for your information, a copy
                    of my despatch No. 382, of this date, to Mr. Adams, relative to military
                    events.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">William L. Dayton</hi>, Esq., <hi rend="italic"
                            >&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                    <p>[The above-mentioned enclosure will be found in the correspondence with Mr.
                        Adams.]</p>
                </postscript>
            </div>
        </body>
    </text>
