<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1879-02-03T23:59:59-05:00" frus:doc-dateTime-min="1879-02-03T00:00:00-05:00" n="507" subtype="historical-document" type="document" xml:id="d507">
                        <head>No. 475.<lb/><hi rend="italic">Mr. <persName type="from">Farman</persName> to Mr. <persName type="to">Evarts</persName>.</hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Agency
                                        and Consulate-General of the United States in
                                        Egypt</hi>,<lb/><hi rend="italic">Cairo</hi></placeName>,
                                    <date calendar="gregorian" when="1879-02-03"><hi rend="italic">February</hi> 3, 1879</date>. (Received March
                                1.)</dateline>
                            <seg rendition="#left">No. 277.]</seg></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have the honor to transmit herewith a
                            short article upon the Suez Canal, for such use as you may deem
                            proper.</p>
                        <p>I am, sir, &amp;c.,</p>
                        <closer><signed>E. E. FARMAN.</signed></closer>
                    </div>
                    </body></text></TEI>