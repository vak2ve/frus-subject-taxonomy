                            <cell rendition="#border-right">
                                <hi rend="italic">Yen.</hi>
                            </cell>
                            <cell>
                                <hi rend="italic">Yen.</hi>
                            </cell>
                        </row>
                        <row>
                            <cell rendition="#border-right">1st</cell>
