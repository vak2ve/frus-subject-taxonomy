                            <cell rendition="#border-right" role="num">13,000,000</cell>
                            <cell rendition="#border-right" role="num">20,000,000</cell>
                            <cell role="num">11,000,000</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right #border-bottom">Silver exported</cell>
                            <cell rendition="#border-right #border-bottom" role="num"
