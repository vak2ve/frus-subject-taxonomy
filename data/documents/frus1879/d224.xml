                            <cell role="num">6,139,612</cell>
                        </row>
                        <row>
                            <cell>December 28, 1878</cell>
                            <cell role="num">5,798,494</cell>
                        </row>
                    </table>
                    <p>Irish banks:</p>
                    <table cols="2" rows="3">
                        <row>
                            <cell>December 30, 1876</cell>
                            <cell role="num">7,409,342</cell>
                        </row>
                        <row>
