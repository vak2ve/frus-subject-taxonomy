                subtype="historical-document" type="document" xml:id="d365">
                <note rend="inline" type="source">893.00/5786: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from">
                        <hi rend="italic">Cunningham</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1924-11-22">
                            <hi rend="italic">November 22, 1924</hi>
                        </date>.<lb/>[Received November 22—1:45 p.m.]</dateline>
                </opener>
                <p>Following from Nanking: <quote rend="blockquote">
                        <p>“November 22, 11 a.m. Please send following telegram to the Department:
                            ‘Marshal Chi embarrassed by Wu’s unauthorized use of his name in
                            manifesto proclaiming Yangtze military government, and has repeated
                            circular telegram endorsing Tuan. He will assist Wu defensively but
                            considers aggression impracticable.</p>
                        <p>Situation delicate and uncertain. Davis.’ ”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cunningham</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
