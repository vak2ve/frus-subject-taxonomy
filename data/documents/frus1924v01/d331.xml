                subtype="historical-document" type="document" xml:id="d331">
                <note rend="inline" type="source">893.00/5521: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName type="from">
                        <hi rend="italic">Bell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1924-09-14T19:00:00+08:00">
                            <hi rend="italic">September 14, 1924—7 p.m.</hi>
                        </date>
                        <lb/>[Received September 14—1:30 p.m.]</dateline>
                </opener>
                <p>Consul Mukden reports by telegraph heavy troop movements from Mukden southward in
                    last three days. I have no information that they have gone further south than
                    Great Wall.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
