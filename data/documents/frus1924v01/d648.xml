                subtype="historical-document" type="document" xml:id="d648">
                <note rend="inline" type="source">822.61334/148: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Ecuador</hi> (<persName type="from">
                        <hi rend="italic">Bading</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Quito</hi>
                        </placeName>, <date calendar="gregorian" when="1924-12-02T11:00:00-05:14">
                            <hi rend="italic">December 2, 1924—11 a.m.</hi>
                        </date>
                        <lb/>[Received December 3—9:10 a.m.]</dateline>
                </opener>
                <p>19. Department’s telegram November 26, 6 p.m. From sources believed to be
                    reliable it is learned that all debts to local banks and <hi rend="italic"
                        >vale</hi> holders have been paid except one <hi rend="italic">vale</hi> in
                    litigation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bading</hi>
                    </signed>
                </closer>
            </div>
        </body>
