<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1923-03-29T10:00:00-05:00" frus:doc-dateTime-min="1923-03-29T10:00:00-05:00" n="658" subtype="historical-document" type="document" xml:id="d658">
                        <note rend="inline" type="source">883.927/18: Telegram</note>
                        <head><hi rend="italic">The Minister in Egypt</hi> (<persName type="from"><hi rend="italic">Howell</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Cairo</hi></placeName>, <date calendar="gregorian" when="1923-03-29T17:00:00+02:00"><hi rend="italic">March 29,
                                        1923—5 p.m.</hi></date><lb/>[Received March 29—2:51
                                p.m.]</dateline></opener>
                        <p>9. Officially informed that antiquities law now prevailing will continue
                            season of 1923–24 permitting our museums to continue their work.</p>
                        <closer><signed><hi rend="smallcaps">Howell</hi></signed></closer>
                    </div>
                    </body></text></TEI>