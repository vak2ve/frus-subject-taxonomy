<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1924-02-05T12:00:00-05:00" frus:doc-dateTime-min="1924-02-05T12:00:00-05:00" n="176" subtype="historical-document" type="document" xml:id="d176">
                        <note rend="inline" type="source">811.2300/43: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from"><hi rend="italic">Kellogg</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1924-02-05T17:00:00+00:00"><hi rend="italic">February 5,
                                        1924—5 p.m.</hi></date><lb/>[Received February 5—2:57
                                p.m.]</dateline></opener>
                        <p>51. Your 10, January 18, 7 p.m.<note n="11" xml:id="d176fn11">Not
                                printed.</note> Foreign Office informs me that Canada has granted
                            permission for flight over her territory; will give all facilities asked
                            for.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>