<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1924-01-23T06:00:00-05:00" frus:doc-dateTime-min="1924-01-23T06:00:00-05:00" n="170" subtype="historical-document" type="document" xml:id="d170">
                        <note rend="inline" type="source">811.2300/30: Telegram</note>
                        <head><hi rend="italic">The Minister in Denmark</hi> (<persName type="from"><hi rend="italic">Prince</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Copenhagen</hi></placeName>, <date calendar="gregorian" when="1924-01-23T12:00:00+01:00"><hi rend="italic">January 23,
                                        1924—noon</hi></date>.<lb/>[Received January 23—9:20
                                a.m.]</dateline></opener>
                        <p>6. Department’s 3, January 18, 7 p.m.<note n="99" xml:id="d170fn99">Not
                                printed.</note> Am informed verbally by Director General of Foreign
                            Office that permission will be granted for requests as outlined. Written
                            confirmation to follow.</p>
                        <closer><signed><hi rend="smallcaps">Prince</hi></signed></closer>
                    </div>
                    </body></text></TEI>