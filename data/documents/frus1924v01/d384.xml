    <text>
        <body>
            <div frus:doc-dateTime-max="1924-10-25T23:59:59-05:00"
                frus:doc-dateTime-min="1924-10-25T00:00:00-05:00" n="384"
                subtype="historical-document" type="document" xml:id="d384">
                <note rend="inline" type="source">893.51/4709</note>
                <head>
                    <hi rend="italic">The British Ambassador</hi> (<persName type="from">
                        <hi rend="italic">Howard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1924-10-25">
                            <hi rend="italic">October 25, 1924</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 1006</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honour to inform you that His
                    Majesty’s Government have learnt that the Canton Government are again
                    threatening to seize the Customs House and to declare Canton a free port.</p>
                <p>I am directed by my Government to express the earnest hope that you will
                    authorize the United States Representative at Peking to concert with His
                    Majesty’s Representative in arranging for a renewal of the naval
                    demonstration.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Esme Howard</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
