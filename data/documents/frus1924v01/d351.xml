                subtype="historical-document" type="document" xml:id="d351">
                <note rend="inline" type="source">893.00/5691: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName type="from">
                        <hi rend="italic">Mayer</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1924-10-31T10:00:00+08:00">
                            <hi rend="italic">October 31, 1924—10 a.m.</hi>
                        </date>
                        <lb/>[Received October 31—2:42 a.m.]</dateline>
                </opener>
                <p>418. American consul Tientsin advises despatch of American naval vessel to
                    Tientsin to afford additional protection American life and property if
                    necessary. Ships of other nationalities now present. I have recommended to
                    commander in chief Asiatic Fleet accordingly.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Mayer</hi>
                    </signed>
                </closer>
            </div>
        </body>
