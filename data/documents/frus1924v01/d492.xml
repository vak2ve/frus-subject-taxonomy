<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1924-10-03T04:34:00-05:00" frus:doc-dateTime-min="1924-10-03T04:34:00-05:00" n="492" subtype="historical-document" type="document" xml:id="d492">
                        <note rend="inline" type="source">861.77/3660: Telegram</note>
                        <head><hi rend="italic">The Consul at Harbin</hi> (<persName type="from"><hi rend="italic">Hanson</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Harbin</hi></placeName>, <date calendar="gregorian" when="1924-10-03T18:00:00+08:26"><hi rend="italic">October 3,
                                        1924—6 p.m.</hi></date><lb/>[Received 8:50
                            p.m.]</dateline></opener>
                        <p>General Manager Ostroumoff arrested and imprisoned by Chinese police;
                            charges unknown. Informed the Legation and Mukden.</p>
                        <closer><signed><hi rend="smallcaps">Hanson</hi></signed></closer>
                    </div>
                    </body></text></TEI>