                subtype="historical-document" type="document" xml:id="d52">
                <note rend="inline" type="source">511.4 A 2/110: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Switzerland</hi> (<persName type="to">
                        <hi rend="italic">Gibson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1924-10-15T18:00:00-05:00">
                            <hi rend="italic">October 15, 1924—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>78. You may inform the Secretary General of the League of Nations in reply to his
                    telegram received today that the United States accepts the invitation to be
                    represented at the Opium Conference on the third Monday in November, 1924.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
