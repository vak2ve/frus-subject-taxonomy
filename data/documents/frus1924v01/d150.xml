<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1923-08-01T11:00:00-05:00" frus:doc-dateTime-min="1923-08-01T11:00:00-05:00" n="150" subtype="historical-document" type="document" xml:id="d150">
                        <note rend="inline" type="source">811.2300/1: Telegram</note>
                        <head><hi rend="italic">The Minister in Denmark</hi> (<persName type="from"><hi rend="italic">Prince</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Copenhagen</hi></placeName>, <date calendar="gregorian" when="1923-08-01T17:00:00+01:00"><hi rend="italic">August 1,
                                        1923—5 p.m.</hi></date><lb/>[Received August 1—1:53
                                p.m.]</dateline></opener>
                        <p>26. Department’s telegram 20, July 17, 2 p.m. Danish Foreign Office
                            informs me that Icelandic Government has granted permission for proposed
                            investigation by War Department.</p>
                        <closer><signed><hi rend="smallcaps">Prince</hi></signed></closer>
                    </div>
