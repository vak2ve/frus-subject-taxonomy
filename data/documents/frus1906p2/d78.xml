                subtype="historical-document" type="document" xml:id="d78">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                        Ambassador <persName type="to">White</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1906-01-20">
                            <hi rend="italic">January 20, 1906</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Root instructs Mr. White upon his return to Rome to sign agricultural
                    convention, subject to advice and the consent of Senate and enactment of
                    legislation by Congress to give it effect so far as concerns the United
                    States.)</p>
            </div>
