    <text>
        <body>
            <div frus:doc-dateTime-max="1906-02-06T23:59:59-05:00"
                frus:doc-dateTime-min="1906-02-06T00:00:00-05:00" n="233"
                subtype="historical-document" type="document" xml:id="d233">
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Chargé <persName type="to">McCreery</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1906-02-06">
                            <hi rend="italic">February 6, 1906</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 97.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I inclose herewith a copy of a letter<note n="a"
                        xml:id="d233fna">Not printed.</note> from Mr. G. T. Moeskes, asking if two
                    bonds, of which he gives a description and which were issued by the Mexican
                    Empire in 1864, are redeemable by the Mexican treasury.</p>
                <p>You will make informal inquiry in regard to the matter and report to the
                    department.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Bacon.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
