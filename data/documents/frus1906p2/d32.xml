    <text>
        <body>
            <div frus:doc-dateTime-max="1906-04-02T23:59:59-05:00"
                frus:doc-dateTime-min="1906-04-02T00:00:00-05:00" n="32"
                subtype="historical-document" type="document" xml:id="d32">
                <head>
                    <hi rend="italic">Minister <persName type="from">Furniss</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1906-04-02">
                            <hi rend="italic">April 2, 1906</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 46.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In further reference to my No. 33, of March 12, I
                    have to inform the department that the convention between France and Haiti for
                    the prolongation of the treaty therein mentioned was signed on the 31st ultimo
                    by Minister Bezaure and Secretary Férère.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">H. W. Furniss.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
