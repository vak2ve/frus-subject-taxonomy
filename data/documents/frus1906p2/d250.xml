    <text>
        <body>
            <div frus:doc-dateTime-max="1906-05-23T23:59:59-05:00"
                frus:doc-dateTime-min="1906-05-23T00:00:00-05:00" n="250"
                subtype="historical-document" type="document" xml:id="d250">
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Ambassador <persName type="to">Thompson</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1906-05-23">
                            <hi rend="italic">May 23, 1906</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 36.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I inclose herewith for your information in
                    connection with previous correspondence on the subject, a copy of a letter from
                    Mr. C. W. Burket,<note n="a" xml:id="d250fna">Not printed.</note> general
                    manager of the Ures Consolidated Mining Company, in relation to the depredations
                    of the Yaqui Indians in Mexico.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Bacon.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
