                subtype="historical-document" type="document" xml:id="d382">
                <head>
                    <hi rend="italic">Chargé <persName type="from">Eddy</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">St. Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1906-08-23">
                            <hi rend="italic">August 23, 1906</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 634.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I beg leave to confirm herewith my cablegram of
                    to-day sent en clair, as follows: <quote rend="blockquote">
                        <p>All strikes concluded, Reval; factories have resumed work.</p>
                    </quote>
                </p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Spencer Eddy</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
