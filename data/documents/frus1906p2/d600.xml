    <text>
        <body>
            <div frus:doc-dateTime-max="1906-04-07T23:59:59-05:00"
                frus:doc-dateTime-min="1906-04-07T00:00:00-05:00" n="600"
                subtype="historical-document" type="document" xml:id="d600">
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">Argentine Minister</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1906-04-07">
                            <hi rend="italic">April 7, 1906</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I beg to inclose for your information a copy of a
                        correspondence<note n="a" xml:id="d600fna">Notes of April 3 and 6 from and
                        to the Russian Embassy, supra.</note> between the Russian ambassador at
                    Washington and the Secretary of State in regard to the proposed convoking of the
                    Second Conference at The Hague during the first half of the month of July
                    next.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Bacon.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>Same to all the diplomatic representatives of American Republics.</p>
                </postscript>
            </div>
        </body>
    </text>
