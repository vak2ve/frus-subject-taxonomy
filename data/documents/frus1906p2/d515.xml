<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1906-10-01T23:59:59-05:00" frus:doc-dateTime-min="1906-10-01T00:00:00-05:00" n="515" subtype="historical-document" type="document" xml:id="d515">
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">O’Brien</persName></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1906-10-01"><hi rend="italic">October 1,
                                1906</hi></date>.</dateline></opener>
                        <p>Advise Government of Uruguay<note n="a" xml:id="d515fna">Same, mutatis
                                mutandis, to American diplomatic representatives in Argentine
                                Republic, Brazil, Chile, Colombia, Peru, and Panama.</note> of safe
                            arrival of myself and family at Washington, and convey my salutation and
                            sincere good wishes.</p>
                        <closer><signed><hi rend="smallcaps">Root.</hi></signed></closer>
                    </div>
                </body></text></TEI>