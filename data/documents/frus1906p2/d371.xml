                subtype="historical-document" type="document" xml:id="d371">
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Meyer</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">St. Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1906-01-01">
                            <hi rend="italic">January 1, 1906</hi>
                        </date>.</dateline>
                </opener>
                <p>Consul Smith in Moscow reports to-day by telephone that everything is quieting
                    down; barricades being removed; streets regaining normal condition. American
                    consulate has not been disturbed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Meyer.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
