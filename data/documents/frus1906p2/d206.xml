    <text>
        <body>
            <div frus:doc-dateTime-max="1906-09-28T23:59:59-05:00"
                frus:doc-dateTime-min="1906-09-28T00:00:00-05:00" n="206"
                subtype="historical-document" type="document" xml:id="d206">
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Ambassador <persName type="to">Thompson</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1906-09-28">
                            <hi rend="italic">September 28, 1906</hi>.</date>
                    </dateline>
                </opener>
                <p>Referring to your telegram, 13th instant, case of the schooner <hi rend="italic"
                        >Hatteras</hi>. Please forward to department copy of paragraph 2, article 5,
                    of Mexican law of December 18, 1902. If paragraph is not too lengthy you may
                    forward it by telegraph.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Adee.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
