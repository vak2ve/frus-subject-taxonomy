                subtype="historical-document" type="document" xml:id="d281">
                <head>
                    <hi rend="italic">Minister <persName type="from">Hill</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">The Hague, Netherlands</hi>
                        </placeName>, <date calendar="gregorian" when="1906-07-24">
                            <hi rend="italic">July 24, 1906</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 102.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to state that the Netherlands
                    Official Gazette of this date announces that the exchange of the acts of
                    ratification of the extradition treaty between the Netherlands and Greece of the
                    26th of August, 1905, took place at Athens on the 20th of July, 1906.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">David J. Hill.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
