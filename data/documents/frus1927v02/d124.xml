                subtype="historical-document" type="document" xml:id="d124">
                <note rend="inline" type="source">893.00/9402: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in China</hi> (<persName type="to">
                        <hi rend="italic">Mayer</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1927-09-10T13:00:00-04:00">
                            <hi rend="italic">September 10, 1927—1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>341. Your No. 862, September 8, 4 p.m. Merely send the Foreign Office a
                    third-person acknowledgment stating that contents of the note relating to
                    withdrawing of troops have been communicated to your Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
