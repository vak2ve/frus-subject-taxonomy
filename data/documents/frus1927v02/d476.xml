                <note rend="inline" type="source">893.512/680: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in China</hi> (<persName type="to">
                        <hi rend="italic">Mayer</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1927-10-01T16:00:00-05:00">
                            <hi rend="italic">October 1, 1927—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>354. Your 896, September 29, 11 a.m. You are authorized to interpose no objection
                    to the proposed surtax provided other interested Legations take similar
                    stand.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
