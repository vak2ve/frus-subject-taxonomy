                subtype="historical-document" type="document" xml:id="d126">
                <note rend="inline" type="source">893.00/9603: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName type="from">
                        <hi rend="italic">Mayer</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1927-11-21T16:00:00+08:00">
                            <hi rend="italic">November 21, 1927—4 p.m.</hi>
                        </date>
                        <lb/>[Received November 21—1:45 p.m.]</dateline>
                </opener>
                <p>1016. Following from commander in chief: <quote rend="blockquote">
                        <p>“The landing party sent ashore from United States Ship <hi rend="italic"
                                >Asheville</hi> at Yeungkong, Kwangtung, on 18th November reported
                            there had been small disturbance ashore and few shots fired at Catholic
                            mission but Presbyterian mission not attacked. All Americans safe.
                            Yangtze quiet.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Mayer</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
