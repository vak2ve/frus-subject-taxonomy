                subtype="historical-document" type="document" xml:id="d134">
                <note rend="inline" type="source">393.1123/5: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">MacMurray</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1927-03-28T15:00:00+08:00">
                            <hi rend="italic">March 28, 1927—3 p.m.</hi>
                        </date>
                        <lb/>[Received March 28—9:20 a.m.]</dateline>
                </opener>
                <p>270. Following received from American consul general Hankow: <quote
                        rend="blockquote">
                        <p>“March 26, 6 p.m. Ch’en desires me to convey to you his sincere regret
                            for the loss of American life at Nanking ‘regardless whether <pb
                                facs="0259" n="151" xml:id="pg_151"/> acts were committed by
                            Nationalist or Northern troops’. He asks me to say he will issue
                            statement as soon as facts definitely established.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">MacMurray</hi>
                    </signed>
                </closer>
            </div>
        </body>
