                subtype="historical-document" type="document" xml:id="d353">
                <note rend="inline" type="source">393.11/674: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">MacMurray</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1927-06-18T13:00:00+08:00">
                            <hi rend="italic">June 18, 1927—1 p.m.</hi>
                        </date>
                        <lb/>[Received June 18—7:12 a.m.]</dateline>
                </opener>
                <p>656. Your 257, June 16, 6 p.m. I have instructed Jacobs June 17, 4 p.m., in
                    accordance with paragraph No. 2 of the Legation’s 646, June 16, 4 p.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">MacMurray</hi>
                    </signed>
                </closer>
            </div>
        </body>
