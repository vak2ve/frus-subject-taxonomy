<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-04-29T17:00:00-05:00" frus:doc-dateTime-min="1927-04-29T17:00:00-05:00" n="335" subtype="historical-document" type="document" xml:id="d335">
                        <note rend="inline" type="source">393.1163/171: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Consul General at Shanghai</hi> (<persName type="to"><hi rend="italic">Gauss</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1927-04-29T18:00:00-04:00"><hi rend="italic">April 29,
                                        1927—6 p.m.</hi></date></dateline></opener>
                        <p>Your April 16, 4 p.m. Department informed Mission has telegraphed
                            missionaries to conform with your recommendations.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>