                subtype="historical-document" type="document" xml:id="d239">
                <note rend="inline" type="source">393.11/425; Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName type="from">
                        <hi rend="italic">Mayer</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1927-01-26T11:00:00+08:00">
                            <hi rend="italic">January 26, 1927—11 a.m.</hi>
                        </date>
                        <lb/>[Received January 27—10:30 a.m.]</dateline>
                </opener>
                <p>83. Following from Canton: <quote rend="blockquote">
                        <p>“I am discreetly advising Americans in the interior to leave for places
                            of safety. This includes Canton and environs.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Mayer</hi>
                    </signed>
                </closer>
            </div>
        </body>
