                subtype="historical-document" type="document" xml:id="d163">
                <note rend="inline" type="source">893.00 Nanking/62: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">MacMurray</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1927-04-11T14:00:00+08:00">
                            <hi rend="italic">April 11, 1927—2 p.m.</hi>
                        </date>
                        <lb/>[Received April 11—3:45 a.m.]</dateline>
                </opener>
                <p>405. Following from American consul, Shanghai: <quote rend="blockquote">
                        <p>“5. April 9, 8 p.m. Chiang Kai-shek left for Nanking this morning.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">MacMurray</hi>
                    </signed>
                </closer>
            </div>
        </body>
