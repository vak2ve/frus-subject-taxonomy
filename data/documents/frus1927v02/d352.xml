<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-06-16T17:00:00-05:00" frus:doc-dateTime-min="1927-06-16T17:00:00-05:00" n="352" subtype="historical-document" type="document" xml:id="d352">
                        <note rend="inline" type="source">393.11/673: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in China</hi> (<persName type="to"><hi rend="italic">MacMurray</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1927-06-16T18:00:00-04:00"><hi rend="italic">June 16,
                                        1927—6 p.m.</hi></date></dateline></opener>
                        <p>257. Your 646, June 16, 4 p.m. You are authorized to instruct Jacobs at
                            Yunnanfu as requested in paragraph 2 of your telegram. See Department’s
                            224, May 18, 4 p.m.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>