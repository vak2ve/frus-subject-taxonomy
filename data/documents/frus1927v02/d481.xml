                subtype="historical-document" type="document" xml:id="d481">
                <note rend="inline" type="source">893.512/688: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from">
                        <hi rend="italic">Cunningham</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1927-10-05T14:00:00+08:00">
                            <hi rend="italic">October 5, 1927—2 p.m.</hi>
                        </date>
                        <lb/>[Received October 5—6:02 a.m.]</dateline>
                </opener>
                <p>Your October 4, 6 p.m. Will accept only treaty duties of five percent plus
                    wharfage and Whangpoo Conservancy taxes.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cunningham</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
