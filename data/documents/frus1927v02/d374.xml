                subtype="historical-document" type="document" xml:id="d374">
                <note rend="inline" type="source">893.00/8739: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">MacMurray</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1927-04-21T23:00:00+08:00">
                            <hi rend="italic">April 21, 1927—11 p.m.</hi>
                        </date>
                        <lb/>[Received April 21—3:37 p.m.]</dateline>
                </opener>
                <p>469. My 390, April 9, 1 p.m. Detachments from the Legation guards (American,
                    British, Italian and Japanese) today took over the defense of the wall formerly
                    defended by the Russian Legation guard.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">MacMurray</hi>
                    </signed>
                </closer>
            </div>
        </body>
