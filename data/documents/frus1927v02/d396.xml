                subtype="historical-document" type="document" xml:id="d396">
                <note rend="inline" type="source">893.8007/33: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">MacMurray</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1927-12-06T15:00:00+08:00">
                            <hi rend="italic">December 6, 1927—3 p.m.</hi>
                        </date>
                        <lb/>[Received December 6—7:55 a.m.]</dateline>
                </opener>
                <p>1069. Legation’s 1045 of November 29, noon.</p>
                <list>
                    <label>1.</label>
                    <item>It is stated by the Japanese Minister that his Government agrees to the
                        arrangements as explained in the Legation’s telegram mentioned above,
                        paragraph 8, the last two sentences.</item>
                    <label>2.</label>
                    <item>According to instructions received by the French Minister from his
                        Government, he is authorized to join with his colleagues concerned in the
                        proposed plan for dealing with the question of piracy.</item>
                </list>
                <closer>
                    <signed>
                        <hi rend="smallcaps">MacMurray</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
