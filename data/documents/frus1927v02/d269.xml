                <note rend="inline" type="source">393.11/499: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Mukden</hi> (<persName type="from">
                        <hi rend="italic">Sokobin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mukden</hi>
                        </placeName>, <date calendar="gregorian" when="1927-03-28T09:00:00+08:00">
                            <hi rend="italic">March 28, 1927—9 a.m.</hi>
                        </date>
                        <lb/>[Received March 28—6:08 a.m.]</dateline>
                </opener>
                <p>I venture to suggest full publicity be given to the fact that Americans in
                    Manchuria are in nowise affected by the events in the Yangtze Valley; situation
                    here absolutely normal.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sokobin</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
