                subtype="historical-document" type="document" xml:id="d332">
                <note rend="inline" type="source">393.11/613: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Amoy</hi> (<persName type="from">
                        <hi rend="italic">Putnam</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Amoy</hi>
                        </placeName>, <date calendar="gregorian" when="1927-04-26T20:00:00+08:00">
                            <hi rend="italic">April 26, 1927—8 p.m.</hi>
                        </date>
                        <lb/>[Received April 25—3:15 p.m.]</dateline>
                </opener>
                <p>All Americans have come in from the interior. Conditions throughout consular
                    district quiet except for bandits in some sections.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Putnam</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
