<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-06-29T23:59:59-05:00" frus:doc-dateTime-min="1927-06-29T00:00:00-05:00" n="676" subtype="historical-document" type="document" xml:id="d676">
                        <note rend="inline" type="source">711.5112 France/35</note>
                        <head><hi rend="italic">President <persName type="from">Coolidge</persName>
                                to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Rapid
                                        City, S. Dak.</hi></placeName>, <date calendar="gregorian" when="1927-06-29"><hi rend="italic">June 29,
                                1927</hi></date>.<lb/>[Received July 5.]</dateline></opener>
                        <p><hi rend="smallcaps">My Dear Mr. Secretary</hi>: Thank you for your
                            letter of the 27th, which I have read with care. I approve of the
                            conclusions you have reached.</p>
                        <p>Very truly yours,</p>
                        <closer><signed><hi rend="smallcaps">Calvin Coolidge</hi></signed></closer>
                    </div>
                    </body></text></TEI>