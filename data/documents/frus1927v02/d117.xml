                subtype="historical-document" type="document" xml:id="d117">
                <note rend="inline" type="source">893.00/9141½</note>
                <head>
                    <hi rend="italic">President <persName type="from">Coolidge</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rapid City, S. Dak.</hi>
                        </placeName>, <date calendar="gregorian" when="1927-06-23">
                            <hi rend="italic">June 23, 1927</hi>
                        </date>.<lb/>[Received June 27.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: I have your letter, together
                    with the substance of the recent dispatch from Minister MacMurray. I approve the
                    suggestions made by the Minister and referred to in your own letter, subject of
                    course to your judgment on them.</p>
                <p>Very truly yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Calvin Coolidge</hi>
                    </signed>
                </closer>
            </div>
        </body>
