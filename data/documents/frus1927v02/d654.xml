<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-11-07T03:00:00-05:00" frus:doc-dateTime-min="1927-11-07T03:00:00-05:00" n="654" subtype="historical-document" type="document" xml:id="d654">
                        <note rend="inline" type="source">884.6461 Tsana Dam/17: Telegram</note>
                        <head><hi rend="italic">The Chargé in Egypt</hi> (<persName type="from"><hi rend="italic">Winship</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Cairo</hi></placeName>, <date calendar="gregorian" when="1927-11-07T10:00:00+02:00"><hi rend="italic">November 7,
                                        1927—10 a.m.</hi></date><lb/>[Received November 7—7:54
                                a.m.]</dateline></opener>
                        <p>8. Alleged contract of White Company for Tsana Dam has aroused great
                            local interest and numerous inquiries indicate anxiety.</p>
                        <closer><signed><hi rend="smallcaps">Winship</hi></signed></closer>
                    </div>
                    </body></text></TEI>