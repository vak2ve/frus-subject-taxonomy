<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-06-22T06:00:00-05:00" frus:doc-dateTime-min="1928-06-22T06:00:00-05:00" n="668" subtype="historical-document" type="document" xml:id="d668">
                        <note rend="inline" type="source">711.532/3: Telegram</note>
                        <head><hi rend="italic">The Minister in Portugal</hi> (<persName type="from"><hi rend="italic">Dearing</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Lisbon</hi></placeName>, <date calendar="gregorian" when="1928-06-22T12:00:00+01:00"><hi rend="italic">June 22,
                                        1928—noon</hi></date>.<lb/>[Received June 22—10:15
                                a.m.]</dateline></opener>
                        <p>25. Department’s instruction number 898, April 11. Minister for Foreign
                            Affairs desires to examine draft treaty. Please send.</p>
                        <closer><signed><hi rend="smallcaps">Dearing</hi></signed></closer>
                    </div>
