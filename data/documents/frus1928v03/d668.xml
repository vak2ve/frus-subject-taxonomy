                <note rend="inline" type="source">711.532/3: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Portugal</hi> (<persName type="from">
                        <hi rend="italic">Dearing</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lisbon</hi>
                        </placeName>, <date calendar="gregorian" when="1928-06-22T12:00:00+01:00">
                            <hi rend="italic">June 22, 1928—noon</hi>
                        </date>.<lb/>[Received June 22—10:15 a.m.]</dateline>
                </opener>
                <p>25. Department’s instruction number 898, April 11. Minister for Foreign Affairs
                    desires to examine draft treaty. Please send.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dearing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
