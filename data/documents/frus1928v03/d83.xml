                subtype="historical-document" type="document" xml:id="d83">
                <note rend="inline" type="source">815.00/4332: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Honduras</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1928-12-29T11:00:00-06:00">
                            <hi rend="italic">December 29, 1928—11 a.m.</hi>
                        </date>
                        <lb/>[Received 4:05 p.m.]</dateline>
                </opener>
                <p>148. My telegram No. 146 of December 24, 11 a.m. Political situation appears to
                    have improved greatly in the past few days with noticeable diminution of
                    official and public anxiety and apprehension of trouble.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
