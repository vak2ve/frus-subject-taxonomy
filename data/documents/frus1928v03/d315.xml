                subtype="historical-document" type="document" xml:id="d315">
                <note rend="inline" type="source">856d.6363/525: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in the Netherlands</hi> (<persName type="from">
                        <hi rend="italic">Tobin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Hague</hi>
                        </placeName>, <date calendar="gregorian" when="1928-04-10T16:00:00+00:19">
                            <hi rend="italic">April 10, 1928—4 p.m.</hi>
                        </date>
                        <lb/>[Received 4:13 p.m.]</dateline>
                </opener>
                <p>16. Department’s telegram No. 10, March 28, 7 p.m. Foreign Office assures me that
                    signature of bill granting concessions may soon be expected.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Tobin</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
