                subtype="historical-document" type="document" xml:id="d360">
                <note rend="inline" type="source">817.00/5296: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Nicaragua</hi> (<persName type="to">
                        <hi rend="italic">Munro</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-01-22T13:00:00-05:00">
                            <hi rend="italic">January 22, 1928—1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>26. The following telegram has been received from Habana:</p>
                <p>[Here follows the text of telegram No. 13, January 21, 1928, 9 p.m., from the
                    Chairman of the American Delegation to the Sixth International Conference of
                    American States to the Secretary of State, printed <hi rend="italic"
                    >supra.</hi>]</p>
                <pb facs="0557" n="447" xml:id="pg_447"/>
                <p>The Department would be pleased to receive your comment on these suggestions.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
