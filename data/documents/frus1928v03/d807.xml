<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-02-14T13:00:00-05:00" frus:doc-dateTime-min="1928-02-14T13:00:00-05:00" n="807" subtype="historical-document" type="document" xml:id="d807">
                        <note rend="inline" type="source">367.1164 Brusa School Trial/16:
                            Telegram</note>
                        <head><hi rend="italic">The Ambassador in Turkey</hi> (<persName type="from"><hi rend="italic">Grew</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Constantinople</hi></placeName>, <date calendar="gregorian" when="1928-02-14T20:00:00+02:00"><hi rend="italic">February 14,
                                        1928—8 p.m.</hi></date><lb/>[Received February 14—5:45
                                p.m.]</dateline></opener>
                        <p>19. Department’s 13, February 9, 6 p.m. Four pupil witnesses heard today.
                            Hearings postponed until March 5. Goodsell optimistic.</p>
                        <closer><signed><hi rend="smallcaps">Grew</hi></signed></closer>
                    </div>
                    </body></text></TEI>