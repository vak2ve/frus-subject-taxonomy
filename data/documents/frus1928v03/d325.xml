                subtype="historical-document" type="document" xml:id="d325">
                <note rend="inline" type="source">856d.6363/544: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in the Netherlands</hi> (<persName type="from">
                        <hi rend="italic">Tobin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Hague</hi>
                        </placeName>, <date calendar="gregorian" when="1928-07-17T16:00:00+01:19">
                            <hi rend="italic">July 17, 1928—4 p.m.</hi>
                        </date>
                        <lb/>[Received July 17—12:55 p.m.]</dateline>
                </opener>
                <p>35. My 34, July 7, 3 p.m.<note n="21" xml:id="d325fn21">Not printed.</note>
                    Minister for the Colonies has today signed and delivered Koloniale [Petroleum
                    Company] contracts.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Tobin</hi>
                    </signed>
                </closer>
            </div>
        </body>
