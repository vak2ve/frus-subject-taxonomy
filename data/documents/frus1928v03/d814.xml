                <note rend="inline" type="source">367.1164 Brusa School Trial/50: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Turkey</hi> (<persName type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Constantinople</hi>
                        </placeName>, <date calendar="gregorian" when="1928-08-30T17:00:00+02:00">
                            <hi rend="italic">August 30, 1928—5 p.m.</hi>
                        </date>
                        <lb/>[Received August 31—1:20 a.m.]</dateline>
                </opener>
                <p>104. Press today announces that on account of questions of procedure Court of
                    Appeals has annulled judgment against American teachers of Brusa School and that
                    case will be heard again.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
