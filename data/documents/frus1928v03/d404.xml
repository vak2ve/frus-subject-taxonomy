                subtype="historical-document" type="document" xml:id="d404">
                <note rend="inline" type="source">817.00/5485: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Eberhardt</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1928-03-20T12:00:00-05:45">
                            <hi rend="italic">March 20, 1928—noon</hi>
                        </date>.<lb/>[Received 3:43 p.m.]</dateline>
                </opener>
                <p>138. General McCoy took oath of office as Chairman of the National Board of
                    Elections this morning before the Supreme Court.</p>
                <p>[Paraphrase.] General McCoy and I hope to have the decree issued on March 21.
                    [End paraphrase.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Eberhardt</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
