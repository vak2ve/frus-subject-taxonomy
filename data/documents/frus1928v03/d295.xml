                <note rend="inline" type="source">881.00/1382: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Spain</hi> (<persName type="to">
                        <hi rend="italic">Hammond</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-03-07T17:00:00-05:00">
                            <hi rend="italic">March 7, 1928—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>24. Your 33, March 5, 11 a.m. Department perceives no objection to your
                    discussing Moroccan matters with Primo on the basis of its 21, February 29, 3
                    p.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
