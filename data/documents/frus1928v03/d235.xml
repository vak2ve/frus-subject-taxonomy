                subtype="historical-document" type="document" xml:id="d235">
                <note rend="inline" type="source">812.6363/2480: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Mexico</hi> (<persName type="to">
                        <hi rend="italic">Schoenfeld</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-01-13T15:00:00-05:00">
                            <hi rend="italic">January 13, 1928—3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>12. Your telegrams Nos. 23, January 12, noon, and 24, January 12, 2 p.m. The
                    Department is giving a statement to the press based upon the above-mentioned
                    telegrams.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
