<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-04-18T15:00:00-05:00" frus:doc-dateTime-min="1928-04-18T15:00:00-05:00" n="164" subtype="historical-document" type="document" xml:id="d164">
                        <note rend="inline" type="source">711.60p2/32: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Latvia</hi> (<persName type="to"><hi rend="italic">Coleman</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1928-04-18T15:00:00-05:00"><hi rend="italic">April 18,
                                        1928—3 p.m.</hi></date></dateline></opener>
                        <p>24. Your 35, April 17th, noon. You are authorized to sign the Treaty of
                            Friendship, Commerce and Consular Rights.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>