<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-11-22T03:00:00-05:00" frus:doc-dateTime-min="1928-11-22T03:00:00-05:00" n="184" subtype="historical-document" type="document" xml:id="d184">
                        <note rend="inline" type="source">860p.512 Residence/9: Telegram</note>
                        <head><hi rend="italic">The Chargé in Latvia</hi> (<persName type="from"><hi rend="italic">Sussdorff</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Riga</hi></placeName>, <date calendar="gregorian" when="1928-11-22T10:00:00+02:00"><hi rend="italic">November 22,
                                        1928—10 a.m.</hi></date><lb/>[Received November 22—9:10
                                a.m.]</dateline></opener>
                        <p>95. Your 68, November 21, 6 p.m. Tax in question does not apply to
                            Latvian nationals.</p>
                        <closer><signed><hi rend="smallcaps">Sussdorff</hi></signed></closer>
                    </div>
