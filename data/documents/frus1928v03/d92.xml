<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-05-09T19:00:00-05:00" frus:doc-dateTime-min="1928-05-09T19:00:00-05:00" n="92" subtype="historical-document" type="document" xml:id="d92">
                        <note rend="inline" type="source">714.1515/657: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Costa Rica</hi> (<persName type="to"><hi rend="italic">Davis</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1928-05-09T20:00:00-04:00"><hi rend="italic">May 9, 1928—8
                                        p.m.</hi></date></dateline></opener>
                        <p>17. Your 27, May 8, 11 a.m. You may inform the Minister for Foreign
                            Affairs that the Department deeply appreciates his courteous action in
                            making this statement.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>