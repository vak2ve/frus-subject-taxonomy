<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-02-17T10:00:00-05:00" frus:doc-dateTime-min="1928-02-17T10:00:00-05:00" n="25" subtype="historical-document" type="document" xml:id="d25">
                        <note rend="inline" type="source">711.682 (1928)/3: Telegram</note>
                        <head><hi rend="italic">The Minister in Greece</hi> (<persName type="from"><hi rend="italic">Skinner</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Athens</hi></placeName>, <date calendar="gregorian" when="1928-02-17T17:00:00+02:00"><hi rend="italic">February 17,
                                        1928—5 p.m.</hi></date><lb/>[Received February 17—1:40
                                p.m.]</dateline></opener>
                        <p>12. Department’s 12, February 7 [<hi rend="italic">8</hi>], 6 p.m. Greek
                            Government accepts suggestion that commercial treaty be negotiated here
                            and invites draft proposals.</p>
                        <closer><signed><hi rend="smallcaps">Skinner</hi></signed></closer>
                    </div>
