                subtype="historical-document" type="document" xml:id="d264">
                <note rend="inline" type="source">811.71212/66: Telegram</note>
                <head>
                    <hi rend="italic">President <persName type="from">Calles</persName> to President
                            <persName type="to">Coolidge</persName>
                    </hi>
                    <note n="45" xml:id="d264fn45">Received in the Department of State October
                        3.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Translation<note n="46" xml:id="d264fn46">File
                            translation revised.</note>]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1928-10-01T11:30:00-06:00">
                            <hi rend="italic">October 1, 1928—11:30 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>I congratulate Your Excellency most cordially on the establishment of the air
                    mail service between our countries, which, being initiated today, now marks a
                    new spirit looking toward better relations between the peoples of Mexico and the
                    United States.</p>
                <closer>
                    <signed>P[<hi rend="smallcaps">lutarco</hi>] <hi rend="smallcaps">Elias
                            Calles</hi>
                    </signed>
                </closer>
            </div>
        </body>
