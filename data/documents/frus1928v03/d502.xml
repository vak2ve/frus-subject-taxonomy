                subtype="historical-document" type="document" xml:id="d502">
                <note rend="inline" type="source">817.00/5433: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Eberhardt</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1928-02-28T14:00:00-05:45">
                            <hi rend="italic">February 28, 1928—2 p.m.</hi>
                        </date>
                        <lb/>[Received 6:05 p.m.]</dateline>
                </opener>
                <p>99. For advance and confidential information: Air patrol returning to Managua
                    this noon reports an attack last night upon pack train returning from Yalito
                    Condega in which marines suffered some casualties. Details will be furnished as
                    soon as they can be ascertained.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Eberhardt</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
