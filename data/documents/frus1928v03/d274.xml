<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-04-26T05:41:00-05:00" frus:doc-dateTime-min="1928-04-26T05:41:00-05:00" n="274" subtype="historical-document" type="document" xml:id="d274">
                        <note rend="inline" type="source">411.12P/408: Telegram</note>
                        <head><hi rend="italic">The Minister in the Netherlands</hi> (<persName type="from"><hi rend="italic">Tobin</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">The
                                        Hague</hi></placeName>, <date calendar="gregorian" when="1928-04-26T11:00:00+00:19"><hi rend="italic">April 26,
                                        1928—11 a.m.</hi></date><lb/>[Received April 26—7:52
                                a.m.]</dateline></opener>
                        <p>17. Department’s 13, April 23, 9 p.m. Foreign Minister<note n="58" xml:id="d274fn58">The Netherlands Minister for Foreign Affairs acts
                                as President of the Permanent Administrative Council. See art. XLIX
                                of the convention of October 18, 1907, <ref target="frus1907p2#pg_1191"><hi rend="italic">ibid.</hi>, 1907,
                                    pt. 2, p. 1191</ref>.</note> has accepted.</p>
                        <closer><signed><hi rend="smallcaps">Tobin</hi></signed></closer>
                    </div>
