                subtype="historical-document" type="document" xml:id="d433">
                <note rend="inline" type="source">817.00/5904: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Eberhardt</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1928-08-10T10:00:00-05:45">
                            <hi rend="italic">August 10, 1928—10 a.m.</hi>
                        </date>
                        <lb/>[Received 2:15 p.m.]</dateline>
                </opener>
                <p>306. Medrano, candidate Vice Presidency, has resigned on account of serious
                    illness.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Eberhardt</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
