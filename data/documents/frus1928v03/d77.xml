                subtype="historical-document" type="document" xml:id="d77">
                <note rend="inline" type="source">815.00/4278a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Honduras</hi> (<persName type="to">
                        <hi rend="italic">Summerlin</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-10-27T17:00:00-05:00">
                            <hi rend="italic">October 27, 1928—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>95. Your 125, October 26 noon. Navy Department states USS <hi rend="italic"
                        >Cleveland</hi> will remain Puerto Cortes for additional period. Cable your
                    opinion regarding earliest practicable day upon which vessel should depart.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
