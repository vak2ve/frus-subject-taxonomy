                <note rend="inline" type="source">817.00/5978: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Costa Rica</hi> (<persName type="to">
                        <hi rend="italic">De Lambert</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-09-14T16:00:00-04:00">
                            <hi rend="italic">September 14, 1928—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>30. Your 60, September 13, 5 p.m. Please watch developments carefully and keep
                    the Department and the Legation at Managua fully informed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
