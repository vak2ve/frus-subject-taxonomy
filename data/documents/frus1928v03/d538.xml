<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-09-14T15:00:00-05:00" frus:doc-dateTime-min="1928-09-14T15:00:00-05:00" n="538" subtype="historical-document" type="document" xml:id="d538">
                        <note rend="inline" type="source">817.00/5978: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in Costa Rica</hi> (<persName type="to"><hi rend="italic">De Lambert</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1928-09-14T16:00:00-04:00"><hi rend="italic">September 14,
                                        1928—4 p.m.</hi></date></dateline></opener>
                        <p>30. Your 60, September 13, 5 p.m. Please watch developments carefully and
                            keep the Department and the Legation at Managua fully informed.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>