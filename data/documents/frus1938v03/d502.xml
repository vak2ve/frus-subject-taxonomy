                subtype="historical-document" type="document" xml:id="d502">
                <note rend="inline" type="source">793.94/12975: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Geneva</hi> (<persName type="from">
                        <hi rend="italic">Bucknell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Geneva</hi>
                        </placeName>, <date calendar="gregorian" when="1938-05-07T11:00:00+01:00"
                            >May 7, 1938—11 a.m.</date>
                        <lb/>[Received May 7—9:10 a.m.]</dateline>
                </opener>
                <p>79. Secretary General has received a note from Chinese permanent delegate
                    bringing up the nature of Japanese outrages in Sino-Japanese conflict. Hoo asks
                    that this be circulated to members of the League and to members of the Far
                    Eastern Advisory Committee.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bucknell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
