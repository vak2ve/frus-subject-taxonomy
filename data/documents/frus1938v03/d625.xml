                subtype="historical-document" type="document" xml:id="d625">
                <note rend="inline" type="source">793.94116/50: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1938-06-08T11:00:00+09:00"
                            >June 8, 1938—11 a.m.</date>
                        <lb/>[Received June 7—10:41 p.m.]</dateline>
                </opener>
                <p>364. Our 359, June 6, 6 p.m.<note n="15" xml:id="d625fn15">Not printed.</note> My
                    French colleague now informs me that he has presented an <hi rend="italic"
                        >aide-mémoire</hi> to the Japanese Government protesting vigorously against
                    the bombing of the French hospital at Canton.</p>
                <p>Copy by mail.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
