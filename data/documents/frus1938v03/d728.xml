<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1938-05-03T17:00:00-05:00" frus:doc-dateTime-min="1938-05-03T17:00:00-05:00" n="728" subtype="historical-document" type="document" xml:id="d728">
                        <note rend="inline" type="source">693.002/629: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in China</hi> (<persName type="to"><hi rend="italic">Johnson</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1938-05-03T18:00:00-04:00">May 3, 1938—6
                                p.m.</date></dateline>
                        </opener>
                        <p>138. Your 231, May 3, 11 a.m. The Department approves the reply made by
                            you to the Counselor of the British Embassy. Please repeat to Tokyo
                            through Shanghai.</p>
                        <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                    </div>
                    </body></text></TEI>