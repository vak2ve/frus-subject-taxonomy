                subtype="historical-document" type="document" xml:id="d286">
                <note rend="inline" type="source">793.94/13948: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Hankow</hi> (<persName type="from">
                        <hi rend="italic">Josselyn</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Hankow</hi>
                        </placeName>, <date calendar="gregorian" when="1938-09-23T14:00:00+08:00"
                            >September 23, 1938—2 p.m.</date>
                        <lb/>[Received 7:13 p.m.]</dateline>
                </opener>
                <p>My September 13, 7 p.m. regarding proposed Chinese defenses on oil company
                    installations.</p>
                <p>Mayor informed me orally this morning that Chinese military had decided not to
                    erect defenses on Standard Oil Company or Texas Oil Company property.</p>
                <p>Sent to Chungking.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Josselyn</hi>
                    </signed>
                </closer>
            </div>
        </body>
