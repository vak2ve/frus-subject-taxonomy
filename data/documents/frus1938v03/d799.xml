<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1938-10-07T02:00:00-05:00" frus:doc-dateTime-min="1938-10-07T02:00:00-05:00" n="799" subtype="historical-document" type="document" xml:id="d799">
                        <note rend="inline" type="source">893.156 CH/240: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Japan</hi> (<persName type="from"><hi rend="italic">Grew</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Tokyo</hi></placeName>, <date calendar="gregorian" when="1938-10-07T16:00:00+09:00">October 7, 1938—4
                                p.m.</date><lb/>[Received October 8—7:15 a.m.]</dateline>
                        </opener>
                        <p>650. Department’s 338, September 28, 6 p.m.<note n="21" xml:id="d799fn21">See <hi rend="italic">supra</hi>.</note> Chefoo Harbor Commission.
                            Formal note was delivered today to the Foreign Office. The British
                            Ambassador has taken similar action.</p>
                        <p>Repeated to Chungking and Chefoo.</p>
                        <closer><signed><hi rend="smallcaps">Grew</hi></signed></closer>
                    </div>
                    </body></text></TEI>