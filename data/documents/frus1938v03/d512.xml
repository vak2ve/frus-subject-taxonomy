                subtype="historical-document" type="document" xml:id="d512">
                <note rend="inline" type="source">793.94/13913: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Geneva</hi> (<persName type="from">
                        <hi rend="italic">Bucknell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Geneva</hi>
                        </placeName>, <date calendar="gregorian" when="1938-09-19T19:00:00+01:00"
                            >September 19, 1938—7 p.m.</date>
                        <lb/>[Received September 19—2:45 p.m.]</dateline>
                </opener>
                <p>211. The Council today agreed to telegraph an invitation to the Japanese
                    Government in accordance with paragraph 1 of article 17. It was agreed that no
                    action in accordance with paragraph 2 of that article was necessary at this time
                    in view of the fact that an inquiry into the circumstances of the dispute had
                    already been made by the League.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bucknell</hi>
                    </signed>
                </closer>
            </div>
        </body>
