                                <persName corresp="#p_DCW_1">Charles W. Duncan</persName>
                            </item>
                            <item>Gen. William Smith (<gloss target="#t_JCS_1">JCS</gloss>)</item>
                            <item>Maynard Glitman</item>
                        </list>
                    </item>
