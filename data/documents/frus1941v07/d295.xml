<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-10-01T23:59:59-05:00" frus:doc-dateTime-min="1941-10-01T00:00:00-05:00" n="295" subtype="historical-document" type="document" xml:id="d295">
                        <note rend="inline" type="source">838.51/4356: Telegram</note>
                        <head><hi rend="italic">The Minister in Haiti</hi> (<persName type="from"><hi rend="italic">White</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Port-au-Prince</hi></placeName>, <date calendar="gregorian" when="1941-10-01">October 1, 1941</date>.<lb/>[Received 3:08
                                p.m.]</dateline>
                        </opener>
                        <p>186. Executive agreement of September 13, 1941 to replace the accord of
                            August 7, 1933 is due to enter into force today at 4 p.m.</p>
                        <closer><signed><hi rend="smallcaps">White</hi></signed></closer>
                    </div>
                </body></text></TEI>