                subtype="historical-document" type="document" xml:id="d234">
                <note rend="inline" type="source">822.796/450: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Ecuador</hi> (<persName type="to">
                        <hi rend="italic">Long</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1941-09-23T16:00:00-04:00"
                            >September 23, 1941—4 p.m.</date>
                    </dateline>
                </opener>
                <p>266. For Morgan from Clayton. Your cable 354 received. Approve maximum amount
                    suggested by you.</p>
                <p>Suggest following addition at end of line 51 as desirable but not absolutely
                    essential “and the obligation of Defense Supplies Corporation to make such
                    advances shall terminate on”. Here insert mutually agreeable date not more than
                    1 year hence.</p>
                <p>Please advise when contract has been signed giving dates and amounts inserted.
                    [Clayton.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
