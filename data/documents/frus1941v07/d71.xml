    <text>
        <body>
            <div frus:doc-dateTime-max="1941-06-05T23:59:59-05:00"
                frus:doc-dateTime-min="1941-06-05T00:00:00-05:00" n="71"
                subtype="historical-document" type="document" xml:id="d71">
                <note rend="inline" type="source">821.51/2632</note>
                <head>
                    <hi rend="italic">The Colombian Ambassador</hi> (<persName type="from">
                        <hi rend="italic">Turbay</hi>
                    </persName>) <hi rend="italic">to the Adviser on Political Relations</hi>
                        (<persName type="to">
                        <hi rend="italic">Duggan</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">No. 1215</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1941-06-05">June 5,
                            1941</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Duggan</hi>: I am pleased to send you herewith,
                    for your information, two copies of the announcement published in today’s
                    newspapers with regard to the Offer of the Republic of Colombia for the exchange
                    of the 1927 and 1928 6% External Gold Bonds and two copies of the Offer and
                    Letter of Transmittal to be sent directly to the bondholders.<note n="98"
                        xml:id="d71fn98">Enclosures not printed.</note>
                </p>
                <p>With best regards, I am</p>
                <p>Yours very sincerely,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gabriel Turbay</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
