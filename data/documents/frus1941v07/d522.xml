<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-12-26T20:00:00-05:00" frus:doc-dateTime-min="1941-12-26T20:00:00-05:00" n="522" subtype="historical-document" type="document" xml:id="d522">
                        <note rend="inline" type="source">831.24/77: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Venezuela</hi> (<persName type="to"><hi rend="italic">Corrigan</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1941-12-26T20:00:00-05:00">December 26, 1941—8
                                p.m.</date></dateline>
                        </opener>
                        <p>294. Your 322, December 22, 7 p.m. Please inform President Medina that
                            his request is receiving the immediate attention of the appropriate
                            authorities of this Government and that everything possible will be done
                            to supply the desired equipment.</p>
                        <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                    </div>
                    </body></text></TEI>