<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-09-13T23:59:59-05:00" frus:doc-dateTime-min="1941-09-13T00:00:00-05:00" n="292" subtype="historical-document" type="document" xml:id="d292">
                        <note rend="inline" type="source">838.51/4317: Telegram</note>
                        <head><hi rend="italic">The Minister in Haiti</hi> (<persName type="from"><hi rend="italic">White</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Port-au-Prince</hi></placeName> [<date ana="#date_undated-inferred-from-document-content" calendar="gregorian" when="1941-09-13">undated</date>].<lb/>[Received September 13, 1941—12:13
                                p.m.]</dateline>
                        </opener>
                        <p>Bank Accord signed.</p>
                        <closer><signed><hi rend="smallcaps">White</hi></signed></closer>
                        <postscript>
                            <p>[For text of agreement between the United States and Haiti to replace
                                the agreement of August 7, 1933, signed at Port-au-Prince September
                                13, 1941, and the exchange of notes, see Department of State
                                Executive Agreement Series No. 220, or 55 Stat. (pt. 2) 1348.]</p>
                        </postscript>
                    </div>
                    </body></text></TEI>