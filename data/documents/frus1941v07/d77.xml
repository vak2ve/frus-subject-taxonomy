    <text>
        <body>
            <div frus:doc-dateTime-max="1941-10-07T12:00:00-05:00"
                frus:doc-dateTime-min="1941-10-07T12:00:00-05:00" n="77"
                subtype="historical-document" type="document" xml:id="d77">
                <note rend="inline" type="source">821.51/2655: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Colombia</hi> (<persName type="from">
                        <hi rend="italic">Braden</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bogotá</hi>
                        </placeName>, <date calendar="gregorian" when="1941-10-07T12:00:00-05:00"
                            >October 7, 1941—noon</date>.<lb/>[Received 1:22 p.m.]</dateline>
                </opener>
                <p>464. Export-Import Bank loan approved by both Houses, now goes to President for
                    signature.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Braden</hi>
                    </signed>
                </closer>
            </div>
        </body>
