                <note rend="inline" type="source">815.00/2400: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the Vice
                        Consul at Puerto Cortez</hi> (<persName type="to">
                        <hi rend="italic">Alexander</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1922-08-10T16:00:00-04:00">
                            <hi rend="italic">August 10, 1922—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your August 8, 4 p.m.</p>
                <p>Department understands U.S.S. <hi rend="italic">Galveston</hi> will arrive in two
                    or three days.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
