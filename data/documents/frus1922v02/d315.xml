                subtype="historical-document" type="document" xml:id="d315">
                <note rend="inline" type="source">868.00/301: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Greece</hi> (<persName type="to">
                        <hi rend="italic">Caffery</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1922-11-01T14:00:00-05:00">
                            <hi rend="italic">November 1, 1922—2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>76. Your 150, October 26, 8 p.m. and 152 October 27 9 P.M.<note n="4"
                        xml:id="d315fn4">Latter not printed.</note>
                </p>
                <p>You may in your discretion orally and informally indicate to Greek authorities
                    that arbitrary action in the trial or execution of political prisoners in Greece
                    would in your own opinion undoubtedly make an unfortunate impression in this
                    country.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
