                subtype="historical-document" type="document" xml:id="d221">
                <note rend="inline" type="source">811.54262/308: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName type="from">
                        <hi rend="italic">Houghton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1922-05-09T11:00:00+01:00">
                            <hi rend="italic">May 9, 1922—11 a.m.</hi>
                        </date>
                        <lb/>[Received 11:35 a.m.]</dateline>
                </opener>
                <p>92. Department’s 61 May 6, 3 p.m. I handed to Von Haniel<note n="10"
                        xml:id="d221fn10">German Secretary of State in the Ministry of Foreign
                        Affairs.</note> yesterday a note dated May 8th containing the text of the
                    Department’s notification.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Houghton</hi>
                    </signed>
                </closer>
            </div>
        </body>
