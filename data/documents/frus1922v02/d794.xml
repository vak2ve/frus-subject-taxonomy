    <text>
        <body>
            <div frus:doc-dateTime-max="1923-01-03T19:00:00-05:00"
                frus:doc-dateTime-min="1923-01-03T19:00:00-05:00" n="794"
                subtype="historical-document" type="document" xml:id="d794">
                <note rend="inline" type="source">816.51/224: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Salvador</hi> (<persName type="from">
                        <hi rend="italic">Hewes</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Salvador</hi>
                        </placeName>, <date calendar="gregorian" when="1923-01-03T18:00:00-06:00">
                            <hi rend="italic">January 3</hi> [<hi rend="italic">2?</hi>], <hi
                                rend="italic">1923—6 p.m.</hi>
                        </date>
                        <lb/>[Received January 3—10:40 a.m.]</dateline>
                </opener>
                <p>3. By Executive decree issued today the Metropolitan Trust Company of New York is
                    named fiscal agent of the loan in accordance with article II of the contract of
                    June 24th.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hewes</hi>
                    </signed>
                </closer>
            </div>
        </body>
