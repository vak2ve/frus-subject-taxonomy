                subtype="historical-document" type="document" xml:id="d529">
                <note rend="inline" type="source">862i.01/185</note>
                <head>
                    <hi rend="italic">The Japanese Ambassador</hi> (<persName type="from">
                        <hi rend="italic">Shidehara</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1922-02-11">
                            <hi rend="italic">February 11, 1922</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In proceeding this day to the signature of the
                    Convention between Japan and the United States with respect to the islands,
                    under Japan’s Mandate, situated in the Pacific Ocean and lying north of the
                    Equator, I have the honor to assure you, under authorization of my Government,
                    that the usual comity will be extended to nationals and vessels of the United
                    States in visiting the harbors and waters of those islands.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">K. Shidehara.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
