    <text>
        <body>
            <div frus:doc-dateTime-max="1922-06-08T16:40:00-05:00"
                frus:doc-dateTime-min="1922-06-08T16:40:00-05:00" n="16"
                subtype="historical-document" type="document" xml:id="d16">
                <note rend="inline" type="source">839.00/2531: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in the Dominican Republic</hi> (<persName
                        type="from">
                        <hi rend="italic">Russell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1922-06-08T17:00:00-04:40">
                            <hi rend="italic">June 8, 1922—5 p.m.</hi>
                        </date>
                        <lb/>[Received June 12—2:25 p.m.]</dateline>
                </opener>
                <p>23. General Horacio Vasquez<note n="22" xml:id="d16fn22">Horacio Vasquez replaced
                        Jacinto de Castro as representative of the Nacional party.</note> and
                    Federico Velasquez left here yesterday for Washington via Porto Rico and will
                    arrive at New York about June 13th. …</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Russell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
