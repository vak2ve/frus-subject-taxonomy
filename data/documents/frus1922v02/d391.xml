                <note rend="inline" type="source">838.00/1855: Telegram</note>
                <head>
                    <hi rend="italic">The High Commissioner in Haiti</hi> (<persName type="from">
                        <hi rend="italic">Russell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1922-04-11T12:00:00-05:00">
                            <hi rend="italic">April 11, 1922—noon</hi>
                        </date>.<lb/>[Received April 12—2:40 p.m.]</dateline>
                </opener>
                <p>38. Louis Borno elected President by Council of State last night at 7:20. …</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Russell</hi>
                    </signed>
                </closer>
            </div>
        </body>
