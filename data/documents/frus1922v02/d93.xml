<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1922-04-25T23:59:59-05:00" frus:doc-dateTime-min="1922-04-25T00:00:00-05:00" n="93" subtype="historical-document" type="document" xml:id="d93">
                        <note rend="inline" type="source">422.11Am8/39</note>
                        <head><hi rend="italic">The Consul General at Guayaquil</hi> (<persName type="from"><hi rend="italic">Goding</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><seg rendition="#center">[Extract]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Guayaquil</hi></placeName>, <date calendar="gregorian" when="1922-04-25"><hi rend="italic">April 25,
                                1922</hi></date>.<lb/>[Received May 10, 1922.]</dateline>
                            <seg rendition="#left">No. 790</seg></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have the honor to inform you that the
                            indebtedness of the Municipality of Guayaquil to Amsinck &amp; Company
                            of New York has been settled, and the money therefor is deposited in the
                            bank to the credit of that house.</p>
                        <p rend="center">. . . . . . . . . . . . . .</p>
                        <p>I have [etc.]</p>
                        <closer><signed><hi rend="smallcaps">Frederic W.
                            Goding</hi></signed></closer>
                    </div>
                </body></text></TEI>