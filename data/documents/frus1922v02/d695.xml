                <note rend="inline" type="source">550.E1/291: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Italy</hi> (<persName type="to">
                        <hi rend="italic">Child</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1922-05-18T12:00:00-04:00">
                            <hi rend="italic">May 18, 1922—noon</hi>
                        </date>.</dateline>
                </opener>
                <p>14. No objection to your receiving Krassin privately, unofficially and
                    confidentially.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
