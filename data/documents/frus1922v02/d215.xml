                <note rend="inline" type="source">462.11 W 892/55</note>
                <head>
                    <hi rend="italic">Memorandum by President Harding for the Secretary of
                        State</hi>
                    <note n="5" xml:id="d215fn5">This undated memorandum, in longhand, was received
                        by the Secretary on Aug. 10.</note>
                </head>
                <dateline>
                    <date ana="#date_undated-inferred-from-document-content" calendar="gregorian"
                        when="1922-08-10">undated</date>
                </dateline>
                <p>
                    <hi rend="smallcaps">Dear Mr. Sec</hi>[<hi rend="smallcaps">retar</hi>]<hi
                        rend="smallcaps">y</hi>: In making the announcement, please <hi
                        rend="italic">emphasize</hi> the request to us to name umpire. It is so
                    unusual that its significance is worth bringing well to the fore.</p>
                <closer>
                    <signed>W[<hi rend="smallcaps">arren</hi>] G. H[<hi rend="smallcaps"
                        >arding</hi>]</signed>
                </closer>
            </div>
        </body>
