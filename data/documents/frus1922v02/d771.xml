    <text>
        <body>
            <div frus:doc-dateTime-max="1922-06-30T12:00:00-05:00"
                frus:doc-dateTime-min="1922-06-30T12:00:00-05:00" n="771"
                subtype="historical-document" type="document" xml:id="d771">
                <note rend="inline" type="source">860m.01/132: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Herrick</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1922-06-30T18:00:00+01:00">
                            <hi rend="italic">June 30, 1922—6 p.m.</hi>
                        </date>
                        <lb/>[Received June 30—4:35 p.m.]</dateline>
                </opener>
                <p>271. My 234, January 23, 1920.<note n="86" xml:id="d771fn86">Not printed.</note>
                    Conference of Ambassadors at 183rd meeting held this morning decided that
                    Principal Allied Powers would recognize Lithuania <hi rend="italic">de
                    jure</hi>. This is independent of determination of status of Memel to study
                    which question a committee of Conference secretaries is to be appointed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Herrick</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
