    <text>
        <body>
            <div frus:doc-dateTime-max="1922-11-09T23:59:59-05:00"
                frus:doc-dateTime-min="1922-11-09T00:00:00-05:00" n="397"
                subtype="historical-document" type="document" xml:id="d397">
                <note rend="inline" type="source">838.51/1443</note>
                <head>
                    <hi rend="italic">The High Commissioner in Haiti</hi> (<persName type="from">
                        <hi rend="italic">Russell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1922-11-09">
                            <hi rend="italic">November 9, 1922</hi>
                        </date>.<lb/>[Received November 25.]</dateline>
                    <seg rendition="#left">No. 81</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to report that the Financial
                    Adviser, Mr. John S. Hord, has received his appointment from the Haitian
                    Government and has assumed his duties as Financial Adviser to the Republic of
                    Haiti.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John H. Russell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
