<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1922-11-07T14:00:00-05:00" frus:doc-dateTime-min="1922-11-07T14:00:00-05:00" n="847" subtype="historical-document" type="document" xml:id="d847">
                        <note rend="inline" type="source">867.4016/720: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the High Commissioner at Constantinople</hi> (<persName type="to"><hi rend="italic">Bristol</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1922-11-07T14:00:00-05:00"><hi rend="italic">November 7,
                                        1922—2 p.m.</hi></date></dateline></opener>
                        <p>245. Department approves action described in your 301, November 4, 3 P.M.
                            In case you or Allied High Commissioners make written representations,
                            telegraph text. Advise Department if reported decision of Kemalists to
                            evacuate Christians is confirmed.</p>
                        <closer><signed><hi rend="smallcaps">Hughes</hi></signed></closer>
                    </div>
                    </body></text></TEI>