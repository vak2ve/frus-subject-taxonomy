                subtype="historical-document" type="document" xml:id="d54">
                <note rend="inline" type="source">500.A15A4 General Committee/883: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        American Delegate</hi> (<persName type="to">
                        <hi rend="italic">Wilson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-04-25T19:00:00-05:00"
                            >April 25, 1934—7 p.m.</date>
                    </dateline>
                </opener>
                <p>411. Your 834, April 23, 7 p.m. You may address a communication to Henderson
                    informing him that the proposed change in the dates for the convening of the
                    Bureau and the General Commission are satisfactory to this Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
