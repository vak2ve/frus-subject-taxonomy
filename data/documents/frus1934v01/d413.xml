                subtype="historical-document" type="document" xml:id="d413">
                <note rend="inline" type="source">740.0011 Mutual Guarantee (Eastern Locarno)/11:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from">
                        <hi rend="italic">Long</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1934-07-13T18:00:00+01:00"
                            >July 13, 1934—6 p.m.</date>
                        <lb/> [Received July 13—3:05 p.m.]</dateline>
                </opener>
                <p>143. Evening press publishes communiqué and inspired editorial which indicate a
                    modification of attitude of the Italian Government regarding an Eastern Locarno
                    and practically announcing it approves the plan but withholds participation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Long</hi>
                    </signed>
                </closer>
            </div>
        </body>
