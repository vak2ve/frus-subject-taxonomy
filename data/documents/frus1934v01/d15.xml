<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-02-13T23:59:59-05:00" frus:doc-dateTime-min="1934-02-13T00:00:00-05:00" n="15" subtype="historical-document" type="document" xml:id="d15">
                            <note rend="inline" type="source">500.A15A4 General Committee/778</note>
                            <head>
                                <hi rend="italic">The British Ambassador</hi> (<persName type="from"><hi rend="italic">Lindsay</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#left">No. 52</seg>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1934-02-13">13 February,
                                        1934</date>.</dateline>
                            </opener>
                            <p>
                                <hi rend="smallcaps">Sir</hi>: I have the honour, under instructions
                                from His Majesty’s Principal Secretary of State for Foreign Affairs,
                                to transmit to you herewith, for your information, a copy of the
                                Memorandum on Disarmament issued by His Majesty’s Government in the
                                United Kingdom.<note n="55" xml:id="d15fn55">For text of British
                                    memorandum of January 29, 1934, see Department of State, <hi rend="italic">Press Releases</hi>, March 3, 1934, p. 110;
                                    also Great Britain, Cmd. 4512, p. 21.</note>
                            </p>
                            <p>I have [etc.]</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">R. C. Lindsay</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>