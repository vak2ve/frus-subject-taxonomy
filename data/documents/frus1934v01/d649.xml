                subtype="historical-document" type="document" xml:id="d649">
                <note rend="inline" type="source">341.1154L58/197: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Atherton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1933-04-07T12:00:00+00:00"
                            >April 7, 1933—noon</date>.<lb/>[Received April 7—8:15 a.m.]</dateline>
                </opener>
                <p>78. Personally presented note last evening in compliance with your instruction
                    454, March 27.</p>
                <pb facs="0906" n="806" xml:id="pg_806"/>
                <p>Was informally advised that recent representation on this subject by Belgian
                    Embassy has been refused and that I might expect reply in the near future.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Atherton</hi>
                    </signed>
                </closer>
            </div>
        </body>
