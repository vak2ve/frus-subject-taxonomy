                subtype="historical-document" type="document" xml:id="d101">
                <note rend="inline" type="source">500.A14/664a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chairman of the American Delegation</hi> (<persName type="to">
                        <hi rend="italic">Davis</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-06-07T19:00:00-04:00"
                            >June 7, 1934—7 p.m.</date>
                    </dateline>
                </opener>
                <p>429. Your 883, June 7, 3 p.m. Every effort is being made to secure favorable
                    action by the Senate on the Treaty and it appears probable that advice and
                    consent to ratification will be given next week.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
