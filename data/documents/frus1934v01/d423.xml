<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-09-05T10:00:00-05:00" frus:doc-dateTime-min="1934-09-05T10:00:00-05:00" n="423" subtype="historical-document" type="document" xml:id="d423">
                        <note rend="inline" type="source">740.0011 Mutual Guarantee (Eastern
                            Locarno)/42: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in Poland</hi> (<persName type="from"><hi rend="italic">Cudahy</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Warsaw</hi></placeName>, <date calendar="gregorian" when="1934-09-05T16:00:00+01:00">September
                                    5, 1934—4 p.m.</date>
                                <lb/> [Received September 5—2:15 p.m.]</dateline>
                        </opener>
                        <p>46. Beck expresses opinion Eastern Locarno will fail.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Cudahy</hi>
                            </signed>
                        </closer>
                    </div>
