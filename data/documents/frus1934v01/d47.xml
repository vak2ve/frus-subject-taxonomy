                subtype="historical-document" type="document" xml:id="d47">
                <note rend="inline" type="source">500.A15A4/2490: Telegram</note>
                <head>
                    <hi rend="italic">The American Delegate</hi> (<persName type="from">
                        <hi rend="italic">Wilson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Geneva</hi>
                        </placeName>, <date calendar="gregorian" when="1934-04-19T12:00:00+01:00"
                            >April 19, 1934—noon</date>.<lb/>[Received April 19—7:28
                        a.m.]</dateline>
                </opener>
                <p>833. Until we can ascertain the effect most recent French note to Great Britain
                    it might be advisable to postpone decision on my 832 April 15, 8 p.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wilson</hi>
                    </signed>
                </closer>
            </div>
        </body>
