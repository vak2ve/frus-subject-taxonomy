<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-07-13T16:00:00-05:00" frus:doc-dateTime-min="1934-07-13T16:00:00-05:00" n="244" subtype="historical-document" type="document" xml:id="d244">
                            <note rend="inline" type="source">500.A15A/144: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Great Britain</hi> (<persName type="to"><hi rend="italic">Bingham</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1934-07-13T17:00:00-04:00">July
                                        13, 1934—5 p.m.</date>
                                </dateline>
                            </opener>
                            <p>299. For Norman Davis. Your 406, July 12, 8 p.m. The course you
                                propose seems to me the wisest one possible given all the
                                circumstances.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>