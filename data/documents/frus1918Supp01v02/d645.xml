    <text>
        <body>
            <div frus:doc-dateTime-max="1918-03-26T19:00:00-05:00"
                frus:doc-dateTime-min="1918-03-26T19:00:00-05:00" n="645"
                subtype="historical-document" type="document" xml:id="d645">
                <note rend="inline" type="source">File No. 654.119/169a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Switzerland</hi> (<persName corresp="frus1918Supp01v01#p_SPA1"
                        type="to">
                        <hi rend="italic">Stovall</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-26T19:00:00-05:00">
                            <hi rend="italic">March 26, 1918, 7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1677. The Government of the United States for the purpose of assisting to meet
                    the existing difficult food situation of the Swiss people proposes at once to
                    make available for a voyage to Cette for Swiss relief 64,000 tons of shipping
                    provided satisfactory safe conduct from the German Government can be secured by
                    Switzerland.</p>
                <p>This action is taken despite the urgent need of utilizing all available tonnage
                    in purely national service.</p>
                <p>You will please inform the Foreign Office of the foregoing and you may make any
                    other utilization of this information which you feel desirable.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
