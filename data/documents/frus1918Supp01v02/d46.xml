<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-02-19T19:00:00-05:00" frus:doc-dateTime-min="1918-02-19T19:00:00-05:00" n="46" subtype="historical-document" type="document" xml:id="d46">
                            <note rend="inline" type="source">File No. 656.119/178b</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in the Netherlands</hi> (<persName corresp="frus1918Supp01v01#p_GJW1" type="to"><hi rend="italic">Garrett</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-02-19T19:00:00-05:00">
                                        <hi rend="italic">February 19, 1918, 7 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>991. War Trade Board in agreement with British and French will,
                                beginning February 20, consider applications for licenses to export
                                to Sweden and Holland certain commodities, a list of which we
                                understand has been furnished you by American Embassy, London.</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>