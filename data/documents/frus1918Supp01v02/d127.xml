                subtype="historical-document" type="document" xml:id="d127">
                <note rend="inline" type="source">File No. 763.72112/7602</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="frus1918Supp01v01#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-21T16:00:00+00:00">
                            <hi rend="italic">March 21, 1918, 4 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received March 21, 11.10 a.m.</hi>]</dateline>
                </opener>
                <p>9154. War Trade Board [from <persName>Frothingham</persName>]:</p>
                <p>No. 318. <persName corresp="frus1918Supp01v01#p_FPj1">Fuller</persName>. Your
                    139. May we understand coordination proposals through British Embassy per our
                    183 have received final approval, and that at time review of cases Washington,
                    London, Paris, respectively, agreed upon, additions or removals will be made,
                    simultaneously to respective official lists?
                    <persName>Frothingham</persName>.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
