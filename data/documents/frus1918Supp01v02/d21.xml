                subtype="historical-document" type="document" xml:id="d21">
                <note rend="inline" type="source">File No. 600.119/484</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName
                        corresp="frus1918Supp01v01#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-01-15T21:00:00-05:00">
                            <hi rend="italic">January 15, 1918, 9 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>6261. Following for <persName corresp="frus1918Supp01v01#p_SLP1"
                        >Sheldon</persName> from War Trade Board:</p>
                <p>Our No. 10. In connection with the doing away of letters of assurance, please
                    report to us your recommendations as to the plan for division of rations, as
                    between Great Britain, United States, and other countries.</p>
                <p>
                    <persName corresp="frus1918Supp01v01#p_MVC1">McCormick</persName> discussed this
                    matter with you when in London, but desires you to submit your complete and
                    detailed recommendations upon this subject, in order that we can all agree upon
                    a policy and thereby avoid friction in the future.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
