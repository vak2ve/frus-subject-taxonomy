<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-02-04T12:00:00-05:00" frus:doc-dateTime-min="1918-02-04T12:00:00-05:00" n="637" subtype="historical-document" type="document" xml:id="d637">
                            <note rend="inline" type="source">File No. 654.119/119</note>
                            <head>
                                <hi rend="italic">The Chargé in Switzerland</hi> (<persName corresp="frus1918Supp01v01#p_WHR1" type="from"><hi rend="italic">Wilson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Berne</hi></placeName>, <date calendar="gregorian" when="1918-02-04T18:00:00+01:00">
                                        <hi rend="italic">February 4, 1918, 6 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received February 6, 12.43
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>2575. For War Trade Board:</p>
                            <p>Your 1378, January 26 [<hi rend="italic">22</hi>], 6 p.m. In
                                    <persName corresp="frus1918Supp01v01#p_DEL1">Dresel</persName>’s
                                absence inform you that Foreign Office has replied to Legation’s
                                memorandum [which] requests elimination of words “of American
                                origin,” as indicated your telegram, and adding that Department of
                                Public Economy is quite in accord to suppress the words in
                                question.</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_WHR1">
                                        <hi rend="smallcaps">Wilson</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>