<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-01-16T17:00:00-05:00" frus:doc-dateTime-min="1918-01-16T17:00:00-05:00" n="632" subtype="historical-document" type="document" xml:id="d632">
                            <note rend="inline" type="source">File No. 654.119/99</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in Switzerland</hi> (<persName corresp="frus1918Supp01v01#p_WHR1" type="to"><hi rend="italic">Wilson</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-01-16T17:00:00-05:00">
                                        <hi rend="italic">January 16, 1918, 5 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>1347. Referring Legation’s No. 2379 of January 10, 10 a.m.,<note n="1" xml:id="d632fn1">Not printed.</note>
                                <persName corresp="frus1918Supp01v01#p_DEL1">Dresel</persName>
                                should be instructed to participate as suggested with British and
                                French representatives in forthcoming negotiations for the reduction
                                of cotton and rubber goods in accordance with the rights reserved in
                                [part II,] article 11 (<hi rend="italic">a</hi>) of the
                                Swiss-American agreement signed in Paris on December 5, 1917.<note n="2" xml:id="d632fn2">
                                    <ref target="frus1917Supp02v02#pg_1185">
                                        <hi rend="italic">Foreign Relations</hi>, 1917, Supplement
                                        2, vol. II, pp. 1185</ref>–<ref target="frus1917Supp02v02#pg_1196">1196</ref>.</note>
                            </p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>