    <text>
        <body>
            <div frus:doc-dateTime-max="1918-08-19T04:00:00-05:00"
                frus:doc-dateTime-min="1918-08-19T04:00:00-05:00" n="755"
                subtype="historical-document" type="document" xml:id="d755">
                <note rend="inline" type="source">File No. 103.96/2602</note>
                <head>
                    <hi rend="italic">The Ambassador in Spain</hi> (<persName
                        corresp="frus1918Supp01v01#p_WJE1" type="from">
                        <hi rend="italic">Willard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                    <note n="1" xml:id="d755fn1">Copied from confirmation; original not received by
                        wire.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1918-08-19T10:00:00+01:00">
                            <hi rend="italic">August 19, 1918, 10 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1692. For War Trade Board [from <persName>Smith</persName>]:</p>
                <p>Your cable 1411, August 10. Am leaving for home today. Please notify Ward Line,
                    New York. Full report to you in Washington necessary. No headway possible while
                    Government and owners maintain present attitude. <persName>Smith</persName>.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_WJE1">
                            <hi rend="smallcaps">Willard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
