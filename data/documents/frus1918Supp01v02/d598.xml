                subtype="historical-document" type="document" xml:id="d598">
                <note rend="inline" type="source">File No. 656.119/786a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in the Netherlands</hi> (<persName corresp="frus1918Supp01v01#p_BRW1"
                        type="to">
                        <hi rend="italic">Bliss</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-10-02">
                            <hi rend="italic">October 2, 1918</hi>
                        </date>.</dateline>
                </opener>
                <p>2158. Do not act on telegram No. 2154, October 1, 4 p.m., until you receive
                    further instructions.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
