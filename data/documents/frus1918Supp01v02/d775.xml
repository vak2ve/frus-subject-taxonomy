                subtype="historical-document" type="document" xml:id="d775">
                <note rend="inline" type="source">File No. 763.72/11172</note>
                <head>
                    <hi rend="italic">The Ambassador in Spain</hi> (<persName
                        corresp="frus1918Supp01v01#p_WJE1" type="from">
                        <hi rend="italic">Willard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1918-08-30T13:00:00+01:00">
                            <hi rend="italic">August 30, 1918, 1 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received August 31, 4.25 a.m.</hi>]</dateline>
                </opener>
                <p>Embassy’s August 30, noon.<note n="1" xml:id="d775fn1">Not printed.</note>
                    Minister of Foreign Affairs requested me to obtain telegraphically from my
                    Government replies to following questions: (1) How were Germans in America
                    treated upon severance of relations? (2) How were they treated after declaration
                    of war? (3) Upon severance of relations what steps were taken with respect to
                    German ships in American ports? (4) Upon declaration of war what steps were
                    taken with respect to these ships?<note n="2" xml:id="d775fn2">Reply of Oct. 4,
                        telegram No. 1642, giving information requested, not printed.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_WJE1">
                            <hi rend="smallcaps">Willard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
