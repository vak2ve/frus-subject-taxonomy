    <text>
        <body>
            <div frus:doc-dateTime-max="1918-05-29T23:59:59-05:00"
                frus:doc-dateTime-min="1918-05-29T00:00:00-05:00" n="296"
                subtype="historical-document" type="document" xml:id="d296">
                <note rend="inline" type="source">File No. 657.119/514</note>
                <head>
                    <hi rend="italic">The British Ambassador on Special Mission</hi> (<persName
                        corresp="frus1918Supp01v01#p_RERDI1" type="from">
                        <hi rend="italic">Reading</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 598</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-05-29">
                            <hi rend="italic">May 29, 1918</hi>
                        </date>. <lb/> [<hi rend="italic">Received June 1.</hi>]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: I beg to acknowledge the
                    receipt of your letter of May 3d enclosing copy of the Norwegian agreement which
                    was signed by Mr. <persName corresp="frus1918Supp01v01#p_MVC1"
                        >McCormick</persName> and Doctor <persName corresp="frus1918Supp01v01#p_NF1"
                        >Nansen</persName>.</p>
                <p>I have received instructions from Mr. <persName
                        corresp="frus1918Supp01v01#p_BAJ1">Balfour</persName> to inform you that His
                    Majesty’s Government are prepared formally to adhere to the agreement as
                    enclosed in your note of the 3d instant.</p>
                <p>Believe me [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_RERDI1">
                            <hi rend="smallcaps">Reading</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
