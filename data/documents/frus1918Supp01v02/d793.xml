<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-11-21T16:29:00-05:00" frus:doc-dateTime-min="1917-11-21T16:29:00-05:00" n="793" subtype="historical-document" type="document" xml:id="d793">
                        <note rend="inline" type="source">File No. 837.711/2</note>
                        <head>
                            <hi rend="italic">The Chargé in Cuba</hi> (<persName type="from"><hi rend="italic">Scholle</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Habana</hi></placeName>, <date calendar="gregorian" when="1917-11-21T16:00:00-05:29">
                                    <hi rend="italic">November 21, 1917, 4 p.m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received 7 p.m.</hi>]</dateline>
                        </opener>
                        <p>Your November 20, 6 p.m. President approves in principle and is anxious
                            to have officer come at once to explain.</p>
                        <closer>
                            <signed>
                                <persName>
                                    <hi rend="smallcaps">Scholle</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>