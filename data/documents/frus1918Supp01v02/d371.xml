<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-10-15T23:59:59-05:00" frus:doc-dateTime-min="1918-10-15T00:00:00-05:00" n="371" subtype="historical-document" type="document" xml:id="d371">
                            <note rend="inline" type="source">File No. 658.119/659</note>
                            <head>
                                <hi rend="italic">The Chargé in Great Britain</hi> (<persName corresp="frus1918Supp01v01#p_LIB1" type="from"><hi rend="italic">Laughlin</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1918-10-15">
                                        <hi rend="italic">October 15, 1918</hi>.</date>
                                    <lb/> [<hi rend="italic">Received 8.30 p.m.</hi>]</dateline>
                            </opener>
                            <p>2807. War Trade Board [from <persName corresp="frus1918Supp01v01#p_SLP1">Sheldon</persName>]:</p>
                            <p>No. 1667. Referring to my letter No. 5385 of September 12<note n="1" xml:id="d371fn1">Not printed.</note> with reference to our
                                engagement to bear one-third of the expense in connection with the
                                purchase of iron ore under the Swedish agreement. Please let me have
                                answer as soon as possible.</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_LIB1">
                                        <hi rend="smallcaps">Laughlin</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>