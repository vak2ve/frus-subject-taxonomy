                subtype="historical-document" type="document" xml:id="d693">
                <note rend="inline" type="source">File No. 654.119/583</note>
                <head>
                    <hi rend="italic">The Minister in Switzerland</hi> (<persName
                        corresp="frus1918Supp01v01#p_SPA1" type="from">
                        <hi rend="italic">Stovall</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berne</hi>
                        </placeName>, <date calendar="gregorian" when="1918-10-23T00:00:00+01:00">
                            <hi rend="italic">October 23, 1918, 12 a.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received October 25, 11.27 a.m.</hi>]</dateline>
                </opener>
                <p>5353. For War Trade Board [from Heck]:</p>
                <p>No. 231. Your telegram 1396 [<hi rend="italic">1397</hi>] of October 12, 1 [<hi
                        rend="italic">2</hi>] p.m., for <persName corresp="frus1918Supp01v01#p_SLP1"
                        >Sheldon</persName>. Am advised by Italian delegate that the new Italo-Swiss
                    agreement is being signed to-day in view of instructions transmitted to
                        <persName corresp="frus1918Supp01v01#p_JS1">Stewart</persName> to withdraw
                    request for delay. Heck.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_SPA1">
                            <hi rend="smallcaps">Stovall</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
