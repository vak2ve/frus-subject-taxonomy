    <text>
        <body>
            <div frus:doc-dateTime-max="1918-03-23T18:00:00-05:00"
                frus:doc-dateTime-min="1918-03-23T18:00:00-05:00" n="319"
                subtype="historical-document" type="document" xml:id="d319">
                <note rend="inline" type="source">File No. 658.119/260</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Sweden</hi> (<persName corresp="frus1918Supp01v01#p_MIN1"
                        type="to">
                        <hi rend="italic">Morris</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-23T18:00:00-05:00">
                            <hi rend="italic">March 23, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>631. From War Trade Board:</p>
                <p>Your 1682, March 15, 5 p.m. Wheat Executive have guaranteed Swedish Minister
                    Sweden may purchase, if agreement concluded, from Argentine 100,000 tons wheat,
                    50,000 tons oats, 100,000 tons maize; from Australia 100,000 tons wheat, 80,000
                    tons wheat flour.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
