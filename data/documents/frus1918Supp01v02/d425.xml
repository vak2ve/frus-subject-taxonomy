                subtype="historical-document" type="document" xml:id="d425">
                <note rend="inline" type="source">File No. 659.119/485</note>
                <head>
                    <hi rend="italic">The Chargé in Denmark</hi> (<persName
                        corresp="frus1918Supp01v01#p_GSU1" type="from">
                        <hi rend="italic">Grant-Smith</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Copenhagen</hi>
                        </placeName>, <date calendar="gregorian" when="1918-09-21T17:00:00+01:00">
                            <hi rend="italic">September 21, 1918, 5 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 6.17 p.m.</hi>]</dateline>
                </opener>
                <p>2817. News of the signature of the United States-Danish agreement received with
                    general satisfaction and relief throughout Denmark. <pb facs="0528" n="1362"
                        xml:id="pg_1362"/> During discussion with Foreign Minister yesterday I
                    suggested that a note of warning be sounded in the press against the expectation
                    of the immediate receipt of all the goods enumerated.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_GSU1">
                            <hi rend="smallcaps">Grant-Smith</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
