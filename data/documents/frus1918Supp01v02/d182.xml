                subtype="historical-document" type="document" xml:id="d182">
                <note rend="inline" type="source">File No. 763.72112/10139</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName
                        corresp="frus1918Supp01v01#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-09-26">
                            <hi rend="italic">September 26, 1918</hi>
                        </date>.</dateline>
                </opener>
                <p>1626. For <persName corresp="frus1918Supp01v01#p_SLP1">Sheldon</persName> [from
                        <persName corresp="frus1918Supp01v01#p_FPj1">Fuller</persName>, War Trade
                    Board]:</p>
                <p>No. 1274. <persName>Frothingham</persName>. Embassy’s 1906, September 16, your
                    1441. Action therein proposed is approved. <persName
                        corresp="frus1918Supp01v01#p_FPj1">Fuller</persName>.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
