    <text>
        <body>
            <div frus:doc-dateTime-max="1918-04-18T08:41:00-05:00"
                frus:doc-dateTime-min="1918-04-18T08:41:00-05:00" n="521"
                subtype="historical-document" type="document" xml:id="d521">
                <note rend="inline" type="source">File No. 656.119/363</note>
                <head>
                    <hi rend="italic">The Minister in the Netherlands</hi> (<persName
                        corresp="frus1918Supp01v01#p_GJW1" type="from">
                        <hi rend="italic">Garrett</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Hague</hi>
                        </placeName>, <date calendar="gregorian" when="1918-04-18T15:00:00+01:19">
                            <hi rend="italic">April 18, 1918, 3 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received April 19, 2 a.m.</hi>]</dateline>
                </opener>
                <p>2337. My 2284, April 10. Belgian Commission Relief informs me that first cargo to
                    arrive since April 10 has been sent on to Belgium.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_GJW1">
                            <hi rend="smallcaps">Garrett</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
