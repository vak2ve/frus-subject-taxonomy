<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-02-16T16:00:00-05:00" frus:doc-dateTime-min="1918-02-16T16:00:00-05:00" n="796" subtype="historical-document" type="document" xml:id="d796">
                        <note rend="inline" type="source">File No. 837.711/10</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Cuba</hi> (<persName corresp="frus1918Supp01v01#p_GWE1" type="to"><hi rend="italic">Gonzales</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-02-16T16:00:00-05:00">
                                    <hi rend="italic">February 16, 1918, 4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Major <persName>Van Natta</persName> and Captain <persName>Robert
                                Goelet</persName>, U. S. A[rmy], have been designated as
                            representatives of the United States Censorship Board to act as liaison
                            officers, in Cuba. They will arrive about the 15th instant.</p>
                        <closer>
                            <signed>
                                <persName corresp="frus1918Supp01v01#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>