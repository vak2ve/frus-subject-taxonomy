                subtype="historical-document" type="document" xml:id="d392">
                <note rend="inline" type="source">File No. 659.119/237a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Denmark</hi> (<persName corresp="frus1918Supp01v01#p_GSU1"
                        type="to">
                        <hi rend="italic">Grant-Smith</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-01T18:00:00-05:00">
                            <hi rend="italic">March 1, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>759. From War Trade Board:</p>
                <p>Please advise us as to possibility and desirability of exportation from here to
                    Denmark of raw materials to maintain Danish industries for domestic consumption,
                    suggesting figures for same.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
