<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-12-21T14:00:00-05:00" frus:doc-dateTime-min="1918-12-21T14:00:00-05:00" n="210" subtype="historical-document" type="document" xml:id="d210">
                            <note rend="inline" type="source">File No. 763.72112A/5402a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Ambassador in Mexico</hi> (<persName corresp="frus1918Supp01v01#p_FHP1" type="to"><hi rend="italic">Fletcher</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-12-21T14:00:00-05:00">
                                        <hi rend="italic">December 21, 1918, 2 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>1735. Japan is now participating enemy trade conferences London,
                                Paris, and Washington. You are authorized in conjunction with your
                                British, French, and Italian colleagues to invite representative of
                                Japan to participate in inter-Allied conferences on proposed changes
                                in black lists.</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_PFL1">
                                        <hi rend="smallcaps">Polk</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                    </body></text></TEI>