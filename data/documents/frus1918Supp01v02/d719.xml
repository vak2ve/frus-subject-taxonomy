    <text>
        <body>
            <div frus:doc-dateTime-max="1918-03-07T09:00:00-05:00"
                frus:doc-dateTime-min="1918-03-07T09:00:00-05:00" n="719"
                subtype="historical-document" type="document" xml:id="d719">
                <note rend="inline" type="source">File No. 652.119/628</note>
                <head>
                    <hi rend="italic">The Ambassador in Spain</hi> (<persName
                        corresp="frus1918Supp01v01#p_WJE1" type="from">
                        <hi rend="italic">Willard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-07T14:00:00+00:00">
                            <hi rend="italic">March 7, 1918, 2 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received March 8, 6.35 a.m.</hi>]</dateline>
                </opener>
                <p>1118. American-Spanish commercial agreement and French-Spanish commercial
                    financial agreement simultaneously ratified today by exchange of identic
                        notes.<note n="1" xml:id="d719fn1">The former agreement only is printed, <hi
                            rend="italic">infra.</hi>
                    </note> Copies by next pouch.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_WJE1">
                            <hi rend="smallcaps">Willard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
