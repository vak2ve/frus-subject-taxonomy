<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-03-18T13:00:00-05:00" frus:doc-dateTime-min="1918-03-18T13:00:00-05:00" n="480" subtype="historical-document" type="document" xml:id="d480">
                            <note rend="inline" type="source">File No. 656.119/224a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in the Netherlands</hi> (<persName corresp="frus1918Supp01v01#p_GJW1" type="to"><hi rend="italic">Garrett</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-03-18T13:00:00-05:00">
                                        <hi rend="italic">March 18, 1918, 1 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>1031. Cable at once any action Dutch Government may take with
                                reference to requisitioning boats. This Government is prepared to
                                act this evening.</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>