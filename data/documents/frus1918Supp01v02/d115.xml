<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-02-01T16:00:00-05:00" frus:doc-dateTime-min="1918-02-01T16:00:00-05:00" n="115" subtype="historical-document" type="document" xml:id="d115">
                            <note rend="inline" type="source">File No. 763.72112A/2734</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Great Britain</hi> (<persName corresp="frus1918Supp01v01#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-02-01T16:00:00-05:00">
                                        <hi rend="italic">February 1, 1918, 4 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>6408. For <persName>Frothingham</persName> from <persName corresp="frus1918Supp01v01#p_FPj1">Fuller</persName>:</p>
                            <p>Plan suggested yours January 23 <hi rend="italic">re</hi> enemy
                                trading list for Persia approved provided American representative is
                                guided by our law and instructions already forwarded you.</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>