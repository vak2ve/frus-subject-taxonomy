<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-01-30T23:59:59-05:00" frus:doc-dateTime-min="1918-01-30T00:00:00-05:00" n="32" subtype="historical-document" type="document" xml:id="d32">
                            <note rend="inline" type="source">File No. 763.72/8526</note>
                            <head>
                                <hi rend="italic">The Counselor for the Department of State</hi>
                                    (<persName corresp="frus1918Supp01v01#p_PFL1" type="from"><hi rend="italic">Polk</hi></persName>) <hi rend="italic">to
                                        <persName corresp="frus1918Supp01v01#p_GMM1" type="to">Major
                                        Grimprel</persName> of the French High Commission</hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-01-30">
                                        <hi rend="italic">January 30, 1918</hi></date>.</dateline>
                            </opener>
                            <p>
                                <hi rend="smallcaps">My Dear <persName corresp="frus1918Supp01v01#p_GMM1">Major
                                    Grimprel</persName></hi>: Referring to your letter of the 11th
                                instant, I beg to advise you that at the present time this
                                Government is not prepared to appoint a representative on the
                                Permanent International Committee on Economic Action.</p>
                            <p>Yours sincerely,</p>
                            <closer>[<signed><persName corresp="frus1918Supp01v01#p_PFL1">
                                        <hi rend="smallcaps">Frank L. Polk</hi>
                                    </persName></signed>]</closer>
                        </div>
                        </body></text></TEI>