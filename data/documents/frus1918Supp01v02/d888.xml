<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-07-09T15:48:00-05:00" frus:doc-dateTime-min="1918-07-09T15:48:00-05:00" n="888" subtype="historical-document" type="document" xml:id="d888">
                        <note rend="inline" type="source">File No. 763.72111/7037</note>
                        <head>
                            <hi rend="italic">The Chargé in Honduras</hi> (<persName corresp="frus1918Supp01v01#p_CCB1" type="from"><hi rend="italic">Curtis</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Tegucigalpa</hi></placeName>, <date calendar="gregorian" when="1918-07-09T15:00:00-05:48">
                                    <hi rend="italic">July 9, 1918, 3 p.m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received July 10, 11.52
                                a.m.</hi>]</dateline>
                        </opener>
                        <p>In reference to your July 6, 7 p.m. The President, the Minister for
                            Foreign Affairs, assure me that there are no restrictions whatsoever as
                            to the entrance into Honduran ports of American merchant vessels armed
                            for defense only.</p>
                        <closer>
                            <signed>
                                <persName corresp="frus1918Supp01v01#p_CCB1">
                                    <hi rend="smallcaps">Curtis</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>