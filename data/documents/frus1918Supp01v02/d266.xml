                            <cell role="num">10,000</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Naphtha and benzine</cell>
                            <cell role="num">3,000</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Petroleum</cell>
                            <cell role="num">40,000</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Crude oil</cell>
                            <cell role="num">20,000</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Fuel oil, including gasoline and Diesel oil</cell>
                            <cell role="num">3,500</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>(Mineral oils) paraffin wax, stearine, stearine acid, and palm
                                acid</cell>
                            <cell role="num">650</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Vegetable and mineral turpentine and white spirits</cell>
                            <cell role="num">190</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Varnishes</cell>
                            <cell role="num">260</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Shellac</cell>
                            <cell role="num">68</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Ceresin, carnauba wax</cell>
                            <cell role="num">40</cell>
                        </row>
                        <row>
                            <cell>C.</cell>
                            <cell>Rubber:</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Rubber shoes, tires, and other articles made of rubber</cell>
                            <cell role="num">500</cell>
                        </row>
                        <row>
                            <cell>D.</cell>
                            <cell>Textiles:</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell/>
                            <cell>Silk yarn and tissues</cell>
                            <cell role="num">110</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Cotton, raw, and yarn and manufactures</cell>
                            <cell role="num">8,000</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Wool, wool yarn, and products</cell>
                            <cell role="num">3,700</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Flax, hemp, jute, and tow</cell>
                            <cell role="num">5,000</cell>
                        </row>
                        <row>
                            <cell>E.</cell>
                            <cell>Miscellaneous:</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Corkwood</cell>
                            <cell role="num">900</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Borax and boric acid</cell>
                            <cell role="num">80</cell>
                        </row>
                        <row>
                            <cell/>
