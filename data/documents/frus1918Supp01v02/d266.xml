                            <cell role="num">12</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Hides</cell>
                            <cell role="num">2,500</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Tanning extract</cell>
                            <cell role="num">3,500</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Resin</cell>
                            <cell role="num">400</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Tobacco</cell>
                            <cell role="num">2,000</cell>
                        </row>
                        <pb facs="0313" n="1147" xml:id="pg_1147"/>
                        <row>
                            <cell>F.</cell>
                            <cell>Metals, minerals, etc.:</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell/>
                            <cell>Tin</cell>
                            <cell role="num">80</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Tin plate</cell>
                            <cell role="num">25,000</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Lead</cell>
                            <cell role="num">1,000</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Iron and steel (pig-iron ingots, bars, hoops, beams, angles,
                                plates, pipes, fittings, wire, etc.)</cell>
                            <cell role="num">50,000</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Copper (plates, bars, pipes, wire cable)</cell>
                            <cell role="num">2,000</cell>
                        </row>
                        <row>
                            <cell>G.</cell>
                            <cell>Machinery, etc., to be agreed; chemicals to be agreed; office
                                equipment and supplies as required; musical instruments,
                                phonographs, as required; glassware, pottery, ornamental electrical
                                fixtures, etc., as required; hardware as required.</cell>
                            <cell/>
                        </row>
                    </table>
                </p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
