<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-10-23T19:00:00-05:00" frus:doc-dateTime-min="1918-10-23T19:00:00-05:00" n="195" subtype="historical-document" type="document" xml:id="d195">
                            <note rend="inline" type="source">File No. 763.72112/10412</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Italy</hi> (<persName corresp="frus1918Supp01v01#p_PTN1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-10-23T20:00:00-04:00">
                                        <hi rend="italic">October 23, 1918, 8 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>1788. For <persName corresp="frus1918Supp01v01#p_SWAW1">Stewart</persName> [from War Trade Board]:</p>
                            <p>No. 26. Embassy’s 2122, October 10 [<hi rend="italic">11</hi>], 6
                                p.m. Exceptions outlined are in accordance with those proposed by
                                War Trade Board. Express our gratification at success of these
                                negotiations. Formal conferences now taking place at London, Paris,
                                and Washington.</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>