<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-08-16T23:59:59-05:00" frus:doc-dateTime-min="1918-08-16T00:00:00-05:00" n="300" subtype="historical-document" type="document" xml:id="d300">
                            <note rend="inline" type="source">War Trade Board Files:
                                American-Norwegian Agreement, Vol. III</note>
                            <head>
                                <hi rend="italic">The Italian High Commissioner</hi> (<persName corresp="frus1918Supp01v01#p_MdCCV1" type="from"><hi rend="italic">Macchi di Cellere</hi></persName>) <hi rend="italic">to the Chairman of the War Trade Board</hi>
                                    (<persName corresp="frus1918Supp01v01#p_MVC1" type="to"><hi rend="italic">McCormick</hi></persName>)</head>
                            <opener>
                                <seg rendition="#left">No. 8130/C—6</seg>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-08-16">
                                        <hi rend="italic">August 16, 1918</hi></date>.</dateline>
                            </opener>
                            <p>
                                <hi rend="smallcaps">My Dear Mr. <persName corresp="frus1918Supp01v01#p_MVC1">McCormick</persName></hi>: With reference to the Norwegian
                                agreement signed on April 30 last, I am directed by my Government to
                                notify you of their adhesion to said agreement.</p>
                            <p>Yours very truly,</p>
                            <closer>High Commissioner for Italy <lb/>
                                <hi rend="italic">per</hi>
                                <signed>
                                    <persName>
                                        <hi rend="smallcaps">F. Quattrone</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>