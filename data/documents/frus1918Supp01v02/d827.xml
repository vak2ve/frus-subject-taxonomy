<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-09-09T15:00:00-05:00" frus:doc-dateTime-min="1918-09-09T15:00:00-05:00" n="827" subtype="historical-document" type="document" xml:id="d827">
                        <note rend="inline" type="source">File No. 600.119/1259</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Spain</hi> (<persName corresp="frus1918Supp01v01#p_WJE1" type="to"><hi rend="italic">Willard</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-09-09T16:00:00-04:00">
                                    <hi rend="italic">September 9, 1918, 4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>1535. For <persName corresp="frus1918Supp01v01#p_CTL1">Chadbourne</persName> [from War Trade Board]:</p>
                        <p>No. 240. Yours of August 31, 7 p.m., Embassy’s 1761. Subject matter
                            referred to in your cable at present under discussion with Cuba. Will
                            cable you when final negotiations complete.</p>
                        <closer>
                            <signed>
                                <persName corresp="frus1918Supp01v01#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>