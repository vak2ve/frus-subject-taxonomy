    <text>
        <body>
            <div frus:doc-dateTime-max="1918-05-23T09:00:00-05:00"
                frus:doc-dateTime-min="1918-05-23T09:00:00-05:00" n="668"
                subtype="historical-document" type="document" xml:id="d668">
                <note rend="inline" type="source">File No. 654.119/280</note>
                <head>
                    <hi rend="italic">The Minister in Switzerland</hi> (<persName
                        corresp="frus1918Supp01v01#p_SPA1" type="from">
                        <hi rend="italic">Stovall</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berne</hi>
                        </placeName>, <date calendar="gregorian" when="1918-05-23T15:00:00+01:00">
                            <hi rend="italic">May 23, 1918, 3 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received May 25, 12.12 a.m.</hi>]</dateline>
                </opener>
                <p>3439. For War Trade Board [from Heck]:</p>
                <p>No. 46. Our No. 45.<note n="1" xml:id="d668fn1">Not printed.</note> German-Swiss
                    convention covering period of nine months from May 1 signed May 22. It may be
                    denounced every second month by a preliminary notice of one month. It contains
                    no clause referring to deliveries of coal by countries at war with Germany.
                    Heck.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_SPA1">
                            <hi rend="smallcaps">Stovall</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
