                subtype="historical-document" type="document" xml:id="d820">
                <note rend="inline" type="source">File No. 652.119/1102</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Spain</hi> (<persName corresp="frus1918Supp01v01#p_WJE1"
                        type="to">
                        <hi rend="italic">Willard</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-08-03T16:00:00-04:00">
                            <hi rend="italic">August 3, 1918, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1382. For <persName corresp="frus1918Supp01v01#p_CTL1">Chadbourne</persName>
                    [from War Trade Board]:</p>
                <p>No. 182. Embassy’s 1519, your No. 142, July 6, 6 p.m. We might be willing to
                    consider Spanish boats on South American route calling at some British port for
                    search and bunkers if you consider it advisable. Would like your
                    recommendations.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
