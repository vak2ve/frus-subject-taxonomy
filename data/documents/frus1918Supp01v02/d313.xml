                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="frus1918Supp01v01#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1918-02-13T10:00:00+00:00">
                            <hi rend="italic">February 13, 1918, 10 a.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received February 14, 5.30 a.m.</hi>]</dateline>
                </opener>
                <p>8638. War Trade Board [from <persName corresp="frus1918Supp01v01#p_SLP1"
                        >Sheldon</persName>]:</p>
