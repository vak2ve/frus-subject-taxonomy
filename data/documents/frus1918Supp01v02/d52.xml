                subtype="historical-document" type="document" xml:id="d52">
                <note rend="inline" type="source">File No. 103.96/321</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="frus1918Supp01v01#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-06T11:00:00+00:00">
                            <hi rend="italic">March 6, 1918, 11 a.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 12.20 p.m.</hi>]</dateline>
                </opener>
                <p>8908. War Trade Board [from <persName corresp="frus1918Supp01v01#p_SLP1"
                        >Sheldon</persName>]:</p>
                <p>No. 233. Your 99.<note n="1" xml:id="d52fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_957">p. 957</ref>.</note>
                    Foreign Office state they have telegraphed Embassy, Washington, concurring in
                    scheme arranged between yourselves and their Embassy under which call at
                    Halifax, with a saving as to special directions in any particular case, is to be
                    eliminated for vessels examined at New York.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
