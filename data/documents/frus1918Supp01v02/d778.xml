                subtype="historical-document" type="document" xml:id="d778">
                <note rend="inline" type="source">File No. 127.6/5a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Spain</hi> (<persName corresp="frus1918Supp01v01#p_WJE1"
                        type="to">
                        <hi rend="italic">Willard</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-09-03T14:00:00-04:00">
                            <hi rend="italic">September 3, 1918, 2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1504. Advise Department at once if there is any action which you wish the War
                    Trade Board to take in order to assist you in the present delicate diplomatic
                    situation in Spain.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
