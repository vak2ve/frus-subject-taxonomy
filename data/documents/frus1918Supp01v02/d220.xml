<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-07-15T17:00:00-05:00" frus:doc-dateTime-min="1918-07-15T17:00:00-05:00" n="220" subtype="historical-document" type="document" xml:id="d220">
                        <note rend="inline" type="source">File No. 763.72112Sa/3a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Ambassador in France</hi> (<persName corresp="frus1918Supp01v01#p_SWG1" type="to"><hi rend="italic">Sharp</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-07-15T18:00:00-04:00">
                                    <hi rend="italic">July 15, 1918, 6 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>5021. For <persName corresp="frus1918Supp01v01#p_MG1">McFadden</persName>
                            [from War Trade Board]:</p>
                        <p>No. 193. We have decided to permit auxiliary sailing vessels, chartered
                            to or for the account of the Swiss Government and holding safe conducts
                            from Germany, to traverse the submarine danger zone with goods destined
                            for Switzerland.</p>
                        <closer>
                            <signed>
                                <persName corresp="frus1918Supp01v01#p_PFL1">
                                    <hi rend="smallcaps">Polk</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>