                subtype="historical-document" type="document" xml:id="d517">
                <note rend="inline" type="source">File No. 656.119/350</note>
                <head>
                    <hi rend="italic">The Minister in the Netherlands</hi> (<persName
                        corresp="frus1918Supp01v01#p_GJW1" type="from">
                        <hi rend="italic">Garrett</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Hague</hi>
                        </placeName>, <date calendar="gregorian" when="1918-04-11T18:00:00+01:19">
                            <hi rend="italic">April 11</hi> [<hi rend="italic">13</hi>], <hi
                                rend="italic">1918, 6 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received April 14, 10.34 a.m.</hi>]</dateline>
                </opener>
                <p>2309. Your 1085, April 8, 5 p.m.<note n="1" xml:id="d517fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_1454">p. 1454</ref>.</note>
                    After comparison with instructions received by British Minister, I today
                    [communicated] to Minister for Foreign Affairs text of terms agreed upon for
                    payment, etc., for Dutch requisitioned ships and have given it to the press for
                    publication tomorrow.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_GJW1">
                            <hi rend="smallcaps">Garrett</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
