                <note rend="inline" type="source">File No. 600.119/1259</note>
                <head>
                    <hi rend="italic">The Ambassador in Spain</hi> (<persName
                        corresp="frus1918Supp01v01#p_WJE1" type="from">
                        <hi rend="italic">Willard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Sebastian</hi>
                        </placeName>, <date calendar="gregorian" when="1918-08-31T19:00:00+01:00">
                            <hi rend="italic">August 31, 1918, 7 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received September 1, 9.35 a.m.</hi>]</dateline>
                </opener>
                <p>1761. War Trade Board [from <persName corresp="frus1918Supp01v01#p_CTL1"
                        >Chadbourne</persName>]:</p>
                <p>233. Understand United States bunker rules do not apply to boats sailing between
                    Spain and Cuba not touching at any port in the United States or its possessions
                    but do not know whether or not the Republic of Cuba has issued bunker rules of
                    its own by agreement with United States. Please inform so that we may advise
                    consuls. <persName corresp="frus1918Supp01v01#p_CTL1">Chadbourne</persName>.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_WJE1">
                            <hi rend="smallcaps">Willard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
