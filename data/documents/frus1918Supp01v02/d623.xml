    <text>
        <body>
            <div frus:doc-dateTime-max="1918-11-25T23:59:59-05:00"
                frus:doc-dateTime-min="1918-11-25T00:00:00-05:00" n="623"
                subtype="historical-document" type="document" xml:id="d623">
                <note rend="inline" type="source">File No. 656.119/892</note>
                <head>
                    <hi rend="italic">The Chargé in Great Britain</hi> (<persName
                        corresp="frus1918Supp01v01#p_LIB1" type="from">
                        <hi rend="italic">Laughlin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-25">
                            <hi rend="italic">November 25, 1918</hi>
                        </date>. <lb/> [<hi rend="italic">Received 6.26 p.m.</hi>]</dateline>
                </opener>
                <p>4026. War Trade Board [from <persName corresp="frus1918Supp01v01#p_SLP1"
                        >Sheldon</persName>]:</p>
                <p>No. 1941. Dutch agreement was signed tonight. Such alterations as were made in
                    text sent you in my 1874, Embassy’s 3727, November 14,<note n="1"
                        xml:id="d623fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_1565">p. 1565</ref>.</note>
                    will be cabled you tomorrow. Of course the general embargo for all articles on
                    the ration list is automatically lifted.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_LIB1">
                            <hi rend="smallcaps">Laughlin</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
