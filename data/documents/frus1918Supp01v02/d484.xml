                subtype="historical-document" type="document" xml:id="d484">
                <note rend="inline" type="source">File No. 656.119/234</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="frus1918Supp01v01#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-20T12:00:00+00:00">
                            <hi rend="italic">March 20, 1918, 12 noon.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received March 20, 8.20 a.m.</hi>]</dateline>
                </opener>
                <p>9130. War Trade Board [from <persName corresp="frus1918Supp01v01#p_SLP1"
                        >Sheldon</persName>]:</p>
                <p>No. 309. <persName corresp="frus1918Supp01v01#p_CLR1">Cecil</persName> has just
                    informed me that he cabled the British Embassy late last night saying that His
                    Majesty’s Government considered the Dutch had refused proposal which was to
                    expire on the 18th, adding that they were prepared to requisition Dutch boats
                    and asking when you were doing likewise, so that the action might be
                    simultaneous. I take it, therefore, that you will be taking such steps
                    immediately.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
