<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-06-03T05:41:00-05:00" frus:doc-dateTime-min="1918-06-03T05:41:00-05:00" n="554" subtype="historical-document" type="document" xml:id="d554">
                            <note rend="inline" type="source">File No. 656.119/505</note>
                            <head>
                                <hi rend="italic">The Minister in the Netherlands</hi> (<persName corresp="frus1918Supp01v01#p_GJW1" type="from"><hi rend="italic">Garrett</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">The Hague</hi></placeName>, <date calendar="gregorian" when="1918-06-03T12:00:00+01:19">
                                        <hi rend="italic">June 3, 1918, 12 noon</hi></date>. <lb/>
                                        [<hi rend="italic">Received 3.29 p.m.</hi>]</dateline>
                            </opener>
                            <p>3000. Your 1343, June 1, 6 p.m.,<note n="1" xml:id="d554fn1">Not
                                    printed.</note> received today. Minister for Foreign Affairs
                                writes me <hi rend="italic">Hector</hi> and <hi rend="italic">Zijldijk</hi> have now received the German safe conducts and
                                are sailing today simultaneously with the <hi rend="italic">Java</hi> and <hi rend="italic">Stella</hi> from America.</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_GJW1">
                                        <hi rend="smallcaps">Garrett</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>