                subtype="historical-document" type="document" xml:id="d749">
                <note rend="inline" type="source">File No. 652.119/1354j</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Spain</hi> (<persName corresp="frus1918Supp01v01#p_WJE1"
                        type="to">
                        <hi rend="italic">Willard</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-08-10T13:00:00-04:00">
                            <hi rend="italic">August 10, 1918, 1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1411. For <persName>Smith</persName> from War Trade Board:</p>
                <p>Embassy’s 1608, July 31, 11 a.m. We are satisfied to have you come home for a
                    conference when in your judgment it seems best.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
