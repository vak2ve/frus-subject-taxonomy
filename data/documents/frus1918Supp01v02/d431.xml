<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-05-27T21:00:00-05:00" frus:doc-dateTime-min="1918-05-27T21:00:00-05:00" n="431" subtype="historical-document" type="document" xml:id="d431">
                        <note rend="inline" type="source">File No. 659a.119/18a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in Great Britain</hi> (<persName corresp="frus1918Supp01v01#p_LIB1" type="to"><hi rend="italic">Laughlin</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-05-27T22:00:00-04:00">
                                    <hi rend="italic">May 27, 1918, 10 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>7971. For <persName corresp="frus1918Supp01v01#p_SLP1">Sheldon</persName>
                            [from War Trade Board]:</p>
                        <p>No. 577. Your No. 640, Embassy 10222, May 24, noon.<note n="1" xml:id="d431fn1">Not printed.</note> Before formally adhering to
                            Iceland agreement please cable us the full text thereof. Meanwhile we
                            will continue to issue export licenses as contemplated by the agreement,
                            as set out in your No. 626, Embassy 10185, May 22, 5 p.m.</p>
                        <closer>
                            <signed>
                                <persName corresp="frus1918Supp01v01#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>