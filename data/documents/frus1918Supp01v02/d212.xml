    <text>
        <body>
            <div frus:doc-dateTime-max="1918-06-08T07:00:00-05:00"
                frus:doc-dateTime-min="1918-06-08T07:00:00-05:00" n="212"
                subtype="historical-document" type="document" xml:id="d212">
                <note rend="inline" type="source">File No. 763.72112Sa/16</note>
                <head>
                    <hi rend="italic">The Chargé in Great Britain</hi> (<persName
                        corresp="frus1918Supp01v01#p_LIB1" type="from">
                        <hi rend="italic">Laughlin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1918-06-08T13:00:00+01:00">
                            <hi rend="italic">June 8, 1918, 1 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 3.17 p.m.</hi>]</dateline>
                </opener>
                <p>10509. War Trade Board [from <persName corresp="frus1918Supp01v01#p_SLP1"
                        >Sheldon</persName>]:</p>
                <p>No. 748. I am informed that in consequence of an agreement between Germany and
                    Sweden the Germans will grant safe-conduct letters <pb facs="0248" n="1082"
                        xml:id="pg_1082"/> to Swedish steamers carrying noncontraband cargoes under
                    the general agreement between Sweden and the Associated Governments and also to
                    those ships proceeding to oversea countries outside the war zone. Swedish
                    authorities request that permission be granted to carry these letters in such
                    cases as vessels chartered for the Belgian Relief. British agree. Please
                    confirm.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_LIB1">
                            <hi rend="smallcaps">Laughlin</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
