<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-01-05T16:00:00-05:00" frus:doc-dateTime-min="1918-01-05T16:00:00-05:00" n="443" subtype="historical-document" type="document" xml:id="d443">
                            <note rend="inline" type="source">File No. 656.119/119b</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Great Britain</hi> (<persName corresp="frus1918Supp01v01#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-01-05T16:00:00-05:00">
                                        <hi rend="italic">January 5, 1918, 4 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>6172. For the Ambassador and <persName corresp="frus1918Supp01v01#p_SLP1">Sheldon</persName>:</p>
                            <p>For your confidential information and for the confidential
                                information of Foreign Office, but not under any circumstances to be
                                used by you or Foreign Office in any negotiations. In the event that
                                reasonable propositions made by United States are refused by Dutch
                                Government concerning tonnage, United States Government proposed
                                    [<hi rend="italic">sic</hi>] to requisition Dutch boats under
                                its control.</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>