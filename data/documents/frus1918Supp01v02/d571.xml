<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-07-11T11:00:00-05:00" frus:doc-dateTime-min="1918-07-11T11:00:00-05:00" n="571" subtype="historical-document" type="document" xml:id="d571">
                            <note rend="inline" type="source">File No. 656.119/608</note>
                            <head>
                                <hi rend="italic">The Chargé in Great Britain</hi> (<persName corresp="frus1918Supp01v01#p_LIB1" type="from"><hi rend="italic">Laughlin</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1918-07-11T17:00:00+01:00">
                                        <hi rend="italic">July 11, 1918, 5 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received July 11, 2.41
                                    p.m.</hi>]</dateline>
                            </opener>
                            <p>265. War Trade Board [from <persName corresp="frus1918Supp01v01#p_SLP1">Sheldon</persName>]:</p>
                            <p>No. 988. I have received the following cable from <persName corresp="frus1918Supp01v01#p_EPL1">Edwards</persName>: <quote rend="blockquote">
                                    <p>515, July 10, 4 p.m. For <persName corresp="frus1918Supp01v01#p_SLP1">Sheldon</persName>
                                        from <persName corresp="frus1918Supp01v01#p_EPL1">Edwards</persName>. Understand that within a few days
                                        Dutch expect to put forth general proposal for supplying of
                                        rations, granting of credit, etc. <persName corresp="frus1918Supp01v01#p_GJW1">Garrett</persName>.</p>
                                </quote>
                            </p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_LIB1">
                                        <hi rend="smallcaps">Laughlin</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>