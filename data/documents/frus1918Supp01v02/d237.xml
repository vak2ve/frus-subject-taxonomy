                subtype="historical-document" type="document" xml:id="d237">
                <note rend="inline" type="source">File No. 763.72112Sa/80a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Switzerland</hi> (<persName corresp="frus1918Supp01v01#p_SPA1"
                        type="to">
                        <hi rend="italic">Stovall</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-09-27T15:00:00-04:00">
                            <hi rend="italic">September 27, 1918—3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3007. For <persName corresp="frus1918Supp01v01#p_DEL1">Dresel</persName> [from
                    War Trade Board]:</p>
                <p>No. 120. Sailing vessels carrying “safe-conducts” from the German Government will
                    for the time being be permitted to sail from United States ports to Cette with
                    cargoes destined to Switzerland, provided such cargoes are not
                        objectionable.<note n="2" xml:id="d237fn2">See also telegram to the
                        Ambassador in Great Britain, No. 1648, Sept. 27, <hi rend="italic"
                        >ante</hi>, <ref target="#pg_997">p. 997</ref>.</note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
