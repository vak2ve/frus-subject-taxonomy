<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-07-06T23:59:59-05:00" frus:doc-dateTime-min="1918-07-06T00:00:00-05:00" n="887" subtype="historical-document" type="document" xml:id="d887">
                        <note rend="inline" type="source">File No. 763.72111/7035a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in Honduras</hi> (<persName corresp="frus1918Supp01v01#p_CCB1" type="to"><hi rend="italic">Curtis</hi></persName>)<note n="1" xml:id="d887fn1">The same,
                                on the same date, to the Ministers in Salvador and Guatemala (File
                                Nos. 763.72111/7035b and 7035c).</note>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-07-06">
                                    <hi rend="italic">July 6, 1918</hi></date>.</dateline>
                        </opener>
                        <p>Inform Department by cable what restrictions, if any, are imposed by
                            Government of country to which you are accredited, upon entrance into
                            its ports of armed American merchantmen engaged in commerce.</p>
                        <closer>
                            <signed>
                                <persName corresp="frus1918Supp01v01#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>