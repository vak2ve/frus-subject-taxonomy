    <text>
        <body>
            <div frus:doc-dateTime-max="1918-08-19T23:59:59-05:00"
                frus:doc-dateTime-min="1918-08-19T00:00:00-05:00" n="302"
                subtype="historical-document" type="document" xml:id="d302">
                <note rend="inline" type="source">File No. 657.119/873</note>
                <head>
                    <hi rend="italic">The Chargé in Norway</hi> (<persName
                        corresp="frus1918Supp01v01#p_SHFA1" type="from">
                        <hi rend="italic">Schoenfeld</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 890</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Christiania</hi>
                        </placeName>, <date calendar="gregorian" when="1918-08-19">
                            <hi rend="italic">August 19, 1918</hi>
                        </date>. <lb/> [<hi rend="italic">Received September 12.</hi>]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to report, for the Department’s
                    information, that a notice appeared in the press, under date of the 14th inst.,
                    that the Storting had unanimously approved, without debate, the report relative
                    to the agreement with the United States signed by Minister <persName
                        corresp="frus1918Supp01v01#p_NF1">Nansen</persName> on April 30, 1918.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_SHFA1">
                            <hi rend="smallcaps">H. F. Arthur Schoenfeld</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
