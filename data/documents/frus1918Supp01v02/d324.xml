    <text>
        <body>
            <div frus:doc-dateTime-max="1918-04-06T12:00:00-05:00"
                frus:doc-dateTime-min="1918-04-06T12:00:00-05:00" n="324"
                subtype="historical-document" type="document" xml:id="d324">
                <note rend="inline" type="source">File No. 658.119/300</note>
                <head>
                    <hi rend="italic">The Minister in Sweden</hi> (<persName
                        corresp="frus1918Supp01v01#p_MIN1" type="from">
                        <hi rend="italic">Morris</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Stockholm</hi>
                        </placeName>, <date calendar="gregorian" when="1918-04-06T18:00:00+01:00">
                            <hi rend="italic">April 6, 1918, 6 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 11.57 p.m.</hi>]</dateline>
                </opener>
                <p>1855. Your 673. British Minister has received instructions from his Government to
                    drop matter, as they did not wish to consider requisitioning.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_MIN1">
                            <hi rend="smallcaps">Morris</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
