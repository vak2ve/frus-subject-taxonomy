    <text>
        <body>
            <div frus:doc-dateTime-max="1918-03-27T12:00:00-05:00"
                frus:doc-dateTime-min="1918-03-27T12:00:00-05:00" n="494"
                subtype="historical-document" type="document" xml:id="d494">
                <note rend="inline" type="source">File No. 656.119/261</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="frus1918Supp01v01#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-27T18:00:00+01:00">
                            <hi rend="italic">March 27, 1918, 6 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received March 27, 11.17 a.m.</hi>]</dateline>
                </opener>
                <p>9240. War Trade Board [from <persName corresp="frus1918Supp01v01#p_SLP1"
                        >Sheldon</persName>]:</p>
                <p>No. 347. Foreign Office inquire reason for the release of Dutch steamers <hi
                        rend="italic">Borneo</hi> and <hi rend="italic">Cornelis</hi> and
                    reinstatement of crews after their having been taken over by the United States
                    Government.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
