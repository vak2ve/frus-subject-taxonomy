<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-05-31T17:00:00-05:00" frus:doc-dateTime-min="1918-05-31T17:00:00-05:00" n="552" subtype="historical-document" type="document" xml:id="d552">
                            <note rend="inline" type="source">File No. 656.119/491</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in the Netherlands</hi> (<persName corresp="frus1918Supp01v01#p_GJW1" type="to"><hi rend="italic">Garrett</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-05-31T18:00:00-04:00">
                                        <hi rend="italic">May 31, 1918, 6 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>1330. Your 2915, May 27, noon. Statement communicated to you by
                                    <persName corresp="frus1918Supp01v01#p_SRB1">Stevens</persName>
                                and quoted in your cable is approved and should be transmitted to
                                Foreign Office instead of statement contained in Department’s 1282,
                                May 25, 3 p.m.<note n="1" xml:id="d552fn1">Not printed.</note>
                            </p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>