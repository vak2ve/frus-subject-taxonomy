<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-02-06T18:00:00-05:00" frus:doc-dateTime-min="1918-02-06T18:00:00-05:00" n="427" subtype="historical-document" type="document" xml:id="d427">
                        <note rend="inline" type="source">File No. 659a.119/2</note>
                        <head>
                            <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="frus1918Supp01v01#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1918-02-06T23:00:00+00:00">
                                    <hi rend="italic">February 6, 1918, 11 p.m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received February 6, 9.45
                                p.m.</hi>]</dateline>
                        </opener>
                        <p>8540. War Trade Board [from <persName corresp="frus1918Supp01v01#p_SLP1">Sheldon</persName>]:</p>
                        <p>Restriction of Enemy Supplies Department reminds us that Iceland
                            negotiations are awaiting your reply to our No. 8421. Proposal has been
                            made to Board of Trade to stop dealing in Icelandic produce by private
                            British firms pending negotiations, provided the United States
                            Government agrees to adopt same course. <persName corresp="frus1918Supp01v01#p_SLP1">Sheldon</persName>.</p>
                        <closer>
                            <signed>
                                <persName corresp="frus1918Supp01v01#p_PWH1">
                                    <hi rend="smallcaps">Page</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>