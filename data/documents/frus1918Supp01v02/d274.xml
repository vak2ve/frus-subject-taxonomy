<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-03-25T09:00:00-05:00" frus:doc-dateTime-min="1918-03-25T09:00:00-05:00" n="274" subtype="historical-document" type="document" xml:id="d274">
                            <note rend="inline" type="source">File No. 657.119/379</note>
                            <head>
                                <hi rend="italic">The Minister in Norway</hi> (<persName corresp="frus1918Supp01v01#p_SAG1" type="from"><hi rend="italic">Schmedeman</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Christiania</hi></placeName>, <date calendar="gregorian" when="1918-03-25T15:00:00+01:00">
                                        <hi rend="italic">March 25, 1918—3 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 10.29 p.m.</hi>]</dateline>
                            </opener>
                            <p>616. For War Trade Board from <persName corresp="frus1918Supp01v01#p_DAV1">Dye</persName>: <quote rend="blockquote">
                                    <p>Referring to War Trade Board letter of January 26.<note n="1" xml:id="d274fn1">Not printed.</note> All food supplies
                                        which arrived on steamship <hi rend="italic">Bergensfjord</hi> consigned to firms at Bergen and
                                        Christiania have been requisitioned by Norwegian Government.
                                        I do not think any more export licenses should be issued
                                        until through diplomatic channels it is made clear that
                                        consignees will receive goods sent.</p>
                                </quote>
                            </p>
                            <p>I concur.</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_SAG1">
                                        <hi rend="smallcaps">Schmedeman</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>