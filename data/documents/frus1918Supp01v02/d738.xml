                subtype="historical-document" type="document" xml:id="d738">
                <note rend="inline" type="source">File No. 652.119/1082a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Spain</hi> (<persName corresp="frus1918Supp01v01#p_WJE1"
                        type="to">
                        <hi rend="italic">Willard</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-06-29T18:00:00-04:00">
                            <hi rend="italic">June 29, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1278. For <persName corresp="frus1918Supp01v01#p_CTL1">Chadbourne</persName>
                    [from <persName>Smith</persName>, War Trade Board]:</p>
                <p>No. 127. Yours, June 25, from Paris.<note n="1" xml:id="d738fn1">Not
                        printed.</note> In accordance with your recommendation we have decided to
                    extend bunker licensing freely from Atlantic and Gulf ports of the United
                    States. Meantime will probably decide to hold <hi rend="italic">Aviles</hi> at
                    Canal account War Department does not want nitrates to go to Spain as of
                    possible use in making ammunition.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
