<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-04-29T18:00:00-05:00" frus:doc-dateTime-min="1918-04-29T18:00:00-05:00" n="534" subtype="historical-document" type="document" xml:id="d534">
                            <note rend="inline" type="source">File No. 656.119/393</note>
                            <head>
                                <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="frus1918Supp01v01#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1918-04-30T00:00:00+01:00">
                                        <hi rend="italic">April 30, 1918, 12 a.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 4.13 p.m.</hi>]</dateline>
                            </opener>
                            <p>9781. War Trade Board [from <persName corresp="frus1918Supp01v01#p_SLP1">Sheldon</persName>]:</p>
                            <p>No. 502. My 485. Foreign Office requests no steps be taken publishing
                                the declination [<hi rend="italic">declaration?</hi>] without
                                further consultation with them. They believe publication should be
                                postponed until Dutch-German position is clear.<note n="1" xml:id="d534fn1">See <hi rend="italic">post</hi>, <ref target="#pg_1797">pp. 1797</ref>
                                    <hi rend="italic">et seq.</hi>
                                </note>
                            </p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_PWH1">
                                        <hi rend="smallcaps">Page</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>