    <text>
        <body>
            <div frus:doc-dateTime-max="1917-11-28T12:29:00-05:00"
                frus:doc-dateTime-min="1917-11-28T12:29:00-05:00" n="794"
                subtype="historical-document" type="document" xml:id="d794">
                <note rend="inline" type="source">File No. 837.711/4</note>
                <head>
                    <hi rend="italic">The Chargé in Cuba</hi> (<persName type="from">
                        <hi rend="italic">Scholle</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1917-11-28T12:00:00-05:29">
                            <hi rend="italic">November 28, 1917, 12 noon</hi>
                        </date>. <lb/> [<hi rend="italic">Received 1.40 p.m.</hi>]</dateline>
                </opener>
                <p>President has issued a decree establishing censorship on telegrams, letters,
                    newspaper articles, prints, writings and speeches. Sending translation by
                        mail.<note n="1" xml:id="d794fn1">Not printed.</note>
                </p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Scholle</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
