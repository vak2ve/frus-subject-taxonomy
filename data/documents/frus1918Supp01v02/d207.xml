<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-11-20T16:00:00-05:00" frus:doc-dateTime-min="1918-11-20T16:00:00-05:00" n="207" subtype="historical-document" type="document" xml:id="d207">
                            <note rend="inline" type="source">File No. 763.72112/10817</note>
                            <head>
                                <hi rend="italic">The Ambassador in France</hi> (<persName corresp="frus1918Supp01v01#p_SWG1" type="from"><hi rend="italic">Sharp</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1918-11-20T21:00:00+00:00">
                                        <hi rend="italic">November 20, 1918, 9 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 10 p.m.</hi>]</dateline>
                            </opener>
                            <p>5935. War Trade Board, Bureau of Enemy Trade [from <persName corresp="frus1918Supp01v01#p_MG1">McFadden</persName>]:</p>
                            <p>No. 617. Referring to Department’s 6206 of October 13 [<hi rend="italic">November 8</hi>], your 425. French Government are
                                in accord with your views that decisions of enemy license
                                conferences should become effective at once and are advising their
                                representatives in Washington and London to this effect. <persName corresp="frus1918Supp01v01#p_MG1">McFadden</persName>.</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1918Supp01v01#p_SWG1">
                                        <hi rend="smallcaps">Sharp</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>