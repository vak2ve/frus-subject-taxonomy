                subtype="historical-document" type="document" xml:id="d825">
                <note rend="inline" type="source">File No. 652.119/1469</note>
                <head>
                    <hi rend="italic">The War Trade Board Representative in Cuba</hi> (<persName
                        corresp="frus1918Supp01v01#p_MHH1" type="from">
                        <hi rend="italic">Morgan</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1918-08-22T16:00:00-05:29">
                            <hi rend="italic">August 22, 1918, 4 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 7.45 p.m.</hi>]</dateline>
                </opener>
                <p>For <persName corresp="frus1918Supp01v01#p_SJH2">Stabler</persName>. Your August
                    21. Spanish Minister advises me that he sent a telegram for the Transatlantic
                    Company some days ago <pb facs="0910" n="1744" xml:id="pg_1744"/> regarding the
                    matter discussed in your office and expects a reply from day to day. See my
                    letters of August 10 and 14 upon this subject.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_MHH1">
                            <hi rend="smallcaps">Morgan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
