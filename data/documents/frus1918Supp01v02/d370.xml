<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-10-07T11:00:00-05:00" frus:doc-dateTime-min="1918-10-07T11:00:00-05:00" n="370" subtype="historical-document" type="document" xml:id="d370">
                            <note rend="inline" type="source">File No. 658.119/646</note>
                            <head>
                                <hi rend="italic">The Chargé in Sweden</hi> (<persName type="from"><hi rend="italic">Whitehouse</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Stockholm</hi></placeName>, <date calendar="gregorian" when="1918-10-07T17:00:00+01:00">
                                        <hi rend="italic">October 7, 1918, 5 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received October 8, 1.45
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>2954. Allied ministers have informed Minister for Foreign Affairs
                                that their Governments adhered to our note regarding the breach of
                                agreement.</p>
                            <closer>
                                <signed>
                                    <persName>
                                        <hi rend="smallcaps">Whitehouse</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>