    <text>
        <body>
            <div frus:doc-dateTime-max="1918-03-29T15:00:00-05:00"
                frus:doc-dateTime-min="1918-03-29T15:00:00-05:00" n="131"
                subtype="historical-document" type="document" xml:id="d131">
                <note rend="inline" type="source">File No. 763.72112/7434</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName corresp="frus1918Supp01v01#p_SWG1"
                        type="to">
                        <hi rend="italic">Sharp</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-29T15:00:00-05:00">
                            <hi rend="italic">March 29, 1918, 3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3402. <persName>Frederick A. Sterling</persName> of your Embassy, who is familiar
                    with procedure for the inclusion or removal of names from enemy trading list,
                    designated for the purpose mentioned your 3214, February 19, 11 a.m.<note n="1"
                        xml:id="d131fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_1017">p. 1017</ref>.</note> So
                    inform Foreign Office.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1918Supp01v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
