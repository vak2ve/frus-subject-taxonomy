<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1923-07-21T07:00:00-05:00" frus:doc-dateTime-min="1923-07-21T07:00:00-05:00" n="696" subtype="historical-document" type="document" xml:id="d696">
                        <note rend="inline" type="source">711.60 f 2/2: Telegram</note>
                        <head><hi rend="italic">The Minister in Czechoslovakia</hi> (<persName type="from"><hi rend="italic">Einstein</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Prague</hi></placeName>, <date calendar="gregorian" when="1923-07-21T13:00:00+01:00"><hi rend="italic">July 21,
                                        1923—1 p.m.</hi></date><lb/>[Received July 23—4:10
                                p.m.]</dateline></opener>
                        <p>34. Your 27. Minister for Foreign Affairs assures me that Czechoslovak
                            Government will be very glad to negotiate a general treaty.</p>
                        <closer><signed><hi rend="smallcaps">Einstein</hi></signed></closer>
                    </div>
                    </body></text></TEI>