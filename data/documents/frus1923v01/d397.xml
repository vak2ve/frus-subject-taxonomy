<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1923-01-18T22:00:00-05:00" frus:doc-dateTime-min="1923-01-18T22:00:00-05:00" n="397" subtype="historical-document" type="document" xml:id="d397">
                        <note rend="inline" type="source">893.00/4824: Telegram</note>
                        <head><hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">Schurman</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1923-01-19T11:00:00+08:00"><hi rend="italic">January 19,
                                        1923—11 a.m.</hi></date><lb/>[Received January 19—6:54
                                a.m.]</dateline></opener>
                        <p>24. Following from Canton: <quote rend="blockquote">
                                <p>“January 18, 7 p.m. Referring to my telegram of January 16th, 11
                                    a.m. Chen went to Waichow not to Hong Kong. Situation at Canton
                                    confused as there is no leader here recognized by all military
                                    forces in the city.”</p>
                            </quote></p>
                        <closer><signed><hi rend="smallcaps">Schurman</hi></signed></closer>
                    </div>
                    </body></text></TEI>