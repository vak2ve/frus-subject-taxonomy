<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1923-04-14T19:00:00-05:00" frus:doc-dateTime-min="1923-04-14T19:00:00-05:00" n="665" subtype="historical-document" type="document" xml:id="d665">
                        <note rend="inline" type="source">711.1828/10: Telegram</note>
                        <head><hi rend="italic">The Minister in Costa Rica</hi> (<persName type="from"><hi rend="italic">Davis</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">San
                                        José</hi></placeName>, <date calendar="gregorian" when="1923-04-14T18:00:00-06:00"><hi rend="italic">April 14,
                                        1923—6 p.m.</hi></date><lb/>[Received April 16—3
                                p.m.]</dateline></opener>
                        <p>23. My number 22, April 10, 4 p.m.<note n="4" xml:id="d665fn4">Not
                                printed.</note> President Acosta yesterday withdrew canal protocol
                            from Congress.</p>
                        <closer><signed><hi rend="smallcaps">Davis</hi></signed></closer>
                    </div>
                </body></text></TEI>