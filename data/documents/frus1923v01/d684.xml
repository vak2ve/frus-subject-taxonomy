                subtype="historical-document" type="document" xml:id="d684">
                <note rend="inline" type="source">637.0023/24: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Cuba</hi> (<persName type="from">
                        <hi rend="italic">Howell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1923-08-11T10:00:00-05:29">
                            <hi rend="italic">August 11, 1923—10 a.m.</hi>
                        </date>
                        <lb/>[Received 12:06 p.m.]</dateline>
                </opener>
                <p>72. Your 67, August 10, noon, and Mr. Wright’s<note n="29" xml:id="d684fn29">J.
                        Butler Wright, Third Assistant Secretary of State.</note> conversation by
                    telephone.</p>
                <p>The note regarding Tarafa bill was handed to the Secretary of State last
                    night.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Howell</hi>
                    </signed>
                </closer>
            </div>
        </body>
