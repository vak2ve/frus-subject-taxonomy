                subtype="historical-document" type="document" xml:id="d346">
                <note rend="inline" type="source">893.002/121: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Schurman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1923-04-09T10:00:00+08:00">
                            <hi rend="italic">April 9, 1923—10 a.m.</hi>
                        </date>
                        <lb/>[Received April 9—4: 37 a.m.]</dateline>
                </opener>
                <p>98. My 93, March 29, 5 p.m.<note n="11" xml:id="d346fn11">Not printed.</note> By
                    Presidential mandate yesterday resignation of Huang Fu is accepted and
                    Wellington Koo appointed Acting Minister of Foreign Affairs.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schurman</hi>
                    </signed>
                </closer>
            </div>
        </body>
