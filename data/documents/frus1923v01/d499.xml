                subtype="historical-document" type="document" xml:id="d499">
                <note rend="inline" type="source">393.1123 Lincheng/28: Telegram</note>
                <head>
                    <hi rend="italic">The Counselor of Legation at Peking</hi> (<persName
                        type="from">
                        <hi rend="italic">Bell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1923-05-10T15:00:00+08:00">
                            <hi rend="italic">May 10, 1923—3 p.m.</hi>
                        </date>
                        <lb/>[Received May 10—8:30 a.m.]</dateline>
                </opener>
                <p>148. My 139, May 8, 11 a.m.<note n="76" xml:id="d499fn76">Not printed.</note>
                    Following from Consul Davis, Lincheng: <quote rend="blockquote">
                        <p>“Robert Allen, Rowland Pinger released. Their fathers in good condition.
                            Hope others will be released soon. Situation hopeful. Davis.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schurman</hi> [<hi rend="italic">Bell</hi>]</signed>
                </closer>
            </div>
        </body>
    </text>
