                <note rend="inline" type="source">512.4 A 1a/229½</note>
                <head>
                    <hi rend="italic">President <persName type="from">Coolidge</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1923-08-21">
                            <hi rend="italic">August 21, 1923</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: I have noted your letter of
                    August 21st in regard to the International Office of Public Health and will be
                        <pb facs="0231" n="115" xml:id="pg_115"/> glad to have you act favorably in
                    the matter you present if your judgment approves.</p>
                <p>Very truly yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Calvin Coolidge</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
