                subtype="historical-document" type="document" xml:id="d399">
                <note rend="inline" type="source">893.00/4856: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Schurman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1923-02-15T23:00:00+08:00">
                            <hi rend="italic">February 15, 1923—11 p.m.</hi>
                        </date>
                        <lb/>[Received 12:18 p.m.]</dateline>
                </opener>
                <p>58. Following from Shanghai: <quote rend="blockquote">
                        <p>“February 15, 4 p.m. Sun Yat-sen and staff sailed today steamship <hi
                                rend="italic">President Jefferson</hi> for Hongkong.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schurman</hi>
                    </signed>
                </closer>
            </div>
        </body>
