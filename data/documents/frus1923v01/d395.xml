<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1923-01-16T04:00:00-05:00" frus:doc-dateTime-min="1923-01-16T04:00:00-05:00" n="395" subtype="historical-document" type="document" xml:id="d395">
                        <note rend="inline" type="source">893.00/4819: Telegram</note>
                        <head><hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">Schurman</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1923-01-16T17:00:00+08:00"><hi rend="italic">January 16,
                                        1923—5 p.m.</hi></date><lb/>[Received January 16—9:34
                                a.m.]</dateline></opener>
                        <p>20. Following from Consul at Canton: <quote rend="blockquote">
                                <p>“January 16, 11 a.m. Yunnan-Kwangsi army occupied Samshui. Chen
                                    Chiung-ming left Canton believed for Hong Kong. Local troops
                                    ready to change sides.”</p>
                            </quote></p>
                        <closer><signed><hi rend="smallcaps">Schurman</hi></signed></closer>
                    </div>
                    </body></text></TEI>