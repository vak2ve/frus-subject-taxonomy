                subtype="historical-document" type="document" xml:id="d182">
                <note rend="inline" type="source">710.E/180: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Bolivia</hi> (<persName type="from">
                        <hi rend="italic">Cottrell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">La Paz</hi>
                        </placeName>, <date calendar="gregorian" when="1923-02-17T10:00:00-04:32">
                            <hi rend="italic">February 17, 1923—10 a.m.</hi>
                        </date>
                        <lb/>[Received 2:40 p.m.]</dateline>
                </opener>
                <p>6. Bolivian Government announces it will not concur [<hi rend="italic">sic</hi>]
                    in Pan American Conference because of Chile’s unwillingness to accept a revision
                    of the treaty of 1904.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cottrell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
