                subtype="historical-document" type="document" xml:id="d707">
                <note rend="inline" type="source">711.60f 2/12: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Czechoslovakia</hi> (<persName type="from">
                        <hi rend="italic">White</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Prague</hi>
                        </placeName>, <date calendar="gregorian" when="1923-11-16T12:00:00+01:00">
                            <hi rend="italic">November 16, 1923—noon</hi>
                        </date>.<lb/>[Received 8:15 p.m.]</dateline>
                </opener>
                <p>49. Your telegram number 39.<note n="8" xml:id="d707fn8">Not printed.</note>
                    While agreement not yet ratified by Parliament other formalities completed and
                    it has been legally effective since November 5th.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">White</hi>
                    </signed>
                </closer>
            </div>
        </body>
