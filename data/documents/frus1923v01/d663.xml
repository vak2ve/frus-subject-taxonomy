                <note rend="inline" type="source">711.1828/5: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Costa Rica</hi> (<persName type="from">
                        <hi rend="italic">Davis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San José</hi>
                        </placeName>, <date calendar="gregorian" when="1923-03-27T20:00:00-06:00">
                            <hi rend="italic">March 27, 1923—8 p.m.</hi>
                        </date>
                        <lb/>[Received March 28—4:40 p.m.]</dateline>
                </opener>
                <p>19. My 12, March 2, 4 p.m.<note n="3" xml:id="d663fn3">Not printed.</note> I have
                    been informed that ratification of Canal protocol is doubtful. …</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
