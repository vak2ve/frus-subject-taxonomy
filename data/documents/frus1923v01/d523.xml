                subtype="historical-document" type="document" xml:id="d523">
                <note rend="inline" type="source">393.1123 Lincheng/139: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Schurman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1923-06-10T19:00:00+08:00">
                            <hi rend="italic">June 10, 1923—7 p.m.</hi>
                        </date>
                        <lb/>[Received June 10—2:05 p.m.]</dateline>
                </opener>
                <p>213. Following telegram from Davis and Philoon dated June 9, 8 p.m. received June
                    10, 5 p.m.: <pb facs="0772" n="656" xml:id="pg_656"/>
                    <quote rend="blockquote">
                        <p>Banditti today stated all terms acceptable but requested three more days
                            to complete enrollment. Efforts are being made to effect release
                            Monday.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schurman</hi>
                    </signed>
                </closer>
            </div>
        </body>
