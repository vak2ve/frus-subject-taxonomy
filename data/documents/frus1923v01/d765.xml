    <text>
        <body>
            <div frus:doc-dateTime-max="1923-06-23T09:40:00-05:00"
                frus:doc-dateTime-min="1923-06-23T09:40:00-05:00" n="765"
                subtype="historical-document" type="document" xml:id="d765">
                <note rend="inline" type="source">839.6463/114: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in the Dominican Republic</hi> (<persName
                        type="from">
                        <hi rend="italic">Russell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1923-06-23T10:00:00-04:40">
                            <hi rend="italic">June 23, 1923—10 a.m.</hi>
                        </date>
                        <lb/>[Received June 25—3:40 p.m.]</dateline>
                </opener>
                <p>28. Contract for settlement of the case of the Santo Domingo Water, Light and
                    Power Company has been approved by both municipalities. <pb facs="1038" n="922"
                        xml:id="pg_922"/> Please notify company. Contract will be forwarded by next
                        mail.<note n="14" xml:id="d765fn14">Despatch no. 868, June 24, not
                        printed.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Russell</hi>
                    </signed>
                </closer>
            </div>
        </body>
