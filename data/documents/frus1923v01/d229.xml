    <text>
        <body>
            <div frus:doc-dateTime-max="1923-03-01T23:59:59-05:00"
                frus:doc-dateTime-min="1923-03-01T00:00:00-05:00" n="229"
                subtype="historical-document" type="document" xml:id="d229">
                <note rend="inline" type="source">723.2515/1129</note>
                <head>
                    <hi rend="italic">The Chilean Ambassador</hi> (<persName type="from">
                        <hi rend="italic">Mathieu</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1923-03-01">
                            <hi rend="italic">March 1, 1923</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 52</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: I have the honor to inform
                    Your Excellency that my Government has appointed the former Minister of Foreign
                    Relations, Señor Ernesto Barros Jarpa, to take charge of Chile’s interests in
                    the arbitration agreed with Peru in the Protocol of July 20, 1922.</p>
                <p>Señor Barros Jarpa is already in Washington and will have his office at the
                    Embassy.</p>
                <p>In bringing this appointment to Your Excellency’s knowledge for all pertinent
                    purposes, I take [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">B. Mathieu</hi>
                    </signed>
                </closer>
            </div>
        </body>
