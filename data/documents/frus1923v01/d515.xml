<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1923-05-31T03:00:00-05:00" frus:doc-dateTime-min="1923-05-31T03:00:00-05:00" n="515" subtype="historical-document" type="document" xml:id="d515">
                        <note rend="inline" type="source">393.1123 Lincheng/117: Telegram</note>
                        <head><hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from"><hi rend="italic">Cunningham</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Shanghai</hi></placeName>, <date calendar="gregorian" when="1923-05-31T16:00:00+08:00"><hi rend="italic">May 31,
                                        1923—4 p.m.</hi></date><lb/>[Received May 31—4:36
                                a.m.]</dateline></opener>
                        <p>Davis reports Allen<note n="89" xml:id="d515fn89">Maj. Robert A. Allen,
                                United States Army.</note> and Smith<note n="90" xml:id="d515fn90">William Smith, British citizen.</note> released unconditionally.
                            Proceeding Tientsin. Negotiations continuing favorably.</p>
                        <closer><signed><hi rend="smallcaps">Cunningham</hi></signed></closer>
                    </div>
                    </body></text></TEI>