                <head ana="#head_untitled-missing-head-in-printed-volume">[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Birkenhead Iron Works,</hi>
                            <hi rend="italic">Birkenhead,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1863-10-28">
                            <hi rend="italic">October</hi> 28, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Sir:</hi> In reply to your note of this day, asking
                    for Mr. Bravay’s address, it is as follows: Messrs. A. Bravay &amp; Co., 6 Rue
                    de Londres, Paris.</p>
                <p>Your obedient servant,</p>
                <closer>
                    <signed>LAIRD BROTHERS.</signed>
                </closer>
                <postscript>
                    <p>Mr. <hi rend="smallcaps">Morgan.</hi>
                    </p>
                </postscript>
            </div>
        </body>
