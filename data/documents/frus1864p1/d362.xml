<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1863-07-08T23:59:59-05:00" frus:doc-dateTime-min="1863-07-08T00:00:00-05:00" n="362" subtype="historical-document" type="document" xml:id="d362">
                    <opener><seg rendition="#center">No. 5.</seg></opener>
                    <head><persName type="from">Earl Russell</persName> to <persName type="to">Mr.
                            Mason</persName>.</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName><hi rend="smallcaps">Foreign Office,</hi></placeName>
                            <date calendar="gregorian" when="1863-07-08"><hi rend="italic">July</hi>
                                8, 1863.</date></dateline></opener>
                    <p><hi rend="smallcaps">Sir:</hi> I have the honor to acknowledge the receipt of
                        your letter of the 4th instant and its enclosures, relative to the position
                        of Mr. G. Moore, her Majesty’s consul at Richmond.</p>
                    <p>I am, &amp;c.</p>
                    <closer>
                        <signed>RUSSELL.</signed></closer>
                </div>
                </body></text></TEI>