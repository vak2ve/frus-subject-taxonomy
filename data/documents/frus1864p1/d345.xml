<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1864-05-09T23:59:59-05:00" frus:doc-dateTime-min="1864-05-09T00:00:00-05:00" n="345" subtype="historical-document" type="document" xml:id="d345">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName>.</head>
                        <opener>
                            <seg rendition="#left">No. 943]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1864-05-09"><hi rend="italic">May</hi> 9, 1864.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> I have the honor to acknowledge the
                            receipt of your despatches of the 21st ultimo, Nos. 662 to 665
                            inclusive; also those of the 22d, Nos. 666 to 669; and they are
                            approved.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">C. F. Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>