<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1863-12-17T23:59:59-05:00" frus:doc-dateTime-min="1863-12-17T00:00:00-05:00" n="242" subtype="historical-document" type="document" xml:id="d242">
                            <opener><seg rendition="#center">No. 12.</seg></opener>
                            <head><persName type="from">Earl Russell</persName> to <persName type="to">Mr. Adams</persName>.</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName><hi rend="smallcaps">Foreign Office,</hi></placeName>
                                    <date calendar="gregorian" when="1863-12-17"><hi rend="italic">December</hi> 17, 1863.</date></dateline></opener>
                            <p><hi rend="smallcaps">Sir:</hi> I have the honor to acknowledge the
                                receipt of your note of the 14th instant, respecting the seamen
                                embarked on board the United States steamer Kearsarge at
                                Queenstown.</p>
                            <p>I am, &amp;c.,</p>
                            <closer>
                                <signed>RUSSELL.</signed></closer>
                        </div>
                        </body></text></TEI>