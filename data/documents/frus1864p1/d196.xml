    <text>
        <body>
            <div frus:doc-dateTime-max="1863-12-21T23:59:59-05:00" frus:doc-dateTime-min="1863-12-21T00:00:00-05:00" n="196" subtype="historical-document" type="document" xml:id="d196">
                <head>
                    <persName type="from">Laird Brothers</persName> to <persName type="to">her Majesty’s Treasury</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Birkenhead Iron Works,</hi>
                            <hi rend="italic">Birkenhead,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1863-12-21">
                            <hi rend="italic">December</hi> 21, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> We beg to acknowlege the receipt of
                                your letter of the 18th instant, and hope to send a reply
                                to-morrow.</p>
                <p>We are, sir, your obedient servants,</p>
                <closer>
                    <signed>LAIRD BROTHERS.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">G. A. Hamilton,</hi> Esq.</p>
                </postscript>
            </div>
        </body>
