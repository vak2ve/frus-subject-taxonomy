    <text>
        <body>
            <div frus:doc-dateTime-max="1864-04-04T23:59:59-05:00"
                frus:doc-dateTime-min="1864-04-04T00:00:00-05:00" n="297"
                subtype="historical-document" type="document" xml:id="d297">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Adams</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 894.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1864-04-04">
                            <hi rend="italic">April</hi> 4, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have received your despatch of March 18, No.
                    622, and have placed before the President the proceedings of the meeting of the
                    citizens of Rochdale. They were received by him with feelings of grateful
                    satisfaction. I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">C. F. Adams</hi>, Esq., <hi rend="italic">&amp;c.,
                            &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
