    <text>
        <body>
            <div frus:doc-dateTime-max="1863-10-26T23:59:59-05:00" frus:doc-dateTime-min="1863-10-26T00:00:00-05:00" n="221" subtype="historical-document" type="document" xml:id="d221">
                <head>
                    <persName type="from">Captain Inglefield, H. M. S.
                                    Majestic,</persName> to <persName type="to">Laird
                                    Brothers</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Her Majesty’s Steamer
                                            Majestic,</hi>
                            <hi rend="italic">Rock Ferry,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1863-10-26">
                            <hi rend="italic">October,</hi> 26, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Gentlemen:</hi> I have to acknowledge your
                                letter of the 24th instant, acquainting me that you propose to open
                                your graving dock to-morrow morning.</p>
                <p>I am, gentlemen, your obedient servant,</p>
                <closer>
                    <signed>E. A. INGLEFIELD, <hi rend="italic">Captain.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
