<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1864-04-13T23:59:59-05:00" frus:doc-dateTime-min="1864-04-13T00:00:00-05:00" n="357" subtype="historical-document" type="document" xml:id="d357">
                    <opener><seg rendition="#center">No. 6.</seg></opener>
                    <head><persName type="from">Earl Russell</persName> to <persName type="to">Mr.
                            Adams</persName>.</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName><hi rend="smallcaps">Foreign Office,</hi></placeName>
                            <date calendar="gregorian" when="1864-04-13"><hi rend="italic">April</hi> 13, 1864.</date></dateline></opener>
                    <p><hi rend="smallcaps">Sir:</hi> I have the honor to acknowledge the receipt of
                        your note of the 11th instant, relative to the proceedings of the officers
                        of the United States steamer Kearsarge, in regard to the enlistment of
                        British subjects for service on board that vessel.</p>
                    <p>I am, &amp;c.,</p>
                    <closer>
                        <signed>RUSSELL.</signed></closer>
                </div>
            </body></text></TEI>