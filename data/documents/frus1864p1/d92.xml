    <text>
        <body>
            <div frus:doc-dateTime-max="1864-02-29T23:59:59-05:00" frus:doc-dateTime-min="1864-02-29T00:00:00-05:00" n="92" subtype="historical-document" type="document" xml:id="d92">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 857.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1864-02-29">
                            <hi rend="italic">February</hi> 29, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I transmit herewith, for your information,
                            a copy of an instruction to Mr. Dayton, of the 25th instant, No. 487, in
                            regard to the newspaper report of S. R<hi rend="italic">.</hi> Mallory,
                            the pretended secretary of the navy of the insurgents, recently sent to
                            you.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">C. F. Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
                <frus:attachment>
                    <p>[See instructions to Mr. Dayton for enclosure.]</p>
                </frus:attachment>
            </div>
        </body>
    </text>
