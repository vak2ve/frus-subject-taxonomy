    <text>
        <body>
            <div frus:doc-dateTime-max="1863-12-09T23:59:59-05:00" frus:doc-dateTime-min="1863-12-09T00:00:00-05:00" n="259" subtype="historical-document" type="document" xml:id="d259">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr Gunnison</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1863-12-09">
                            <hi rend="italic">December</hi> 9, 1863—1.30 <hi rend="italic">p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Is the steamer Chesapeake, or has she been, in your port? Please
                                answer.</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
            </div>
        </body>
