<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1863-10-08T23:59:59-05:00" frus:doc-dateTime-min="1863-10-08T00:00:00-05:00" n="210" subtype="historical-document" type="document" xml:id="d210">
                            <head><persName type="from">Assistant collector of her Majesty’s
                                    customs, Liverpool,</persName> to <persName type="to">Laird
                                    Brothers</persName>.</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName><hi rend="smallcaps">Custom-House,
                                        Liverpool,</hi></placeName>
                                    <date calendar="gregorian" when="1863-10-08"><hi rend="italic">October</hi> 8, 1863.</date></dateline></opener>
                            <p><hi rend="smallcaps">Gentlemen:</hi> I beg to acknowledge the receipt
                                of your letter of this day’s date, stating that you had given to Mr.
                                Morgan, surveyor, an order of admission to the iron-clad El Tousson,
                                and beg to thank you for the facility afforded by you to the
                                officers of customs at all times.</p>
                            <p>I am, gentlemen, your obedient servant,</p>
                            <closer>
                                <signed>W. G. STEWART, <hi rend="italic">Assistant
                                    Collector.</hi></signed></closer>
                            <postscript>
                                <p>Messrs. <hi rend="smallcaps">Laird Brothers.</hi></p>
                            </postscript>
                        </div>
                        </body></text></TEI>