<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1864-01-06T23:59:59-05:00" frus:doc-dateTime-min="1864-01-06T00:00:00-05:00" n="101" subtype="historical-document" type="document" xml:id="d101">
                            <opener><seg rendition="#center">No. 4.</seg></opener>
                            <head><persName type="from">Mr. Hammond</persName> to <persName type="to">Messrs. Sinclair &amp; Co</persName>.</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName><hi rend="smallcaps">Foreign Office,</hi></placeName>
                                    <date calendar="gregorian" when="1864-01-06"><hi rend="italic">January</hi> 6, 1864.</date></dateline></opener>
                            <p><hi rend="smallcaps">Gentlemen:</hi> I am directed by Earl Russell to
                                acknowledge the receipt of <pb facs="0274" n="264" xml:id="pg_264"/>
                                your letter of the 4th instant, respecting the seizure of the bark
                                Saxon by the United States steamer Vanderbilt; and I am to inform
                                you that this case is under the consideration of her Majesty’s
                                government.</p>
                            <p>I am, &amp;c.,</p>
                            <closer>
                                <signed>E.HAMMOND.</signed></closer>
                        </div>
                        </body></text></TEI>