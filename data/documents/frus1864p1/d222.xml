            <div frus:doc-dateTime-max="1863-10-28T23:59:59-05:00"
                frus:doc-dateTime-min="1863-10-28T00:00:00-05:00" n="222"
                subtype="historical-document" type="document" xml:id="d222">
                <head ana="#head_untitled-missing-head-in-printed-volume">[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Custom-House,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1863-10-28">
                            <hi rend="italic">October</hi> 28, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Sir:</hi> We have received instructions to transmit to
                    Mr. Bravay a notice of seizure similar to that which was handed to you
                    yesterday.</p>
                <p>Will you be so to good as send per bearer the address of that gentleman.</p>
                <p>Your obedient servant,</p>
                <closer>
                    <signed>E. MORGAN, <hi rend="italic">Surveyor.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>Messrs. <hi rend="smallcaps">Laird Brothers.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
