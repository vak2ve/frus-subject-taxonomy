<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1863-10-09T23:59:59-05:00" frus:doc-dateTime-min="1863-10-09T00:00:00-05:00" n="212" subtype="historical-document" type="document" xml:id="d212">
                            <head><persName type="from">E. Morgan, surveyor, her Majesty’s customs,
                                    Liverpool,</persName> to <persName type="to">Laird
                                    Brothers</persName>.</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName><hi rend="smallcaps">Customs,
                                        Liverpool,</hi></placeName>
                                    <date calendar="gregorian" when="1863-10-09"><hi rend="italic">October</hi> 9, 1863.</date></dateline></opener>
                            <p><hi rend="smallcaps">Gentlemen:</hi> I hereby beg to give you notice
                                that I have this day seized the iron-plated cupola vessel now lying
                                in the dock attached to your premises, by order of the commissioners
                                of customs.</p>
                            <p>Respectfully,</p>
                            <closer>
                                <signed>E. MORGAN, <hi rend="italic">Surveyor.</hi></signed></closer>
                            <postscript>
                                <p>Messrs. <hi rend="smallcaps">Laird.</hi></p>
                            </postscript>
                        </div>
                        </body></text></TEI>