    <text>
        <body>
            <div frus:doc-dateTime-max="1863-03-11T23:59:59-05:00" frus:doc-dateTime-min="1863-03-11T00:00:00-05:00" n="359" subtype="historical-document" type="document" xml:id="d359">
                <opener>
                    <seg rendition="#center">No. 2.</seg>
                </opener>
                <head>
                    <persName type="from">Earl Russell</persName> to <persName type="to">Mr.
                            Mason</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Foreign Office,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1863-03-11">
                            <hi rend="italic">March</hi> 11, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have the honor to acknowledge the receipt of
                        your letter of the 2d instant, enclosing a copy of a despatch signed by Mr.
                        Benjamin, and dated Richmond, December 11, 1862, and I request you will
                        accept my thanks for this communication.</p>
                <p>I am, &amp;c.,</p>
                <closer>
                    <signed>RUSSELL.</signed>
                </closer>
            </div>
        </body>
