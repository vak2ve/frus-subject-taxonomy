    <text>
        <body>
            <div frus:doc-dateTime-max="1864-02-20T23:59:59-05:00" frus:doc-dateTime-min="1864-02-20T00:00:00-05:00" n="124" subtype="historical-document" type="document" xml:id="d124">
                <opener>
                    <seg rendition="#center">No. 27.</seg>
                </opener>
                <head>
                    <persName type="from">Earl Russell</persName> to <persName type="to">Lord Lyons</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Foreign Office,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1864-02-20">
                            <hi rend="italic">February</hi> 20, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Lord:</hi> With reference to my previous
                                despatch of this day’s date, I enclose for your information copies
                                of farther papers,<note n="†" xml:id="d124fn1">Nos 14, 15,17, 18,
                                    and 20.</note> as marked in the margin, relative to the case of
                                the Saxon.</p>
                <p>I am, &amp;c.,</p>
                <closer>
                    <signed>RUSSELL.</signed>
                </closer>
            </div>
        </body>
    </text>
