<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1942-07-02T21:00:00-05:00" frus:doc-dateTime-min="1942-07-02T21:00:00-05:00" n="219" subtype="historical-document" type="document" xml:id="d219">
                        <note rend="inline" type="source">811.20 Defense (M) Colombia/108:
                            Telegram</note>
                        <head>
                            <hi rend="italic">The Chargé in Colombia</hi> (<persName type="from"><hi rend="italic">Keith</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1942-07-02T21:00:00-05:00">July 2,
                                    1942—9 p.m.</date>
                                <lb/> [Received July 3—1:29 a.m.]</dateline>
                        </opener>
                        <p>907. Embassy’s telegram No. 888, July 1, noon.<note n="70" xml:id="d219fn70">Not printed.</note> Rubber agreement signed July 1
                            by Caja and Pocklington and approved by Minister of National Economy and
                            Ambassador Lane. Copy being taken to Washington by the Ambassador.<note n="71" xml:id="d219fn71">No copy of rubber agreement found in
                                Department files.</note>
                        </p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Keith</hi>
                            </signed>
                        </closer>
                    </div>
                </body></text></TEI>