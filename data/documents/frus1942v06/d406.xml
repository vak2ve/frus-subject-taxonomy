                subtype="historical-document" type="document" xml:id="d406">
                <note rend="inline" type="source">811.34522/52: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Ecuador</hi> (<persName type="from">
                        <hi rend="italic">Long</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Quito</hi>
                        </placeName>, <date calendar="gregorian" when="1942-10-13T19:00:00-05:00"
                            >October 13, 1942—7 p.m.</date>
                        <lb/> [Received October 14—12:39 a.m.]</dateline>
                </opener>
                <p>835. The following telegram has been sent to Panama.</p>
                <quote rend="blockquote">
                    <p>October 13, 6 p.m. For General Andrews. Galápagos negotiations have been
                        postponed indefinitely. Captains Stone, Symington, and Colonel Montesinos
                        returning to Canal Zone October 14. Repeated to Department.</p>
                </quote>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Long</hi>
                    </signed>
                </closer>
            </div>
        </body>
