                subtype="historical-document" type="document" xml:id="d606">
                <note rend="inline" type="source">810.20 Defense/2921: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Paraguay</hi> (<persName type="from">
                        <hi rend="italic">Frost</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Asunción</hi>
                        </placeName>, <date calendar="gregorian" when="1942-07-01T18:00:00-04:00"
                            >July 1, 1942—6 p.m.</date>
                        <lb/> [Received 11:03 p.m.]</dateline>
                </opener>
                <p>302. Department’s 202, June 20, 7 p.m. Concession approved by Council of State
                    June 30 and decree signed by President and Cabinet today July 1 including
                    language as suggested as translated by this Mission.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Frost</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
