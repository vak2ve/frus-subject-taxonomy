<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1942-10-10T12:00:00-05:00" frus:doc-dateTime-min="1942-10-10T12:00:00-05:00" n="685" subtype="historical-document" type="document" xml:id="d685">
                        <note rend="inline" type="source">833.51/1001: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Ambassador in Uruguay</hi> (<persName type="to"><hi rend="italic">Dawson</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1942-10-10T13:00:00-04:00">October
                                    10, 1942—1 p.m.</date>
                            </dateline>
                        </opener>
                        <p>610. Your A–81, September 26, noon. Department prefers that matter be
                            taken up by Uruguayan Government through its Embassy in Washington.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Welles</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>