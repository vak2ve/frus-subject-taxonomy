<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1942-09-15T21:00:00-05:00" frus:doc-dateTime-min="1942-09-15T21:00:00-05:00" n="191" subtype="historical-document" type="document" xml:id="d191">
                        <note rend="inline" type="source">811.34521/15: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Colombia</hi> (<persName type="to"><hi rend="italic">Lane</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1942-09-15T22:00:00-04:00">September
                                    15, 1942—10 p.m.</date>
                            </dateline>
                        </opener>
                        <p>967. Your 1191 of September 12, 3 p.m. Your authority is contained in the
                            last paragraph of the Department’s telegram 959 of September 12.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
