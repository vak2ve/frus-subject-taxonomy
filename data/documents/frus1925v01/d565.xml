                subtype="historical-document" type="document" xml:id="d565">
                <note rend="inline" type="source">893.5045/244: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">MacMurray</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1925-10-28T17:00:00+08:00">
                            <hi rend="italic">October 28, 1925—5 p.m.</hi>
                        </date>
                        <lb/>[Received October 28—7:48 a.m.]</dateline>
                </opener>
                <p>467. My 446, October 16, 6 p.m. Following from Justice Johnson: “Court has
                    finished inquiry and I will make report in 6 to 10 days.”</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">MacMurray</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
