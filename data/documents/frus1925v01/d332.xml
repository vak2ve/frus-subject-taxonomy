    <text>
        <body>
            <div frus:doc-dateTime-max="1925-02-03T09:00:00-05:00"
                frus:doc-dateTime-min="1925-02-03T09:00:00-05:00" n="332"
                subtype="historical-document" type="document" xml:id="d332">
                <note rend="inline" type="source">875.01/266: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Albania</hi> (<persName type="from">
                        <hi rend="italic">Grant-Smith</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tirana</hi>
                        </placeName>, <date calendar="gregorian" when="1925-02-03T15:00:00+01:00">
                            <hi rend="italic">February 3, 1925—3 p.m.</hi>
                        </date>
                        <lb/>[Received February 4—7:51 a.m.]</dateline>
                </opener>
                <p>10. Department’s 5, January 30 [<hi rend="italic">31</hi>], 6 p.m. Acknowledgment
                    notification of vote of confidence and of adoption of republican form of
                    government made under date of 2d instant. Copy to European Information
                    Center.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grant-Smith</hi>
                    </signed>
                </closer>
            </div>
        </body>
