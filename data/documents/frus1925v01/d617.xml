<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1925-11-09T00:00:00-05:00" frus:doc-dateTime-min="1925-11-09T00:00:00-05:00" n="617" subtype="historical-document" type="document" xml:id="d617">
                        <note rend="inline" type="source">893.00/6744: Telegram</note>
                        <head><hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">MacMurray</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1925-11-09T13:00:00+08:00"><hi rend="italic">November 9,
                                        1925—1 p.m.</hi></date><lb/>[Received November 9—5:45
                                a.m.]</dateline></opener>
                        <p>478. My 477, November 6, 4 p.m. Following from Swatow: <quote rend="blockquote">
                                <p>“November 7, 12 noon. Chiang Kai-shek arrived yesterday with
                                    several thousand troops, quiet.”</p>
                            </quote></p>
                        <closer><signed><hi rend="smallcaps">MacMurray</hi></signed></closer>
                    </div>
                    </body></text></TEI>