                subtype="historical-document" type="document" xml:id="d455">
                <note rend="inline" type="source">893.00/6843: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">MacMurray</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1925-12-12T20:00:00+08:00">
                            <hi rend="italic">December 12, 1925—8 p.m.</hi>
                        </date>
                        <lb/>[Received December 13—11:15 a.m.]</dateline>
                </opener>
                <p>527. My 524, December 11, 7 p.m. International train arrived Peking at 6 this
                    evening with all on board unhurt and well.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">MacMurray</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
