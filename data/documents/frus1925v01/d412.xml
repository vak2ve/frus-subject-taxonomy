<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1925-03-19T18:00:00-05:00" frus:doc-dateTime-min="1925-03-19T18:00:00-05:00" n="412" subtype="historical-document" type="document" xml:id="d412">
                        <note rend="inline" type="source">825.01/41: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Chile</hi> (<persName type="to"><hi rend="italic">Collier</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1925-03-19T18:00:00-05:00"><hi rend="italic">March 19,
                                        1925—6 p.m.</hi></date></dateline></opener>
                        <p>11. Your 28, March 10, 1 p.m.<note n="4" xml:id="d412fn4">Not
                                printed.</note> Upon Señor Alessandri’s resumption of office formal
                            relations may be maintained with him. No formal communication or special
                            action necessary in this connection nor should any comment or
                            explanation in so doing be made.<note n="5" xml:id="d412fn5">Señor
                                Alessandri resumed the functions of Constitutional President on
                                March 20 (file No. 825.001A12/27).</note></p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                </body></text></TEI>