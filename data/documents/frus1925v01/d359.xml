<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1925-07-20T10:00:00-05:00" frus:doc-dateTime-min="1925-07-20T10:00:00-05:00" n="359" subtype="historical-document" type="document" xml:id="d359">
                        <note rend="inline" type="source">875.6363/216: Telegram</note>
                        <head><hi rend="italic">The Chargé in Albania</hi> (<persName type="from"><hi rend="italic">Kodding</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Tirana</hi></placeName>, <date calendar="gregorian" when="1925-07-20T16:00:00+01:00"><hi rend="italic">July 20,
                                        1925—4 p.m.</hi></date><lb/>[Received July 21—5:53
                                a.m.]</dateline></opener>
                        <p>48. Ratification Standard Oil Company’s concession in Albania completed
                            yesterday.</p>
                        <closer><signed><hi rend="smallcaps">Kodding</hi></signed></closer>
                    </div>
