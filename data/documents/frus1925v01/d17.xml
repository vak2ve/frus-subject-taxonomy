                subtype="historical-document" type="document" xml:id="d17">
                <note rend="inline" type="source">500.A12/68: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in France</hi> (<persName type="from">
                        <hi rend="italic">Whitehouse</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Extract—Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1925-10-23T18:00:00+00:00">
                            <hi rend="italic">October 23, 1925—6 p.m.</hi>
                        </date>
                        <lb/>[Received 11:55 p.m.]</dateline>
                </opener>
                <p>510. Your 335 [<hi rend="italic">385</hi>], October 22. Press comment is
                    uniformly opposed to any conference on disarmament under the President’s
                    auspices, whether held at Washington or at The Hague.</p>
                <p rend="center">. . . . . . . . . . . . . .</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Whitehouse</hi>
                    </signed>
                </closer>
            </div>
        </body>
