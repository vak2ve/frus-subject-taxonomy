    <text>
        <body>
            <div frus:doc-dateTime-max="1925-02-05T11:00:00-05:00"
                frus:doc-dateTime-min="1925-02-05T11:00:00-05:00" n="335"
                subtype="historical-document" type="document" xml:id="d335">
                <note rend="inline" type="source">875.6363/158: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Albania</hi> (<persName type="from">
                        <hi rend="italic">Grant-Smith</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tirana</hi>
                        </placeName>, <date calendar="gregorian" when="1925-02-05T17:00:00+01:00">
                            <hi rend="italic">February 5, 1925—5 p.m.</hi>
                        </date>
                        <lb/>[Received 7:40 p.m.]</dateline>
                </opener>
                <p>12. Your 6, February 4, 6 p.m. No further information available other than
                    contained in my 7, January 26 [<hi rend="italic">25</hi>], 9 a.m.,<note n="8"
                        xml:id="d335fn8">Not printed.</note> and 11, February 4, 7 p.m., except that
                    Yugoslav Chargé d’Affaires has urged postponement of decision on oil concession
                    until assembly of new Parliament. Copy to foreign information bureau.<note n="9"
                        xml:id="d335fn9">i. e., European Information Center.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grant-Smith</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
