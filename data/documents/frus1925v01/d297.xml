                subtype="historical-document" type="document" xml:id="d297">
                <note rend="inline" type="source">721.2315/179: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from">
                        <hi rend="italic">Morgan</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1925-03-03T12:00:00-03:00">
                            <hi rend="italic">March 3, 1925—noon.</hi>
                        </date>
                        <lb/>[Received March 3—11 a.m.]</dateline>
                </opener>
                <p>21. Your telegram number 17, March 2, 2 p.m. was communicated to the Minister for
                    Foreign Affairs this morning. Foreign Office on reading telegram considers
                    Grade’s instructions already adequate.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Morgan</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
