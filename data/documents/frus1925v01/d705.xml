                subtype="historical-document" type="document" xml:id="d705">
                <note rend="inline" type="source">500.A 4 e/404: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in China</hi> (<persName type="to">
                        <hi rend="italic">MacMurray</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1925-10-15T18:00:00-05:00">
                            <hi rend="italic">October 15, 1925—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>292.</p>
                <p rend="center">. . . . . . . . . . . . . .</p>
                <p>Your action in regard to Chinese tentative agenda report in your No. 443 October
                    15, 3 p.m. is approved.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
