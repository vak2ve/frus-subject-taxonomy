                subtype="historical-document" type="document" xml:id="d443">
                <note rend="inline" type="source">893.00/6450: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">MacMurray</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1925-07-25T16:00:00+08:00">
                            <hi rend="italic">July 25, 1925—4 p.m.</hi>
                        </date>
                        <lb/>[Received July 25—8:45 a.m.]</dateline>
                </opener>
                <p>290. Legation’s 259, July 2, 7 p.m. Press reports Chang Tso-lin has arrived back
                    at Mukden.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">MacMurray</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
