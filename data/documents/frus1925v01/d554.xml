                subtype="historical-document" type="document" xml:id="d554">
                <note rend="inline" type="source">893.5045/204: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in China</hi> (<persName type="to">
                        <hi rend="italic">MacMurray</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1925-09-04T17:00:00-04:00">
                            <hi rend="italic">September 4, 1925—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>232. Your 379 September 4, 9 p.m. [<hi rend="italic">a.m.</hi>] Formula
                    satisfactory to Department. You are authorized to sign it or any modification
                    thereof importing no substantial alteration.</p>
                <p>Department is considering question of judge.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
