                subtype="historical-document" type="document" xml:id="d18">
                <note rend="inline" type="source">500.A12/69: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Italy</hi> (<persName type="from">
                        <hi rend="italic">Robbins</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1925-10-24T11:00:00+01:00">
                            <hi rend="italic">October 24, 1925—11 a.m.</hi>
                        </date>
                        <lb/>[Received 1:35 p.m.]</dateline>
                </opener>
                <p>160. Your 385, Oct. 22, 4 p.m. to Paris. No comment whatever in local press.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robbins</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
