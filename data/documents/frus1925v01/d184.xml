                subtype="historical-document" type="document" xml:id="d184">
                <note rend="inline" type="source">121.5760c/1: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Poland</hi> (<persName type="from">
                        <hi rend="italic">Stetson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Warsaw</hi>
                        </placeName>, <date calendar="gregorian" when="1925-09-23T10:00:00+01:00">
                            <hi rend="italic">September 23, 1925—10 a.m.</hi>
                        </date>
                        <lb/>[Received 2 p.m.]</dateline>
                </opener>
                <p>88. Your despatch number 110, April 21, regarding customs attachés.<note n="80"
                        xml:id="d184fn80">See footnote 41, <ref target="#pg_227">p.
                        227</ref>.</note> Foreign Office has made negative answer.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stetson</hi>
                    </signed>
                </closer>
            </div>
        </body>
