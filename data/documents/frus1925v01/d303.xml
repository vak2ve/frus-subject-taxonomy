<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1925-03-04T20:00:00-05:00" frus:doc-dateTime-min="1925-03-04T20:00:00-05:00" n="303" subtype="historical-document" type="document" xml:id="d303">
                            <note rend="inline" type="source">721.2315/183a: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in Peru</hi> (<persName type="to"><hi rend="italic">Poindexter</hi></persName>)<note n="18" xml:id="d303fn18">The same to the Ambassador in Brazil;
                                    first sentence, only, to the Minister in Colombia (file No.
                                    721.2315/183 b, c).</note></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1925-03-04T20:00:00-05:00"><hi rend="italic">March 4,
                                            1925—8 p.m.</hi></date></dateline></opener>
                            <p>11. Procès Verbal signed today. Much appreciate your able
                                cooperation.</p>
                            <closer><signed><hi rend="smallcaps">Hughes</hi></signed></closer>
                        </div>
                        </body></text></TEI>