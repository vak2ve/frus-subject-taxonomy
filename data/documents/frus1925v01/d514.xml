    <text>
        <body>
            <div frus:doc-dateTime-max="1925-06-14T02:00:00-05:00"
                frus:doc-dateTime-min="1925-06-14T02:00:00-05:00" n="514"
                subtype="historical-document" type="document" xml:id="d514">
                <note rend="inline" type="source">893.5045/89: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName type="from">
                        <hi rend="italic">Mayer</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1925-06-14T15:00:00+08:00">
                            <hi rend="italic">June 14, 1925—3 p.m.</hi>
                        </date>
                        <lb/>[Received June 14—10:25 a.m.]</dateline>
                </opener>
                <p>225. My 211, June 8, 7 p.m. American consul, Shanghai, reports that owing to
                    improved situation part of defence forces have been withdrawn. Full publicity
                    being given.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Mayer</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
