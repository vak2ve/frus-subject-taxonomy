<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1925-12-25T05:00:00-05:00" frus:doc-dateTime-min="1925-12-25T05:00:00-05:00" n="463" subtype="historical-document" type="document" xml:id="d463">
                        <note rend="inline" type="source">893.00/6878: Telegram</note>
                        <head><hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">MacMurray</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1925-12-25T18:00:00+08:00"><hi rend="italic">December 25,
                                        1925—6 p.m.</hi></date><lb/>[Received December 25—12:57
                                p.m.]</dateline></opener>
                        <p>545. My 544, December 24, 5 p.m. International train has arrived at
                            Tientsin from Peking. Commercial service resumed with depleted
                            equipment.</p>
                        <closer><signed><hi rend="smallcaps">MacMurray</hi></signed></closer>
                    </div>
                    </body></text></TEI>