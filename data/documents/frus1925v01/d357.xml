<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1925-07-08T16:00:00-05:00" frus:doc-dateTime-min="1925-07-08T16:00:00-05:00" n="357" subtype="historical-document" type="document" xml:id="d357">
                        <note rend="inline" type="source">875.6363/215: Telegram</note>
                        <head><hi rend="italic">The Chargé in Albania</hi> (<persName type="from"><hi rend="italic">Kodding</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Tirana</hi></placeName>, <date calendar="gregorian" when="1925-07-08T22:00:00+01:00"><hi rend="italic">July 8,
                                        1925—10 p.m.</hi></date><lb/>[Received July 9—12:06
                                p.m.]</dateline></opener>
                        <p>45. Albanian Cabinet approved concession proposed by Standard Oil Company
                            and referred it to Parliament yesterday. Copy to European Information
                            Center.</p>
                        <closer><signed><hi rend="smallcaps">Kodding</hi></signed></closer>
                    </div>
                    </body></text></TEI>