                subtype="historical-document" type="document" xml:id="d135">
                <note rend="inline" type="source">463.00 R 29/166: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in France</hi> (<persName type="from">
                        <hi rend="italic">Whitehouse</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1925-02-06T13:00:00+00:00">
                            <hi rend="italic">February 6, 1925—1 p.m.</hi>
                        </date>
                        <lb/>[Received February 6—11:40 a.m.]</dateline>
                </opener>
                <p>108. My 75, January 21, 3 p.m. British memorandum was adopted by the Conference
                    this morning, subject to my reservation that I had as yet received no
                    instructions.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Whitehouse</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
