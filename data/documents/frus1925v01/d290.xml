<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1925-02-28T13:00:00-05:00" frus:doc-dateTime-min="1925-02-28T13:00:00-05:00" n="290" subtype="historical-document" type="document" xml:id="d290">
                            <note rend="inline" type="source">721.2315/175: Telegram</note>
                            <head><hi rend="italic">The Ambassador in Peru</hi> (<persName type="from"><hi rend="italic">Poindexter</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Lima</hi></placeName>, <date calendar="gregorian" when="1925-02-28T13:00:00-05:00"><hi rend="italic">February
                                            28, 1925—1 p.m.</hi></date><lb/>[Received 1:30
                                    p.m.]</dateline></opener>
                            <p>9. Section 1. My 8, February 28, 3 p.m. [<hi rend="italic">a.m.</hi>]
                                Minister for Foreign Affairs assures me instructions will be cabled
                                Velarde before 1 p.m. today.</p>
                            <closer><signed><hi rend="smallcaps">Poindexter</hi></signed></closer>
                        </div>
                        </body></text></TEI>