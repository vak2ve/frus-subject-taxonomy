                subtype="historical-document" type="document" xml:id="d428">
                <note rend="inline" type="source">893.00/6082: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Schurman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1925-03-12T11:00:00+08:00">
                            <hi rend="italic">March 12, 1925—11 a.m.</hi>
                        </date>
                        <lb/>[Received March 12—5:33 a.m.]</dateline>
                </opener>
                <p>102. Sun Yat-sen died at 9:30 this morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schurman</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
