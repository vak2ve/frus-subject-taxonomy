<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1925-07-22T07:00:00-05:00" frus:doc-dateTime-min="1925-07-22T07:00:00-05:00" n="176" subtype="historical-document" type="document" xml:id="d176">
                        <note rend="inline" type="source">121.5751/3: Telegram</note>
                        <head><hi rend="italic">The Chargé in France</hi> (<persName type="from"><hi rend="italic">Whitehouse</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1925-07-22T13:00:00+01:00"><hi rend="italic">July 22,
                                        1925—1 p.m.</hi></date><lb/>[Received July 22—8:50
                                a.m.]</dateline></opener>
                        <p>394. Your instruction number 1475, April 21st, 1925. Have just received
                            note from Foreign Office stating that it cannot grant diplomatic status
                            to customs attachés. Copy of the note going forward by next pouch.<note n="66" xml:id="d176fn66">Not printed.</note></p>
                        <closer><signed><hi rend="smallcaps">Whitehouse</hi></signed></closer>
                    </div>
                    </body></text></TEI>