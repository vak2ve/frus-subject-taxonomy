                <note rend="inline" type="source">893.00/6679: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in China</hi> (<persName type="to">
                        <hi rend="italic">MacMurray</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1925-10-29T18:00:00-05:00">
                            <hi rend="italic">October 29, 1925—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>308. Your 447, October 16, 7 P.M. You are authorized to instruct Consulate
                    General Canton in manner suggested in your telegram.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
