<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1948-03-08T12:00:00-05:00" frus:doc-dateTime-min="1948-03-08T12:00:00-05:00" n="80" subtype="historical-document" type="document" xml:id="d80">
                        <note rend="inline" type="source">501.BB Palestine/3–848: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the United States Representative at the United Nations</hi>
                                (<persName type="to"><hi rend="italic">Austin</hi></persName>)</head>
                        <opener>
                            <seg rendition="#left">
                                <hi rend="smallcaps">top secret</hi>
                            </seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1948-03-08T12:00:00-05:00">March 8,
                                    1948—noon</date>.</dateline>
                        </opener>
                        <p>116. The President has approved draft statement on situation in Palestine
                            after May 15, 1948, with concluding remarks as set forth in <gloss target="#t_Deptel1">Deptel</gloss> 107, March 5, for use if and when
                            necessary.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Marshall</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>