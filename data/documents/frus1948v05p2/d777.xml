<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1948-11-19T18:00:00-05:00" frus:doc-dateTime-min="1948-11-19T18:00:00-05:00" n="777" subtype="historical-document" type="document" xml:id="d777">
                        <note rend="inline" type="source">501.BB Palestine/11–1948: Circular
                            telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to <gloss type="to">Certain Diplomatic and
                                    Consular Offices</gloss>
                            </hi><note n="1" xml:id="d777fn1">At Arab capitals, Jerusalem, and Tel
                                Aviv.</note>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1948-11-19T18:00:00-05:00">November
                                    19, 1948—6 p. m.</date>
                            </dateline>
                        </opener>
                        <p>
                            <gloss target="#t_GA1">GA</gloss> plenary session today approved
                            resolution originally submitted by US, UK, Belgium, Netherlands for 32
                            million dollar program relief Palestinian refugees of all communities
                            covering period ending Aug 31, 1949. Resolution as approved includes 5
                            million dollar advance from UN working capital fund.<note n="2" xml:id="d777fn2">For text of resolution 212(III), see <gloss target="#t_GA1">GA</gloss>, <hi rend="italic">3rd sess., Pt. I,
                                    Resolutions, 1948</hi>, p. 66.</note> Details will follow.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lovett</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>