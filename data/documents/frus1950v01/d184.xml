        <body>
            <div frus:doc-dateTime-max="1950-08-08T23:59:59-05:00"
                frus:doc-dateTime-min="1950-08-08T00:00:00-05:00" n="184"
                subtype="historical-document" type="document" xml:id="d184">
                <note rend="inline" type="source">SCI Files<note n="1" xml:id="d184fn1">Files
                        retained by the Bureau of International Scientific and Technological
