    <text>
        <body>
            <div frus:doc-dateTime-max="1919-02-28T23:59:59-05:00"
                frus:doc-dateTime-min="1919-02-28T00:00:00-05:00" n="526"
                subtype="historical-document" type="document" xml:id="d526">
                <note rend="inline" type="source">812.00/22570</note>
                <head>
                    <hi rend="italic">The Chargé in Mexico</hi> (<persName type="from">
                        <hi rend="italic">Summerlin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1919-02-28">
                            <hi rend="italic">February 28, 1919</hi>
                        </date>.<lb/>[<hi rend="italic">Received March 18.</hi>]</dateline>
                    <seg rendition="#left">No. 1850</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to the Department’s telegraphic
                    instruction No. 1876 of February 19, 3 P.M., I have the honor to enclose
                    herewith, copy and translation of a note,<note n="48" xml:id="d526fn48">Not
                        printed.</note> dated February 24, 1919, received from the Mexican Foreign
                    Office, stating that just as soon as the representations of the Embassy were
                    received in regard to the assassination <pb facs="0655" n="570" xml:id="pg_570"
                    /> of the two foreigners in the vicinity of Tapachula, Chiapas, the matter was
                    referred to the respective authorities for appropriate action.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">George T. Summerlin</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
