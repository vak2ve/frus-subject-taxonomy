                subtype="historical-document" type="document" xml:id="d107">
                <note rend="inline" type="source">422.11G93/979: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Ecuador</hi> (<persName type="to">
                        <hi rend="italic">Belt</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-04-02T17:00:00-04:00">
                            <hi rend="italic">April 2, 1919, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your October 25, 7 p.m.<note n="16" xml:id="d107fn16">
                        <ref target="frus1918#pg_420">
                            <hi rend="italic">Foreign Relations</hi>, 1918, p. 420</ref>.</note>
                </p>
                <p>Cable Department whether daily deposits are still being paid and if not what
                    reason is alleged by Ecuadorian Government for discontinuance.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
