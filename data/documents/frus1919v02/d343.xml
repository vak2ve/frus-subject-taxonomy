<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-10-02T11:48:00-05:00" frus:doc-dateTime-min="1919-10-02T11:48:00-05:00" n="343" subtype="historical-document" type="document" xml:id="d343">
                            <note rend="inline" type="source">815.00/2058: Telegram</note>
                            <head><hi rend="italic">The Minister in Honduras</hi> (<persName type="from"><hi rend="italic">Jones</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Tegucigalpa</hi></placeName>, <date calendar="gregorian" when="1919-10-02T11:00:00-05:48"><hi rend="italic">October 2, 1919, 11
                                        a.m.</hi></date><lb/>[<hi rend="italic">Received October 4,
                                        4.15 p.m.</hi>]</dateline></opener>
                            <p>Your September 10, 6 p.m. Francisco Bogran arrived here September
                                29th and will assume the Presidency on the 5th instant 3 p.m.</p>
                            <closer><signed><hi rend="smallcaps">Jones</hi></signed></closer>
                        </div>
                        </body></text></TEI>