                <note rend="inline" type="source">823.00/311a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Peruvian Chargé</hi> (<persName type="to">
                        <hi rend="italic">Gibson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-09-04">
                            <hi rend="italic">September 4, 1919</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that the
                    Government of the United States has recognized Señor Leguia as head of the <hi
                        rend="italic">de facto</hi> Government of Peru.</p>
                <p>Accept [etc.]</p>
                <closer>For the Secretary of State:<lb/>
                    <signed>
                        <hi rend="smallcaps">Alvey A. Adee</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
