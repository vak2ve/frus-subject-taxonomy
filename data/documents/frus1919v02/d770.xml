<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-04-29T23:59:59-05:00" frus:doc-dateTime-min="1919-04-29T00:00:00-05:00" n="770" subtype="historical-document" type="document" xml:id="d770">
                        <note rend="inline" type="source">816.48/76: Telegram</note>
                        <head><hi rend="italic">The Chargé in Salvador</hi> (<persName type="from"><hi rend="italic">Arnold</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Acting Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">San
                                        Salvador</hi></placeName>, <date calendar="gregorian" when="1919-04-29"><hi rend="italic">April 29,
                                    1919</hi></date>.<lb/>[<hi rend="italic">Received 7.20
                                p.m.</hi>]</dateline></opener>
                        <p>President of Salvador Red Cross requests aid of 100 tents from American
                            Red Cross to house the homeless.</p>
                        <closer><signed><hi rend="smallcaps">Arnold</hi></signed></closer>
                    </div>
                    </body></text></TEI>