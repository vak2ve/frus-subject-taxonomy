<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-12-08T13:00:00-05:00" frus:doc-dateTime-min="1919-12-08T13:00:00-05:00" n="33" subtype="historical-document" type="document" xml:id="d33">
                            <note rend="inline" type="source">837.00/1596: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Minister in Cuba</hi> (<persName type="to"><hi rend="italic">Gonzales</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-12-08T13:00:00-05:00"><hi rend="italic">December
                                            8, 1919, 1 p.m.</hi></date></dateline></opener>
                            <p>Your December 4, 1 p.m.</p>
                            <p>Department desires outline of suggested statement which, in view of
                                Department’s present attitude, would not be construed as injuring
                                any political party.</p>
                            <closer><signed><hi rend="smallcaps">Lansing</hi></signed></closer>
                        </div>
                        </body></text></TEI>