<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-10-30T18:00:00-05:00" frus:doc-dateTime-min="1919-10-30T18:00:00-05:00" n="70" subtype="historical-document" type="document" xml:id="d70">
                            <note rend="inline" type="source">839.00/2162: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Minister in the Dominican Republic</hi>
                                    (<persName type="to"><hi rend="italic">Russell</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-10-30T18:00:00-05:00"><hi rend="italic">October
                                            30, 1919, 6 p.m.</hi></date></dateline></opener>
                            <p>Your October 29, 6 p.m.</p>
                            <p>Carvajal does not intend to go to Santo Domingo at this time and has
                                returned to Cuba.</p>
                            <p>Mail Department full details as to powers, etc., of proposed advisory
                                board.</p>
                            <closer><signed><hi rend="smallcaps">Lansing</hi></signed></closer>
                        </div>
                        </body></text></TEI>