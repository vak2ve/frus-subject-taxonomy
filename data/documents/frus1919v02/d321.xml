<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-05-12T23:48:00-05:00" frus:doc-dateTime-min="1919-05-12T23:48:00-05:00" n="321" subtype="historical-document" type="document" xml:id="d321">
                            <note rend="inline" type="source">815.00/1853: Telegram</note>
                            <head><hi rend="italic">The Minister in Honduras</hi> (<persName type="from"><hi rend="italic">Jones</hi></persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                                        State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Tegucigalpa</hi></placeName>, <date calendar="gregorian" when="1919-05-12T23:00:00-05:48"><hi rend="italic">May 12, 1919, 11 p.m.</hi></date><lb/>[<hi rend="italic">Received May 13, 11.20
                                p.m.</hi>]</dateline></opener>
                            <p>United States Ship <hi rend="italic">Machias</hi> arrived at Amapala
                                this afternoon. Recommend its presence until further developments
                                warrant withdrawal.</p>
                            <closer><signed><hi rend="smallcaps">Jones</hi></signed></closer>
                        </div>
                        </body></text></TEI>