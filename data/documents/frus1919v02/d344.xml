<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-10-06T09:48:00-05:00" frus:doc-dateTime-min="1919-10-06T09:48:00-05:00" n="344" subtype="historical-document" type="document" xml:id="d344">
                            <note rend="inline" type="source">815.00/2062: Telegram</note>
                            <head><hi rend="italic">The Minister in Honduras</hi> (<persName type="from"><hi rend="italic">Jones</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Tegucigalpa</hi></placeName>, <date calendar="gregorian" when="1919-10-06T09:00:00-05:48"><hi rend="italic">October 6, 1919, 9
                                        a.m.</hi></date><lb/>[<hi rend="italic">Received October 7,
                                        2.15 a.m.</hi>]</dateline></opener>
                            <p>My telegram of October 2nd 11 a.m. Inauguration of President Bogran
                                took place at 3 p.m. yesterday with great popular demonstration.</p>
                            <closer><signed><hi rend="smallcaps">Jones</hi></signed></closer>
                        </div>
                        </body></text></TEI>