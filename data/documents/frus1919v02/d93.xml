<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-10-25T23:59:59-05:00" frus:doc-dateTime-min="1919-10-25T00:00:00-05:00" n="93" subtype="historical-document" type="document" xml:id="d93">
                            <note rend="inline" type="source">639.003/62</note>
                            <head><hi rend="italic">The Minister in the Dominican Republic</hi>
                                    (<persName type="from"><hi rend="italic">Russell</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Santo Domingo</hi></placeName>, <date calendar="gregorian" when="1919-10-25"><hi rend="italic">October 25, 1919</hi></date>.<lb/>[<hi rend="italic">Received November 13.</hi>]</dateline>
                                <seg rendition="#left">No. 515</seg></opener>
                            <p><hi rend="smallcaps">Sir</hi>: I have the honor to forward herewith
                                three copies of the new Dominican Tariff to be effective on January
                                1, 1920.<note n="53" xml:id="d93fn53">Not printed.</note></p>
                            <p>There is also enclosed a copy of the Final Report and Recommendations
                                of the Dominican Tariff Commission,<note n="53" xml:id="d93fn54">Not
                                    printed.</note> which explains the changes in the new tariff
                                rates.</p>
                            <p>I have [etc.]</p>
                            <closer><signed><hi rend="smallcaps">William W.
                                Russell</hi></signed></closer>
                        </div>
                    </body></text></TEI>