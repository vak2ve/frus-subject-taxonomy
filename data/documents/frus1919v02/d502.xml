                subtype="historical-document" type="document" xml:id="d502">
                <note rend="inline" type="source">612.119/2748</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Mexican Ambassador</hi> (<persName type="to">
                        <hi rend="italic">Bonillas</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-01-23">
                            <hi rend="italic">January 23, 1920</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to acknowledge the
                    receipt of Your Excellency’s note No. F–493, dated January 7, 1920, in which you
                    make inquiry relative to my decision with respect to the exportation of arms and
                    munitions of war from the United States to Mexico.</p>
                <p>In reply, I have the honor to inform Your Excellency that, after mature
                    deliberation, it appears to me inexpedient to permit the issuance of licenses to
                    ship arms and munitions of war to Mexico at the present time.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
