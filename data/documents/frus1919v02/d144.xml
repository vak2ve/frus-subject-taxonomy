<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-03-04T15:00:00-05:00" frus:doc-dateTime-min="1919-03-04T15:00:00-05:00" n="144" subtype="historical-document" type="document" xml:id="d144">
                            <note rend="inline" type="source">860d.00/374a: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Consul at Helsingfors</hi> (<persName type="to"><hi rend="italic">Haynes</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-03-04T15:00:00-05:00"><hi rend="italic">March 4,
                                            1919, 3 p.m.</hi></date></dateline></opener>
                            <p>Please report fully result of elections indicating especially how far
                                results indicate a mandate from the people.</p>
                            <closer><signed><hi rend="smallcaps">Polk</hi></signed></closer>
                        </div>
                        </body></text></TEI>