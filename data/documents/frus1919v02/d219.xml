                subtype="historical-document" type="document" xml:id="d219">
                <note rend="inline" type="source">814.00/317: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Guatemala</hi> (<persName type="from">
                        <hi rend="italic">Thurston</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guatemala</hi>
                        </placeName>, <date calendar="gregorian" when="1919-08-21T19:00:00-06:36">
                            <hi rend="italic">August 21, 1919, 7 p.m.</hi>
                        </date>
                        <lb/>[<hi rend="italic">Received August 25, 5.05 a.m.</hi>]</dateline>
                </opener>
                <p>Bishop Pinol released yesterday.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Thurston</hi>
                    </signed>
                </closer>
            </div>
        </body>
