<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-10-03T18:00:00-05:00" frus:doc-dateTime-min="1919-10-03T18:00:00-05:00" n="182" subtype="historical-document" type="document" xml:id="d182">
                        <note rend="inline" type="source">124.62/62: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">Commission to Negotiate
                            Peace</gloss></hi></head>
                        <opener><seg rendition="#center">[Extract]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-10-03T19:00:00-04:00"><hi rend="italic">October 3,
                                        1919, 7 p.m.</hi></date></dateline></opener>
                        <p>3337. Your 4472. For Polk from Phillips.</p>
                        <p>Department shares your view regarding the desirability of sending a
                            commissioner to Berlin, …</p>
                        <closer><signed><hi rend="smallcaps">Lansing</hi></signed></closer>
                    </div>
