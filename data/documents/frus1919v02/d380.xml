                subtype="historical-document" type="document" xml:id="d380">
                <note rend="inline" type="source">893.00/2983: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Reinsch</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1919-03-15T00:00:00+08:00">
                            <hi rend="italic">March 15, 1919, midnight</hi>
                        </date>.<lb/>[<hi rend="italic">Received March 15, 1 p.m.</hi>]</dateline>
                </opener>
                <p>My telegram March 13th, 8 p.m. Heintzleman<note n="16" xml:id="d380fn16">P.
                        Stewart Heintzleman, Consul General at Tientsin.</note> reports situation
                    well in hand. No further developments expected. Full report by mail.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Reinsch</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
