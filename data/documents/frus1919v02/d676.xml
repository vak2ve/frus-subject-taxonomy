                subtype="historical-document" type="document" xml:id="d676">
                <note rend="inline" type="source">741.91/21: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Persia</hi> (<persName type="to">
                        <hi rend="italic">Caldwell</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-08-19T17:00:00-04:00">
                            <hi rend="italic">August 19, 1919, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>141. Your 160, August 11th; 161, August 13th;<note n="4" xml:id="d676fn4">Not
                        printed.</note> and 162 August 13, keep Department fully and promptly
                    informed all developments matters referred to in these telegrams particularly as
                    to how treaty is received by Persians.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
