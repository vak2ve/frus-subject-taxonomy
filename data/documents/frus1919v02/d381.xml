                <note rend="inline" type="source">893.00/2983: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in China</hi> (<persName type="to">
                        <hi rend="italic">Reinsch</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-03-15T16:00:00-05:00">
                            <hi rend="italic">March 15, 1919, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your March 15, midnight.</p>
                <p>Report essential facts by cable.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Polk</hi>
                    </signed>
                </closer>
            </div>
        </body>
