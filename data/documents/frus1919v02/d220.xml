<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-09-11T10:36:00-05:00" frus:doc-dateTime-min="1919-09-11T10:36:00-05:00" n="220" subtype="historical-document" type="document" xml:id="d220">
                            <note rend="inline" type="source">814.00/321: Telegram</note>
                            <head><hi rend="italic">The Chargé in Guatemala</hi> (<persName type="from"><hi rend="italic">Thurston</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Guatemala</hi></placeName>, <date calendar="gregorian" when="1919-09-11T09:00:00-06:36"><hi rend="italic">September
                                            11, 1919, 9 a.m.</hi></date><lb/>[<hi rend="italic">Received September 12, 7 p.m.</hi>]</dateline></opener>
                            <p>Bishop Pinol left this morning for Puerto Barrios to take steamer to
                                United States <hi rend="italic">en route</hi> to Rome.</p>
                            <closer><signed><hi rend="smallcaps">Thurston</hi></signed></closer>
                        </div>
                        </body></text></TEI>