                subtype="historical-document" type="document" xml:id="d347">
                <note rend="inline" type="source">701.1511/108: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul in Charge of the Legation in Honduras</hi> (<persName type="to">
                        <hi rend="italic">Lawton</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-10-29T17:00:00-05:00">
                            <hi rend="italic">October 29, 1919, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your October 24, 10 a.m.</p>
                <p rend="center">. . . . . . .</p>
                <p>Department is pleased with the acts of Bogran which have come to its notice.</p>
                <p rend="center">. . . . . . .</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
