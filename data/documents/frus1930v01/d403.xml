                subtype="historical-document" type="document" xml:id="d403">
                <note rend="inline" type="source">863.51 Relief Credits/248: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Edge</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1930-06-27T12:00:00+01:00"
                            >June 27, 1930—noon</date>.<lb/>[Received June 27—9:20 a.m.]</dateline>
                </opener>
                <p>199. Reparation 313. Following meeting Austrian section yesterday the Reparation
                    Commission in order to avoid any delay in loan negotiations sent letter to
                    Austrian Minister at Paris in sense indicated my reparation 312, June 26, noon.
                    Letter will receive retroactive approval by Commission tomorrow.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edge</hi>
                    </signed>
                </closer>
            </div>
        </body>
