                subtype="historical-document" type="document" xml:id="d428">
                <note rend="inline" type="source">824.01/14: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Bolivia</hi> (<persName type="from">
                        <hi rend="italic">Hibbard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">La Paz</hi>
                        </placeName>, <date calendar="gregorian" when="1930-09-11T16:00:00-04:32"
                            >September 11, 1930—4 p.m.</date>
                        <lb/>[Received 5:20 p.m.]</dateline>
                </opener>
                <p>60. Chile officially recognized the present Bolivian Government yesterday
                    afternoon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hibbard</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
