<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-07-24T16:32:00-05:00" frus:doc-dateTime-min="1930-07-24T16:32:00-05:00" n="295" subtype="historical-document" type="document" xml:id="d295">
                            <note rend="inline" type="source">724.3415/1088: Telegram</note>
                            <head><hi rend="italic">The Chargé in Bolivia</hi> (<persName type="from"><hi rend="italic">Hibbard</hi></persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                                        State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">La
                                            Paz</hi></placeName>, <date calendar="gregorian" when="1930-07-24T17:00:00-04:32">July 24, 1930—5
                                    p.m.</date><lb/>[Received 6 p.m.]</dateline></opener>
                            <p>51. I have been officially informed by the Acting Minister for
                                Foreign Affairs that yesterday the final act in accordance with the
                                Washington agreement was signed and that Forts Boquerón and
                                Vanguardia were returned in the presence of Uruguayan officers.</p>
                            <closer><signed><hi rend="smallcaps">Hibbard</hi></signed></closer>
                        </div>
                    </body></text></TEI>