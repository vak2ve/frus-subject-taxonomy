                subtype="historical-document" type="document" xml:id="d151">
                <note rend="inline" type="source">500.A15a3/1224: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from">
                        <hi rend="italic">Garrett</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1930-11-01T13:00:00+01:00"
                            >November 1, 1930—1 p.m.</date>
                        <lb/>[Received November 1—11:30 a.m.]</dateline>
                </opener>
                <p>104. From Gibson. I should like to have your reassurance that the line I have
                    taken with the press agrees with yours.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Garrett</hi>
                    </signed>
                </closer>
            </div>
        </body>
