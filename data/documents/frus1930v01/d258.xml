<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-09-02T16:00:00-05:00" frus:doc-dateTime-min="1930-09-02T16:00:00-05:00" n="258" subtype="historical-document" type="document" xml:id="d258">
                        <note rend="inline" type="source">810.154/246: Telegram</note>
                        <head><hi rend="italic">The Minister in Honduras</hi> (<persName type="from"><hi rend="italic">Lay</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Tegucigalpa</hi></placeName>, <date calendar="gregorian" when="1930-09-02T15:00:00-06:00">September 2, 1930—3
                                p.m.</date><lb/>[Received 6:30 p.m.]</dateline></opener>
                        <p>83. Department’s instruction No. 13, July 21 [<hi rend="italic">22</hi>],<note n="5" xml:id="d258fn5">See footnote 99, <ref target="#pg_285">p. 285</ref>.</note> Government of Honduras
                            accepts cooperation American engineers. Have suggested that Minister of
                            Public Works so advise Pan American Union direct.</p>
                        <closer><signed><hi rend="smallcaps">Lay</hi></signed></closer>
                    </div>
                    </body></text></TEI>