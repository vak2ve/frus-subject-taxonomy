<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-08-20T14:00:00-05:00" frus:doc-dateTime-min="1930-08-20T14:00:00-05:00" n="348" subtype="historical-document" type="document" xml:id="d348">
                            <note rend="inline" type="source">715.1715/386: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Minister in Nicaragua</hi> (<persName type="to"><hi rend="italic">Hanna</hi></persName>)<note n="96" xml:id="d348fn96">Repeated to the Minister in Honduras as
                                    telegram No. 43.</note></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1930-08-20T15:00:00-04:00">August 20, 1930—3
                                        p.m.</date></dateline></opener>
                            <p>86. The Department perceives no objection to your submitting to the
                                Nicaraguan Government for approval the changes in the boundary
                                protocol suggested by the Honduran Government and being forwarded to
                                you from Tegucigalpa by air mail.</p>
                            <closer><signed><hi rend="smallcaps">Castle</hi></signed></closer>
                        </div>
                        </body></text></TEI>