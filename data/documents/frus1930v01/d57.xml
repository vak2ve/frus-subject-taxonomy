<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-03-14T15:00:00-05:00" frus:doc-dateTime-min="1930-03-14T15:00:00-05:00" n="57" subtype="historical-document" type="document" xml:id="d57">
                        <note rend="inline" type="source">500.A15a3/750: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Chairman of the American Delegation</hi>
                                (<persName type="to"><hi rend="italic">Stimson</hi></persName>)</head>
                        <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1930-03-14T15:00:00-05:00">March 14, 1930—3
                                p.m.</date></dateline></opener>
                        <p>211. Your telegram No. 134, March 13, 6 p.m. We approve your
                            recommendation to Japan.</p>
                        <closer><signed><hi rend="smallcaps">Cotton</hi></signed></closer>
                    </div>
