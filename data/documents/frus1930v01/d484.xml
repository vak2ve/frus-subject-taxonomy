                subtype="historical-document" type="document" xml:id="d484">
                <note rend="inline" type="source">832.113/47: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from">
                        <hi rend="italic">Morgan</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1930-11-11T11:00:00-03:00"
                            >November 11, 1930—11 a.m.</date>
                        <lb/>[Received November 11—10:10 a.m.]</dateline>
                </opener>
                <p>147. Action already taken on Department’s telegram No. 83, November 8, noon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Morgan</hi>
                    </signed>
                </closer>
            </div>
        </body>
