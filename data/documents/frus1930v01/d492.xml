<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-11-26T16:00:00-05:00" frus:doc-dateTime-min="1930-11-26T16:00:00-05:00" n="492" subtype="historical-document" type="document" xml:id="d492">
                        <note rend="inline" type="source">832.30/219: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Brazil</hi> (<persName type="to"><hi rend="italic">Morgan</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1930-11-26T16:00:00-05:00">November 26, 1930—4
                                p.m.</date></dateline></opener>
                        <p>91. Your 155, November 25, noon. January 31 acceptable as date for
                            termination of mission’s services.</p>
                        <closer><signed><hi rend="smallcaps">Stimson</hi></signed></closer>
