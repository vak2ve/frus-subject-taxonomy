                <note rend="inline" type="source">832.00 Revolutions/116: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Brazil</hi> (<persName type="to">
                        <hi rend="italic">Washington</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1930-10-20T11:00:00-05:00"
                            >October 20, 1930—11 a.m.</date>
                    </dateline>
                </opener>
                <p>69. Your 107, October 18, noon. Inform Brazilian Government in usual manner of
                    visit of <hi rend="italic">Pensacola.</hi>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
