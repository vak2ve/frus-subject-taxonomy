                subtype="historical-document" type="document" xml:id="d266">
                <note rend="inline" type="source">810.154/257: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Honduras</hi> (<persName type="from">
                        <hi rend="italic">Lay</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1930-10-19T12:00:00-06:00"
                            >October 19, 1930—noon</date>.<lb/>[Received 10:52 p.m.]</dateline>
                </opener>
                <p>102. Department’s telegram No. 61, October 11, 4 p.m. Minister of Fomento states
                    agreeable if engineers come about November 1st but not later, during rainy
                    season.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lay</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
