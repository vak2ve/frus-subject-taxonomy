                subtype="historical-document" type="document" xml:id="d316">
                <note rend="inline" type="source">724.3415/1120: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Paraguay</hi> (<persName type="from">
                        <hi rend="italic">Wheeler</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Asunción</hi>
                        </placeName>, <date calendar="gregorian" when="1930-09-12T15:00:00-03:50"
                            >September 12, 1930—3 p.m.</date>
                        <lb/>[Received September 13—6:55 a.m.]</dateline>
                </opener>
                <p>70. My telegram No. 65, August 14, 3 p.m.<note n="74a" xml:id="d316fn74a">Not
                        printed.</note> Zubizarreta has several times asked me if I have received
                    any word from you giving your opinion as to the best time for the opening of the
                    conversations at Washington.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wheeler</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
