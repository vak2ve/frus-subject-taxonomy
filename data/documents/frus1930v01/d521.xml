                subtype="historical-document" type="document" xml:id="d521">
                <note rend="inline" type="source">811.51632 National City Bank/47: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from">
                        <hi rend="italic">Morgan</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1930-07-24T09:00:00-03:00"
                            >July 24, 1930—9 a.m.</date>
                        <lb/>[Received July 24—9 a.m.]</dateline>
                </opener>
                <p>44. Department’s 49, July 12, 1 p.m.<note n="31" xml:id="d521fn31">Not
                        printed.</note> Ministerial order regarding <pb facs="0554" n="474"
                        xml:id="pg_474"/> National City Bank published this morning after signature
                    of revised text which reads: <quote rend="blockquote">
                        <p>“I decide that there are no grounds for the charge of infraction and that
                            the penalty imposed is void.”</p>
                    </quote>
                </p>
                <p>Full text follows by mail.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Morgan</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
