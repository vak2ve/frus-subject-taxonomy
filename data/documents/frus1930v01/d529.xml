    <text>
        <body>
            <div frus:doc-dateTime-max="1930-09-01T23:59:59-05:00"
                frus:doc-dateTime-min="1930-09-01T00:00:00-05:00" n="529"
                subtype="historical-document" type="document" xml:id="d529">
                <note rend="inline" type="source">811.512332 Shipping/20</note>
                <head>
                    <hi rend="italic">The Director of Commercial and Consular Affairs in the
                        Brazilian Ministry of Foreign Affairs</hi> (<persName type="from">
                        <hi rend="italic">Eulalio</hi>
                    </persName>) <hi rend="italic">to the American Ambassador in Brazil</hi>
                        (<persName type="to">
                        <hi rend="italic">Morgan</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Translation]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1930-09-01">September 1,
                            1930</date>.</dateline>
                    <seg rendition="#left">NC/72</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Ambassador</hi>: Acknowledging the receipt of your Note
                    No. 1526, of August 21 of the present year, I have the honor to thank Your
                    Excellency for your courtesy in communicating to this Department the decision of
                    the United States of America, regarding the exemption from income tax of
                    Brazilian citizens who derive profit exclusively from the operation of ships
                    registered in Brazil with which decision this Ministry has just acquainted the
                    Ministry of Finance.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Jm. Eulalio</hi>
                    </signed>
                </closer>
            </div>
        </body>
