<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-11-08T14:00:00-05:00" frus:doc-dateTime-min="1930-11-08T14:00:00-05:00" n="481" subtype="historical-document" type="document" xml:id="d481">
                        <note rend="inline" type="source">832.01/8: Telegram</note>
                        <head><hi rend="italic">The Minister in Colombia</hi> (<persName type="from"><hi rend="italic">Caffery</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1930-11-08T14:00:00-05:00">November 8, 1930—2
                                p.m.</date><lb/>[Received 11 p.m.]</dateline></opener>
                        <p>132. Department’s 62.<note n="18" xml:id="d481fn18"><hi rend="italic">Ante</hi>, <ref target="#pg_452">p. 452</ref>.</note> Colombian
                            Government also recognizing the Brazilian Government today.</p>
                        <closer><signed><hi rend="smallcaps">Caffery</hi></signed></closer>
