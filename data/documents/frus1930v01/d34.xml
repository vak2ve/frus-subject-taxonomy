<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1930-03-03T13:00:00-05:00" frus:doc-dateTime-min="1930-03-03T13:00:00-05:00" n="34" subtype="historical-document" type="document" xml:id="d34">
                        <note rend="inline" type="source">500.A15a3/728: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Ambassador in Japan</hi> (<persName type="to"><hi rend="italic">Castle</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1930-03-03T13:00:00-05:00">March 3, 1930—1
                                p.m.</date></dateline></opener>
                        <p>41. 1 have repeated your 35 to London as I do not know the answer.</p>
                        <closer><signed><hi rend="smallcaps">Cotton</hi></signed></closer>
