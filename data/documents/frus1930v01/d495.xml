                subtype="historical-document" type="document" xml:id="d495">
                <note rend="inline" type="source">121.5532/8: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Brazil</hi> (<persName type="to">
                        <hi rend="italic">Morgan</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1930-12-03T18:00:00-05:00"
                            >December 3, 1930—6 p.m.</date>
                    </dateline>
                </opener>
                <p>94. Your 158, December 1, 5 p.m. Departments concerned are disposed to comply
                    with your recommendation for appointment of Lieutenant Commander Blandy as Naval
                    Attaché but before taking definite action desire to await receipt of Brazilian
                    Government’s formal notification of its disposition with reference to
                    termination of the services of the Naval Mission.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
