                subtype="historical-document" type="document" xml:id="d149">
                <head>149. Memorandum From the President’s Assistant for National Security Affairs
                        (<persName corresp="#p_BZ_1">Brzezinski</persName>) to President <persName
                        corresp="#p_CJ_2">Carter</persName>
                    <note n="1" type="source" xml:id="d149fn1">Source: Carter Library, National
                        Security Affairs, <persName corresp="#p_BZ_1">Brzezinski</persName>
                        Material, <persName corresp="#p_BZ_1">Brzezinski</persName> Office File,
                        Subject Chron File, Box 113, <gloss target="#t_SALT_1">SALT</gloss>:
                        1–2/1977. Top Secret; Sensitive. The meeting was held in the White House
                        Situation Room. At the top of the page is <persName corresp="#p_CJ_2"
                            >Carter</persName>’s handwritten note that reads: “OK, J.C.”</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            from="1977-02-03T09:06:00-05:00" to="1977-02-03T10:48:00-05:00">February
                            3, 1977, 9:06–10:48 a.m.</date>
                    </dateline>
                </opener>
                <list type="subject">
                    <head>SUBJECT</head>
                    <item>Summary Report for your Information and Reaction of the Special
                        Coordination Committee Meeting, Feb. 3</item>
                </list>
