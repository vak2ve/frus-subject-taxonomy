    <text>
        <body>
            <div frus:doc-dateTime-max="1968-09-25T23:59:59-05:00"
                frus:doc-dateTime-min="1968-09-25T00:00:00-05:00" n="263"
                subtype="historical-document" type="document" xml:id="d263">
                <head>263. Central Intelligence Agency Intelligence Information Cable<note n="1"
                        type="source" xml:id="d263fn1">Source: Johnson Library, National Security
                        File, Country File, United Arab Republic, Vol. VII, Cables and Memos,
                        6/68–1/69. Secret; Routine; No Foreign Dissem.</note>
                </head>
                <opener>
                    <seg rendition="#left">[<hi rend="italic">document number not
                        declassified</hi>]</seg>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1968-09-25">September 25, 1968</date>.</dateline>
                </opener>
                <list>
                    <head>COUNTRY</head>
                    <item>
                        <gloss target="#t_UAR1">UAR</gloss>/<gloss target="#t_USSR1"
                        >USSR</gloss>/ISRAEL</item>
                </list>
                <list>
                    <head>DOI</head>
                    <item>Late August 1968</item>
                </list>
                <list type="subject">
                    <head>SUBJECT</head>
                    <item>Possible Provision of Advanced Aircraft to <gloss target="#t_UAR1"
                            >UAR</gloss> by the <gloss target="#t_USSR1">USSR</gloss>
                    </item>
                </list>
                <list>
                    <head>ACQ</head>
                    <item>[<hi rend="italic">less than 1 line of source text not
                        declassified</hi>]</item>
                </list>
                <list type="sources">
                    <head>SOURCE</head>
                    <item>[<hi rend="italic">3 lines of source text not declassified</hi>]</item>
                </list>
                <list>
                    <label>1.</label>
                    <item>Lieutenant General Amir Khammash, Jordan Arab Army Chief of Staff, was
                        informed during a visit to Cairo in late August 1968 by both War Minister
                        Muhammad Fawzi and <gloss target="#t_UAR1">UAR</gloss> Army Chief of Staff
                        Major General Abd-al-Munim Riyad that the Soviet Union had promised to
                        provide the <gloss target="#t_UAR1">UAR</gloss> with advanced aircraft to
                        offset any sale of U.S. Phantom aircraft to Israel. (Field Comment. Source
                        did not have any details as to type or number of aircraft.)</item>
                    <label>2.</label>
                    <item>Field Dissem. <gloss target="#t_CINCMEAFSA1">CINCMEAFSA</gloss> (also sent
                        Cairo.)</item>
                </list>
            </div>
