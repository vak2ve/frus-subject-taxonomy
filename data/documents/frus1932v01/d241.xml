<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1932-11-02T15:00:00-05:00" frus:doc-dateTime-min="1932-11-02T15:00:00-05:00" n="241" subtype="historical-document" type="document" xml:id="d241">
                        <note rend="inline" type="source">500.A15A4 Permanent Disarmament
                            Commission/7: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the American Delegate (<persName corresp="#p_WHR1" type="to">Wilson</persName>)</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1932-11-02T15:00:00-05:00">November
                                    2, 1932—3 p.m.</date>
                            </dateline>
                        </opener>
                        <p>229. Your 428, November 2, noon. We defer to your judgment, and approve
                            your suggested method of handling the problem.</p>
                        <closer>
                            <signed>
                                <persName>
                                    <hi rend="smallcaps">Carr</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>