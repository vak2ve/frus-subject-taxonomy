                subtype="historical-document" type="document" xml:id="d585">
                <note rend="inline" type="source">550.S1/254: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Geneva (<persName corresp="#p_VSRG1" type="to"
                        >Gilbert</persName>)</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-10-12T17:00:00-05:00"
                            >October 12, 1932—5 p.m.</date>
                    </dateline>
                </opener>
                <p>158. Department is announcing appointment of Mr. <persName corresp="#p_DEE1"
                        >Edmond E. Day</persName>, Director of Social Science, Rockefeller
                    Foundation, and Professor <persName corresp="#p_WJH1">John H.
                        Williams</persName>, Harvard University, as American representatives on
                    preparatory committee of experts for the Monetary and Economic Conference. They
                    will sail on Steamship <hi rend="italic">Exeter</hi> October 18th and should
                    reach Geneva October 29.</p>
                <p>Please inform Secretary General.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SHL1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
