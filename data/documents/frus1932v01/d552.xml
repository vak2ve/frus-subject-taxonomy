    <text>
        <body>
            <div frus:doc-dateTime-max="1932-09-14T23:59:59-05:00"
                frus:doc-dateTime-min="1932-09-14T00:00:00-05:00" n="552"
                subtype="historical-document" type="document" xml:id="d552">
                <note rend="inline" type="source">800.51W89 Poland/81</note>
                <head>
                    <hi rend="italic">The Polish Chargé (<persName type="from"
                        >Sokolowski</persName>) to the <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 537/32</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1932-09-14">September 14,
                            1932</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Acting upon instructions received from my
                    Government, I have the honor to inform you that the Government of the Republic
                    of Poland, in conformity with the provisions of paragraph 2 of the Agreement for
                    the funding of the debt of Poland to the United States of November 14,
                        1924,<note n="22" xml:id="d552fn22">
                        <hi rend="italic">Combined Annual Reports of the World War Foreign Debt
                            Commission, 1922–1926</hi>, pp. 156–160.</note> postpones the payment of
                    principal falling due on December 15, 1932, for two years, that is to December
                    15, 1934.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Wladyslaw Sokolowski</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
