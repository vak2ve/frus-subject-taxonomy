                subtype="historical-document" type="document" xml:id="d422">
                <note rend="inline" type="source">800.51W89 Great Britain/300: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain (<persName corresp="#p_MAW1"
                            type="from">Mellon</persName>) to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1932-05-14T13:00:00+01:00"
                            >May 14, 1932—1 p.m.</date>
                        <lb/> [Received May 14—8:09 a.m.]</dateline>
                </opener>
                <p>172. For Secretary <persName corresp="#p_MOL1">Mills</persName>. Foreign Office
                    asks significance of date May 20th mentioned in your telegram 133, April 30, 2
                    p.m., to me.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MAW1">
                            <hi rend="smallcaps">Mellon</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
