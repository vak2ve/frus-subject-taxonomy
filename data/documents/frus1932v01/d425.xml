                subtype="historical-document" type="document" xml:id="d425">
                <note rend="inline" type="source">800.51W89 Greece/88: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Greece (<persName type="from">Morris</persName>)
                        to the <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Athens</hi>
                        </placeName>, <date calendar="gregorian" when="1932-03-15T11:00:00+02:00"
                            >March 15, 1932—11 a.m.</date>
                        <lb/> [Received March 15—7:58 a.m.]</dateline>
                </opener>
                <p>12. Department’s circular February 26, 11 a.m. Minister of Foreign Affairs
                    advises that <persName corresp="#p_SC1">Simopoulos</persName>, Greek Minister at
                    Washington, has been authorized to conduct negotiation.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Morris</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
