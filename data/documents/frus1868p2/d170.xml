    <text>
        <body>
            <div frus:doc-dateTime-max="1868-02-20T23:59:59-05:00" frus:doc-dateTime-min="1868-02-20T00:00:00-05:00" n="170" subtype="historical-document" type="document" xml:id="d170">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Asboth</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 52.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1868-02-20">
                            <hi rend="italic">February</hi> 20, 1868.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> You will receive herewith the
                                correspondence<note n="*" xml:id="d170fn1">For inclosures see
                                correspondence with the United States minister to Italy.</note>
                            which has taken place between this department and Mr. Marsh, United
                            States minister at Florence, on the subject of an Italian fleet from the
                            Mediterranean to the waters of the La Plata.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Alexander Asboth,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
