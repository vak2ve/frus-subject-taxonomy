    <text>
        <body>
            <div frus:doc-dateTime-max="1867-09-16T23:59:59-05:00" frus:doc-dateTime-min="1867-09-16T00:00:00-05:00" n="634" subtype="historical-document" type="document" xml:id="d634">
                <head>
                    <persName type="from">Mr. Sullivan</persName> to <persName type="to">Mr. Seward</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 25.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States,</hi>
                            <hi rend="italic">Bogota,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1867-09-16">
                            <hi rend="italic">September</hi> 16, 1867.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Inclosed are copies of correspondence had
                            between the United States consul at Carthagena and myself, on the rumor
                            that an American citizen was shot by General Herrera at Rio Hatché.</p>
                <p>I have the honor to be, sir, your obedient servant,</p>
                <closer>
                    <signed>PETER J. SULLIVAN.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William H. Seward,</hi>
                        <hi rend="italic">Secretary of State, Washington, D. C.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
