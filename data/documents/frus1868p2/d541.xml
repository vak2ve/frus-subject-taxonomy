    <text>
        <body>
            <div frus:doc-dateTime-max="1868-11-24T23:59:59-05:00"
                frus:doc-dateTime-min="1868-11-24T00:00:00-05:00" n="541"
                subtype="historical-document" type="document" xml:id="d541">
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Señor
                        Garcia</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1868-11-24">
                            <hi rend="italic">November</hi> 24, 1868.</date>
                    </dateline>
                </opener>
                <p>The direction you desire has been given to the collector.</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>Señor Don <hi rend="smallcaps">José Antonio Garcia y Garcia,</hi>
                        <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
