    <text>
        <body>
            <div frus:doc-dateTime-max="1868-04-27T23:59:59-05:00" frus:doc-dateTime-min="1868-04-27T00:00:00-05:00" n="531" subtype="historical-document" type="document" xml:id="d531">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Señor Garcia</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1868-04-27">
                            <hi rend="italic">April</hi> 27, 1868.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I transmit for your information a copy
                                of the reply<note n="*" xml:id="d531fn1">For this inclosure see page
                                    646.</note> of this department to a note of Señor Don Ignacio
                                Gomez, the minister plenipotentiary of the republic of Nicaragua,
                                upon the subject of the good offices of the state of Central America
                                towards putting an end to the war between Spain on the one side, and
                                Ecuador, Peru, Bolivia, and Chili on the other.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>Señor Don <hi rend="smallcaps">José Antonio Garcia y
                                        Garcia</hi>
                        <hi rend="italic">, &amp;c<hi rend="italic">.,
                                            &amp;</hi>c<hi rend="italic">.,</hi> &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
