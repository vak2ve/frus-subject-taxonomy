<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1868-12-03T23:59:59-05:00" frus:doc-dateTime-min="1868-12-03T00:00:00-05:00" n="543" subtype="historical-document" type="document" xml:id="d543">
                            <opener><seg rendition="#center">[Telegram.]</seg></opener>
                            <head><persName type="from">Señor Garcia</persName> to <persName type="to">Mr. Seward</persName>.</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName><hi rend="smallcaps">New Orleans,</hi></placeName>
                                    <date calendar="gregorian" when="1868-12-03"><hi rend="italic">December</hi> 3, 1868.</date></dateline></opener>
                            <p>The assurance that I have given to you about iron-clads in my
                                government’s name shall be held. You can use it as you please.</p>
                            <closer>
                                <signed>J. A. GARCIA.</signed></closer>
                            <postscript>
                                <p>Hon. <hi rend="smallcaps">Willam</hi> H. <hi rend="smallcaps">Seward,</hi>
                                    <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                            </postscript>
                        </div>
                        </body></text></TEI>