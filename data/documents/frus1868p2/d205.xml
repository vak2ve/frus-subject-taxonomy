<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1868-04-30T23:59:59-05:00" frus:doc-dateTime-min="1868-04-30T00:00:00-05:00" n="205" subtype="historical-document" type="document" xml:id="d205">
                        <opener><seg rendition="#center">[Extract.]</seg></opener>
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Kilpatrick</persName>.</head>
                        <opener><seg rendition="#left">No. 60.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1868-04-30"><hi rend="italic">April</hi> 30, 1868.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                            dispatch No. 104, Unclosing a copy of the note of the minister of
                            foreign affairs of Chili, dated on the 24th March last, with reference
                            to mediation in the Spanish-American question. His reply will be
                            communicated to the Spanish government.</p>
                        <p rend="center">* * * * * * * *</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Judson Kilpatrick,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>