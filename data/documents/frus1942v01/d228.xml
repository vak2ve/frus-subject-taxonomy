                subtype="historical-document" type="document" xml:id="d228">
                <note rend="inline" type="source">701.6211/1486a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Switzerland</hi> (<persName type="to">
                        <hi rend="italic">Huddle</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1941-12-30">December 30,
                            1941</date>.</dateline>
                </opener>
                <p>431. Department’s 338, 19th, paragraph 3. Please request Swiss Government to
                    inform the German, Italian, Rumanian and Hungarian Governments that Department
                    is prepared on the basis of reciprocity to extend exemption from search or
                    control of personal effects to consular and other official personnel and to
                    their accompanying dependents and staffs.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
