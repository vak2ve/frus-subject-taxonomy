                <note rend="inline" type="source">740.0011 European War 1939/18977: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Ireland</hi> (<persName type="to">
                        <hi rend="italic">Gray</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1942-01-31T19:00:00-05:00"
                            >January 31, 1942—7 p.m.</date>
                    </dateline>
                </opener>
                <p>6. Your 7, January 27. Department agrees that it would not be wise to change our
                    policy under existing circumstances.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
