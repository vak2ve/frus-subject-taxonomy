                subtype="historical-document" type="document" xml:id="d554">
                <note rend="inline" type="source">123 Johnson, Louis A./35: Telegram</note>
                <head>
                    <hi rend="italic">The Officer in Charge at New Delhi</hi> (<persName type="from">
                        <hi rend="italic">Merrell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">New Delhi</hi>
                        </placeName>, <date calendar="gregorian" when="1942-05-16T13:00:00+05:30"
                            >May 16, 1942—1 p.m.</date>
                        <lb/>[Received 1:23 p.m.]</dateline>
                </opener>
                <p>293. For the President and Secretary from Colonel Johnson: “Leaving Karachi for
                    Cairo today. Saw Foreign Secretary Thursday who assures my going will not be
                    misinterpreted and who recommends seek further medical treatment
                    immediately.”</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Merrell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
