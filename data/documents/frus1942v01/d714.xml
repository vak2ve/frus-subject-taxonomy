                subtype="historical-document" type="document" xml:id="d714">
                <note rend="inline" type="source">740.00114A Pacific War/228: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Switzerland</hi> (<persName type="to">
                        <hi rend="italic">Harrison</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1942-11-12">November 12,
                            1942</date>.</dateline>
                </opener>
                <p>2529. American interests—Japan, prisoners of war. Your 5010, November 5. Request
                    Swiss Government to endeavor to obtain names of aviators upon whom penalties
                    were imposed together with specification of charges and penalties in each
                    case.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
