<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1942-11-12T23:59:59-05:00" frus:doc-dateTime-min="1942-11-12T00:00:00-05:00" n="714" subtype="historical-document" type="document" xml:id="d714">
                            <note rend="inline" type="source">740.00114A Pacific War/228:
                                Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Minister in Switzerland</hi> (<persName type="to"><hi rend="italic">Harrison</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1942-11-12">November 12, 1942</date>.</dateline>
                            </opener>
                            <p>2529. American interests—Japan, prisoners of war. Your 5010, November
                                5. Request Swiss Government to endeavor to obtain names of aviators
                                upon whom penalties were imposed together with specification of
                                charges and penalties in each case.</p>
                            <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                        </div>
                        </body></text></TEI>