                subtype="historical-document" type="document" xml:id="d213">
                <note rend="inline" type="source">390.1115A/1010b: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at Calcutta</hi> (<persName type="to">
                        <hi rend="italic">Schnare</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1942-07-24T14:00:00-04:00"
                            >July 24, 1942—2 p.m.</date>
                    </dateline>
                </opener>
                <p>318. Your 506, July 14. Department informed two large vessels operating under War
                    Shipping Administration presently available at Karachi for evacuation purposes.
                    Available accommodations on these vessels apparently ample to afford all persons
                    referred to in your 506 opportunity of repatriation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
