<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-03-14T18:00:00-05:00" frus:doc-dateTime-min="1933-03-14T18:00:00-05:00" n="37" subtype="historical-document" type="document" xml:id="d37">
                        <note rend="inline" type="source">500.A15A4 Personnel/955: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Acting Chairman of the American Delegation</hi> (<persName type="to"><hi rend="italic">Gibson</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1933-03-14T18:00:00-05:00">March 14,
                                    1933—6 p.m.</date>
                            </dateline>
                        </opener>
                        <p>304. Personal for Gibson. The President has appointed Mr. Norman Davis
                            Chairman of the Delegation to the Disarmament Conference. He is planning
                            to sail for Europe within 10 days and is being given the personal rank
                            of Ambassador.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>