<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-06-15T14:00:00-05:00" frus:doc-dateTime-min="1933-06-15T14:00:00-05:00" n="463" subtype="historical-document" type="document" xml:id="d463">
                        <note rend="inline" type="source">550.S1 Monetary Commission/4:
                            Telegram</note>
                        <head>
                            <hi rend="italic">The Chairman of the American Delegation</hi>
                                (<persName type="from"><hi rend="italic">Hull</hi></persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                                    State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1933-06-15T20:00:00+01:00">June 15,
                                    1933—8 p.m.</date>
                                <lb/> [Received June 15—2:35 p.m.]</dateline>
                        </opener>
                        <p>34. Cox elected Chairman of Monetary Commission, Bonnet nominating him.
                                Colijn<note n="55" xml:id="d463fn55">Hendryk Colijn, President of
                                the Netherlands Council of Ministers.</note> elected President
                            Economic Commission.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>