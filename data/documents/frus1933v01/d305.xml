<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-06-07T23:59:59-05:00" frus:doc-dateTime-min="1933-06-07T00:00:00-05:00" n="305" subtype="historical-document" type="document" xml:id="d305">
                    <note rend="inline" type="source">740.0011 Four Power Pact/92: Telegram</note>
                    <head>
                        <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from"><hi rend="italic">Long</hi></persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Rome</hi>
                            </placeName> [<date ana="#date_undated-inferred-from-outside-research" calendar="gregorian" when="1933-06-07">undated</date>].<lb/>[Received June 7—3:48 p.m.]</dateline>
                    </opener>
                    <p>60. Four Power Pact<note n="41" xml:id="d305fn41">For English text, see <ref target="#pg_417">p. 417</ref>.</note> is being initialed in Rome at
                        7:30 p.m.</p>
                    <p>Repeated to Geneva, London, Paris, Berlin.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Long</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>