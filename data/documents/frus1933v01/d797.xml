<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-05-22T18:00:00-05:00" frus:doc-dateTime-min="1933-05-22T18:00:00-05:00" n="797" subtype="historical-document" type="document" xml:id="d797">
                    <note rend="inline" type="source">579.6L3/61: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            Ambassador in Italy</hi> (<persName type="to"><hi rend="italic">Garrett</hi></persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1933-05-22T19:00:00-04:00">May 22, 1933—7
                                p.m.</date>
                        </dateline>
                    </opener>
                    <p>27. Your 38, May 20, 1 p.m. For Cooper. American delegates are authorized to
                        sign convention with declaration that it applies only to continental United
                        States.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Hull</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>