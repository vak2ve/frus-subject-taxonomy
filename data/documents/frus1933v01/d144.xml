                subtype="historical-document" type="document" xml:id="d144">
                <note rend="inline" type="source">500.A15A4/2015: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chairman of the American Delegation</hi> (<persName type="to">
                        <hi rend="italic">Davis</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1933-05-29T17:00:00-04:00"
                            >May 29, 1933—5 p.m.</date>
                    </dateline>
                </opener>
                <p>345. Your 666, May 27, 11 a.m. No reply received from Japanese.<note n="41"
                        xml:id="d144fn41">Received June 6; see telegram No. 351, June 6, 6 p.m., to
                        the Chairman of the American delegation, <ref target="#pg_184">p.
                        184</ref>.</note> In my conversations with Ishii, I have had no discussion
                    of political matters.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
