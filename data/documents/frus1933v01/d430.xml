<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-05-12T19:00:00-05:00" frus:doc-dateTime-min="1933-05-12T19:00:00-05:00" n="430" subtype="historical-document" type="document" xml:id="d430">
                        <note rend="inline" type="source">550.S1/770: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in Great Britain</hi> (<persName type="to"><hi rend="italic">Atherton</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1933-05-12T20:00:00-04:00">May 12,
                                    1933—8 p.m.</date>
                            </dateline>
                        </opener>
                        <p>108. For Norman Davis. Your 121, May 12, 9 p.m. This is a splendid job.
                            You have my best congratulations.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>