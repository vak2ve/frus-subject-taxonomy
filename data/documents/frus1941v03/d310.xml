<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-04-25T23:59:59-05:00" frus:doc-dateTime-min="1941-04-25T00:00:00-05:00" n="310" subtype="historical-document" type="document" xml:id="d310">
                            <note rend="inline" type="source">365D.1163/172: Telegram</note>
                            <head><hi rend="italic">The Minister in Egypt</hi> (<persName type="from"><hi rend="italic">Kirk</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Cairo</hi></placeName>, <date calendar="gregorian" when="1941-04-25">April 25, 1941</date>.<lb/>[Received April
                                    26—1:37 p.m.]</dateline>
                            </opener>
                            <p>335. Department’s 67, March 31. Legation is informed by British
                                military authorities that following members American mission at
                                Addis Ababa with other names to follow are safe and will be given
                                all assistance necessary: Mr. and Mrs. Duncan, Henry W. Henry, H.
                                Hanson and Mae Matthews.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Kirk</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>