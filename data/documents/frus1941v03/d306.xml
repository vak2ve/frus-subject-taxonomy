                subtype="historical-document" type="document" xml:id="d306">
                <note rend="inline" type="source">740.0011 European War 1939/9686: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Egypt</hi> (<persName type="from">
                        <hi rend="italic">Kirk</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Cairo</hi>
                        </placeName>, <date calendar="gregorian" when="1941-04-06T13:00:00+02:00"
                            >April 6, 1941—1 p.m.</date>
                        <lb/>[Received April 7—3:02 a.m.]</dateline>
                </opener>
                <p>202. The Legation is informed that the report has just been received of the fall
                    of Addis Ababa but that the report has not yet been released.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kirk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
