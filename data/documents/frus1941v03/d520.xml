                subtype="historical-document" type="document" xml:id="d520">
                <note rend="inline" type="source">890G.00/587: Telegram</note>
                <head>
                    <hi rend="italic">The Minister Resident in Iraq</hi> (<persName type="from">
                        <hi rend="italic">Knabenshue</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Baghdad</hi>
                        </placeName>, <date calendar="gregorian" when="1941-04-28T17:00:00+03:00"
                            >April 28, 1941—5 p.m.</date>
                        <lb/>[Received 8:30 p.m.]</dateline>
                </opener>
                <p>103. Referring my 97, April 24.<note n="34" xml:id="d520fn34">Not printed.</note>
                    Saw Foreign Minister today informing him I had been authorized establish
                    informal contact with him. He did not press for anything further at this
                    juncture.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Knabenshue</hi>
                    </signed>
                </closer>
            </div>
        </body>
