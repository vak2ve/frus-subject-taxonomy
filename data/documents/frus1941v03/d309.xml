                subtype="historical-document" type="document" xml:id="d309">
                <note rend="inline" type="source">740.0011 European War 1939/9797: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Aden</hi> (<persName type="to">
                        <hi rend="italic">Timberlake</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1941-04-12T19:00:00-05:00"
                            >April 12, 1941—7 p.m.</date>
                    </dateline>
                </opener>
                <p>10. For Timberlake. You are instructed to proceed Addis Ababa, Berbera and
                    Djibouti for the purpose indicated in your 17, April 7, 2 p.m.…</p>
                <p rend="center">. . . . . . . . . . . . . .</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
