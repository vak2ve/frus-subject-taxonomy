                subtype="historical-document" type="document" xml:id="d644">
                <note rend="inline" type="source">867N.01/1780</note>
                <head>
                    <hi rend="italic">The Under Secretary of State</hi> (<persName type="from">
                        <hi rend="italic">Welles</hi>
                    </persName>) <hi rend="italic">to <persName type="to">Rabbi Stephen S.
                            Wise</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1941-10-08">October 8,
                            1941</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Dr. Wise</hi>: I wish to acknowledge the receipt of
                    your letter of September 26, 1941. I have noted your remarks regarding the
                    possibility of political changes in the Near East, and I shall be glad to send
                    you information on the subject as soon as possible.</p>
                <p>Sincerely yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sumner Welles</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
