<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-10-23T19:00:00-05:00" frus:doc-dateTime-min="1941-10-23T19:00:00-05:00" n="107" subtype="historical-document" type="document" xml:id="d107">
                            <note rend="inline" type="source">561.321D1 Advisory Committee/64:
                                Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in Brazil</hi> (<persName type="to"><hi rend="italic">Caffery</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1941-10-23T19:00:00-05:00">October 23, 1941—7
                                        p.m.</date></dateline>
                            </opener>
                            <p>1000. In view of decrease in price of Brazilian cotton the subsidy on
                                exports of United States cotton to Canada has been increased to 3
                                cents in accordance with the plan referred to in last sentence of
                                Section C, our telegram no. 804 of September 15, 1941.</p>
                            <p>Repeat to São Paulo.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>