                subtype="historical-document" type="document" xml:id="d305">
                <note rend="inline" type="source">365D.1163/170: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Egypt</hi> (<persName type="from">
                        <hi rend="italic">Kirk</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Cairo</hi>
                        </placeName>, <date calendar="gregorian" when="1941-04-03T16:00:00+02:00"
                            >April 3, 1941—4 p.m.</date>
                        <lb/>[Received April 5—5:40 p.m.]</dateline>
                </opener>
                <p>180. Department’s 67, March 31, 4 p.m., concerning American mission personnel at
                    Addis Ababa. The British Embassy states that this matter has been brought to the
                    attention of the appropriate military authorities.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kirk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
