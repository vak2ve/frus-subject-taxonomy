<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-10-01T06:00:00-05:00" frus:doc-dateTime-min="1941-10-01T06:00:00-05:00" n="296" subtype="historical-document" type="document" xml:id="d296">
                            <note rend="inline" type="source">883.5151/49: Telegram</note>
                            <head><hi rend="italic">The Minister in Egypt</hi> (<persName type="from"><hi rend="italic">Kirk</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Cairo</hi></placeName>, <date calendar="gregorian" when="1941-10-01T13:00:00+02:00">October 1, 1941—1
                                        p.m.</date><lb/>[Received October 2—4:33 p.m.]</dateline>
                            </opener>
                            <p>1500. My 1496, September 30, 6 p.m. The Legation has received a note
                                from the Foreign Office confirming the telephone message mentioned
                                in the Legation’s telegram under reference to the effect that
                                pending a final decision on the matter American nationals and firms
                                in Egypt will be exempt from declaring their dollar holdings in
                                Egypt and abroad.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Kirk</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>