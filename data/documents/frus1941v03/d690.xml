<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-07-24T23:59:59-05:00" frus:doc-dateTime-min="1941-07-24T00:00:00-05:00" n="690" subtype="historical-document" type="document" xml:id="d690">
                            <note rend="inline" type="source">890D.927/145: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Consul General at Beirut</hi>
                                    (<persName type="to"><hi rend="italic">Engert</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1941-07-24">July 24, 1941</date>.</dateline>
                            </opener>
                            <p>145. Following from Oriental Institute: <quote rend="blockquote">
                                    <p>“Please ask present Government Syria<note n="14" xml:id="d690fn14">Established after the occupation of
                                            Syria by the British-Free French forces; for
                                            correspondence on this subject, see <ref target="#pg_725">pp. 725</ref> ff.</note> confirm
                                        Fakhariyah concession.”<note n="15" xml:id="d690fn15">Concession confirmed, April 14, 1942.</note></p>
                                </quote></p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Welles</hi>
                                </signed>
                            </closer>
                        </div>
                    </body></text></TEI>