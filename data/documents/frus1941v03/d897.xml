<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-03-04T05:00:00-05:00" frus:doc-dateTime-min="1941-03-04T05:00:00-05:00" n="897" subtype="historical-document" type="document" xml:id="d897">
                            <note rend="inline" type="source">740.0011 European War 1939/8782:
                                Telegram</note>
                            <head><hi rend="italic">The Ambassador in Turkey</hi> (<persName type="from"><hi rend="italic">MacMurray</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Ankara</hi></placeName>, <date calendar="gregorian" when="1941-03-04T13:00:00+03:00">March 4, 1941—1
                                    p.m.</date><lb/>[Received 10:35 p.m.]</dateline>
                            </opener>
                            <p>52. For Secretary and Under Secretary. From authoritative source I
                                have confirmed substantial accuracy of my 49, March 1, although I
                                have not yet received fuller details as to results of Eden
                                mission.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">MacMurray</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>