<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-08-09T10:00:00-05:00" frus:doc-dateTime-min="1941-08-09T10:00:00-05:00" n="367" subtype="historical-document" type="document" xml:id="d367">
                            <note rend="inline" type="source">740.0011 European War 1939/13821:
                                Telegram</note>
                            <head><hi rend="italic">The Ambassador in the United Kingdom</hi>
                                    (<persName type="from"><hi rend="italic">Winant</hi></persName>)
                                    <hi rend="italic">to the <gloss type="to">Secretary of
                                        State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1941-08-09T17:00:00+02:00">August 9, 1941—5
                                        p.m.</date><lb/>[Received August 9—11:10 a.m.]</dateline>
                            </opener>
                            <p>3532. For the Secretary and the Under Secretary. My 3511, August 8,
                                10 p.m. Mr. Eden informs me that the date of August 16th mentioned
                                in first paragraph has been changed to August 14th.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Winant</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>