                subtype="historical-document" type="document" xml:id="d530">
                <note rend="inline" type="source">740.0011 European War 1939/11513: Telegram</note>
                <head>
                    <hi rend="italic">The Minister Resident in Iraq</hi> (<persName type="from">
                        <hi rend="italic">Knabenshue</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Baghdad</hi>
                        </placeName>, <date calendar="gregorian" when="1941-05-31">May 31,
                            1941</date>.<lb/>[Received June 1—5:35 p.m.]</dateline>
                </opener>
                <p>127. Armistice signed this afternoon. Terms will be communicated to Embassy
                    London by Foreign Office. I have confidence that new Government arranged but not
                    yet announced will establish situation as it should be.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Knabenshue</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
