<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-12-09T21:00:00-05:00" frus:doc-dateTime-min="1941-12-09T21:00:00-05:00" n="482" subtype="historical-document" type="document" xml:id="d482">
                            <note rend="inline" type="source">861.248/162: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in the United Kingdom</hi>
                                    (<persName type="to"><hi rend="italic">Winant</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1941-12-09T21:00:00-05:00">December 9, 1941—9
                                        p.m.</date></dateline>
                            </opener>
                            <p>5791. Your 5752, November 29, 4 p.m. More detailed communication
                                urgently awaited.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>