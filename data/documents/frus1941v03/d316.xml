<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-05-18T05:00:00-05:00" frus:doc-dateTime-min="1941-05-18T05:00:00-05:00" n="316" subtype="historical-document" type="document" xml:id="d316">
                            <note rend="inline" type="source">740.0011 European War 1939/11104:
                                Telegram</note>
                            <head><hi rend="italic">The Minister in Egypt</hi> (<persName type="from"><hi rend="italic">Kirk</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Cairo</hi></placeName>, <date calendar="gregorian" when="1941-05-18T13:00:00+03:00">May 18, 1941—1
                                    p.m.</date><lb/>[Received May 20—3:44 a.m.]</dateline>
                            </opener>
                            <p>522. It is reported but not yet officially announced that the Duke of
                                Aosta has surrendered with 7,000 men.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Kirk</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>