                subtype="historical-document" type="document" xml:id="d72">
                <note rend="inline" type="source">840.48/5046: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the United Kingdom</hi> (<persName type="to">
                        <hi rend="italic">Winant</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1941-08-20T11:00:00-04:00"
                            >August 20, 1941—11 a.m.</date>
                    </dateline>
                </opener>
                <p>3240. Your 3615, August 13, 9 p.m. and 3637, August 14, 6 p.m.<note n="24"
                        xml:id="d72fn24">Latter not printed.</note> Please inform Mr. Eden that we
                    have taken note of the revised language of paragraph number 5 relating to
                    shipping, that it seems adequately to cover the point made in our earlier
                    comment, and that we have no further comment to make.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
