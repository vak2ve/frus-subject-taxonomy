<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-07-12T18:00:00-05:00" frus:doc-dateTime-min="1941-07-12T18:00:00-05:00" n="608" subtype="historical-document" type="document" xml:id="d608">
                            <note rend="inline" type="source">881.822/199: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Chargé at Tangier</hi> (<persName type="to"><hi rend="italic">Childs</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1941-07-12T19:00:00-04:00">July 12, 1941—7
                                    p.m.</date></dateline>
                            </opener>
                            <p>85. Your 238, July 3, noon. Your action approved. A note is being
                                telegraphed to the Embassy at Madrid for presentation to the Spanish
                                Government the text of which the Embassy will repeat to you.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Welles</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>