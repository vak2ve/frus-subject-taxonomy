<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-04-18T13:00:00-05:00" frus:doc-dateTime-min="1941-04-18T13:00:00-05:00" n="516" subtype="historical-document" type="document" xml:id="d516">
                            <note rend="inline" type="source">740.0011 European War 1939/10087:
                                Telegram</note>
                            <head><hi rend="italic">The Minister Resident in Iraq</hi> (<persName type="from"><hi rend="italic">Knabenshue</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Baghdad</hi></placeName>, <date calendar="gregorian" when="1941-04-18T21:00:00+03:00">April 18, 1941—9
                                        p.m.</date><lb/>[Received April 19—12:03 a.m.]</dateline>
                            </opener>
                            <p>87. Sea-borne British troops arrived Basrah and air-borne at Shaiba
                                today without incident.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Knabenshue</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>