<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-04-30T19:00:00-05:00" frus:doc-dateTime-min="1941-04-30T19:00:00-05:00" n="212" subtype="historical-document" type="document" xml:id="d212">
                            <note rend="inline" type="source">740.0011 European War 1939/10388:
                                Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Minister in Egypt</hi> (<persName type="to"><hi rend="italic">Kirk</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1941-04-30T20:00:00-04:00">April 30, 1941—8
                                        p.m.</date></dateline>
                            </opener>
                            <p>108. Your 349, April 27. Department approves of your action in this
                                matter.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
