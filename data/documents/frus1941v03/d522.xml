    <text>
        <body>
            <div frus:doc-dateTime-max="1941-04-29T15:00:00-05:00"
                frus:doc-dateTime-min="1941-04-29T15:00:00-05:00" n="522"
                subtype="historical-document" type="document" xml:id="d522">
                <note rend="inline" type="source">390G.1115/15: Telegram</note>
                <head>
                    <hi rend="italic">The Minister Resident in Iraq</hi> (<persName type="from">
                        <hi rend="italic">Knabenshue</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Baghdad</hi>
                        </placeName>, <date calendar="gregorian" when="1941-04-29T23:00:00+03:00"
                            >April 29, 1941—11 p.m.</date>
                        <lb/>[Received 11:23 p.m.]</dateline>
                </opener>
                <p>109. Referring my 107 of even date.<note n="35" xml:id="d522fn35">Not
                        printed.</note> All American women and children left Baghdad this afternoon,
                    with one exception, who refused to leave.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Knabenshue</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
