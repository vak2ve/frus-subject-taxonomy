<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-06-03T23:59:59-05:00" frus:doc-dateTime-min="1941-06-03T00:00:00-05:00" n="533" subtype="historical-document" type="document" xml:id="d533">
                            <note rend="inline" type="source">890G.01/381: Telegram</note>
                            <head><hi rend="italic">The Minister Resident in Iraq</hi> (<persName type="from"><hi rend="italic">Knabenshue</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Baghdad</hi></placeName>, <date calendar="gregorian" when="1941-06-03">June 3, 1941</date>.<lb/>[Received June
                                    3—8:02 p.m.]</dateline>
                            </opener>
                            <p>133. New government formed by Jamil Madfai as Prime Minister and
                                Interior with Ali Jawdet [<hi rend="italic">Jawdat</hi>] Ayoubi,
                                Minister Foreign Affairs.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Knabenshue</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>