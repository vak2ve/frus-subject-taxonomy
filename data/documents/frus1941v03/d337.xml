<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-07-24T19:00:00-05:00" frus:doc-dateTime-min="1941-07-24T19:00:00-05:00" n="337" subtype="historical-document" type="document" xml:id="d337">
                            <note rend="inline" type="source">811.20(D)Regulations/3305:
                                Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Minister in Iran</hi> (<persName type="to"><hi rend="italic">Dreyfus</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1941-07-24T20:00:00-04:00">July 24, 1941—8
                                    p.m.</date></dateline>
                            </opener>
                            <p>59. Your 72, July 14, 10 a.m. Application of June 10 was rejected
                                July 21 but United States Steel Export Corporation has now been
                                invited to submit new application which will be considered in
                                connection with Prime Minister’s recommendation.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Welles</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>