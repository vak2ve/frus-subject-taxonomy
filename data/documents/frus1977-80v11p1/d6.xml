                            <item>
                                <persName corresp="#p_BZ_1">Zbigniew Brzezinski</persName>
                            </item>
                            <item>
                                <persName corresp="#p_JHH_1">Hamilton Jordan</persName>
                            </item>
                            <item>
                                <persName corresp="#p_PJJ_1">Jody Powell</persName>
                            </item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <head>
                                <hi rend="italic">
                                    <gloss target="#t_NSC_1">NSC</gloss>
                                </hi>
                            </head>
                            <item>Colonel <persName corresp="#p_OWE_1">William Odom</persName>
                            </item>
                            <item>
                                <persName corresp="#p_SG_1">Gary Sick</persName>
                            </item>
