                <head>6. Summary of Conclusions of a Special Coordination Committee Meeting<note
                        n="1" type="source" xml:id="d6fn1">Source: Carter Library, National Security
                        Council, <gloss target="#t_NSC_1">NSC</gloss> Institutional Files (H–Files),
                        Box 105, <gloss target="#t_SCC_1">SCC</gloss> 195 Iran. Top Secret;
                        Sensitive. The meeting took place in the White House Situation Room.
                            <persName corresp="#p_CJ_1">Carter</persName> initialed “C” in the upper
                        right corner.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            from="1979-11-06T09:00:00-05:00" to="1979-11-06T10:00:00-05:00">November
                            6, 1979, 9–10 a.m.</date>
                    </dateline>
                </opener>
                <list type="subject">
                    <head>SUBJECT</head>
                    <item>Iran</item>
                </list>
                <list type="participants">
                    <head>PARTICIPANTS</head>
                    <item>
                        <list>
                            <head>
                                <hi rend="italic">State</hi>
                            </head>
                            <item>Secretary <persName corresp="#p_VC_1">Cyrus Vance</persName>
                            </item>
