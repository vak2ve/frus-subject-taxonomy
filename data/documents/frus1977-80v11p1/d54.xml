                <head>54. Summary of Conclusions of a Special Coordination Committee (Intelligence)
                        Meeting<note n="1" type="source" xml:id="d54fn1">Source: National Security
                        Council, <persName corresp="#p_CJ_1">Carter</persName> Intelligence Files,
                        Box I020, <gloss target="#t_SCC_1">SCC</gloss> Meetings, Minutes—<gloss
                            target="#t_SCC_1">SCC</gloss> 1979. Top Secret. The meeting took place
                        in the White House Situation Room.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            from="1979-11-23T10:10:00-05:00" to="1979-11-23T10:30:00-05:00">November
                            23, 1979, 10:10–10:30 a.m.</date>
                    </dateline>
                </opener>
                <list type="subject">
                    <head>SUBJECT</head>
                    <item>Iran</item>
                </list>
                <list type="participants">
                    <head>PARTICIPANTS</head>
                    <item>
                        <list>
                            <head>
                                <hi rend="italic">State</hi>
                            </head>
