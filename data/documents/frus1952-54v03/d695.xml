<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1954-04-30T10:00:00-05:00" frus:doc-dateTime-min="1954-04-30T10:00:00-05:00" n="695" subtype="historical-document" type="document" xml:id="d695">
                    <note rend="inline" type="source">310.2/4–3054: Telegram</note>
                    <head>
                        <hi rend="italic">The Ambassador in France</hi> (<persName type="from"><hi rend="italic">Dillon</hi></persName>) <hi rend="italic">to the
                                <gloss type="to">Department of State</gloss></hi></head>
                    <opener>
                        <seg rendition="#left">
                            <hi rend="smallcaps">secret</hi></seg>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1954-04-30T16:00:00+01:00">April 30,
                                1954—4 p.m.</date></dateline>
                    </opener>
                    <p>4157. <gloss target="#t_Deptel1">Deptel</gloss> 3872 (Vienna 3180). We have
                        discussed Department’s position with <persName>Sauvagnargues</persName>.
                        Foreign Office views are identical and they will instruct French <gloss target="#t_HICOMER1">HICOMER</gloss> accordingly.</p>
                    <closer>
                        <signed>
                            <persName>
                                <hi rend="smallcaps">Dillon</hi></persName></signed></closer>
                </div>
                </body></text></TEI>