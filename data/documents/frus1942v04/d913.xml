                subtype="historical-document" type="document" xml:id="d913">
                <note rend="inline" type="source">811.248/824: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Egypt</hi> (<persName type="from">
                        <hi rend="italic">Kirk</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Cairo</hi>
                        </placeName>, <date calendar="gregorian" when="1942-12-30T09:00:00+02:00"
                            >December 30, 1942—9 a.m.</date>
                        <lb/> [Received December 31—11 p.m.]</dateline>
                </opener>
                <p>2276. My 2225, December 20, 5 p.m.<note n="1" xml:id="d913fn1">Not
                        printed.</note> Following telegram has been sent to Ankara.</p>
                <quote rend="blockquote">
                    <p>“December 29, 9 a.m. Legation’s December 24, noon.</p>
                    <p>Army now advises that 30 days required repair plane and requests you inform
                        Washington whether you consider time element still sufficiently important
                        warrant sending another B–24 to Turkey in substitution.</p>
                    <p>Please repeat here for Army’s information any recommendation you make to
                        Washington.”</p>
                </quote>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kirk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
