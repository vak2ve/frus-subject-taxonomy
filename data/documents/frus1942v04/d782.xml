<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1942-11-16T10:00:00-05:00" frus:doc-dateTime-min="1942-11-16T10:00:00-05:00" n="782" subtype="historical-document" type="document" xml:id="d782">
                        <note rend="inline" type="source">123 W 111/419: Telegram</note>
                        <head>
                            <hi rend="italic">The Consul at Beirut</hi> (<persName type="from"><hi rend="italic">Gwynn</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Beirut</hi></placeName>, <date calendar="gregorian" when="1942-11-16T17:00:00+02:00">November
                                    16, 1942—5 p.m.</date>
                                <lb/> [Received November 17—12:16 p.m.]</dateline>
                        </opener>
                        <p>455. Wadsworth arrived, am relinquishing charge as of close of business
                            today.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Gwynn</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>