                subtype="historical-document" type="document" xml:id="d279">
                <note rend="inline" type="source">891.50A/8a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Iran</hi> (<persName type="to">
                        <hi rend="italic">Dreyfus</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1942-09-04T19:00:00-04:00"
                            >September 4, 1942—7 p.m.</date>
                    </dateline>
                </opener>
                <p>233. Supply Adviser Sheridan and City Police Adviser L. Stephen Timmerman will
                    depart by air for Tehran on or about September 6. <pb facs="0264" n="252"
                        xml:id="pg_252"/> You may present them to Iranian officials but should make
                    it clear they are not connected with Legation or this Government. Mail
                    instruction follows.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
