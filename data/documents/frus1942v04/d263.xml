<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1942-06-13T16:00:00-05:00" frus:doc-dateTime-min="1942-06-13T16:00:00-05:00" n="263" subtype="historical-document" type="document" xml:id="d263">
                        <note rend="inline" type="source">891.00/1881: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in the United Kingdom</hi> (<persName type="to"><hi rend="italic">Winant</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1942-06-13T17:00:00-04:00">June 13,
                                    1942—5 p.m.</date>
                            </dateline>
                        </opener>
                        <p>2728. Your 3037, June 1 and Department’s 2417, May 22 [<hi rend="italic">27</hi>]. War Department prefers not to undertake organization of a
                            mission to Iran at this time but indicates it may be willing to
                            reconsider proposal later.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>