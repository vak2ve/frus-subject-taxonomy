<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1942-04-20T08:44:00-05:00" frus:doc-dateTime-min="1942-04-20T08:44:00-05:00" n="454" subtype="historical-document" type="document" xml:id="d454">
                        <note rend="inline" type="source">882.7962/79: Telegram</note>
                        <head>
                            <hi rend="italic">The Chargé in Liberia</hi> (<persName type="from"><hi rend="italic">Wharton</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Monrovia</hi></placeName>, <date calendar="gregorian" when="1942-04-20T13:00:00-00:44">April 20,
                                    1942—1 p.m.</date>
                                <lb/> [Received April 20—12:39 p.m.]</dateline>
                        </opener>
                        <p>132. Referring to my 120, April 7, 2 p.m. Fisherman Lake agreement signed
                            today.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Wharton</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>