                subtype="historical-document" type="document" xml:id="d98">
                <note rend="inline" type="source">740.0011European War 1939/25048: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Egypt</hi> (<persName type="from">
                        <hi rend="italic">Kirk</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Cairo</hi>
                        </placeName>, <date calendar="gregorian" when="1942-10-24T10:00:00+03:00"
                            >October 24, 1942—10 a.m.</date>
                        <lb/> [Received October 24—7:19 a.m.]</dateline>
                </opener>
                <p>1870. My 1819, October 14, 5 p.m.<note n="29" xml:id="d98fn29">Not
                        printed.</note> The British started an offensive in Western Desert last
                    night. No announcement has as yet been made.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kirk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
