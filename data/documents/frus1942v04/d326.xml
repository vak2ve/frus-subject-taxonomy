                <note rend="inline" type="source">891.20/133</note>
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to the
                        Lend-Lease Administrator</hi> (<persName type="to">
                        <hi rend="italic">Stettinius</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1942-03-10">March 10,
                            1942</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Stettinius</hi>: For purposes of implementing
                    the authority conferred upon you as Lend-Lease Administrator by Executive Order
                    No. 8926, dated October 28, 1941, and in order to enable you to arrange for
                    Lend-Lease aid to the Government of Iran, I hereby find that the defense of the
                    Government of Iran is vital to the defense of the United States.</p>
                <p>Very truly yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Franklin</hi> D. <hi rend="smallcaps">Roosevelt</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
