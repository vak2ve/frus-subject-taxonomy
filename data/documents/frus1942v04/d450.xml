                subtype="historical-document" type="document" xml:id="d450">
                <note rend="inline" type="source">882.20/552: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Liberia</hi> (<persName type="to">
                        <hi rend="italic">Wharton</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1942-03-29T15:00:00-04:00"
                            >March 29, 1942—3 p.m.</date>
                    </dateline>
                </opener>
                <p>74. Your 104, March 27, 8 p.m. For McBride. Changes in Article VI approved.</p>
                <p>Department congratulates you on extremely able manner in which you have handled
                    negotiations and on successful outcome thereof.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Welles</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
