                subtype="historical-document" type="document" xml:id="d33">
                <note rend="inline" type="source">124.90H/56a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Iran</hi> (<persName type="to">
                        <hi rend="italic">Dreyfus</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1941-12-13T21:00:00-05:00"
                            >December 13, 1941—9 p.m.</date>
                    </dateline>
                </opener>
                <p>157. Please ascertain whether Afghan Government agreeable to establishment
                    Legation at Kabul. If no objection a Foreign Service Officer will probably be
                    appointed as Minister Resident and Consul General.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
