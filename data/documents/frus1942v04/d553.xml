                subtype="historical-document" type="document" xml:id="d553">
                <note rend="inline" type="source">882.515/76: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Liberia</hi> (<persName type="from">
                        <hi rend="italic">Hibbard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1942-09-09T18:00:00-00:44"
                            >September 9, 1942—6 p.m.</date>
                        <lb/> [Received September 9—3:21 p.m.]</dateline>
                </opener>
                <p>291. My telegram number 287, September 3, 5 p.m. The President is still reluctant
                    to issue the necessary proclamation declaring American currency legal tender
                    until he has received final confirmation from the Treasury that the agreement is
                    approved. Would it be possible to send me a brief telegram to this effect so
                    that the operation can be started at once.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hibbard</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
