                subtype="historical-document" type="document" xml:id="d837">
                <note rend="inline" type="source">867.24/359: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Turkey</hi> (<persName type="to">
                        <hi rend="italic">Steinhardt</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1942-07-18T20:00:00-04:00"
                            >July 18, 1942—8 p.m.</date>
                    </dateline>
                </opener>
                <p>347. Your 751, July 17, noon, and 752, July 17, 3 p.m. Department is giving
                    immediate attention to Turkish Premier’s request in cooperation with interested
                    American and British agencies, with <pb facs="0742" n="730" xml:id="pg_730"/>
                    particular regard to recourse to MESC.<note n="60" xml:id="d837fn60">Middle East
                        Supply Center.</note> We assume Turkish Ambassador has been or is being
                    instructed in the matter.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
