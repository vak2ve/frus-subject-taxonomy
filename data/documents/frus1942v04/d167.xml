                subtype="historical-document" type="document" xml:id="d167">
                <note rend="inline" type="source">891.24/222a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the United Kingdom</hi> (<persName type="to">
                        <hi rend="italic">Winant</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1942-07-29T19:00:00-04:00"
                            >July 29, 1942—7 p.m.</date>
                    </dateline>
                </opener>
                <p>3533. Department’s 3475, July 25. Tehran reports UKCC has advised Iranian Finance
                    Ministry that 3,000 requisitioned tires will be delivered immediately to Iranian
                    Government. Consequently, you may disregard last paragraph of telegram under
                    reference.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
