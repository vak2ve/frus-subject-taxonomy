                subtype="historical-document" type="document" xml:id="d682">
                <note rend="inline" type="source">890F.7962/20: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Saudi Arabia</hi> (<persName type="to">
                        <hi rend="italic">Moose</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1942-08-04T22:00:00-04:00"
                            >August 4, 1942—10 p.m.</date>
                    </dateline>
                </opener>
                <p>29. Your 26, July 25, 5 p.m. and 27, July 29, 6 p.m. to Cairo.<note n="29"
                        xml:id="d682fn29">For texts, see telegram No. 1359, <hi rend="italic"
                            >supra</hi>.</note> You are instructed to make request jointly and in
                    other respects as you suggest.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
