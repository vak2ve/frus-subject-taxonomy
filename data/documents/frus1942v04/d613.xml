<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1942-09-24T22:00:00-05:00" frus:doc-dateTime-min="1942-09-24T22:00:00-05:00" n="613" subtype="historical-document" type="document" xml:id="d613">
                        <note rend="inline" type="source">852.711/108: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé at Tangier</hi> (<persName type="to"><hi rend="italic">Childs</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1942-09-24T23:00:00-04:00">September
                                    24, 1942—11 p.m.</date>
                            </dateline>
                        </opener>
                        <p>173. Your despatch 1005, August 27. Department approves the action
                            suggested in your penultimate paragraph.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
