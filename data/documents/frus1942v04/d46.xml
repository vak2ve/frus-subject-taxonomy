<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1942-06-06T09:00:00-05:00" frus:doc-dateTime-min="1942-06-06T09:00:00-05:00" n="46" subtype="historical-document" type="document" xml:id="d46">
                        <note rend="inline" type="source">124.90H/78: Telegram</note>
                        <head>
                            <hi rend="italic">The Chargé in Afghanistan</hi> (<persName type="from"><hi rend="italic">Thayer</hi></persName>)<note n="7" xml:id="d46fn7">Thayer had arrived at Kabul on May 31.</note>
                            <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Kabul</hi></placeName>, <date calendar="gregorian" when="1942-06-06T18:00:00+04:00">June 6,
                                    1942—6 p.m.</date>
                                <lb/> [Received June 30—9:49 a.m.<note n="8" xml:id="d46fn8">Reason
                                    for this delayed receipt not apparent from available
                                    documents.</note>]</dateline>
                        </opener>
                        <p>7. The Legation at Kabul has been opened today. Repeated to Calcutta,
                            Karachi, Tehran, Ankara and Kuibyshev.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Thayer</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>