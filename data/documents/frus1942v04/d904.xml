<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1942-07-08T19:00:00-05:00" frus:doc-dateTime-min="1942-07-08T19:00:00-05:00" n="904" subtype="historical-document" type="document" xml:id="d904">
                        <note rend="inline" type="source">811.248/603: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Turkey</hi> (<persName type="to"><hi rend="italic">Steinhardt</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1942-07-08T20:00:00-04:00">July 8,
                                    1942—8 p.m.</date>
                            </dateline>
                        </opener>
                        <p>325. Your 663, June 25, 2 p.m. Would appreciate information regarding
                            present status of your negotiations regarding bombers.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>