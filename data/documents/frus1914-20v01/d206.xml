<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-03-01T23:59:59-05:00" frus:doc-dateTime-min="1916-03-01T00:00:00-05:00" n="206" subtype="historical-document" type="document" xml:id="d206">
                        <note rend="inline" type="source">763.72111 Ap 4/48½</note>
                        <head>
                            <hi rend="italic">President <persName type="from">Wilson</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-03-01">
                                    <hi rend="italic">1 March, 1916</hi>.</date>
                            </dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Secretary</hi>: I have looked this
                            paper through very carefully, and do not see how we could have taken any
                            other position.</p>
                        <p>I return the papers to you at once, as you requested.</p>
                        <p>Faithfully Yours,</p>
                        <closer>
                            <signed>W. W.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>