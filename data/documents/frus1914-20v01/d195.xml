    <text>
        <body>
            <div frus:doc-dateTime-max="1915-04-10T23:59:59-05:00"
                frus:doc-dateTime-min="1915-04-10T00:00:00-05:00" n="195"
                subtype="historical-document" type="document" xml:id="d195">
                <note rend="inline" type="source">763.72111/2082</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        President <persName type="to">Wilson</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-04-10">
                            <hi rend="italic">April 10, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. President</hi>: I enclose a reply to the German
                    Ambassador relative to the refusal to clear the German steamship <hi
                        rend="italic">Pisa</hi>.<note n="58" xml:id="d195fn1">For the reply as sent,
                        see <ref target="frus1915Supp#pg_861">
                            <hi rend="italic">Foreign Relations</hi>, 1915, supp., p.
                        861</ref>.</note> If it meets with your approval kindly return it to me for
                    transmittal.</p>
                <p>Very sincerely yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
