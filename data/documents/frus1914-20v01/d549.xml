<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-01-04T23:59:59-05:00" frus:doc-dateTime-min="1917-01-04T00:00:00-05:00" n="549" subtype="historical-document" type="document" xml:id="d549">
                        <note rend="inline" type="source">763.72/3106½</note>
                        <head>
                            <hi rend="italic">President <persName type="from">Wilson</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-01-04">
                                    <hi rend="italic">4 January, 1917</hi>.</date>
                            </dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Secretary</hi>: Let me thank you for
                            the enclosed,<note n="72" xml:id="d549fn1">
                                <hi rend="italic">Supra</hi>.</note> which I return for your files.
                            The information about the U–boats makes painfully interesting
                            reading.</p>
                        <p>Faithfully Yours,</p>
                        <closer>
                            <signed>W. W.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>