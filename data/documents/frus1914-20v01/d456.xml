                subtype="historical-document" type="document" xml:id="d456">
                <note rend="inline" type="source">763.72/2327½a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        German Ambassador</hi> (<persName type="to">
                        <hi rend="italic">Bernstorff</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-12-15">
                            <hi rend="italic">December 15, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Ambassador</hi>: I have been hoping to hear
                    from you in regard to the <hi rend="italic">Lusitania</hi> affair. I feel that
                    continued delay in reaching an agreement in this matter may precipitate a
                    situation which both of us would seriously regret. I trust that you can give me
                    an indication as to the attitude of your Government upon the formula which we
                    considered sometime ago.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
