<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-01-24T23:59:59-05:00" frus:doc-dateTime-min="1917-01-24T00:00:00-05:00" n="89" subtype="historical-document" type="document" xml:id="d89">
                        <note rend="inline" type="source">702.6211/267½</note>
                        <head>
                            <hi rend="italic">President <persName type="from">Wilson</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-01-24">
                                    <hi rend="italic">24 January, 1917</hi>.</date>
                            </dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Secretary</hi>: I hope I may say
                            without impropriety that I have signed the enclosed with real
                                pleasure.<note n="35" xml:id="d89fn1">See <hi rend="italic">supra</hi>
                            </note>
                        </p>
                        <p>Faithfully Yours,</p>
                        <closer>
                            <signed>W. W.</signed>
                        </closer>
                    </div>
                </body></text></TEI>