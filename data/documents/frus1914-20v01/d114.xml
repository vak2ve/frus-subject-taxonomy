    <text>
        <body>
            <div frus:doc-dateTime-max="1915-04-19T23:59:59-05:00"
                frus:doc-dateTime-min="1915-04-19T00:00:00-05:00" n="114"
                subtype="historical-document" type="document" xml:id="d114">
                <note rend="inline" type="source">763.72111/1930</note>
                <head>
                    <hi rend="italic">President <persName type="from">Wilson</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-04-19">
                            <hi rend="italic">19 April, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: Here is my try at a note in
                    reply to Bernstorff.<note n="18" xml:id="d114fn1">Enclosed draft note not
                        printed.</note> Please let me know what you and Lansing think of it. I shall
                    be at my desk again on Wednesday and we might finish this at that time.</p>
                <p>I enclose the other, earlier, papers in the case.</p>
                <p>Faithfully Yours,</p>
                <closer>
                    <signed>W. W.</signed>
                </closer>
            </div>
        </body>
    </text>
