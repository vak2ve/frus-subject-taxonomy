<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-01-10T23:59:59-05:00" frus:doc-dateTime-min="1916-01-10T00:00:00-05:00" n="294" subtype="historical-document" type="document" xml:id="d294">
                        <note rend="inline" type="source">763.72/2352½</note>
                        <head>
                            <hi rend="italic">President <persName type="from">Wilson</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1916-01-10">
                                    <hi rend="italic">10 January, 1916</hi>.</date>
                            </dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Secretary</hi>: This seems to me
                            reasonable, and thoroughly worth trying.</p>
                        <p>Faithfully Yours,</p>
                        <closer>
                            <signed>W.W.</signed>
                        </closer>
                    </div>
