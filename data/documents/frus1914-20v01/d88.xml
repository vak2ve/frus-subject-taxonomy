    <text>
        <body>
            <div frus:doc-dateTime-max="1917-01-22T23:59:59-05:00"
                frus:doc-dateTime-min="1917-01-22T00:00:00-05:00" n="88"
                subtype="historical-document" type="document" xml:id="d88">
                <note rend="inline" type="source">702.6211/265c</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to President
                            <persName type="to">Wilson</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-01-22">
                            <hi rend="italic">January 22, 1917</hi>.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. President</hi>: I am sending you herewith for
                    your signature, the formal revocation and annulment of the exequatur issued to
                    Mr. Franz Bopp as Consul General of Germany at San Francisco.<note n="34"
                        xml:id="d88fn1">For correspondence previously printed concerning this case,
                        see <ref target="frus1916Supp#pg_597">
                            <hi rend="italic">ibid.</hi>, 1917, supp. 1, pp. 597 ff</ref>.</note>
                </p>
                <p>With assurances [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
