    <text>
        <body>
            <div frus:doc-dateTime-max="1915-12-20T23:59:59-05:00"
                frus:doc-dateTime-min="1915-12-20T00:00:00-05:00" n="461"
                subtype="historical-document" type="document" xml:id="d461">
                <note rend="inline" type="source">763.72/2328½</note>
                <head>
                    <hi rend="italic">The German Ambassador</hi> (<persName type="from">
                        <hi rend="italic">Bernstorff</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">J. No. A 8326</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-12-20">
                            <hi rend="italic">December 20, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: With reference to previous
                    correspondence I beg to inform you that according to a wireless message I
                    received today, my Government has mailed explicit instructions to me which it
                    hopes will lead to an amicable settlement of the <hi rend="italic"
                        >Lusitania</hi> case.</p>
                <p>I remain [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">J. Bernstorff</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
