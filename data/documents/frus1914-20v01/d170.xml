                subtype="historical-document" type="document" xml:id="d170">
                <note rend="inline" type="source">763.72111/1333½</note>
                <head>
                    <hi rend="italic">President <persName type="from">Wilson</persName> to the
                        Counselor for the Department of State</hi> (<persName type="to">
                        <hi rend="italic">Lansing</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-12-14">
                            <hi rend="italic">December 14, 1914</hi>.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Lansing</hi>: Thank you very warmly for the
                    trouble you have taken in sending a full reply to my inquiry about the telegram
                    from Messrs. Fuller, Tracy, and Coudert. I now feel fully fortified in the
                    matter.</p>
                <p>Cordially and faithfully yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Woodrow Wilson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
