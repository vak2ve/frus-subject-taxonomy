                subtype="historical-document" type="document" xml:id="d149">
                <note rend="inline" type="source">811.51/2624a</note>
                <head>
                    <hi rend="italic">President <persName type="from">Wilson</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-09-08">
                            <hi rend="italic">8 September, 1915</hi>.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: I have no doubt that our oral
                    discussion of this matter yesterday suffices. If it does not, will you let me
                    know that you would like a written reply?</p>
                <p>Faithfully Yours,</p>
                <closer>
                    <signed>W. W.</signed>
                </closer>
            </div>
        </body>
    </text>
