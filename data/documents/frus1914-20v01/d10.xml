                subtype="historical-document" type="document" xml:id="d10">
                <note rend="inline" type="source">763.72119/35½</note>
                <head>
                    <hi rend="italic">The Acting <gloss type="from">Secretary of State</gloss> to
                        President <persName type="to">Wilson</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-09-18">
                            <hi rend="italic">September 18, 1914</hi>.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. President</hi>: I beg to acknowledge your note
                    of the 17th instant enclosing a copy of a despatch from the Imperial Chancellor
                    of Germany regarding proposals of peace. My judgment is the same as yours that
                    the despatch needs for the present no reply.</p>
                <p>Respectfully yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
