                <note rend="inline" type="source">763.72/2833½</note>
                <head>
                    <hi rend="italic">President <persName type="from">Wilson</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-07-27">
                            <hi rend="italic">27 July, 1916</hi>.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: Thank you for letting me see
                    this letter from Penfield. He always says something that it is useful to keep in
                    mind.</p>
                <p>Faithfully yours,</p>
                <closer>
                    <signed>W. W.</signed>
                </closer>
            </div>
        </body>
