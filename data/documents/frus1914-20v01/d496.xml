    <text>
        <body>
            <div frus:doc-dateTime-max="1916-02-02T20:07:00-05:00"
                frus:doc-dateTime-min="1916-02-02T20:07:00-05:00" n="496"
                subtype="historical-document" type="document" xml:id="d496">
                <note rend="inline" type="source">763.72/2389½: Telegram</note>
                <head>
                    <hi rend="italic">President <persName type="from">Wilson</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Kansas City, Mo.</hi>
                        </placeName>, <date calendar="gregorian" when="1916-02-02T19:07:00-06:00">
                            <hi rend="italic">February 2, 1916—7:07 p. m.</hi>
                        </date>
                        <lb/> [Received 10:30 p. m.]</dateline>
                </opener>
                <p>Your letter of January 31st received. Please frame and send message you suggest
                    explaining the point at issue.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Woodrow Wilson</hi>
                    </signed>
                </closer>
            </div>
        </body>
