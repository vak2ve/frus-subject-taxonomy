<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-12-31T23:59:59-05:00" frus:doc-dateTime-min="1915-12-31T00:00:00-05:00" n="475" subtype="historical-document" type="document" xml:id="d475">
                        <note rend="inline" type="source">865.857 An 2/111½</note>
                        <head>
                            <hi rend="italic">President <persName type="from">Wilson</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Hot Springs, Va.</hi></placeName>, <date calendar="gregorian" when="1915-12-31">
                                    <hi rend="italic">31 December, 1915</hi>.</date>
                            </dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Secretary</hi>: This does indeed afford
                            us something more than a ray of hope for a satisfactory settlement, and
                            my mind is, at any rate for the time being, much relieved.</p>
                        <p>Faithfully Yours,</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Woodrow Wilson</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>