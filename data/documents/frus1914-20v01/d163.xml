<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-10-28T23:59:59-05:00" frus:doc-dateTime-min="1914-10-28T00:00:00-05:00" n="163" subtype="historical-document" type="document" xml:id="d163">
                        <note rend="inline" type="source">763.72112/287½</note>
                        <head>
                            <hi rend="italic">President <persName type="from">Wilson</persName> to
                                the <gloss type="to">Acting Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1914-10-28">
                                    <hi rend="italic">October 28, 1914</hi>.</date>
                            </dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Lansing</hi>: Thank you for having let
                            me see the enclosed campaign sheet.<note n="11" xml:id="d163fn1">The
                                article referred to in the preceding document.</note> It is not,
                            however worthy of attention.</p>
                        <p>Cordially and faithfully yours,</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Woodrow Wilson</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>