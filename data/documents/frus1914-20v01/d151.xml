<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-09-15T23:59:59-05:00" frus:doc-dateTime-min="1915-09-15T00:00:00-05:00" n="151" subtype="historical-document" type="document" xml:id="d151">
                        <note rend="inline" type="source">811.51/2624</note>
                        <head>
                            <hi rend="italic">President <persName type="from">Wilson</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-09-15">
                                    <hi rend="italic">15 September, 1915</hi>.</date>
                            </dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Secretary</hi>: This is a most
                            extraordinary letter.<note n="21" xml:id="d151fn1">
                                <hi rend="italic">Supra</hi>.</note> I am sure you know how to
                            handle it. I am much obliged to you for letting me see it.</p>
                        <p>Faithfully Yours,</p>
                        <closer>
                            <signed>W. W.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>