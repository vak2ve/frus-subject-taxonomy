<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-11-17T23:59:59-05:00" frus:doc-dateTime-min="1915-11-17T00:00:00-05:00" n="199" subtype="historical-document" type="document" xml:id="d199">
                        <note rend="inline" type="source">763.72111/3139</note>
                        <head>
                            <hi rend="italic">President <persName type="from">Wilson</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-11-17">
                                    <hi rend="italic">17 November, 1915</hi>.</date>
                            </dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Secretary</hi>: I think this reply to
                            the German Ambassador altogether the right one, and take pleasure in
                            returning it with my entire approval.</p>
                        <p>Faithfully Yours,</p>
                        <closer>
                            <signed>W. W.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>