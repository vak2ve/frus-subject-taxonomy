    <text>
        <body>
            <div frus:doc-dateTime-max="1916-06-21T23:59:59-05:00"
                frus:doc-dateTime-min="1916-06-21T00:00:00-05:00" n="614"
                subtype="historical-document" type="document" xml:id="d614">
                <note rend="inline" type="source">763.72/2804½</note>
                <head>
                    <hi rend="italic">President <persName type="from">Wilson</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-06-21">
                            <hi rend="italic">21 June, 1916</hi>.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: Thank you very much for having
                    let me see the enclosed very interesting letter.<note n="3" xml:id="d614fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_655">p. 655</ref>.</note> I
                    dare say that it is now very much out of date because of the Russian successes
                    and of the altered aspect of the fight in the North Sea.</p>
                <p>Faithfully Yours,</p>
                <closer>
                    <signed>W. W.</signed>
                </closer>
            </div>
        </body>
    </text>
