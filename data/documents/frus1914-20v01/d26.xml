    <text>
        <body>
            <div frus:doc-dateTime-max="1914-08-27T23:59:59-05:00"
                frus:doc-dateTime-min="1914-08-27T00:00:00-05:00" n="26"
                subtype="historical-document" type="document" xml:id="d26">
                <note rend="inline" type="source">763.72111/82½</note>
                <head>
                    <hi rend="italic">President <persName type="from">Wilson</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1914-08-27">
                            <hi rend="italic">August 27, 1914</hi>.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: Thank you sincerely for having
                    let me see the enclosed memorandum.<note n="1" xml:id="d26fn1">Memorandum by the
                        Counselor for the Department of State, <hi rend="italic">supra</hi>.</note>
                    I think that Mr. Lansing handled the matter in exactly the right way.</p>
                <p>Faithfully yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Woodrow Wilson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
