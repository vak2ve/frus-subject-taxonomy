<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1914-10-13T23:59:59-05:00" frus:doc-dateTime-min="1914-10-13T00:00:00-05:00" n="103" subtype="historical-document" type="document" xml:id="d103">
                        <note rend="inline" type="source">763.72112/134½</note>
                        <head>
                            <hi rend="italic">President <persName type="from">Wilson</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1914-10-13">
                                    <hi rend="italic">October 13, 1914</hi>.</date>
                            </dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Secretary</hi>: Mr. Lansing was kind
                            enough to submit the enclosed to me.<note n="2" xml:id="d103fn1">
                                <hi rend="italic">Supra</hi>.</note> I return it with the assurance
                            that I think it is desirable that such a statement should be issued, and
                            this statement seems to me excellent.</p>
                        <p>Cordially and faithfully yours,</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Woodrow Wilson</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>