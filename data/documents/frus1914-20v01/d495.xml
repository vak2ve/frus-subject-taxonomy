                subtype="historical-document" type="document" xml:id="d495">
                <note rend="inline" type="source">763.72/2364: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Germany</hi> (<persName type="to">
                        <hi rend="italic">Gerard</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-01-31T10:00:00-05:00">
                            <hi rend="italic">January 31, 1916—10 a. m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>2661. Your 4008 [<hi rend="italic">3408</hi>].<note n="13" xml:id="d495fn1">
                        <ref target="frus1916Supp#pg_153">
                            <hi rend="italic">Foreign Relations</hi>, 1916, supp., p.
                        153</ref>.</note> Offer no encouragement that the suggested statement would
                    be at all acceptable. It has already been several times submitted to this
                    Government. Will advise you later.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
