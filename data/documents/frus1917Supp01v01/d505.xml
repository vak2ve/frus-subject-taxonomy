<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-10-19T14:00:00-05:00" frus:doc-dateTime-min="1917-10-19T14:00:00-05:00" n="505" subtype="historical-document" type="document" xml:id="d505">
                            <note rend="inline" type="source">File No. 763.72/7338</note>
                            <head>
                                <hi rend="italic">The Chargé in Colombia</hi> (<persName corresp="#p_BP1" type="from"><hi rend="italic">Belden</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1917-10-19T14:00:00-05:00">
                                        <hi rend="italic">October 19, 1917, 2 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received October 20, 12.35
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>Colombian Senate has passed resolution protesting against submarine
                                warfare.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_BP1">
                                        <hi rend="smallcaps">Belden</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>