                subtype="historical-document" type="document" xml:id="d862">
                <note rend="inline" type="source">File No. 124.63/12a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Spain</hi> (<persName corresp="#p_WJE1" type="to">
                        <hi rend="italic">Willard</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-02-04T14:00:00-05:00">
                            <hi rend="italic">February 4, 1917, 2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>210. Inquire of Spanish Government whether they would take charge of the
                    interests of this Government in Austria-Hungary in the event of severance of
                    relations between Austria-Hungary and the United States.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
