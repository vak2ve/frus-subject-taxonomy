<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-02-27T05:00:00-05:00" frus:doc-dateTime-min="1917-02-27T05:00:00-05:00" n="166" subtype="historical-document" type="document" xml:id="d166">
                        <note rend="inline" type="source">File No. 300.115L98/13</note>
                        <head>
                            <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName corresp="#p_PFC1" type="from"><hi rend="italic">Penfield</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Vienna</hi></placeName>, <date calendar="gregorian" when="1917-02-27T11:00:00+01:00">
                                    <hi rend="italic">February 27, 1917, 11 a.m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received 9 p.m.</hi>]</dateline>
                        </opener>
                        <p>1729. In informal conference to-day with Minister for Foreign Affairs he
                            stated that American sailing ship <hi rend="italic">Lyman M. Law</hi>
                            was not sunk by Austro-Hungarians.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_PFC1">
                                    <hi rend="smallcaps">Penfield</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>