    <text>
        <body>
            <div frus:doc-dateTime-max="1917-05-21T23:59:59-05:00"
                frus:doc-dateTime-min="1917-05-21T00:00:00-05:00" n="720"
                subtype="historical-document" type="document" xml:id="d720">
                <note rend="inline" type="source">File No. 300.115/12464</note>
                <head>
                    <hi rend="italic">The British Ambassador</hi> (<persName corresp="#p_SRSCA1"
                        type="from">
                        <hi rend="italic">Spring Rice</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 146</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-05-21">
                            <hi rend="italic">May 21, 1917</hi>
                        </date>. <lb/> [<hi rend="italic">Received May 23.</hi>]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honour to inform you that His
                    Majesty’s Government have given instructions to His Majesty’s Consul General at
                        <pb facs="0685" n="513" xml:id="pg_513"/> Rotterdam that all permits which
                    were issued for the release of American goods of German origin and which lapsed
                    owing to difficulties of finding shipping space have now been renewed.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SRSCA1">
                            <hi rend="smallcaps">Cecil Spring Rice</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
