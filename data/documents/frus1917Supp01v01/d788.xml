<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-02-13T21:20:00-05:00" frus:doc-dateTime-min="1917-02-12T00:00:00-05:00" n="788" subtype="historical-document" type="document" xml:id="d788">
                        <note rend="inline" type="source">File No. 763.72111/4515</note>
                        <head>
                            <hi rend="italic">The Governor of the Hawaiian Islands</hi> (<persName type="from"><hi rend="italic">Pinkham</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Honolulu</hi></placeName>, <date ana="#date_undated-inferred-from-document-content-and-sibling-dates" calendar="gregorian" notAfter="1917-02-13T21:20:00-05:00" notBefore="1917-02-12T00:00:00-05:00"><hi rend="italic">undated</hi></date>. <lb/> [<hi rend="italic">Received
                                    February 13, 1917, 9.20 p.m.</hi>]</dateline>
                        </opener>
                        <p>All transactions of local representatives have been respectively reported
                            Treasury, Justice, Immigration, War, and Navy Departments, Washington.
                            The policy you specify is being carried out.</p>
                        <closer>
                            <signed>
                                <persName>
                                    <hi rend="smallcaps">Pinkham</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>