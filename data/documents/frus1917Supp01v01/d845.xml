<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-02-04T18:00:00-05:00" frus:doc-dateTime-min="1917-02-04T18:00:00-05:00" n="845" subtype="historical-document" type="document" xml:id="d845">
                            <note rend="inline" type="source">File No. 124.62/18</note>
                            <head>
                                <hi rend="italic">The Ambassador in Spain</hi> (<persName corresp="#p_WJE1" type="from"><hi rend="italic">Willard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Madrid</hi></placeName>, <date calendar="gregorian" when="1917-02-04T23:00:00+00:00">
                                        <hi rend="italic">February 4, 1917, 11 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received February 5, 7.20
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>327. Department’s telegram 209, February 3, 1 p.m. Spain accedes
                                gratefully to Department’s request therein expressed and has
                                accordingly telegraphed Spanish Ambassador in Berlin.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_WJE1">
                                        <hi rend="smallcaps">Willard</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>