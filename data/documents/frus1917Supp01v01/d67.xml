<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-03-30T08:00:00-05:00" frus:doc-dateTime-min="1917-03-30T08:00:00-05:00" n="67" subtype="historical-document" type="document" xml:id="d67">
                            <note rend="inline" type="source">File No. 868.00/100</note>
                            <head>
                                <hi rend="italic">The Minister in Greece</hi> (<persName corresp="#p_DG1" type="from"><hi rend="italic">Droppers</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Athens</hi></placeName>, <date calendar="gregorian" when="1917-03-30T15:00:00+02:00">
                                        <hi rend="italic">March 30, 1917, 3 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received March 31, 6
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>285. Provisional Government Saloniki requests recognition by
                                Government of the United States with a view to sending accredited
                                agent <persName corresp="#p_WHL1">Washington</persName>.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_DG1">
                                        <hi rend="smallcaps">Droppers</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>