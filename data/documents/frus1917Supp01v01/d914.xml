                <note rend="inline" type="source">File No. 124.55/9</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Belgium</hi> (<persName corresp="#p_WB1" type="to">
                        <hi rend="italic">Whitlock</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-03-02T20:00:00-05:00">
                            <hi rend="italic">March 2, 1917, 8 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>264. Your 45. Obtain assurances in writing from German authorities that the
                    American members of the commission may leave Belgium when they desire.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
