<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-02-07T08:00:00-05:00" frus:doc-dateTime-min="1917-02-07T08:00:00-05:00" n="820" subtype="historical-document" type="document" xml:id="d820">
                            <note rend="inline" type="source">File No. 701.6211/408</note>
                            <head>
                                <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_SWG1" type="from"><hi rend="italic">Sharp</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1917-02-07T13:00:00+00:00">
                                        <hi rend="italic">February 7, 1917, 1 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 6.30 p.m.</hi>]</dateline>
                            </opener>
                            <p>1854. My 1853.<note n="3" xml:id="d820fn3">Not printed.</note>
                                Foreign Office informs me that it will accord safe-conduct to German
                                Ambassador and party.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_SWG1">
                                        <hi rend="smallcaps">Sharp</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>