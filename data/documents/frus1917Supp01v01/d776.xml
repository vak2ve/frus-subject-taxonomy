<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-03-17T10:00:00-05:00" frus:doc-dateTime-min="1917-03-17T10:00:00-05:00" n="776" subtype="historical-document" type="document" xml:id="d776">
                        <note rend="inline" type="source">File No. 763.72/3530</note>
                        <head>
                            <hi rend="italic">The Minister in Sweden</hi> (<persName corresp="#p_MIN1" type="from"><hi rend="italic">Morris</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Stockholm</hi></placeName>, <date calendar="gregorian" when="1917-03-17T16:00:00+01:00">
                                    <hi rend="italic">March 17, 1917, 4 p.m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received March 18, 9 a.m.</hi>]</dateline>
                        </opener>
                        <p>231. Since German blockade proclaimed Norwegian Government permitting
                            armed British merchant vessels to enter and depart from the Norwegian
                            ports.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_MIN1">
                                    <hi rend="smallcaps">Morris</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>