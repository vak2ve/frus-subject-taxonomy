                subtype="historical-document" type="document" xml:id="d496">
                <note rend="inline" type="source">File No. 763.72/7151</note>
                <head>
                    <hi rend="italic">The Consul General at Lima</hi> (<persName corresp="#p_HWW1"
                        type="from">
                        <hi rend="italic">Handley</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1917-10-06T14:00:00-05:00">
                            <hi rend="italic">October 6, 1917, 2 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 9.10 p.m.</hi>]</dateline>
                </opener>
                <p>Minister for Foreign Affairs for Peru has telegraphed Peruvian-Minister at
                    [Berlin] to demand his passport and to turn over Peruvian interests to the
                    Minister of Spain German Minister at Lima given his passport October 6, 12 noon,
                    and will probably proceed to Chile.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HWW1">
                            <hi rend="smallcaps">Handley</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
