<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-02-05T23:59:59-05:00" frus:doc-dateTime-min="1917-02-05T00:00:00-05:00" n="106" subtype="historical-document" type="document" xml:id="d106">
                            <note rend="inline" type="source">File No. 841.857/313</note>
                            <head>
                                <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1917-02-05">
                                        <hi rend="italic">February 5, 1917</hi></date>. <lb/> [<hi rend="italic">Received 9.15 p.m.</hi>]</dateline>
                            </opener>
                            <p>5607. I am informed by the Official Press Bureau that British ship
                                    <hi rend="italic">Eavestone, en route</hi> Newport News to
                                Liverpool, was to-day <pb facs="0287" n="115" xml:id="pg_115"/>
                                shelled by German submarine; men took to boats and submarine
                                continued shelling; captain and three seamen killed while in small
                                boats, one of latter being American citizen, <persName>Richard
                                    Wallace</persName> of Baltimore.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_PWH1">
                                        <hi rend="smallcaps">Page</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>