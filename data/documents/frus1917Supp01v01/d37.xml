    <text>
        <body>
            <div frus:doc-dateTime-max="1917-02-10T11:00:00-05:00"
                frus:doc-dateTime-min="1917-02-10T11:00:00-05:00" n="37"
                subtype="historical-document" type="document" xml:id="d37">
                <note rend="inline" type="source">File No. 763.72/3290</note>
                <head>
                    <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="from">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1917-02-10T17:00:00+01:00">
                            <hi rend="italic">February 10, 1917, 5 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received February 11, 3.30 p.m.</hi>]</dateline>
                </opener>
                <p>1700. German Kaiser expected to come to Vienna to-night for two days’ conference
                    with Emperor. Newspapers forbidden to announce visit.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
