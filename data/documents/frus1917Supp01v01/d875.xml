    <text>
        <body>
            <div frus:doc-dateTime-max="1917-02-03T17:00:00-05:00"
                frus:doc-dateTime-min="1917-02-03T17:00:00-05:00" n="875"
                subtype="historical-document" type="document" xml:id="d875">
                <note rend="inline" type="source">File No. 704.6200/17a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)<note n="1" xml:id="d875fn1">The same, with appropriate references,
                        to the diplomatic representatives in France, Greece, Japan, Portugal,
                        Roumania, Morocco, Russia, and Egypt.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Circular Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-02-03T17:00:00-05:00">
                            <hi rend="italic">February 3, 1917, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Department’s 4385, February 3, 2 p.m. Suspend all activities on behalf of Germany
                    until further instructions from Department or information is received from other
                    sources indicating which country will be entrusted with German interests.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
