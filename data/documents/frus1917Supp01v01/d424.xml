    <text>
        <body>
            <div frus:doc-dateTime-max="1917-06-15T16:44:00-05:00"
                frus:doc-dateTime-min="1917-06-15T16:44:00-05:00" n="424"
                subtype="historical-document" type="document" xml:id="d424">
                <note rend="inline" type="source">File No. 763.72/5336</note>
                <head>
                    <hi rend="italic">The Minister in Uruguay</hi> (<persName corresp="#p_JRE1"
                        type="from">
                        <hi rend="italic">Jeffery</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Montevideo</hi>
                        </placeName>, <date calendar="gregorian" when="1917-06-15T18:00:00-03:44">
                            <hi rend="italic">June 15, 1917, 6 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received June 16, 2 a.m.</hi>]</dateline>
                </opener>
                <p>Uruguayan Minister for Foreign Affairs authorizes me to say to Department of
                    State that all ships of the American Navy, of any kind whatsoever, may now and
                    henceforth visit the ports of Uruguay, for any purpose whatsoever, where they
                    will be received as friend, and not as belligerent, and without
                    restrictions.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_JRE1">
                            <hi rend="smallcaps">Jeffery</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
