                subtype="historical-document" type="document" xml:id="d548">
                <note rend="inline" type="source">File No. 763.72119/955</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName corresp="#p_MEV1"
                        type="from">
                        <hi rend="italic">Morgan</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1917-11-23T19:00:00-03:00">
                            <hi rend="italic">November 23, 1917, 7 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received November 24, 1.55 a.m.</hi>]</dateline>
                </opener>
                <p>Brazilian Minister for Foreign Affairs wishes to prevent proposed Latin-American
                    congress, or, if this proves impossible, to <pb facs="0546" n="374"
                        xml:id="pg_374"/> impose the condition that acceptance of invitation depends
                    upon? acceptance of principle that relations with Germany shall be broken. He
                    approves Peru’s attitude and is encouraging Bolivia to follow.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MEV1">
                            <hi rend="smallcaps">Morgan</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
