    <text>
        <body>
            <div frus:doc-dateTime-max="1917-04-10T23:59:59-05:00"
                frus:doc-dateTime-min="1917-04-10T00:00:00-05:00" n="867"
                subtype="historical-document" type="document" xml:id="d867">
                <note rend="inline" type="source">File No. 705.6358/1</note>
                <head>
                    <hi rend="italic">The Swedish Minister</hi> (<persName corresp="#p_EWAF1"
                        type="from">
                        <hi rend="italic">Ekengren</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-10">
                            <hi rend="italic">April 10, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Your Excellency</hi>: I herewith have the honor to bring to
                    your excellency’s knowledge that I have to-day been instructed by my Government
                    to assume charge of the Austro-Hungarian interests in the United States, and
                    that I have accordingly taken over these interests.</p>
                <p>With renewed assurances [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_EWAF1">
                            <hi rend="smallcaps">W. A. F. Ekengren</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
