<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-04-20T06:00:00-05:00" frus:doc-dateTime-min="1917-04-20T06:00:00-05:00" n="831" subtype="historical-document" type="document" xml:id="d831">
                            <note rend="inline" type="source">File No. 701.6311/281</note>
                            <head>
                                <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_SWG1" type="from"><hi rend="italic">Sharp</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1917-04-20T12:00:00+01:00">
                                        <hi rend="italic">April 20, 1917, noon</hi></date>. <lb/>
                                        [<hi rend="italic">Received 2.40 p.m.</hi>]</dateline>
                            </opener>
                            <p>2031. Your 2166, April 16, 4 p.m.<note n="1" xml:id="d831fn1">Not
                                    printed.</note> Foreign Office has just verbally given me
                                assurances that safe-conduct will be accorded to the steamer on
                                which Austro-Hungarian diplomats and consuls and German consuls from
                                China embark.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_SWG1">
                                        <hi rend="smallcaps">Sharp</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>