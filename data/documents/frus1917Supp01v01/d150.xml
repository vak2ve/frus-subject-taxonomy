<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-02-21T23:59:59-05:00" frus:doc-dateTime-min="1917-02-21T00:00:00-05:00" n="150" subtype="historical-document" type="document" xml:id="d150">
                            <note rend="inline" type="source">File No. 851.857/55</note>
                            <head>
                                <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1917-02-21">
                                        <hi rend="italic">February 21, 1917</hi></date>. <lb/> [<hi rend="italic">Received 7.45 p.m.</hi>]</dateline>
                            </opener>
                            <p>5732. Consul, Southampton, is forwarding to Department affidavit of
                                four seamen, <persName>George Goldrainer</persName>, <persName>Fred
                                    O’Neill</persName>, <persName>Clarence Barrett</persName>, <pb facs="0314" n="142" xml:id="pg_142"/>
                                <persName>Edward Staples</persName>, claiming American citizenship,
                                members crew French sailing ship <hi rend="italic">Bayonne</hi>,
                                from New York, December 28, for England, cargo wheat. Submarine
                                signaled ship stop February 17, 4.30 afternoon, 25 miles off
                                starting point; crew took to boats, weather calm, foggy. Submarine
                                of German nationality took provisions from ship and blew her up.
                                Germans provisioned ship’s boats, lights of five steamers visible,
                                crew reached land in 17 hours. <hi rend="italic">Bayonne</hi> did
                                not attempt escape or resist.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_PWH1">
                                        <hi rend="smallcaps">Page</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>