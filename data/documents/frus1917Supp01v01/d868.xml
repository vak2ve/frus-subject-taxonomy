    <text>
        <body>
            <div frus:doc-dateTime-max="1917-04-23T23:59:59-05:00"
                frus:doc-dateTime-min="1917-04-23T00:00:00-05:00" n="868"
                subtype="historical-document" type="document" xml:id="d868">
                <note rend="inline" type="source">File No. 705.6358/1</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Swedish Minister</hi> (<persName corresp="#p_EWAF1" type="to">
                        <hi rend="italic">Ekengren</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-23">
                            <hi rend="italic">April 23, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of April 10, 1917, in which you state that you had been instructed on
                        <pb facs="0792" n="620" xml:id="pg_620"/> that day by your Government to
                    assume charge of the Austro-Hungarian interests in the United States and that
                    you have accordingly taken over those interests.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Robert Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
