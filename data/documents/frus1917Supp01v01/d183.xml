    <text>
        <body>
            <div frus:doc-dateTime-max="1917-03-05T23:59:59-05:00"
                frus:doc-dateTime-min="1917-03-05T00:00:00-05:00" n="183"
                subtype="historical-document" type="document" xml:id="d183">
                <note rend="inline" type="source">File No. 841.857/389</note>
                <head>
                    <hi rend="italic">The Consul at Liverpool</hi> (<persName corresp="#p_WHL1"
                        type="from">
                        <hi rend="italic">Washington</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Liverpool</hi>
                        </placeName>, <date calendar="gregorian" when="1917-03-05">
                            <hi rend="italic">March 5, 1917</hi>
                        </date>. <lb/> [<hi rend="italic">Received 10.80 a.m.</hi>]</dateline>
                </opener>
                <p>
                    <persName>Harold E. Burke</persName>, American citizen, residing 24 Holmes
                    Court, Portsmouth, N. H., affirms member crew British schooner. <hi
                        rend="italic">Mayola</hi>, St. John’s, Newfoundland-Alicante, Spain, cargo
                    fish, unarmed. German submarine commander, 4.15 p.m., February 16, ordered
                    abandon vessel, placed boinbs on board <hi rend="italic">Mayola</hi>. Crew in
                    palm sea, wind moderate, rowed 21 miles to Albufeira, Portugal. No other
                    Americans on board affidavit mailed.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WHL1">
                            <hi rend="smallcaps">Washington</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
