<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-05-01T13:16:00-05:00" frus:doc-dateTime-min="1917-05-01T13:16:00-05:00" n="367" subtype="historical-document" type="document" xml:id="d367">
                            <note rend="inline" type="source">File No. 763.72/4213</note>
                            <head>
                                <hi rend="italic">The Ambassador in Argentina</hi> (<persName corresp="#p_SFJ1" type="from"><hi rend="italic">Stimson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Buenos Aires</hi></placeName>, <date calendar="gregorian" when="1917-05-01T14:00:00-04:16">
                                        <hi rend="italic">May 1, 1917, 2 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 3.45 p.m.</hi>]</dateline>
                            </opener>
                            <p>Socialist party by close majorities voted yesterday against
                                intervention in the war, whereupon leaders resigned.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_SFJ1">
                                        <hi rend="smallcaps">Stimson</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>