<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-05-11T15:00:00-05:00" frus:doc-dateTime-min="1917-05-11T15:00:00-05:00" n="666" subtype="historical-document" type="document" xml:id="d666">
                            <note rend="inline" type="source">File No. 763.72/4458</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in Liberia</hi> (<persName corresp="#p_CJL1" type="to"><hi rend="italic">Curtis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-05-11T15:00:00-05:00">
                                        <hi rend="italic">May 11, 1917, 3 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Your May 7, 4 p.m. Definite instructions will be sent you after
                                conclusion consultation with British Government.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>