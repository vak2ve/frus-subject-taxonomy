    <text>
        <body>
            <div frus:doc-dateTime-max="1917-02-07T23:59:59-05:00"
                frus:doc-dateTime-min="1917-02-07T00:00:00-05:00" n="876"
                subtype="historical-document" type="document" xml:id="d876">
                <note rend="inline" type="source">File No. 704.6241/29</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1917-02-07">
                            <hi rend="italic">February 7, 1917</hi>
                        </date>. <lb/> [<hi rend="italic">Received 5 p.m.</hi>]</dateline>
                </opener>
                <p>5627. At the formal request of the Swiss Minister I have to-day turned over to
                    him the care of the German interests in this country pursuant to last clause of
                    your telegraphic circular instruction of February 3, 5 p.m.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
