<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-11-10T17:00:00-05:00" frus:doc-dateTime-min="1917-11-10T17:00:00-05:00" n="533" subtype="historical-document" type="document" xml:id="d533">
                            <note rend="inline" type="source">File No. 763.72111/6765</note>
                            <head>
                                <hi rend="italic">The Minister in Panama</hi> (<persName corresp="#p_PWJ1" type="from"><hi rend="italic">Price</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Panama</hi></placeName>, <date calendar="gregorian" when="1917-11-10T17:00:00-05:00">
                                        <hi rend="italic">November 10, 1917, 5 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 11 p.m.</hi>]</dateline>
                            </opener>
                            <p>Referring to my cable of October 29, 5 p.m.<note n="1" xml:id="d533fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_354">p.
                                    354</ref>.</note> Guatemala replies that it considers its
                                attitude defined by its breaking diplomatic relations <pb facs="0537" n="365" xml:id="pg_365"/> with the German Government
                                and declines to participate in conference.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_PWJ1">
                                        <hi rend="smallcaps">Price</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>