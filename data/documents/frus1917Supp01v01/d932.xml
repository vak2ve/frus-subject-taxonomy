                <note rend="inline" type="source">File No. 855.48/512</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Commission for Relief in Belgium</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-03-27">
                            <hi rend="italic">March 27, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>Your telegram received. Please inform London office, Department considers it
                    desirable that members of commission leave at once.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Robert Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
