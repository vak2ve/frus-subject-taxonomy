                subtype="historical-document" type="document" xml:id="d603">
                <note rend="inline" type="source">File No. 763.72/3270</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in China</hi> (<persName corresp="#p_RPS1" type="to">
                        <hi rend="italic">Reinsch</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-02-10T13:00:00-05:00">
                            <hi rend="italic">February 10, 1917, 1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Until further instructed avoid giving any promises or assurances and take no
                    other action in regard to matters mentioned in your cipher telegrams of February
                    6, 1 p.m. and 11 p.m., February 7, 6 p.m., and February 8, 12 midnight. Matter
                    under consideration.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
