<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-03-03T16:00:00-05:00" frus:doc-dateTime-min="1917-03-03T16:00:00-05:00" n="767" subtype="historical-document" type="document" xml:id="d767">
                        <note rend="inline" type="source">File No. 763.72/3421a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Denmark</hi> (<persName corresp="#p_EMF1" type="to"><hi rend="italic">Egan</hi></persName>)<note n="2" xml:id="d767fn2">The same, on the same date, to the diplomatic
                                representatives in Spain (No. 303), Norway (No. 86), Sweden (No.
                                137); and on Mar. 8, 10 a.m. to the representative in the
                                Netherlands (No. 431).</note>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-03-03T16:00:00-05:00">
                                    <hi rend="italic">March 3, 1917, 4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>268. Please ascertain officially and telegraph whether government to
                            which you are accredited prohibits the entrance and departure of
                            merchant vessels armed for defensive purposes.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>