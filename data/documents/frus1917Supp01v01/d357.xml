                subtype="historical-document" type="document" xml:id="d357">
                <note rend="inline" type="source">File No. 763.72/4084</note>
                <head>
                    <hi rend="italic">The Minister in Haiti</hi> (<persName corresp="#p_BBA1"
                        type="from">
                        <hi rend="italic">Bailly-Blanchard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-26T15:00:00-05:00">
                            <hi rend="italic">April 26, 1917, 3 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 6 p.m.</hi>]</dateline>
                </opener>
                <p>Pursuant to cable received from Minister <persName corresp="#p_MS1"
                        >Ménos</persName> stating that Department promised Haiti <hi rend="italic"
                        >appui convertible</hi>, Minister for Foreign <pb facs="0440" n="268"
                        xml:id="pg_268"/> Affairs called to ask this Legation to ascertain precisely
                    what support the United States would give to Haiti in the event of her declaring
                    war against the Imperial German Government. Respectfully urge early reply.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BBA1">
                            <hi rend="smallcaps">Blanchard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
