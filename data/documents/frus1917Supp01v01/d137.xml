<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-02-14T23:59:59-05:00" frus:doc-dateTime-min="1917-02-14T00:00:00-05:00" n="137" subtype="historical-document" type="document" xml:id="d137">
                            <note rend="inline" type="source">File No. 841.857/343</note>
                            <head>
                                <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1917-02-14">
                                        <hi rend="italic">February 14, 1917</hi></date>. <lb/> [<hi rend="italic">Received February 15, 9.40
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>5689. British sailing ship <hi rend="italic">Ainsdale</hi>, from
                                Buenos Ayres November 1 for England, stopped by submarine 180 miles
                                from Cape Clear, February 5; crew of 25 ordered into boats; ship
                                sunk; crew rescued after 10 hours; suffered great hardship. Consul,
                                Liverpool, forwarding affidavit only American member crew.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_PWH1">
                                        <hi rend="smallcaps">Page</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>