    <text>
        <body>
            <div frus:doc-dateTime-max="1917-11-13T18:00:00-05:00"
                frus:doc-dateTime-min="1917-11-13T18:00:00-05:00" n="536"
                subtype="historical-document" type="document" xml:id="d536">
                <note rend="inline" type="source">File No. 763.72/7757</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Panama</hi> (<persName corresp="#p_PWJ1" type="to">
                        <hi rend="italic">Price</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-11-13T18:00:00-05:00">
                            <hi rend="italic">November 13, 1917, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your April 7, 10 p.m.,<note n="1" xml:id="d536fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_245">p. 245</ref>.</note> and
                    November 7, 8 p.m.<note n="2" xml:id="d536fn2">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_363">p. 363</ref>.</note> In
                    view of these two telegrams a formal declaration of war is regarded as
                    practically unnecessary. For your information it is not deemed desirable that
                    Panama make a formal declaration of war.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
