<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-12-03T18:36:00-05:00" frus:doc-dateTime-min="1917-12-03T18:36:00-05:00" n="558" subtype="historical-document" type="document" xml:id="d558">
                            <note rend="inline" type="source">File No. 763.72119/980</note>
                            <head>
                                <hi rend="italic">The Ambassador in Mexico</hi> (<persName corresp="#p_FHP1" type="from"><hi rend="italic">Fletcher</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Mexico City</hi></placeName>, <date calendar="gregorian" when="1917-12-03T17:00:00-06:36">
                                        <hi rend="italic">December 3, 1917, 5 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received December 4, 3
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>600. My 552, November 8, 5 p.m.<note n="1" xml:id="d558fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_364">p.
                                    364</ref>.</note> The Mexican delegation to the Buenos Aires
                                conference is as follows: President and special delegate,
                                    <persName>Luis Cabrera</persName>; special delegate,
                                    <persName>Gerzayn Ugarte</persName>; secretaries, Deputies
                                    <persName>Flavio Perez Garza</persName> and <persName>Enrique
                                    Parra</persName>; military, Gen. <persName>Federico
                                    Montes</persName>; publicity secretary, <persName>Ernesto
                                    Hidalgo</persName>; and two clerks.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_FHP1">
                                        <hi rend="smallcaps">Fletcher</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>