<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-02-12T23:59:59-05:00" frus:doc-dateTime-min="1917-02-12T00:00:00-05:00" n="247" subtype="historical-document" type="document" xml:id="d247">
                        <note rend="inline" type="source">File No. 763.72111Y2/16</note>
                        <head>
                            <hi rend="italic">The Swiss Minister</hi> (<persName corresp="#p_RDP1" type="from"><hi rend="italic">Ritter</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-02-12">
                                    <hi rend="italic">February 12, 1917</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: Upon cable instructions from my
                            Government, dated February 11, I have the honor to transmit to the
                            American Government the following communication from the German
                            Government.</p>
                        <quote rend="blockquote">
                            <p>The immediate release of about 70 Americans, brought in as prisoners
                                of war by the steamer <hi rend="italic">Yarrowdale</hi>, is
                                conditional to the German vessels in American waters not being
                                seized and their crews not being interned.</p>
                        </quote>
                        <p>Accept [etc.]</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_RDP1">
                                    <hi rend="smallcaps">P. Ritter</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>