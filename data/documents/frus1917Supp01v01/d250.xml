<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-02-25T11:00:00-05:00" frus:doc-dateTime-min="1917-02-25T11:00:00-05:00" n="250" subtype="historical-document" type="document" xml:id="d250">
                        <note rend="inline" type="source">File No. 763.72111Y2/18</note>
                        <head>
                            <hi rend="italic">The Ambassador in Spain</hi> (<persName corresp="#p_WJE1" type="from"><hi rend="italic">Willard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Madrid</hi></placeName>, <date calendar="gregorian" when="1917-02-25T16:00:00+00:00">
                                    <hi rend="italic">February 25, 1917, 4 p.m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received 10 p.m.</hi>]</dateline>
                        </opener>
                        <p>370. Department’s 269, February 20, 3 p.m. Foreign Office has just
                            informed me <hi rend="italic">Yarrowdale</hi> prisoners were released
                            16th instant.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_WJE1">
                                    <hi rend="smallcaps">Willard</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>