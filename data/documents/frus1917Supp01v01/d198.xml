    <text>
        <body>
            <div frus:doc-dateTime-max="1917-03-14T09:00:00-05:00"
                frus:doc-dateTime-min="1917-03-14T09:00:00-05:00" n="198"
                subtype="historical-document" type="document" xml:id="d198">
                <note rend="inline" type="source">File No. 701.6311/269</note>
                <head>
                    <hi rend="italic">The Ambassador-in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="from">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1917-03-14T15:00:00+01:00">
                            <hi rend="italic">March 14, 1917, 3 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received March 16, 12.30 a.m.</hi>]</dateline>
                </opener>
                <p>1760. My 1746, March 6, 3 p.m. Minister for Foreign Affairs pressing daily to
                    know why <persName corresp="#p_TCA1">Tarnowski</persName> not fully received.
                    Emperor <persName corresp="#p_CI1">Charles</persName> has asked Minister for
                    Foreign Affairs for information and lean foresee prospect of difficulties
                    here.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
