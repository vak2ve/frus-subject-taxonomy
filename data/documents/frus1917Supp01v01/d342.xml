                subtype="historical-document" type="document" xml:id="d342">
                <note rend="inline" type="source">File No. 763.72119/558</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Argentina</hi> (<persName corresp="#p_SFJ1" type="to">
                        <hi rend="italic">Stimson</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-18T16:00:00-05:00">
                            <hi rend="italic">April 18, 1917, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your telegram April 16, 12 noon, referring to your March 16, 6 p.m., apparently
                    on another subject, not understood. To what commercial congress do you
                    refer?</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
