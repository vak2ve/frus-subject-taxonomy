<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-03-12T05:00:00-05:00" frus:doc-dateTime-min="1917-03-12T05:00:00-05:00" n="254" subtype="historical-document" type="document" xml:id="d254">
                        <note rend="inline" type="source">File No. 763.72111Y2/27</note>
                        <head>
                            <hi rend="italic">The Ambassador in Spain</hi> (<persName corresp="#p_WJE1" type="from"><hi rend="italic">Willard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Madrid</hi></placeName>, <date calendar="gregorian" when="1917-03-12T10:00:00+00:00">
                                    <hi rend="italic">March 12, 1917, 10 a.m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received 6 p.m.</hi>]</dateline>
                        </opener>
                        <p>408. Spanish Ambassador states that on March 8, 59 Americans of <hi rend="italic">Yarrowdale</hi> detained at Brandenburg left Germany
                            via Sweden [<hi rend="italic">Switzerland?</hi>] and one other from
                            another camp was also released.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_WJE1">
                                    <hi rend="smallcaps">Willard</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>