                subtype="historical-document" type="document" xml:id="d399">
                <note rend="inline" type="source">File No. 763.72119/608</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Diplomatic Representatives in Central and South
                            America, except Argentina, Mexico, Panama, Cuba, Brazil, and the
                            Dominican Republic</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Circular telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-05-25T16:00:00-05:00">
                            <hi rend="italic">May 25, 1917, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Bring to attention of Government to which you are accredited following telegram
                    sent by Department to Embassy at Buenos Aires, April 22 last:</p>
                <p>[Here follows the text of telegram printed on <ref target="#pg_263">page
                        263</ref>.]</p>
                <p>For your own information and discreet use should occasion arise, the Department,
                    after careful consideration, does not consider that such a conference would
                    serve any useful purpose at this time.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
