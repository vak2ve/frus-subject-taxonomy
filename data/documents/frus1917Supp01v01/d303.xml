                subtype="historical-document" type="document" xml:id="d303">
                <note rend="inline" type="source">File No. 763.72119/481</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Argentina</hi> (<persName corresp="#p_SFJ1" type="to">
                        <hi rend="italic">Stimson</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram—Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-03-14T18:00:00-05:00">
                            <hi rend="italic">March 14, 1917, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your February 27, 11 a.m. You are instructed immediately and discreetly to
                    investigate and report upon the activities of the Government of the Argentine
                    Republic in regard to mediation by Latin-American powers referred to in your
                    cablegram. …</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
