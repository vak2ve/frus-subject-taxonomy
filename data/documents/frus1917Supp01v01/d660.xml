                subtype="historical-document" type="document" xml:id="d660">
                <note rend="inline" type="source">File No. 763.72/4044</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-30T18:00:00-05:00">
                            <hi rend="italic">April 30, 1917, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>4772. Your 6077, April 24. Department has to-day informed the British Embassy
                    that upon receipt of information that adequate protection has actually arrived
                    in Liberian waters, an instruction will be sent to the American Minister in
                    Monrovia to join with his British and French colleagues in advising the Liberian
                    Government to break with Germany.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
