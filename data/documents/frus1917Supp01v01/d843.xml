                subtype="historical-document" type="document" xml:id="d843">
                <note rend="inline" type="source">File No. 701.6292/5</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Siam</hi> (<persName corresp="#p_AFD1" type="to">
                        <hi rend="italic">Arnold</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-08-08T16:00:00-05:00">
                            <hi rend="italic">August 8, 1917, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your August 5, 1 p.m. Please state to Minister for Foreign Affairs that this
                    Government regrets that it can not permit German and Austrian charges to take
                    ship through Panama Canal.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
