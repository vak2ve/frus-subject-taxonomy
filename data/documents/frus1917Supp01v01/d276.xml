                subtype="historical-document" type="document" xml:id="d276">
                <note rend="inline" type="source">File No. 763.72/3233</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Honduras</hi> (<persName corresp="#p_EJ1" type="to">
                        <hi rend="italic">Ewing</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-02-08T16:00:00-05:00">
                            <hi rend="italic">February 8, 1917, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your February 5, 6 p.m. I am pleased with the sympathetic attitude of Honduras
                    and the other Central American governments, but the Government of the United
                    States is not in a position to guarantee protection in case of aggression
                    resulting from the proposed action.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
