                subtype="historical-document" type="document" xml:id="d436">
                <note rend="inline" type="source">File No. 835.032/24</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Argentina</hi> (<persName corresp="#p_SFJ1" type="to">
                        <hi rend="italic">Stimson</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-07-03T17:00:00-05:00">
                            <hi rend="italic">July 3, 1917, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your July 1, 12 noon. Cable brief outline plan of congress of neutrals in message
                    of President.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
