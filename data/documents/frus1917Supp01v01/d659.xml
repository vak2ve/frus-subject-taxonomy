                subtype="historical-document" type="document" xml:id="d659">
                <note rend="inline" type="source">File No. 763.72/4044</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-24T18:00:00+01:00">
                            <hi rend="italic">April 24, 1917, 6 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 9.30 p.m.</hi>]</dateline>
                </opener>
                <p>6077. Your 4726, April 19, 6 p.m. British Government is now instructing <persName
                        corresp="#p_SRSCA1">Spring Rice</persName> to propose that American, French,
                    and British representatives at Monrovia jointly advise Liberian Government to
                    break with Germany; promises such assistance as may be necessary.</p>
                <p>The suggestion of sending a ship or ships to Liberian waters seems good to the
                    Foreign Office who are consulting Admiralty and will give me answer later.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
