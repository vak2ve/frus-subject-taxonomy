                subtype="historical-document" type="document" xml:id="d855">
                <note rend="inline" type="source">File No. 703.5262/19</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé d’Affaires in the Netherlands</hi> (<persName corresp="#p_LM1"
                        type="to">
                        <hi rend="italic">Langhorne</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-07-03T16:00:00-05:00">
                            <hi rend="italic">July 3, 1917, 4, p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>585. Your 1026. Please inform Spanish Minister that the Department has no
                    alternative than to request the Swiss Legation here to dispense with the
                    services of the former German Embassy employees.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
