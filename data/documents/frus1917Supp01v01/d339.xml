<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-04-16T15:44:00-05:00" frus:doc-dateTime-min="1917-04-16T15:44:00-05:00" n="339" subtype="historical-document" type="document" xml:id="d339">
                            <note rend="inline" type="source">File No. 763.72/3865</note>
                            <head>
                                <hi rend="italic">The Minister in Uruguay</hi> (<persName corresp="#p_JRE1" type="from"><hi rend="italic">Jeffery</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Montevideo</hi></placeName>, <date calendar="gregorian" when="1917-04-16T17:00:00-03:44">
                                        <hi rend="italic">April 16, 1917, 5 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 11 p.m.</hi>]</dateline>
                            </opener>
                            <p>The Uruguayan Government has expressed its sympathy for the Brazilian
                                Government on the occasion of its having broken off relations with
                                the Imperial Government of Germany.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_JRE1">
                                        <hi rend="smallcaps">Jeffery</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>