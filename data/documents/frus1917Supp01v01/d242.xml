                subtype="historical-document" type="document" xml:id="d242">
                <note rend="inline" type="source">File No. 763.72111Y2/4</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Germany</hi> (<persName corresp="#p_GJW1" type="to">
                        <hi rend="italic">Gerard</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-01-22T16:00:00-05:00">
                            <hi rend="italic">January 22, 1917, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3809. Your 4909, January 19, 7 p.m. Please telegraph immediately whether there
                    are any American citizens among prisoners brought to Swinemünde by the <hi
                        rend="italic">Yarrowdale</hi>. If so, their names and American
                    addresses.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
