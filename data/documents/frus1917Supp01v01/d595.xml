<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-01-15T13:29:00-05:00" frus:doc-dateTime-min="1918-01-15T13:29:00-05:00" n="595" subtype="historical-document" type="document" xml:id="d595">
                            <note rend="inline" type="source">File No. 862.85/291</note>
                            <head>
                                <hi rend="italic">The Minister in Cuba</hi> (<persName corresp="#p_GWE1" type="from"><hi rend="italic">Gonzales</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Habana</hi></placeName>, <date calendar="gregorian" when="1918-01-15T13:00:00-05:29">
                                        <hi rend="italic">January 15, 1918, 1 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 2.36 p.m.</hi>]</dateline>
                            </opener>
                            <p>Your December 14, 5 p.m.,<note n="2" xml:id="d595fn2">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_386">p.
                                    386</ref>.</note> and January 12, 5 p.m.<note n="3" xml:id="d595fn3">Not printed.</note> President endeavoring to
                                find legal way to conform with board’s wishes. Believes will succeed
                                in doing so this week.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_GWE1">
                                        <hi rend="smallcaps">Gonzales</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                    </body></text></TEI>