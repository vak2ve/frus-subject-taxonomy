<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-06-09T18:00:00-05:00" frus:doc-dateTime-min="1917-06-09T18:00:00-05:00" n="642" subtype="historical-document" type="document" xml:id="d642">
                            <note rend="inline" type="source">File No. 763.72/5206</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in China</hi> (<persName corresp="#p_RPS1" type="to"><hi rend="italic">Reinsch</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-06-09T18:00:00-05:00">
                                        <hi rend="italic">June 9, 1917, 6 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Your June 8, 6 p.m. Department considers it inadvisable to change its
                                attitude upon this question. See <ref target="frus1902">
                                    <hi rend="italic">Foreign Relations</hi>, 1902</ref>.<note n="1" xml:id="d642fn1">
                                    <hi rend="italic">Op. cit.</hi>, pp. 184–201.</note>
                            </p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>