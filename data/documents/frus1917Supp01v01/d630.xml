    <text>
        <body>
            <div frus:doc-dateTime-max="1917-04-22T23:00:00-05:00"
                frus:doc-dateTime-min="1917-04-22T23:00:00-05:00" n="630"
                subtype="historical-document" type="document" xml:id="d630">
                <note rend="inline" type="source">File No. 763.72/4004</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName corresp="#p_RPS1"
                        type="from">
                        <hi rend="italic">Reinsch</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-23T12:00:00+08:00">
                            <hi rend="italic">April 23, 1917, 12 noon</hi>
                        </date>. <lb/> [<hi rend="italic">Received April 23, 8.30
                        a.m.</hi>]</dateline>
                </opener>
                <p>Your April 19, 4 p.m. If the Department has made any statements to the Chinese
                    Minister with respect to eventual financial assistance, I beg to be
                    informed.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_RPS1">
                            <hi rend="smallcaps">Reinsch</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
