    <text>
        <body>
            <div frus:doc-dateTime-max="1917-01-11T04:00:00-05:00"
                frus:doc-dateTime-min="1917-01-11T04:00:00-05:00" n="9"
                subtype="historical-document" type="document" xml:id="d9">
                <note rend="inline" type="source">File No. 763.72/3126</note>
                <head>
                    <hi rend="italic">The Minister in Greece</hi> (<persName corresp="#p_DG1"
                        type="from">
                        <hi rend="italic">Droppers</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Athens</hi>
                        </placeName>, <date calendar="gregorian" when="1917-01-11T11:00:00+02:00">
                            <hi rend="italic">January 11, 1917, 11 a.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 5 p.m.</hi>]</dateline>
                </opener>
                <p>222. Ultimatum referred to in my 221, January 9, 10 p.m., accepted in principle,
                    Greek Government absolutely guaranteed against aggression on the part of
                    Provisional Government both by land and sea.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DG1">
                            <hi rend="smallcaps">Droppers</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
