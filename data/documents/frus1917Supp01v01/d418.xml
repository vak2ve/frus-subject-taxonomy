<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-06-11T14:50:00-05:00" frus:doc-dateTime-min="1917-06-11T14:50:00-05:00" n="418" subtype="historical-document" type="document" xml:id="d418">
                            <note rend="inline" type="source">File No. 763.72119/636</note>
                            <head>
                                <hi rend="italic">The Minister in Paraguay</hi> (<persName corresp="#p_MDF1" type="from"><hi rend="italic">Mooney</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Asuncion</hi></placeName>, <date calendar="gregorian" when="1917-06-11T16:00:00-03:50">
                                        <hi rend="italic">June 11, 1917, 4 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 8 p.m.</hi>]</dateline>
                            </opener>
                            <p>The Paraguayan Government is not in favor of a convention of the
                                neutral American states nor of any other than that of the American
                                states.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_MDF1">
                                        <hi rend="smallcaps">Mooney</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>