                subtype="historical-document" type="document" xml:id="d24">
                <note rend="inline" type="source">File No. 763.72119/424</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1917-01-23T18:00:00+01:00">
                            <hi rend="italic">January 23, 1917, 6 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received January 24, 8.05 p.m.</hi>]</dateline>
                </opener>
                <p>803. Minister for Foreign Affairs expresses interest in knowing what particular
                    plan President [proposes] for peace preservation league. Swiss Minister declares
                    address “finest noblest diplomatic document read by him during long diplomatic
                    life.”</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PTN1">
                            <hi rend="smallcaps">Nelson Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
