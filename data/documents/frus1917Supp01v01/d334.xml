    <text>
        <body>
            <div frus:doc-dateTime-max="1917-04-15T10:16:00-05:00"
                frus:doc-dateTime-min="1917-04-15T10:16:00-05:00" n="334"
                subtype="historical-document" type="document" xml:id="d334">
                <note rend="inline" type="source">File No. 763.72/3860</note>
                <head>
                    <hi rend="italic">The Ambassador in Argentina</hi> (<persName corresp="#p_SFJ1"
                        type="from">
                        <hi rend="italic">Stimson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-15T11:00:00-04:16">
                            <hi rend="italic">April 15, 1917, 11 a.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 4 p.m.</hi>]</dateline>
                </opener>
                <p>Brigantine <hi rend="italic">Monte Protegido</hi>, under Argentine flag, sunk off
                    Scilly Islands by German submarine; will probably not cause intervention.
                    Captain and crew all Norwegian but severance of diplomatic relations with
                    Germany likely at any moment.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SFJ1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
