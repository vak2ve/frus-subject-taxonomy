                subtype="historical-document" type="document" xml:id="d379">
                <note rend="inline" type="source">File No. 763.72119/592</note>
                <head>
                    <hi rend="italic">The Minister in Honduras</hi> (<persName corresp="#p_EJ1"
                        type="from">
                        <hi rend="italic">Ewing</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1917-05-10T14:00:00-05:48">
                            <hi rend="italic">May 10, 1917, 2 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 6.30 p.m.</hi>]</dateline>
                </opener>
                <p>Last night the Minister for Foreign Affairs received telegrams from the Argentine
                    Republic inviting Honduran Government to participate in a consultation to
                    determine Latin-American joint action regarding war policy. Honduras accepts
                    understanding that united support of United States is contemplated.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_EJ1">
                            <hi rend="smallcaps">Ewing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
