    <text>
        <body>
            <div frus:doc-dateTime-max="1917-01-16T16:00:00-05:00"
                frus:doc-dateTime-min="1917-01-16T16:00:00-05:00" n="16"
                subtype="historical-document" type="document" xml:id="d16">
                <note rend="inline" type="source">File No. 763.72/3136</note>
                <head>
                    <hi rend="italic">The Minister in Greece</hi> (<persName corresp="#p_DG1"
                        type="from">
                        <hi rend="italic">Droppers</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Athens</hi>
                        </placeName>, <date calendar="gregorian" when="1917-01-16T23:00:00+02:00">
                            <hi rend="italic">January 16, 1917, 11 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received January 17, 8.40 a.m.</hi>]</dateline>
                </opener>
                <p>228. Your 186.<note n="1" xml:id="d16fn1">Not printed.</note> Conditions
                    ultimatum mentioned in my 211<note n="2" xml:id="d16fn2">
                        <ref target="frus1916Supp#pg_127">
                            <hi rend="italic">Foreign Relations</hi>, 1916, Supplement, p.
                        127</ref>.</note> accepted without reservation to-day. Two main difficulties
                    liberation political prisoners to be effected at once and internal control
                    decided as Entente demand. Danger from reservists possible but unlikely.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DG1">
                            <hi rend="smallcaps">Droppers</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
