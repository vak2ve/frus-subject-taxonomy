<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-06-30T09:41:00-05:00" frus:doc-dateTime-min="1917-06-30T09:41:00-05:00" n="854" subtype="historical-document" type="document" xml:id="d854">
                            <note rend="inline" type="source">File No. 703.5262/19</note>
                            <head>
                                <hi rend="italic">The Chargé d’Affaires in the Netherlands</hi>
                                    (<persName corresp="#p_LM1" type="from"><hi rend="italic">Langhorne</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">The Hague</hi></placeName>, <date calendar="gregorian" when="1917-06-30T16:00:00+01:19">
                                        <hi rend="italic">June 30, 1917, 4 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received July 1, 2
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>1026. Spanish Minister informs me that German Government will
                                withdraw permission for Americans to work at Spanish Embassy,
                                Berlin, if German employees at Swiss Legation, Washington, are
                                dismissed, and expresses hope that this situation may not arise as
                                the departure of the few Americans now at the Embassy would impair
                                efficiency of its work.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LM1">
                                        <hi rend="smallcaps">Langhorne</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>