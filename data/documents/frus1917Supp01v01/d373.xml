<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-05-04T15:00:00-05:00" frus:doc-dateTime-min="1917-05-04T15:00:00-05:00" n="373" subtype="historical-document" type="document" xml:id="d373">
                            <note rend="inline" type="source">File No. 838.032/28</note>
                            <head>
                                <hi rend="italic">The Minister in Haiti</hi> (<persName corresp="#p_BBA1" type="from"><hi rend="italic">Bailly-Blanchard</hi></persName>) <hi rend="italic">to the
                                        <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Port au Prince</hi></placeName>, <date calendar="gregorian" when="1917-05-04T15:00:00-05:00">
                                        <hi rend="italic">May 4, 1917, 3 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 8.30 p.m.</hi>]</dateline>
                            </opener>
                            <p>National Assembly met to-day; war message of the President of Haiti
                                read, discussed, and referred to committee for report.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_BBA1">
                                        <hi rend="smallcaps">Blanchard</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>