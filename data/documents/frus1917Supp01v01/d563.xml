    <text>
        <body>
            <div frus:doc-dateTime-max="1917-12-07T17:00:00-05:00"
                frus:doc-dateTime-min="1917-12-07T17:00:00-05:00" n="563"
                subtype="historical-document" type="document" xml:id="d563">
                <note rend="inline" type="source">File No. 763.72119/990</note>
                <head>
                    <hi rend="italic">The Minister in Panama</hi> (<persName corresp="#p_PWJ1"
                        type="from">
                        <hi rend="italic">Price</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Panama</hi>
                        </placeName>, <date calendar="gregorian" when="1917-12-07T17:00:00-05:00">
                            <hi rend="italic">December 7, 1917, 5 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 8.24 p.m.</hi>]</dateline>
                </opener>
                <p>Costa Rican Minister for Foreign Affairs cables Argentine Minister for Foreign
                    Affairs, Costa Rica abstains from appointing delegates owing to special
                    conditions in the country and regrets that circumstances beyond his control
                    prevent taking part in so important assembly.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PWJ1">
                            <hi rend="smallcaps">Price</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
