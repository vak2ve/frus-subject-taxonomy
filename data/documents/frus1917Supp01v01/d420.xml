<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-06-13T08:00:00-05:00" frus:doc-dateTime-min="1917-06-13T08:00:00-05:00" n="420" subtype="historical-document" type="document" xml:id="d420">
                            <note rend="inline" type="source">File No. 641.326/2</note>
                            <head>
                                <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1917-06-13T14:00:00+01:00">
                                        <hi rend="italic">June 13, 1917, 2 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 5.45 p.m.</hi>]</dateline>
                            </opener>
                            <p>6448. Your 4939, June 6, 4 p.m. The Foreign Office has sent <persName corresp="#p_SRSCA1">Spring Rice</persName> a practical agreement
                                to Brazil’s wish, which I dare say he has now delivered to you.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_PWH1">
                                        <hi rend="smallcaps">Page</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>