<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-05-01T23:59:59-05:00" frus:doc-dateTime-min="1917-05-01T00:00:00-05:00" n="873" subtype="historical-document" type="document" xml:id="d873">
                            <note rend="inline" type="source">File No. 705.6752/–</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Spanish Ambassador</hi> (<persName corresp="#p_RGDJ1" type="to"><hi rend="italic">Riaño</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-05-01">
                                        <hi rend="italic">May 1, 1917</hi></date>.</dateline>
                            </opener>
                            <p>
                                <hi rend="smallcaps">Excellency</hi>: I have the honor to
                                acknowledge the receipt of your note of April 27, 1917, in which you
                                state that you have on that date taken charge of the interests of
                                Turkey in the United States.</p>
                            <p>Accept [etc.]</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Robert Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                    </body></text></TEI>