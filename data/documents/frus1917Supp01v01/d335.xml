                <note rend="inline" type="source">File No. 763.72111N39/48</note>
                <head>
                    <hi rend="italic">The Ambassador in Mexico</hi> (<persName corresp="#p_FHP1"
                        type="from">
                        <hi rend="italic">Fletcher</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico City</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-15T00:00:00-06:36">
                            <hi rend="italic">April 15, 1917, midnight</hi>
                        </date>. <lb/> [<hi rend="italic">Received April 16, 6.45
                        a.m.</hi>]</dateline>
                </opener>
                <p>95. <persName corresp="#p_CGV1">Carranza</persName> declared before Congress
                    to-night that Mexico would observe strict neutrality in the present war.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_FHP1">
                            <hi rend="smallcaps">Fletcher</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
