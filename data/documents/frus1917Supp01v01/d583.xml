    <text>
        <body>
            <div frus:doc-dateTime-max="1917-12-21T23:59:59-05:00"
                frus:doc-dateTime-min="1917-12-21T00:00:00-05:00" n="583"
                subtype="historical-document" type="document" xml:id="d583">
                <note rend="inline" type="source">File No. 763.72/8296</note>
                <head>
                    <hi rend="italic">The Cuban Chargé</hi> (<persName type="from">
                        <hi rend="italic">Torralbas</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation]</seg>
                </opener>
                <opener>
                    <seg rendition="#left">No. 170</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-12-21">
                            <hi rend="italic">December 21, 1917</hi>
                        </date>. <lb/> [<hi rend="italic">Received December 22.</hi>]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary</hi>: I have the honor to inform your
                    excellency that the Congress of my nation in joint session of the 16th instant
                    declared and the President of the Republic proclaimed a state of war between the
                    Republic of Cuba and the Imperial and Royal Government of Austria-Hungary.</p>
                <p>I avail myself [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dr. <persName>J. R. Torralbas</persName>
                        </hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
