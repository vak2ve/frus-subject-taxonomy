    <text>
        <body>
            <div frus:doc-dateTime-max="1917-04-16T11:16:00-05:00"
                frus:doc-dateTime-min="1917-04-16T11:16:00-05:00" n="338"
                subtype="historical-document" type="document" xml:id="d338">
                <note rend="inline" type="source">File No. 763.72119/558</note>
                <head>
                    <hi rend="italic">The Ambassador in Argentina</hi> (<persName corresp="#p_SFJ1"
                        type="from">
                        <hi rend="italic">Stimson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-16T12:00:00-04:16">
                            <hi rend="italic">April 16, 1917, 12 noon</hi>
                        </date>. <lb/> [<hi rend="italic">Received 2 p.m.</hi>]</dateline>
                </opener>
                <p>My telegram March 16, 6 p.m.<note n="1" xml:id="d338fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_241">p. 241</ref>.</note> I am
                    informed on good authority that the invitation of commercial conference of
                    American nations here now includes United States as well as Guatemala, Ecuador,
                    and other countries not diplomatically represented here.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SFJ1">
                            <hi rend="smallcaps">Stimson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
