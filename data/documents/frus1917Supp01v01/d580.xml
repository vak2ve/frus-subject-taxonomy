                subtype="historical-document" type="document" xml:id="d580">
                <note rend="inline" type="source">File No. 763.72/8166</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Panama</hi> (<persName corresp="#p_PWJ1" type="to">
                        <hi rend="italic">Price</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-12-20T15:00:00-05:00">
                            <hi rend="italic">December 20, 1917, 3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your December 16, 3 p.m. Department understands position taken by you in
                    informally suggesting to Government of Panama that National Assembly declare
                    existence of state of war between Panama and Austria-Hungary. Your action is
                    approved.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
