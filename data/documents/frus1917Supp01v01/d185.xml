                subtype="historical-document" type="document" xml:id="d185">
                <note rend="inline" type="source">File No. 701.6311/268</note>
                <head>
                    <hi rend="italic">The Ambassador in Austria-Hungary</hi> (<persName
                        corresp="#p_PFC1" type="from">
                        <hi rend="italic">Penfield</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1917-03-06T15:00:00+01:00">
                            <hi rend="italic">March 6, 1917, 3 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received March 7, 3.30 p.m.</hi>]</dateline>
                </opener>
                <p>1746. Minister for Foreign Affairs asks me to do what can to facilitate,
                        <persName corresp="#p_TCA1">Tarnowski</persName>’s full reception as
                    Ambassador. Minister for Foreign Affairs doing much to keep good relations here,
                    has stopped abus of our country in the press, and done other helpful things. Not
                    my intention to intrude any suggestion or express opinions, but my work, in
                    certain directions would be greatly facilitated were <persName corresp="#p_TCA1"
                        >Tarnowski</persName> received.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFC1">
                            <hi rend="smallcaps">Penfield</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
