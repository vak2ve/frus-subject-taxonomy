                subtype="historical-document" type="document" xml:id="d816">
                <note rend="inline" type="source">File No. 124.62/45a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Spain</hi> (<persName corresp="#p_WJE1" type="to">
                        <hi rend="italic">Willard</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-02-26T11:00:00-05:00">
                            <hi rend="italic">February 26, 1917, 11 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>285. When Mr. <persName corresp="#p_GJW1">Gerard</persName> decides definitely
                    the date of his sailing for the United States, you should request the Spanish
                    Government to be so kind as to instruct the Spanish Ambassador in Berlin to
                    communicate that fact to the German Government for its information.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
