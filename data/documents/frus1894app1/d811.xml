    <text>
        <body>
            <div frus:doc-dateTime-max="1894-04-03T23:59:59-05:00" frus:doc-dateTime-min="1894-04-03T00:00:00-05:00" n="811" subtype="historical-document" type="document" xml:id="d811">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Mr.
                                    <persName type="to">Runyon</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 78.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                        of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-04-03">
                            <hi rend="italic">April 3,
                                1894</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I inclose herewith, for your information
                            and the files of your embassy, copy of a correspondence between this
                            Department and the ambassadors here of Great Britain and Germany
                            respecting the expense of the maintenance of Mataafa and other Samoan
                            chiefs during their temporary detention at Fakaofo.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edwin E. Uhl</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
