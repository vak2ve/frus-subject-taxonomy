    <text>
        <body>
            <div frus:doc-dateTime-max="1891-12-29T23:59:59-05:00" frus:doc-dateTime-min="1891-12-29T00:00:00-05:00" n="789" subtype="historical-document" type="document" xml:id="d789">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr.
                                    <persName type="to">Phelps</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1891-12-29">
                            <hi rend="italic">December 29,
                                    1891</hi>
                        </date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Phelps</hi>, <hi rend="italic">Minister, Berlin:</hi>
                </p>
                <p>Ascertain by thorough investigation and advise as to character and
                            fitness of Baron Senfft von Pilsach for president municipal council,
                            Apia.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blaine.</hi>
                    </signed>
                </closer>
            </div>
        </body>
