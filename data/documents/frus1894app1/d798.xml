    <text>
        <body>
            <div frus:doc-dateTime-max="1893-05-15T23:59:59-05:00" frus:doc-dateTime-min="1893-05-15T00:00:00-05:00" n="798" subtype="historical-document" type="document" xml:id="d798">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Phelps</persName> to Mr.
                                    <persName type="to">Gresham</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1893-05-15">
                            <hi rend="italic">May 15,
                                1893</hi>
                        </date>.</dateline>
                </opener>
                <p>Samoan affairs, dispatch 561, England and Germany will prolong until
                            March 31 next, if we agree.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phelps.</hi>
                    </signed>
                </closer>
            </div>
        </body>
