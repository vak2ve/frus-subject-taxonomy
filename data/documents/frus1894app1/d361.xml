    <text>
        <body>
            <div frus:doc-dateTime-max="1886-11-30T23:59:59-05:00" frus:doc-dateTime-min="1886-11-30T00:00:00-05:00" n="361" subtype="historical-document" type="document" xml:id="d361">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Curry</persName> to Mr.
                                <persName type="to">Bayard</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of
                                    the United States</hi>,<lb/>
                            <hi rend="italic">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1886-11-30">
                            <hi rend="italic">November</hi> 30,
                            1886</date>.</dateline>
                </opener>
                <p>This Government offers $1,500,000 in full settlement of the claim of Mora.
                        Will be charged on Cuban budget of next year. Shall I accept with authority
                        to arrange details of payment?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Curry.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
