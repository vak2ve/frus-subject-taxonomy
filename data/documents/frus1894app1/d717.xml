    <text>
        <body>
            <div frus:doc-dateTime-max="1893-08-24T23:59:59-05:00" frus:doc-dateTime-min="1893-08-24T00:00:00-05:00" n="717" subtype="historical-document" type="document" xml:id="d717">
                <head>
                    <hi rend="italic">Baron <persName type="from">Ketteler</persName> to
                                Mr. <persName type="to">Gresham</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">New
                                        York</hi>
                        </placeName>, <date calendar="gregorian" when="1893-08-24">
                            <hi rend="italic">August 24,
                                1893</hi>
                        </date>.</dateline>
                </opener>
                <p>Received instructions to represent to Department desirability of early
                            presence of American member of land commission in Samoa in order to
                            avoid further prolongation of term.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Ketteler.</hi>
                    </signed>
                </closer>
            </div>
        </body>
