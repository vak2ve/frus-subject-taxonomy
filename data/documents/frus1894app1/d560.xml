<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1893-06-23T23:59:59-05:00" frus:doc-dateTime-min="1893-06-23T00:00:00-05:00" n="560" subtype="historical-document" type="document" xml:id="d560">
                        <head><hi rend="italic">Mr. <persName type="from">Gresham</persName> to Sir
                                    <persName type="to">Julian Pauncefote</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1893-06-23"><hi rend="italic">June 23,
                                1893</hi></date>.</dateline></opener>
                        <p>Germany objects to conference and I waive my request for it.</p>
                        <closer><signed><hi rend="smallcaps">W. Q. Gresham.</hi></signed></closer>
                    </div>
                    </body></text></TEI>