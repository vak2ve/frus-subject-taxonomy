    <text>
        <body>
            <div frus:doc-dateTime-max="1894-11-20T23:59:59-05:00"
                frus:doc-dateTime-min="1894-11-20T00:00:00-05:00" n="77"
                subtype="historical-document" type="document" xml:id="d77">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Mr. <persName
                            type="to">Yang Yü</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 78.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-11-20">
                            <hi rend="italic">November 20, 1894</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that our minister
                    at Tokyo is advised that any direct overtures for peace made by China to Japan
                    through the American minister at Peking will be considered.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. Q. Gresham.</hi>
                    </signed>
                </closer>
            </div>
        </body>
