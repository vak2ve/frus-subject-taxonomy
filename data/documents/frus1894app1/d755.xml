    <text>
        <body>
            <div frus:doc-dateTime-max="1894-05-16T23:59:59-05:00"
                frus:doc-dateTime-min="1894-05-16T00:00:00-05:00" n="755"
                subtype="historical-document" type="document" xml:id="d755">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Baron <persName
                            type="to">Saurma</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-05-16">
                            <hi rend="italic">May 16, 1894</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to acknowledge receipt of
                    your note of the 2d instant, with which was inclosed a copy of the report of the
                    commanding officer of the German cruiser <hi rend="italic">Sperber</hi> in
                    relation to the transportation of Mataafa and his followers to the Marshall
                    Islands.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edwin F. Uhl</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
