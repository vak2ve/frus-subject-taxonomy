                subtype="historical-document" type="document" xml:id="d567">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Quincy</persName> to Sir <persName
                            type="to">Julian Pauncefote</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1893-06-30">
                            <hi rend="italic">June 30, 1893</hi>
                        </date>.</dateline>
                </opener>
                <p>Your personal note to Secretary Gresham of 27th received. But one vessel now
                    available, and under immediate sailing orders. She is heavily manned and can
                    efficiently aid proposed demonstration.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Josiah Quincy</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
