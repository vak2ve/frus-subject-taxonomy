    <text>
        <body>
            <div frus:doc-dateTime-max="1894-01-20T23:59:59-05:00" frus:doc-dateTime-min="1894-01-20T00:00:00-05:00" n="809" subtype="historical-document" type="document" xml:id="d809">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Mr.
                                    <persName type="to">Runyon</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-01-20">
                            <hi rend="italic">January 20,
                                1894</hi>
                        </date>.</dateline>
                </opener>
                <p>Your 25 received. Having ascertained concurrence of Great Britain, this
                            Government agrees to continue land commission in Samoa until end of this
                            year if necessary to complete its work.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gresham.</hi>
                    </signed>
                </closer>
            </div>
        </body>
