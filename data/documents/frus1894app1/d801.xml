                <head>
                    <hi rend="italic">Mr. <persName type="from">Runyon</persName> to Mr.
                                    <persName type="to">Gresham</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1893-06-20">
                            <hi rend="italic">June 20,
                                1893</hi>
                        </date>.</dateline>
                </opener>
                <p>Suggested conference; reply promised in a day or two.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Runyon.</hi>
                    </signed>
                </closer>
            </div>
