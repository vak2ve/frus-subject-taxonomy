<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1894-03-28T23:59:59-05:00" frus:doc-dateTime-min="1894-03-28T00:00:00-05:00" n="273" subtype="historical-document" type="document" xml:id="d273">
                    <head><hi rend="italic">Mr. <persName type="from">Gresham</persName> to Mr.
                                <persName type="to">Braida</persName>.</hi></head>
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1894-03-28"><hi rend="italic">March 28,
                            1894</hi></date>.</dateline></opener>
                    <p>You are not authorized to perform diplomatic functions, and will not meddle
                        in political affairs in Mosquito. Naval vessel will soon reach
                        Bluefields.</p>
                </div>
                </body></text></TEI>