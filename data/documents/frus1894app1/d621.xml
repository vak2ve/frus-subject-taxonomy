                subtype="historical-document" type="document" xml:id="d621">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Sir <persName
                            type="to">Julian Pauncefote</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-05-16">
                            <hi rend="italic">May 16, 1894</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to acknowledge the
                    receipt of your note of the 14th instant, in which you inclose copy of a
                    dispatch from Her Majesty’s consul at Apia, reporting the steps taken by the
                    consular representatives of the three powers with a view to the restoration of
                    peace in the Navigators Islands.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edwin F. Uhl</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
