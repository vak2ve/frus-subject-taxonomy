<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1889-07-30T23:59:59-05:00" frus:doc-dateTime-min="1889-07-30T00:00:00-05:00" n="378" subtype="historical-document" type="document" xml:id="d378">
                    <head><hi rend="italic">Mr. <persName type="from">Wharton</persName> to Mr.
                                <persName type="to">Palmer</persName></hi>.</head>
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department
                                    of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1889-07-30"><hi rend="italic">July 30,
                            1889</hi></date>.</dateline></opener>
                    <p>Have you no information as to Mora case for us?</p>
                    <closer><signed><hi rend="smallcaps">Wharton.</hi></signed></closer>
                </div>
                </body></text></TEI>