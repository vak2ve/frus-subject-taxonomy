                subtype="historical-document" type="document" xml:id="d555">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Sir <persName
                            type="to">Julian Pauncefote</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1893-05-17">
                            <hi rend="italic">May 17, 1893</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to apprise you of the assent of
                    the Government of the United States to the proposition, as modified by the
                    concurrence of your Government and that of the German Empire, to extend the term
                    of the Samoan land commission to March 31, 1894.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. Q. Gresham</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
