                subtype="historical-document" type="document" xml:id="d559">
                <head>
                    <hi rend="italic">Sir <persName type="from">Julian Pauncefote</persName> to Mr.
                            <persName type="to">Gresham</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Newport, R. I.</hi>
                        </placeName>, <date calendar="gregorian" when="1893-06-22">
                            <hi rend="italic">June 22, 1893</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 19th instant, relative to the apprehended hostilities in Samoa
                    between King Malietoa and the rebel chief Mataafa and the intended dispatch of
                    United States vessels of war to Samoan waters for the purposes explained in your
                    note, the substance of which I immediately communicated by telegraph to the Earl
                    of Rosebery.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Julian Pauncefote.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
