    <text>
        <body>
            <div frus:doc-dateTime-max="1894-05-31T23:59:59-05:00"
                frus:doc-dateTime-min="1894-05-31T00:00:00-05:00" n="758"
                subtype="historical-document" type="document" xml:id="d758">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Baron <persName
                            type="to">Saurma</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-05-31">
                            <hi rend="italic">May 31, 1894</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to acknowledge the
                    receipt of your note of the 26th instant, transmitting a copy of a report from
                    the German consul at Apia, dated March 26, 1894, on the situation in Samoa.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edwin E. Uhl</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
