                subtype="historical-document" type="document" xml:id="d368">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Rives</persName> to Messrs.
                            <persName type="to">Shipman, Barlow, Larocque and
                        Choate</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1888-03-12">
                            <hi rend="italic">March</hi> 12, 1888</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Gentlemen</hi>: In response to your letter, of the 7th
                    instant, in relation to the claim of Antonio Mora against the Government of
                    Spain, I have to say that the Department has not made to nor accepted from the
                    Spanish Government any proposition to offset that claim against similar claims
                    of Spanish subjects against the United States.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">G. L. Rives</hi>,<lb/>
                        <hi rend="italic">Assistant Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
