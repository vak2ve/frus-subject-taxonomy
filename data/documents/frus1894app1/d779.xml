    <text>
        <body>
            <div frus:doc-dateTime-max="1891-03-24T23:59:59-05:00" frus:doc-dateTime-min="1891-03-24T00:00:00-05:00" n="779" subtype="historical-document" type="document" xml:id="d779">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Lincoln</persName> to Mr.
                                    <persName type="to">Blaine</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">London</hi>
                        </placeName>, <date calendar="gregorian" when="1891-03-24">
                            <hi rend="italic">March 24,
                                1891</hi>
                        </date>.</dateline>
                </opener>
                <p>Bayett Michael Hazzard appointed British member Samoan land commission
                            last July. Now in Samoa.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lincoln.</hi>
                    </signed>
                </closer>
            </div>
        </body>
