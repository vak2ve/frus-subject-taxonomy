<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1892-11-30T23:59:59-05:00" frus:doc-dateTime-min="1892-11-30T00:00:00-05:00" n="546" subtype="historical-document" type="document" xml:id="d546">
                        <head><hi rend="italic">Mr. <persName type="from">Foster</persName> to Sir
                                    <persName type="to">Julian Pauncefote</persName>.</hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1892-11-30"><hi rend="italic">November 30,
                                    1892</hi></date>.</dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your note of the 25th instant, in relation to the protection
                            of life and property in Samoa by the vessels of war of the three treaty
                            powers.</p>
                        <p>I have, etc.,</p>
                        <closer><signed><hi rend="smallcaps">John W. Foster.</hi></signed></closer>
                    </div>
                    </body></text></TEI>