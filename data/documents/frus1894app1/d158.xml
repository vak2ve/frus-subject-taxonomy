    <text>
        <body>
            <div frus:doc-dateTime-max="1894-03-24T23:59:59-05:00"
                frus:doc-dateTime-min="1894-03-24T00:00:00-05:00" n="158"
                subtype="historical-document" type="document" xml:id="d158">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Mr. <persName
                            type="to">White</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-03-24">
                            <hi rend="italic">March 24, 1894</hi>
                        </date>.</dateline>
                </opener>
                <p>United States will agree to prohibit their citizens from taking seals within 10
                    miles of Russian coast and within zone of 30 miles around Commander and Robbin
                    islands until agreement is terminated by notice.</p>
            </div>
