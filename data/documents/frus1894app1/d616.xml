    <text>
        <body>
            <div frus:doc-dateTime-max="1894-04-19T23:59:59-05:00" frus:doc-dateTime-min="1894-04-19T00:00:00-05:00" n="616" subtype="historical-document" type="document" xml:id="d616">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Sir
                                    <persName type="to">Julian Pauncefote</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-04-19">
                            <hi rend="italic">April 19,
                                1894</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to acknowledge the
                            receipt of your note of the 14th instant, inclosing the substance of a
                            telegram to the Earl of Kimberley from Her Majesty’s consul at Apia,
                            reporting the, outbreak of hostilities in Samoa.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edwin E. Uhl</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
