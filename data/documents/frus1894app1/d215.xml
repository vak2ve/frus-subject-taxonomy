    <text>
        <body>
            <div frus:doc-dateTime-max="1894-05-12T23:59:59-05:00" frus:doc-dateTime-min="1894-05-12T00:00:00-05:00" n="215" subtype="historical-document" type="document" xml:id="d215">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Prince
                                <persName type="to">Cantacuzene</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-05-12">
                            <hi rend="italic">May 12,
                            1894</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                        your note of the 4th instant, and to express to you the gratification with
                        which this Government accepts your declaration that the Imperial Government
                        is prepared to negotiate and sign with the United States, England, and Japan
                        a treaty in virtue of which the principles and regulations of the Paris
                        Tribunal of Arbitration shall be applicable, indifferently, to all the
                        waters of the Pacific Ocean north of the thirty-fifth parallel of north
                        latitude.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edwin F. Uhl</hi>, <hi rend="italic">Acting
                                Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
