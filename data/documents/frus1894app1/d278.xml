    <text>
        <body>
            <div frus:doc-dateTime-max="1894-04-02T23:59:59-05:00"
                frus:doc-dateTime-min="1894-04-02T00:00:00-05:00" n="278"
                subtype="historical-document" type="document" xml:id="d278">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Mr. <persName
                            type="to">Baker</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-04-02">
                            <hi rend="italic">April 2, 1894</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have received your two dispatches of the 9th
                    ultimo, relative to the disturbances at the Mosquito Reservation, stating that
                    this Government has not failed to take the action which appeared proper to the
                    end of protecting American interests there.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. Q. Gresham.</hi>
                    </signed>
                </closer>
            </div>
        </body>
