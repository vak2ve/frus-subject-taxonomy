    <text>
        <body>
            <div frus:doc-dateTime-max="1863-10-20T23:59:59-05:00" frus:doc-dateTime-min="1863-10-20T00:00:00-05:00" n="117" subtype="historical-document" type="document" xml:id="d117">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Dayton</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 415.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1863-10-20">
                            <hi rend="italic">October</hi> 20, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have to acknowledge the receipt of your
                            despatch of the 6th instant, (No. 357,) relative to the movements of the
                            steamer Southerner, which will be submitted to the Secretary of the
                            Navy.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">William</hi> L <hi rend="smallcaps">Dayton</hi>,
                                Esq., <hi rend="italic">&amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
