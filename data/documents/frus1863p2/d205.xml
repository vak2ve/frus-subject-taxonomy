<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1863-01-14T23:59:59-05:00" frus:doc-dateTime-min="1863-01-14T00:00:00-05:00" n="205" subtype="historical-document" type="document" xml:id="d205">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Pike</persName>.</head>
                        <opener>
                            <seg rendition="#left">No. 86.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                                <date calendar="gregorian" when="1863-01-14"><hi rend="italic">January</hi> 14, 1863.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> I have to acknowledge the receipt of your
                            despatch (No. 69) of the 24th ultimo, and to inform you that that part
                            of it relating to finance has been communicated to the Secretary of the
                            Treasury.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">James</hi> S. <hi rend="smallcaps">Pike</hi>,
                                Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>