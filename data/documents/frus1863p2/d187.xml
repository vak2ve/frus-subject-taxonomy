    <text>
        <body>
            <div frus:doc-dateTime-max="1863-06-19T23:59:59-05:00" frus:doc-dateTime-min="1863-06-19T00:00:00-05:00" n="187" subtype="historical-document" type="document" xml:id="d187">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Clay</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 20.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1863-06-19">
                            <hi rend="italic">June</hi> 19, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Your despatch of the 25th ultimo (No. 6)
                            has been received. Accept my thanks for the interesting information
                            which it contains.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Cassius</hi> M. <hi rend="smallcaps">Clay</hi>,
                                    <hi rend="italic">&amp;c., &amp;c., &amp;c..</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
