    <text>
        <body>
            <div frus:doc-dateTime-max="1863-04-13T23:59:59-05:00" frus:doc-dateTime-min="1863-04-13T00:00:00-05:00" n="219" subtype="historical-document" type="document" xml:id="d219">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Pike</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 96.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1863-04-13">
                            <hi rend="italic">April</hi> 13, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have received your despatch (No. 77) of
                            the 25th of February, and shall lay it before the Secretary of the
                            Treasury.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">James</hi> S. <hi rend="smallcaps">Pike</hi>,
                                Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
