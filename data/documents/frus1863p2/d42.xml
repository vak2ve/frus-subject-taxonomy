    <text>
        <body>
            <div frus:doc-dateTime-max="1863-05-14T23:59:59-05:00" frus:doc-dateTime-min="1863-05-14T00:00:00-05:00" n="42" subtype="historical-document" type="document" xml:id="d42">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Dayton</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 343.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1863-05-14">
                            <hi rend="italic">May</hi> 14, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Your despatch of the 20th ultimo (No. 300)
                            was duly received. The information which it contains as to the
                            proceedings of the French government in regard to the insurgent steamer
                            Japan, or Virginia, is satisfactory.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">William</hi> L. <hi rend="smallcaps">Dayton</hi>, Esq., <hi rend="italic">&amp;c., &amp;c.,
                                &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
