    <text>
        <body>
            <div frus:doc-dateTime-max="1863-02-14T23:59:59-05:00"
                frus:doc-dateTime-min="1863-02-14T00:00:00-05:00" n="8"
                subtype="historical-document" type="document" xml:id="d8">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Dayton</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 300.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1863-02-14">
                            <hi rend="italic">February</hi> 14, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Your despatch of the 27th of January, No. 261,
                    has been received. The assiduity and discretion which you have practiced in
                    giving us the tone of the Parisian press are very highly appreciated.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">William</hi> L. <hi rend="smallcaps">Dayton</hi>, Esq.,
                            <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
