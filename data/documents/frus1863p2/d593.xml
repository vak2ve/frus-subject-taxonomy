                            <lb/>
                            <signed>B. C. MORRIS, <hi rend="italic">Pres’t Columbian Mutual
                                    Insurance Company.</hi></signed>
                            <lb/>
                            <signed>ALFRED EDWARDS, <hi rend="italic">Pres’t Pacific Mutual
                                    Insurance Company.</hi></signed>
                            <lb/>
                            <signed>J. P. TAPPAN, <hi rend="italic">Pres’t Neptune Insurance
                                    Company.</hi></signed>
                            <lb/>
                            <signed>A. W. WHIPPLE, <hi rend="italic">Pres’t Washington Mutual
                                    Insurance Company.</hi></signed>
                            <lb/>
                            <signed>SAMUEL DRAKE SMITH, <hi rend="italic">Pres’t Commercial Mutual
                                    Insurance Company.</hi></signed>
                            <lb/>
                            <signed>JOHN H. EARLY, <hi rend="italic">Pres’t New York Mutual
                                    Insurance Company.</hi></signed>
                            <lb/>
                            <signed>F. L. LATHROP, <hi rend="italic">Pres’t Union Mutual Insurance
                                    Company.</hi></signed></closer>
                        <postscript>
                            <p>Hon. <hi rend="smallcaps">William</hi> H. <hi rend="smallcaps">Seward</hi>, <hi rend="italic">Secretary of State of the United
                                    States, Washington, D. C.</hi></p>
                        </postscript>
