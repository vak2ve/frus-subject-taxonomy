    <text>
        <body>
            <div frus:doc-dateTime-max="1863-09-08T23:59:59-05:00"
                frus:doc-dateTime-min="1863-09-08T00:00:00-05:00" n="86"
                subtype="historical-document" type="document" xml:id="d86">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Dayton</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 393.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1863-09-08">
                            <hi rend="italic">September</hi> 8, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Your despatch of the 20th of August (No. 334) has
                    been submitted to the President, and I have the pleasure of stating that the
                    explanation made by Mr. Drouyn de l’Huys, concerning the Moniteur article, is
                    entirely satisfactory.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">William</hi> L. <hi rend="smallcaps">Dayton</hi>,
                        Esq.</p>
                </postscript>
            </div>
        </body>
    </text>
