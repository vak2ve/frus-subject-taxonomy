    <text>
        <body>
            <div frus:doc-dateTime-max="1863-10-10T23:59:59-05:00" frus:doc-dateTime-min="1863-10-10T00:00:00-05:00" n="114" subtype="historical-document" type="document" xml:id="d114">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Dayton</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 413.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1863-10-10">
                            <hi rend="italic">October</hi> 10, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Your despatch of the 24th ultimo, (No.
                            351,) relative to the Southerner, has been received, and a copy thereof
                            sent to the Secretary of the Navy.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Wm.</hi> L. <hi rend="smallcaps">Dayton</hi>,
                                Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
