<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1863-03-02T23:59:59-05:00" frus:doc-dateTime-min="1863-03-02T00:00:00-05:00" n="253" subtype="historical-document" type="document" xml:id="d253">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Burlingame</persName></head>
                        <opener>
                            <seg rendition="#left">No. 28.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                                <date calendar="gregorian" when="1863-03-02"><hi rend="italic">March</hi> 2, 1863.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> I have to acknowledge the receipt of your
                            despatch No, 29, of the 12th of December last, and to approve your
                            proceedings therein recited. The regulations which accompanied will be
                            at once made public.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Anson Burlingame</hi>, Esq., <hi rend="italic">&amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>