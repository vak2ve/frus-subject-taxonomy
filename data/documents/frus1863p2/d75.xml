<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1863-08-18T23:59:59-05:00" frus:doc-dateTime-min="1863-08-18T00:00:00-05:00" n="75" subtype="historical-document" type="document" xml:id="d75">
                        <head><persName type="from">Mr. F. W. Seward</persName> to <persName type="to">Mr. Dayton</persName></head>
                        <opener>
                            <seg rendition="#left">No. 386.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                                <date calendar="gregorian" when="1863-08-18"><hi rend="italic">August</hi> 18, 1863.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> Your despatch of the 4th instant (No. 331)
                            has been received. Your prompt proceeding, therein reported, is
                            approved. The attention of the Secretary of the Navy has been drawn to
                            the matter.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>F. W. SEWARD. <hi rend="italic">Acting
                            Secretary.</hi></signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">William</hi> L. <hi rend="smallcaps">Dayton</hi>, Esq.</p>
                        </postscript>
                    </div>
                    </body></text></TEI>