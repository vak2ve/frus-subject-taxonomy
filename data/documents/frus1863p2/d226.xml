<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1863-06-30T23:59:59-05:00" frus:doc-dateTime-min="1863-06-30T00:00:00-05:00" n="226" subtype="historical-document" type="document" xml:id="d226">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Pike</persName>.</head>
                        <opener>
                            <seg rendition="#left">No. 106.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                                <date calendar="gregorian" when="1863-06-30"><hi rend="italic">June</hi> 30, 1863.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> I have to acknowledge the receipt of your
                            despatch of the 10th instant, No. 88, and to thank you for the
                            interesting information which it presents.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">James</hi> S. <hi rend="smallcaps">Pike</hi>,
                                Esq., <hi rend="italic">&amp;c</hi>., <hi rend="italic">&amp;c.,
                                    &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>