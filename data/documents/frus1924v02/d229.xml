                        <note rend="inline" type="source">611.6831/63: Telegram</note>
                        <head><hi rend="italic">The Minister in Greece</hi> (<persName type="from"><hi rend="italic">Laughin</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
