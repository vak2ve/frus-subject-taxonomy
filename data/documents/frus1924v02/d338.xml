                subtype="historical-document" type="document" xml:id="d338">
                <note rend="inline" type="source">812.00/26803: Telegram</note>
                <head>
                    <hi rend="italic">The Vice Consul at Salina Cruz</hi> (<persName type="from">
                        <hi rend="italic">Wood</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Salina Cruz</hi>
                        </placeName>, <date calendar="gregorian" when="1924-01-20T09:00:00-07:00">
                            <hi rend="italic">January 20, 1924—9 a.m.</hi>
                        </date>
                        <lb/>[Received January 21—3:10 a.m.]</dateline>
                </opener>
                <p>Your cable January 19, 6 p.m. Federal Government officials have mined the
                    port.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wood</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
