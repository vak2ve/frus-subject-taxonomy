                subtype="historical-document" type="document" xml:id="d336">
                <note rend="inline" type="source">812.00/26794: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the Vice
                        Consul at Salina Cruz</hi> (<persName type="to">
                        <hi rend="italic">Wood</hi>
                    </persName>)<note n="9" xml:id="d336fn9">Harold C. Wood.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1924-01-19T18:00:00-05:00">
                            <hi rend="italic">January 19, 1924—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Telegraph immediately whether rebels or Federal Government officials are placing
                    mines reported in your January 18, 4 p.m.<note n="10" xml:id="d336fn10">Not
                        printed.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
