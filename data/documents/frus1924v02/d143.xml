<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1924-09-17T12:00:00-05:00" frus:doc-dateTime-min="1924-09-17T12:00:00-05:00" n="143" subtype="historical-document" type="document" xml:id="d143">
                        <note rend="inline" type="source">811.348 Z 4/162: Telegram</note>
                        <head><hi rend="italic">The Chargé in France</hi> (<persName type="from"><hi rend="italic">Whitehouse</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1924-09-17T18:00:00+01:00"><hi rend="italic">September 17,
                                        1924—6 p.m.</hi></date><lb/>[Received September 17—2:12
                                p.m.]</dateline></opener>
                        <p>407. Your [<hi rend="italic">My</hi>] 404, September 13, 1 p.m.<note n="2" xml:id="d143fn2">Not printed.</note> Permission granted but
                            French authorities request that certain fortified seaports be avoided
                            and suppose Zeppelin will have American officers on board and will fly
                            the American flag.</p>
                        <closer><signed><hi rend="smallcaps">Whitehouse</hi></signed></closer>
                    </div>
                    </body></text></TEI>