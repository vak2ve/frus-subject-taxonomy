                subtype="historical-document" type="document" xml:id="d337">
                <note rend="inline" type="source">812.00/26805: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Vera Cruz</hi> (<persName type="from">
                        <hi rend="italic">Wood</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vera Cruz</hi>
                        </placeName>, <date calendar="gregorian" when="1924-01-19T19:00:00-07:00">
                            <hi rend="italic">January 19, 1924—7 p.m.</hi>
                        </date>
                        <lb/>[Received January 21—12:44 a.m.]</dateline>
                </opener>
                <p>Department’s January 15, 5 p.m., January 15, 7 p.m., January 16, noon.<note
                        n="11" xml:id="d337fn11">None printed.</note> Following vigorous
                    representations made to Mr. de la Huerta in accordance with instructions, the
                    Department of Marine informed me that the terms of the blockade decree will not
                    go into effect until the end of the month.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wood</hi>
                    </signed>
                </closer>
            </div>
        </body>
