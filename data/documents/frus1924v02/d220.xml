                subtype="historical-document" type="document" xml:id="d220">
                <note rend="inline" type="source">868.01/219: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Greece</hi> (<persName type="from">
                        <hi rend="italic">Atherton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Athens</hi>
                        </placeName>, <date calendar="gregorian" when="1924-04-19T13:00:00+02:00">
                            <hi rend="italic">April 19, 1924—1 p.m.</hi>
                        </date>
                        <lb/>[Received 1:50 p.m.]</dateline>
                </opener>
                <p>65. Department’s 46, April 17, 5 p.m. Note forwarded Minister for Foreign Affairs
                    Roussos according to Department’s instructions.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Atherton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
