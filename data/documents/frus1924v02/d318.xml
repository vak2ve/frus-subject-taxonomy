                <note rend="inline" type="source">741.942/23: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Great Britain</hi> (<persName type="to">
                        <hi rend="italic">Kellogg</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1924-07-17T18:00:00-04:00">
                            <hi rend="italic">July 17, 1924—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>221. Your telegram No. 250, July 14, 2 p.m. You may give Foreign Office informal
                    memorandum of views as suggested.</p>
                <p rend="center">. . . . . . . . . . . . . .</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
