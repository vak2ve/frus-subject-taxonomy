<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1924-09-10T12:00:00-05:00" frus:doc-dateTime-min="1924-09-10T12:00:00-05:00" n="599" subtype="historical-document" type="document" xml:id="d599">
                        <note rend="inline" type="source">611.5231/369: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Spain</hi> (<persName type="from"><hi rend="italic">Moore</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Madrid</hi></placeName>, <date calendar="gregorian" when="1924-09-10T18:00:00+01:00"><hi rend="italic">September 10,
                                        1924—6 p.m.</hi></date><lb/>[Received 10:05
                            p.m.]</dateline></opener>
                        <p>46. Please send me copy of commercial treaty which Department desires me
                            present to Spanish Government.</p>
                        <closer><signed><hi rend="smallcaps">Moore</hi></signed></closer>
                    </div>
                    </body></text></TEI>