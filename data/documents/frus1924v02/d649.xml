                subtype="historical-document" type="document" xml:id="d649">
                <note rend="inline" type="source">867.113/33</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName type="to">
                        <hi rend="italic">Kellogg</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1924-04-15">
                            <hi rend="italic">April 15, 1924</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 155</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: With reference to the Department’s instruction
                    No. 1053 of December 10, 1923,<note n="43" xml:id="d649fn43">Not printed.</note>
                    there is enclosed, for your confidential information, a copy of a note from the
                    British Embassy dated April 5, 1924<note n="44" xml:id="d649fn44">
                        <hi rend="italic">Supra</hi>.</note> with reference to the removal by the
                    British Government of the embargo on the export of arms and munitions from Great
                    Britain to Turkey. The Department has acknowledged the receipt of this note
                    without comment.</p>
                <p>The Department perceives no reason for altering at the present time the policy
                    set forth in its note of December 6, 1923 to the British Embassy, a copy of
                    which was enclosed with the instruction referred to above.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Charles E. Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
