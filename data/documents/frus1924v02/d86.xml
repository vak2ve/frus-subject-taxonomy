                subtype="historical-document" type="document" xml:id="d86">
                <note rend="inline" type="source">462.00 R 296/814: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Herrick</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1925-01-03T11:00:00+00:00">
                            <hi rend="italic">January 3, 1925—11 a.m.</hi>
                        </date>
                        <lb/>[Received 2:43 p.m.]</dateline>
                </opener>
                <p>7. Your 3, January 2, 6 p.m.<note n="21a" xml:id="d86fn21a">Not printed.</note>
                    Note accepting invitation to finance conference was delivered on December 31st
                    in form telegraphed in Department’s 492, December 30, 7 p.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Herrick</hi>
                    </signed>
                </closer>
            </div>
        </body>
