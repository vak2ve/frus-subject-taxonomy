                subtype="historical-document" type="document" xml:id="d417">
                <note rend="inline" type="source">817.00/3052: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Ramer</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1924-04-01T16:00:00-05:45">
                            <hi rend="italic">April 1, 1924—4 p.m.</hi>
                        </date>
                        <lb/>[Received 11:45 p.m.]</dateline>
                </opener>
                <p>57. Department’s 34 March 28, 4 p.m. President Martinez agrees to retain one of
                    Dodds’ assistants throughout electoral period.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Ramer</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
