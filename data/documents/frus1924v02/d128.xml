<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1923-10-16T06:00:00-05:00" frus:doc-dateTime-min="1923-10-16T06:00:00-05:00" n="128" subtype="historical-document" type="document" xml:id="d128">
                        <note rend="inline" type="source">811.348 Z 4/52: Telegram</note>
                        <head><hi rend="italic">The Minister in Portugal</hi> (<persName type="from"><hi rend="italic">Dearing</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Lisbon</hi></placeName>, <date calendar="gregorian" when="1923-10-16T11:00:00+00:00"><hi rend="italic">October 16,
                                        1923—11 a.m.</hi></date><lb/>[Received 7:35
                            p.m.]</dateline></opener>
                        <p>63. Department’s instruction of September 18th. Portuguese Government
                            authorizes flight of <hi rend="italic">ZR–3</hi> across Portugal and
                            Azores.</p>
                        <closer><signed><hi rend="smallcaps">Dearing</hi></signed></closer>
                    </div>
                    </body></text></TEI>