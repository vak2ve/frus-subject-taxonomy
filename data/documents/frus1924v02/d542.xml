<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1924-08-07T18:00:00-05:00" frus:doc-dateTime-min="1924-08-07T18:00:00-05:00" n="542" subtype="historical-document" type="document" xml:id="d542">
                        <note rend="inline" type="source">871.6363/204: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Minister in Rumania</hi> (<persName type="to"><hi rend="italic">Jay</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1924-08-07T19:00:00-04:00"><hi rend="italic">August 7,
                                        1924—7 p.m.</hi></date></dateline></opener>
                        <p>38. Your 54, August 5, 9 p.m. received. Department fully approves
                            arrangements indicated and desires you to confirm departure by
                            telegram.</p>
                        <closer><signed><hi rend="smallcaps">Grew</hi></signed></closer>
                    </div>
