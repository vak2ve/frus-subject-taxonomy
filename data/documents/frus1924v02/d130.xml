                <note rend="inline" type="source">811.348 Z 4/133: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in the Netherlands</hi> (<persName type="from">
                        <hi rend="italic">Tobin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Hague</hi>
                        </placeName>, <date calendar="gregorian" when="1923-11-19T11:00:00+00:19">
                            <hi rend="italic">November 19, 1923—11 a.m.</hi>
                        </date>
                        <lb/>[Received November 19—11:02 a.m.]</dateline>
                </opener>
                <p>62. Your September 18th. Foreign Office grants permission for <hi rend="italic"
                        >ZR–3</hi> to fly over Dutch territory.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Tobin</hi>
                    </signed>
                </closer>
            </div>
        </body>
