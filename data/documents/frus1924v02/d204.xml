                <note rend="inline" type="source">868.01/197</note>
                <head>
                    <hi rend="italic">President <persName type="from">Coolidge</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1924-01-25">
                            <hi rend="italic">January 25, 1924</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: The recommendations you make in
                    your communication of January 25th, concerning the relations between this
                    country and Greece, are approved.</p>
                <p>Very truly yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Calvin Coolidge</hi>
                    </signed>
                </closer>
            </div>
        </body>
