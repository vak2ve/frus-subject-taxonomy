                            <hi rend="italic">Special Advisers</hi>
                        </p>
                        <list>
                            <item>
                                <persName corresp="#p_DLW1">Lewis C. Douglas</persName>, Ambassador
                                in the United Kingdom.</item>
                            <item>
                                <persName corresp="#p_SWB1">Walter Bedell Smith</persName>,
                                Ambassador in the Soviet Union.</item>
                            <item>
                                <persName corresp="#p_DJF1">John Foster Dulles</persName>.</item>
                            <item>General <persName corresp="#p_CLD1">Lucius D. Clay</persName>,
                                Military Governor for Germany.</item>
                            <item>Lieutenant General <persName corresp="#p_KG1">Geoffrey
                                    Keyes</persName>, High Commissioner for Austria.</item>
                        </list>
