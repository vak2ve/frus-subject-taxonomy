<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1947-12-30T18:00:00-05:00" frus:doc-dateTime-min="1946-12-31T00:00:00-05:00" n="271" subtype="editorial-note" type="document" xml:id="d271">
                        <head>
                            <hi rend="italic">Editorial Note</hi>
                        </head>
                        <p rend="flushleft">
                            <hi rend="smallcaps">Principal Members of the Delegations to the Fifth
                                Session of the Council of Foreign Ministers, London, November</hi>
                                25—<hi rend="smallcaps">December</hi> 15, 1947.<note n="76" xml:id="d271fn6">This list was compiled from materials in the files
                                of the Department of State. For the complete list of the United
                                States Delegation, see <hi rend="italic">Participation of the United
                                    States Government in International Conferences July 1, 1947–June
                                    30, 1948</hi>, Department of State Publication 3443 (Washington,
                                Government Printing Office, 1949), pp. 10–13.</note>
                        </p>
                        <p rend="center">
                            <hi rend="smallcaps">United States Delegation</hi>
                        </p>
                        <p rend="flushleft">
                            <hi rend="italic">Member</hi>
                        </p>
                        <list>
                            <item>
                                <persName corresp="#p_MGC1">George C. Marshall</persName>, Secretary
                                of State.</item>
                        </list>
                        <p rend="flushleft">
                            <hi rend="italic">Deputy for Germany</hi>
                        </p>
                        <list>
                            <item>
                                <persName corresp="#p_MRD1">Robert D. Murphy</persName>, Political
                                Adviser for Germany.</item>
                        </list>
                        <p rend="flushleft">
                            <hi rend="italic">Deputy for Austria</hi>
                        </p>
                        <list>
                            <item>
                                <persName corresp="#p_DJM1">Joseph M. Dodge</persName>, Former
                                Representative on the Austrian Treaty Commission.</item>
                        </list>
