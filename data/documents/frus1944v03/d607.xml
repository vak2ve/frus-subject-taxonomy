<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1944-04-07T21:00:00-05:00" frus:doc-dateTime-min="1944-04-07T21:00:00-05:00" n="607" subtype="historical-document" type="document" xml:id="d607">
                            <note rend="inline" type="source">851.01/3639: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Acting American Representative to the French Committee of
                                    National Liberation at Algiers</hi> (<persName type="to"><hi rend="italic">Chapin</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1944-04-07T22:00:00-04:00">April
                                        7, 1944—10 p.m.</date>
                                </dateline>
                            </opener>
                            <p>1055. For Murphy. We are in full agreement with your conclusion in
                                your 1149, April 6, that we should interpose no objection to
                                Giraud’s departure.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>