<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1944-03-06T12:00:00-05:00" frus:doc-dateTime-min="1944-03-06T12:00:00-05:00" n="55" subtype="historical-document" type="document" xml:id="d55">
                            <note rend="inline" type="source">800.6363/1515: Telegram</note>
                            <head>
                                <hi rend="italic">The Ambassador in the United Kingdom</hi>
                                    (<persName type="from"><hi rend="italic">Winant</hi></persName>)
                                    <hi rend="italic">to the <gloss type="to">Secretary of
                                        State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1944-03-06T18:00:00+01:00">March
                                        6, 1944—6 p.m.</date>
                                    <lb/> [Received March 6—12:35 p.m.]</dateline>
                            </opener>
                            <p>1822. Personal for the Acting Secretary of State. Your 1680, March 5.
                                Please postpone statement until tomorrow. Cabinet meeting for
                                decision this evening.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Winant</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>