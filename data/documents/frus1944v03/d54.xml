<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1944-03-05T12:00:00-05:00" frus:doc-dateTime-min="1944-03-05T12:00:00-05:00" n="54" subtype="historical-document" type="document" xml:id="d54">
                            <note rend="inline" type="source">800.636/1514c: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Ambassador in the United Kingdom</hi>
                                    (<persName type="to"><hi rend="italic">Winant</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1944-03-05T13:00:00-04:00">March
                                        5, 1944—1 p.m.</date>
                                </dateline>
                            </opener>
                            <p>1680. Personal for the Ambassador. The press is beginning to
                                speculate unfavorably on a breakdown of proposed oil talks. It is
                                    <pb facs="0116" n="104" xml:id="pg_104"/> vital to make some
                                announcement tomorrow. Please do all you can to get an immediate
                                decision.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Stettinius</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>