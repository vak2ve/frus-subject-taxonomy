                subtype="historical-document" type="document" xml:id="d1133">
                <note rend="inline" type="source">841.79658/79: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in the United Kingdom</hi> (<persName
                        type="from">
                        <hi rend="italic">Winant</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1944-03-09T19:00:00+01:00"
                            >March 9, 1944—7 p.m.</date>
                        <lb/> [Received March 9—4:20 p.m.]</dateline>
                </opener>
                <p>1921. For the Acting Secretary. Your 1764 of March 8. I have been promised an
                    answer by Eden<note n="31" xml:id="d1133fn31">Anthony Eden, British Secretary of
                        State for Foreign Affairs.</note> within 48 hours. I hope it will be
                    favorable.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Winant</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
