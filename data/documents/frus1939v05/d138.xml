    <text>
        <body>
            <div frus:doc-dateTime-max="1939-12-17T18:30:00-05:00"
                frus:doc-dateTime-min="1939-12-17T05:55:00-05:00" n="138"
                subtype="historical-document" type="document" xml:id="d138">
                <note rend="inline" type="source">740.0011 European War 1939/1219: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Uruguay</hi> (<persName type="from">
                        <hi rend="italic">Wilson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Montevideo</hi>
                        </placeName>
                        <date ana="#date_undated-inferred-from-document-content"
                            calendar="gregorian" notAfter="1939-12-17T18:30:00-05:00"
                            notBefore="1939-12-17T07:55:00-03:00" when="1939-12-17"
                        >[undated]</date>.<lb/>[Received December 17, 1939—6:30 p.m.]</dateline>
                </opener>
                <p>
                    <hi rend="italic">Graf Spee</hi> blown up 7:55 o’clock, 7 miles off shore, both
                    magazine groups exploded.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wilson</hi>
                    </signed>
                </closer>
            </div>
        </body>
