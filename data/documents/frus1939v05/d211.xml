<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-03-07T17:00:00-05:00" frus:doc-dateTime-min="1939-03-07T17:00:00-05:00" n="211" subtype="historical-document" type="document" xml:id="d211">
                            <note rend="inline" type="source">715.1715/1400: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Representative of the President</hi> (<persName type="to"><hi rend="italic">Corrigan</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1939-03-07T17:00:00-05:00">March
                                        7, 1939—5 p.m.</date>
                                </dateline>
                            </opener>
                            <p>18. Your No. 24, March 6, 10 a.m. What do you suggest?</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
