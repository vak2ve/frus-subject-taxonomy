<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-09-08T12:00:00-05:00" frus:doc-dateTime-min="1939-09-08T12:00:00-05:00" n="41" subtype="historical-document" type="document" xml:id="d41">
                        <note rend="inline" type="source">740.00111 A.R./96: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in Panama</hi> (<persName type="from"><hi rend="italic">Dawson</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Panama</hi></placeName>, <date calendar="gregorian" when="1939-09-08T12:00:00-05:00">September
                                    8, 1939—noon</date>.<lb/>[Received 1:45 p.m.]</dateline>
                        </opener>
                        <p>101. Department’s telegram No. 74, September 7, 3 p.m. Minister of
                            Foreign Affairs will send an invitation to the Director General of the
                            Pan American Union immediately.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Dawson</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>