                subtype="historical-document" type="document" xml:id="d37">
                <note rend="inline" type="source">740.00111 A.R./31: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Panama</hi> (<persName type="from">
                        <hi rend="italic">Dawson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Panama</hi>
                        </placeName>, <date calendar="gregorian" when="1939-09-05T22:00:00-05:00"
                            >September 5, 1939—10 p.m.</date>
                        <lb/> [Received September 6—12:10 a.m.]</dateline>
                </opener>
                <p>95. The joint invitation was despatched by the Panamanian Government to the other
                    12 republics at 10:00 p.m. this evening.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dawson</hi>
                    </signed>
                </closer>
            </div>
        </body>
