<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-07-05T17:00:00-05:00" frus:doc-dateTime-min="1939-07-05T17:00:00-05:00" n="17" subtype="historical-document" type="document" xml:id="d17">
                        <note rend="inline" type="source">810.24/31a: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Nicaragua</hi> (<persName type="to"><hi rend="italic">Nicholson</hi></persName>)<note n="5" xml:id="d17fn5">The same on the same date to the Ambassador in Cuba
                                as telegram No. 78, and to the Minister in Honduras as telegram No.
                                14.</note>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1939-07-05T18:00:00-04:00">July 5,
                                    1939—6 p.m.</date>
                            </dateline>
                        </opener>
                        <p>42. Please expedite reply to Department’s circular telegram of June 27, 7
                            p.m.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>