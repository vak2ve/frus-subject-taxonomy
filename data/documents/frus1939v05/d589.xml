<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-06-28T10:00:00-05:00" frus:doc-dateTime-min="1939-06-28T10:00:00-05:00" n="589" subtype="historical-document" type="document" xml:id="d589">
                        <note rend="inline" type="source">611.2231/407: Telegram</note>
                        <head>
                            <hi rend="italic">The Minister in Ecuador</hi> (<persName type="from"><hi rend="italic">Long</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Quito</hi></placeName>, <date calendar="gregorian" when="1939-06-28T10:00:00-05:00">June 28,
                                    1939—10 a.m.</date>
                                <lb/> [Received 2:35 p.m.]</dateline>
                        </opener>
                        <p>51. My telegram No. 50, June 27, 10 a.m.<note n="44" xml:id="d589fn44">Not printed.</note> Thirty per cent import control plan<note n="45" xml:id="d589fn45">Decree of June 26, <hi rend="italic">Registro
                                    Oficial</hi>, July 1.</note> becomes effective July 1, the text
                            being identic with Spanish transmitted with my despatch 538, June
                                23.<note n="44" xml:id="d589fn1">Not printed.</note>
                        </p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Long</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>