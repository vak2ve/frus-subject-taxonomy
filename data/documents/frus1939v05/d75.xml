<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-12-29T14:00:00-05:00" frus:doc-dateTime-min="1939-12-29T14:00:00-05:00" n="75" subtype="historical-document" type="document" xml:id="d75">
                        <note rend="inline" type="source">802.33/105: Telegram</note>
                        <head>
                            <hi rend="italic">The Chargé in Nicaragua</hi> (<persName type="from"><hi rend="italic">Baldwin</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Managua</hi></placeName>, <date calendar="gregorian" when="1939-12-29T13:00:00-06:00">December
                                    29, 1939—1 p.m.</date>
                                <lb/> [Received 3:30 p.m.]</dateline>
                        </opener>
                        <p>154. Instruction No. 299, December 21<note n="3" xml:id="d75fn3">See
                                footnote 2, <ref target="#pg_49">p. 49</ref>.</note> and my telegram
                            125, October 18, 4 p.m.<note n="4" xml:id="d75fn4">Not printed.</note>
                            The Foreign Minister commends the suggested patrol and authorizes
                            Nicaragua’s fullest cooperation and extension of facilities under the
                            terms and conditions suggested.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Baldwin</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>