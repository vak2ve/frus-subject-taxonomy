<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-02-17T20:00:00-05:00" frus:doc-dateTime-min="1939-02-17T20:00:00-05:00" n="209" subtype="historical-document" type="document" xml:id="d209">
                            <note rend="inline" type="source">715.1715/1392: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Representative of the President</hi> (<persName type="to"><hi rend="italic">Corrigan</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1939-02-17T20:00:00-05:00">February 17, 1939—8 p.m.</date>
                                </dateline>
                            </opener>
                            <p>14. Your No. 20, February 9, noon. Ocheltree being authorized to
                                proceed Panama for consultation with you and thence to Tegucigalpa
                                on business of Commission.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>