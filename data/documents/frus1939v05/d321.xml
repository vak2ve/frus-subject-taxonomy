<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-08-28T17:00:00-05:00" frus:doc-dateTime-min="1939-08-28T17:00:00-05:00" n="321" subtype="historical-document" type="document" xml:id="d321">
                        <note rend="inline" type="source">824.00/947: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Bolivia</hi> (<persName type="to"><hi rend="italic">Dawson</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1939-08-28T18:00:00-04:00">August 28,
                                    1939—6 p.m.</date>
                            </dateline>
                        </opener>
                        <p>25. Your 54, August 27, 5 p.m. The Department is of the opinion that no
                            issue of recognition need arise. You should therefore continue normal
                            relations with the Bolivian Government.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>