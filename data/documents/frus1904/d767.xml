<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1904-10-06T23:59:59-05:00" frus:doc-dateTime-min="1904-10-06T00:00:00-05:00" n="767" subtype="historical-document" type="document" xml:id="d767">
                            <head><hi rend="italic">Mr. <persName type="from">McCormick</persName>
                                    to Mr. <persName type="to">Hay</persName>.</hi></head>
                            <opener><seg rendition="#center">[Telegram.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Embassy</hi>,<lb/><hi rend="italic">St.
                                            Petersburg</hi></placeName>, <date calendar="gregorian" when="1904-10-06"><hi rend="italic">October 6,
                                        1904</hi></date>.</dateline></opener>
                            <p>Greener telegraphs appraisement committee fixes bond for <hi rend="italic">Calchas</hi> 674,830 rubles for release of
                                steamer; neutral cargo still on board.</p>
                            <closer><signed><hi rend="smallcaps">McCormick.</hi></signed></closer>
                        </div>
                        </body></text></TEI>