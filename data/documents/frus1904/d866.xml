<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1904-08-04T23:59:59-05:00" frus:doc-dateTime-min="1904-08-04T00:00:00-05:00" n="866" subtype="historical-document" type="document" xml:id="d866">
                        <head><hi rend="italic">Mr. <persName type="from">Leishman</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Therapia</hi></placeName>, <date calendar="gregorian" when="1904-08-04"><hi rend="italic">August 4,
                                1904</hi></date>.</dateline></opener>
                        <p>Regret to report that the promised reply to the President’s message has
                            not been received.</p>
                        <closer><signed><hi rend="smallcaps">Leishman.</hi></signed></closer>
                    </div>
                    </body></text></TEI>