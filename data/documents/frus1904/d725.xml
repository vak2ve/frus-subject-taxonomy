<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1904-05-17T23:59:59-05:00" frus:doc-dateTime-min="1904-05-17T00:00:00-05:00" n="725" subtype="historical-document" type="document" xml:id="d725">
                            <head><hi rend="italic">Mr. <persName type="from">McCormick</persName>
                                    to Mr. <persName type="to">Hay</persName>.</hi></head>
                            <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Embassy</hi>,<lb/><hi rend="italic">St.
                                            Petersburg</hi></placeName>, <date calendar="gregorian" when="1904-05-17"><hi rend="italic">May 17,
                                    1904</hi></date>.</dateline></opener>
                            <p>(Mr. McCormick reports that under the decree of April 23 raw and not
                                manufactured cotton is contraband of war.)</p>
                        </div>
                        </body></text></TEI>