                subtype="historical-document" type="document" xml:id="d627">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Tyler</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Teheran</hi>
                        </placeName>, <date calendar="gregorian" when="1904-10-26">
                            <hi rend="italic">October 26, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Tyler reports that according to a telegram from the Crown Prince a
                    detachment of fifty mounted men have been dispatched to arrest the
                    murderers.)</p>
            </div>
