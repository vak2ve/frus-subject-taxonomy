                subtype="historical-document" type="document" xml:id="d7">
                <head>[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-08-05">
                            <hi rend="italic">August 5, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="italic">To the Diplomatic Officers of the United States.</hi>
                </p>
                <p>
                    <hi rend="smallcaps">Gentlemen</hi>: You are instructed to advise the Government
                    to which you are accredited that by an order, dated June 24, 1904, the President
                    has declared the Canal Zone of the Isthmus of Panama open to commerce with
                    friendly nations, and has established Ancon and Crystobal as ports of entry in
                    the said zone.</p>
                <p>I am, etc</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
