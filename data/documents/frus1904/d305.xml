<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1904-02-15T23:59:59-05:00" frus:doc-dateTime-min="1904-02-15T00:00:00-05:00" n="305" subtype="historical-document" type="document" xml:id="d305">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Choate</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1904-02-15"><hi rend="italic">February 15,
                                    1904</hi></date>.</dateline></opener>
                        <p>(Mr. Hay instructs Mr. Choate to express to Lord Lansdowne cordial
                            appreciation for the prompt and energetic cooperation in the matter of
                            the neutrality of China.)</p>
                    </div>
