    <text>
        <body>
            <div frus:doc-dateTime-max="1904-08-20T23:59:59-05:00"
                frus:doc-dateTime-min="1904-08-20T00:00:00-05:00" n="945"
                subtype="historical-document" type="document" xml:id="d945">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Bowen</persName> to Mr. <persName
                            type="to">Hay.</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Caracas, Venezuela</hi>
                        </placeName>, <date calendar="gregorian" when="1904-08-20">
                            <hi rend="italic">August 20, 1904</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 315.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to make the following report
                    about the awards of the mixed commission: <table cols="2" rows="18">
                        <row>
                            <cell rendition="#border-right #border-bottom #border-top"
                                >Claimant.</cell>
                            <cell rendition="#border-top #border-bottom">Amount of awards.</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right"/>
                            <cell>
                                <hi rend="italic">Bolivars</hi>.</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right">Great Britain</cell>
                            <cell role="num">9,401,267.86</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right">Germany</cell>
                            <cell role="num">2,091,908.75</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right">France</cell>
                            <cell role="num">2,667,079.51</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right">Spain</cell>
                            <cell role="num">1,974,818.41</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right">Belgium</cell>
                            <cell role="num">10,898,643.86</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right">Sweden and Norway</cell>
                            <cell role="num">174,359.08</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right">The Netherlands</cell>
                            <cell role="num">544,301.47</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right">The United States of America</cell>
                            <cell role="num">2,313,711.37</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right">Mexico</cell>
                            <cell role="num">2,577,328.10</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right">Italy</cell>
                            <cell rendition="#border-bottom" role="num">5,785,962.19</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right"/>
                            <cell role="num">38,428,580,60</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right">Paid to the allied powers (Germany,
                                Great Britain, and Italy) up to June 30, 1904.</cell>
                            <cell rendition="#border-bottom" role="num">6,880,450.00</cell>
                        </row>
                        <row>
                            <cell rend="padding-left: 3em;" rendition="#border-right">Remaining to
                                be paid</cell>
                            <cell rendition="#border-bottom" role="num">31,548,130.60</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right">To said allied powers</cell>
                            <cell role="num">10,398,688.80</cell>
                        </row>
                        <row>
                            <cell rendition="#border-right">To the other claimants</cell>
                            <cell rendition="#border-bottom" role="num">21,149,441.80</cell>
                        </row>
                        <row>
                            <cell rendition="#border-bottom #border-right"/>
                            <cell rendition="#border-bottom" role="num">31,548,130.60</cell>
                        </row>
                    </table>
                </p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Herbert W. Bowen.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
