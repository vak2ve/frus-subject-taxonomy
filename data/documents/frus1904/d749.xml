                subtype="historical-document" type="document" xml:id="d749">
                <head>
                    <hi rend="italic">Mr. <persName type="from">McCormick</persName> to Mr.
                            <persName type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">St. Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1904-08-30">
                            <hi rend="italic">August 30, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. McCormick reports that he has been informed that interested parties in
                    seizure cases will be allowed to present evidence before the council of
                    admiralty.)</p>
            </div>
