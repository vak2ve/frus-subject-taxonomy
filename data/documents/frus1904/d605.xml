                subtype="historical-document" type="document" xml:id="d605">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Pearson</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Teheran</hi>
                        </placeName>, <date calendar="gregorian" when="1904-03-13">
                            <hi rend="italic">March 13, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>American Missionary Labaree was murdered near Urumia, Persia, 9th instant. Motive
                    apparently robbery. Government, at my request, has ordered search for criminal
                    and prompt punishment.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Pearson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
