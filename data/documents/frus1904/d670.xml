    <text>
        <body>
            <div frus:doc-dateTime-max="1904-06-11T23:59:59-05:00"
                frus:doc-dateTime-min="1904-06-11T00:00:00-05:00" n="670"
                subtype="historical-document" type="document" xml:id="d670">
                <head>
                    <hi rend="italic">The <gloss type="from">King of Portugal</gloss> to President
                            <persName type="to">Roosevelt</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lisbon</hi>
                        </placeName>, <date calendar="gregorian" when="1904-06-11">
                            <hi rend="italic">June 11, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>Had to-day the great pleasure of proposing your health at luncheon on board the
                        <hi rend="italic">Kearsarge</hi>. American men-of-war are always welcome in
                    Portuguese waters.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">King of Portugal.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
