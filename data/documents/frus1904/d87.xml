                subtype="historical-document" type="document" xml:id="d87">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Conger</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1904-02-10">
                            <hi rend="italic">February 10, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Conger reports that the representatives of France, Germany, Great Britain,
                    and Italy have asked their respective governments that an agreement be suggested
                    to the belligerents not to send any of their troops into Chihli.)</p>
            </div>
