                subtype="historical-document" type="document" xml:id="d687">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Loomis</persName> to Mr. <persName
                            type="to">McCormick</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-03-19">
                            <hi rend="italic">March 19, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>Your telegram 19th reporting arrival from Irkutsk of 12 destitute Japanese
                    received. Japanese minister has requested our protection for these refugees.
                    Your action approved by Department.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Loomis</hi>, <hi rend="italic">Acting.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
