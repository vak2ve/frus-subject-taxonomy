                subtype="historical-document" type="document" xml:id="d707">
                <head>
                    <hi rend="italic">Mr. <persName type="from">McCormick</persName> to Mr.
                            <persName type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">St. Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1904-06-30">
                            <hi rend="italic">June 30, 1904</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 164.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In compliance with your instruction No. 92, of
                    April 1, 1904, I have the honor to inform you that I have forwarded to the
                    Japanese minister at Berlin a list of Japanese prisoners of war transmitted to
                    me by the imperial ministry for foreign affairs.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert S. McCormick.</hi>
                    </signed>
                </closer>
            </div>
        </body>
