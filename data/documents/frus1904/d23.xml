    <text>
        <body>
            <div frus:doc-dateTime-max="1904-10-10T23:59:59-05:00"
                frus:doc-dateTime-min="1904-10-10T00:00:00-05:00" n="23"
                subtype="historical-document" type="document" xml:id="d23">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Iddings</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">Rome, Italy</hi>
                        </placeName>, <date calendar="gregorian" when="1904-10-10">
                            <hi rend="italic">October 10, 1904</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 413.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In compliance with your unnumbered instruction of
                    September 23, 1904, I beg leave to send you herewith a copy of the Official
                    Gazette of February 11, 1904, containing the neutrality proclamation issued by
                    the Italian Government after the beginning of the war between Japan and
                        Russia.<note n="a" xml:id="d23fna">Not printed. The proclamation is
                        expressed in the same terms as the proclamation of April 25, 1898, printed
                        in <ref target="frus1898#pg_874">Foreign Relations 1898, page 874</ref> et
                        seq.</note>
                </p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lewis Morris Iddings.</hi>
                    </signed>
                </closer>
            </div>
        </body>
