                subtype="historical-document" type="document" xml:id="d703">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">McCormick</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-05-11">
                            <hi rend="italic">May 11, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Hay informs Mr. McCormick that the Japanese Government have no objection to
                    the use of the Japanese consular buildings at Vladivostok for Red Cross purposes
                    by the Russian authorities.)</p>
            </div>
