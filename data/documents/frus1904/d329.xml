                subtype="historical-document" type="document" xml:id="d329">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Sir <persName
                            type="to">Mortimer Durand</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-12-01">
                            <hi rend="italic">December 1, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Excellency</hi>: I have the honor to inform you that
                    the President has designated Rear-Admiral Charles Henry Davis, of the United
                    States Navy, an officer of great learning and high distinction, to serve on the
                    court of inquiry.</p>
                <p>Very sincerely, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
