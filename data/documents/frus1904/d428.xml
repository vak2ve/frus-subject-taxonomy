                subtype="historical-document" type="document" xml:id="d428">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Takahira</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-06-23">
                            <hi rend="italic">June 23, 1904</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 152.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to your note, No. 37, of the 23d
                    ultimo, I have the honor to inform you that the Department is in receipt of a
                    telegram, dated the 22d instant, from the United States ambassador at St.
                    Petersburg, reporting that the viceroy declines, for considerations pertaining
                    to the state of war, to grant the request of your Government that the crew of
                    the <hi rend="italic">Hagino-ura Maru</hi> be returned to Japan.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
