<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1904-06-25T23:59:59-05:00" frus:doc-dateTime-min="1904-06-25T00:00:00-05:00" n="273" subtype="historical-document" type="document" xml:id="d273">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Porter</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1904-06-25"><hi rend="italic">June 25,
                                1904</hi></date>.</dateline></opener>
                        <p>(Mr. Hay instructs Mr. Porter to convey to the minister for foreign
                            affairs the deep appreciation of the President of the kindly and
                            efficient cooperation of the French Government in effecting the rescue
                            of Mr. Perdicaris.)</p>
                    </div>
                </body></text></TEI>