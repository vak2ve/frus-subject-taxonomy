                subtype="historical-document" type="document" xml:id="d757">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr. <persName
                            type="to">McCormick</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-09-16">
                            <hi rend="italic">September 16, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Adee requests Mr. McCormick to send to the Department without delay the
                    answer of the minister for foreign affairs to Mr. McCormick’s notes
                    communicating Department’s Nos. 143 and 144.)</p>
            </div>
        </body>
