                subtype="historical-document" type="document" xml:id="d402">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Takahira</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Japan</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-02-20">
                            <hi rend="italic">February 20, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: I beg to acknowledge the
                    receipt of your letter of yesterday’s date conveying the gratifying intelligence
                    that the Government of Russia had responded favorably to the proposal to limit
                    the zone of military activities in the war between Japan and Russia so far as
                    Chinese territories are concerned. Please accept my cordial thanks for your
                    kindness in informing me of this gratifying result of the wise and benevolent
                    policy of your Government.</p>
                <p>Believe, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">K. Takahira.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
