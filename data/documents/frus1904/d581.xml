<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1904-09-13T23:59:59-05:00" frus:doc-dateTime-min="1904-09-13T00:00:00-05:00" n="581" subtype="historical-document" type="document" xml:id="d581">
                        <head><hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr.
                                    <persName type="to">Barrett</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1904-09-13"><hi rend="italic">September 13,
                                    1904</hi></date>.</dateline></opener>
                        <p>(Mr. Adee informs Mr. Barrett that Haass has been in Panama for some
                            time, and that it is expected that he will be at the Hotel Gran Central
                            to-day.)</p>
                    </div>
                    </body></text></TEI>