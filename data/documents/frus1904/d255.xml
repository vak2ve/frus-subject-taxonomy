                subtype="historical-document" type="document" xml:id="d255">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr. <persName
                            type="to">Dawson</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-08-31">
                            <hi rend="italic">August 31, 1904</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 20.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                    dispatch No. 14, of the 13th instant, inclosing correspondence in relation to
                    the imprisonment of Francisco Martinez, a Porto Rican, at Macoris, and to inform
                    you that your course in the case is approved by the Department.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alvey A. Adee</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
