                subtype="historical-document" type="document" xml:id="d150">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Loomis</persName> to Mr. <persName
                            type="to">Conger</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-07-15">
                            <hi rend="italic">July 15, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>Etzel money should be transmitted to the Department and not to family. So
                    instruct Ragsdale.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Loomis.</hi>
                    </signed>
                </closer>
            </div>
        </body>
