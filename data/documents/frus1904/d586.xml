<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1904-11-19T23:59:59-05:00" frus:doc-dateTime-min="1904-11-19T00:00:00-05:00" n="586" subtype="historical-document" type="document" xml:id="d586">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Lee</persName>.</hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1904-11-19"><hi rend="italic">November, 19,
                                    1904</hi></date>.</dateline>
                            <seg rendition="#left">No. 27.]</seg></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I inclose herewith a certified copy of the
                            indictment and sentence in the case of Herman E. Haass for transmission
                            to the Panaman Government, in accordance with the request made by that
                            Government at the time of the surrender of the accused.</p>
                        <p>I am, etc.,</p>
                        <closer><signed><hi rend="smallcaps">John Hay.</hi></signed></closer>
                    </div>
                </body></text></TEI>