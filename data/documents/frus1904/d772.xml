<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1904-10-24T23:59:59-05:00" frus:doc-dateTime-min="1904-10-24T00:00:00-05:00" n="772" subtype="historical-document" type="document" xml:id="d772">
                            <head><hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr.
                                        <persName type="to">Eddy</persName>.</hi></head>
                            <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1904-10-24"><hi rend="italic">October 24,
                                        1904</hi></date>.</dateline></opener>
                            <p>(Mr. Adee instructs Mr. Eddy to advise and assist American claimants
                                concerning claims arising from the seizure and confiscation of goods
                                by Russian authorities.)</p>
                        </div>
                        </body></text></TEI>