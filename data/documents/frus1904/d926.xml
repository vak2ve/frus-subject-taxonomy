                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr. <persName
                            type="to">Ruffin.</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-08-15">
                            <hi rend="italic">August 15, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>Consulate should not be used as an asylum for political refugees.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Adee.</hi>
                    </signed>
                </closer>
            </div>
