                subtype="historical-document" type="document" xml:id="d602">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Russell</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Panama</hi>
                        </placeName>, <date calendar="gregorian" when="1904-05-21">
                            <hi rend="italic">May 21, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Russell reports that he has received written reply from the Government of
                    Panama accepting terms of the United States relating to the payment of the canal
                    indemnity to J. P. Morgan.)</p>
            </div>
