                subtype="historical-document" type="document" xml:id="d202">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Squiers</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-03-01">
                            <hi rend="italic">March 1, 1904</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 347.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your No.
                    853, of the 12th ultimo, regarding the outrage on the United States consulate at
                    Cienfuegos.</p>
                <p>In reply I have to say that in view of the apologies made and the precautions
                    taken to prevent a repetition of the insult, the Department is of opinion that
                    the incident may be regarded as closed. * * *</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
