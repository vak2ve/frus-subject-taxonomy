<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1904-09-30T23:59:59-05:00" frus:doc-dateTime-min="1904-09-30T00:00:00-05:00" n="240" subtype="historical-document" type="document" xml:id="d240">
                        <head><hi rend="italic">Mr. <persName type="from">Dawson</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Santo
                                        Domingo</hi></placeName>, <date calendar="gregorian" when="1904-09-30"><hi rend="italic">September 30,
                                    1904</hi></date>.</dateline></opener>
                        <p>(Mr. Dawson reports that the Dominican Government refuses to recognize
                            the award unless 60 per cent of the custom receipts are reserved for
                            administrative expenditures.)</p>
                    </div>
                    </body></text></TEI>