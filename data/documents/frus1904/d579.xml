<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1904-09-08T23:59:59-05:00" frus:doc-dateTime-min="1904-09-08T00:00:00-05:00" n="579" subtype="historical-document" type="document" xml:id="d579">
                        <head><hi rend="italic">Mr. <persName type="from">Barrett</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Panama</hi></placeName>, <date calendar="gregorian" when="1904-09-08"><hi rend="italic">September 8,
                                    1904</hi></date>.</dateline></opener>
                        <p>Panama Government agrees as act of comity to entertain request for
                            surrender of fugitive.</p>
                        <closer><signed><hi rend="smallcaps">Barrett.</hi></signed></closer>
                    </div>
                    </body></text></TEI>