    <text>
        <body>
            <div frus:doc-dateTime-max="1904-05-25T23:59:59-05:00"
                frus:doc-dateTime-min="1904-05-25T00:00:00-05:00" n="344"
                subtype="historical-document" type="document" xml:id="d344">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Léger</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-05-25">
                            <hi rend="italic">May 25, 1904</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 76.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 7th instant, in which you inclose drafts of a treaty of
                    extradition between the United States and Haiti and of a treaty of amity between
                    the same parties.</p>
                <p rend="center">* * * * * * *</p>
                <p>The Department will, at an early date, again communicate with you on the subject
                    of the treaty of amity.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
