<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1904-10-24T23:59:59-05:00" frus:doc-dateTime-min="1904-10-24T00:00:00-05:00" n="156" subtype="historical-document" type="document" xml:id="d156">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Conger</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1904-10-24"><hi rend="italic">October 24,
                                1904</hi></date>.</dateline></opener>
                        <p>(Mr. Hay authorizes Mr. Conger to accept the proposal of the Chinese
                            Government when the other powers signify their acceptance.)</p>
                    </div>
