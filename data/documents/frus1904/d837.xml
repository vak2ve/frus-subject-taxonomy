<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1904-06-24T23:59:59-05:00" frus:doc-dateTime-min="1904-06-24T00:00:00-05:00" n="837" subtype="historical-document" type="document" xml:id="d837">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Hardy</persName>.</hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1904-06-24"><hi rend="italic">June 24,
                                1904</hi></date>.</dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                            No. 233 of the 7th instant, transmitting the first of exchange on New
                            York to the order of the International Ocean Telegraph Company for
                            $10,003.46, in payment of its claim against Spain.</p>
                        <p>I am, etc.,</p>
                        <closer><signed><hi rend="smallcaps">John Hay.</hi></signed></closer>
                    </div>
                </body></text></TEI>