                <head>
                    <hi rend="italic">Mr. <persName type="from">Gummeré</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Consulate-General</hi>,<lb/>
                            <hi rend="italic">Tangier</hi>
                        </placeName>, <date calendar="gregorian" when="1904-05-30">
                            <hi rend="italic">May 30, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Gummeré reports the arrival of the American man-of-war <hi rend="italic"
                        >Brooklyn</hi>, and that there have been no further developments.)</p>
            </div>
        </body>
