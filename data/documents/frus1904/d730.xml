                subtype="historical-document" type="document" xml:id="d730">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Eddy</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">St. Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1904-07-28">
                            <hi rend="italic">July 28, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>Steamship <hi rend="italic">Ardova</hi> was released two days ago.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Eddy.</hi>
                    </signed>
                </closer>
            </div>
        </body>
