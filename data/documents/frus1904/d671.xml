                subtype="historical-document" type="document" xml:id="d671">
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to the
                            <gloss type="to">King of Portugal</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">White House</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-06-13">
                            <hi rend="italic">June 13, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>I thank Your Majesty most sincerely for all your courtesy to me and generous
                    hospitality to our fleet, and beg to express my best wishes and those of the
                    American people for the health and happiness of Your Majesty, and the prosperity
                    of the people of Portugal.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
