<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1904-05-22T23:59:59-05:00" frus:doc-dateTime-min="1904-05-22T00:00:00-05:00" n="492" subtype="historical-document" type="document" xml:id="d492">
                        <head><hi rend="italic">Mr. <persName type="from">Loomis</persName> to Mr.
                                    <persName type="to">Gummeré</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1904-05-22"><hi rend="italic">May 22,
                                1904</hi></date>.</dateline></opener>
                        <p>(Mr. Loomis instructs Mr. Gummeré to work actively in behalf of Mr.
                            Perdicaris and to forward full reports of any progress that may be
                            made.)</p>
                    </div>
