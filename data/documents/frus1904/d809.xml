                subtype="historical-document" type="document" xml:id="d809">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Eddy</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">St. Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1904-07-20">
                            <hi rend="italic">July 20, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Eddy reports that he has communicated Department’s telegram of the 18th
                    instant to the minister for foreign affairs, and that three days will be
                    required for a formal answer.)</p>
            </div>
