                        <head><hi rend="italic">Mr. <persName type="from">Finch</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Montevideo</hi></placeName>, <date calendar="gregorian" when="1904-09-12"><hi rend="italic">September 12,
                                    1904</hi></date>.</dateline></opener>
