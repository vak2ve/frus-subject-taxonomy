                subtype="historical-document" type="document" xml:id="d529">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to <persName
                            type="to">Baron Gevers</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-02-16">
                            <hi rend="italic">February 16, 1904</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Minister</hi>: Mr. Hay has requested me to
                    communicate to you the accompanying memorandum in response to the inquiry you
                    made of him this morning in regard to the Japanese proclamation of coal as
                    contraband of war.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alvey A. Adee.</hi>
                    </signed>
                </closer>
            </div>
        </body>
