                subtype="historical-document" type="document" xml:id="d492">
                <note rend="inline" type="source">740.00119 European War 1939/1348: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Spain</hi> (<persName type="from">
                        <hi rend="italic">Hayes</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1943-03-21T14:00:00+01:00"
                            >March 21, 1943—2 p.m.</date>
                        <lb/> [Received 9:30 p.m.]</dateline>
                </opener>
                <p>W6. Argentine Ambassador<note n="2" xml:id="d492fn2">Alberto Palacios
                        Costa.</note> informs me that Rumanian Minister<note n="3" xml:id="d492fn3"
                        >Nicolas Dimitresco.</note> on behalf of his Government yesterday requested
                    him and Portuguese Ambassador<note n="4" xml:id="d492fn4">Pedro Teotonio
                        Pereira.</note> to serve as intermediaries in communicating Rumania’s desire
                    to make peace with United Nations at earliest possible moment.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hayes</hi>
                    </signed>
                </closer>
            </div>
        </body>
