<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-09-28T22:00:00-05:00" frus:doc-dateTime-min="1943-09-28T22:00:00-05:00" n="696" subtype="historical-document" type="document" xml:id="d696">
                    <note rend="inline" type="source">740.00119 MPC/9b: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss>
                            to the Ambassador in the United Kingdom</hi> (<persName type="to"><hi rend="italic">Winant</hi></persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1943-09-28T23:00:00-04:00">September 28,
                                1943—11 p.m.</date>
                        </dateline>
                    </opener>
                    <p>5974. The President has appointed Mr. Edwin C. Wilson, presently Ambassador
                        to Panama, as the representative of this Government on the Mediterranean
                        Commission.</p>
                    <p>Please inform the appropriate authorities.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Berle</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>