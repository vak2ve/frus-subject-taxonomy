    <text>
        <body>
            <div frus:doc-dateTime-max="1943-04-08T07:00:00-05:00"
                frus:doc-dateTime-min="1943-04-08T07:00:00-05:00" n="276"
                subtype="historical-document" type="document" xml:id="d276">
                <note rend="inline" type="source">852.48/1489: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Spain</hi> (<persName type="from">
                        <hi rend="italic">Hayes</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1943-04-08T13:00:00+01:00"
                            >April 8, 1943—1 p.m.</date>
                        <lb/> [Received April 8—12:35 p.m.]</dateline>
                </opener>
                <p>844. My 793, April 1, midnight. Foreign Office has given oral assurances refugees
                    who succeed in entering Spain will not be returned to France.</p>
                <p>Repeated to Algiers for Murphy.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hayes</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
