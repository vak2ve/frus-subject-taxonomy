<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-04-24T21:00:00-05:00" frus:doc-dateTime-min="1943-04-24T21:00:00-05:00" n="130" subtype="historical-document" type="document" xml:id="d130">
                    <note rend="inline" type="source">548.G1/55: Telegram</note>
                    <head>
                        <hi rend="italic">The Consul General at Hamilton</hi> (<persName type="from"><hi rend="italic">Beck</hi></persName>) <hi rend="italic">to the
                                <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Hamilton, Bermuda</hi></placeName>, <date calendar="gregorian" when="1943-04-24T22:00:00-04:00">April 24,
                                1943—10 p.m.</date>
                            <lb/> [Received April 25—2:29 a.m.]</dateline>
                    </opener>
                    <p>140. For Long from Dodds. Draft proposal regarding Intergovernmental
                        Committee tentatively accepted today in general with only language
                        modifications. Will telegraph final draft when approved. [Dodds.]</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Beck</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>