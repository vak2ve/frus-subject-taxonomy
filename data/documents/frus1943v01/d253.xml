<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-03-25T13:00:00-05:00" frus:doc-dateTime-min="1943-03-25T13:00:00-05:00" n="253" subtype="historical-document" type="document" xml:id="d253">
                    <note rend="inline" type="source">852.48/1453: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            Minister in Portugal</hi> (<persName type="to"><hi rend="italic">Fish</hi></persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1943-03-25T14:00:00-04:00">March 25,
                                1943—2 p.m.</date>
                        </dateline>
                    </opener>
                    <p>501. Madrid’s 704, March 24 repeated to you. You are requested to address a
                        letter to Salazar concerning the transit of refugees from Spain in
                        accordance with Ambassador Hayes’ suggestion.</p>
                    <p>Repeat to Madrid.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Hull</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>