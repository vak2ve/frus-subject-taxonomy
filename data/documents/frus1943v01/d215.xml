<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-12-29T23:59:59-05:00" frus:doc-dateTime-min="1943-12-29T00:00:00-05:00" n="215" subtype="historical-document" type="document" xml:id="d215">
                    <note rend="inline" type="source">840.48 Refugees/4926: Telegram</note>
                    <head>
                        <hi rend="italic">The Ambassador in the United Kingdom</hi> (<persName type="from"><hi rend="italic">Winant</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1943-12-29">December 29,
                            1943</date>.<lb/>[Received December 29—11:19 a.m.]</dateline>
                    </opener>
                    <p>9034. Director states that December 28th Soviet Embassy informed him that
                        Soviet Government accepts membership in Intergovernmental Committee on
                        Refugees.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Winant</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>