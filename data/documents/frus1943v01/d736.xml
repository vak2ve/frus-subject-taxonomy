<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-03-29T14:00:00-05:00" frus:doc-dateTime-min="1943-03-29T14:00:00-05:00" n="736" subtype="historical-document" type="document" xml:id="d736">
                    <note rend="inline" type="source">550.AD1/15: Telegram</note>
                    <head>
                        <hi rend="italic">The Chargé in the United Kingdom</hi> (<persName type="from"><hi rend="italic">Matthews</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1943-03-29T20:00:00+01:00">March 29,
                                1943—8 p.m.</date>
                            <lb/> [Received March 29—6:30 p.m.]</dateline>
                    </opener>
                    <p>2236. Department’s telegram number 1819, March 24, midnight.<note n="12" xml:id="d736fn12">See footnote 10, <ref target="#pg_824">p.
                            824</ref>.</note> The Prime Minister informs me that the British
                        Government has no objection to inviting the four countries concerned.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Matthews</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>