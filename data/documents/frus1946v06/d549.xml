                subtype="historical-document" type="document" xml:id="d549">
                <note rend="inline" type="source">861.458/11–646: Telegram</note>
                <head>
                    <hi rend="italic">President <persName type="from">Truman</persName> to the
                        Chairman of the Presidium of the Supreme Council of the Soviet Union</hi>
                        (<persName type="to">
                        <hi rend="italic">Shvernik</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1946-11-06">November 6,
                            1946</date>.</dateline>
                </opener>
                <p>The people of the United States join me on the national anniversary of the Union
                    of Soviet Socialist Republics in expressing to Your Excellency and to the people
                    of the Soviet Union congratulations and best wishes.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Harry S. Truman</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
