        <body>
            <div frus:doc-dateTime-max="1946-01-22T23:59:59-05:00" frus:doc-dateTime-min="1946-01-22T00:00:00-05:00" n="569" subtype="historical-document" type="document" xml:id="d569">
                <note rend="inline" type="source">861.24/1–2246</note>
                <head>
                    <hi rend="italic">The Chairman of the Government Purchasing Commission of the
                        Soviet Union in the U.S.A</hi>. (<persName type="from">
                        <hi rend="italic">Rudenko</hi>
                    </persName>) <hi rend="italic">to Mr. <persName type="to">Willard L.
                            Thorp</persName>, Deputy to the Assistant Secretary of State for
                        Economic Affairs</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1946-01-22">January 22,
                            1946</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Thorp</hi>: With reference to your letter of
                    January 4, 1946, I wish to state that the question raised in your letter is
                    beyond the competence of the Government Purchasing Commission of the Soviet
                    Union in the U.S.A.</p>
                <p>Sincerely yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">L. Rudenko</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
