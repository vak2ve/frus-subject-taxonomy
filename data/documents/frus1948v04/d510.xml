<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Acting Secretary of State to
                        the Legation in Finland</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1948v04</bibl><bibl type="frus-document-id">d510</bibl><bibl type="frus-document-number">510</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1948-04-21T14:00:00-05:00" notAfter="1948-04-21T14:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1948-04-21T14:00:00-05:00" frus:doc-dateTime-min="1948-04-21T14:00:00-05:00" n="510" subtype="historical-document" type="document" xml:id="d510">
                <note rend="inline" type="source">760D.6111/4–1648: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">Legation in Finland</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1948-04-21T14:00:00-05:00">April 21, 1948—2 p. m.</date>
                    </dateline>
                </opener>
                <p>92. At least until fully informed as to possible unpublished protocols Dept does
                    not expect to comment on pact (<gloss target="#t_Legtel1">Legtel</gloss> 251 Apr
                        16<note n="1" xml:id="d510fn1">Not printed.</note>) and in any case does not
                    desire influence Finnish decision on ratification.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lovett</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
