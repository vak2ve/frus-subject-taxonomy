    <teiHeader><fileDesc><titleStmt><title>The Ambassador in the Soviet Union (
                        Smith
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1948v04</bibl><bibl type="frus-document-id">d553</bibl><bibl type="frus-document-number">553</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1948-04-12T09:00:00-05:00" notAfter="1948-04-12T09:00:00-05:00"/></setting></settingDesc>            <textClass>
                <keywords scheme="frus-subject-taxonomy">
                    <term ref="recf388f47d4e50787" type="topic" category="department-of-state" subcategory="buildings-foreign" subject="embassy">Embassy</term>
                </keywords>
