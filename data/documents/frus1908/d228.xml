<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1908-06-20T23:59:59-05:00" frus:doc-dateTime-min="1908-06-20T00:00:00-05:00" n="228" subtype="historical-document" type="document" xml:id="d228">
                        <note rend="inline" type="source">File No. 13739/2.</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Minister <persName type="to">Fox</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1908-06-20"><hi rend="italic">June 20,
                                1908</hi></date>.</dateline></opener>
                        <p>(Mr. Adee directs Mr. Fox to convey to the minister for foreign affairs
                            department’s congratulations on the completion of the railway to
                            Quito.)</p>
                    </div>
