    <text>
        <body>
            <div frus:doc-dateTime-max="1908-06-19T23:59:59-05:00"
                frus:doc-dateTime-min="1908-06-19T00:00:00-05:00" n="171"
                subtype="historical-document" type="document" xml:id="d171">
                <note rend="inline" type="source">File No. 10388/25–26.</note>
                <head>
                    <hi rend="italic">Consul General <persName type="from">Denby</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Consulate General</hi>,<lb/>
                            <hi rend="italic">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1908-06-19">
                            <hi rend="italic">June 19, 1908</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 209.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that the Chinese
                    Government has paid to me the amount claimed for damages to American citizens on
                    account of the Shanghai riots of December, 1905, the aggregate of the claims
                    amounting to $889.73, United States currency.</p>
                <p>In pursuance of the department’s telegraphic instructions of June 1, I inclose
                    herewith a draft on the International Banking Corporation of New York for
                    $889.73, the amount above stated.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Chas. Denby.</hi>
                    </signed>
                </closer>
            </div>
        </body>
