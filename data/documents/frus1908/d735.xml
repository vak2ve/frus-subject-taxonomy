    <text>
        <body>
            <div frus:doc-dateTime-max="1907-08-06T23:59:59-05:00"
                frus:doc-dateTime-min="1907-08-06T00:00:00-05:00" n="735"
                subtype="historical-document" type="document" xml:id="d735">
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Minister <persName type="to">Russell</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-08-06">
                            <hi rend="italic">August 6, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>Answering yours July 27, you will present formal proposal for arbitration,
                    following instruction No 90.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bacon.</hi>
                    </signed>
                </closer>
            </div>
        </body>
