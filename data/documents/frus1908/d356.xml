<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1908-09-20T23:59:59-05:00" frus:doc-dateTime-min="1908-09-20T00:00:00-05:00" n="356" subtype="historical-document" type="document" xml:id="d356">
                        <note rend="inline" type="source">File No. 6775/573.</note>
                        <head><hi rend="italic">President <persName type="from">Roosevelt</persName>
                                to the <gloss type="to">President of Guatemala</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">The
                                        White House</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1908-09-20"><hi rend="italic">September 20,
                                    1908</hi></date>.</dateline></opener>
                        <p>It affords me pleasure to acknowledge your telegram and to convey my
                            congratulations upon the auspicious inauguration of the international
                            Central American Bureau.</p>
                        <closer><signed><hi rend="smallcaps">Theodore
                            Roosevelt.</hi></signed></closer>
                    </div>
                    </body></text></TEI>