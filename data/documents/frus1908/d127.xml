<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1908-11-16T23:59:59-05:00" frus:doc-dateTime-min="1908-11-16T00:00:00-05:00" n="127" subtype="historical-document" type="document" xml:id="d127">
                        <note rend="inline" type="source">File No. 14911/8.</note>
                        <head><hi rend="italic">Minister <persName type="from">Rockhill</persName>
                                to the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Peking</hi></placeName>, <date calendar="gregorian" when="1908-11-16"><hi rend="italic">November 16,
                                    1908</hi></date>.</dateline></opener>
                        <p>It is officially stated that the Empress Dowager died yesterday
                            afternoon, 2.45.</p>
                        <closer><signed><hi rend="smallcaps">Rockhill.</hi></signed></closer>
                    </div>
                    </body></text></TEI>