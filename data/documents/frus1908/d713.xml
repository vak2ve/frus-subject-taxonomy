                subtype="historical-document" type="document" xml:id="d713">
                <note rend="inline" type="source">File No. 10044/101.</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Leishman</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">Constantinople</hi>
                        </placeName>, <date calendar="gregorian" when="1908-12-04">
                            <hi rend="italic">December 4, 1908</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="italic">Scorpion</hi> arrived to-day.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Leishman.</hi>
                    </signed>
                </closer>
            </div>
        </body>
