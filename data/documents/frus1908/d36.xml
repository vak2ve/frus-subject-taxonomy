<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1908-01-03T23:59:59-05:00" frus:doc-dateTime-min="1908-01-03T00:00:00-05:00" n="36" subtype="historical-document" type="document" xml:id="d36">
                        <note rend="inline" type="source">File No. 836/86.</note>
                        <head><hi rend="italic">Ambassador <persName type="from">Dudley</persName>
                                to the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Embassy</hi>,<lb/><hi rend="italic">Petropolis</hi></placeName>, <date calendar="gregorian" when="1908-01-03"><hi rend="italic">January 3,
                                1908</hi></date>.</dateline></opener>
                        <p>Brazilian Congress continues during 1908 existing 20 per cent tariff
                            reduction favor United States.</p>
                        <closer><signed><hi rend="smallcaps">Dudley.</hi></signed></closer>
