<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1908-05-02T23:59:59-05:00" frus:doc-dateTime-min="1908-05-02T00:00:00-05:00" n="482" subtype="historical-document" type="document" xml:id="d482">
                        <note rend="inline" type="source">File No. 13329/1–3.</note>
                        <head><hi rend="italic">The <gloss type="from">Emperor of Japan</gloss> to
                                President <persName type="to">Roosevelt</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Tokyo</hi></placeName>, <date calendar="gregorian" when="1908-05-02"><hi rend="italic">May 2,
                                1908</hi></date>.</dateline></opener>
                        <p>The great sympathy which you have so earnestly expressed on account of
                            the terrible disaster to our warship <hi rend="italic">Matsushima</hi>
                            has touched me very deeply, and I hope you will accept for yourself and
                            the American people my sincere thanks.</p>
                        <closer><signed><hi rend="smallcaps">Mutsuhito.</hi></signed></closer>
                    </div>
                    </body></text></TEI>