<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1908-08-01T23:59:59-05:00" frus:doc-dateTime-min="1908-08-01T00:00:00-05:00" n="79" subtype="historical-document" type="document" xml:id="d79">
                        <note rend="inline" type="source">File No. 774/273A.</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Ambassador <persName type="to">O’Brien</persName>.</hi><note n="1" xml:id="d79fn1">Repeated to
                                Great Britain, France, Germany, Netherlands, Portugal,
                            China.</note></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1908-08-01"><hi rend="italic">August 1,
                                1908</hi></date>.</dateline></opener>
                        <p>(Mr. Adee directs Mr. O’Brien to inform the minister for foreign affairs
                            that Charles D. Brent replaces Thomas Burke as senior American
                            commissioner on Joint International Opium Commission.)</p>
                    </div>
                    </body></text></TEI>