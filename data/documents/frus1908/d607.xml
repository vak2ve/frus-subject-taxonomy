                subtype="historical-document" type="document" xml:id="d607">
                <note rend="inline" type="source">File No. 2151/106.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Spanish Minister</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>
                            <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1908-01-20">
                            <hi rend="italic">January 20, 1908</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Minister</hi>: In accordance with my oral
                    promise, I send you inclosed a memorandum in reply to yours of the 17th instant,
                    concerning measures which your Government may find itself obliged to take in
                    Morocco.</p>
                <p>Faithfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Elihu Root.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
