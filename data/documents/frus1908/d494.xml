                subtype="historical-document" type="document" xml:id="d494">
                <note rend="inline" type="source">File No. 15984/13.</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">O’Brien</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1908-12-17">
                            <hi rend="italic">December 17, 1908</hi>
                        </date>.</dateline>
                </opener>
                <p>Abe case. Favorable action by court Dalny. Prisoner being conveyed Yokohama for
                    delivery to Hawaiian officer on board steamship <hi rend="italic">China</hi>
                    sailing 23d.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">O’Brien.</hi>
                    </signed>
                </closer>
            </div>
        </body>
