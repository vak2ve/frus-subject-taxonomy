<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1908-09-20T23:59:59-05:00" frus:doc-dateTime-min="1908-09-20T00:00:00-05:00" n="354" subtype="historical-document" type="document" xml:id="d354">
                        <note rend="inline" type="source">File No. 6775/575.</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the <gloss type="to">Minister of Foreign
                                    Affairs of Guatemala</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1908-09-20"><hi rend="italic">September 20,
                                    1908</hi></date>.</dateline></opener>
                        <p>Accept appreciative acknowledgment of your gratifying telegram reporting
                            the inauguration of the international bureau.</p>
                        <closer><signed><hi rend="smallcaps">Adee.</hi></signed></closer>
                    </div>
                    </body></text></TEI>