<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1908-01-20T23:59:59-05:00" frus:doc-dateTime-min="1908-01-20T00:00:00-05:00" n="31" subtype="historical-document" type="document" xml:id="d31">
                        <note rend="inline" type="source">File No. 11502/3–4.</note>
                        <head><hi rend="italic">Minister <persName type="from">Wilson</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Brussels</hi></placeName>, <date calendar="gregorian" when="1908-01-20"><hi rend="italic">January 20,
                                1908</hi></date>.</dateline>
                            <seg rendition="#left">No. 283.]</seg></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have the honor to transmit herewith, for
                            the information of the department, a triplicate copy, in the original
                                texts,<note n="1" xml:id="d31fn1">Not printed.</note> of a treaty of
                            commerce between Belgium and Servia.</p>
                        <p>I have, etc.,</p>
                        <closer><signed><hi rend="smallcaps">Henry Lane
                            Wilson.</hi></signed></closer>
                        <postscript>
                            <p rend="center">[SEE ALSO KONGO, <ref target="#pg_537">P.
                                537</ref>.]</p>
                        </postscript>
                    </div>
                </body></text></TEI>