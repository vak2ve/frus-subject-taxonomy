    <text>
        <body>
            <div frus:doc-dateTime-max="1908-01-07T23:59:59-05:00"
                frus:doc-dateTime-min="1908-01-07T00:00:00-05:00" n="322"
                subtype="historical-document" type="document" xml:id="d322">
                <note rend="inline" type="source">File No. 10793/1.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Guatemalan Minister</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1908-01-07">
                            <hi rend="italic">January 7, 1908</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 14.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that in acceptance
                    of the invitation extended by the Government of Guatemala, the President has
                    commissioned Maj. Gen. George W. Davis, United States Army, retired, to be envoy
                    extraordinary and minister plenipotentiary on special mission as the
                    representative of the United States at the ceremonies attending the formal
                    opening of the Interoceanic Railway of Guatemala on the 15th of this month.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Elihu Root.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
