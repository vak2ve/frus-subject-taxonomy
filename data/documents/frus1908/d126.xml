    <text>
        <body>
            <div frus:doc-dateTime-max="1908-11-15T23:59:59-05:00"
                frus:doc-dateTime-min="1908-11-15T00:00:00-05:00" n="126"
                subtype="historical-document" type="document" xml:id="d126">
                <note rend="inline" type="source">File No. 1518/176.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Chinese Minister</gloss> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Imperial Chinese Legation</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1908-11-15">
                            <hi rend="italic">November 15, 1908</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 13.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that by an
                    Imperial edict, issued by Her Imperial Majesty the Empress Dowager, P’u-yi, the
                    eldest son of His Imperial Highness Prince Ch’un, has been appointed on the
                    demise of Sis Imperial Majesty the Emperor Kuanghsu, to <pb facs="0219" n="117"
                        xml:id="pg_117"/> succeed to the throne as the August Sovereign of China,
                    and His Highness Prince Ch’un as Regent of the Empire.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wu Ting Fang.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
