<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1908-11-16T23:59:59-05:00" frus:doc-dateTime-min="1908-11-16T00:00:00-05:00" n="130" subtype="historical-document" type="document" xml:id="d130">
                        <note rend="inline" type="source">File No. 14911/7.</note>
                        <head><hi rend="italic">The <gloss type="from">Chinese Minister</gloss> to
                                the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Imperial Chinese Legation</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1908-11-16"><hi rend="italic">November 16,
                                    1908</hi></date>.</dateline>
                            <seg rendition="#left">No. 14.]</seg></opener>
                        <p><hi rend="smallcaps">Sir</hi>: It is with very great sorrow that I have
                            further to announce to you the demise of Her Imperial Majesty the
                            Empress Dowager, which occurred in Peking at 2 o’clock yesterday
                            afternoon (November 14).</p>
                        <p>Accept, etc.,</p>
                        <closer><signed><hi rend="smallcaps">Wu Ting Fang.</hi></signed></closer>
                    </div>
                    </body></text></TEI>