                subtype="historical-document" type="document" xml:id="d530">
                <head>
                    <hi rend="italic">Minister <persName type="from">Wilson</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Brussels</hi>
                        </placeName>, <date calendar="gregorian" when="1908-03-26">
                            <hi rend="italic">March 26, 1908</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 316.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to the department’s cablegram of March
                    19, I have the honor to report that until this time the British legation at
                    Brussels has received no instructions of the kind referred to therein.</p>
                <p>Should the British minister submit any propositions for a concerted action to me,
                    I will immediately cable them fully.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Henry Lane Wilson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
