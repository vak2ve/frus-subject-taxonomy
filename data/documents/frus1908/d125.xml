    <text>
        <body>
            <div frus:doc-dateTime-max="1908-11-15T23:59:59-05:00"
                frus:doc-dateTime-min="1908-11-15T00:00:00-05:00" n="125"
                subtype="historical-document" type="document" xml:id="d125">
                <note rend="inline" type="source">File No. 14911/6.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Chinese Minister</gloss> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Imperial Chinese Legation</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1908-11-15">
                            <hi rend="italic">November 15, 1908</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 12.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: It is my very sad duty to announce to you the
                    demise of His Imperial Majesty Kuanghsu, the Emperor of China, which occurred in
                    Peking at 5 o’clock yesterday afternoon (November 14).</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wu Ting Fang.</hi>
                    </signed>
                </closer>
            </div>
        </body>
