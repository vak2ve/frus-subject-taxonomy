    <text>
        <body>
            <div frus:doc-dateTime-max="1908-06-17T23:59:59-05:00"
                frus:doc-dateTime-min="1908-06-17T00:00:00-05:00" n="170"
                subtype="historical-document" type="document" xml:id="d170">
                <note rend="inline" type="source">File No. 10388/27.</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Rockhill</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1908-06-17">
                            <hi rend="italic">June 17, 1908</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 943.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In continuation of the legation’s No. 818 of
                    January 22 last, I have the honor to inform you that the payment of the American
                    claims on account of the 1905 riots at Shanghai has been made in full <pb
                        facs="0253" n="151" xml:id="pg_151"/> by the local Chinese officials to the
                    consul general there, who informs me that he has forwarded same to the
                    department as instructed.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. R. Rockhill.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
