                subtype="historical-document" type="document" xml:id="d113">
                <note rend="inline" type="source">File No. 774/415.</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">O’Brien</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1908-11-27">
                            <hi rend="italic">November 27, 1908</hi>
                        </date>.</dateline>
                </opener>
                <p>Your telegram of the 20th. There is no objection on the part of the Government of
                    Japan to the proposed postponement.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">O’Brien.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
