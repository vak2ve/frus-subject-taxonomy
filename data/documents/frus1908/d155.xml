                subtype="historical-document" type="document" xml:id="d155">
                <note rend="inline" type="source">File No. 4992/49.</note>
                <head>
                    <hi rend="italic">Chargé <persName type="from">Fletcher</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1908-01-24">
                            <hi rend="italic">January 24, 1908</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 830.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In continuation of my No. 803,<note n="1"
                        xml:id="d155fn1">Not printed.</note> of the 6th instant, I have the honor to
                    report that on the 22d instant, in pursuance of the department’s <pb facs="0236"
                        n="134" xml:id="pg_134"/> instructions, Horace G. McKinley was delivered by
                    the consul general at Tientsin into the custody of J. F. Kerrigan, the agent of
                    the Department of Justice, who had been sent to receive him. Mr. Kerrigan left
                    Tientsin with his charge on the same day.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Henry P. Fletcher.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
