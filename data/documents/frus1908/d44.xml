                        <opener><seg rendition="#center">[Telegram.—Extract.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Bucharest</hi></placeName>, <date calendar="gregorian" when="1908-10-05"><hi rend="italic">October 5,
