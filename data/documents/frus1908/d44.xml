                <note rend="inline" type="source">File No. 5072/14.</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Knowles</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Extract.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Bucharest</hi>
                        </placeName>, <date calendar="gregorian" when="1908-10-05">
                            <hi rend="italic">October 5, 1908</hi>
                        </date>.</dateline>
                </opener>
                <p>Bulgaria proclaimed her independence to-day.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Knowles.</hi>
                    </signed>
                </closer>
            </div>
        </body>
