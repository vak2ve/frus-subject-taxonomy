<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1908-06-18T23:59:59-05:00" frus:doc-dateTime-min="1908-06-18T00:00:00-05:00" n="226" subtype="historical-document" type="document" xml:id="d226">
                        <note rend="inline" type="source">File No. 13739/2.</note>
                        <head><hi rend="italic">Minister <persName type="from">Fox</persName> to the
                                    <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Quito</hi></placeName>, <date calendar="gregorian" when="1908-06-18"><hi rend="italic">June 18,
                                1908</hi></date>.</dateline></opener>
                        <p>Railway reached Quito yesterday. Golden spike driven by America Alfaro,
                            President’s daughter.</p>
                        <closer><signed><hi rend="smallcaps">Fox.</hi></signed></closer>
                    </div>
                    </body></text></TEI>