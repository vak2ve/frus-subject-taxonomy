                subtype="historical-document" type="document" xml:id="d325">
                <note rend="inline" type="source">751G.94/384: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Japan</hi> (<persName type="to">
                        <hi rend="italic">Grew</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1941-10-06T17:00:00-05:00"
                            >October 6, 1941—5 p.m.</date>
                    </dateline>
                </opener>
                <p>641. With reference to recent developments in Japanese activity within and in
                    relation to French Indochina, the Department continues to hold the view
                    expressed in its telegram no. 441, July 29, 11 p.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
