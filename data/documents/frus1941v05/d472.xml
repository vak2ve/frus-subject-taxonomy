<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-09-01T23:59:59-05:00" frus:doc-dateTime-min="1941-09-01T00:00:00-05:00" n="472" subtype="historical-document" type="document" xml:id="d472">
                    <note rend="inline" type="source">394.1115/74: Telegram</note>
                    <head>
                        <hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from"><hi rend="italic">Lockhart</hi></persName>) <hi rend="italic">to
                            the <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Shanghai</hi></placeName>, <date calendar="gregorian" when="1941-09-01">September 1,
                            1941</date>.<lb/>[Received September 1—2:30 a.m.]</dateline>
                    </opener>
                    <p>1194. Fifty-nine Americans reached Shanghai August 30th aboard <hi rend="italic">Tatuta Maru</hi>, including 10 Foreign Service personnel,
                        9 Army officers, 4 Navy officers, 1 Navy wife and 1 Navy child.</p>
                    <p>Huffman and Smith sailed <hi rend="italic">Garfield</hi> today for
                        Bombay.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Lockhart</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>