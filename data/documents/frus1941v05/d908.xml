                subtype="historical-document" type="document" xml:id="d908">
                <note rend="inline" type="source">893.102S/2455: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chungking</hi>
                        </placeName>, <date calendar="gregorian" when="1941-04-08T10:00:00+07:00"
                            >April 8, 1941—10 a.m.</date>
                        <lb/> [Received April 8—9:06 a.m.]</dateline>
                </opener>
                <quote rend="blockquote">
                    <p>“The decision of the Chinese Government communicated to you on April 4<note
                            n="97" xml:id="d908fn1">See telegram of April 4, 6 p.m., <ref
                                target="#pg_844">p. 844</ref>.</note> was based upon the assumption
                        that the provisions of the land regulations concerning the number and
                        nationality of the councilors would be suspended for a period not exceeding
                        2 years.”</p>
                </quote>
                <p>Sent to Shanghai, repeated to Department and Peiping.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
