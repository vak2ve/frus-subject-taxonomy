    <text>
        <body>
            <div frus:doc-dateTime-max="1941-03-22T16:00:00-05:00"
                frus:doc-dateTime-min="1941-03-22T16:00:00-05:00" n="647"
                subtype="historical-document" type="document" xml:id="d647">
                <note rend="inline" type="source">893.248/215: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Consul General at Hong Kong</hi> (<persName type="to">
                        <hi rend="italic">Southard</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1941-03-22T16:00:00-05:00"
                            >March 22, 1941—4 p.m.</date>
                    </dateline>
                </opener>
                <p>63. For Lieutenant Colonel Mayer<note n="15" xml:id="d647fn1">Military Attaché in
                        China.</note> from War Department.</p>
                <p>Your 99, March 15, noon,<note n="16" xml:id="d647fn2">Not printed.</note> one
                    hundred American planes are being <pb facs="0624" n="614" xml:id="pg_614"/>
                    allotted by the British to China. War Department knows nothing of date of
                    shipment or American pilots. Additional information will be furnished when
                    available.</p>
                <p>Sent to Hong Kong. Repeated to Chungking.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Welles</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
