<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-07-31T22:00:00-05:00" frus:doc-dateTime-min="1943-07-31T22:00:00-05:00" n="659" subtype="historical-document" type="document" xml:id="d659">
                    <note rend="inline" type="source">125.385/29: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            Chargé in China</hi> (<persName type="to"><hi rend="italic">Atcheson</hi></persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1943-07-31T23:00:00-04:00">July 31,
                                1943—11 p.m.</date>
                        </dateline>
                    </opener>
                    <p>1003. Regret not practicable to reopen Consulate at or near Foochow now.
                        Please so inform committee mentioned your 1241 of July 21.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Hull</hi>
                        </signed>
                    </closer>
                </div>
            </body></text></TEI>