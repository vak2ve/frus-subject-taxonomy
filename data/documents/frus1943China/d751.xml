<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-11-22T23:59:59-05:00" frus:doc-dateTime-min="1943-11-22T00:00:00-05:00" n="751" subtype="historical-document" type="document" xml:id="d751">
                    <note rend="inline" type="source">893.001 Chiang Kai-shek/12</note>
                    <head>
                        <hi rend="italic">Memorandum of Conversation, by the Secretary of State</hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">[<placeName><hi rend="smallcaps">Washington</hi></placeName>,] <date calendar="gregorian" when="1943-11-22">November 22, 1943</date>.</dateline>
                    </opener>
                    <p>The Chinese Ambassador called under instructions of General Chiang Kai-shek
                        to extend to me the most hearty and sincere congratulations of the
                        Generalissimo for my aid to China at Moscow.</p>
                    <closer>
                        <signed>C[<hi rend="smallcaps">ordell</hi>] H[<hi rend="smallcaps">ull</hi>]</signed>
                    </closer>
                </div>
            </body></text></TEI>