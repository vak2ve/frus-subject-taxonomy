<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-07-31T16:00:00-05:00" frus:doc-dateTime-min="1943-07-31T16:00:00-05:00" n="399" subtype="historical-document" type="document" xml:id="d399">
                        <note rend="inline" type="source">893.51/7701: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in China</hi> (<persName type="to"><hi rend="italic">Atcheson</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1943-07-31T17:00:00-04:00">July 31,
                                    1943—5 p.m.</date>
                            </dateline>
                        </opener>
                        <p>997. Your 1329, July 29 and Department’s 967, July 26. For Adler from the
                            Secretary of the Treasury. Re TF–144, July 29.</p>
                        <list>
                            <label>1.</label>
                            <item>The day you receive this message you should submit your
                                resignation as of then.</item>
                            <label>2.</label>
                            <item>The above information has been communicated to the British in
                                Washington. [Morgenthau.]</item>
                        </list>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>