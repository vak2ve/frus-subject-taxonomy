                subtype="historical-document" type="document" xml:id="d253">
                <note rend="inline" type="source">811.43 Institute of Pacific Relations/198:
                    Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in China</hi> (<persName type="to">
                        <hi rend="italic">Atcheson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-08-26T18:00:00-04:00"
                            >August 26, 1943—6 p.m.</date>
                    </dateline>
                </opener>
                <p>1186. Your 1552, August 24, 3 p.m. Regarding visitors’ expression of interest in
                    the Communist situation, for Embassy’s guidance, Department has approved views
                    expressed in a recent OWI directive that the less discussion there is currently
                    of Kuomintang-Communist difficulties and problem the better.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
