                <note rend="inline" type="source">893.24/1490: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Gauss</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-01-23T19:00:00-04:00"
                            >January 23, 1943—7 p.m.</date>
                    </dateline>
                </opener>
                <p>123. Your 82, January 16, 10 a.m. The Department has referred this matter to the
                    War Department with the request that every effort be made to supply at least the
                    minimum needs of C.N.A.C.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
