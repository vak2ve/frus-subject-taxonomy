<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-01-23T18:00:00-05:00" frus:doc-dateTime-min="1943-01-23T18:00:00-05:00" n="596" subtype="historical-document" type="document" xml:id="d596">
                    <note rend="inline" type="source">893.24/1490: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            Ambassador in China</hi> (<persName type="to"><hi rend="italic">Gauss</hi></persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1943-01-23T19:00:00-04:00">January 23,
                                1943—7 p.m.</date>
                        </dateline>
                    </opener>
                    <p>123. Your 82, January 16, 10 a.m. The Department has referred this matter to
                        the War Department with the request that every effort be made to supply at
                        least the minimum needs of C.N.A.C.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Hull</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>