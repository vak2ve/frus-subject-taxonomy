                subtype="historical-document" type="document" xml:id="d126">
                <head>126. Memorandum From the President’s Assistant for National Security Affairs
                        (<persName corresp="#p_KHA1" type="from">Kissinger</persName>) to President
                        <persName corresp="#p_NRM1" type="to">Nixon</persName>
                    <note n="1" type="source" xml:id="d126fn1">Source: National Archives, <persName
                            corresp="#p_NRM1">Nixon</persName> Presidential Materials, <gloss
                            target="#t_NSC1">NSC</gloss> Files, <gloss target="#t_NSC1">NSC</gloss>
                        Institutional Files (H-Files), Box H–26, <gloss target="#t_NSC1">NSC</gloss>
                        Meeting, February 11, 1970. Secret; Nodis. <persName>Richard
                            Kennedy</persName> of the <gloss target="#t_NSC1">NSC</gloss> Staff
                        forwarded the memorandum to <persName corresp="#p_KHA1">Kissinger</persName>
                        under a February 10 covering memorandum for <persName corresp="#p_KHA1"
                            >Kissinger</persName>’s review.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1970-02-06">February 6, 1970</date>.</dateline>
                </opener>
                <p>[Source: National Archives, <persName corresp="#p_NRM1">Nixon</persName>
                    Presidential Materials, <gloss target="#t_NSC1">NSC</gloss> Files, Box 275,
                    Agency Files, <gloss target="#t_PFIAB1">PFIAB</gloss>, Vol. III. Top Secret;
                    Code word. 5 pages not declassified.]</p>
            </div>
