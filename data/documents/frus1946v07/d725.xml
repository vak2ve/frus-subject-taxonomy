    <text>
        <body>
            <div frus:doc-dateTime-max="1946-11-13T17:00:00-05:00"
                frus:doc-dateTime-min="1946-11-13T17:00:00-05:00" n="725"
                subtype="historical-document" type="document" xml:id="d725">
                <note rend="inline" type="source">195.2/11–1346: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Turkey</hi> (<persName type="to">
                        <hi rend="italic">Wilson</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">confidential</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1946-11-13T17:00:00-05:00"
                            >November 13, 1946—5 p.m.</date>
                    </dateline>
                </opener>
                <p>749. National Advisory Council Nov 6 approved action advising Maritime Commission
                    that <gloss target="#t_NAC1">NAC</gloss> no objection Commission consider
                    extension approx $5 million credit Turkey for purchase six ships.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Acheson</hi>
                    </signed>
                </closer>
            </div>
        </body>
