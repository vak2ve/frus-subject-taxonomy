                <head>No. 316.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName> to Mr. <persName
                            type="to">Jackson</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1886-07-19">
                            <hi rend="italic">July</hi> 19, 1886</date>.</dateline>
                </opener>
                <p>You are instructed to demand of the Mexican Government the instant release of A.
                    K. Cutting, a citizen of the United States, now unlawfully imprisoned at Paso
                    del Norte.</p>
                <closer>
                    <signed>BAYARD.</signed>
                </closer>
            </div>
        </body>
