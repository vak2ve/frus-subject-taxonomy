                subtype="historical-document" type="document" xml:id="d220">
                <head>No. 216.<lb/>
                    <hi rend="italic">The <gloss type="from">President</gloss> to the <gloss
                            type="to">Queen</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Executive Mansion</hi>, <hi rend="italic"
                                >Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1886-09-04">
                            <hi rend="italic">September</hi> 4, 1886</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">To Victoria</hi>, <hi rend="italic">Queen and Empress,
                        Balmoral, Scotland:</hi>
                </p>
                <p>Your Majesty’s expression of sympathy for the sufferers by the earthquake is
                    warmly appreciated and awakes grateful response in American hearts.</p>
                <closer>
                    <signed>GROVER CLEVELAND,<lb/>
                        <hi rend="italic">President.</hi>
                    </signed>
                </closer>
            </div>
        </body>
