    <text>
        <body>
            <div frus:doc-dateTime-max="1886-09-11T23:59:59-05:00" frus:doc-dateTime-min="1886-09-11T00:00:00-05:00" n="222" subtype="historical-document" type="document" xml:id="d222">
                <head>No. 218.<lb/>
                    <hi rend="italic">Sir <persName type="from">L.
                                    West</persName> to Mr. <persName type="to">Bayard</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1886-09-11">
                            <hi rend="italic">September</hi> 11,
                                    1886</date>. (Received September 14.)</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your note of yesterday’s date calling attention to the case
                            of the Mollie Adams.</p>
                <p>I have, &amp;c.,</p>
                <closer>
                    <signed>L. S. SACKVILLE WEST.</signed>
                </closer>
            </div>
        </body>
