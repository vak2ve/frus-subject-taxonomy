    <text>
        <body>
            <div frus:doc-dateTime-max="1886-09-25T23:59:59-05:00" frus:doc-dateTime-min="1886-09-25T00:00:00-05:00" n="283" subtype="historical-document" type="document" xml:id="d283">
                <head>No. 279.<lb/>
                    <hi rend="italic">King <persName type="from">Kaldkaua</persName> to the <gloss type="to">President</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram received at the Executive Mansion
                            from San Francisco, Cal, October 2, 1886.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Honolulu</hi>
                        </placeName>, <date calendar="gregorian" when="1886-09-25">
                            <hi rend="italic">September</hi> 25,
                            1886</date>.</dateline>
                </opener>
                <p>I desire to convey through you my heartfelt sympathy for the sufferers by the
                        great earthquakes which have devastated so many homes.</p>
                <closer>
                    <signed>KALAKAUA.</signed>
                </closer>
            </div>
        </body>
    </text>
