                subtype="historical-document" type="document" xml:id="d152">
                <head>No. 148.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName> to Mr. <persName
                            type="to">Roustan</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1886-05-10">
                            <hi rend="italic">May</hi> 10, 1886</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 28th ultimo, inclosing a copy of a notice published by the
                    Government of France to the effect that persons having claims on account of
                    damages suffered during the recent conflict between the French Government and
                    the Hova Government should present the same with the documentary evidence in
                    support thereof.</p>
                <p>Accept, sir, &amp;c.,</p>
                <closer>
                    <signed>T. F. BAYARD.</signed>
                </closer>
            </div>
        </body>
    </text>
