    <text>
        <body>
            <div frus:doc-dateTime-max="1886-02-16T23:59:59-05:00" frus:doc-dateTime-min="1886-02-16T00:00:00-05:00" n="69" subtype="historical-document" type="document" xml:id="d69">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Owyang Ming</persName> to
                                Mr. <persName type="to">Cheng</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San
                                        Francisco</hi>
                        </placeName>,<lb/>
                        <date calendar="gregorian" when="1886-02-16">
                            <hi rend="italic">February</hi> 16,
                                    1886</date>. (Received February 19.)</dateline>
                </opener>
                <p>Petition from Chinese merchants resident in Portland, Oreg., asking
                            protection against threatened outrages, forwarded to you to-day;
                            immediate action asked.</p>
                <closer>
                    <signed>OWYANG MING.</signed>
                </closer>
            </div>
        </body>
