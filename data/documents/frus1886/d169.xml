                subtype="historical-document" type="document" xml:id="d169">
                <head>No. 165.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName> to Mr. <persName
                            type="to">Phelps</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1886-05-11">
                            <hi rend="italic">May</hi> 11, 1886</date>.</dateline>
                    <seg rendition="#left">No. 289.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: With reference to your telegram of the 9th
                    instant, in regard to the fisheries question, I transmit to you herewith a copy
                    of a note which I addressed to Sir Lionel West yesterday on the subject.</p>
                <p>I am, &amp;c.,</p>
                <closer>
                    <signed>T. F. BAYARD.</signed>
                </closer>
                <frus:attachment>
                    <opener>
                        <seg rendition="#center">[Inclosure No. 289.]</seg>
                    </opener>
                    <dateline>[<date ana="#date_undated-inferred-from-document-content"
                            calendar="gregorian" when="1886-05-10">May 10, 1886</date>]</dateline>
                    <p>Mr. Bayard to Sir L. West, May 10, 1886.<note n="*" xml:id="d169fn1">For
                            inclosure see 183, p. .)</note>
                    </p>
                </frus:attachment>
            </div>
        </body>
    </text>
