                <head>No. 319.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr. <persName
                            type="to">Jackson</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1886-07-22">
                            <hi rend="italic">July</hi> 22, 1886</date>.</dateline>
                </opener>
                <p>Summarize reasons briefly by telegraph.</p>
                <closer>
                    <signed>ADEE,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
