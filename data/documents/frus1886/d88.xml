<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1884-12-30T23:59:59-05:00" frus:doc-dateTime-min="1884-12-30T00:00:00-05:00" n="88" subtype="historical-document" type="document" xml:id="d88">
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <head>No. 84.<lb/><hi rend="italic">Mr. <persName type="from">Davis</persName>
                            to Mr. <persName type="to">Beach</persName>.</hi></head>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department
                                    of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1884-12-30"><hi rend="italic">December</hi> 30,
                            1884</date>.</dateline></opener>
                    <p>Julio Romano Santos, American, imprisoned at Guayaquil. Urge speedy and fair
                        trial.</p>
                    <closer><signed>DAVIS.</signed></closer>
                </div>
                </body></text></TEI>