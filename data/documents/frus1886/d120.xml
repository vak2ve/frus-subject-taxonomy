                subtype="historical-document" type="document" xml:id="d120">
                <head>No. 116.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Beach</persName> to Mr. <persName
                            type="to">Bayard.</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guayaquil</hi>
                        </placeName>, <date calendar="gregorian" when="1885-07-13">
                            <hi rend="italic">July</hi> 13, 1885</date>. (Received July
                        13.)</dateline>
                </opener>
                <p rend="flushleft">Secretary <hi rend="smallcaps">Bayard</hi>, <hi rend="italic"
                        >Washington:</hi>
                </p>
                <p>President telegraphed yesterday, saying order by mail to governor Manibi for
                    Santos’s release.</p>
                <closer>
                    <signed>BEACH.</signed>
                </closer>
            </div>
        </body>
