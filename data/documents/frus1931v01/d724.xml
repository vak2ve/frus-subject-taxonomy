<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1931-03-30T04:00:00-05:00" frus:doc-dateTime-min="1931-03-30T04:00:00-05:00" n="724" subtype="historical-document" type="document" xml:id="d724">
                        <note rend="inline" type="source">711.632/101: Telegram</note>
                        <head><hi rend="italic">The Minister in Austria</hi> (<persName type="from"><hi rend="italic">Stockton</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Vienna</hi></placeName>, <date calendar="gregorian" when="1931-03-30T10:00:00+01:00">March 30, 1931—10
                                a.m.</date><lb/>[Received March 30—7:14 a.m.]</dateline></opener>
                        <p>24. Your 13, March 28, 2 p.m.<note n="16" xml:id="d724fn16">Not
                                printed.</note> Austrian President will ratify supplemental article
                            and reservation next week. Urge American instrument be sent me
                            immediately as Austrian Government will be prepared to effect exchange
                            as soon as it reaches me.</p>
                        <closer><signed><hi rend="smallcaps">Stockton</hi></signed></closer>
                    </div>
                    </body></text></TEI>