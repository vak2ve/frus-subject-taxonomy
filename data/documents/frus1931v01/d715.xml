    <text>
        <body>
            <div frus:doc-dateTime-max="1930-11-25T11:00:00-05:00"
                frus:doc-dateTime-min="1930-11-25T11:00:00-05:00" n="715"
                subtype="historical-document" type="document" xml:id="d715">
                <note rend="inline" type="source">711.632/76: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Austria</hi> (<persName type="from">
                        <hi rend="italic">Stockton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1930-11-25T17:00:00+01:00"
                            >November 25, 1930—5 p.m.</date>
                        <lb/>[Received November 25—2:20 p.m.]</dateline>
                </opener>
                <p>61. My despatch 95, September 2.<note n="12" xml:id="d715fn12">Not
                        printed.</note> New Parliament will convene December 2. Request instructions
                    concerning treaty.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stockton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
