    <text>
        <body>
            <div frus:doc-dateTime-max="1931-11-04T04:00:00-05:00"
                frus:doc-dateTime-min="1931-11-04T04:00:00-05:00" n="184"
                subtype="historical-document" type="document" xml:id="d184">
                <note rend="inline" type="source">462.00R296/5266: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Latvia</hi> (<persName type="from">
                        <hi rend="italic">Cole</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Riga</hi>
                        </placeName>, <date calendar="gregorian" when="1931-11-04T11:00:00+02:00"
                            >November 4, 1931—11 a.m.</date>
                        <lb/>[Received 12:10 p.m.]</dateline>
                </opener>
                <p>48. Department’s 38, October 24, 2 p.m. Estonian Government wholeheartedly
                    appreciate this important action of the President of the United States and
                    accepts unconditionally. Despatch follows.<note n="24" xml:id="d184fn24">Not
                        printed.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cole</hi>
                    </signed>
                </closer>
            </div>
        </body>
