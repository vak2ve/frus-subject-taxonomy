                subtype="historical-document" type="document" xml:id="d653">
                <note rend="inline" type="source">715.1715/426: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Honduras</hi> (<persName type="from">
                        <hi rend="italic">Lay</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1931-02-10T10:00:00-06:00"
                            >February 10, 1931—10 a.m.</date>
                        <lb/>[Received 1:45 p.m.]</dateline>
                </opener>
                <p>32. My telegram No. 25, February 3, 10 a.m.<note n="14c" xml:id="d653fn14c">Not
                        printed.</note> Honduran Congress after third and final reading and some
                    discussion ratified yesterday, by unanimous vote and without reservations, the
                    Honduran Nicaraguan boundary protocol.</p>
                <p>Repeated to Managua.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lay</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
