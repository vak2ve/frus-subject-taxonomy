<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1931-11-05T23:59:59-05:00" frus:doc-dateTime-min="1931-11-05T00:00:00-05:00" n="807" subtype="historical-document" type="document" xml:id="d807">
                        <note rend="inline" type="source">825.001 Montero, Juan/7</note>
                        <head><hi rend="italic">The Chargé in Chile</hi> (<persName type="from"><hi rend="italic">Norweb</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Santiago</hi></placeName>, <date calendar="gregorian" when="1931-11-05">November 5, 1931</date>.<lb/>[Received
                                November 14.]</dateline>
                            <seg rendition="#left">No. 1013</seg></opener>
                        <p><hi rend="smallcaps">Sir</hi>: In the event that the Department desires
                            to transmit a message of congratulation for President-elect Montero, I
                            have the honor to report that the inauguration will take place on
                            December 5th.</p>
                        <p>Respectfully yours,</p>
                        <closer><signed><hi rend="smallcaps">R. Henry Norweb</hi></signed></closer>
                    </div>
                    </body></text></TEI>