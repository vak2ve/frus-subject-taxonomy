                subtype="historical-document" type="document" xml:id="d553">
                <note rend="inline" type="source">810.154/359: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Honduras</hi> (<persName type="from">
                        <hi rend="italic">Higgins</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1931-10-28T17:00:00-06:00"
                            >October 28, 1931—5 p.m.</date>
                        <lb/>[Received 10:50 p.m.]</dateline>
                </opener>
                <p>177. Department’s instruction No. 188 October 15, 1931.<note n="45"
                        xml:id="d553fn45">See footnote 44a, <ref target="#pg_712">p.
                        712</ref>.</note> Permission granted for aerial surveys for Inter-American
                    Highway.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Higgins</hi>
                    </signed>
                </closer>
            </div>
        </body>
