<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1931-07-27T17:00:00-05:00" frus:doc-dateTime-min="1931-07-27T17:00:00-05:00" n="783" subtype="historical-document" type="document" xml:id="d783">
                        <note rend="inline" type="source">825.01/47: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Ambassador in Chile</hi> (<persName type="to"><hi rend="italic">Culbertson</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1931-07-27T18:00:00-04:00">July 27, 1931—6
                                p.m.</date></dateline></opener>
                        <p>31. Your 82, July 27, noon. Department concurs in the view that no
                            recognition of new Chilean Government is necessary.</p>
                        <closer><signed><hi rend="smallcaps">Castle</hi></signed></closer>
                    </div>
                    </body></text></TEI>