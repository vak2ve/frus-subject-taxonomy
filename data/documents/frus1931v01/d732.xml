                subtype="historical-document" type="document" xml:id="d732">
                <note rend="inline" type="source">711.632/116: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Austria</hi> (<persName type="from">
                        <hi rend="italic">Stockton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1931-05-27T11:00:00+01:00"
                            >May 27, 1931—11 a.m.</date>
                        <lb/>[Received May 27—8:40 a.m.]</dateline>
                </opener>
                <p>42. Ratifications exchanged this morning. Austrian instruments will be forwarded
                    by pouch today.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stockton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
