                subtype="historical-document" type="document" xml:id="d151">
                <note rend="inline" type="source">462.00R296/4607</note>
                <head>
                    <hi rend="italic">The Czechoslovak Minister</hi> (<persName type="from">
                        <hi rend="italic">Veverka</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1931-07-15">July 15,
                            1931</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honour to communicate herewith that
                    the Government of the Czechoslovak Republic accepts with great pleasure, both as
                    creditor and debtor, the principles of the moratorium proposed by His
                    Excellency, President Hoover.</p>
                <p>In accepting this proposal of the United States the Czechoslovak Government
                    expresses its firm hope that it will mark the beginning of the economic revival
                    of the world.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Ferdinand Veverka</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
