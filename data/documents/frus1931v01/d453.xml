                subtype="historical-document" type="document" xml:id="d453">
                <note rend="inline" type="source">760C.60K/124: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Danzig</hi> (<persName type="from">
                        <hi rend="italic">Perkins</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Danzig</hi>
                        </placeName>, <date calendar="gregorian" when="1931-04-16T12:00:00+01:00"
                            >April 16, 1931—noon</date>.<lb/>[Received April 16—9 a.m.]</dateline>
                </opener>
                <p>The Department’s April 15, 5 p.m., has been received.</p>
                <p>Invitation will not be accepted and probably will not be issued as the Senate is
                    reported to be unwilling to accept the proposal.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Perkins</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
