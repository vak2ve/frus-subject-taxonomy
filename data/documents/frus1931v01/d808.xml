<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1931-11-16T09:00:00-05:00" frus:doc-dateTime-min="1931-11-16T09:00:00-05:00" n="808" subtype="historical-document" type="document" xml:id="d808">
                        <note rend="inline" type="source">825.001 Montero, Juan/8: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Chile</hi> (<persName type="from"><hi rend="italic">Culbertson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Santiago</hi></placeName>, <date calendar="gregorian" when="1931-11-16T10:00:00-04:00">November 16, 1931—10
                                    a.m.</date><lb/>[Received November 16—10
                            a.m.]</dateline></opener>
                        <p>139. Montero reassumed Vice Presidency yesterday. Balmaceda, Minister of
                            Foreign Affairs; Izquierdo, Minister of Hacienda.</p>
                        <closer><signed><hi rend="smallcaps">Culbertson</hi></signed></closer>
                    </div>
