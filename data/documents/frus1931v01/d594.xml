                        <note rend="inline" type="source">724.3415/1272: Telegram</note>
                        <head><hi rend="italic">The Chargé in Paraguay</hi> (<persName type="from"><hi rend="italic">Horn</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Acting Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Asunción</hi></placeName>, <date calendar="gregorian" when="1931-07-05T10:00:00-03:50">July 5, 1931—10
