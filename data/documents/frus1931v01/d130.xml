                subtype="historical-document" type="document" xml:id="d130">
                <note rend="inline" type="source">462.00R296/4478: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Belgium</hi> (<persName type="from">
                        <hi rend="italic">Gibson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Brussels</hi>
                        </placeName>, <date calendar="gregorian" when="1931-07-14T23:00:00+01:00"
                            >July 14, 1931—11 p.m.</date>
                        <lb/>[Received July 15—5:43 a.m.]</dateline>
                </opener>
                <p>83. Reference is made to my telegram No. 79, July 13, 10 a.m.<note n="73"
                        xml:id="d130fn73">Not printed.</note> The Belgian Legation at Berlin has
                    informed the Belgian Government that discussions with regard to Belgian-German
                    questions have been initiated in Berlin by the German Government. These
                    conversations will be continued at London.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gibson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
