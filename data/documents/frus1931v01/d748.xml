<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1931-12-10T13:00:00-05:00" frus:doc-dateTime-min="1931-12-10T13:00:00-05:00" n="748" subtype="historical-document" type="document" xml:id="d748">
                        <note rend="inline" type="source">832.802 Lloyd Brasileiro Navigation
                            Co./44: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Brazil</hi> (<persName type="to"><hi rend="italic">Morgan</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1931-12-10T13:00:00-05:00">December 10, 1931—1
                                p.m.</date></dateline></opener>
                        <p>96. Please report briefly by telegraph in reply to the Department’s
                            instruction No. 1662 of August 27, 1931, relative to the discount on
                            consular fees to shippers by the Lloyd Brasileiro Navigation
                            Company.</p>
                        <closer><signed><hi rend="smallcaps">Stimson</hi></signed></closer>
                    </div>
                    </body></text></TEI>