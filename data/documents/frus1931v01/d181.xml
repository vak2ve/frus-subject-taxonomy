    <text>
        <body>
            <div frus:doc-dateTime-max="1931-11-19T23:59:59-05:00"
                frus:doc-dateTime-min="1931-11-19T00:00:00-05:00" n="181"
                subtype="historical-document" type="document" xml:id="d181">
                <note rend="inline" type="source">462.00R296/5323</note>
                <head>
                    <hi rend="italic">The Lithuanian Minister</hi> (<persName type="from">
                        <hi rend="italic">Balutis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1931-11-19">November 19,
                            1931</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sib</hi>: Referring to your communication of October 24,
                        1931,<note n="23" xml:id="d181fn23">Not printed.</note> concerning the
                    postponement of all payments upon the debts of foreign Governments to the
                    American Government payable during the fiscal year beginning July 1, 1931, and a
                    request for a statement of the attitude of the Lithuanian Government with regard
                    to its acceptance of the President’s Proposal, I have the honor to state that I
                    have been instructed by my Government to inform you that the Lithuanian
                    Government is ready to accept the President’s Proposal, as set forth in his
                    statement of June 20, 1931.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">B. K. Balutis</hi>
                    </signed>
                </closer>
            </div>
        </body>
