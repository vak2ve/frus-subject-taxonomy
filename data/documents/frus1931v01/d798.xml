                subtype="historical-document" type="document" xml:id="d798">
                <note rend="inline" type="source">825.00/690: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Chile</hi> (<persName type="from">
                        <hi rend="italic">Culbertson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santiago</hi>
                        </placeName>, <date calendar="gregorian" when="1931-09-06T18:00:00-04:00"
                            >September 6, 1931—6 p.m.</date>
                        <lb/>[Received 7:19 p.m.]</dateline>
                </opener>
                <p>111. Alessandri nominated for the presidency today with almost unanimity by a
                    convention of all the Left parties except the extreme Communists who support
                    Hidalgo. His acceptance would be just another complication.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Culbertson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
