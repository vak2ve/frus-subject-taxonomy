                subtype="historical-document" type="document" xml:id="d718">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Danish Minister</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-05-03">
                            <hi rend="italic">May 3, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Minister</hi>: I take pleasure in confirming what
                    I said to you this morning, that this Government is bound by the text of the
                    treaty as adopted, and that our interpretation of it agrees with that of the
                    Danish Government as set forth in your note of April 18th,</p>
                <p>Very sincerely yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
