                subtype="historical-document" type="document" xml:id="d681">
                <head>
                    <hi rend="italic">Minister <persName type="from">Swenson</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Copenhagen</hi>
                        </placeName>, <date calendar="gregorian" when="1901-10-23">
                            <hi rend="italic">October 23, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>A quarter million dollars more would not satisfy Danish Government. Convention
                    will not be concluded without concessions on points difference and an increase
                    of compensation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Swenson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
