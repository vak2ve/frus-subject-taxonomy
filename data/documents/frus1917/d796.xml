                subtype="historical-document" type="document" xml:id="d796">
                <note rend="inline" type="source">File No. 711.5914/59</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Egan</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Copenhagen</hi>
                        </placeName>, <date calendar="gregorian" when="1916-05-23T12:00:00+02:00">
                            <hi rend="italic">May 23, 1916, noon</hi>
                        </date>.</dateline>
                </opener>
                <p>107. Referring to the Legation’s despatch number 317 of April 10, 1916. The
                    Minister for Foreign Affairs thinks that the time is propitious for presenting
                    the question of the islands here. He believes that the Government of the United
                    States will not object to the Danish Government’s extending their political and
                    economic interests to the whole of Greenland.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Egan</hi>
                    </signed>
                </closer>
            </div>
        </body>
