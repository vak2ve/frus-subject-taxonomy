<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-03-14T11:29:00-05:00" frus:doc-dateTime-min="1917-03-14T11:29:00-05:00" n="586" subtype="historical-document" type="document" xml:id="d586">
                        <note rend="inline" type="source">File No. 337.11/282</note>
                        <head>
                            <hi rend="italic">Minister <persName type="from">Gonzales</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegrams]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Habana</hi></placeName>, <date calendar="gregorian" when="1917-03-14T11:00:00-05:29">
                                    <hi rend="italic">March 14, 1917, 11 a.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>My telegram of March 12, 7 p.m. Van Patton, American Administrator Punta
                            Alegre, has been released.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Gonzales</hi>
                            </signed>
                        </closer>
                    </div>
