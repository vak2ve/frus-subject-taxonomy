<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-07-25T23:59:59-05:00" frus:doc-dateTime-min="1916-07-25T00:00:00-05:00" n="24" subtype="historical-document" type="document" xml:id="d24">
                            <note rend="inline" type="source">File No. 711.7121/2</note>
                            <head>
                                <hi rend="italic">Minister <persName type="from">Vopicka</persName>
                                    to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">American Legation</hi>, <lb/>
                                        <hi rend="italic">Bucharest</hi></placeName>, <date calendar="gregorian" when="1916-07-25">
                                        <hi rend="italic">July 25, 1916</hi></date>.</dateline>
                            </opener>
                            <p>281. Department’s circular April 1. Was assured verbally yesterday at
                                Foreign Office that Seamen’s Act approved and written acceptance
                                would follow shortly.<note n="4" xml:id="d24fn4">No further reply
                                    seems to have been received from the Roumanian
                                    Government.</note>
                            </p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Vopicka</hi>
                                </signed>
                            </closer>
                        </div>
                    </body></text></TEI>