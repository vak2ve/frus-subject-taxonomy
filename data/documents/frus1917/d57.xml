<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-05-14T17:00:00-05:00" frus:doc-dateTime-min="1917-05-14T17:00:00-05:00" n="57" subtype="historical-document" type="document" xml:id="d57">
                        <note rend="inline" type="source">File No. 763.72/4568</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Reinsch</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1917-05-14T17:00:00-05:00">
                                    <hi rend="italic">May 14, 1917, 5 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Your telegram of May 11, 7 p.m. Your action approved. I shall discuss the
                            situation with the British Ambassador.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>