<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-08-25T23:59:59-05:00" frus:doc-dateTime-min="1916-08-25T00:00:00-05:00" n="836" subtype="historical-document" type="document" xml:id="d836">
                            <note rend="inline" type="source">File No. 711.5914/122</note>
                            <head>
                                <hi rend="italic">Consul <persName type="from">Payne</persName> to
                                    the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                        <hi rend="italic">St. Thomas</hi></placeName>, <date calendar="gregorian" when="1916-08-25">
                                        <hi rend="italic">August 25, 1916</hi></date>.</dateline>
                            </opener>
                            <p>By unanimous order local Colonial Council Governor today cabling
                                Copenhagen petitioning immediate sale islands.</p>
                            <closer>
                                <hi rend="smallcaps">American Consul</hi>
                            </closer>
                        </div>
                        </body></text></TEI>