                subtype="historical-document" type="document" xml:id="d27">
                <note rend="inline" type="source">File No. 711.6521/100</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Italian Ambassador</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-03-29">
                            <hi rend="italic">March 29, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My dear Mr. Ambassador</hi>: Referring to Mr. Brambilla’s
                    recent call at the Department, relative to the conflict of the so-called
                    Seamen’s Act, approved March 4, 1915, with certain treaty provisions between
                    this Government and Italy, I beg to transmit, herewith, for your information, a
                    copy of an instruction dated March 23, regarding the matter, which has been sent
                    to the American Ambassador at Rome.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
