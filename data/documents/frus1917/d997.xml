                <note rend="inline" type="source">File No. 838.51/603</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Blanchard</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1917-03-28T18:00:00-05:00">
                            <hi rend="italic">March 28, 1917, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your March 22, 5 p.m. Protocol as amended just signed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blanchard</hi>
                    </signed>
                </closer>
            </div>
        </body>
