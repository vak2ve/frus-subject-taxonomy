                <note rend="inline" type="source">File No. 812.63/348</note>
                <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-02-02T16:00:00-05:00">
                            <hi rend="italic">February 2, 1917, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>647. Your 663, January 30, 4 p.m.<note n="2" xml:id="d1225fn2">Not
                        printed.</note> If Mexican authorities will not consent to withdrawal of
                    decree, Department desires you exercise your very best efforts to have time
                    limit further extended.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
