<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-03-10T23:59:59-05:00" frus:doc-dateTime-min="1917-03-10T00:00:00-05:00" n="1041" subtype="historical-document" type="document" xml:id="d1041">
                        <note rend="inline" type="source">File No. 123G98/32</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Japanese Ambassador</gloss> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Imperial Japanese Embassy</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1917-03-10">
                                    <hi rend="italic">March 10, 1917</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: In pursuance of telegraphic instructions
                            from the Imperial Government I have the honor to express on their behalf
                            the most sincere condolence and sympathy to the United States Government
                            for the lamentable death of his excellency Ambassador George W. Guthrie
                            at Tokyo.</p>
                        <p>Accept [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Atmaro Sato</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>