                <note rend="inline" type="source">File No. 711.5914/54</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Egan</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-04-24T14:00:00-05:00">
                            <hi rend="italic">April 24, 1916, 2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>99. Your 238, April 23, 11 a.m. Please cable complete Danish <hi rend="italic"
                        >contre</hi> proposition.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
