                <note rend="inline" type="source">File No. 812.00/20636</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Fletcher</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Mexico City</hi>
                        </placeName>, <date calendar="gregorian" when="1917-03-12T15:00:00-06:36">
                            <hi rend="italic">March 12, 1917, 3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>20. Carranza elected President yesterday.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Fletcher</hi>
                    </signed>
                </closer>
            </div>
        </body>
