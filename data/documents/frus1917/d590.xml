                subtype="historical-document" type="document" xml:id="d590">
                <note rend="inline" type="source">File No. 337.11/279</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Gonzales</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegrams]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-03-15T20:00:00-05:00">
                            <hi rend="italic">March 15, 1917, 8 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>American interests owning Compañía Química de la Gloria at Colombia, Camaguey
                    Province, request protection for its property, damaged and threatened with
                    destruction. Large stores of general merchandise and provisions have been
                    confiscated.</p>
                <p>You are instructed to demand adequate protection for these American interests
                    from the Cuban Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
