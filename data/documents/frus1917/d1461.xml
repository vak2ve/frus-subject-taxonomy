<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-06-09T23:59:59-05:00" frus:doc-dateTime-min="1917-06-09T00:00:00-05:00" n="1461" subtype="historical-document" type="document" xml:id="d1461">
                        <note rend="inline" type="source">File No. 816.48/7a</note>
                        <head>
                            <hi rend="italic">President <persName type="from">Wilson</persName> to
                                President <persName type="to">Melendez</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">The White House</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1917-06-09">
                                    <hi rend="italic">June 9, 1917</hi></date>.</dateline>
                        </opener>
                        <p>I wish to extend to you my heartfelt sympathy in the terrible disaster
                            that has overtaken El Salvador, and to express, in my own name and that
                            of the American people an earnest desire to render every possible aid
                            and assistance to your country in its distress and to the sufferers from
                            this calamity.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Woodrow Wilson</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>