                subtype="historical-document" type="document" xml:id="d890">
                <note rend="inline" type="source">File No. 839.51/1821</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Russell</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-01-02T16:00:00-05:00">
                            <hi rend="italic">January 2, 1917, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>With reference to conversations at Department it is thought that Military
                    Government may now economize as was suggested.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
