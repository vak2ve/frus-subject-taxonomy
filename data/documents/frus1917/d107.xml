<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-07-02T23:00:00-05:00" frus:doc-dateTime-min="1917-07-02T23:00:00-05:00" n="107" subtype="historical-document" type="document" xml:id="d107">
                        <note rend="inline" type="source">File No. 893.00/2644</note>
                        <head>
                            <hi rend="italic">Consul General <gloss type="from">Sammons</gloss> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate General</hi>, <lb/>
                                    <hi rend="italic">Shanghai</hi></placeName>, <date calendar="gregorian" when="1917-07-03T12:00:00+08:00">
                                    <hi rend="italic">July 3, 1917, noon</hi></date>.</dateline>
                        </opener>
                        <p>Chinese Commissioner of Foreign Affairs states confidently Vice President
                            Feng and all local military and naval forces agree oppose monarchy.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Sammons</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>