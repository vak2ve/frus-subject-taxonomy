                <note rend="inline" type="source">File No. 893.00/2658a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Reinsch</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-07-03T17:00:00-05:00">
                            <hi rend="italic">July 3, 1917, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Does situation require increase of guard or naval protection of Americans in the
                    ports?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
