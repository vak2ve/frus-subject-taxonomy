<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-01-03T18:00:00-05:00" frus:doc-dateTime-min="1917-01-03T18:00:00-05:00" n="225" subtype="historical-document" type="document" xml:id="d225">
                        <note rend="inline" type="source">File No. 893.77/1574</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Reinsch</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1917-01-03T18:00:00-05:00">
                                    <hi rend="italic">January 3, 1917, 6 p.m</hi></date>.</dateline>
                        </opener>
                        <p>Your telegram of December 29, 7 p.m. Department has not been informed
                            result of <hi rend="italic">pourparlers</hi>. Your action approved.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>