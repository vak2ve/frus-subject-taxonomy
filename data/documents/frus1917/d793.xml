                <note rend="inline" type="source">File No. 711.5914/54</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Egan</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Copenhagen</hi>
                        </placeName>, <date calendar="gregorian" when="1916-04-23T11:00:00+01:00">
                            <hi rend="italic">April 23, 1916, 11 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>238. Danish <hi rend="italic">contre projet</hi> on subject of islands received.
                    Shall I cable synopsis?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Egan</hi>
                    </signed>
                </closer>
            </div>
        </body>
