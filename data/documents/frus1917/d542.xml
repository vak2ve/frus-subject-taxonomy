<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-05-10T23:59:59-05:00" frus:doc-dateTime-min="1917-05-10T00:00:00-05:00" n="542" subtype="historical-document" type="document" xml:id="d542">
                        <note rend="inline" type="source">File No. 837.00/1336</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Gonzales</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1917-05-10">
                                    <hi rend="italic">May 10, 1917</hi></date>.</dateline>
                        </opener>
                        <p>Your May 7. Convey to Cuban Government congratulations of this Government
                            in view of proclamation by Cuban Congress of the election of President
                            Menocal and Vice President Nuñez.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>