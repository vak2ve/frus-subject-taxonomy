<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-01-27T17:00:00-05:00" frus:doc-dateTime-min="1917-01-27T17:00:00-05:00" n="1260" subtype="historical-document" type="document" xml:id="d1260">
                        <note rend="inline" type="source">File No. 812.011/19a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Mr. <persName type="to">Parker</persName>, representing American
                                interests</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1917-01-27T17:00:00-05:00">
                                    <hi rend="italic">January 27, 1917, 5 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>638. Telegraph full text Department of Fomento’s latest proposed
                            constitutional amendment relative to nationalization of oil fields.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>