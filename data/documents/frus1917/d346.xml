                <note rend="inline" type="source">File No. 611.9331/43</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Reinsch</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/> [<hi rend="italic"
                                >Peking</hi>
                        </placeName>
                        <date ana="#date_undated-inferred-from-document-content"
                            calendar="gregorian" notAfter="1917-04-05T09:30:00-05:00"
                            notBefore="1917-04-01T00:00:00+08:00">
                            <hi rend="italic">undated</hi>
                        </date>
                        <hi rend="italic">; received April 5, 1917, 9.30 a.m.</hi>]</dateline>
                </opener>
                <p>Revenue Council has issued instructions permitting foreign and Chinese merchants
                    to export flour on payment of forty cents Mexican per bag.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Reinsch</hi>
                    </signed>
                </closer>
            </div>
        </body>
