<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-11-21T05:00:00-05:00" frus:doc-dateTime-min="1917-11-21T05:00:00-05:00" n="296" subtype="historical-document" type="document" xml:id="d296">
                        <note rend="inline" type="source">File No. 893.811/279</note>
                        <head>
                            <hi rend="italic">Minister <persName type="from">Reinsch</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Extract]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Peking</hi></placeName>, <date calendar="gregorian" when="1917-11-21T18:00:00+08:00">
                                    <hi rend="italic">November 21, 1917, 6
                                p.m</hi></date>.</dateline>
                        </opener>
                        <p>Grand Canal contract signed yesterday subject to consent of
                            Parliament.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Reinsch</hi>
                            </signed>
                        </closer>
                    </div>
