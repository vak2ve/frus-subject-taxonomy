                subtype="historical-document" type="document" xml:id="d845">
                <note rend="inline" type="source">File No. 711.5914/140</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Danish Minister</gloss> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Danish Legation</hi>, <lb/>
                            <hi rend="italic">Bar Harbor</hi>
                        </placeName>, <date calendar="gregorian" when="1916-09-08">
                            <hi rend="italic">September 8, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>Your telegram to-day. Accept my warmest congratulations upon the successful
                    passage of our West India Treaty by the Senate of the United States.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Brun</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
