                subtype="historical-document" type="document" xml:id="d565">
                <note rend="inline" type="source">File No. 337.11/169½</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Gonzales</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-02-19T18:00:00-05:00">
                            <hi rend="italic">February 19, 1917, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Counsel for Central Fe near Caibarien informs Department that cane scales and
                    loading station at San Lorenzo destroyed by fire and working of mill
                    prevented.</p>
                <p>Inform Cuban Government of these conditions and request that adequate protection
                    be given to American interests at this point.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
