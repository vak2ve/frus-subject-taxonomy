<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-11-22T14:29:00-05:00" frus:doc-dateTime-min="1915-11-22T14:29:00-05:00" n="629" subtype="historical-document" type="document" xml:id="d629">
                        <note rend="inline" type="source">File No. 837.156/209</note>
                        <head>
                            <hi rend="italic">Minister <persName type="from">Gonzales</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Habana</hi></placeName>, <date calendar="gregorian" when="1915-11-22T14:00:00-05:29">
                                    <hi rend="italic">November 22, 1915, 2 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Court renders decision against Cuban Ports Company leaving company
                            without standing. Five days before copy decision obtainable.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Gonzales</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>