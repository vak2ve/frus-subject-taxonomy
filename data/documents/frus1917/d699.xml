                subtype="historical-document" type="document" xml:id="d699">
                <head>
                    <hi rend="italic">Minister <persName type="from">Swenson</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Copenhagen</hi>
                        </placeName>, <date calendar="gregorian" when="1902-01-15">
                            <hi rend="italic">January 15, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>Brun advises Minister for Foreign Affairs by cable order plebiscite before
                    signing the treaty. Press for immediate signature protesting against such delay
                    and plebiscite as contrary to agreement.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Swenson</hi>
                    </signed>
                </closer>
            </div>
        </body>
