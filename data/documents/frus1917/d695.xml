<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1902-01-02T23:59:59-05:00" frus:doc-dateTime-min="1902-01-02T00:00:00-05:00" n="695" subtype="historical-document" type="document" xml:id="d695">
                        <head>
                            <hi rend="italic">Minister <persName type="from">Swenson</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Copenhagen</hi></placeName>, <date calendar="gregorian" when="1902-01-02">
                                    <hi rend="italic">January 2, 1902</hi></date>.</dateline>
                        </opener>
                        <p>Hold Minister for Foreign Affairs agreement sign the treaty with this
                            understanding: that no plebiscite will be ordered for any purpose.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Swenson</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>