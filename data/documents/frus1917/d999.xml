    <text>
        <body>
            <div frus:doc-dateTime-max="1917-03-29T23:59:59-05:00"
                frus:doc-dateTime-min="1917-03-29T00:00:00-05:00" n="999"
                subtype="historical-document" type="document" xml:id="d999">
                <note rend="inline" type="source">File No. 711.38/120</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Blanchard</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 135</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1917-03-29">
                            <hi rend="italic">March 29, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to my March 28, 6 p.m., I have the
                    honor to forward herewith the original and copy of the Protocol, signed
                        yesterday,<note n="3" xml:id="d999fn3">Printed above.</note> calling into
                    being full force Article XVI of the Convention of September 16, 1915.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">A. Bailly-Blanchard</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
