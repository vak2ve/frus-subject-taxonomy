<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-07-14T15:00:00-05:00" frus:doc-dateTime-min="1917-07-14T15:00:00-05:00" n="120" subtype="historical-document" type="document" xml:id="d120">
                        <note rend="inline" type="source">File No. 893.00/2669</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Minister <persName type="to">Reinsch</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1917-07-14T15:00:00-05:00">
                                    <hi rend="italic">July 14, 1917, 3 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Your July 13, 8 p.m. Please give names and condition of Americans wounded
                            and correct or confirm report published here of execution of Prince
                            Pulun by Chang Hsün.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Polk</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>