                subtype="historical-document" type="document" xml:id="d284">
                <note rend="inline" type="source">File No. 893.811/262</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Reinsch</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-07-03T18:00:00-05:00">
                            <hi rend="italic">July 3, 1917, 6 p.m</hi>
                        </date>.</dateline>
                </opener>
                <p>Department cannot undertake responsibility of passing on constitutional question
                    raised your June 26, 3 p.m. Interested American citizens should consult private
                    legal counsel.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
