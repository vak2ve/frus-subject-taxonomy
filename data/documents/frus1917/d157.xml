<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-01-25T16:00:00-05:00" frus:doc-dateTime-min="1917-01-25T16:00:00-05:00" n="157" subtype="historical-document" type="document" xml:id="d157">
                        <note rend="inline" type="source">File No. 893.51/1737</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Reinsch</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Extract]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1917-01-25T16:00:00-05:00">
                                    <hi rend="italic">January 25, 1917, 4
                                p.m</hi></date>.</dateline>
                        </opener>
                        <p>Your telegram of January 23, 1 p.m. Chicago contract grants option on
                            additional loan up to twenty-five millions but option limited to sixty
                            days from date of application for such additional loan.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>