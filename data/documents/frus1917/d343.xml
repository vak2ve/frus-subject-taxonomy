                <note rend="inline" type="source">File No. 611.9331/38</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Reinsch</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-01-19T16:00:00-05:00">
                            <hi rend="italic">January 19, 1917, 4 p.m</hi>
                        </date>.</dateline>
                </opener>
                <p>Based upon stand Chinese Government, that exportation grain products forbidden by
                    treaty, you may take position outlined last paragraph your January 16, 6
                    p.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
