<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-07-17T05:00:00-05:00" frus:doc-dateTime-min="1917-07-17T05:00:00-05:00" n="121" subtype="historical-document" type="document" xml:id="d121">
                        <note rend="inline" type="source">File No. 893.001F35/1</note>
                        <head>
                            <hi rend="italic">Minister <persName type="from">Reinsch</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegrams]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Peking</hi></placeName>, <date calendar="gregorian" when="1917-07-17T18:00:00+08:00">
                                    <hi rend="italic">July 17, 1917, 6 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Minister for Foreign Affairs communicates notification from Vice
                            President Feng that in accordance with law he is performing in an acting
                            capacity the duties of the President, having assumed office on the 6th
                            instant.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Reinsch</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>