                subtype="historical-document" type="document" xml:id="d404">
                <note rend="inline" type="source">File No. 818.00/160</note>
                <head>
                    <hi rend="italic">Chargé <persName type="from">Johnson</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegrams]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">San José</hi>
                        </placeName>, <date calendar="gregorian" when="1917-05-25T18:00:00-05:36">
                            <hi rend="italic">May 25, 1917—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your May 24, 5 p.m. Assurances obtained, and González family left the American
                    Legation 5 p.m. today for their home.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
