                <note rend="inline" type="source">File No. 812.00/20846</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Fletcher</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Mexico City</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-27T11:00:00-06:36">
                            <hi rend="italic">April 27, 1917, 11 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Election of Carranza declared official yesterday.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Fletcher</hi>
                    </signed>
                </closer>
            </div>
        </body>
