    <text>
        <body>
            <div frus:doc-dateTime-max="1917-08-03T23:59:59-05:00"
                frus:doc-dateTime-min="1917-08-03T00:00:00-05:00" n="1446"
                subtype="historical-document" type="document" xml:id="d1446">
                <note rend="inline" type="source">File No. 819.154/26</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">Minister of Panama</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 33</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-08-03">
                            <hi rend="italic">August 3, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 27th ultimo<note n="2" xml:id="d1446fn2">Not printed.</note> in
                    which, under the instruction of your Government, you ask when the work on the
                    road system of Panama is to be commenced.</p>
                <p>In reply I have the honor to say that the subject of your note is receiving
                    consideration.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Frank L. Polk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
