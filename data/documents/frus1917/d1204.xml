                        <note rend="inline" type="source">File No. 812.00/21537a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Consul <persName type="to">Simpich</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegrams]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1917-12-08T16:00:00-05:00">
                                    <hi rend="italic">December 8, 1917, 4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Send detailed report on Yaqui situation Sonora.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
