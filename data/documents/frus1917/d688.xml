<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1901-12-17T23:59:59-05:00" frus:doc-dateTime-min="1901-12-17T00:00:00-05:00" n="688" subtype="historical-document" type="document" xml:id="d688">
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Swenson</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1901-12-17">
                                    <hi rend="italic">December 17, 1901</hi></date>.</dateline>
                        </opener>
                        <p>Please remind Minister of Foreign Affairs that the Senate adjourns for
                            the holidays on Thursday and that it would be quite desirable to have
                            the treaty signed before that day if possible.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hay</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>