                subtype="historical-document" type="document" xml:id="d1321">
                <note rend="inline" type="source">File No. 704.9312/13</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                            <persName type="to">Silliman</persName>
                    </hi>
                    <note n="23" xml:id="d1321fn23">The same to other Consular Officers in
                        Mexico.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-03-23">
                            <hi rend="italic">March 23, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In response to a request from the Chinese
                    Minister at Washington, you are instructed, when it may seem necessary to do so,
                    to render such informal good offices as may be possible and as you are permitted
                    to exercise by the local authorities to Chinese citizens resident in Mexico.</p>
                <p>I am [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <hi rend="smallcaps">Wilbur J. Carr</hi>
                    </signed>
                </closer>
            </div>
        </body>
