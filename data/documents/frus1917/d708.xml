                subtype="historical-document" type="document" xml:id="d708">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Swenson</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 137</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-02-19">
                            <hi rend="italic">February 19, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to inform you that the Senate, by its
                    resolution of February 17, 1902, has given its advice and consent to the
                    ratification, without amendment, of the treaty signed by Mr. Constantin Brun,
                    the Danish Minister at Washington and myself on January 24th last, providing for
                    the cession to the United States of the islands of St. Thomas, St. John, and St.
                    Croix in the West Indies.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
