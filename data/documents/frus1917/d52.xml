                subtype="historical-document" type="document" xml:id="d52">
                <note rend="inline" type="source">File No. 813.00/876</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Fletcher</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1917-09-14T11:00:00-06:36">
                            <hi rend="italic">September 14, 1917, 11 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>433. Your number 431, September 6, 3 p.m. Mexican Government has been asked to be
                    represented at conference, and at a Cabinet meeting day before yesterday it was
                    decided to accept the invitation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Fletcher</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
