                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">American Legation</hi>, <lb/>
                                        <hi rend="italic">Copenhagen</hi></placeName>, [<date ana="#date_undated-inferred-from-document-content-and-sibling-dates" calendar="gregorian" notAfter="1917-01-10T23:59:59-05:00" notBefore="1917-01-08T16:00:00-05:00">undated</date>] (<hi rend="italic">received January 10, 1917</hi>).</dateline>
                            </opener>
                            <p>415. Referring Department’s 216, January 6th, maps will be sent by
