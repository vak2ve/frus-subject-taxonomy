<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-12-21T11:00:00-05:00" frus:doc-dateTime-min="1916-12-21T11:00:00-05:00" n="869" subtype="historical-document" type="document" xml:id="d869">
                            <note rend="inline" type="source">File No. 711.5914/178</note>
                            <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">American Legation</hi>, <lb/>
                                        <hi rend="italic">Copenhagen</hi></placeName>, <date calendar="gregorian" when="1916-12-21T17:00:00+01:00">
                                        <hi rend="italic">December 21, 1916, 5 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>402. Upper House today voted 40 for arid 19 against ratification.
                                This is final and assures cession of Danish West Indies to the
                                United States.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Egan</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>