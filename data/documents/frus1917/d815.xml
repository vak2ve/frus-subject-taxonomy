<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-08-08T23:59:59-05:00" frus:doc-dateTime-min="1916-08-08T00:00:00-05:00" n="815" subtype="historical-document" type="document" xml:id="d815">
                            <note rend="inline" type="source">File No. 711.5914/83b</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the <gloss type="to">Danish
                                        Minister</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Department of State</hi>, <lb/>
                                        <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1916-08-08">
                                        <hi rend="italic">August 8, 1916</hi></date>.</dateline>
                            </opener>
                            <p>Treaty transmitted by President to Senate today with a request that
                                the details be kept secret.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Frank L. Polk</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>