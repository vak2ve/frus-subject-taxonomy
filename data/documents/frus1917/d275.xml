<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-02-09T17:00:00-05:00" frus:doc-dateTime-min="1917-02-09T17:00:00-05:00" n="275" subtype="historical-document" type="document" xml:id="d275">
                        <note rend="inline" type="source">File No. 893.811/246</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Reinsch</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1917-02-09T17:00:00-05:00">
                                    <hi rend="italic">February 9, 1917, 5
                                p.m</hi></date>.</dateline>
                        </opener>
                        <p>Your February 2, 5 p.m. See International Corporation’s telegram of
                            February 5 to their Peking representative.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
