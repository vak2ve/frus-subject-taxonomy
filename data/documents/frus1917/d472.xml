                subtype="historical-document" type="document" xml:id="d472">
                <note rend="inline" type="source">File No. 837.00/1141</note>
                <head>
                    <hi rend="italic">Consul <persName type="from">Griffith</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Consulate</hi>, <lb/>
                            <hi rend="italic">Santiago</hi>
                        </placeName> [<date
                            ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                            calendar="gregorian" notAfter="1917-02-26T23:59:59-05:00"
                            notBefore="1917-02-25T19:00:00-05:29">
                            <hi rend="italic">undated</hi>
                        </date>
                        <hi rend="italic">; received February 26, 1917</hi>].</dateline>
                </opener>
                <p>Cuban gunboat <hi rend="italic">Cuba</hi> now outside blockading harbor
                    entrance.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Griffith</hi>
                    </signed>
                </closer>
            </div>
        </body>
