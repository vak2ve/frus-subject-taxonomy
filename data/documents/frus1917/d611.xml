<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-04-19T10:29:00-05:00" frus:doc-dateTime-min="1917-04-19T10:29:00-05:00" n="611" subtype="historical-document" type="document" xml:id="d611">
                        <note rend="inline" type="source">File No. 337.11/456</note>
                        <head>
                            <hi rend="italic">Minister <persName type="from">Gonzales</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Habana</hi></placeName>, <date calendar="gregorian" when="1917-04-19T10:00:00-05:29">
                                    <hi rend="italic">April 19, 1917, 10 a.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Your April 17, 5 p.m. President reports guard regulars at Exploration
                            Company’s plant.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Gonzales</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>