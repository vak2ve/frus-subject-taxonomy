                <note rend="inline" type="source">File No. 337.11/456</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Gonzales</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-19T10:00:00-05:29">
                            <hi rend="italic">April 19, 1917, 10 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your April 17, 5 p.m. President reports guard regulars at Exploration Company’s
                    plant.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gonzales</hi>
                    </signed>
                </closer>
            </div>
        </body>
