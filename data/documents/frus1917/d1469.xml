                subtype="historical-document" type="document" xml:id="d1469">
                <note rend="inline" type="source">File No. 816.48/7</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Ewing</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-06-11T18:00:00-05:00">
                            <hi rend="italic">June 11, 1917, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your undated telegram received June 11, 11.35 a.m. Contents of your cable have
                    been sent to American Red Cross which will render all aid possible.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
