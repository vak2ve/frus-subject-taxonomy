<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-04-07T17:00:00-05:00" frus:doc-dateTime-min="1917-04-07T17:00:00-05:00" n="241" subtype="historical-document" type="document" xml:id="d241">
                        <note rend="inline" type="source">File No. 893.77/1594</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Reinsch</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1917-04-07T17:00:00-05:00">
                                    <hi rend="italic">April 7, 1917, 5 p.m</hi></date>.</dateline>
                        </opener>
                        <p>Your telegram of April 3, 6 p.m. You are authorized as you request to
                            take the position stated by you.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>