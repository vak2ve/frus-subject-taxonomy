    <text>
        <body>
            <div frus:doc-dateTime-max="1917-12-18T23:59:59-05:00"
                frus:doc-dateTime-min="1917-12-18T00:00:00-05:00" n="1406"
                subtype="historical-document" type="document" xml:id="d1406">
                <note rend="inline" type="source">File No. 817.51/1065</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Chargé d’Affaires of Nicaragua</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 56</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-12-18">
                            <hi rend="italic">December 18, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of December 5, stating that, in accordance with Article 1 of the
                    contract signed October 1, 1917, you sent on November 30, through the National
                    City Bank of New York, a telegraphic order for one hundred and sixty-eight
                    thousand and eight pounds, four shillings, and seven pence, to be paid to the
                    Corporation of Foreign Bondholders of London, and that the bank has notified you
                    that payment was effected on December 3.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
