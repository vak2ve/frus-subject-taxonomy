<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-01-08T12:36:00-05:00" frus:doc-dateTime-min="1917-01-08T12:36:00-05:00" n="1256" subtype="historical-document" type="document" xml:id="d1256">
                        <note rend="inline" type="source">File No. 812.5034/33</note>
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Parker</persName>,
                                representing American interests, to the <gloss type="to">Secretary
                                    of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Querétaro</hi></placeName>, <date calendar="gregorian" when="1917-01-08T11:00:00-06:36">
                                    <hi rend="italic">January 8, 1917—11 a.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>631. Department’s 604, January 6, 6 p.m. Data required not available
                            here, have instructed Thurston to comply with Department’s
                            instruction.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Parker</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>