<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-02-28T16:00:00-05:00" frus:doc-dateTime-min="1917-02-28T16:00:00-05:00" n="1238" subtype="historical-document" type="document" xml:id="d1238">
                        <note rend="inline" type="source">File No. 812.63/380</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Ambassador <persName type="to">Fletcher</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1917-02-28T16:00:00-05:00">
                                    <hi rend="italic">February 28, 1917, 4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>16. Department views with satisfaction assurances given by Minister for
                            Foreign Affairs that it is not the intention to confiscate American
                            properties under decrees requiring resumption of work in mines.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>