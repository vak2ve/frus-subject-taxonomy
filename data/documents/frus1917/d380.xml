    <text>
        <body>
            <div frus:doc-dateTime-max="1917-02-12T23:59:59-05:00"
                frus:doc-dateTime-min="1917-02-12T00:00:00-05:00" n="380"
                subtype="historical-document" type="document" xml:id="d380">
                <note rend="inline" type="source">File No. 818.00/74</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                            <persName type="to">Chase</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 19</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-02-12">
                            <hi rend="italic">February 12, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has received, and read with
                    interest, your despatch No. 24 of January 27, 1917, reporting that on that date
                    a revolution was started in San José, Costa Rica, by the Minister of War,
                    Federico Tinoco.</p>
                <p>Your action in not giving information regarding the attitude of the Government of
                    the United States is approved by the Department.</p>
                <p>I am [etc.]</p>
                <closer>For the Secretary of State: <lb/>
                    <signed>
                        <hi rend="smallcaps">Wilbur J. Carr</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
