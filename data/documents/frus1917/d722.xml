                subtype="historical-document" type="document" xml:id="d722">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Swenson</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegrams]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-05-17">
                            <hi rend="italic">May 17, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>I have already said to Mr. Brun that I would sign a protocol extending limit
                    ratification whenever he is authorized.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hay</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
