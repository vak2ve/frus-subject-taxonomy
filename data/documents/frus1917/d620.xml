                subtype="historical-document" type="document" xml:id="d620">
                <note rend="inline" type="source">File No. 337.11/485</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                            <persName type="to">Griffith</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-05-08T18:00:00-05:00">
                            <hi rend="italic">May 8, 1917, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your telegram of 6th. <hi rend="italic">Machias</hi> now returning to
                    Santiago.</p>
                <p>When cabling information to Department send duplicate by wire to Legation at
                    Habana.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
