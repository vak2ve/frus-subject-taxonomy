    <text>
        <body>
            <div frus:doc-dateTime-max="1917-06-17T23:59:59-05:00"
                frus:doc-dateTime-min="1917-06-17T00:00:00-05:00" n="92"
                subtype="historical-document" type="document" xml:id="d92">
                <note rend="inline" type="source">File No. 893.00/2620</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Sharp</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1917-06-17">
                            <hi rend="italic">June 17, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>2190. Your 2313, June 4, and 2338, June 9. The following is a translation of a
                    note from the Ministry for Foreign Affairs in reply thereto, just received.<note
                        n="7" xml:id="d92fn7">Printed as inclosure to despatch No. 5456, June 20,
                        1917, from the American Embassy at Paris.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sharp</hi>
                    </signed>
                </closer>
            </div>
        </body>
