    <text>
        <body>
            <div frus:doc-dateTime-max="1917-12-29T23:59:59-05:00"
                frus:doc-dateTime-min="1917-12-29T00:00:00-05:00" n="902"
                subtype="historical-document" type="document" xml:id="d902">
                <note rend="inline" type="source">File No. 439.00/22</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Russell</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-12-29">
                            <hi rend="italic">December 29, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>Your dispatch No. 275, December 15, 1917. In accordance with General Rule No. 1,
                    Dominican Claims Commission of 1917, enter appearance for American claimants
                    listed with Johnston Commission who have not filed claims with present
                    Commission as you purpose doing for other American claimants who have not
                    appeared.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
