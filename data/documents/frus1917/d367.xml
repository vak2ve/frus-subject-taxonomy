<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-01-27T00:36:00-05:00" frus:doc-dateTime-min="1917-01-27T00:36:00-05:00" n="367" subtype="historical-document" type="document" xml:id="d367">
                        <note rend="inline" type="source">File No. 818.00/55</note>
                        <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Limon</hi></placeName>, <date calendar="gregorian" when="1917-01-27T00:00:00-05:36">
                                    <hi rend="italic">January 27, 1917,
                                midnight</hi></date>.</dateline>
                        </opener>
                        <p>The President and the Cabinet and Maximo Fernandez, the President of
                            Congress, request the protection of the Government of the United States
                            to sustain legal Government.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hale</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>