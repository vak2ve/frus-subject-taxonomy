                subtype="historical-document" type="document" xml:id="d391">
                <note rend="inline" type="source">File No. 818.00/123</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Hale</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-05T17:00:00-05:00">
                            <hi rend="italic">April 5, 1917—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your April 2, 4 p.m. Department has been informed by other sources that Tinoco
                    was elected President of Costa Rica. This is not clear from your telegram.
                    Please report immediately by cable to Department.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
