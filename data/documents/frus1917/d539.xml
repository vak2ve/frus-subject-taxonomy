                subtype="historical-document" type="document" xml:id="d539">
                <note rend="inline" type="source">File No. 837.00/1327</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                            <persName type="to">Wolcott</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-05-10T17:00:00-05:00">
                            <hi rend="italic">May 10, 1917—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your May 1, 11 a.m. Department is giving careful consideration contents your
                    cablegram. Keep Legation at Habana informed as well as Department, of all
                    changes of situation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
