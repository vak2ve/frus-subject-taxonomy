<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-07-03T23:59:59-05:00" frus:doc-dateTime-min="1917-07-03T00:00:00-05:00" n="1292" subtype="historical-document" type="document" xml:id="d1292">
                        <note rend="inline" type="source">File No. 312.115/315</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Collector <persName type="to">Cobb</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1917-07-03">
                                    <hi rend="italic">July 3, 1917</hi></date>.</dateline>
                        </opener>
                        <p>Your June 29, 11 a.m. Should any American companies complain to
                            Department, prompt consideration will be given matter.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>