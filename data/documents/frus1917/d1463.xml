    <text>
        <body>
            <div frus:doc-dateTime-max="1917-06-10T23:59:59-05:00"
                frus:doc-dateTime-min="1917-06-10T00:00:00-05:00" n="1463"
                subtype="historical-document" type="document" xml:id="d1463">
                <note rend="inline" type="source">File No. 816.48/10</note>
                <head>
                    <hi rend="italic">President <persName type="from">Melendez</persName> to
                        President <persName type="to">Wilson</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Translation]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Salvador</hi>
                        </placeName>, <date calendar="gregorian" when="1917-06-10">
                            <hi rend="italic">June 10, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>In the name of the people of Salvador, and in my own, I acknowledge with
                    heartfelt thanks the sentiments of sympathy from Your Excellency and the
                    American people arid also the generous wishes you are pleased to express to me
                    for the sufferers of the disaster that has taken place.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">President Melendez</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
