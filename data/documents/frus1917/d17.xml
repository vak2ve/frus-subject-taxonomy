                <note rend="inline" type="source">File No. 711.6321/86</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Ambassador <persName type="to">Penfield</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-07-24T16:00:00-05:00">
                            <hi rend="italic">July 24, 1916, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1305. Your 1339, July 17, 11 a.m. Department not entirely clear respecting
                    meaning Foreign Office note. Mail copy as soon as possible.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Polk</hi>
                    </signed>
                </closer>
            </div>
        </body>
