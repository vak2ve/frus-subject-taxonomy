                <note rend="inline" type="source">File No. 711.5914/176</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Egan</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegrams]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Copenhagen</hi>
                        </placeName>, <date calendar="gregorian" when="1916-12-15T09:00:00+01:00">
                            <hi rend="italic">December 15, 1916, 9 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>397. Result of plebiscite approximately 284,000 for sale and 158,000 against.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Egan</hi>
                    </signed>
                </closer>
            </div>
