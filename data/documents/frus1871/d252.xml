                subtype="historical-document" type="document" xml:id="d252">
                <opener>
                    <seg rendition="#center">No. 231.</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Pakenham</persName> to <persName type="to">Mr.
                        Davis</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1871-08-15">
                            <hi rend="italic">August</hi> 15, 1871</date>. (Received August
                        16.)</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have the honor to acquaint you that official
                    information has this day reached me to the effect that Sir Alexander Cockburn,
                    chief justice of England, has been appointed arbitrator on behalf of Her
                    Majesty’s government, under article I of the treaty of Washington of the 8th of
                    May last.</p>
                <p>I have the honor, &amp;c.,</p>
                <closer>
                    <signed>F. J. PAKENHAM.</signed>
                </closer>
            </div>
        </body>
    </text>
