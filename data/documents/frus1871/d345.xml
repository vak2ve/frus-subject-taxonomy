    <text>
        <body>
            <div frus:doc-dateTime-max="1870-10-03T23:59:59-05:00" frus:doc-dateTime-min="1870-10-03T00:00:00-05:00" n="345" subtype="historical-document" type="document" xml:id="d345">
                <opener>
                    <seg rendition="#center">No. 324.</seg>
                </opener>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Fish</persName> to <persName type="to">General
                            Sickles</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1870-10-03">
                            <hi rend="italic">October</hi> 3, 1870.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sickles</hi>, <hi rend="italic">Minister</hi>, <hi rend="italic">Madrid:</hi>
                </p>
                <p>Repeat from without result to end of dispatch. Opinion on terms reserved till
                        full telegram can be read.</p>
                <closer>
                    <signed>FISH.</signed>
                </closer>
            </div>
        </body>
    </text>
