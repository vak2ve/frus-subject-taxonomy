    <text>
        <body>
            <div frus:doc-dateTime-max="1870-12-20T23:59:59-05:00"
                frus:doc-dateTime-min="1870-12-20T00:00:00-05:00" n="364"
                subtype="historical-document" type="document" xml:id="d364">
                <opener>
                    <seg rendition="#center">No. 343.</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Fish</persName> to <persName type="to">General
                        Sickles</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 129.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1870-12-20">
                            <hi rend="italic">December</hi> 20, 1870.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> The following telegram was forwarded to you on
                    the 19th instant, through the United States legation at London.</p>
                <p>I am, &amp;c.,</p>
                <closer>
                    <signed>HAMILTON FISH.</signed>
                </closer>
                <frus:attachment>
                    <head>[Untitled]</head>
                    <p>
                        <hi rend="smallcaps">Moran</hi>, <hi rend="italic">London</hi>:</p>
                    <p>Send following to Sickles, minister, Madrid: Telegram received. Full powers
                        forwarded the 12th.</p>
                    <p>Act as if you had them.</p>
                    <closer>
                        <signed>FISH.</signed>
                    </closer>
                </frus:attachment>
            </div>
        </body>
    </text>
