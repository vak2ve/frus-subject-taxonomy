<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1870-12-23T23:59:59-05:00" frus:doc-dateTime-min="1870-12-23T00:00:00-05:00" n="367" subtype="historical-document" type="document" xml:id="d367">
                    <opener><seg rendition="#center">No. 346.</seg></opener>
                    <head><persName type="from">Mr. Fish</persName> to <persName type="to">General
                            Sickles</persName></head>
                    <opener>
                        <seg rendition="#left">No. 131.]</seg>
                        <dateline rendition="#right">
                            <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1870-12-23"><hi rend="italic">December</hi> 23, 1870.</date></dateline></opener>
                    <p><hi rend="smallcaps">Sir:</hi> The following telegram was sent to Mr. Moran
                        on the 22d, for transmission to you:</p>
                    <p><hi rend="smallcaps">Moran</hi>, <hi rend="italic">Chargé</hi>, <hi rend="italic">London:</hi></p>
                    <p>Telegraph, and send by mail to Sickles:</p>
                    <p>“Telegram of 19th received; bases enumerated therein are entirely
                        inadmissible.”</p>
                    <p>I am, &amp;c.,</p>
                    <closer>
                        <signed>HAMILTON FISH.</signed></closer>
                </div>
                </body></text></TEI>