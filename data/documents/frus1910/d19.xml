    <text>
        <body>
            <div frus:doc-dateTime-max="1910-11-22T23:59:59-05:00"
                frus:doc-dateTime-min="1910-11-22T00:00:00-05:00" n="19"
                subtype="historical-document" type="document" xml:id="d19">
                <note rend="inline" type="source">File No. 835.415A/97.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Argentine Chargé</gloss> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Argentine Legation</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1910-11-22">
                            <hi rend="italic">November 22, 1910</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: I have the honor to inclose
                    office copy and original of the autograph letter<note n="1" xml:id="d19fn1">Not
                        printed.</note> of the President of the Argentine <pb facs="0124" n="12"
                        xml:id="pg_12"/> Republic acknowledging the letter sent by President Taft
                    upon the occasion of the centenary anniversity of Argentine independence.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Jacinto L. Villegas.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
