                <note rend="inline" type="source">File No. 24607.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">British Minister for Foreign Affairs</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1910-05-07">
                            <hi rend="italic">May 7, 1910</hi>
                        </date>.</dateline>
                </opener>
                <p>I offer to your excellency the expression of my personal sympathy and sorrow in
                    the great loss which has been sustained by the Government of Great Britain in
                    the death of His Majesty King Edward.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">P. C. Knox.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
