<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1909-02-14T23:59:59-05:00" frus:doc-dateTime-min="1909-02-11T23:56:00-05:00" n="361" subtype="historical-document" type="document" xml:id="d361">
                        <head><hi rend="italic">Minister <persName type="from">Dawson</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="smallcaps">Bogota</hi></placeName>
                                <date ana="#date_undated-inferred-from-document-content-and-sibling-dates" calendar="gregorian" notAfter="1909-02-14T23:59:59-05:00" notBefore="1909-02-12T00:00:00-04:56">undated</date>)<lb/>(Received Feb. 14, 1909).</dateline></opener>
                        <p>Arrived. National assembly summoned for February 22; prospects
                            ratification favorable.</p>
                        <closer><signed><hi rend="smallcaps">Dawson.</hi></signed></closer>
                    </div>
                    </body></text></TEI>