    <text>
        <body>
            <div frus:doc-dateTime-max="1908-05-22T23:59:59-05:00"
                frus:doc-dateTime-min="1908-05-22T00:00:00-05:00" n="716"
                subtype="historical-document" type="document" xml:id="d716">
                <head>
                    <hi rend="italic">The <gloss type="from">Liberian Commission</gloss> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The “Arlington,”</hi>
                            <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1908-05-22">
                            <hi rend="italic">May 22, 1908</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: We have the honor to inform you that we have
                    arrived in Washington in the capacity of envoys extraordinary from the Republic
                    of Liberia to your Government, and to respectfully ask that you appoint a time
                    when we may call on you.</p>
                <p>We have, etc.,</p>
                <closer>
                    <signed>
                        <list>
                            <item>
                                <hi rend="smallcaps">Garretson W. Gibson</hi>.</item>
                            <item>
                                <hi rend="smallcaps">James J. Dossen</hi>.</item>
                            <item>
                                <hi rend="smallcaps">Chas. B. Dunbar</hi>.</item>
                        </list>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
