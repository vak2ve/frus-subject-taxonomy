<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1910-10-07T23:59:59-05:00" frus:doc-dateTime-min="1910-10-07T00:00:00-05:00" n="908" subtype="historical-document" type="document" xml:id="d908">
                        <note rend="inline" type="source">File No. 853.00/89.</note>
                        <head><hi rend="italic">Minister <persName type="from">Gage</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Lisbon</hi></placeName>, <date calendar="gregorian" when="1910-10-07"><hi rend="italic">October 7,
                                1910</hi></date>.</dateline></opener>
                        <p>Shall I transmit ordinary business of this office with the provisional
                            government by unofficial action?</p>
                        <closer><signed><hi rend="smallcaps">Gage.</hi></signed></closer>
                    </div>
                    </body></text></TEI>