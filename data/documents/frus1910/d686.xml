    <text>
        <body>
            <div frus:doc-dateTime-max="1910-07-12T23:59:59-05:00"
                frus:doc-dateTime-min="1910-07-12T00:00:00-05:00" n="686"
                subtype="historical-document" type="document" xml:id="d686">
                <note rend="inline" type="source">File No. 25010/36.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Italian Chargé</gloss> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Italian Embassy</hi>,<lb/>
                            <hi rend="italic">Manchester, Mass.</hi>
                        </placeName>, <date calendar="gregorian" when="1910-07-12">
                            <hi rend="italic">July 12, 1910</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 131.]</seg>
                </opener>
                <p>Mr. <hi rend="smallcaps">Secretary of State</hi>: In continuation of previous
                    correspondence, I have the honor to transmit herewith to your excellency a copy
                    of the warrant of arrest issued June 13 last by the examining magistrate of the
                    civil and criminal court of Como against Mr. Porter Charlton.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Montagliari.</hi>
                    </signed>
                </closer>
            </div>
        </body>
