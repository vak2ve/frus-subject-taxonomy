<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1910-07-04T23:59:59-05:00" frus:doc-dateTime-min="1910-07-04T00:00:00-05:00" n="831" subtype="historical-document" type="document" xml:id="d831">
                        <note rend="inline" type="source">File No. 7370/36.</note>
                        <head><hi rend="italic"><gloss type="from">Norwegian Chargé</gloss> to the
                                    <gloss type="to">Acting Secretary of State</gloss></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Norwegian Legation</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1910-07-04"><hi rend="italic">July 4,
                                1910</hi></date>.</dateline></opener>
                        <p>Please accept this legation’s sincere thanks for message of sympathy,
                            which I have conveyed to my Government.</p>
                        <closer><signed><hi rend="smallcaps">Morgenstierne.</hi></signed></closer>
                    </div>
                    </body></text></TEI>