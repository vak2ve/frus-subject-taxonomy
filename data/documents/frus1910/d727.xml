<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1910-03-21T23:59:59-05:00" frus:doc-dateTime-min="1910-03-21T00:00:00-05:00" n="727" subtype="historical-document" type="document" xml:id="d727">
                        <head><hi rend="italic">The <gloss type="from">Vice President of
                                    Liberia</gloss> to President <persName type="to">Taft</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Monrovia, Liberia</hi></placeName>,<lb/><date calendar="gregorian" when="1910-03-21"><hi rend="italic">March
                                        21, 1910</hi></date>.</dateline></opener>
                        <p>Liberian public boundlessly grateful for the magnanimous help of your
                            great and good nation.</p>
                        <closer><signed><hi rend="smallcaps">Vice President
                            Dossen.</hi></signed></closer>
                    </div>
                    </body></text></TEI>