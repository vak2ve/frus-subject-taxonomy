<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1910-11-04T23:59:59-05:00" frus:doc-dateTime-min="1910-11-04T00:00:00-05:00" n="939" subtype="historical-document" type="document" xml:id="d939">
                        <note rend="inline" type="source">File No. 892.001/9.</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Chargé <persName type="to">Tarler</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1910-11-04"><hi rend="italic">November 4,
                                1910</hi></date>.</dateline></opener>
                        <p>You will attend ceremony as the special representative of the President.
                            I have so cabled minister of foreign affairs.</p>
                        <closer><signed><hi rend="smallcaps">Adee.</hi></signed></closer>
                    </div>
                    </body></text></TEI>