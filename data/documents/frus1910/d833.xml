                <note rend="inline" type="source">File No. 847/218.</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Weitzel</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Panama</hi>
                        </placeName>, <date calendar="gregorian" when="1910-03-01">
                            <hi rend="italic">March 1, 1910</hi>
                        </date>.</dateline>
                </opener>
                <p>The President of Panama died at 2.40 this afternoon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Weitzel.</hi>
                    </signed>
                </closer>
            </div>
        </body>
