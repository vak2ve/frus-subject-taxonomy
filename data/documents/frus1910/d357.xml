<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1909-01-30T23:59:59-05:00" frus:doc-dateTime-min="1909-01-29T00:00:00-05:00" n="357" subtype="historical-document" type="document" xml:id="d357">
                        <head><hi rend="italic">Minister <persName type="from">Squiers</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Panama</hi></placeName> (<date ana="#date_undated-inferred-from-document-content" calendar="gregorian" notAfter="1909-01-30T23:59:59-05:00" notBefore="1909-01-29T00:00:00-05:00">undated</date>).<lb/>(Received January 30,
                            1909.)</dateline></opener>
                        <p>Recent treaty between Colombia and Panama ratified by national assembly
                            this afternoon without amendment or discussion.</p>
                        <closer><signed><hi rend="smallcaps">Squiers.</hi></signed></closer>
                    </div>
                    </body></text></TEI>