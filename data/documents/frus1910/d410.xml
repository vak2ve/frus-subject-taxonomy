<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1910-05-06T23:59:59-05:00" frus:doc-dateTime-min="1910-05-06T00:00:00-05:00" n="410" subtype="historical-document" type="document" xml:id="d410">
                        <note rend="inline" type="source">File No. 24354/4.</note>
                        <head><hi rend="italic">President <persName type="from">Taft</persName> to
                                the <gloss type="to">President of Costa Rica</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">The
                                        White House</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1910-05-06"><hi rend="italic">May 6,
                                1910</hi></date>.</dateline></opener>
                        <p>Accept the profound sympathy of the people and Government of the United
                            States in the calamity at Cartago, of which I learn with the deepest
                            regret.</p>
                        <closer><signed><hi rend="smallcaps">Wm. H. Taft.</hi></signed></closer>
                    </div>
                    </body></text></TEI>