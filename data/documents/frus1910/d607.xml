    <text>
        <body>
            <div frus:doc-dateTime-max="1910-05-07T23:59:59-05:00"
                frus:doc-dateTime-min="1910-05-07T00:00:00-05:00" n="607"
                subtype="historical-document" type="document" xml:id="d607">
                <head>
                    <hi rend="italic">His Majesty King <persName type="from">George V</persName> to
                        President <persName type="to">Taft</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1910-05-07">
                            <hi rend="italic">May 7, 1910</hi>
                        </date>.</dateline>
                </opener>
                <p>I am deeply grateful to you, your Government, and people for your condolence on
                    the death of my beloved father and for your good wishes for my future
                    prosperity.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">George R. and I</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
