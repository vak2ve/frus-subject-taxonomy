                <note rend="inline" type="source">File No. 2491/163.</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Merry</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">San Jose</hi>
                        </placeName>, <date calendar="gregorian" when="1910-08-22">
                            <hi rend="italic">August 22, 1910</hi>
                        </date>.</dateline>
                </opener>
                <p>Government of Costa Rica has approved boundary treaty.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Merry.</hi>
                    </signed>
                </closer>
            </div>
        </body>
