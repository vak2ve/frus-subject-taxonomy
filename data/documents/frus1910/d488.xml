                subtype="historical-document" type="document" xml:id="d488">
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Dudley</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Extract.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">Petropolis</hi>
                        </placeName>, <date calendar="gregorian" when="1910-05-30">
                            <hi rend="italic">May 30, 1910</hi>
                        </date>.</dateline>
                </opener>
                <p>Your May 28 repeated from Buenos Aires. Brazilian minister for foreign affairs
                    says the representatives of Brazil at Lima and Quito will be instructed
                    immediately to join in proposed recommendation for withdrawal of troops June
                    4th.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dudley.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
