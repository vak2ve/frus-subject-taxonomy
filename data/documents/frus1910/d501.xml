                subtype="historical-document" type="document" xml:id="d501">
                <head>
                    <hi rend="italic">Minister <persName type="from">Fox</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Quito</hi>
                        </placeName>, <date calendar="gregorian" when="1910-06-03">
                            <hi rend="italic">June 3, 1910</hi>
                        </date>.</dateline>
                </opener>
                <p>Gen. Franco, commanding Ecuadorian army on the frontier, has telegraphed to-day
                    minister of war that he has commenced to withdraw his troops.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Fox.</hi>
                    </signed>
                </closer>
            </div>
        </body>
