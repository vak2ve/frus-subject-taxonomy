<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1910-05-06T23:59:59-05:00" frus:doc-dateTime-min="1910-05-06T00:00:00-05:00" n="409" subtype="historical-document" type="document" xml:id="d409">
                        <note rend="inline" type="source">File No. 24354/4.</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Chargé <persName type="to">Monroe</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1910-05-06"><hi rend="italic">May 6,
                                1910</hi></date>.</dateline></opener>
                        <p>Express to the Costa Rican Government and to the Central American court
                            of justice the profound sympathy of the United States in the calamity at
                            Cartago.</p>
                        <closer><signed><hi rend="smallcaps">Knox.</hi></signed></closer>
                    </div>
                    </body></text></TEI>