                subtype="historical-document" type="document" xml:id="d48">
                <note rend="inline" type="source">File No. 21158/4.</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Kerens</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1910-09-22">
                            <hi rend="italic">September 22, 1910</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 105.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to my dispatch No. 66 of July 30, 1910,
                    transmitting the sworn statement and passport application of Mr. Rudolf
                    Warren-Lippit, may I inquire if the department has reached a decision in the
                    matter, and, if so, the result of same?</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">R. C. Kerens.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
