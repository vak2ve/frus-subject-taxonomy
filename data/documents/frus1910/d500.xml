<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1910-06-03T23:59:59-05:00" frus:doc-dateTime-min="1910-06-03T00:00:00-05:00" n="500" subtype="historical-document" type="document" xml:id="d500">
                        <head><hi rend="italic">Minister <persName type="from">Sherrill</persName>
                                to the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Buenos
                                        Aires</hi></placeName>, <date calendar="gregorian" when="1910-06-03"><hi rend="italic">June 3,
                                1910</hi></date>.</dateline></opener>
                        <p>Your June 1–2. Argentine minister for foreign affairs is in complete
                            accord with you.</p>
                        <closer><signed><hi rend="smallcaps">Sherrill.</hi></signed></closer>
                    </div>
                    </body></text></TEI>