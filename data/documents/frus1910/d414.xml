<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1910-05-07T23:59:59-05:00" frus:doc-dateTime-min="1910-05-07T00:00:00-05:00" n="414" subtype="historical-document" type="document" xml:id="d414">
                        <note rend="inline" type="source">File No. 24354/6.</note>
                        <head><hi rend="italic">The <gloss type="from">President of Costa
                                    Rica</gloss> to President <persName type="to">Taft</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Translation.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">San
                                        Jose</hi></placeName>, <date calendar="gregorian" when="1910-05-07"><hi rend="italic">May 7–8,
                                1910</hi></date>.</dateline></opener>
                        <p>In the name of the people and Government of Costa Rica I express to your
                            excellency our most profound gratitude.</p>
                        <closer><signed><hi rend="smallcaps">Cleto Gonzalez
                            Viquez.</hi></signed></closer>
                    </div>
                    </body></text></TEI>