                <note rend="inline" type="source">File No. 24354/6.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">President of Costa Rica</gloss> to
                        President <persName type="to">Taft</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Jose</hi>
                        </placeName>, <date calendar="gregorian" when="1910-05-07">
                            <hi rend="italic">May 7–8, 1910</hi>
                        </date>.</dateline>
                </opener>
                <p>In the name of the people and Government of Costa Rica I express to your
                    excellency our most profound gratitude.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cleto Gonzalez Viquez.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
