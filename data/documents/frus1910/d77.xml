                subtype="historical-document" type="document" xml:id="d77">
                <note rend="inline" type="source">File No. 4737/35.</note>
                <head>
                    <hi rend="italic">President <persName type="from">Taft</persName> to the <gloss
                            type="to">President of Brazil</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The White House</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1910-01-17">
                            <hi rend="italic">January 17, 1910</hi>
                        </date>.</dateline>
                </opener>
                <p>For my countrymen and in my own name I offer heartfelt condolence upon the death
                    of Ambassador Nabuco.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wm. H. Taft.</hi>
                    </signed>
                </closer>
            </div>
        </body>
