                subtype="historical-document" type="document" xml:id="d365">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Dawson</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1909-02-26">
                            <hi rend="italic">February 26, 1909</hi>
                        </date>.</dateline>
                </opener>
                <p>On 24th instant Senate approved treaty with Colombia without change and treaty
                    with Panama with understanding no questions shall be submitted to arbitration
                    affecting vital interests of United States in construction, operation,
                    maintenance, sanitation, and protection of canal.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bacon.</hi>
                    </signed>
                </closer>
            </div>
        </body>
