                subtype="historical-document" type="document" xml:id="d399">
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Minister <persName type="to">Northcott</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1909-10-28">
                            <hi rend="italic">October 28, 1909</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 15.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The department has received your No. 12 of the
                    1st instant inclosing copy and translation of a memorandum which the Colombian
                    minister for foreign affairs requested you to sign with him, proposing that as
                    it would be impossible to obtain the consent of the Colombian Congress to the
                    ratification of the United States-Panama-Colombia treaties, those treaties be
                    dropped and negotiations be opened at Bogota.</p>
                <p>The department commends your action in declining to sign the
                    memorandum-protocol.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Huntington Wilson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
