    <text>
        <body>
            <div frus:doc-dateTime-max="1909-11-04T23:59:59-05:00"
                frus:doc-dateTime-min="1909-11-04T00:00:00-05:00" n="401"
                subtype="historical-document" type="document" xml:id="d401">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Northcott</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1909-11-04">
                            <hi rend="italic">November 4, 1909</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 17.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The department has received your No. 14 of the
                    7th ultimo, relative to the proposed treaty between the United States, Colombia,
                    and Panama, and in reply you are referred to the cabled instructions of October
                    4 and 23, as defining the department’s attitude on the subject.</p>
                <p>I am, etc.,</p>
                <closer>(For <signed>Mr. Knox</signed>.)<lb/>
                    <signed>
                        <hi rend="smallcaps">Huntington Wilson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
