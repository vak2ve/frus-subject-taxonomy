<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1907-01-24T23:59:59-05:00" frus:doc-dateTime-min="1907-01-24T00:00:00-05:00" n="434" subtype="historical-document" type="document" xml:id="d434">
                        <note rend="inline" type="source">File No. 4001/19.</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Archbishop <persName type="to">Nuttall</persName></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1907-01-24"><hi rend="italic">January 24,
                                1907</hi></date>.</dateline></opener>
                        <p>The President much pleased with your kindly message, and directs me to
                            express his warmest thanks.</p>
                        <closer><signed><hi rend="smallcaps">Robert Bacon.</hi></signed></closer>
                    </div>
                    </body></text></TEI>