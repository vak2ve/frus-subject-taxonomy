                <note rend="inline" type="source">File No. 3294/30.</note>
                <head>
                    <hi rend="italic">Consul-General <persName type="from">Skinner</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Marseilles</hi>
                        </placeName>, <date calendar="gregorian" when="1907-06-15">
                            <hi rend="italic">June 15, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>Jacobs leaving 20th; closing incident.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Skinner.</hi>
                    </signed>
                </closer>
            </div>
