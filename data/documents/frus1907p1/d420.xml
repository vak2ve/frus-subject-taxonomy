                <note rend="inline" type="source">File No 3892.</note>
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to King
                            <persName type="to">Edward</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The White House</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-01-16">
                            <hi rend="italic">January 16, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>I beg your Majesty to accept my own sympathy and that of the American people on
                    account of the dire disaster that has befallen your Majesty’s subjects in
                    Jamaica.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
