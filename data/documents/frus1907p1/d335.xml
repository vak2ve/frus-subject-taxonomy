                <note rend="inline" type="source">File No. 7625.</note>
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to
                        President <persName type="to">Failleres</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-07-15">
                            <hi rend="italic">July 15, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>Accept my cordial congratulations on fortunate escape from injury.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
