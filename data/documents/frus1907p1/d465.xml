<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1907-09-23T23:59:59-05:00" frus:doc-dateTime-min="1907-09-23T00:00:00-05:00" n="465" subtype="historical-document" type="document" xml:id="d465">
                        <note rend="inline" type="source">File No. 1296/7.</note>
                        <head><hi rend="italic">Minister <persName type="from">Jackson</persName> to
                                the <gloss type="to">Secretary of State</gloss></hi>.</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Athens</hi></placeName>, <date calendar="gregorian" when="1907-09-23"><hi rend="italic">September 23,
                                    1907</hi></date>.</dateline>
                            <seg rendition="#left">No. 583 Greek Series.]</seg></opener>
                        <p><hi rend="smallcaps">Sir</hi>: Referring to previous correspondence, I
                            have the honor to transmit copies of Nos. 122 and 131 of the Greek
                            Official Gazette, which contain the text of the extradition
                                treaties<note n="a" xml:id="d465fna">Not printed.</note> negotiated
                            by Greece Avith France (March 29–April 11, 1906) and Germany (February
                            27–March 12, 1907), respectively, and to be sir, etc.,</p>
                        <closer><signed><hi rend="smallcaps">John B. Jackson.</hi></signed></closer>
                    </div>
                </body></text></TEI>