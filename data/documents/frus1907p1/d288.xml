                <note rend="inline" type="source">File No. 2540/15.</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Fox</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Quito</hi>
                        </placeName>, <date calendar="gregorian" when="1907-06-22">
                            <hi rend="italic">June 22, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>Carlos A. Aguirre appointed arbitrator railway question; awaiting designation by
                    President.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Fox.</hi>
                    </signed>
                </closer>
            </div>
        </body>
