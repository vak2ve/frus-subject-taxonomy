                <note rend="inline" type="source">File No. 3892.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Governor of Jamaica</gloss>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-01-16">
                            <hi rend="italic">January 16, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>I beg your excellency to believe in the deep and sincere sympathy of the people
                    of the United States at this time of death and suffering in Jamaica.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Elihu Root.</hi>
                    </signed>
                </closer>
            </div>
        </body>
