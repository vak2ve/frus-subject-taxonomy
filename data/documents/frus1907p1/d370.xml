                <note rend="inline" type="source">File No. 5727/141.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">Italian Chargé</gloss>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-10-17">
                            <hi rend="italic">October 17, 1907</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 543.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge receipt of your
                    note of the 4th instant, relative to acceptance by the appraising officers of
                    the United States of the certificates of value issued by Italian chambers of
                    commerce.</p>
                <p>In reply I have the honor to inform you that this question has been referred to
                    the Secretary of the Treasury, whose decision will be communicated promptly to
                    you.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alvey A. Adee.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
