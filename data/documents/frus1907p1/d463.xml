    <text>
        <body>
            <div frus:doc-dateTime-max="1907-03-08T23:59:59-05:00"
                frus:doc-dateTime-min="1907-03-08T00:00:00-05:00" n="463"
                subtype="historical-document" type="document" xml:id="d463">
                <note rend="inline" type="source">File No. 5619.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Minister <persName type="to">Jackson</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-03-08">
                            <hi rend="italic">March 8, 1907</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 145 Greek Series.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I inclose for appropriate inquiry and report copy
                    of a letter from J. T. Gore, D. D. S., of Philadelphia, requesting information
                    relative to the practice of dentistry in Greece by foreigners.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Bacon.</hi>
                    </signed>
                </closer>
                <frus:attachment>
                    <opener>
                        <seg rendition="#center">[Inclosure.]</seg>
                    </opener>
                    <head>
                        <hi rend="italic">Doctor <persName type="from">Gore</persName> to the <gloss
                                type="to">Secretary of State</gloss>
                        </hi>.</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Philadelphia</hi>
                            </placeName>, <date calendar="gregorian" when="1907-03-03">
                                <hi rend="italic">March 3, 1907</hi>
                            </date>.</dateline>
                    </opener>
                    <p>
                        <hi rend="smallcaps">Dear Sir</hi>: Will you kindly advise me whether it
                        would be necessary for one holding a diploma of the University of
                        Pennsylvania and a certificate of the state board of dental examiners of
                        Pennsylvania to undergo an examination in order to practice the profession
                        of dentistry in Athens, Greece.</p>
                    <p>A prompt reply will be appreciated by,</p>
                    <p>Yours, truly,</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">T. J. Gore, D. D. S</hi>.</signed>
                    </closer>
                </frus:attachment>
            </div>
        </body>
