<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1907-01-16T23:59:59-05:00" frus:doc-dateTime-min="1907-01-16T00:00:00-05:00" n="421" subtype="historical-document" type="document" xml:id="d421">
                        <note rend="inline" type="source">File No. 3892.</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">British Chargé</gloss></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1907-01-16"><hi rend="italic">January 16,
                                1907</hi></date>.</dateline></opener>
                        <p>Express to Sir Edward Grey my profound sympathy on account of the
                            disaster in Jamaica.</p>
                        <closer><signed><hi rend="smallcaps">Root.</hi></signed></closer>
                    </div>
                    </body></text></TEI>