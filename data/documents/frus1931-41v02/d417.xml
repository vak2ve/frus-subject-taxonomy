                subtype="historical-document" type="document" xml:id="d417">
                <note rend="inline" type="source">740.0011 Pacific War/856</note>
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The White House, Washington</hi>
                        </placeName> [<date calendar="gregorian" when="1941-12-06">December 6,
                            1941</date>].</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Cordell</hi>: Shoot this<note n="69" xml:id="d417fn69"
                        >See document <hi rend="italic">infra</hi>.</note> to Grew—I think it can go
                    in gray code—saves time—I don’t mind if it gets picked up.</p>
                <closer>
                    <signed>F.D.R.</signed>
                </closer>
            </div>
        </body>
