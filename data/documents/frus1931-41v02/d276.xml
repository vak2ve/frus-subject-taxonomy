    <text>
        <body>
            <div frus:doc-dateTime-max="1941-07-04T23:59:59-05:00"
                frus:doc-dateTime-min="1941-07-04T00:00:00-05:00" n="276"
                subtype="historical-document" type="document" xml:id="d276">
                <note rend="inline" type="source">711.94/2178<hi rend="superscript">2/18</hi>
                </note>
                <head>
                    <hi rend="italic">The Japanese Ambassador</hi> (<persName type="from">
                        <hi rend="italic">Nomura</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                    <note n="52" xml:id="d276fn52">Notation on original: “This letter was handed to
                        Mr. Ballantine by the Japanese Ambassador on July 4, 1941 with the request
                        that its contents be telephoned to the Secretary as soon as possible. The
                        contents of the letter were telephoned to the Secretary on July 5 by Mr.
                        Renchard.”</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1941-07-04">July 4,
                            1941</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: I am glad to inform you that I
                    am now authorized by the Foreign Minister to assure you that there is no
                    divergence of views in the Government regarding its fundamental policy of
                    adjusting Japanese-American relations on a fair basis.</p>
                <p>Yours very sincerely,</p>
                <closer>
                    <signed>K. <hi rend="smallcaps">Nomura</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
