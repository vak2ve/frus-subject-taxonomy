        <body>
            <div frus:doc-dateTime-max="1949-03-03T23:59:59-05:00" frus:doc-dateTime-min="1949-03-03T00:00:00-05:00" n="791" subtype="historical-document" type="document" xml:id="d791">
                <note rend="inline" type="source">611.9331/3–349</note>
                <head>
                    <hi rend="italic">Memorandum by the Executive Secretary of the National Security
                        Council</hi> (<persName type="from">
                        <hi rend="italic">Souers</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Council</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1949-03-03">March 3,
                            1949</date>.</dateline>
                </opener>
                <p rend="flushleft">Subject: United States Policy Regarding Trade With China</p>
                <p rend="flushleft">Reference: NSC 41</p>
                <p>The President has this date approved the Conclusions contained in the reference
                    report, and directs that they be implemented by all appropriate Executive
                    Departments and Agencies of the United States Government under the coordination
                    of the Secretary of State.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sidney</hi> W. <hi rend="smallcaps">Souers</hi>
                    </signed>
                </closer>
            </div>
        </body>
