<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-09-29T02:00:00-05:00" frus:doc-dateTime-min="1949-09-29T02:00:00-05:00" n="1393" subtype="historical-document" type="document" xml:id="d1393">
                        <note rend="inline" type="source">393.1115/9–2949: Telegram</note>
                        <head>
                            <hi rend="italic">The Second Secretary of Embassy in China</hi>
                                (<persName type="from"><hi rend="italic">Bacon</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Nanking</hi></placeName>, <date calendar="gregorian" when="1949-09-29T15:00:00+08:00">September
                                    29, 1949—3 p. m.</date>
                                <lb/> [Received September 29—6:23 a. m.]</dateline>
                        </opener>
                        <p>2192. ReDeptel 1131, September 26.<note n="73" xml:id="d1393fn73">See
                                footnote 71, <ref target="#pg_1348">p. 1348</ref>.</note> No
                            official or nonofficial Americans Nanking district refused exit permits
                            or deprived opportunity leave on <hi rend="italic">Gordon</hi>.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Bacon</hi>
                            </signed>
                        </closer>
                    </div>
