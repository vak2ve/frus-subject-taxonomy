<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-06-21T22:00:00-05:00" frus:doc-dateTime-min="1949-06-21T22:00:00-05:00" n="1015" subtype="historical-document" type="document" xml:id="d1015">
                    <note rend="inline" type="source">661.9331/6–2249: Telegram</note>
                    <head>
                        <hi rend="italic">The Minister-Counselor of Embassy in China</hi> (<persName type="from"><hi rend="italic">Clark</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Canton</hi></placeName>, <date calendar="gregorian" when="1949-06-22T11:00:00+08:00">June 22,
                                1949—11 a. m.</date>
                            <lb/> [Received June 22—6:21 a. m.]</dateline>
                    </opener>
                    <p>Cantel 630. Inquiry FonOff reveals Sino-Soviet trade discussions remain
                        standstill, Cantel 219, April 15; repeated Nanking 193, Shanghai 141.</p>
                    <p>Sent Department, repeated Nanking 421, Shanghai 361.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Clark</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>