                subtype="historical-document" type="document" xml:id="d1080">
                <note rend="inline" type="source">893.801/6–3049: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Bruce</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1949-06-30T15:00:00+01:00"
                            >June 30, 1949—3 p. m.</date>
                        <lb/> [Received June 30—12:35 p. m.]</dateline>
                </opener>
                <p>2720. Foreign Office informs us that reply is being sent to Chinese Government’s
                    note re closing certain Chinese ports and is similar US note in rejection
                    legality closure.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bruce</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
