<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-08-01T21:00:00-05:00" frus:doc-dateTime-min="1949-08-01T21:00:00-05:00" n="970" subtype="historical-document" type="document" xml:id="d970">
                        <note rend="inline" type="source">893.6363/8–249: Telegram</note>
                        <head>
                            <hi rend="italic">The Consul at Tsingtao</hi> (<persName type="from"><hi rend="italic">Hawthorne</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Tsingtao</hi></placeName>, <date calendar="gregorian" when="1949-08-02T10:00:00+08:00">August 2,
                                    1949—10 a. m.</date>
                                <lb/> [Received August 5–12:49 p. m.]</dateline>
                        </opener>
                        <p>399. Caltex Tsingtao shipping 200,000 gallons avigas Peiping account
                            Communists. Unknown whether for commercial or military use. Department
                            pass Nanking at its discretion.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hawthorne</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>