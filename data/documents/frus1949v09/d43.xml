        <body>
            <div frus:doc-dateTime-max="1949-06-08T00:00:00-05:00" frus:doc-dateTime-min="1949-06-08T00:00:00-05:00" n="43" subtype="historical-document" type="document" xml:id="d43">
                <note rend="inline" type="source">893.01/6–849: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Australia</hi> (<persName type="from">
                        <hi rend="italic">Foster</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Canberra</hi>
                        </placeName>, <date calendar="gregorian" when="1949-06-08T15:00:00+10:00">June 8, 1949—3 p. m.</date>
                        <lb/> [Received June 8—6:06 a. m.]</dateline>
                </opener>
                <p>114. Would appreciate reply Embtel 111, June 1, especially since External Affairs
                    might interpret my silence as indication US reconsidering policy nonrecognition
                    Communist regime China.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Foster</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
