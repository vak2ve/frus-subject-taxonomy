                subtype="historical-document" type="document" xml:id="d144">
                <note rend="inline" type="source">893.01/10–1349: Telegram</note>
                <head>
                    <hi rend="italic">The Special Assistant at Vatican City</hi> (<persName
                        type="from">
                        <hi rend="italic">Gowen</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vatican City</hi>
                        </placeName>, <date calendar="gregorian" when="1949-10-13">October 13,
                            1949</date>.<lb/>[Received October 15—11:44 a. m.]</dateline>
                </opener>
                <p>43. Deptel 18, October 11, re China.<note n="25" xml:id="d144fn25">See footnote
                        7, <ref target="#pg_116">p. 116</ref>.</note> Matter mentioned by me to
                    Montini, Vatican Under Secretary State, today. He said case extremely serious
                    and some days required for answer.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gowen</hi>
                    </signed>
                </closer>
            </div>
        </body>
