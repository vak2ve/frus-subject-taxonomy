<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-11-15T22:00:00-05:00" frus:doc-dateTime-min="1949-11-15T22:00:00-05:00" n="1406" subtype="historical-document" type="document" xml:id="d1406">
                        <note rend="inline" type="source">393.1115/11–1649: Telegram</note>
                        <head>
                            <hi rend="italic">The Consul General at Taipei</hi> (<persName type="from"><hi rend="italic">Macdonald</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Taipei</hi></placeName>, <date calendar="gregorian" when="1949-11-16T11:00:00+08:00">November
                                    16, 1949—11 a. m.</date>
                                <lb/> [Received November 16—1:01 a. m.]</dateline>
                        </opener>
                        <p>707. ReDeptel 423, November 2, 7 p. m. Started oral warnings November
                            15.</p>
                        <p>Sent Department; repeated Manila for Terry unnumbered.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Macdonald</hi>
                            </signed>
                        </closer>
                    </div>
