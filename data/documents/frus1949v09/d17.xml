    <teiHeader><fileDesc><titleStmt><title>The Ambassador in France (
                        Caffery
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1949v09</bibl><bibl type="frus-document-id">d17</bibl><bibl type="frus-document-number">17</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1949-05-10T07:00:00-05:00" notAfter="1949-05-10T07:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1949-05-10T07:00:00-05:00" frus:doc-dateTime-min="1949-05-10T07:00:00-05:00" n="17" subtype="historical-document" type="document" xml:id="d17">
                <note rend="inline" type="source">893.01/5–1049: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Caffery</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1949-05-10T13:00:00+01:00">May 10, 1949—1 p. m.</date>
                        <lb/> [Received 5:07 p. m.]</dateline>
                </opener>
                <p>1887. Schuman<note n="36" xml:id="d17fn36">Robert Schuman, French Minister for
                        Foreign Affairs.</note> told me last night that he agrees with Department’s
                    position with regard to recognizing Chinese Communist Government as set forth in
                    Deptcirtel May 6, 3 a. m. [<hi rend="italic">5 p. m</hi>.].</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caffery</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
