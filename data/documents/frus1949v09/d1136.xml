<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-10-15T23:59:59-05:00" frus:doc-dateTime-min="1949-10-15T00:00:00-05:00" n="1136" subtype="historical-document" type="document" xml:id="d1136">
                    <note rend="inline" type="source">393.115/10–1549: Telegram</note>
                    <head>
                        <hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from"><hi rend="italic">McConaughy</hi></persName>) <hi rend="italic">to
                            the <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Shanghai</hi></placeName>, <date ana="#date_apparent-typo-based-on-sibling-dates" calendar="gregorian" when="1949-10-15">October 15, 1949</date>.
                            <lb/> [Received October 15—6:51 p. m.]</dateline>
                    </opener>
                    <p>Unnumbered. Following message received from master SS <hi rend="italic">Flying Trader</hi> 2220 hours October 15 local time to A. P. Pattison
                        and Company, Shanghai agents, Isbrandtsen:</p>
                    <quote rend="blockquote">
                        <p>“Fired at and stopped by Chinese warship on Kiutoan Spit buoy. Now
                            anchored awaiting further orders.”</p>
                    </quote>
                    <p>Sent Department; repeated Chungking, Hong Kong, Taipei.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">McConaughy</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>