<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-10-06T23:59:59-05:00" frus:doc-dateTime-min="1949-10-06T00:00:00-05:00" n="115" subtype="historical-document" type="document" xml:id="d115">
                        <note rend="inline" type="source">893.01/10–649: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in Yugoslavia</hi> (<persName type="from"><hi rend="italic">Cannon</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>Belgrade</placeName>, <date calendar="gregorian" when="1949-10-06">October 6, 1949</date>.<lb/>[Received October
                                7—12:36 a. m.]</dateline>
                        </opener>
                        <p>1036. Today’s <hi rend="italic">Borba</hi><note n="88" xml:id="d115fn88">Yugoslav Communist newspaper.</note> announces FPRY<note n="89" xml:id="d115fn89">Federated People’s Republic of Yugoslavia.</note>
                            recognition yesterday of Central Government of the People’s Republic of
                            China.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Cannon</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>