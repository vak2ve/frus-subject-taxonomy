<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-12-12T12:00:00-05:00" frus:doc-dateTime-min="1949-12-12T12:00:00-05:00" n="244" subtype="historical-document" type="document" xml:id="d244">
                        <note rend="inline" type="source">893.01/12–1249: Telegram</note>
                        <opener>
                            <seg rendition="#center">[Extract]</seg>
                        </opener>
                        <head>
                            <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from"><hi rend="italic">Dunn</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Rome</hi></placeName>, <date calendar="gregorian" when="1949-12-12T18:00:00+01:00">December
                                    12, 1949—6 p. m.</date>
                                <lb/> [Received December 12—2:39 p. m.]</dateline>
                        </opener>
                        <p>4056. ReEmbtel 4041, December 10. Italian Government reply December 7 to
                            British <hi rend="italic">pro memoria</hi> agrees with British
                            evaluation of present political and military situation in China …</p>
                        <p rend="center">. . . . . . . . . . . . . .</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Dunn</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>