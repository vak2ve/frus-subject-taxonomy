<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-10-21T23:59:59-05:00" frus:doc-dateTime-min="1949-10-21T00:00:00-05:00" n="1397" subtype="historical-document" type="document" xml:id="d1397">
                        <note rend="inline" type="source">893.00/10–2149: Telegram</note>
                        <head>
                            <hi rend="italic">The Consul General at Hong Kong</hi> (<persName type="from"><hi rend="italic">Rankin</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Hong Kong</hi></placeName>, <date calendar="gregorian" when="1949-10-21">October 21,
                                1949</date>.<lb/>[Received October 21—8:17 a. m.]</dateline>
                        </opener>
                        <p>911. First message from British Consulate General Canton indicates all
                            quiet and no reports of American citizens in difficulties.<note n="75" xml:id="d1397fn75">Chinese Government troops evacuated Canton on
                                October 14.</note>
                        </p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Rankin</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>