        <body>
            <div frus:doc-dateTime-max="1949-10-05T23:59:59-05:00" frus:doc-dateTime-min="1949-10-05T00:00:00-05:00" n="676" subtype="historical-document" type="document" xml:id="d676">
                <note rend="inline" type="source">893.50 Recovery/9–3049</note>
                <head>
                    <hi rend="italic">President <persName type="from">Truman</persName> to Dr.
                            <persName type="to">Kan Chieh-hou</persName>, Personal Representative of
                        the Acting President of China</hi> (<persName>
                        <hi rend="italic">Li</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1949-10-05">October 5,
                            1949</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Kan</hi>: Thanks very much for your letter of
                    September thirtieth. I appreciate very much your interest in the matter referred
                    to and I am glad you have discussed it with Mr. Rusk and Mr. Butterworth.</p>
                <p>Sincerely yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Harry</hi> S. <hi rend="smallcaps">Truman</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
