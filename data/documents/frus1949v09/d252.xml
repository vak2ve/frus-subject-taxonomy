                subtype="historical-document" type="document" xml:id="d252">
                <note rend="inline" type="source">893.01/12–1749: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Burma</hi> (<persName type="from">
                        <hi rend="italic">Day</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rangoon</hi>
                        </placeName>, <date calendar="gregorian" when="1949-12-17T19:00:00+06:30"
                            >December 17, 1949—7 p. m.</date>
                        <lb/> [Received December 17—10:49 a. m.]</dateline>
                </opener>
                <p>550. Deputy Secretary Foreign Office has confirmed the Burma Government has
                    extended recognition Communist China as reportedly revealed by Foreign Minister
                    to press in Calcutta.</p>
                <p>Sent Department 550, repeated New Delhi 62.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Day</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
