<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-11-02T23:59:59-05:00" frus:doc-dateTime-min="1949-11-02T00:00:00-05:00" n="682" subtype="historical-document" type="document" xml:id="d682">
                        <note rend="inline" type="source">893.24/10–1349</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Dr. <persName type="to">Kan Chieh-hou</persName>, Personal
                                Representative of the Acting President of China</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1949-11-02">November 2,
                                1949</date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Dr. Kan</hi>: I am grateful for the frank
                            expression of your views respecting the present situation in China
                            contained in your letters of October 13 and October 23, 1949. I assure
                            you again that your views and those of your Government are most welcome
                            and that they will be given the most careful consideration.</p>
                        <p>Sincerely yours,</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Dean Acheson</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>