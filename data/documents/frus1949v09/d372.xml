<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-05-09T14:00:00-05:00" frus:doc-dateTime-min="1949-05-09T14:00:00-05:00" n="372" subtype="historical-document" type="document" xml:id="d372">
                    <note rend="inline" type="source">893.01/5–649: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            Consul at Taipei</hi> (<persName type="to"><hi rend="italic">Edgar</hi></persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1949-05-09T15:00:00-04:00">May 9, 1949—3
                                p. m.</date>
                        </dateline>
                    </opener>
                    <p>88. Urtel 150 May 6. Dept notes ur statement “question being asked locally”
                        etc. Pls identify persons raising this question.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Acheson</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>