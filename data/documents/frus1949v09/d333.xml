<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-03-23T04:00:00-05:00" frus:doc-dateTime-min="1949-03-23T04:00:00-05:00" n="333" subtype="historical-document" type="document" xml:id="d333">
                    <note rend="inline" type="source">894A.01/3–2349: Telegram</note>
                    <head>
                        <hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from"><hi rend="italic">Cabot</hi></persName>) <hi rend="italic">to the
                                <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Shanghai</hi></placeName>, <date calendar="gregorian" when="1949-03-23T17:00:00+08:00">March 23,
                                1949—5 p. m.</date>
                            <lb/> [Received March 23—5:43 a. m.]</dateline>
                    </opener>
                    <p>981. Mayor Wu<note n="3" xml:id="d333fn3">K. C. Wu, Mayor of Shanghai.</note>
                        has again urged on me in long conversation American aid to bolster up last
                        ditch Nationalist stand on Taiwan.</p>
                    <p>Sent Department, repeated Nanking 577.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Cabot</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>