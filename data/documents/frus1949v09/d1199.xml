<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-01-26T21:00:00-05:00" frus:doc-dateTime-min="1949-01-26T21:00:00-05:00" n="1199" subtype="historical-document" type="document" xml:id="d1199">
                    <note rend="inline" type="source">811.3393/1–2549: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            Consul at Tsingtao</hi> (<persName type="to"><hi rend="italic">Strong</hi></persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1949-01-26T21:00:00-05:00">January 26,
                                1949—9 p. m.</date>
                        </dateline>
                    </opener>
                    <p>42. Dept understands (Contel 44 Jan 24[<hi rend="italic">25</hi>]) Navy has
                        forwarded Adm Badger material for use in connection any publicity re
                        withdrawal.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Acheson</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>