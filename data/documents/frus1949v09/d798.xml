                subtype="historical-document" type="document" xml:id="d798">
                <note rend="inline" type="source">693.0031/4–2949: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in the United Kingdom</hi> (<persName
                        type="from">
                        <hi rend="italic">Douglas</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1949-04-29T20:00:00+01:00"
                            >April 29, 1949—8 p. m.</date>
                        <lb/> [Received April 29—4:18 p. m.]</dateline>
                </opener>
                <p>1661. Received Deptel 1382, April 22. Tomlinson,<note n="28" xml:id="d798fn28"
                        >Frank S. Tomlinson of the Far Eastern Department, British Foreign
                        Office.</note> Foreign Office, states decision at highest level required.
                    British apparently particularly worried re application policy Hong Kong and had
                    awaited recent arrival UK trade commissioner that colony in order discuss this
                    aspect.</p>
                <p>Foreign Office cannot indicate definite date when final decision possible but
                    will expedite consideration.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Douglas</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
