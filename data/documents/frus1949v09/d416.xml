                subtype="historical-document" type="document" xml:id="d416">
                <note rend="inline" type="source">893.50 Recovery/8–2949: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at Taipei</hi> (<persName type="to">
                        <hi rend="italic">Taipei</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1949-08-29T19:00:00-04:00"
                            >August 29, 1949—7 p. m.</date>
                    </dateline>
                </opener>
                <p>269. Dept unno instr Aug 9.<note n="4" xml:id="d416fn4">Not printed.</note> For
                    your info, JCS views previously expressed in memo Feb 10 to NSC have been
                    reaffirmed and clarified in JCS memo to NSC contained in NSC 37/7 Aug 22. Copy
                    this document being forwarded soonest.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Acheson</hi>
                    </signed>
                </closer>
            </div>
        </body>
