<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>Memorandum by the Executive Secretary of the National Security
                        Council (
                        Souers
                    ) to the Council</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1949v09</bibl><bibl type="frus-document-id">d323</bibl><bibl type="frus-document-number">323</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1949-03-03T00:00:00-05:00" notAfter="1949-03-03T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1949-03-03T23:59:59-05:00" frus:doc-dateTime-min="1949-03-03T00:00:00-05:00" n="323" subtype="historical-document" type="document" xml:id="d323">
                <note rend="inline" type="source">Executive Secretariat Files</note>
                <head>
                    <hi rend="italic">Memorandum by the Executive Secretary of the National Security
                        Council</hi> (<persName type="from">
                        <hi rend="italic">Souers</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Council</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1949-03-03">March 3,
                            1949</date>.</dateline>
                </opener>
                <p rend="flushleft">Subject: Supplementary Measures With Respect to Formosa</p>
                <p rend="flushleft">Reference: NSC 37/5<note n="94" xml:id="d323fn94">March 1, <ref target="#pg_290">p. 290</ref>.</note>
                </p>
                <p>The President has this date approved the Conclusions contained in the reference
                    report, and directs that they be implemented by all appropriate <pb facs="0307" n="297" xml:id="pg_297"/> Executive Departments and Agencies of the United
                    States Government under the coordination of the Secretary of State.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sidney</hi> W. <hi rend="smallcaps">Souers</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
