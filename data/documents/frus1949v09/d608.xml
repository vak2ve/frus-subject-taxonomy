<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-02-05T17:00:00-05:00" frus:doc-dateTime-min="1949-02-05T17:00:00-05:00" n="608" subtype="historical-document" type="document" xml:id="d608">
                        <note rend="inline" type="source">893.50 Recovery/2–249: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Consul General at Peiping</hi> (<persName type="to"><hi rend="italic">Clubb</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1949-02-05T17:00:00-05:00">February
                                    5, 1949—5 p. m.</date>
                            </dateline>
                        </opener>
                        <p>66. Rptd Shanghai 204, Nanking 181. ECA agrees recommendation final para
                            Contel 167 Feb 2 subject Lapham’s approval. Dept concurs.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Acheson</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>