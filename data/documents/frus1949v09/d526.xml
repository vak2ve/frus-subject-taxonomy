        <body>
            <div frus:doc-dateTime-max="1949-03-03T23:59:59-05:00" frus:doc-dateTime-min="1949-03-03T00:00:00-05:00" n="526" subtype="historical-document" type="document" xml:id="d526">
                <note rend="inline" type="source">Executive Secretariat Files</note>
                <head>
                    <hi rend="italic">Memorandum by the Acting Executive Secretary of the National
                        Security Council</hi> (<persName type="from">
                        <hi rend="italic">Lay</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Council</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1949-03-03">March 3,
                            1949</date>.</dateline>
                </opener>
                <p rend="flushleft">Subject: United States Policy Toward China</p>
                <p rend="flushleft">Reference: NSC 34/2<note n="51" xml:id="d526fn51">February 28,
                            <ref target="#pg_491">p. 491</ref>.</note>
                </p>
                <p>The President has this date approved the Recommendations contained in the
                    reference report, and directs that they be implemented by all appropriate
                    Executive Departments and Agencies of the United States Government under the
                    coordination of the Secretary of State.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">James</hi> S. <hi rend="smallcaps">Lay, Jr.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
