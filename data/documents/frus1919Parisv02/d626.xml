                subtype="historical-document" type="document" xml:id="d626">
                <note rend="inline" type="source">600.119/1775a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Italy</hi> (<persName type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-18T19:00:00-05:00"
                            >November 18, 1918—7 p.m.</date>
                    </dateline>
                </opener>
                <p>1843. For Stewart [from War Trade Board]: number 43. We desire to impress upon
                    our foreign representatives the importance during the period of Armistice of
                    maintaining close and sympathetic relations with the representatives of the
                    Associated Governments. We trust that your relations with your British and
                    French colleagues are marked by cordial cooperation and mutual frankness.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
