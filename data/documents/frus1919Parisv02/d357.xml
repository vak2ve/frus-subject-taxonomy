                subtype="historical-document" type="document" xml:id="d357">
                <note rend="inline" type="source">860c.01/185a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in France</hi> (<persName type="to">
                        <hi rend="italic">Sharp</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-12-21T15:00:00-05:00"
                            >December 21, 1918—3 p.m.</date>
                    </dateline>
                </opener>
                <p>6704. Investigate carefully and report promptly exact relations existing between
                    Polish National Committee in Paris and Polish officers in charge of affairs in
                    Poland.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Polk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
