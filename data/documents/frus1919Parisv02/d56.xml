<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-11-26T23:59:59-05:00" frus:doc-dateTime-min="1918-11-26T00:00:00-05:00" n="56" subtype="historical-document" type="document" xml:id="d56">
                        <note rend="inline" type="source">763.72119/2804</note>
                        <head>
                            <hi rend="italic">The Swiss Minister</hi> (<persName type="from"><hi rend="italic">Sulzer</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi>
                                </placeName>, <date calendar="gregorian" when="1918-11-26">November
                                    26, 1918</date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: I am directed by my Government to inform
                            your Excellency that the German Government would be grateful to receive
                            an early reply from the United States and Allied Governments to its
                            communication regarding negotiations for a preliminary peace, which
                            communication I had the honor to transmit to your Excellency with my
                            note of November 13, 1918.<note n="1" xml:id="d56fn1">For text of the
                                note of Nov. 13, see telegram No. 29, Dec. 14, 5 p.m., to the
                                Commission to Negotiate Peace, <ref target="#pg_72">p.
                                72</ref>.</note>
                        </p>
                        <p>Accept [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hans Sulzer</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>