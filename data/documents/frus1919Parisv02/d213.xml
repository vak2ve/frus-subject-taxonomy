                subtype="historical-document" type="document" xml:id="d213">
                <note rend="inline" type="source">763.72/12285: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-18T20:00:00+01:00"
                            >November 18, 1918—8 p.m.</date>
                        <lb/> [Received November 19—3:20 a.m.]</dateline>
                </opener>
                <p>2378. I hear that the French have taken over bay near Fiume. They say as naval
                    base for their troops in the country, reason which Italians seem to
                    question.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Nelson Page</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
