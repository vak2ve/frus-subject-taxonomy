<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-01-09T23:59:59-05:00" frus:doc-dateTime-min="1919-01-09T00:00:00-05:00" n="404" subtype="historical-document" type="document" xml:id="d404">
                        <note rend="inline" type="source">Robert Lansing Papers</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the French Ambassador to the United States</hi> (<persName type="to"><hi rend="italic">Jusserand</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Paris</hi>
                                </placeName>, <date calendar="gregorian" when="1919-01-09">January
                                    9, 1919</date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Ambassador</hi>: I have your letter of
                            January 7th enclosing certain documents regarding the Schleswig-Holstein
                            question and am indeed grateful to you for sending me the interesting
                            information.</p>
                        <p>With kindest regards [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Robert Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                </body></text></TEI>