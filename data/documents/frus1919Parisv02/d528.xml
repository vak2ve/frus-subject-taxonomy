                subtype="historical-document" type="document" xml:id="d528">
                <note rend="inline" type="source">840.48/2598: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Special Representative</hi> (<persName type="to">
                        <hi rend="italic">House</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-29T15:00:00-05:00"
                            >November 29, 1918—3 p.m.</date>
                    </dateline>
                </opener>
                <p>90. Your No. 188.<note n="16" xml:id="d528fn16">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_636">p. 636</ref>.</note> On
                    the assumption that Mr. Hoover agrees, the President authorizes you to propose
                    the plan set forth.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
