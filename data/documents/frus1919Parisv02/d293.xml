                subtype="historical-document" type="document" xml:id="d293">
                <note rend="inline" type="source">Robert Lansing Papers</note>
                <head>
                    <hi rend="italic">President <persName type="from">Wilson</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1919-01-11">11 January,
                            1919</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: King Nicholas of Montenegro is
                    seeking an interview with me. I would very much value a tip from you and your
                    fellow Commissioners as to whether it would be wise or serviceable for me to
                    give him an audience.</p>
                <p>Cordially and faithfully yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Woodrow Wilson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
