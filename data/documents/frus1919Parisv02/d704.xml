<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-01-13T23:59:59-05:00" frus:doc-dateTime-min="1919-01-13T00:00:00-05:00" n="704" subtype="historical-document" type="document" xml:id="d704">
                    <note rend="inline" type="source">600.119/2009b: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss>
                            to the Ambassador in Great Britain</hi> (<persName type="to"><hi rend="italic">Davis</hi></persName>)<note n="67" xml:id="d704fn67">The same, on same date, to Embassies in France (for McFadden, No. 587,
                            for Taylor) and in Italy (for Stewart, No. 62).</note>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi>
                            </placeName>, <date calendar="gregorian" when="1919-01-13">January 13,
                                1919</date>.</dateline>
                    </opener>
                    <p>For Sheldon [from War Trade Board]: No. 2050. Applications for export
                        licenses to Allied countries are no longer being referred to the Allied
                        Missions here.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Polk</hi>
                        </signed>
                    </closer>
                </div>
            </body></text></TEI>