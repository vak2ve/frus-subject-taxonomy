                subtype="historical-document" type="document" xml:id="d666">
                <note rend="inline" type="source">103.96/1768: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Davis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1918-12-20">December 20,
                            1918</date>.<lb/>[Received December 20—12:48 p.m.]</dateline>
                </opener>
                <p>4772. War Trade Board [from Sheldon]: No. 2140. For McCormick. Refer your 1859,
                    Department’s 3470, December 17, <pb facs="0854" n="766" xml:id="pg_766"/>
                    British, French and Italian representatives on A.B.C. are submitting urgent
                    statement of their position and ask you to withhold action proposed in last
                    sentence of your telegram until you receive their statement which is being
                    telegraphed today.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
