                subtype="historical-document" type="document" xml:id="d661">
                <note rend="inline" type="source">600.119/1854: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Laughlin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1918-12-18">December 18,
                            1918</date>.<lb/>[Received December 18—12:55 p.m.]</dateline>
                </opener>
                <p>4701. War Trade Board [from Sheldon]: 2121. Your 1831, Department’s 3527,
                    December 13. See our 2067, December 12. In addition to Syria and Palestine trade
                    will be resumed with Mesopotamia as from January 1st. For all three territories
                    proclamations are about to be issued.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Laughlin</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
