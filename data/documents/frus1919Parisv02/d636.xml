                subtype="historical-document" type="document" xml:id="d636">
                <note rend="inline" type="source">763.72112/10840: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Great Britain</hi> (<persName type="to">
                        <hi rend="italic">Laughlin</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-27">November 27,
                            1918</date>.</dateline>
                </opener>
                <p>3098. For Sheldon [from War Trade Board]: No. 1732. Department’s 3072 Nov. 26 our
                    1728, sent before receiving Embassy’s 3944, Nov. 22. Your 1916. From cursory
                    examination your 1916 see no reason to modify views expressed our 1728. Your
                    1916 will, however, receive further immediate consideration if desired.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
