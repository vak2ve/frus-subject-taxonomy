<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-01-06T23:59:59-05:00" frus:doc-dateTime-min="1919-01-06T00:00:00-05:00" n="590" subtype="historical-document" type="document" xml:id="d590">
                    <note rend="inline" type="source">Paris Peace Conf. 103.97/95: Telegram</note>
                    <head>
                        <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Commission to Negotiate Peace</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Rome</hi>
                            </placeName>, <date calendar="gregorian" when="1919-01-06">January 6,
                                1919</date>.<lb/>[Received January 7—3:50 a.m.]</dateline>
                    </opener>
                    <p>51. For Hoover.</p>
                    <quote rend="blockquote">
                        <p>“Appreciating your considerations I have telegraphed to accept 20,000
                            tons of pork for January and that Italy unites with England and France
                            to take her share of the 100,000,000 bushels of grain. Cordial
                            greetings. Crespi.”</p>
                    </quote>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Nelson Page</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>