<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-12-04T16:00:00-05:00" frus:doc-dateTime-min="1918-12-04T16:00:00-05:00" n="409" subtype="historical-document" type="document" xml:id="d409">
                    <note rend="inline" type="source">861.00/6537: Telegram</note>
                    <head>
                        <hi rend="italic">Colonel <persName type="from">E. M. House</persName> to
                            the <gloss type="to">Acting Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Paris</hi>
                            </placeName>, <date calendar="gregorian" when="1918-12-04T21:00:00+00:00">December 4, 1918—9 p.m.</date>
                            <lb/> [Received December 4—4:49 p.m.]</dateline>
                    </opener>
                    <p>227. Your number 115, December 2, 9 p.m. respecting situation in Russia. This
                        telegram was very helpful and I appreciate being kept advised along these
                        lines.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Edward House</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>