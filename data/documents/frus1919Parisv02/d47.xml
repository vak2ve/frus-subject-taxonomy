                subtype="historical-document" type="document" xml:id="d47">
                <note rend="inline" type="source">Paris Peace Conf. 185.001/23½</note>
                <head>
                    <hi rend="italic">The Liaison Officer for General Pershing</hi> (<persName
                        type="from">
                        <hi rend="italic">Hayes</hi>
                    </persName>) <hi rend="italic">to the Secretary of the Commission to Negotiate
                        Peace</hi> (<persName type="to">
                        <hi rend="italic">Grew</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1919-01-07">January 7,
                            1919</date>.</dateline>
                </opener>
                <p rend="flushleft">For General Churchill and Mr. Grew:</p>
                <p>On the last day of 1918, the American Expeditionary Force in the American areas
                    of the front totaled 1,846,733; in the British area 4,319; in England 6,049; in
                    Italy 5,473; in Russia 4,720—a total of 1,867,294.</p>
                <closer>
                    <signed>R[<hi rend="smallcaps">alph</hi>] A. H[<hi rend="smallcaps"
                        >ayes</hi>]</signed>
                </closer>
            </div>
        </body>
