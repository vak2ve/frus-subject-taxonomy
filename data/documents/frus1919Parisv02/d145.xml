<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-12-26T23:59:59-05:00" frus:doc-dateTime-min="1918-12-26T00:00:00-05:00" n="145" subtype="historical-document" type="document" xml:id="d145">
                        <note rend="inline" type="source">Paris Peace Conf. 184.011/15</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Professor <persName type="to">A. C. Coolidge</persName>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Paris</hi>
                                </placeName>, <date calendar="gregorian" when="1918-12-26">December
                                    26, 1918</date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Sir</hi>: You are hereby assigned to the American
                            Commission to Negotiate Peace for the purpose of proceeding to Austria
                            for that Commission to observe political conditions in Austria-Hungary
                            and neighboring countries.</p>
                        <p>Yours very truly,</p>
                        <closer>[File copy not signed]</closer>
                    </div>
                    </body></text></TEI>