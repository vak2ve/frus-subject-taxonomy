                subtype="historical-document" type="document" xml:id="d440">
                <note rend="inline" type="source">763.72119/3162: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in China</hi> (<persName type="to">
                        <hi rend="italic">Reinsch</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-01-06T18:00:00-05:00"
                            >January 6, 1919—6 p.m.</date>
                    </dateline>
                </opener>
                <p>Your December 24, 5 p.m. You will please be careful to abstain from any
                    participation along the lines mentioned until you are so instructed. Matter is
                    being communicated to Paris for information.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Polk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
