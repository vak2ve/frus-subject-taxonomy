    <text>
        <body>
            <div frus:doc-dateTime-max="1918-12-30T16:00:00-05:00"
                frus:doc-dateTime-min="1918-12-30T16:00:00-05:00" n="183"
                subtype="historical-document" type="document" xml:id="d183">
                <note rend="inline" type="source">Paris Peace Conf. 183.9 Bulgaria/2:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Bulgaria</hi> (<persName type="from">
                        <hi rend="italic">Wilson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Commission to Negotiate
                            Peace</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Sofia</hi>
                        </placeName>, <date calendar="gregorian" when="1918-12-30T23:00:00+02:00"
                            >December 30, 1918—11 p.m.</date>
                        <lb/> [Received January 3, 1919—10 p.m.]</dateline>
                </opener>
                <p>5. 6, December 16, 11 a.m. [<hi rend="italic">12 a.m.?</hi>], to American Embassy
                    Paris. Would be grateful if some reply could be made to Bulgarian request for
                    permission to send delegates unofficially to Paris. Am in receipt of daily
                    inquiries from Bulgarian Government as to decision of my Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wilson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
