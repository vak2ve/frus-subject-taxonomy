                subtype="historical-document" type="document" xml:id="d200">
                <note rend="inline" type="source">763.72119/3116</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Italian Chargé</hi> (<persName type="to">
                        <hi rend="italic">Valentino</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-01-22">January 22,
                            1919</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your Note of November 19, 1918, transmitting a memorandum regarding the
                    situation in Tripoli arising out of the reported violation of the armistice by
                    Turkey, and stating that the Italian Government would appreciate it if the
                    American Government would approach the British Government with the view of
                    having Turkey keep faith to her engagements.</p>
                <p>In reply I have the honor to inform you that as the United States is not at war
                    with Turkey and is not a party to the armistice it is unable to take the
                    requested action in this matter.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Frank L. Polk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
