    <text>
        <body>
            <div frus:doc-dateTime-max="1943-08-30T23:59:59-05:00"
                frus:doc-dateTime-min="1943-08-30T00:00:00-05:00" n="551"
                subtype="historical-document" type="document" xml:id="d551">
                <note rend="inline" type="source">Roosevelt Papers: Telegram</note>
                <head>
                    <hi rend="italic">Prime Minister <persName type="from">Churchill</persName> to
                        President <persName type="to">Roosevelt</persName>
                    </hi>
                    <note n="1" xml:id="d551fn1">The message originated in Canada. Channel of
                        transmission not indicated.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <date calendar="gregorian" when="1943-08-30">
                            <hi rend="smallcaps">August</hi> 30, 1943</date>.</dateline>
                </opener>
                <p>Message from <gloss target="#t_CW1">Colonel Warden</gloss> to the President.</p>
                <p>Clemmie<note n="2" xml:id="d551fn2">Mrs. Churchill.</note> has benefited by her
                    rest up here and would very much like to come with us to Washington if you still
                    have room. She would not be able to undertake any public engagements.</p>
            </div>
        </body>
    </text>
