<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-05-14T23:59:59-05:00" frus:doc-dateTime-min="1943-05-14T00:00:00-05:00" n="135" subtype="historical-document" type="document" xml:id="d135">
                            <note rend="inline" type="source">Hopkins Papers</note>
                            <head>
                                <hi rend="italic">Prime Minister <persName type="from">Churchill’s</persName> Assistant Private Secretary</hi>
                                        (<persName><hi rend="italic">Rowan</hi></persName>) <hi rend="italic">to the Presidents Special Assistant</hi>
                                    (<persName type="to"><hi rend="italic">Hopkins</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, [<date calendar="gregorian" when="1943-05-14">May 14,
                                    1943</date>.]</dateline>
                            </opener>
                            <p rend="flushleft">
                                <hi rend="smallcaps">Mr. Hopkins.</hi>
                            </p>
                            <p>You asked me to remind you to speak to Mr. Mackenzie King about his
                                visit to the <gloss target="#t_White1">White</gloss> House—see
                                telegram attached.</p>
                            <closer>
                                <signed>T. L. R[<hi rend="smallcaps">owan</hi>]</signed>
                                <lb/> 14.5.43</closer>
                        </div>
                        </body></text></TEI>