    <text>
        <body>
            <div frus:doc-dateTime-max="1943-07-20T23:59:59-05:00"
                frus:doc-dateTime-min="1943-07-20T00:00:00-05:00" n="324"
                subtype="historical-document" type="document" xml:id="d324">
                <note rend="inline" type="source">Roosevelt Papers</note>
                <head>
                    <hi rend="italic">The Presidents Special Assistant</hi> (<persName type="from">
                        <hi rend="italic">Hopkins</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">President</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-07-20">July 20,
                            1943</date>.</dateline>
                </opener>
                <p rend="center">
                    <hi rend="smallcaps">Memorandum for the President</hi>
                </p>
                <p>
                    <hi rend="smallcaps">Dear Mr. President</hi>: I think you made a firm commitment
                    to Churchill in regard to this when he was here and there is nothing to do but
                    go through with it.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Harry</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
