<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-08-02T23:59:59-05:00" frus:doc-dateTime-min="1943-08-02T00:00:00-05:00" n="247" subtype="historical-document" type="document" xml:id="d247">
                            <note rend="inline" type="source">Roosevelt Papers: Telegram</note>
                            <head>
                                <hi rend="italic">Prime Minister <persName type="from">Churchill</persName> to President <persName type="to">Roosevelt</persName>
                                </hi><note n="1" xml:id="d247fn1">Sent to Washington by the United
                                    States Military Attaché London, via Army channels; forwarded by
                                    the White House Map Room to Roosevelt, who was then at Birch
                                    Island.</note>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1943-08-02">2 August
                                    1943</date>.</dateline>
                            </opener>
                            <p>Number 397. <gloss target="#t_FNP1">Former Naval Person</gloss> to
                                President personal. Your number 338.<note n="2" xml:id="d247fn2">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_525">p.
                                    525</ref>.</note> Many thanks.</p>
                        </div>
                        </body></text></TEI>