<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-06-17T23:59:59-05:00" frus:doc-dateTime-min="1943-06-17T00:00:00-05:00" n="320" subtype="historical-document" type="document" xml:id="d320">
                            <note rend="inline" type="source">Hopkins Papers: Telegram</note>
                            <head>
                                <hi rend="italic">The President’s Special Assistant</hi> (<persName type="from"><hi rend="italic">Hopkins</hi></persName>) <hi rend="italic">to Prime Minister <persName type="to">Churchill</persName>
                                </hi><note n="1" xml:id="d320fn1">Channel of transmission not
                                    indicated.</note>
                            </head>
                            <opener>
                                <seg rendition="#left">
                                    <hi rend="smallcaps">secret</hi>
                                </seg>
                                <dateline rendition="#right">[<placeName><hi rend="smallcaps">Washington</hi></placeName>,] <date calendar="gregorian" when="1943-06-17">June 17,
                                    1943</date>.</dateline>
                            </opener>
                            <p rend="center">. . . . . . . . . . . . . .</p>
                            <p>The matter of <gloss target="#t_TubeAlloys1">
                                    <hi rend="smallcaps">Tube Alloys</hi>
                                </gloss> is in hand and I think will be disposed of completely the
                                first of the week.</p>
                            <p rend="center">. . . . . . . . . . . . . .</p>
                        </div>
                        </body></text></TEI>