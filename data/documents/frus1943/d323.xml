<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-07-14T23:59:59-05:00" frus:doc-dateTime-min="1943-07-14T00:00:00-05:00" n="323" subtype="historical-document" type="document" xml:id="d323">
                            <note rend="inline" type="source">Roosevelt Papers</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">President</gloss> to the
                                    Presidents Special Assistant</hi> (<persName type="to"><hi rend="italic">Hopkins</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1943-07-14">July 14,
                                    1943</date>.</dateline>
                            </opener>
                            <p rend="center">
                                <hi rend="smallcaps">Memorandum for Hon. Harry Hopkins</hi>
                            </p>
                            <p>What should I do about this and the reply to Churchill’s wire?</p>
                            <closer>
                                <signed>F[<hi rend="smallcaps">ranklin</hi>] D. R[<hi rend="smallcaps">oosevelt</hi>]</signed>
                            </closer>
                        </div>
                        </body></text></TEI>