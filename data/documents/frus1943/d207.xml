    <text>
        <body>
            <div frus:doc-dateTime-max="1943-08-16T23:59:59-05:00"
                frus:doc-dateTime-min="1943-08-16T00:00:00-05:00" n="207"
                subtype="historical-document" type="document" xml:id="d207">
                <note rend="inline" type="source">Roosevelt Papers: Telegram</note>
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to Prime
                        Minister <persName type="to">Churchill</persName>
                    </hi>
                    <note n="1" xml:id="d207fn1">Sent via Army channels as telegram No. <gloss
                            target="#t_White1">
                            <hi rend="smallcaps">White</hi>
                        </gloss> 89 to the temporary <gloss target="#t_White1">White</gloss> House
                        Map Room established at Quebec.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1943-08-16">16 August
                            1943</date>.</dateline>
                </opener>
                <p>Personal and secret for the <gloss target="#t_FNP1">Former Naval Person</gloss>.
                    Number 345. Reference your 413.<note n="2" xml:id="d207fn2">
                        <hi rend="italic">Supra.</hi>
                    </note> Delighted with arrangements. Things are progressing everywhere.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Roosevelt</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
