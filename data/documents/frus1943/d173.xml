<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-07-21T23:59:59-05:00" frus:doc-dateTime-min="1943-07-21T00:00:00-05:00" n="173" subtype="historical-document" type="document" xml:id="d173">
                        <note rend="inline" type="source">Roosevelt Papers: Telegram</note>
                        <head>
                            <hi rend="italic">Prime Minister <persName type="from">Churchill</persName> to President <persName type="to">Roosevelt</persName>
                            </hi><note n="1" xml:id="d173fn1">Sent by the United States Military
                                Attaché, London, via Army channels.</note>
                        </head>
                        <opener>
                            <seg rendition="#left">
                                <hi rend="smallcaps">secret</hi>
                            </seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1943-07-21">21 July,
                                1943</date>.</dateline>
                        </opener>
                        <p>375. <gloss target="#t_FNP1">Former Naval Person</gloss> to President
                            Personal. <gloss target="#t_Quadrant1">
                                <hi rend="smallcaps">Quadrant</hi></gloss>.</p>
                        <closer>
                            <signed>
                                <gloss target="#t_Prime1">
                                    <hi rend="smallcaps">Prime</hi>
                                </gloss>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>