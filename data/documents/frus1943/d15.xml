                subtype="historical-document" type="document" xml:id="d15">
                <note rend="inline" type="source">Hopkins Papers: Telegram</note>
                <head>
                    <hi rend="italic">Prime Minister <persName type="from">Churchill</persName> to
                        the President’s Special Assistant</hi> (<persName type="to">
                        <hi rend="italic">Hopkins</hi>
                    </persName>)<note n="1" xml:id="d15fn1">Channel of transmission not
                        indicated.</note>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>,] <date calendar="gregorian" when="1943-04-11">April 11,
                            1943</date>.</dateline>
                </opener>
                <p>I cannot help being much disappointed by your telegram.</p>
            </div>
        </body>
    </text>
