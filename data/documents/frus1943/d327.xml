<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-07-26T23:59:59-05:00" frus:doc-dateTime-min="1943-07-26T00:00:00-05:00" n="327" subtype="historical-document" type="document" xml:id="d327">
                            <note rend="inline" type="source">Roosevelt Papers: Telegram</note>
                            <head>
                                <hi rend="italic">President <persName type="from">Roosevelt</persName> to Prime Minister <persName type="to">Churchill</persName>
                                </hi><note n="1" xml:id="d327fn1">Channel of transmission not
                                    indicated.</note>
                            </head>
                            <opener>
                                <seg rendition="#left">
                                    <hi rend="smallcaps">secret</hi>
                                </seg>
                                <dateline rendition="#right">[<placeName><hi rend="smallcaps">Washington</hi></placeName>,] <date calendar="gregorian" when="1943-07-26">July 26,
                                    1943</date>.</dateline>
                            </opener>
                            <p>326. Personal and secret to the <gloss target="#t_FNP1">Former Naval
                                    Person</gloss> from the President.</p>
                            <p>In reply to your 354.<note n="2" xml:id="d327fn2">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_632">p.
                                    632</ref>.</note> I have arranged satisfactorily for the <gloss target="#t_TubeAlloys1">
                                    <hi rend="smallcaps">Tube Alloys</hi></gloss>. Unless you have
                                the proper person in this country now, it might be well if your top
                                man in this enterprise comes over to get full understanding from our
                                people.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Roosevelt</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>