<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-07-14T23:59:59-05:00" frus:doc-dateTime-min="1943-07-14T00:00:00-05:00" n="873" subtype="historical-document" type="document" xml:id="d873">
                            <note rend="inline" type="source">711.94114A/3: Telegram</note>
                            <head>
                                <hi rend="italic">The Minister in Switzerland</hi> (<persName type="from"><hi rend="italic">Harrison</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Bern</hi></placeName>, <date calendar="gregorian" when="1943-07-14">July 14,
                                    1943</date>.<lb/>[Received July 14—9:21 p.m.]</dateline>
                            </opener>
                            <p>4157. American interests Japan. Department’s 1252, May 25. Legation
                                Tokyo telegraphs: <pb facs="1010" n="998" xml:id="pg_998"/>
                                <quote rend="blockquote">
                                    <p>Japanese Foreign Office states Japanese Government not
                                        prepared give such authorization as article 13 Japanese
                                        regulations regarding prisoner of war prescribes witness be
                                        present all visits to prisoners.</p>
                                </quote>
                            </p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Harrison</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>