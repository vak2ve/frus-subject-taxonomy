<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-02-04T22:00:00-05:00" frus:doc-dateTime-min="1943-02-04T22:00:00-05:00" n="64" subtype="historical-document" type="document" xml:id="d64">
                            <note rend="inline" type="source">125.0046B/a: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in the United Kingdom</hi> (<persName type="to"><hi rend="italic">Winant</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1943-02-04T23:00:00-04:00">February 4, 1943—11 p.m.</date>
                                </dateline>
                            </opener>
                            <p>840. In view of decision by this Government to construct additional
                                refining facilities at Bahrein involving substantial increase in
                                American personnel and shipping there, the Department desires to
                                establish a consulate at Bahrein. In as much as the foreign affairs
                                of Bahrein are controlled by the British Government please ascertain
                                whether the appropriate British authorities are agreeable to the
                                establishment of the consulate.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>