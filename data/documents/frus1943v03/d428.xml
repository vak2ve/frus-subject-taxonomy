                subtype="historical-document" type="document" xml:id="d428">
                <note rend="inline" type="source">124.61/263: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in the Soviet Union</hi> (<persName type="from">
                        <hi rend="italic">Standley</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Moscow</hi>
                        </placeName>, <date calendar="gregorian" when="1943-08-10T15:00:00+03:00"
                            >August 10, 1943—3 p.m.</date>
                        <lb/> [Received 9:15 p.m.]</dateline>
                </opener>
                <p>1038. My number 1010, August 3, 5 p.m. Kuibyshev advises that office there will
                    be closed August 14.<note n="58" xml:id="d428fn58">All of the staff at Kuibyshev
                        except one person, who was to come later, arrived in Moscow by special
                        diplomatic train on August 16, 1943.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Standley</hi>
                    </signed>
                </closer>
            </div>
        </body>
