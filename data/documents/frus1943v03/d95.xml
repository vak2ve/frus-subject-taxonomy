                subtype="historical-document" type="document" xml:id="d95">
                <note rend="inline" type="source">841D.01/204: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the United Kingdom</hi> (<persName type="to">
                        <hi rend="italic">Winant</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-10-05T00:00:00-04:00"
                            >October 5, 1943—midnight</date>.</dateline>
                </opener>
                <p>6157. Personal for Winant, Department’s 5736, September 18 and your 6266,
                    September 19. Could you make discreet inquiries as to when we may expect to
                    receive the British Government’s views? As you know the President is personally
                    interested in this matter.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
