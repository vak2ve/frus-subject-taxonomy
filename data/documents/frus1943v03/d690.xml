    <text>
        <body>
            <div frus:doc-dateTime-max="1943-04-29T23:59:59-05:00"
                frus:doc-dateTime-min="1943-04-29T00:00:00-05:00" n="690"
                subtype="historical-document" type="document" xml:id="d690">
                <note rend="inline" type="source">800.01B11 Registration/1637</note>
                <head>
                    <hi rend="italic">The Ambassador of the Soviet Union</hi> (<persName type="from">
                        <hi rend="italic">Litvinov</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <p>The Ambassador of the Union of Soviet Socialist Republics presents his
                    compliments to the Secretary of State and has the honor to transmit herewith
                    Form FA–3F–6M filled out by the Amtorg Trading Corporation, 210 Madison Avenue,
                    New York, N.Y.,<note n="35" xml:id="d690fn35">Official purchasing and sales
                        agency of the Soviet Union in the United States.</note> and would appreciate
                    it if the Secretary would transmit it to the Department of Justice.<note n="36"
                        xml:id="d690fn36">This registration form was sent to the Department of
                        Justice on May 8.</note>
                </p>
                <closer>
                    <dateline rendition="#left">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-04-29">April 29,
                            1943</date>.</dateline>
                </closer>
            </div>
        </body>
    </text>
