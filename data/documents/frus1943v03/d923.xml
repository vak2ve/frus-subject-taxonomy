<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-07-06T23:59:59-05:00" frus:doc-dateTime-min="1943-07-06T00:00:00-05:00" n="923" subtype="historical-document" type="document" xml:id="d923">
                            <note rend="inline" type="source">740.00114 Pacific War/231:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The Minister in Switzerland</hi> (<persName type="from"><hi rend="italic">Harrison</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Bern</hi></placeName>, <date calendar="gregorian" when="1943-07-06">July 6,
                                    1943</date>.<lb/>[Received July 6—9:29 p.m.]</dateline>
                            </opener>
                            <p>3975. American interests Japan. Department’s 1255, May 25. Legation
                                Tokyo telegraphs: <quote rend="blockquote">
                                    <p>Japanese Foreign Office replied Japanese Government assumes
                                        cost maintenance American POWs, internees and in general
                                        assists indigent citizens enemy countries. Each time Swiss
                                        representative desires give supplementary relief should
                                        request authorization Japanese Government which will make
                                        decision after examining if relief corresponds necessity and
                                        if possible transmit funds persons concerned.</p>
                                </quote>
                            </p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Harrison</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>