<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1943-05-07T23:59:59-05:00" frus:doc-dateTime-min="1943-05-07T00:00:00-05:00" n="856" subtype="historical-document" type="document" xml:id="d856">
                            <note rend="inline" type="source">740.00115A Pacific War/440:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The Minister in Switzerland</hi> (<persName type="from"><hi rend="italic">Harrison</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Bern</hi></placeName>, <date calendar="gregorian" when="1943-05-07">May 7,
                                    1943</date>.<lb/>[Received May 7—8:42 p.m.]</dateline>
                            </opener>
                            <p>2808. American interests Far East. Legation’s 1924, March 26.
                                Consulate Shanghai telegraphs: <quote rend="blockquote">
                                    <p>“Made representations Japanese authorities obtain
                                        authorization pay relief internees, send gifts in kind or
                                        assist in any other manner. Also repeatedly requested during
                                        recent months authorization visit camps where interned.</p>
                                    <p>To present all effort unavailing.”</p>
                                </quote>
                            </p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Harrison</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>