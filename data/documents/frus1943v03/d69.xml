                subtype="historical-document" type="document" xml:id="d69">
                <note rend="inline" type="source">125.0046B/4: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the United Kingdom</hi> (<persName type="to">
                        <hi rend="italic">Winant</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1943-05-21T18:00:00-04:00"
                            >May 21, 1943—6 p.m.</date>
                    </dateline>
                </opener>
                <p>3220. Your 3130, May 5, 9 p.m. Please inform the Foreign Office that, in as much
                    as circumstances make it necessary to establish a consulate at Bahrein as soon
                    as possible, a prompt favorable reply to your inquiry would be appreciated.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
