                subtype="historical-document" type="document" xml:id="d625">
                <note rend="inline" type="source">793.94/3179: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Japan</hi> (<persName type="to">
                        <hi rend="italic">Forbes</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1931-12-12T15:00:00-05:00"
                            >December 12, 1931—3 p.m.</date>
                    </dateline>
                </opener>
                <p>264. Your 259, December 12, 8 p.m. In my opinion, you should talk over this
                    matter at once with Baron Shidehara unless you feel it is not advisable to take
                    up the matter except with Shidehara’s successor.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
