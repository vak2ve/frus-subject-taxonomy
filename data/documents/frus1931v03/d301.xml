<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1931-10-27T18:00:00-05:00" frus:doc-dateTime-min="1931-10-27T18:00:00-05:00" n="301" subtype="historical-document" type="document" xml:id="d301">
                        <note rend="inline" type="source">793.94/2332: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Consul General at Nanking</hi> (<persName type="to"><hi rend="italic">Peck</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1931-10-27T18:00:00-05:00">October 27, 1931—6
                                p.m.</date></dateline></opener>
                        <p>104. For the Minister: Your October 26, 10 a.m. Department approves your
                            proceeding to Shanghai as proposed.</p>
                        <closer><signed><hi rend="smallcaps">Stimson</hi></signed></closer>
                    </div>
                    </body></text></TEI>