<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1931-09-23T00:00:00-05:00" frus:doc-dateTime-min="1931-09-23T00:00:00-05:00" n="43" subtype="historical-document" type="document" xml:id="d43">
                        <note rend="inline" type="source">793.94/1837: Telegram</note>
                        <head><hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">Johnson</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peiping</hi></placeName>, <date calendar="gregorian" when="1931-09-23T13:00:00+08:00">September 23, 1931—1
                                    p.m.</date><lb/>[Received September 23—9:05
                            a.m.]</dateline></opener>
                        <p>631. Consul General, Harbin, telegraphs: <quote rend="blockquote">
                                <p>“September 22, 1 p.m. Chinese authorities have informed me that
                                    the Chinese troops evacuated Kirin city night of September 21st
                                    and that Japanese troops entered city this morning at 8
                                    o’clock.”</p></quote></p>
                        <closer><signed><hi rend="smallcaps">Johnson</hi></signed></closer>
                    </div>
                    </body></text></TEI>