                subtype="historical-document" type="document" xml:id="d315">
                <note rend="inline" type="source">793.94/2418: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1931-11-01T09:00:00+08:00"
                            >November 1, 1931—9 a.m.</date>
                        <lb/>[Received November 1—2:40 a.m.]</dateline>
                </opener>
                <p>849. Following from American Consul General at Mukden: <quote rend="blockquote">
                        <p>“October 31, 1 p.m. Reliable information has been received that a
                            Japanese armed guard last night removed $670,000 of Salt Administration
                            funds from the Bank of China, Newchwang, to the Provincial Bank,
                            Newchwang.”</p>
                    </quote>
                </p>
                <closer>For the Minister:<lb/>
                    <signed>
                        <hi rend="smallcaps">Engert</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
