    <text>
        <body>
            <div frus:doc-dateTime-max="1931-10-04T20:00:00-05:00"
                frus:doc-dateTime-min="1931-10-04T20:00:00-05:00" n="121"
                subtype="historical-document" type="document" xml:id="d121">
                <note rend="inline" type="source">793.94/1979: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1931-10-05T09:00:00+08:00"
                            >October 5, 1931—9 a.m.</date>
                        <lb/>[Received 11:50 a.m.]</dateline>
                </opener>
                <p>702. Following from Mukden: <quote rend="blockquote">
                        <p>“October 3, 8 a.m. Japanese forces entered Chinese city of Newchwang at
                            2:15 this morning from Yingkou following bandit attack on the city.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
