                subtype="historical-document" type="document" xml:id="d398">
                <note rend="inline" type="source">793.94/2624: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Japan</hi> (<persName type="to">
                        <hi rend="italic">Forbes</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1931-11-12T17:00:00-05:00"
                            >November 12, 1931—5 p.m.</date>
                    </dateline>
                </opener>
                <p>224. Your 213, November 12, 10 a.m.<note n="10" xml:id="d398fn10">Not
                        printed.</note> Provided that invitation to visit Manchuria is accepted by
                    Military Attachés of leading powers, Department perceives no objection to our
                    Military Attaché likewise accepting.</p>
                <p>Inform Peiping of action taken.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stimson</hi>
                    </signed>
                </closer>
            </div>
        </body>
