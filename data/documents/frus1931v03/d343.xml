    <text>
        <body>
            <div frus:doc-dateTime-max="1931-11-05T02:00:00-05:00"
                frus:doc-dateTime-min="1931-11-05T02:00:00-05:00" n="343"
                subtype="historical-document" type="document" xml:id="d343">
                <note rend="inline" type="source">793.94/2472: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName type="from">
                        <hi rend="italic">Forbes</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1931-11-05T16:00:00+09:00"
                            >November 5, 1931—4 p.m.</date>
                        <lb/>[Received November 5—6:57 a.m.]</dateline>
                </opener>
                <p>206. Your 218, November 4, 5 p.m. At 3 p.m. today I delivered the memorandum. My
                    talk with the Foreign Minister was long and conciliatory; I shall transmit a
                    summary later.<note n="55" xml:id="d343fn55">
                        <hi rend="italic">Infra.</hi>
                    </note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Forbes</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
