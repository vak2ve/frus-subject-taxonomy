<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1931-11-19T00:00:00-05:00" frus:doc-dateTime-min="1931-11-19T00:00:00-05:00" n="469" subtype="historical-document" type="document" xml:id="d469">
                        <note rend="inline" type="source">793.94/2768: Telegram</note>
                        <head><hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">Johnson</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Nanking</hi></placeName>, <date calendar="gregorian" when="1931-11-19T13:00:00+08:00">November 19, 1931—1
                                p.m.</date><lb/>[Received November 19—9 a.m.]</dateline></opener>
                        <p>Your 113, November 17, 7 p.m., to Nanking. No further action at present
                            appears necessary in the matter of investigation into causes of trouble
                            at Tientsin.</p>
                        <closer><signed><hi rend="smallcaps">Johnson</hi></signed></closer>
                    </div>
                    </body></text></TEI>