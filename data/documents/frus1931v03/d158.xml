                subtype="historical-document" type="document" xml:id="d158">
                <note rend="inline" type="source">793.94/2028: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Geneva</hi> (<persName type="from">
                        <hi rend="italic">Gilbert</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Geneva</hi>
                        </placeName>, <date calendar="gregorian" when="1931-10-09T18:00:00+01:00"
                            >October 9, 1931—6 p.m.</date>
                        <lb/>[Received October 9—3:48 p.m.]</dateline>
                </opener>
                <p>168. Council meeting set for noon Tuesday, October 13, at Geneva. Drummond is
                    confident that Reading and Briand will attend and that other Foreign Ministers
                    will follow suit.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gilbert</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
