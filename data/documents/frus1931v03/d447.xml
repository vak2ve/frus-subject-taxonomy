                subtype="historical-document" type="document" xml:id="d447">
                <note rend="inline" type="source">793.94/2739: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1931-11-18T11:00:00+08:00"
                            >November 18, 1931—11 a.m.</date>
                        <lb/>[Received November 18—5:15 a.m.]</dateline>
                </opener>
                <p>955. By mandate of National Government issued yesterday General Wan Fu-lin’s
                    resignation as Chairman of Heilungkiang is accepted and General Ma Chan-shan is
                    appointed in his stead.</p>
                <closer>For the Minister:<lb/>
                    <signed>
                        <hi rend="smallcaps">Engert</hi>
                    </signed>
                </closer>
            </div>
        </body>
