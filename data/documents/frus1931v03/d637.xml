                subtype="historical-document" type="document" xml:id="d637">
                <note rend="inline" type="source">793.94/3249: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1931-12-19T16:00:00+08:00"
                            >December 19, 1931—4 p.m.</date>
                        <lb/>[Received December 19—11:13 a.m.]</dateline>
                </opener>
                <p>1105. Following from American Consul General at Mukden: <quote rend="blockquote">
                        <p>“December 18, 4 p.m. Reliably informed that Japanese planes bombed
                            Tungliao on the 15th, killing three Chinese. City was in a panic.”</p>
                    </quote>
                </p>
                <p>Repeated to Department and Nanking.</p>
                <closer>For the Minister:<lb/>
                    <signed>
                        <hi rend="smallcaps">Perkins</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
