    <text>
        <body>
            <div frus:doc-dateTime-max="1863-01-26T23:59:59-05:00"
                frus:doc-dateTime-min="1863-01-26T00:00:00-05:00" n="370"
                subtype="historical-document" type="document" xml:id="d370">
                <head>
                    <persName type="from">Lord Lyons</persName> to <persName type="to">Mr.
                        Seward</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1863-01-26">
                            <hi rend="italic">January</hi> 26, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I am directed by her Majesty’s government to
                    inform you that Mr. Frere, her Majesty’s judge in the British and United States
                    mixed commission court established at the Cape of Good Hope, under the treaty of
                    the 7th of April last, has completed the necessary formalities for opening the
                    court, with a view to its being ready for the transaction of any business which
                    may be brought before it.</p>
                <p>I have the honor, &amp;c., &amp;c.,</p>
                <closer>
                    <signed>LYONS.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">W. H. Seward</hi>, <hi rend="italic">&amp;c.,
                            &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
