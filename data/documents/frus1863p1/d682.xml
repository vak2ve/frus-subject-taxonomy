<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1863-12-05T23:59:59-05:00" frus:doc-dateTime-min="1863-12-05T00:00:00-05:00" n="682" subtype="historical-document" type="document" xml:id="d682">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName>.</head>
                        <opener>
                            <seg rendition="#left">No. 779.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1863-12-05"><hi rend="italic">December</hi> 5, 1863.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> Your despatch of the 20th ultimo (No. 542)
                            has been received. I give you my thanks for the report of the progress
                            of the trial of the Alexandra, which accompanied it, and remain, sir,
                            your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>