    <text>
        <body>
            <div frus:doc-dateTime-max="1863-08-14T23:59:59-05:00" frus:doc-dateTime-min="1863-08-14T00:00:00-05:00" n="613" subtype="historical-document" type="document" xml:id="d613">
                <head>
                    <persName type="from">Mr. F. W. Seward</persName> to <persName type="to">Lord Lyons</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1863-08-14">
                            <hi rend="italic">August</hi> 14, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Lord:</hi> I have the honor to acknowledge the
                            receipt of your note of yesterday, in which, under the instructions of
                            your government, a representation is made to me concerning the
                            unfortunate affair which resulted in the death of Mr. Hardcastle, in the
                            Old Capitol prison, and to state that it will receive attention.</p>
                <p>I have the honor to be, with high consideration, your lordship’s obedient
                            servant,</p>
                <closer>
                    <signed>F. W. SEWARD, <hi rend="italic">Acting
                            Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>Right Hon. <hi rend="smallcaps">Lord Lyons.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
