<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1863-09-19T23:59:59-05:00" frus:doc-dateTime-min="1863-09-19T00:00:00-05:00" n="296" subtype="historical-document" type="document" xml:id="d296">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName>.</head>
                        <opener>
                            <seg rendition="#left">No. 715.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                                <date calendar="gregorian" when="1863-09-19"><hi rend="italic">September</hi> 19, 1863.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> Your despatch of the 3d of September (No.
                            487) has been received. The President is satisfied with the note of Earl
                            Russell, a copy of which you have transmitted.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Charles Francis Adams</hi>, Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>