    <text>
        <body>
            <div frus:doc-dateTime-max="1863-01-29T23:59:59-05:00" frus:doc-dateTime-min="1863-01-29T00:00:00-05:00" n="376" subtype="historical-document" type="document" xml:id="d376">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Lord Lyons</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1863-01-29">
                            <hi rend="italic">January</hi> 29, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Lord</hi>: I have the honor to acknowledge the
                            receipt of your note of the 26th instant, informing me of the letter
                            which Earl Russell caused to be addressed to the General Post Office, on
                            receiving a copy of my note to you of the 15th ultimo.</p>
                <p>I have the honor to be, with high consideration, your lordship’s obedient
                            servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>Right Hon. <hi rend="smallcaps">Lord Lyons</hi>, <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
