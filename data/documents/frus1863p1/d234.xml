    <text>
        <body>
            <div frus:doc-dateTime-max="1863-07-13T23:59:59-05:00" frus:doc-dateTime-min="1863-07-13T00:00:00-05:00" n="234" subtype="historical-document" type="document" xml:id="d234">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 653.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1863-07-13">
                            <hi rend="italic">July</hi> 13, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Your despatch of June 25 (No. 435) has
                            been received, and your several proceedings therein related are
                            approved.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
