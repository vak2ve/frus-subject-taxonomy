    <text>
        <body>
            <div frus:doc-dateTime-max="1863-11-02T23:59:59-05:00" frus:doc-dateTime-min="1863-11-02T00:00:00-05:00" n="653" subtype="historical-document" type="document" xml:id="d653">
                <head>
                    <persName type="from">Mr. F. W. Seward</persName> to <persName type="to">Mr. Adams</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 748.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1863-11-02">
                            <hi rend="italic">November</hi> 2, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have to acknowledge the receipt of your
                            despatch of the 16th ultimo, (No. 518.) Your note of the 12th of October
                            to Earl Russell, as well as that of the 24th of September, is
                            approved.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>F. W. SEWARD, <hi rend="italic">Acting
                            Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Charles F. Adams,</hi> Esq., &amp;<hi rend="italic">c, &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
