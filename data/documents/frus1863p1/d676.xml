    <text>
        <body>
            <div frus:doc-dateTime-max="1863-11-24T23:59:59-05:00" frus:doc-dateTime-min="1863-11-24T00:00:00-05:00" n="676" subtype="historical-document" type="document" xml:id="d676">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 768.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1863-11-24">
                            <hi rend="italic">November</hi> 24, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Your despatch No. 527, of the 30th ultimo,
                            which shows the manner in which you have carried into effect the
                            instruction of this department, (No. 730,) has been received, submitted
                            to the President, and is approved.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
