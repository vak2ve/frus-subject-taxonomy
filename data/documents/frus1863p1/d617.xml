    <text>
        <body>
            <div frus:doc-dateTime-max="1863-09-12T23:59:59-05:00" frus:doc-dateTime-min="1863-09-12T00:00:00-05:00" n="617" subtype="historical-document" type="document" xml:id="d617">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Stuart</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1863-09-12">
                            <hi rend="italic">September</hi> 12, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have the honor to acknowledge the
                            receipt of your memorandum or the 10th instant, relative to the case of
                            Mr. J. M. Vernon, and to state that the attention of the Secretary of
                            War has been invited to it.</p>
                <p>I have the honor to be, with high consideration, sir, your obedient
                            servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William Stuart,</hi>
                        <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
