<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1863-05-02T23:59:59-05:00" frus:doc-dateTime-min="1863-05-02T00:00:00-05:00" n="488" subtype="historical-document" type="document" xml:id="d488">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Lord Lyons</persName>.</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                                <date calendar="gregorian" when="1863-05-02"><hi rend="italic">May</hi> 2, 1863.</date></dateline></opener>
                        <p><hi rend="smallcaps">My Lord</hi>: I have the honor to acknowledge the
                            receipt of your note of the 27th ultimo, relative to the case of the
                            captured British steamship Granite City, and to inform you that it will
                            receive careful attention.</p>
                        <p>I have the honor to be, with high consideration, your lordship’s
                            obedient</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p>Right Hon. <hi rend="smallcaps">Lord Lyons</hi>, <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>