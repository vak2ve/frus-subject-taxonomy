<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1863-02-20T23:59:59-05:00" frus:doc-dateTime-min="1863-02-20T00:00:00-05:00" n="396" subtype="historical-document" type="document" xml:id="d396">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Lord Lyons</persName>.</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1863-02-20"><hi rend="italic">February</hi> 20, 1863.</date></dateline></opener>
                        <p><hi rend="smallcaps">My Lord</hi>: I have the honor to acknowledge the
                            receipt of your memorandum of yesterday, relative to colored emigrants
                            from the United States for service in the British West Indian colonies,
                            and to inform you that a copy of it has been sent to the Secretary of
                            the Interior for his information and consideration. I have the honor to
                            be your very obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p>Right Hon. <hi rend="smallcaps">Lord Lyons</hi>, <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>