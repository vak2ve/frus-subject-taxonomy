    <text>
        <body>
            <div frus:doc-dateTime-max="1863-03-03T23:59:59-05:00"
                frus:doc-dateTime-min="1863-03-03T00:00:00-05:00" n="408"
                subtype="historical-document" type="document" xml:id="d408">
                <head>
                    <persName type="from">Lord Lyons</persName> to <persName type="to">Mr.
                        Seward</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1863-03-03">
                            <hi rend="italic">March</hi> 3, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have the honor to acknowledge the receipt of
                    your note of yesterday’s date, respecting the dismissal of Mr. Magee from the
                    office of acting consul at Mobile, and to inform you that, in compliance with
                    your request, I immediately forwarded a copy of it to her Majesty’s
                    government.</p>
                <p>I have the honor to be, with the highest consideration, sir, your most obedient,
                    humble servant,</p>
                <closer>
                    <signed>LYONS.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">Secretary
                            of State.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
