                    <head><hi rend="italic">Record of Decisions, Council of Foreign Ministers, Third
                            Session, Eighth Meeting, Waldorf-Astoria Hotel, New York, November 13,
                            1946, 4 p.m.</hi></head>
                    <dateline>
                        <placeName>New York</placeName>, <date ana="#date_undated-inferred-from-document-head" calendar="gregorian" when="1946-11-13T16:00:00-05:00">November 13, 1946, 4 p.m.</date>
