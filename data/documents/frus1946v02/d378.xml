                <head>
                    <hi rend="italic">Record of Decisions, Council of Foreign Ministers, Third
                        Session, Fourteenth Meeting, Waldorf-Astoria Hotel, New York, December 3,
                        1946, 4 p.m.</hi>
                </head>
                <dateline>
                    <placeName>New York</placeName>, <date ana="#date_undated-inferred-from-document-head" calendar="gregorian" when="1946-12-03T16:00:00-05:00">December 3, 1946, 4 p.m.</date>
