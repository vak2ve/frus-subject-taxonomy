                <head>
                    <hi rend="italic">Record of Decisions, Council of Foreign Ministers, Second
                        Session, Twenty-Eighth Meeting, Palais du Luxembourg, Paris, June 27, 1946,
                        4 p.m.</hi>
                </head>
                <dateline>
                    <placeName>Paris</placeName>, <date ana="#date_undated-inferred-from-document-head" calendar="gregorian" when="1946-06-27T16:00:00+01:00">June 27, 1946, 4 p.m.</date>
