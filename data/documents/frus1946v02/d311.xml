                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <lb/>
                    <seg rendition="#left">
                        <gloss target="#t_CFM46NY1">C.F.M.(46) (NY)</gloss> 4th Meeting</seg>
                </opener>
