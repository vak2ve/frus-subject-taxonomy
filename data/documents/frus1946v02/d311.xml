                <head>
                    <hi rend="italic">Record of Decisions, Council of Foreign Ministers, Third
                        Session, Fourth Meeting, Waldorf-Astoria Hotel, New York, November 8, 1946,
                        3:30 p.m.</hi>
                </head>
                <dateline>
                    <placeName>New York</placeName>, <date ana="#date_undated-inferred-from-document-head" calendar="gregorian" when="1946-11-08T15:30:00-05:00">November 8, 1946, 3:30 p.m.</date>
                </dateline>
