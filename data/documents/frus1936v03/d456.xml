                subtype="historical-document" type="document" xml:id="d456">
                <note rend="inline" type="source">701.9111/558: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Iran</hi> (<persName type="from">
                        <hi rend="italic">Merriam</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Teheran</hi>
                        </placeName>, <date calendar="gregorian" when="1936-05-21T17:00:00+03:25"
                            >May 21, 1936—5 p.m.</date>
                        <lb/>[Received May 21—1:30 p.m.]</dateline>
                </opener>
                <p>36. Department’s telegram 26, May 20, 2 p.m. Personal letter delivered to Foreign
                    Minister this afternoon as drafted with translation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Merriam</hi>
                    </signed>
                </closer>
            </div>
        </body>
