                subtype="historical-document" type="document" xml:id="d338">
                <note rend="inline" type="source">765.84/4476: Telegram</note>
                <head>
                    <hi rend="italic">The Minister Resident in Ethiopia</hi> (<persName type="from">
                        <hi rend="italic">Engert</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Addis Ababa</hi>
                        </placeName>, <date calendar="gregorian" when="1936-05-20T17:00:00+03:00"
                            >May 20, 1936—5 p.m.</date>
                        <lb/>[Received 8:10 p.m.]</dateline>
                </opener>
                <p>362. Marshal Badoglio is leaving tomorrow and Marshal Graziani who arrived
                    yesterday is assuming supreme command in Ethiopia.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Engert</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
