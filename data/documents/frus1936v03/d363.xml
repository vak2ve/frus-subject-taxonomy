<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-07-22T04:00:00-05:00" frus:doc-dateTime-min="1936-07-22T04:00:00-05:00" n="363" subtype="historical-document" type="document" xml:id="d363">
                            <note rend="inline" type="source">124.842/140: Telegram</note>
                            <head><hi rend="italic">The Minister Resident in Ethiopia</hi>
                                    (<persName type="from"><hi rend="italic">Engert</hi></persName>)
                                    <hi rend="italic">to the <gloss type="to">Secretary of
                                        State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Addis
                                            Ababa</hi></placeName>, <date calendar="gregorian" when="1936-07-22T12:00:00+03:00">July 22,
                                    1936—noon</date>.<lb/>[Received July 23—6:02 p.m.]</dateline>
                            </opener>
                            <p>485. I have just learned informally that the Legation radio stations
                                will not be permitted to resume transmitting until further
                                notice.</p>
                            <closer><signed><hi rend="smallcaps">Engert</hi></signed></closer>
                        </div>
                        </body></text></TEI>