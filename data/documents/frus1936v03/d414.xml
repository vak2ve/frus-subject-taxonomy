                subtype="historical-document" type="document" xml:id="d414">
                <note rend="inline" type="source">123EN3/490: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from">
                        <hi rend="italic">Phillips</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1936-12-02T11:00:00+01:00"
                            >December 2, 1936—11 a.m.</date>
                        <lb/>[Received December 2—6:55 a.m.]</dateline>
                </opener>
                <p>501. Department’s 167, December 1, 11 a.m. In advising Foreign Office of Hughes’
                    assignment to Addis Ababa may I say orally to Count Ciano that Engert is to be
                    transferred elsewhere?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
