    <text>
        <body>
            <div frus:doc-dateTime-max="1936-05-21T09:00:00-05:00"
                frus:doc-dateTime-min="1936-05-21T09:00:00-05:00" n="240"
                subtype="historical-document" type="document" xml:id="d240">
                <note rend="inline" type="source">765.84/4479: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from">
                        <hi rend="italic">Gibson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1936-05-21T11:00:00-03:00"
                            >May 21, 1936—11 a.m.</date>
                        <lb/>[Received May 21—9:40 a.m.]</dateline>
                </opener>
                <p>128. Foreign Office would appreciate information as to character of reply
                    Department contemplates making to circular communication from Italian Government
                    announcing annexation of Abyssinia.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gibson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
