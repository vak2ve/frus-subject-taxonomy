<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-04-08T12:00:00-05:00" frus:doc-dateTime-min="1936-04-08T12:00:00-05:00" n="57" subtype="historical-document" type="document" xml:id="d57">
                            <note rend="inline" type="source">765.84116/97: Telegram</note>
                            <head><hi rend="italic">The Ambassador in Italy</hi> (<persName type="from"><hi rend="italic">Long</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Rome</hi></placeName>, <date calendar="gregorian" when="1936-04-08T18:00:00+01:00">April 8, 1936—6
                                    p.m.</date><lb/>[Received April 8—1:25 p.m.]</dateline>
                            </opener>
                            <p>98. Virginio Gayda<note n="25" xml:id="d57fn25">Italian Foreign
                                    Office spokesman.</note> in today’s <hi rend="italic">Giornale</hi> denies categorically the use of poison gas by the
                                Italians in Abyssinia.</p>
                            <closer><signed><hi rend="smallcaps">Long</hi></signed></closer>
                        </div>
                        </body></text></TEI>