                subtype="historical-document" type="document" xml:id="d567">
                <note rend="inline" type="source">767.68119/897a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Turkey</hi> (<persName type="to">
                        <hi rend="italic">MacMurray</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-04-20T17:00:00-05:00"
                            >April 20, 1936—5 p.m.</date>
                    </dateline>
                </opener>
                <p>17. Please comment on recent widespread press reports that Turkish troops have
                    entered the demilitarized zone of the Straits.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
