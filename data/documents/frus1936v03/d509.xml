                subtype="historical-document" type="document" xml:id="d509">
                <note rend="inline" type="source">452.11/329: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Diplomatic Agent and Consul General at Tangier</hi> (<persName type="to">
                        <hi rend="italic">Blake</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-01-30T17:00:00-05:00"
                            >January 30, 1936—5 p.m.</date>
                    </dateline>
                </opener>
                <p>1. If you have not already sent in a report, may we have your comments and
                    suggestions by mail with regard to the Madrid Embassy’s despatch 1012, January
                    13?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
