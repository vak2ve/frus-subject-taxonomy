                subtype="historical-document" type="document" xml:id="d371">
                <note rend="inline" type="source">124.846/61: Telegram</note>
                <head>
                    <hi rend="italic">The Minister Resident in Ethiopia</hi> (<persName type="from">
                        <hi rend="italic">Engert</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Addis Ababa</hi>
                        </placeName>, <date calendar="gregorian" when="1936-08-03T09:00:00+03:00"
                            >August 3, 1936—9 a.m.</date>
                        <lb/>[Received August 3—6:36 a.m.]</dateline>
                </opener>
                <p>506. My 498, July 28, 4 p.m. Was officially informed last night that cipher
                    communications between legations and their respective governments are now again
                    permitted.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Engert</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
