<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-03-20T03:25:00-05:00" frus:doc-dateTime-min="1936-03-20T03:25:00-05:00" n="50" subtype="historical-document" type="document" xml:id="d50">
                            <note rend="inline" type="source">765.84/3964: Telegram</note>
                            <head><hi rend="italic">The Minister Resident in Ethiopia</hi>
                                    (<persName type="from"><hi rend="italic">Engert</hi></persName>)
                                    <hi rend="italic">to the <gloss type="to">Secretary of
                                        State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Addis
                                            Ababa</hi></placeName>, <date calendar="gregorian" when="1936-03-20T11:00:00+02:35">March 20, 1936—11
                                        a.m.</date><lb/>[Received 7 p.m.]</dateline>
                            </opener>
                            <p>169. Government announces that on March 18 Korem was subjected to
                                intensive bombing with a new kind of gas which causes much
                                suffering.</p>
                            <closer><signed><hi rend="smallcaps">Engert</hi></signed></closer>
                        </div>
                        </body></text></TEI>