                subtype="historical-document" type="document" xml:id="d413">
                <note rend="inline" type="source">123H875/188: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Italy</hi> (<persName type="to">
                        <hi rend="italic">Phillips</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-12-01T11:00:00-05:00"
                            >December 1, 1936—11 a.m.</date>
                    </dateline>
                </opener>
                <p>167. Your 498, November 30, 5 p.m. Please advise Foreign Office of Hughes’
                    assignment to Addis Ababa in consular capacity and request telegraphic
                    authorization to Italian Embassy here to grant him visa.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Moore</hi>
                    </signed>
                </closer>
            </div>
        </body>
