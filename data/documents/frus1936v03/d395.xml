                subtype="historical-document" type="document" xml:id="d395">
                <note rend="inline" type="source">365D.1163/16: Telegram</note>
                <head>
                    <hi rend="italic">The Minister Resident in Ethiopia</hi> (<persName type="from">
                        <hi rend="italic">Engert</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Addis Ababa</hi>
                        </placeName>, <date calendar="gregorian" when="1936-12-14T13:00:00+03:00"
                            >December 14, 1936—1 p.m.</date>
                        <lb/>[Received 6:47 p.m.]</dateline>
                </opener>
                <p>679. Department’s 399, December 10, 8 p.m.<note n="75" xml:id="d395fn75">Not
                        printed.</note> British Legation informs me that London has likewise made
                    representations to the Italian Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Engert</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
