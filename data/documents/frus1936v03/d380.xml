<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-09-26T12:00:00-05:00" frus:doc-dateTime-min="1936-09-26T12:00:00-05:00" n="380" subtype="historical-document" type="document" xml:id="d380">
                            <note rend="inline" type="source">665D.006/A: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Minister Resident in Ethiopia</hi>
                                    (<persName type="to"><hi rend="italic">Engert</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1936-09-26T13:00:00-04:00">September 26, 1936—1
                                        p.m.</date></dateline>
                            </opener>
                            <p>360. Please submit a comprehensive report on Italian trade
                                regulations in Ethiopia, including data on foreign exchange
                                restriction, etc., and complete information as to the effect of such
                                measures upon American trade.</p>
                            <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                        </div>
                        </body></text></TEI>