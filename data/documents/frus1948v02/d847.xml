                subtype="historical-document" type="document" xml:id="d847">
                <note rend="inline" type="source">740.00119 Council/5–648: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        United States Deputy for Austria at the Council of Foreign Ministers</hi>
                        (<persName corresp="#p_RS1" type="to">
                        <hi rend="italic">Reber</hi>
                    </persName>), <hi rend="italic">at London</hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                        <lb/>
                        <hi rend="smallcaps">us urgent</hi>
                        <lb/>
                        <gloss target="#t_Niact1">
                            <hi rend="smallcaps">niact</hi>
                        </gloss>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1948-05-06T19:00:00-04:00"
                            >May 6, 1948—7 p. m.</date>
                    </dateline>
                </opener>
                <p>1640. For <persName corresp="#p_RS1">Reber</persName>. US Govt remains
                    inalterably opposed to any cessions Austrian territory or payment of reparations
                    to Yugoslavia. We trust Brit and French will maintain same position. Your
                    proposed course of action approved and Dept will leave to your discretion
                    question whether future meetings should be held.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MGC1">
                            <hi rend="smallcaps">Marshall</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
