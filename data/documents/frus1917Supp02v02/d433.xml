<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-10-17T19:30:00-05:00" frus:doc-dateTime-min="1917-10-17T19:30:00-05:00" n="433" subtype="historical-document" type="document" xml:id="d433">
                        <note rend="inline" type="source">File No. 763.72111/5683</note>
                        <head>
                            <hi rend="italic">The Minister in Venezuela</hi> (<persName corresp="frus1917Supp02v01#p_MP1" type="from"><hi rend="italic">McGoodwin</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Caracas</hi></placeName>, <date calendar="gregorian" when="1917-10-17T20:00:00-04:30">
                                    <hi rend="italic">October 17, 1917, 8 p.m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received October 18, 11
                                p.m.</hi>]</dateline>
                        </opener>
                        <p>Department’s October 9, 3 p.m. Venezuelan Government admits freely armed
                            merchantmen. Regulations go forward by mail to-day.</p>
                        <closer>
                            <signed>
                                <persName corresp="frus1917Supp02v01#p_MP1">
                                    <hi rend="smallcaps">McGoodwin</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>