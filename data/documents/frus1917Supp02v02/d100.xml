<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-10-10T16:00:00-05:00" frus:doc-dateTime-min="1917-10-10T16:00:00-05:00" n="100" subtype="historical-document" type="document" xml:id="d100">
                            <note rend="inline" type="source">File No. 763.72112/5054</note>
                            <head>
                                <hi rend="italic">The Consul at Barranquilla</hi> (<persName type="from"><hi rend="italic">Guyant</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Barranquilla</hi></placeName>, <date calendar="gregorian" when="1917-10-10T16:00:00-05:00">
                                        <hi rend="italic">October 10, 1917, 4 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received October 11, 3.45
                                    p.m.</hi>]</dateline>
                            </opener>
                            <p>Shall we continue to certify invoices from German and pro-German
                                firms?</p>
                            <closer>
                                <signed>
                                    <persName>
                                        <hi rend="smallcaps">Guyant</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                    </body></text></TEI>