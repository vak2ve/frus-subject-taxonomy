                subtype="historical-document" type="document" xml:id="d8">
                <note rend="inline" type="source">File No. 763.72112/3551</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="frus1917Supp02v01#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-30T14:00:00+01:00">
                            <hi rend="italic">April 30, 1917, 2 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 3 p.m.</hi>]</dateline>
                </opener>
                <p>6122. My 5958, April 7, 4 p.m.<note n="1" xml:id="d8fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_801">p. 801</ref>.</note>
                    Order in council dated 27th instant publishes withdrawal of statutory black list
                    and I am informed this morning by <persName corresp="frus1917Supp02v01#p_CLR1"
                        >Lord Robert Cecil</persName> that British Government has withdrawn the
                    confidential black lists so far as they relate to firms in the United States,
                    Philippines and Porto Rico.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
