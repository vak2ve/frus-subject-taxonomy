<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-07-03T20:00:00-05:00" frus:doc-dateTime-min="1917-07-03T20:00:00-05:00" n="371" subtype="historical-document" type="document" xml:id="d371">
                        <note rend="inline" type="source">File No. 811.731/145</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Great Britain</hi> (<persName corresp="frus1917Supp02v01#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-07-03T20:00:00-05:00">
                                    <hi rend="italic">July 3, 1917, 8 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>5087. Your 6540, June 26, 4 p.m.<note n="1" xml:id="d371fn1">Not
                                printed.</note> United States censors do not exercise jurisdiction
                            over transatlantic cables originating in or addressed to points in
                            continental United States, but do have jurisdiction over messages in
                            transit through continental United States for transatlantic points.
                            Messages with test word in transit through the United States to or from
                            transatlantic points will not be censored as to test word qualifications
                            by United States censors.</p>
                        <closer>
                            <signed>
                                <persName corresp="frus1917Supp02v01#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>