                subtype="historical-document" type="document" xml:id="d373">
                <note rend="inline" type="source">File No. 841.731/1823</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="frus1917Supp02v01#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1917-07-13T23:00:00+01:00">
                            <hi rend="italic">July 13, 1917, 11 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received July 13, 6.18 p.m.</hi>]</dateline>
                </opener>
                <p>6732. Foreign Office deferring departure two British cable censorship officials
                    pending your approval plan set forth in my 6663, July 6, 5 p.m. Naval attaché
                    states that Navy Department telegraphed him July 3, designating No. 15003, to
                    get both officials.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
