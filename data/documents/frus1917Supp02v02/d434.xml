    <text>
        <body>
            <div frus:doc-dateTime-max="1917-10-19T11:14:00-05:00"
                frus:doc-dateTime-min="1917-10-19T11:14:00-05:00" n="434"
                subtype="historical-document" type="document" xml:id="d434">
                <note rend="inline" type="source">File No. 763.72111/5687</note>
                <head>
                    <hi rend="italic">The Minister in Ecuador</hi> (<persName
                        corresp="frus1917Supp02v01#p_HCS1" type="from">
                        <hi rend="italic">Hartman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Quito</hi>
                        </placeName>, <date calendar="gregorian" when="1917-10-19T11:00:00-05:14">
                            <hi rend="italic">October 19, 1917, 11 a.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received October 20, 3.40 a.m.</hi>]</dateline>
                </opener>
                <p>Department’s circular October 9, 3 p.m. No restrictions imposed by Ecuador.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_HCS1">
                            <hi rend="smallcaps">Hartman</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
