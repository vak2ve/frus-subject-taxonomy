    <text>
        <body>
            <div frus:doc-dateTime-max="1917-06-11T18:00:00-05:00"
                frus:doc-dateTime-min="1917-06-11T18:00:00-05:00" n="27"
                subtype="historical-document" type="document" xml:id="d27">
                <note rend="inline" type="source">File No. 600.119/101</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Sweden</hi> (<persName corresp="frus1917Supp02v01#p_MIN1"
                        type="to">
                        <hi rend="italic">Morris</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-06-11T18:00:00-05:00">
                            <hi rend="italic">June 11, 1917, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>232. Your 402, June 4, 2 p.m.<note n="1" xml:id="d27fn1">Not printed.</note> You
                    should not attend joint meetings of Allied Ministers for the present but secure
                    informally all information disclosed at such meetings, advising Department
                    thereof.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
