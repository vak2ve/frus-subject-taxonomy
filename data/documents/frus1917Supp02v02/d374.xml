<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-07-14T15:00:00-05:00" frus:doc-dateTime-min="1917-07-14T15:00:00-05:00" n="374" subtype="historical-document" type="document" xml:id="d374">
                        <note rend="inline" type="source">File No. 841.731/1823</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Ambassador in Great Britain</hi> (<persName corresp="frus1917Supp02v01#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-07-14T15:00:00-05:00">
                                    <hi rend="italic">July 14, 1917, 3 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>5152. Your 6663 and 6732. Department concurs. Please express to Foreign
                            Office appreciation detail these officers.</p>
                        <closer>
                            <signed>
                                <persName corresp="frus1917Supp02v01#p_PFL1">
                                    <hi rend="smallcaps">Polk</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>