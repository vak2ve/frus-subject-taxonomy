                subtype="historical-document" type="document" xml:id="d391">
                <head>
                    <hi rend="italic">Executive Order No. 2621, May 16, 1917</hi>
                </head>
                <p>In accordance with a request of the Secretary of the Navy, concurred in by the
                    United States Shipping Board, the Secretary of the Treasury is hereby directed
                    to transfer the German vessel <hi rend="italic">Atlas</hi>, now at San
                    Francisco, to the Commandant of the Twelfth Naval District, for use in harbor
                    patrol.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_WW1">
                            <hi rend="smallcaps">Woodrow Wilson</hi>
                        </persName>
                    </signed>
                    <lb/>
                    <dateline rendition="#left">
                        <placeName type="venue">
                            <hi rend="smallcaps">The White House</hi>
                        </placeName>, <lb/>
                        <date calendar="gregorian" when="1917-05-16">
                            <hi rend="italic">16 May, 1917</hi>
                        </date>.</dateline>
                </closer>
            </div>
        </body>
    </text>
