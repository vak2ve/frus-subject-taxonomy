                <note rend="inline" type="source">File No. 763.72112/5054</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Barranquilla</hi> (<persName type="to">
                        <hi rend="italic">Guyant</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-10-16">
                            <hi rend="italic">October 16, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>Your October 10 regarding invoices.<note n="1" xml:id="d104fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_963">p. 963</ref>.</note>
                    Yes.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
