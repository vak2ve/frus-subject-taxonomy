                <note rend="inline" type="source">File No. 763.72111Sp1/58</note>
                <head>
                    <hi rend="italic">The Ambassador in Spain</hi> (<persName
                        corresp="frus1917Supp02v01#p_WJE1" type="from">
                        <hi rend="italic">Willard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1917-06-29T10:00:00+00:00">
                            <hi rend="italic">June 29, 1917, 10 a.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 3.55 p.m.</hi>]</dateline>
                </opener>
                <p>645. Embassy’s 638, June 26, 6 p.m. Submarine sailed 3 o’clock this morning.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_WJE1">
                            <hi rend="smallcaps">Willard</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
