<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-11-15T11:00:00-05:00" frus:doc-dateTime-min="1917-11-15T11:00:00-05:00" n="302" subtype="historical-document" type="document" xml:id="d302">
                        <note rend="inline" type="source">File No. 103.96/83</note>
                        <head>
                            <hi rend="italic">The Special Representative of the War Trade Board</hi>
                                (<persName corresp="frus1917Supp02v01#p_MVC1" type="from"><hi rend="italic">McCormick</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1917-11-15T16:00:00+00:00">
                                    <hi rend="italic">November 15, 1917, 4 p.m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received November 15, 3.40
                                p.m.</hi>]</dateline>
                        </opener>
                        <p>For War Trade Board:</p>
                        <p>Your 5812, our 3. <persName corresp="frus1917Supp02v01#p_TAE1">Taylor</persName> and I will negotiate and will try to close Swiss
                            agreement in Paris.</p>
                        <closer>
                            <signed>
                                <persName corresp="frus1917Supp02v01#p_MVC1">
                                    <hi rend="smallcaps">McCormick</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>