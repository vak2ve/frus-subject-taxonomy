    <text>
        <body>
            <div frus:doc-dateTime-max="1917-12-05T14:00:00-05:00"
                frus:doc-dateTime-min="1917-12-05T14:00:00-05:00" n="312"
                subtype="historical-document" type="document" xml:id="d312">
                <note rend="inline" type="source">File No. 654.119/66</note>
                <head>
                    <hi rend="italic">The Special Representative</hi> (<persName
                        corresp="frus1917Supp02v01#p_HEM1" type="from">
                        <hi rend="italic">House</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1917-12-05T19:00:00+00:00">
                            <hi rend="italic">December 5, 1917, 7 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received December 6, 6.50 a.m.</hi>]</dateline>
                </opener>
                <p>From <persName corresp="frus1917Supp02v01#p_MVC1">McCormick</persName> for War
                    Trade Board: Swiss agreement signed this afternoon.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_HEM1">
                            <hi rend="smallcaps">House</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
