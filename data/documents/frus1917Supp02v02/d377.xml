                subtype="historical-document" type="document" xml:id="d377">
                <note rend="inline" type="source">File No. 811.731/208</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName
                        corresp="frus1917Supp02v01#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-08-15T15:00:00-05:00">
                            <hi rend="italic">August 15, 1917, 3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>5301. Your 6938, August 13, 1 p.m.<note n="1" xml:id="d377fn1">Not
                        printed.</note> Beginning midnight July 25–26, naval cable censorship began
                    to censor all cablegrams passing over Atlantic cables to, from, or in transit
                    through, the United States. Notwithstanding this added censorship, the
                    Department would not deem it wise for the British authorities to relax in any
                    way their censorship.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
