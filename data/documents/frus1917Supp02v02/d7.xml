<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-04-27T05:00:00-05:00" frus:doc-dateTime-min="1917-04-27T05:00:00-05:00" n="7" subtype="historical-document" type="document" xml:id="d7">
                            <note rend="inline" type="source">File No. 763.72112/3536</note>
                            <head>
                                <hi rend="italic">The Ambassador in Spain</hi> (<persName corresp="frus1917Supp02v01#p_WJE1" type="from"><hi rend="italic">Willard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Madrid</hi></placeName>, <date calendar="gregorian" when="1917-04-27T10:00:00+00:00">
                                        <hi rend="italic">April 27, 1917, 10 a.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 7.45 p.m.</hi>]</dateline>
                            </opener>
                            <p>512. British Embassy has furnished this Embassy with complete black
                                list of Spanish firms. [Is it] desired that Embassy cooperate in
                                this matter with British Embassy and to what extent?</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1917Supp02v01#p_WJE1">
                                        <hi rend="smallcaps">Willard</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>