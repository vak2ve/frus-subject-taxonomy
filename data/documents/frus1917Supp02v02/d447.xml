<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-10-07T23:59:59-05:00" frus:doc-dateTime-min="1917-10-07T00:00:00-05:00" n="447" subtype="historical-document" type="document" xml:id="d447">
                        <note rend="inline" type="source">File No. 763.72111Sp1/88</note>
                        <head>
                            <hi rend="italic">The Ambassador in Spain</hi> (<persName corresp="frus1917Supp02v01#p_WJE1" type="from"><hi rend="italic">Willard</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <dateline>[<date ana="#date_undated-inferred-from-outside-research" calendar="gregorian" when="1917-10-07">undated</date>]</dateline>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <p>815. Naval attaché just received following telegram from consular agent
                            at Cadiz: “German submarine interned Cadiz escaped.”</p>
                        <closer>
                            <signed>
                                <persName corresp="frus1917Supp02v01#p_WJE1">
                                    <hi rend="smallcaps">Willard</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>