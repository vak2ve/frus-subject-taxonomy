                subtype="historical-document" type="document" xml:id="d185">
                <note rend="inline" type="source">File No. 657.119/93</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Norway</hi> (<persName corresp="frus1917Supp02v01#p_SAG1"
                        type="to">
                        <hi rend="italic">Schmedeman</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-10-26T16:00:00-05:00">
                            <hi rend="italic">October 26, 1917, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>172. Your 346, October 17, 7 p.m. The War Trade Board has been furnished with a
                    copy of your cablegram and suggests in pursuance of Department’s request for a
                    suggestion as to your course under present circumstances the advisability of
                    your preserving noncommittal attitude while the negotiations between the board
                    and the Norwegian commission are proceeding.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
