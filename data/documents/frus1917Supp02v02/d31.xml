    <text>
        <body>
            <div frus:doc-dateTime-max="1917-06-19T18:00:00-05:00"
                frus:doc-dateTime-min="1917-06-19T18:00:00-05:00" n="31"
                subtype="historical-document" type="document" xml:id="d31">
                <note rend="inline" type="source">File No. 763.72112/3778</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at London</hi> (<persName corresp="frus1917Supp02v01#p_SRP1"
                        type="to">
                        <hi rend="italic">Skinner</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-06-19T18:00:00-05:00">
                            <hi rend="italic">June 19, 1917, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your 11th <hi rend="italic">re</hi> prevention exportations to firms in Latin
                    America assisting enemy. Matter being discussed here with British mission.
                    Department glad to have data regarding activity of firms mentioned.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
