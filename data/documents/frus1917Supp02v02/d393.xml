<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-05-22T23:59:59-05:00" frus:doc-dateTime-min="1917-05-22T00:00:00-05:00" n="393" subtype="historical-document" type="document" xml:id="d393">
                        <head>
                            <hi rend="italic">Executive Order No. 2625, May 22, 1917</hi>
                        </head>
                        <p>In accordance with a request of the Secretary of the Navy, concurred in
                            by the United States Shipping Board, the Secretary of the <pb facs="0502" n="1256" xml:id="pg_1256"/> Treasury is hereby directed
                            to transfer the following German vessels to the Navy for use as colliers
                            and cargo carriers: <list>
                                <item>Hohenfelde</item>
                                <item>Frieda Leonhardt</item>
                                <item>Nicaria</item>
                                <item>Kiel</item>
                                <item>Rudolf Blumberg</item>
                                <item>Vogesen</item>
                                <item>Breslau</item>
                                <item>Saxonia.</item>
                            </list>
                        </p>
                        <closer>
                            <signed>
                                <persName corresp="frus1917Supp02v01#p_WW1">
                                    <hi rend="smallcaps">Woodrow Wilson</hi>
                                </persName>
                            </signed>
                            <lb/><dateline rendition="#left">
                                <placeName type="venue">
                                    <hi rend="smallcaps">The White House</hi>
                                </placeName>, <lb/>
                                <date calendar="gregorian" when="1917-05-22"><hi rend="italic">22
                                        May, 1917</hi></date>.</dateline>
                        </closer>
                    </div>
                    </body></text></TEI>