                subtype="historical-document" type="document" xml:id="d6">
                <note rend="inline" type="source">File No. 763.72112/3505</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in the Netherlands</hi> (<persName corresp="frus1917Supp02v01#p_LM1"
                        type="to">
                        <hi rend="italic">Langhorne</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-23T17:00:00-05:00">
                            <hi rend="italic">April 23, 1917, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>488. Department unprepared at present to make any announcement regarding a
                    black-list measure but it is expected that a harmonious understanding will be
                    had with British Government about the general question at an early date. Any
                    measure dealing with subject must necessarily be enacted by Congress.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
