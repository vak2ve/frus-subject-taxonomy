                subtype="historical-document" type="document" xml:id="d421">
                <note rend="inline" type="source">File No. 763.72111/5035</note>
                <head>
                    <hi rend="italic">The Ambassador in Chile</hi> (<persName
                        corresp="frus1917Supp02v01#p_SJH1" type="from">
                        <hi rend="italic">Shea</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santiago</hi>
                        </placeName>, <date calendar="gregorian" when="1917-05-19T17:00:00-04:42">
                            <hi rend="italic">May 19, 1917, 5 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 10 p.m.</hi>]</dateline>
                </opener>
                <p>Department’s telegram May 18, 5 p.m. I am assured by the Minister for Foreign
                    Affairs that the arrangement suggested is entirely satisfactory.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_SJH1">
                            <hi rend="smallcaps">Shea</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
