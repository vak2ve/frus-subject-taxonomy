<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-07-06T14:00:00-05:00" frus:doc-dateTime-min="1917-07-06T14:00:00-05:00" n="44" subtype="historical-document" type="document" xml:id="d44">
                            <note rend="inline" type="source">File No. 763.72112/3873</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Italy</hi> (<persName corresp="frus1917Supp02v01#p_PTN1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-07-06T14:00:00-05:00">
                                        <hi rend="italic">July 6, 1917, 2 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>860. Your 1003 June 26, 1 p.m.<note n="1" xml:id="d44fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_885">p.
                                    885</ref>.</note> Phrase means that consuls will continue to
                                perform notarial, invoice, and other like conventional services for
                                firms on British black list.</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1917Supp02v01#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>