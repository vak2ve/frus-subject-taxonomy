    <text>
        <body>
            <div frus:doc-dateTime-max="1917-08-30T23:59:59-05:00"
                frus:doc-dateTime-min="1917-08-30T00:00:00-05:00" n="75"
                subtype="historical-document" type="document" xml:id="d75">
                <note rend="inline" type="source">War Trade Board Files</note>
                <head>
                    <hi rend="italic">Resolution of the Exports Administrative Board, August 30,
                        1917</hi>
                </head>
                <dateline>
                    <date ana="#date_undated-inferred-from-document-head" calendar="gregorian"
                        when="1917-08-30">August 30, 1917</date>
                </dateline>
                <p>
                    <hi rend="smallcaps">Resolved</hi> that the following instructions are hereby
                    given to the Director of the Bureau of Export Licenses: … <quote
                        rend="blockquote">
                        <p>(<hi rend="italic">b</hi>) All licenses to export controlled commodities
                            to Norway, Holland, Denmark and Sweden are to be withheld for the
                            present and no applications for such licenses are to be referred to any
                            of the members of the board except upon their special request, provided,
                            however, that applications for licenses to export food to Norway shall
                            be brought to Mr. <persName>White</persName>’s attention.</p>
                    </quote>
                </p>
            </div>
        </body>
