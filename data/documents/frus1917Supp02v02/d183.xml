<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-10-17T13:00:00-05:00" frus:doc-dateTime-min="1917-10-17T13:00:00-05:00" n="183" subtype="historical-document" type="document" xml:id="d183">
                            <note rend="inline" type="source">File No. 658.119/75</note>
                            <head>
                                <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="frus1917Supp02v01#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1917-10-17T18:00:00+00:00">
                                        <hi rend="italic">October 17, 1917, 6 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 8.50 p.m.</hi>]</dateline>
                            </opener>
                            <p>7460. Your 5522, October 2, 6 p.m. Foreign Office state that British
                                Ambassador, Washington, has been authorized to issue letter of
                                assurance regarding consignment rye from United States to
                                Sweden.</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1917Supp02v01#p_PWH1">
                                        <hi rend="smallcaps">Page</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>