<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-06-26T06:00:00-05:00" frus:doc-dateTime-min="1917-06-26T06:00:00-05:00" n="38" subtype="historical-document" type="document" xml:id="d38">
                            <note rend="inline" type="source">File No. 763.72112/3873</note>
                            <head>
                                <hi rend="italic">The Ambassador in Italy</hi> (<persName corresp="frus1917Supp02v01#p_PTN1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Rome</hi></placeName>, <date calendar="gregorian" when="1917-06-26T13:00:00+02:00">
                                        <hi rend="italic">June 26, 1917, 1 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 2.35 p.m.</hi>]</dateline>
                            </opener>
                            <p>1003. Department circular 23d. Suggestion made to Italian Foreign
                                Office as directed. Informal inquiry what is meant by following:
                                “Consuls will perform conventional consular services without regard
                                to British black list.”</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1917Supp02v01#p_PTN1">
                                        <hi rend="smallcaps">Nelson Page</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>