                subtype="historical-document" type="document" xml:id="d291">
                <note rend="inline" type="source">File No. 600.001/121</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in France</hi> (<persName corresp="frus1917Supp02v01#p_SWG1"
                        type="to">
                        <hi rend="italic">Sharp</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-07-17T17:00:00-05:00">
                            <hi rend="italic">July 17, 1917, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>2456. President has set aside necessary sum to cover expenses silk conference
                    proposals.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
