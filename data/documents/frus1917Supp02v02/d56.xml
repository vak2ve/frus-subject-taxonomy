<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-07-24T13:00:00-05:00" frus:doc-dateTime-min="1917-07-24T13:00:00-05:00" n="56" subtype="historical-document" type="document" xml:id="d56">
                            <note rend="inline" type="source">File No. 763.72112/4161</note>
                            <head>
                                <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="frus1917Supp02v01#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1917-07-24T19:00:00+01:00">
                                        <hi rend="italic">July 24, 1917, 7 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received July 27, 12.10
                                    p.m.</hi>]</dateline>
                            </opener>
                            <p>6830. Your 4586, March 24, 6 p.m.<note n="2" xml:id="d56fn2">
                                    <ref target="frus1917Supp02v01#pg_6">Vol. I, p. 6</ref>.</note>
                                Ministry of Blockade would appreciate word with regard to
                                suggestions for extension of financial blockade contained in my
                                despatch No. 6451, June 22,<note n="3" xml:id="d56fn3">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_898">p.
                                    898</ref>.</note> and whether United States would be prepared to
                                join in principle in some such action as therein outlined.</p>
                            <closer>
                                <signed>
                                    <persName corresp="frus1917Supp02v01#p_PWH1">
                                        <hi rend="smallcaps">Page</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>