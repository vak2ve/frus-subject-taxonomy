<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-10-09T16:00:00-05:00" frus:doc-dateTime-min="1917-10-09T16:00:00-05:00" n="449" subtype="historical-document" type="document" xml:id="d449">
                        <note rend="inline" type="source">File No. 763.72111Sp1/94</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Spain</hi> (<persName corresp="frus1917Supp02v01#p_WJE1" type="to"><hi rend="italic">Willard</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-10-09T16:00:00-05:00">
                                    <hi rend="italic">October 9, 1917, 4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>704. Your 818, October 8, 11 a.m. You may take action similar to that of
                            your British and Italian colleagues and express to the Minister of
                            Foreign Affairs the profound regret of this Government at the escape of
                            the German submarine from Cadiz.</p>
                        <closer>
                            <signed>
                                <persName corresp="frus1917Supp02v01#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>