    <text>
        <body>
            <div frus:doc-dateTime-max="1917-11-19T17:00:00-05:00"
                frus:doc-dateTime-min="1917-11-19T17:00:00-05:00" n="456"
                subtype="historical-document" type="document" xml:id="d456">
                <note rend="inline" type="source">File No. 763.72111Sp1/105</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Spain</hi> (<persName corresp="frus1917Supp02v01#p_WW1"
                        type="to">
                        <hi rend="italic">Wilson</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-11-19T17:00:00-05:00">
                            <hi rend="italic">November 19, 1917, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>755. Your 879 and 880.<note n="3" xml:id="d456fn3">No. 880 not printed.</note>
                    You may join with the Allied Ambassadors in similar representations urging the
                    Spanish Government to intern the crews of German vessels now in Spanish
                    ports.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
