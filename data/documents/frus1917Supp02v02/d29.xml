                subtype="historical-document" type="document" xml:id="d29">
                <note rend="inline" type="source">File No. 763.72/5133</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName
                        corresp="frus1917Supp02v01#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-06-14T17:00:00-05:00">
                            <hi rend="italic">June 14, 1917, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>4995. Your June 5, 2 p.m., 6357. Nothing definitely decided in regard to
                    permanent technical mission. Considering advisability of nominating
                    representatives for committees already established. Decision will be reached
                    shortly.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
