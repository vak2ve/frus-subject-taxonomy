                subtype="historical-document" type="document" xml:id="d207">
                <note rend="inline" type="source">File No. 658.119/92</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Sweden</hi> (<persName corresp="frus1917Supp02v01#p_MIN1"
                        type="to">
                        <hi rend="italic">Morris</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-11-20T18:00:00-05:00">
                            <hi rend="italic">November 20, 1917, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>414. Your 982, November 14.<note n="1" xml:id="d207fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_1065">p. 1065</ref>.</note>
                    War Trade Board state negotiations have been proceeding here and they see no
                    reason for transfer to London at present. No formal proposals have been put
                    forward by either side as yet.</p>
                <closer>
                    <signed>
                        <persName corresp="frus1917Supp02v01#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
