                                    <cell>Savannah</cell>
                                    <cell>“</cell>
                                    <cell>“</cell>
                                </row>
                                <row>
                                    <cell>1</cell>
                                    <cell>S.S. <hi rend="italic">Sigrid</hi>
                                    </cell>
                                    <cell>“</cell>
                                    <cell>Norfolk</cell>
                                    <cell>“</cell>
                                    <cell>phosphate</cell>
                                </row>
                                <row>
                                    <cell>2.</cell>
                                    <cell>M.S. <hi rend="italic">Pacific</hi>
                                    </cell>
                                    <cell>“</cell>
                                    <cell>Colon</cell>
                                    <cell>“</cell>
