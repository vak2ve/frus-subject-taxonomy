                            </table>
                            <p>The figures indicate in which order vessels should proceed.</p>
                            <p>I understand S.S. <hi rend="italic">Sir Ernest Cassel</hi> has
                                already been afforded facilities to proceed.</p>
                            <closer>
                                <signed>
                                    <persName>
                                        <hi rend="smallcaps">A. R. Nordvall</hi>
                                    </persName>
                                </signed>
                                <lb/><dateline rendition="#left">
