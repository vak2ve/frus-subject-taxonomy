    <text>
        <body>
            <div frus:doc-dateTime-max="1864-07-01T23:59:59-05:00" frus:doc-dateTime-min="1864-07-01T00:00:00-05:00" n="415" subtype="historical-document" type="document" xml:id="d415">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Lord Lyons</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1864-07-01">
                            <hi rend="italic">July</hi> 1, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Lord</hi>: I have the honor to acknowledge the
                            receipt of your note of the 24th ultimo, relative to the case of Mr.
                            McHugh, a prisoner in Fort Lafayette. I now have the honor to acquaint
                            your lordship, in reply, that the Secretary of War has informed this
                            department that the discharge of the prisoner has been ordered.</p>
                <p>I have the honor to be, with high consideration, my lord, your obedient
                            servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>Right Hon. <hi rend="smallcaps">Lord Lyons,</hi>
                        <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
