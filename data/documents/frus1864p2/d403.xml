    <text>
        <body>
            <div frus:doc-dateTime-max="1864-06-16T23:59:59-05:00"
                frus:doc-dateTime-min="1864-06-16T00:00:00-05:00" n="403"
                subtype="historical-document" type="document" xml:id="d403">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Lord
                        Lyons</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1864-06-16">
                            <hi rend="italic">June</hi> 16, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Lord</hi>: I have the honor to acknowledge the receipt
                    of your note of the 13th instant relative to the case of the Blanche, and, in
                    reply, to assure your lordship that it will receive a careful consideration.</p>
                <p>I have the honor to be, with high consideration, my lord, your obedient
                    servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>Right Hon. Lord Lyons, <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
