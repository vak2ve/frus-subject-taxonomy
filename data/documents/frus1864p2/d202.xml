    <text>
        <body>
            <div frus:doc-dateTime-max="1863-12-17T23:59:59-05:00" frus:doc-dateTime-min="1863-12-17T00:00:00-05:00" n="202" subtype="historical-document" type="document" xml:id="d202">
                <head>
                    <persName type="from">Mr. Seward to Lord Lyons.</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1863-12-17">
                            <hi rend="italic">December</hi> 17, 1863.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My dear Lord Lyons</hi>: I have received your note
                            of yesterday, and thank you for the further proof of courtesy and
                            attention shown in the telegram to the executives of New Brunswick and
                            Nova Scotia, a copy of which you have sent me.</p>
                <p>Very truly, yours,</p>
                <closer>
                    <signed>WILLIAM H. SEWAED. </signed>
                </closer>
                <postscript>
                    <p>Right Hon. <hi rend="smallcaps">Lord Lyons</hi>, <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
