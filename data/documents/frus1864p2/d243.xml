    <text>
        <body>
            <div frus:doc-dateTime-max="1864-01-18T23:59:59-05:00" frus:doc-dateTime-min="1864-01-18T00:00:00-05:00" n="243" subtype="historical-document" type="document" xml:id="d243">
                <head>
                    <persName type="from">Lord Lyons</persName> to <persName type="to">Mr.
                                Seward</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1864-01-18">
                            <hi rend="italic">January</hi> 18, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have the honor to acknowledge the
                            receipt of your note of the day before yesterday’s date, relative to the
                            United States schooner J. L. Gerrity, which was seized by passengers on
                            board and carried to Belize. I have lost no time in forwarding a copy of
                            it to her Majesty’s government.</p>
                <p>I have the honor to be, with the highest consideration, sir, your most
                            obedient, humble servant,</p>
                <closer>
                    <signed>LYONS.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
