    <text>
        <body>
            <div frus:doc-dateTime-max="1864-01-21T23:59:59-05:00"
                frus:doc-dateTime-min="1864-01-21T00:00:00-05:00" n="248"
                subtype="historical-document" type="document" xml:id="d248">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Lord
                        Lyons</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1864-01-21">
                            <hi rend="italic">January</hi> 21, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Lord</hi>: Your note of the 30th ultimo, relative to the
                    case of the “Victor” was duly received, and has been taken into consideration.
                    This department expects to have occasion soon to address you again on that
                    subject. I have the honor to be, my lord, your very obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD. </signed>
                </closer>
                <postscript>
                    <p>Right Hon. <hi rend="smallcaps">Lord Lyons</hi>, <hi rend="italic">&amp;c.,
                            &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
