    <text>
        <body>
            <div frus:doc-dateTime-max="1864-10-23T23:59:59-05:00"
                frus:doc-dateTime-min="1864-10-23T00:00:00-05:00" n="542"
                subtype="historical-document" type="document" xml:id="d542">
                <head>
                    <persName type="from">Mr. Burnley</persName> to <persName type="to">Mr.
                        Seward</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1864-10-23">
                            <hi rend="italic">October</hi> 23, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have the honor to acknowledge receipt of your
                    note of the 21st instant, relative to the affair at St. Albans, and beg to state
                    that I have caused a copy of this note to be sent to his excellency the governor
                    general of Canada.</p>
                <p>I have the honor to be, with the highest consideration, sir, your most obedient,
                    humble servant,</p>
                <closer>
                    <signed>J. HUME BURNLEY.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">&amp;c,
                            &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
