    <text>
        <body>
            <div frus:doc-dateTime-max="1864-10-12T23:59:59-05:00" frus:doc-dateTime-min="1864-10-12T00:00:00-05:00" n="529" subtype="historical-document" type="document" xml:id="d529">
                <head>
                    <persName type="from">Mr. Burnley</persName> to <persName type="to">Mr. Seward</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1864-10-12">
                            <hi rend="italic">October</hi> 12, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have the honor to acknowledge the
                            receipt of your note of the 11th instant, relative to the extradition of
                            William H. Crawford, and to state, in reply, that I have communicated a
                            copy of that note to his excellency the governor general of Canada.</p>
                <p>I have the honor to be, with the highest consideration, sir, your most
                            obedient, humble servant,</p>
                <closer>
                    <signed>J. HUME BURNLEY.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William H. Seward,</hi>
                        <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
