    <text>
        <body>
            <div frus:doc-dateTime-max="1864-11-18T23:59:59-05:00"
                frus:doc-dateTime-min="1864-11-18T00:00:00-05:00" n="577"
                subtype="historical-document" type="document" xml:id="d577">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Lord
                        Lyons</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1864-11-18">
                            <hi rend="italic">November</hi> 18, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Lord</hi>: I have the honor to acknowledge the receipt
                    of your communication of the 15th instant, in answer to my note of the 3d
                    ultimo, relative to information received at the department respecting the
                    alleged proceedings of Captain Hewitt, of the royal navy.</p>
                <p>I have the honor to be, with high consideration, my Lord, your obedient
                    servants,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>Right Hon. <hi rend="smallcaps">Lord Lyons,</hi>
                        <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
