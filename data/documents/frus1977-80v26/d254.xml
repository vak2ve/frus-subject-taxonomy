                        </list>
                    </item>
                    <item>
                        <list>
                            <item>
                                <hi rend="italic">
                                    <gloss target="#t_DCI_1">DCI</gloss>
                                </hi>
                            </item>
                            <item>Ray McCrory, Chief, Arms Control Intelligence Staff</item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <item>[<hi rend="italic">name not declassified</hi>] Chief, Nuclear
                                &amp; Test Monitoring Branch</item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <item>
                                <hi rend="italic">Energy</hi>
                            </item>
                            <item>Duane Sewell, Assistant Secretary for Defense Programs</item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <item>
                                <hi rend="italic">
                                    <gloss target="#t_ACDA_1">ACDA</gloss>
                                </hi>
                            </item>
                            <item>Director <persName corresp="#p_ER_1">Ralph Earle</persName>
                            </item>
                            <item>
                                <persName corresp="#p_KS_1">Spurgeon Keeny</persName>, Deputy
                                Director</item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <item>
                                <hi rend="italic">OSTP</hi>
                            </item>
                            <item>John Marcum, Senior Adviser for Technology &amp; Arms
                                Control</item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <item>
                                <hi rend="italic">White House</hi>
                            </item>
                            <item>
                                <persName corresp="#p_AD_1">David Aaron</persName>
                            </item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <item>
                                <hi rend="italic">
                                    <gloss target="#t_NSC_1">NSC</gloss>
                                </hi>
                            </item>
                            <item>Marshall Brement</item>
