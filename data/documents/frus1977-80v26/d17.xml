                <head>17. Summary of Conclusions of a Special Coordination Committee Meeting<note
                        n="1" type="source" xml:id="d17fn1">Source: Library of Congress, Manuscript
                        Division, <persName corresp="#p_BH_2">Harold Brown</persName> Papers, Box
                        82, Brown Files—General #1, <gloss target="#t_ASAT_1">ASAT</gloss> Arms
                        Control. Top Secret. The meeting took place in the White House Situation
                        Room.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            from="1978-02-15T14:30:00-05:00" to="1978-02-15T15:45:00-05:00">February
                            15, 1978, 2:30–3:45 p.m.</date>
                    </dateline>
                </opener>
                <list type="subject">
                    <head>SUBJECT</head>
                    <item>
                        <gloss target="#t_ASAT_1">ASAT</gloss> Treaty</item>
                </list>
                <list type="participants">
                    <head>PARTICIPANTS</head>
                    <item>
                        <hi rend="italic">State</hi>
                    </item>
                    <item>Secretary <persName corresp="#p_VCR_1">Cyrus Vance</persName>
                    </item>
                    <item>Jerry Kahan, Deputy Director, Office of Political/Military Affairs</item>
                    <item>
                        <hi rend="italic">Defense</hi>
                    </item>
                    <item>Secretary <persName corresp="#p_BH_2">Harold Brown</persName>
                    </item>
                    <item>Deputy Secretary <persName corresp="#p_DCW_1">Charles Duncan</persName>
                    </item>
                    <item>
                        <persName corresp="#p_SWB_1">Walter Slocombe</persName>, Principal Deputy
                        Assistant Secretary for International Security Affairs</item>
                    <item>
                        <hi rend="italic">
                            <gloss target="#t_JCS_1">JCS</gloss>
                        </hi>
