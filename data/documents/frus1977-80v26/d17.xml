                        Assistant to the Chairman</item>
                    <item>
                        <hi rend="italic">
                            <gloss target="#t_ACDA_1">ACDA</gloss>
                        </hi>
                    </item>
                    <item>
                        <persName corresp="#p_KS_1">Spurgeon Keeny</persName>, Deputy
                        Director</item>
                    <item>James Timbie, Head, Strategic Affairs Division</item>
                    <item>
                        <hi rend="italic">
                            <gloss target="#t_NASA_1">NASA</gloss>
                        </hi>
                    </item>
                    <item>
                        <persName corresp="#p_FRA_1">Robert Frosch</persName>, Administrator</item>
                    <item>Alan Lovelace, Deputy Administrator</item>
                    <item>
                        <hi rend="italic">OSTP</hi>
                    </item>
                    <item>
                        <persName corresp="#p_PF_1">Frank Press</persName>
                    </item>
                    <item>Ben Huberman</item>
                    <item>Arthur Morrissey, Senior Analyst</item>
                    <item>
                        <hi rend="italic">
                            <gloss target="#t_OMB_1">OMB</gloss>
                        </hi>
                    </item>
