                            <item>Secretary <persName corresp="#p_VCR_1">Cyrus Vance</persName>
                            </item>
                            <item>
                                <persName corresp="#p_BLW_1">Lucy Benson</persName>, Under Secretary
                                for Security Assistance</item>
                            <item>
                                <persName corresp="#p_GLH_1">Leslie Gelb</persName>, Director,
                                Office of Politico-Military Affairs</item>
                        </list>
                    </item>
                    <item>
                        <list>
