                    <item>
                        <list>
                            <head>White House</head>
                            <item>
                                <persName corresp="#p_BZ_1">Zbigniew Brzezinski</persName>
                            </item>
                            <item>
                                <persName corresp="#p_MJT_1">Jessica Tuchman</persName>, <gloss
                                    target="#t_NSC_1">NSC</gloss>
                            </item>
                            <item>Leslie G. Denend, <gloss target="#t_NSC_1">NSC</gloss>
