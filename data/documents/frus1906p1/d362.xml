                    <hi rend="italic">Third Assistant Secretary of State <persName type="from"
                            >Wilson</persName> to Consul-General <persName type="to"
                            >Rodgers</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Paraphrase.]</seg>
