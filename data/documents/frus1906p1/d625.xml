                subtype="historical-document" type="document" xml:id="d625">
                <head>
                    <hi rend="italic">The <gloss type="from">Earl of Elgin</gloss> to Governor Sir
                            <persName type="to">W. MacGregor</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegraphic]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Downing Street</hi>
                        </placeName>, <date calendar="gregorian" when="1906-10-06">
                            <hi rend="italic">October 6, 1906</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 43.]</seg>
                </opener>
                <p>Referring to your telegram of the 5th instant, His Majesty’s ship <hi
                        rend="italic">Brilliant</hi> has been ordered to remain in Newfoundland
                    waters until end of season.</p>
            </div>
        </body>
