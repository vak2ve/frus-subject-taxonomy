<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1906-06-27T23:59:59-05:00" frus:doc-dateTime-min="1906-06-27T00:00:00-05:00" n="127" subtype="historical-document" type="document" xml:id="d127">
                        <head><hi rend="italic">Minister <persName type="from">Hicks</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Santiago</hi></placeName>, <hi rend="italic"><date calendar="gregorian" when="1906-06-27">June 27,
                                    1906</date></hi>.</dateline></opener>
                        <p>(Announces that the election of Pedro Montt as President by a large
                            majority is conceded by all parties.)</p>
                    </div>
