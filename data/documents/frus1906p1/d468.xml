                subtype="historical-document" type="document" xml:id="d468">
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to King
                        of Denmark, <persName type="to">Frederick VIII</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1906-01-30">
                            <hi rend="italic">January 30, 1906</hi>
                        </date>.</dateline>
                </opener>
                <p>I desire to express to you my profound sympathy in the grief that you and your
                    people feel in the loss of the late King, who during his long reign has been in
                    very truth a father to his people.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
