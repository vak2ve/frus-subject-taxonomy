                subtype="historical-document" type="document" xml:id="d361">
                <head>
                    <hi rend="italic">Consul-General <persName type="from">Rodgers</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Abstract.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1906-12-17">
                            <hi rend="italic">December 17, 1906</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Rodgers reports that the United States court opened this day, and requests
                    that the department cable date of confirmation of the court officials.)</p>
            </div>
        </body>
