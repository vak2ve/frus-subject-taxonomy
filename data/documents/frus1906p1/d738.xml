<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1906-10-26T23:59:59-05:00" frus:doc-dateTime-min="1906-10-26T00:00:00-05:00" n="738" subtype="historical-document" type="document" xml:id="d738">
                        <head><hi rend="italic">President <persName type="from">Roosevelt</persName>
                                to the <gloss type="to">President of Guatemala</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1906-10-26"><hi rend="italic">October 26,
                                1906</hi></date>.</dateline></opener>
                        <p>I thank you for your kind message. On behalf of this nation I paid
                            sympathetic respects to the distinguished deceased.</p>
                        <closer><signed><hi rend="smallcaps">Theodore
                            Roosevelt.</hi></signed></closer>
                    </div>
                </body></text></TEI>