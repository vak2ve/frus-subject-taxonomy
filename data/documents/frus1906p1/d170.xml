    <text>
        <body>
            <div frus:doc-dateTime-max="1906-05-03T23:59:59-05:00"
                frus:doc-dateTime-min="1906-05-03T00:00:00-05:00" n="170"
                subtype="historical-document" type="document" xml:id="d170">
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Chargé <persName type="to">Wilson</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Extract.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <hi rend="italic">
                            <date calendar="gregorian" when="1906-05-03">May 3, 1906</date>
                        </hi>.</dateline>
                    <seg rendition="#left">No. 187.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                    dispatches Nos. 418 and 420, both dated the 28th of March last, relating to the
                    policy of Japan respecting the open door in Manchuria.</p>
                <p>The department commends your conduct in the matter.</p>
                <p>I am, etc.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Bacon</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
