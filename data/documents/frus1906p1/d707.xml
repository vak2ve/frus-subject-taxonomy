<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1906-07-18T23:59:59-05:00" frus:doc-dateTime-min="1906-07-18T00:00:00-05:00" n="707" subtype="historical-document" type="document" xml:id="d707">
                        <head><hi rend="italic">Chargé <persName type="from">Brown</persName> to the
                                    <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.—Extract.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Guatemala</hi></placeName>, <date calendar="gregorian" when="1906-07-18"><hi rend="italic">July 18,
                                1906</hi></date>.</dateline></opener>
                        <p>(Mr. Brown reports that President Estrada deeply appreciates effective
                            cooperation of President Diaz and has cordially invited Mexican minister
                            to attend peace negotiations.)</p>
                    </div>
                    </body></text></TEI>