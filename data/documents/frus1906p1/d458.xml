                subtype="historical-document" type="document" xml:id="d458">
                <head>
                    <hi rend="italic">Chargé <persName type="from">Sleeper</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1906-01-30">
                            <hi rend="italic">January 30, 1906</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Sleeper reports compliance with the department’s telegram of 30th, relative
                    to the Seaboard Rice Milling Company, and adds that the answer of foreign office
                    will be made known to the department as soon as possible.)</p>
            </div>
        </body>
