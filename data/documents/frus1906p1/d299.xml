                subtype="historical-document" type="document" xml:id="d299">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Rockhill</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegrams—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-12-04">
                            <hi rend="italic">December 4, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Root tells Mr. Rockhill, unless he sees reasons to the contrary, to instruct
                    Consul-General Lay according to the wishes of the latter.)</p>
            </div>
