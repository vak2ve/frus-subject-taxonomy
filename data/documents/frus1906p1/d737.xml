<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1906-10-23T23:59:59-05:00" frus:doc-dateTime-min="1906-10-23T00:00:00-05:00" n="737" subtype="historical-document" type="document" xml:id="d737">
                        <head><hi rend="italic">The <gloss type="from">Guatemalan Minister of
                                    Foreign Affairs</gloss> to the <gloss type="to">Secretary of
                                    State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Guatemala</hi></placeName>, <date calendar="gregorian" when="1906-10-23"><hi rend="italic">October 23,
                                1906</hi></date>.</dateline></opener>
                        <p>The President and Government of Guatemala sincerely thank you for
                            expression of condolence and immediate acceptance Chargé Bengoechea.</p>
                        <closer><signed><hi rend="smallcaps">Juan Barrios</hi>.</signed></closer>
                    </div>
                    </body></text></TEI>