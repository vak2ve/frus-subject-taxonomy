                subtype="historical-document" type="document" xml:id="d574">
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Reid</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">London</hi>
                        </placeName>, <date calendar="gregorian" when="1906-09-29">
                            <hi rend="italic">September 29, 1906</hi>
                        </date>.</dateline>
                </opener>
                <p>No. 82. Referring to department’s No. 250, August 7, foreign office reports
                    confiscated property sold some months ago, but proceeds of sale will be handed
                    over to the master of vessel, and he will not be subject to further
                    proceedings.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Reid.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
