                subtype="historical-document" type="document" xml:id="d270">
                <head>
                    <hi rend="italic">Minister <persName type="from">Rockhill</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1906-05-09">
                            <hi rend="italic">May 9, 1906</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Rockhill reports that by an imperial edict issued this day all the customs
                    of China and all the foreigners employed therein are placed under the control of
                    T’ieh Liang, who is appointed minister superintendent of customs affairs, with
                    Vice-Minister T’angShao Yi.)</p>
            </div>
        </body>
