    <text>
        <body>
            <div frus:doc-dateTime-max="1906-01-29T23:59:59-05:00"
                frus:doc-dateTime-min="1906-01-29T00:00:00-05:00" n="470"
                subtype="historical-document" type="document" xml:id="d470">
                <head>
                    <hi rend="italic">The <gloss type="from">Danish Minister</gloss> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Denmark</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1906-01-29">
                            <hi rend="italic">January 29, 1906</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: By order of my Government, I
                    have to perform the painful duty of advising your excellency that His Majesty
                    the King, my august sovereign, died suddenly this afternoon at 3.20.</p>
                <p>I venture to beg your excellency to be so good as to convey this grievous
                    intelligence to the President of the United States.</p>
                <p>Be pleased to accept, Mr. Secretary of State, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">C. Brun.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
