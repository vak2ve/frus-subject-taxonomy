                subtype="historical-document" type="document" xml:id="d102">
                <head>
                    <hi rend="italic">Chargé <persName type="from">Richardson</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">Petropolis</hi>
                        </placeName>, <date calendar="gregorian" when="1906-03-03">
                            <hi rend="italic">March 3, 1906</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 153.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to report that on March 1 Dr.
                    Affonso Penna was elected President and Dr. Nilo Peganha Vice-President of the
                    Republic for the period of four years commencing November 15 next.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Charles Richardson</hi>.</signed>
                </closer>
            </div>
        </body>
