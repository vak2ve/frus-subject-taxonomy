                subtype="historical-document" type="document" xml:id="d377">
                <head>
                    <hi rend="italic">Minister <persName type="from">Barrett</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Bogotá</hi>
                        </placeName>, <date calendar="gregorian" when="1906-06-17">
                            <hi rend="italic">June 17, 1906</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Barrett asks if Secretary Root will accept invitation of Colombia to stop a
                    day at Cartagena en route Panama-New York. The minister of foreign affairs will
                    be sent to meet the Secretary on his arrival.)</p>
            </div>
        </body>
