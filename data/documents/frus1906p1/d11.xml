<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1906-03-12T23:59:59-05:00" frus:doc-dateTime-min="1906-03-12T00:00:00-05:00" n="11" subtype="historical-document" type="document" xml:id="d11">
                        <head><hi rend="italic">Minister <persName type="from">Beaupré</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Buenos
                                        Aires</hi></placeName>, <date calendar="gregorian" when="1906-03-12"><hi rend="italic">March 12,
                                1906</hi></date>.</dateline></opener>
                        <p>President Quintana died this morning at 1.36.</p>
                        <closer><signed><hi rend="smallcaps">Beaupré.</hi></signed></closer>
                    </div>
                    </body></text></TEI>