                <head>
                    <hi rend="italic">Minister <persName type="from">Beaupré</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1906-03-12">
                            <hi rend="italic">March 12, 1906</hi>
                        </date>.</dateline>
                </opener>
                <p>President Quintana died this morning at 1.36.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Beaupré.</hi>
                    </signed>
                </closer>
            </div>
        </body>
