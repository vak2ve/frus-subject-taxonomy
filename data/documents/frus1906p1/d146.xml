                subtype="historical-document" type="document" xml:id="d146">
                <head>
                    <hi rend="italic">Minister <persName type="from">Hicks</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Santiago</hi>
                        </placeName>, <hi rend="italic">
                            <date calendar="gregorian" when="1906-08-23">August 23, 1906</date>
                        </hi>.</dateline>
                </opener>
                <p>Have just delivered to President $10,000, gift of people of San Francisco, Cal.,
                    for earthquake sufferers; first American subscription.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hicks.</hi>
                    </signed>
                </closer>
            </div>
        </body>
