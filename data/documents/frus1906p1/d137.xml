<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1906-08-19T23:59:59-05:00" frus:doc-dateTime-min="1906-08-19T00:00:00-05:00" n="137" subtype="historical-document" type="document" xml:id="d137">
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Minister <persName type="to">Hicks</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <hi rend="italic"><date calendar="gregorian" when="1906-08-19">August 19,
                                        1906</date></hi>.</dateline></opener>
                        <p>The people of the United States share in grief of Chile. President
                            telegraphs condolences.</p>
                        <closer><signed><hi rend="smallcaps">Adee.</hi></signed></closer>
                    </div>
                    </body></text></TEI>