                subtype="historical-document" type="document" xml:id="d12">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Beaupré</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1906-03-12">
                            <hi rend="italic">March 12, 1906</hi>
                        </date>.</dateline>
                </opener>
                <p>Suitably express in President’s name sincere condolence with family late
                    President and his sympathy with the Argentine Government and people in loss they
                    have sustained.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Root.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
