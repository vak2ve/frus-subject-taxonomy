                subtype="historical-document" type="document" xml:id="d469">
                <head>
                    <hi rend="italic">Minister <persName type="from">O’Brien</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Copenhagen</hi>
                        </placeName>, <date calendar="gregorian" when="1906-01-30">
                            <hi rend="italic">January 30, 1906</hi>
                        </date>.</dateline>
                </opener>
                <p>At noon late crown prince proclaimed King Frederick VIII by prime minister in
                    presence of large concourse. Announcement received with enthusiasm.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">O’Brien.</hi>
                    </signed>
                </closer>
            </div>
        </body>
