<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1906-11-17T23:59:59-05:00" frus:doc-dateTime-min="1906-11-17T00:00:00-05:00" n="107" subtype="historical-document" type="document" xml:id="d107">
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Ambassador <persName type="to">Griscom</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1906-11-17"><hi rend="italic">November 17,
                                    1906</hi></date>.</dateline></opener>
                        <p>Express the thanks of this Government and of myself personally to
                            President Penna for the kind and helpful expressions of his inaugural
                            address.</p>
                        <closer><signed><hi rend="smallcaps">Root.</hi></signed></closer>
                    </div>
                </body></text></TEI>