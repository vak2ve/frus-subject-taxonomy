<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1906-01-29T23:59:59-05:00" frus:doc-dateTime-min="1906-01-29T00:00:00-05:00" n="467" subtype="historical-document" type="document" xml:id="d467">
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">O’Brien</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1906-01-29"><hi rend="italic">January 29,
                                1906</hi></date>.</dateline></opener>
                        <p>Convey through appropriate channel the sincere condolences of the
                            President and of your countrymen upon the death of His Majesty King
                            Christian.</p>
                        <closer><signed><hi rend="smallcaps">Root.</hi></signed></closer>
                    </div>
                    </body></text></TEI>