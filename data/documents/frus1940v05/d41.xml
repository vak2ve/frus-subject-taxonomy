                subtype="historical-document" type="document" xml:id="d41">
                <note rend="inline" type="source">810.20 Defense/1432/4: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Bolivia</hi> (<persName type="from">
                        <hi rend="italic">Jenkins</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">La Paz</hi>
                        </placeName>, <date calendar="gregorian" when="1940-10-03T16:00:00-04:00"
                            >October 3, 1940—4 p.m.</date>
                        <lb/>[Received 4:45 p.m.]</dateline>
                </opener>
                <p>79. For General Strong from Major Taylor.</p>
                <p>“After numerous delays conversations with Bolivian Chief of Staff terminated
                    satisfactorily. Air photographs authorized using American equipment. Medical
                    mission approved. Leaving for Washington October 4.”</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Jenkins</hi>
                    </signed>
                </closer>
            </div>
        </body>
