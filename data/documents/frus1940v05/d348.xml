<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-01-31T08:00:00-05:00" frus:doc-dateTime-min="1940-01-31T08:00:00-05:00" n="348" subtype="historical-document" type="document" xml:id="d348">
                        <note rend="inline" type="source">740.00111A.R.–N.C./23: Telegram</note>
                        <head><hi rend="italic">The Minister in Bolivia</hi> (<persName type="from"><hi rend="italic">Jenkins</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">La
                                    Paz</hi></placeName>, <date calendar="gregorian" when="1940-01-31T09:00:00-04:00">January 31, 1940—9
                                a.m.</date><lb/>[Received 10:30 a.m.]</dateline>
                        </opener>
                        <p>4. Department’s telegram of January 27, 3 p.m. Minister for Foreign
                                Affairs<note n="30" xml:id="d348fn1">Alberto Ostria
                                Gutiérrez.</note> states that he wholeheartedly supports position of
                            the Department.</p>
                        <closer><signed><hi rend="smallcaps">Jenkins</hi></signed></closer>
                    </div>
