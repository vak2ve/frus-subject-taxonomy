    <text>
        <body>
            <div frus:doc-dateTime-max="1940-03-25T10:00:00-05:00"
                frus:doc-dateTime-min="1940-03-25T10:00:00-05:00" n="699"
                subtype="historical-document" type="document" xml:id="d699">
                <note rend="inline" type="source">832.51/1795: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from">
                        <hi rend="italic">Caffery</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1940-03-25T12:00:00-03:00"
                            >March 25, 1940—noon</date>.<lb/>[Received 12:18 p.m.]</dateline>
                </opener>
                <p>123. My 119, March 19, 4 p.m., and 120, March 20, 1 p.m.<note n="26"
                        xml:id="d699fn1">Neither printed.</note> The Director of Exchange informs me
                    that acting upon instructions of the Minister of Finance he is today arranging
                    for the distribution of foreign exchange to cover the April payments on the
                    Brazilian foreign debt.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caffery</hi>
                    </signed>
                </closer>
            </div>
        </body>
