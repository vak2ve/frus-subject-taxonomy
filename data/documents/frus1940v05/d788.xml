                subtype="historical-document" type="document" xml:id="d788">
                <note rend="inline" type="source">832.796/232: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from">
                        <hi rend="italic">Caffery</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1940-10-14T16:00:00-03:00"
                            >October 14, 1940—4 p.m.</date>
                        <lb/>[Received 5:12 p.m.]</dateline>
                </opener>
                <p>527. For Duggan.<note n="89" xml:id="d788fn1">Laurence Duggan, Chief of the
                        Division of the American Republics.</note> Referring to your note of October
                        1,<note n="90" xml:id="d788fn2">Not found in Department files.</note>
                        Aranha<note n="91" xml:id="d788fn3">Oswaldo Aranha, Brazilian Minister for
                        Foreign Affairs.</note> told me today that he personally would favor ousting
                    the German aviation element and would be glad to have a look at your
                    formula.…</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caffery</hi>
                    </signed>
                </closer>
            </div>
        </body>
