<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-02-07T13:00:00-05:00" frus:doc-dateTime-min="1940-02-07T13:00:00-05:00" n="362" subtype="historical-document" type="document" xml:id="d362">
                        <note rend="inline" type="source">740.00111A.R.–N.C./40: Telegram</note>
                        <head><hi rend="italic">The Minister in Haiti</hi> (<persName type="from"><hi rend="italic">Mayer</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Port au
                                        Prince</hi></placeName>, <date calendar="gregorian" when="1940-02-07T13:00:00-05:00">February 7, 1940—1
                                p.m.</date><lb/>[Received 2:10 p.m.]</dateline>
                        </opener>
                        <p>17. Department’s circular January 27, 3 p.m. The Minister for Foreign
                                Affairs<note n="42" xml:id="d362fn1">Léon Laleau.</note> strongly
                            supports the Department’s point of view.</p>
                        <closer><signed><hi rend="smallcaps">Mayer</hi></signed></closer>
