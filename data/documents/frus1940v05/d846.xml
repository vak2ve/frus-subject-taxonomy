                subtype="historical-document" type="document" xml:id="d846">
                <note rend="inline" type="source">821.51/2526: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Colombia</hi> (<persName type="from">
                        <hi rend="italic">Braden</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bogotá</hi>
                        </placeName>, <date calendar="gregorian" when="1940-07-15T19:00:00-05:00"
                            >July 15, 1940—7 p.m.</date>
                        <lb/>[Received 10:14 p.m.]</dateline>
                </opener>
                <p>192. My telegram No. 172, June 26, 2 p.m. Interpretation now is special powers
                    expire midnight July 19.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Braden</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
