                subtype="historical-document" type="document" xml:id="d916">
                <note rend="inline" type="source">837.51/2642a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Cuba</hi> (<persName type="to">
                        <hi rend="italic">Messersmith</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-09-04T14:00:00-04:00"
                            >September 4, 1940—2 p.m.</date>
                    </dateline>
                </opener>
                <p>144. Your 96, September 3, 4 p.m.<note n="67" xml:id="d916fn1">Not
                        printed.</note> I shall look forward to discussing with you in Washington
                    when you arrive our relations with Cuba. In the meantime no decision will be
                    taken with respect to the Cuban request for a loan.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
