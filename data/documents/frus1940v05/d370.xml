<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-02-23T17:00:00-05:00" frus:doc-dateTime-min="1940-02-23T17:00:00-05:00" n="370" subtype="historical-document" type="document" xml:id="d370">
                        <note rend="inline" type="source">740.00111A.R.–N.C./54: Telegram</note>
                        <head><hi rend="italic">The Minister in Uruguay</hi> (<persName type="from"><hi rend="italic">Wilson</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Montevideo</hi></placeName>, <date calendar="gregorian" when="1940-02-23T19:00:00-03:00">February 23, 1940—7
                                p.m.</date><lb/>[Received February 23—5:46 p.m.]</dateline>
                        </opener>
                        <p>24. Your 13, February 21. Guani tells me that he cabled an affirmative
                            reply yesterday.</p>
                        <closer><signed><hi rend="smallcaps">Wilson</hi></signed></closer>
                    </div>
