                subtype="historical-document" type="document" xml:id="d130">
                <note rend="inline" type="source">810.20 Defense/67<hi rend="superscript">1/24</hi>:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Minister in El Salvador</hi> (<persName type="from">
                        <hi rend="italic">Frazer</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Salvador</hi>
                        </placeName>, <date calendar="gregorian" when="1940-06-04T02:00:00-06:00"
                            >June 4, 1940—2 a.m.</date>
                        <lb/>[Received 6:33 p.m.]</dateline>
                </opener>
                <p>24. I saw President of Salvador<note n="52" xml:id="d130fn1">Gen. Maximiliano H.
                        Martínez.</note> today who cordially concurs in all ideas set forth in the
                    Department telegram 19 of June 3, 3 p.m.<note n="53" xml:id="d130fn2">See
                        footnote 29, <ref target="#pg_16">p. 16</ref>.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Frazer</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
