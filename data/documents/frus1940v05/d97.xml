                subtype="historical-document" type="document" xml:id="d97">
                <note rend="inline" type="source">810.20 Defense/72<hi rend="superscript">1/15</hi>:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Costa Rica</hi> (<persName type="from">
                        <hi rend="italic">Hornibrook</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San José</hi>
                        </placeName>, <date calendar="gregorian" when="1940-06-04T12:00:00-06:00"
                            >June 4, 1940—noon</date>.<lb/>[Received 6:32 p.m.]</dateline>
                </opener>
                <p>60. Department’s cable No. 40, June 3, 3 p.m.<note n="12" xml:id="d97fn1">See
                        footnote 29, <ref target="#pg_16">p. 16</ref>.</note> I conferred with the
                    President at 11 a.m. He accepted the proposals in their entirety and is anxious
                    to cooperate at the earliest possible date. Please advise as to date of arrival
                    of officers.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hornibrook</hi>
                    </signed>
                </closer>
            </div>
        </body>
