                subtype="historical-document" type="document" xml:id="d142">
                <note rend="inline" type="source">810.20 Defense/52<hi rend="superscript"
                    >14/16</hi>: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Guatemala</hi> (<persName type="from">
                        <hi rend="italic">Des Portes</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guatemala</hi>
                        </placeName>, <date calendar="gregorian" when="1940-09-20T10:00:00-06:00"
                            >September 20, 1940—10 a.m.</date>
                        <lb/>[Received 12:55 p.m.]</dateline>
                </opener>
                <p>85. For General Strong. Permission granted by Guatemalan Government for
                    photographic air mission to operate this country based on Guatemala City. Depart
                    Friday. Delay one day Mexico. Signed Mathewson.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Des Portes</hi>
                    </signed>
                </closer>
            </div>
        </body>
