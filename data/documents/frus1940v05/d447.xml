                subtype="historical-document" type="document" xml:id="d447">
                <note rend="inline" type="source">561.333D3/14: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Secretary General of the Third Pan American Coffee Conference</hi>
                        (<persName type="to">
                        <hi rend="italic">Aguilar</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-06-17">June 17,
                            1940</date>.</dateline>
                </opener>
                <p>In response to your letter of June 14, 1940, the Department of State has
                    designated Mr. Paul C. Daniels, Foreign Service Officer, to attend the Third
                    Pan-American Coffee Conference as its observer.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cordell Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
