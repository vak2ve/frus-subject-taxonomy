    <text>
        <body>
            <div frus:doc-dateTime-max="1940-07-17T16:00:00-05:00"
                frus:doc-dateTime-min="1940-07-17T16:00:00-05:00" n="132"
                subtype="historical-document" type="document" xml:id="d132">
                <note rend="inline" type="source">810.20 Defense/67<hi rend="superscript">3/24</hi>:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Minister in El Salvador</hi> (<persName type="from">
                        <hi rend="italic">Frazer</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Salvador</hi>
                        </placeName>, <date calendar="gregorian" when="1940-07-17T15:00:00-06:00"
                            >July 17, 1940—3 p.m.</date>
                        <lb/>[Received 5:05 p.m.]</dateline>
                </opener>
                <p>34. President of El Salvador today expressed complete accord with proposals
                    contained in Department’s circular telegram dated July 11, 4 p.m.<note n="54"
                        xml:id="d132fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_19">p. 19</ref>.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Frazer</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
