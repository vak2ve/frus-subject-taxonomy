    <text>
        <body>
            <div frus:doc-dateTime-max="1940-12-17T07:00:00-05:00"
                frus:doc-dateTime-min="1940-12-17T07:00:00-05:00" n="780"
                subtype="historical-document" type="document" xml:id="d780">
                <note rend="inline" type="source">832.24/298: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Brazil</hi> (<persName type="from">
                        <hi rend="italic">Burdett</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1940-12-17T09:00:00-03:00"
                            >December 17, 1940—9 a.m.</date>
                        <lb/>[Received 9:33 a.m.]</dateline>
                </opener>
                <p>671. My 669, December 16, 9 a.m. General satisfaction expressed by Rio press
                    concerning release of <hi rend="italic">Siqueira Campos</hi>. Pro-Nazi papers
                    carry no comment.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Burdett</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
