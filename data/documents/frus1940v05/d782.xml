                subtype="historical-document" type="document" xml:id="d782">
                <note rend="inline" type="source">832.24/299: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in the United Kingdom</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1940-12-18T12:00:00+01:00"
                            >December 18, 1940—noon</date>.<lb/>[Received December 18—7:15
                        a.m.]</dateline>
                </opener>
                <p>4110. For the Under Secretary. My 4106, Dec. 17, 8 p.m. Foreign Office informs me
                    that orders were issued this morning for the release of the <hi rend="italic"
                        >Siqueira Campos.</hi>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
