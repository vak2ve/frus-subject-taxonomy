                subtype="historical-document" type="document" xml:id="d663">
                <note rend="inline" type="source">832.51/1722: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Brazil</hi> (<persName type="to">
                        <hi rend="italic">Caffery</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-02-20T17:00:00-05:00"
                            >February 20, 1940—5 p.m.</date>
                    </dateline>
                </opener>
                <p>34. Your 66, February 20, 1 p.m. White<note n="10" xml:id="d663fn1">Francis
                        White, President of the Foreign Bondholders Protective Council.</note> will
                    discuss matter at Department Wednesday, having put it before his Executive
                    Committee today. Department will telegraph tomorrow afternoon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
