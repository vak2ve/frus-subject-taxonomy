                subtype="historical-document" type="document" xml:id="d205">
                <note rend="inline" type="source">810.20 Defense/34<hi rend="superscript">6/12</hi>:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Peru</hi> (<persName type="from">
                        <hi rend="italic">Norweb</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1940-07-13T10:00:00-05:00"
                            >July 13, 1940—10 a.m.</date>
                        <lb/>[Received 11:30 a.m.]</dateline>
                </opener>
                <p>100. Department’s circular telegram of July 11, 4 p.m.<note n="22"
                        xml:id="d205fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_19">p. 19</ref>.</note> The
                    Minister for Foreign Affairs stated that he was in accord with holding staff
                    talks immediately after the Habana Conference and expressed the hope that the
                    conversations might be held at Lima.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Norweb</hi>
                    </signed>
                </closer>
            </div>
        </body>
