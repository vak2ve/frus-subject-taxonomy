<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-06-20T15:00:00-05:00" frus:doc-dateTime-min="1940-06-20T15:00:00-05:00" n="1240" subtype="historical-document" type="document" xml:id="d1240">
                        <note rend="inline" type="source">811.3332/98: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from"><hi rend="italic">Caffery</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Rio de
                                        Janeiro</hi></placeName>, <date calendar="gregorian" when="1940-06-20T17:00:00-03:00">June 20, 1940—5
                                p.m.</date><lb/>[Received June 20—4:51 p.m.]</dateline>
                        </opener>
                        <p>294. For Under Secretary. Department’s telegram No. 175, June 19, noon. I
                            suggest a 3–day informal visit to Recife.</p>
                        <closer><signed><hi rend="smallcaps">Caffery</hi></signed></closer>
                    </div>
                    </body></text></TEI>