                subtype="historical-document" type="document" xml:id="d1034">
                <note rend="inline" type="source">838.51/3955: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Haiti</hi> (<persName type="from">
                        <hi rend="italic">Mayer</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port-au-Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1940-06-17T13:00:00-05:00"
                            >June 17, 1940—1 p.m.</date>
                        <lb/>[Received June 17—1 p.m.]</dateline>
                </opener>
                <p>96. Department’s 89, June 13, 8 p.m.<note n="11" xml:id="d1034fn1">Not
                        printed.</note> In conformity with a recent telephone conversation I
                    suggested to President Vincent in a conversation this morning at which Pixley
                    was present to resume construction at the $160,000 per month rate. President
                    Vincent enthusiastically approved.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Mayer</hi>
                    </signed>
                </closer>
            </div>
        </body>
