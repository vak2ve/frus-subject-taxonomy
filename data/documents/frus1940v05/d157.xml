<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-06-13T14:00:00-05:00" frus:doc-dateTime-min="1940-06-13T14:00:00-05:00" n="157" subtype="historical-document" type="document" xml:id="d157">
                                <note rend="inline" type="source">810.20 Defense/37<hi rend="superscript">6/17</hi>: Telegram</note>
                                <head><hi rend="italic">The Minister in Haiti</hi> (<persName type="from"><hi rend="italic">Mayer</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                            State</gloss></hi></head>
                                <opener>
                                    <dateline rendition="#right"><placeName><hi rend="smallcaps">Port-au-Prince</hi></placeName>, <date calendar="gregorian" when="1940-06-13T14:00:00-05:00">June 13, 1940—2 p.m.</date><lb/>[Received 3:09
                                        p.m.]</dateline>
                                </opener>
                                <p>92. For the Under Secretary and for transmission to Chief of
                                    Naval Operations and Chief of War Plans Division from Colonels
                                    Del Valle and Randolph.</p>
                                <quote rend="blockquote">
                                    <p>“Mission successfully concluded. Proceeding next place
                                        Sunday. Full report follows by air mail pouch. Pending
                                        departure propose discuss airport preliminaries.”</p>
                                </quote>
                                <closer><signed><hi rend="smallcaps">Mayer</hi></signed></closer>
                            </div>
                            </body></text></TEI>