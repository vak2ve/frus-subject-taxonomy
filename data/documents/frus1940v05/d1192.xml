<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-10-12T13:00:00-05:00" frus:doc-dateTime-min="1940-10-12T13:00:00-05:00" n="1192" subtype="historical-document" type="document" xml:id="d1192">
                        <note rend="inline" type="source">811F.504/354: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Panamá</hi> (<persName type="to"><hi rend="italic">Dawson</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1940-10-12T13:00:00-05:00">October 12, 1940—1
                                p.m.</date></dateline>
                        </opener>
                        <p>150. Your 178, October 11, 4 p.m. Interview authorized. Please expedite
                            reply.</p>
                        <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
