    <text>
        <body>
            <div frus:doc-dateTime-max="1865-03-13T23:59:59-05:00" frus:doc-dateTime-min="1865-03-13T00:00:00-05:00" n="354" subtype="historical-document" type="document" xml:id="d354">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Bigelow</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 68.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-03-13">
                            <hi rend="italic">March</hi> 13, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have received your despatch of the 17th
                            of February, No. 35, and I thank you for your careful comment on the
                            Emperor’s speech, which was delivered on the opening of the
                            chambers.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">John Bigelow,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c., &amp;c., Paris.</hi>
                    </p>
                </postscript>
            </div>
        </body>
