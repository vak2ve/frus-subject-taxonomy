    <text>
        <body>
            <div frus:doc-dateTime-max="1865-10-17T23:59:59-05:00"
                frus:doc-dateTime-min="1865-10-17T00:00:00-05:00" n="217"
                subtype="historical-document" type="document" xml:id="d217">
                <head>
                    <persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                        Campbell</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 20.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-10-17">
                            <hi rend="italic">October</hi> 17, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Your despatch No. 26, of September 26, has been
                    received. It is gratifying to hear of the friendship of Sweden and Norway for
                    this government, as expressed by Count Manderstròm at your last interview.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>W. HUNTER, <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">James H. Campbell,</hi> Esq., <hi rend="italic"
                            >&amp;c., &amp;c., Stockholm.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
