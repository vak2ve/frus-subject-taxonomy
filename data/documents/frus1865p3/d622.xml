    <text>
        <body>
            <div frus:doc-dateTime-max="1864-07-14T23:59:59-05:00"
                frus:doc-dateTime-min="1864-07-14T00:00:00-05:00" n="622"
                subtype="historical-document" type="document" xml:id="d622">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Geofroy</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1864-07-14">
                            <hi rend="italic">July</hi> 14, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have the honor to acknowledge the receipt of
                    your communication of the 8th instant, reporting contemplated shipments of
                    powder and arms from California to Mexico, and, in reply, to inform you that the
                    attention of the proper departments will be immediately called to the
                    matter.</p>
                <p>Accept, sir, a renewed assurance of my high consideration.</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>Mr. <hi rend="smallcaps">L. de Geofroy</hi>, <hi rend="italic">&amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
