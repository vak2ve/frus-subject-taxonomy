    <text>
        <body>
            <div frus:doc-dateTime-max="1865-12-09T23:59:59-05:00" frus:doc-dateTime-min="1865-12-09T00:00:00-05:00" n="453" subtype="historical-document" type="document" xml:id="d453">
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <head>
                    <persName type="from">Marquis de Montholon</persName> to
                                    <persName>Mr. Seward.</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of France to the United
                                            States,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-12-09">
                            <hi rend="italic">December</hi> 9, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I hasten to acknowledge the reception
                                of your excellency’s note of the 6th December, in answer to my
                                communication of the 29th ultimo.</p>
                <p>I will not fail to transmit, without delay, this important document
                                to the government of the Emperor.</p>
                <p>Accept the assurances of my high consideration.</p>
                <closer>
                    <signed>MONTHOLON.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">&amp;c., &amp;c., &amp;c., Washington, D.
                                        C.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
