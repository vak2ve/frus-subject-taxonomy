    <text>
        <body>
            <div frus:doc-dateTime-max="1865-03-07T23:59:59-05:00"
                frus:doc-dateTime-min="1865-03-07T00:00:00-05:00" n="350"
                subtype="historical-document" type="document" xml:id="d350">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Bigelow</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 62.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-03-07">
                            <hi rend="italic">March</hi> 7, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Your despatch of the 9th ultimo, No. 25, calling
                    my attention to the official denial, in the Moniteur, of the truth of the report
                    in circulation concerning the cession of certain provinces in Mexico to France,
                    and to the communication of the Emperor to you upon the subject, has been
                    received with satisfaction.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">John Bigelow,</hi> Esq., <hi rend="italic">&amp;c.,
                            &amp;c., &amp;c., Paris.</hi>
                    </p>
                </postscript>
            </div>
        </body>
