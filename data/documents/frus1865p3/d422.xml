    <text>
        <body>
            <div frus:doc-dateTime-max="1865-12-14T23:59:59-05:00" frus:doc-dateTime-min="1865-12-14T00:00:00-05:00" n="422" subtype="historical-document" type="document" xml:id="d422">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Bigelow</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 330.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-12-14">
                            <hi rend="italic">December</hi> 14, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Your despatch of November 24, No. 201,
                            concerning the apprehended expedition of Nubian negroes against Mexico,
                            has been received.</p>
                <p>Instructions upon that subject will be given to you in another
                            despatch.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">John Bigelow,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
