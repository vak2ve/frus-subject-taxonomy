<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-07-04T23:59:59-05:00" frus:doc-dateTime-min="1865-07-04T00:00:00-05:00" n="391" subtype="historical-document" type="document" xml:id="d391">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Bigelow</persName></head>
                        <opener>
                            <seg rendition="#left">No. 216.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1865-07-04"><hi rend="italic">July</hi> 31, 1865.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> Your despatch of the 14th instant, No.
                            145, and its enclosures, have been received. The information which you
                            give of the friendly change in the tone of the French journals is very
                            satisfactory.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>W. HUNTER, <hi rend="italic">Acting
                            Secretary.</hi></signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">John Bigelow</hi>, Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>