    <text>
        <body>
            <div frus:doc-dateTime-max="1865-06-29T23:59:59-05:00"
                frus:doc-dateTime-min="1865-06-29T00:00:00-05:00" n="304"
                subtype="historical-document" type="document" xml:id="d304">
                <head>
                    <persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                        Hale</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 9.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-06-29">
                            <hi rend="italic">June</hi> 29, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have the honor to acknowledge the receipt of
                    your despatches, from No 19 to No. 29, the latter dated May 27, and to thank you
                    for the interesting and valuable information which they communicate.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>W. HUNTER, <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Charles Hale,</hi> Esq., <hi rend="italic">&amp;c.,
                            &amp;c., Alexandria.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
