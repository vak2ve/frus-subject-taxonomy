    <text>
        <body>
            <div frus:doc-dateTime-max="1865-11-04T23:59:59-05:00"
                frus:doc-dateTime-min="1865-11-04T00:00:00-05:00" n="188"
                subtype="historical-document" type="document" xml:id="d188">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Wood</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 115.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-11-04">
                            <hi rend="italic">November</hi> 4, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have to acknowledge the receipt of your
                    despatch No. 205, of October 16th. Your announcement of the liberty which has
                    been granted to the <pb facs="0263" n="181" xml:id="pg_181"/> American Methodist
                    Episcopal Church throughout the kingdom of Denmark is received with great
                    satisfaction.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Bradford R. Wood,</hi>
                        <hi rend="italic">Minister Resident.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
