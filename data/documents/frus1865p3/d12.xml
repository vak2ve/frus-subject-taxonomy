    <text>
        <body>
            <div frus:doc-dateTime-max="1865-04-22T23:59:59-05:00" frus:doc-dateTime-min="1865-04-22T00:00:00-05:00" n="12" subtype="historical-document" type="document" xml:id="d12">
                <head>
                    <persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                                Motley</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 140.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-04-22">
                            <hi rend="italic">April</hi> 22, 1865.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Your despatch of the 2d instant, No. 89,
                            has been received. For the very interesting summary which it presents of
                            the recent debates in the Reichsrath, you will please accept the thanks
                            of the department.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>W. HUNTER, <hi rend="italic">Acting
                            Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">J. Lothrop Motley,</hi>
                        <hi rend="italic">&amp;c., &amp;c., Vienna.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
