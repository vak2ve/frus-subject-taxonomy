<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-12-31T23:59:59-05:00" frus:doc-dateTime-min="1865-12-31T00:00:00-05:00" n="513" subtype="historical-document" type="document" xml:id="d513">
                            <head><persName type="from">Mr. Hunter</persName> to <persName type="to">Mr. Romero</persName></head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName><hi rend="smallcaps">Department of State,
                                            Washington,</hi></placeName>
                                    <date calendar="gregorian" when="1865-12-31"><hi rend="italic">December</hi> 31, 1865.</date></dateline></opener>
                            <p><hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                                receipt of your note of this date, enclosing two documents, dated
                                December 10 and November 18, 1865, issued by M. F. Maury, on the
                                subject of the colonization of Mexico.</p>
                            <p>I avail myself of this opportunity to renew to you, sir, the
                                assurances of my distinguished consideration.</p>
                            <closer>
                                <signed>W. HUNTER, <hi rend="italic">Acting Secretary of
                                    State.</hi></signed></closer>
                            <postscript>
                                <p>Señor <hi rend="smallcaps">Matias Romero, &amp;c., &amp;c.,
                                        &amp;c., Washington, D. C.</hi></p>
                            </postscript>
                        </div>
                        </body></text></TEI>