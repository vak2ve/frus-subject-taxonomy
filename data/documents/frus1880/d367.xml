                subtype="historical-document" type="document" xml:id="d367">
                <head>No. 367.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Evarts</persName> to Mr. <persName
                            type="to">Hoppin</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1880-02-05">
                            <hi rend="italic">February</hi> 5, 1880</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Hoppin</hi>, <hi rend="italic">Chargé, London:</hi>
                </p>
                <p>(Directing him to inquire at what time an answer in respect of the Fortune Bay
                    claims might be expected, and to express the great chagrin of this government
                    that no answer had already been made.)</p>
                <closer>
                    <signed>EVARTS,<lb/>
                        <hi rend="italic">Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
