                subtype="historical-document" type="document" xml:id="d292">
                <head>No. 292.<lb/>
                    <hi rend="italic">Mr. <persName type="from">White</persName> to Mr. <persName
                            type="to">Evarts</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">Received <date calendar="gregorian"
                            type="received-date" when="1880-11-29">November 29,
                        1880</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Evarts</hi>,<lb/>
                    <hi rend="italic">State Department, Washington:</hi>
                </p>
                <p>Gehres’ Alsace case decided in our favor; all penalties and fines remitted both
                    for him and Weill.</p>
                <closer>
                    <signed>WHITE</signed>, <hi rend="italic">Paris.</hi>
                </closer>
            </div>
        </body>
