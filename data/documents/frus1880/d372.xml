                <head>No. 372.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Evarts</persName> to Mr. <persName
                            type="to">Hoppin</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1880-02-26">
                            <hi rend="italic">February</hi> 26, 1880</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Hoppin</hi>, <hi rend="italic">Chargé, London:</hi>
                </p>
                <p>(Stating the increased chagrin with which this government learns, from his No.
                    147, of there being even a possibility of an additional month’s delay, and
                    directing him to urge Her Majesty’s Government to avoid it if possible.)</p>
                <closer>
                    <signed>EVARTS.</signed>
                </closer>
            </div>
        </body>
