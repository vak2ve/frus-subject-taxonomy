                subtype="historical-document" type="document" xml:id="d25">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Wharton</persName> to Count
                            <persName type="to">de Crenneville</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1889-08-14">
                            <hi rend="italic">August</hi> 14, 1889</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 10th instant concerning the case of Mr. Emerich Hasziel, who
                    was not allowed to land at the port of New York on the ground that he was a
                    contract laborer; also to inform you that the matter has been referred to the
                    Secretary of the Treasury.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William F. Wharton.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
