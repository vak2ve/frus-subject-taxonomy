    <text>
        <body>
            <div frus:doc-dateTime-max="1889-11-19T23:59:59-05:00" frus:doc-dateTime-min="1889-11-19T00:00:00-05:00" n="40" subtype="historical-document" type="document" xml:id="d40">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr.
                                <persName type="to">Adams</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1889-11-19">
                            <hi rend="italic">November</hi> 19,
                            1889</date>.</dateline>
                </opener>
                <p>You will maintain diplomatic relations with the provisional government of
                        Brazil.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blaine.</hi>
                    </signed>
                </closer>
            </div>
        </body>
