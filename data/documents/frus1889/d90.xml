                subtype="historical-document" type="document" xml:id="d90">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Chang Yen Hoon</persName> to Mr.
                            <persName type="to">Bayard</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Havana</hi>
                        </placeName>, <date calendar="gregorian" when="1889-02-16">
                            <hi rend="italic">February</hi> 16, 1889</date>.</dateline>
                </opener>
                <p>I respectfully inform you that the marriage of Chinese Emperor will be celebrated
                    twenty-eighth instant. I start for Washington on twentieth, having been
                    courteously entertained by American consul-general.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Chang Yen Hoon.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
