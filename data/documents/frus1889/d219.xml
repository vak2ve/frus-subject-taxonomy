<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1889-02-18T23:59:59-05:00" frus:doc-dateTime-min="1889-02-18T00:00:00-05:00" n="219" subtype="historical-document" type="document" xml:id="d219">
                        <head><hi rend="italic">Mr. <persName type="from">Preston</persName> to Mr.
                                    <persName type="to">Bayard</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">New
                                        York</hi></placeName>, <date calendar="gregorian" when="1889-02-18"><hi rend="italic">February</hi> 18,
                                    1889</date>.</dateline></opener>
                        <p>The <hi rend="italic">Madrid</hi>, now the <hi rend="italic">Conserva</hi>, is still in Gravesend Bay harbor of New York.
                            Request you to order immediately her detention.</p>
                        <closer><signed><hi rend="smallcaps">Stephen Preston.</hi></signed></closer>
                    </div>
                    </body></text></TEI>