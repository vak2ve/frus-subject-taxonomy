    <text>
        <body>
            <div frus:doc-dateTime-max="1889-02-04T23:59:59-05:00"
                frus:doc-dateTime-min="1889-02-04T00:00:00-05:00" n="23"
                subtype="historical-document" type="document" xml:id="d23">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName> to the Chevalier
                            <persName type="to">de Tavera</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1889-02-04">
                            <hi rend="italic">February</hi> 4, 1889</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowlege the receipt of the
                    copy of Count Kalnoky’s telegram in relation to the death of the Crown Prince
                    which accompanied your note of the 2d instant, and to inform you that the same
                    has been placed in the hands of the President.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">T. F. Bayard.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
