    <text>
        <body>
            <div frus:doc-dateTime-max="1889-08-19T23:59:59-05:00" frus:doc-dateTime-min="1889-08-19T00:00:00-05:00" n="325" subtype="historical-document" type="document" xml:id="d325">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Wharton</persName> to Mr.
                                    <persName type="to">Kloss</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1889-08-19">
                            <hi rend="italic">August</hi> 19,
                                1889</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your note of the 13th instant, referring to the letter of the
                            Treasury Department concerning certain Swiss immigrants who were not
                            allowed to land at New York, and expressing your thanks to the Secretary
                            of the Treasury for his courteous action in the premises, and to inform
                            you that the Department has communicated the contents of your note to
                            the Secretary of the Treasury.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William F.
                            Wharton.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
