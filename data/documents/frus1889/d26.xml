                subtype="historical-document" type="document" xml:id="d26">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Rives</persName> to Mr. <persName
                            type="to">Tree</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1888-10-20">
                            <hi rend="italic">October</hi> 20, 1888</date>.</dateline>
                </opener>
                <p>Upon application authorities State of New York, you are instructed to request
                    detention Adolph Sambolino, now under arrest at Antwerp, pending arrival
                    extradition papers charging forgery.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Rives</hi>.</signed>
                </closer>
            </div>
        </body>
