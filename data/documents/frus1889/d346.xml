<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1889-06-19T23:59:59-05:00" frus:doc-dateTime-min="1889-06-19T00:00:00-05:00" n="346" subtype="historical-document" type="document" xml:id="d346">
                    <head><hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr.
                                <persName type="to">Straus</persName>.</hi></head>
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department
                                    of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1889-06-19"><hi rend="italic">June</hi> 19,
                            1889</date>.</dateline></opener>
                    <p>Express grateful appreciation President and Government United States for
                        Sultan’s generous relief flood sufferers.</p>
                    <closer><signed><hi rend="smallcaps">Blaine.</hi></signed></closer>
                </div>
                </body></text></TEI>