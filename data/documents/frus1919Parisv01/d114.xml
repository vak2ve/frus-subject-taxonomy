    <text>
        <body>
            <div frus:doc-dateTime-max="1918-11-27T07:00:00-05:00"
                frus:doc-dateTime-min="1918-11-27T07:00:00-05:00" n="114"
                subtype="historical-document" type="document" xml:id="d114">
                <note rend="inline" type="source">763.72119/2802: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName corresp="#p_PTN1"
                        type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-27T13:00:00+01:00"
                            >November 27, 1918—1 p.m.</date>
                        <lb/> [Received 8:33 p.m.]</dateline>
                </opener>
                <p>2415. Department 1864.<note n="23" xml:id="d114fn23">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_141">p. 141</ref>.</note>
                    Please say to the President for me: “For heavens sake don’t come to Europe
                    without visiting Italy before returning home.”</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PTN1">
                            <hi rend="smallcaps">Nelson Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
