<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-11-07T23:59:59-05:00" frus:doc-dateTime-min="1918-11-07T00:00:00-05:00" n="136" subtype="historical-document" type="document" xml:id="d136">
                        <note rend="inline" type="source">
                            <persName corresp="#p_WW1">Woodrow Wilson</persName> Papers</note>
                        <head>
                            <hi rend="italic">President <persName corresp="#p_WW1" type="from">Wilson</persName> to the Special Representative</hi> (<persName corresp="#p_HCEM1" type="to"><hi rend="italic">House</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">[<placeName>
                                    <hi rend="smallcaps">Washington</hi>
                                </placeName>, <hi rend="italic">circa</hi>
                                <date calendar="gregorian" when="1918-11-07">November 7,
                                1918</date>.]</dateline>
                        </opener>
                        <p>10. Referring to your number 7.<note n="1" xml:id="d136fn1">
                                <hi rend="italic">Supra.</hi>
                            </note> I concur in your views with regard to representation at the
                            Peace Conference.</p>
                        <closer>
                            <signed>[<persName corresp="#p_WW1"><hi rend="smallcaps">Woodrow
                                        Wilson</hi></persName>]</signed>
                        </closer>
                    </div>
                    </body></text></TEI>