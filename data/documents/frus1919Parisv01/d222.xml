<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-12-23T23:59:59-05:00" frus:doc-dateTime-min="1918-12-23T00:00:00-05:00" n="222" subtype="historical-document" type="document" xml:id="d222">
                        <note rend="inline" type="source">Paris Peace Conf. 184.82/2:
                            Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Commission to Negotiate
                                    Peace</gloss> to the <gloss type="to">Acting Secretary of
                                    State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">[<placeName>
                                    <hi rend="smallcaps">Paris</hi>
                                </placeName>,] <date calendar="gregorian" when="1918-12-23">December
                                    23, 1918</date>.</dateline>
                        </opener>
                        <p>76. [From <persName corresp="#p_LR1">Lansing</persName>.] Your 67
                            December 20th 2:00 p.m. The matter dealt with by the Associated Press
                            under date of December 18th mentioned in your telegram has not been
                            discussed here. <persName corresp="#p_LR1">Lansing</persName>.</p>
                        <closer>
                            <hi rend="smallcaps">Am</hi> [<hi rend="smallcaps">erican</hi>] <hi rend="smallcaps">Mission</hi>
                        </closer>
                    </div>
