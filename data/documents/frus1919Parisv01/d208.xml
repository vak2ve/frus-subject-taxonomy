                subtype="historical-document" type="document" xml:id="d208">
                <note rend="inline" type="source">763.72119/3315f: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">Commission to Negotiate Peace</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-12-19T17:00:00-05:00"
                            >December 19, 1918—5 p.m.</date>
                    </dateline>
                </opener>
                <p>54. For <persName corresp="#p_AG1">Auchincloss</persName> from <persName
                        corresp="#p_PFL1">Polk</persName>. <persName corresp="#p_DJF1"
                        >Dulles</persName>
                    <note n="16" xml:id="d208fn16">
                        <persName corresp="#p_DJF1">John Foster Dulles</persName>.</note> sails 21st
                    via England. Representing the Central Bureau of Planning and Statistics, which
                    in turn is allied with the economic organizations of the war boards and which in
                    accordance with memorandum approved by President is to be official agency for
                    supplying economic information to Peace <pb facs="0278" n="208" xml:id="pg_208"
                    /> Commissioners. Convinced it will be useful and hope you will support it.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
