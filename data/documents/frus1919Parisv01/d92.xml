<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-11-13T23:59:59-05:00" frus:doc-dateTime-min="1918-11-13T00:00:00-05:00" n="92" subtype="historical-document" type="document" xml:id="d92">
                        <note rend="inline" type="source">
                            <persName corresp="#p_WW1">Woodrow Wilson</persName> Papers:
                            Telegram</note>
                        <head>
                            <hi rend="italic">President <persName corresp="#p_WW1" type="from">Wilson</persName> to the Special Representative</hi> (<persName corresp="#p_HCEM1" type="to"><hi rend="italic">House</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">[<placeName>
                                    <hi rend="smallcaps">Washington</hi>
                                </placeName>, <date calendar="gregorian" when="1918-11-13">November
                                    13, 1918</date>.]</dateline>
                        </opener>
                        <p>I expect to sail December 3rd.</p>
                        <closer>
                            <signed>[<persName corresp="#p_WW1"><hi rend="smallcaps">Woodrow
                                        Wilson</hi></persName>]</signed>
                        </closer>
                    </div>
                    </body></text></TEI>