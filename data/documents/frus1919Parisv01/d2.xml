<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-11-11T23:59:59-05:00" frus:doc-dateTime-min="1918-11-11T00:00:00-05:00" n="2" subtype="historical-document" type="document" xml:id="d2">
                        <note rend="inline" type="source">
                            <persName corresp="#p_HCEM1">Edward M. House</persName> Papers:
                            Telegram</note>
                        <head>
                            <hi rend="italic">The Special Representative</hi> (<persName corresp="#p_HCEM1" type="from"><hi rend="italic">House</hi></persName>) <hi rend="italic">to President <persName corresp="#p_WW1" type="to">Wilson</persName>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Paris</hi>
                                </placeName>, <date calendar="gregorian" when="1918-11-11">November
                                    11, 1918</date>.</dateline>
                        </opener>
                        <p>13. Autocracy is dead. <persName corresp="#p_LB1">Long</persName> live
                            democracy and its immortal leader. In this great hour my heart goes out
                            to you in pride, admiration and love.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_HCEM1">
                                    <hi rend="smallcaps">Edward House</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>