                subtype="historical-document" type="document" xml:id="d141">
                <note rend="inline" type="source">
                    <persName corresp="#p_WW1">Woodrow Wilson</persName> Papers</note>
                <head>
                    <hi rend="italic">Associate Justice <persName corresp="#p_DC1" type="from"
                            >Day</persName>, of the Supreme Court, to President <persName
                            corresp="#p_WW1" type="to">Wilson</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-14">November 14,
                            1918</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. President</hi>: I am deeply appreciative of the
                    honor which you have conferred upon me in the offer of a place upon the Peace
                    Commission.</p>
                <p>I wish it were practicable for me to accept this opportunity for service. I am,
                    however reluctantly, constrained to forego this privilege.</p>
                <p>Wishing you continued success in the great work before you, I am, with high
                    regard,</p>
                <p>Sincerely yours,</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">William R. Day</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
