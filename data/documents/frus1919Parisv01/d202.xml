<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-11-29T23:59:59-05:00" frus:doc-dateTime-min="1918-11-29T00:00:00-05:00" n="202" subtype="historical-document" type="document" xml:id="d202">
                        <note rend="inline" type="source">763.72119 P 43/1046</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                President <persName corresp="#p_WW1" type="to">Wilson</persName>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi>
                                </placeName>, <date calendar="gregorian" when="1918-11-29">November
                                    29, 1918</date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. President</hi>: You are entirely
                            correct in assuming that my letter of the twenty-sixth of November
                            relates to the expenses of the arrangements for gathering political
                            intelligence, which we have been planning through <persName corresp="#p_HCEM1">Colonel House</persName> in response to his
                            telegrams.</p>
                        <p>Sincerely yours,</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Robert Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>