    <text>
        <body>
            <div frus:doc-dateTime-max="1918-11-27T23:59:59-05:00"
                frus:doc-dateTime-min="1918-11-27T00:00:00-05:00" n="162"
                subtype="historical-document" type="document" xml:id="d162">
                <note rend="inline" type="source">
                    <persName corresp="#p_WW1">Woodrow Wilson</persName> Papers</note>
                <head>
                    <hi rend="italic">President <persName corresp="#p_WW1" type="from"
                            >Wilson</persName> to the Secretary of Labor</hi> (<persName
                        corresp="#p_WW1" type="to">
                        <hi rend="italic">Wilson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1918-11-27">27 November,
                            1918</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: Thank you for sending me
                        <persName>Walsh</persName>’s letter about Mr. <persName corresp="#p_GS1"
                        >Gompers</persName>. Mr. <persName>Gompers</persName> needs no commendation,
                    so far as I am concerned, but I am entirely of your opinion about the
                    representation, or the apparent representation, of special classes or
                    interests.</p>
                <p>Cordially and sincerely yours,</p>
                <closer>
                    <signed>[<persName corresp="#p_WW1">
                            <hi rend="smallcaps">Woodrow Wilson</hi>
                        </persName>]</signed>
                </closer>
            </div>
        </body>
    </text>
