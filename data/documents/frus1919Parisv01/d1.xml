                subtype="historical-document" type="document" xml:id="d1">
                <head>
                    <hi rend="italic">Announcement by President <persName corresp="#p_WW1"
                            >Wilson</persName> of the Signing of the Armistice, November 11,
                        1918</hi>
                    <note n="2" type="source" xml:id="d1fn2">Reprinted from <hi rend="italic"
                            >Official U. S. Bulletin</hi>, vol. 2, No. 460, Nov. 11, 1918.</note>
                </head>
                <dateline>
                    <date ana="#date_undated-inferred-from-document-head" calendar="gregorian"
                        when="1918-11-11">November 11, 1918</date>
                </dateline>
                <p>
                    <hi rend="smallcaps">My Fellow Countrymen</hi>: The armistice was signed this
                    morning. Everything for which America fought has been accomplished. It will now
                    be our fortunate duty to assist by example, by sober, friendly counsel, and by
                    material aid in the establishment of just democracy throughout the world.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WW1">
                            <hi rend="smallcaps">Woodrow Wilson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
