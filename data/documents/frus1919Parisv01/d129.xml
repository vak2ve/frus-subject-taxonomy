    <text>
        <body>
            <div frus:doc-dateTime-max="1918-12-30T14:40:00-05:00"
                frus:doc-dateTime-min="1918-12-30T14:40:00-05:00" n="129"
                subtype="historical-document" type="document" xml:id="d129">
                <note rend="inline" type="source">Paris Peace Conf. 811.001/72c: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Commission to Negotiate Peace</gloss>
                        to the Ambassador in Italy</hi> (<persName corresp="#p_PTN1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1918-12-30T19:40:00+00:00"
                            >December 30, 1918—7:40 p.m.</date>
                    </dateline>
                </opener>
                <p>8. [From <persName corresp="#p_HCEM1">House</persName>.] Your 41.<note n="25"
                        xml:id="d129fn25">Not printed.</note> Following is list of persons who will
                    accompany President to Rome:—President <persName corresp="#p_WW1"
                        >Wilson</persName>, Mrs. <persName corresp="#p_WHR1">Wilson</persName>, Miss
                        <persName>Benham</persName>, <persName>Admiral Grayson</persName>, <persName
                        corresp="#p_HGWW1">General Harts</persName>, Messrs. <persName
                        corresp="#p_CG1">George Creel</persName>, <persName>Arthur E.
                        Frazier</persName>, <persName corresp="#p_HHC1">Hoover</persName>,
                        <persName>Close</persName>, <persName>Swem</persName>, <persName>Captains
                        Garfield</persName>, <persName>Kimball</persName>,
                        <persName>Knightingale</persName>, <persName>Lieutenants
                    Jennings</persName>, <persName>Corcoran</persName>, five journalists, <persName
                        corresp="#p_DJF1">Foster</persName>, <persName>Rodgers</persName>,
                        <persName>Nevin</persName>, <persName>Probert</persName>,
                        <persName>Bender</persName>; four Secret Service men, eight War College
                    photographers, two servants of President. This list is subject to correction.
                        <persName corresp="#p_HCEM1">Edward House</persName>.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Am</hi>[<hi rend="smallcaps">erican</hi>] <hi
                            rend="smallcaps">Mission</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
