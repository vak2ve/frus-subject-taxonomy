                subtype="historical-document" type="document" xml:id="d281">
                <note rend="inline" type="source">763.72119/2725: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_SWG1"
                        type="from">
                        <hi rend="italic">Sharp</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-21T20:00:00+00:00"
                            >November 21, 1918—8 p.m.</date>
                        <lb/> [Received November 21—6:29 p.m.]</dateline>
                </opener>
                <p>5957. Montenegrin Government has addressed a request through me to the American
                    Government to be represented at the Peace Conference. Copy of note being
                    forwarded by today’s pouch.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SWG1">
                            <hi rend="smallcaps">Sharp</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
