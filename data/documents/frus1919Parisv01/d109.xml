<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-11-25T23:59:59-05:00" frus:doc-dateTime-min="1918-11-25T00:00:00-05:00" n="109" subtype="historical-document" type="document" xml:id="d109">
                        <note rend="inline" type="source">
                            <persName corresp="#p_HCEM1">Edward M. House</persName> Papers:
                            Telegram</note>
                        <head>
                            <hi rend="italic">President <persName corresp="#p_WW1" type="from">Wilson</persName> to the Special Representative</hi> (<persName corresp="#p_HCEM1" type="to"><hi rend="italic">House</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi>
                                </placeName>, <date calendar="gregorian" when="1918-11-25">November
                                    25, 1918</date>.</dateline>
                        </opener>
                        <p>17. Referring to my despatch 16 I shall sail directly for France as you
                            advised.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_WW1">
                                    <hi rend="smallcaps">Wilson</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>