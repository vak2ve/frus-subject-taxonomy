                subtype="historical-document" type="document" xml:id="d745">
                <note rend="inline" type="source">893.51/6369: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at Shanghai</hi> (<persName type="to">
                        <hi rend="italic">Gauss</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1937-05-04T12:00:00-04:00"
                            >May 4, 1937—noon</date>.</dateline>
                </opener>
                <p>107. Following from Eximbank<note n="64" xml:id="d745fn64">Export-Import Bank of
                        Washington.</note> for Warren Pierson: <quote rend="blockquote">
                        <p>Executive Committee approved China credit on basis your recommendations
                            subject to your obtaining clearance with Ambassador Johnson. Resolution
                            will not be released pending receipt from you of Ambassador’s views.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
