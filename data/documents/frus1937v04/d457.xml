                subtype="historical-document" type="document" xml:id="d457">
                <note rend="inline" type="source">123 Allison, John M./149: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1937-11-17T11:00:00+08:00"
                            >November 17, 1937—11 a.m.</date>
                        <lb/>[Received November 17—7:30 a.m.]</dateline>
                </opener>
                <p>926. Following from Allison, Tsinan.</p>
                <quote rend="blockquote">
                    <p>“November 16, 5 p.m. Your November 16, 11 a.m., quoting Department’s
                            354.<note n="7" xml:id="d457fn7">Not printed.</note> I intend to leave
                        for Tsingtao tomorrow night. At a meeting of local Americans this afternoon
                        I informed them of latest developments in situation and urged them to
                        evacuate immediately. Most of them expressed determination to remain.
                        Letters being sent Americans at interior points.”</p>
                </quote>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
