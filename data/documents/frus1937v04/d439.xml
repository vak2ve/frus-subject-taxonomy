                subtype="historical-document" type="document" xml:id="d439">
                <note rend="inline" type="source">793.94/10819: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Japan</hi> (<persName type="to">
                        <hi rend="italic">Grew</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1937-10-27T11:00:00-05:00"
                            >October 27, 1937—11 a.m.</date>
                    </dateline>
                </opener>
                <p>269. Shanghai’s 887, October 24, 7 p.m. and Nanking’s 840, October 20, 3 p.m.
                    Department desires that you consult with your interested <pb facs="0379" n="371"
                        xml:id="pg_371"/> colleagues and in your discretion make an approach to the
                    Foreign Office on the basis of the first paragraph of Shanghai’s telegram under
                    reference.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
