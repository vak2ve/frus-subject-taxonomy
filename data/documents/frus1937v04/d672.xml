<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1937-12-24T22:00:00-05:00" frus:doc-dateTime-min="1937-12-24T22:00:00-05:00" n="672" subtype="historical-document" type="document" xml:id="d672">
                        <note rend="inline" type="source">394.115 Panay/197: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Japan</hi> (<persName type="from"><hi rend="italic">Grew</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Tokyo</hi></placeName>, <date calendar="gregorian" when="1937-12-25T12:00:00+09:00">December 25,
                                1937—noon</date>.<lb/>[Received December 25—6:30 a.m.]</dateline>
                        </opener>
                        <p>680. My 677, December 24, 6 p.m.<note n="1" xml:id="d672fn1">Not
                                printed.</note></p>
                        <p>1. <hi rend="italic">Panay</hi>. Complete report of findings of Naval
                            Court of Inquiry received and communicated to the Minister for Foreign
                            Affairs today.</p>
                        <p>Repeated to Shanghai and Commander in Chief.</p>
                        <closer><signed><hi rend="smallcaps">Grew</hi></signed></closer>
                    </div>
                    </body></text></TEI>