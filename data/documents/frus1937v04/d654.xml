                subtype="historical-document" type="document" xml:id="d654">
                <note rend="inline" type="source">394.115 Panay/142: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1937-12-18T15:00:00+09:00"
                            >December 18, 1937—3 p.m.</date>
                        <lb/>[Received December 18—2:57 a.m.]</dateline>
                </opener>
                <p>655. Our 652, December 17, 7 p.m. The Military Attaché was informed today at the
                    War Office that the Chief of the American Section of the General Staff has been
                    sent to Shanghai to investigate the report that Japanese Army launches machine
                    gunned the <hi rend="italic">Panay</hi>.</p>
                <p>Repeated to Shanghai.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
