                subtype="historical-document" type="document" xml:id="d153">
                <note rend="inline" type="source">793.94 Conference/158: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1937-11-02T17:00:00+09:00"
                            >November 2, 1937—5 p.m.</date>
                        <lb/>[Received November 2—6:30 a.m.]</dateline>
                </opener>
                <p>511. All the evening papers published with featured headlines reports from London
                    of speech by Eden in the House of Commons ascribing to American initiative the
                    convocation of the Brussels Conference and stating that any action vis-à-vis the
                    Far Eastern dispute essentially depends on cooperation with the United
                    States.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
