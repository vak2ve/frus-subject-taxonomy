                subtype="historical-document" type="document" xml:id="d248">
                <note rend="inline" type="source">792.94/68½</note>
                <head>
                    <hi rend="italic">The <gloss type="from">British Embassy</gloss> to the <gloss
                            type="to">Department of State</gloss>
                    </hi>
                </head>
                <p rend="center">
                    <hi rend="smallcaps">Extract of Telegram Received From London, Dated
                        November</hi> 4th, 1940</p>
                <p>“According to His Majesty’s Minister at Bangkok present indications are that
                    unless reinforced by United States or ourselves with war material Thai
                    Government would not resist with arms a Japanese violation of Thai
                    territory.[”]</p>
                <closer>
                    <dateline rendition="#left">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-11-11">November 11,
                            1940</date>.</dateline>
                </closer>
            </div>
        </body>
