    <text>
        <body>
            <div frus:doc-dateTime-max="1940-04-24T12:00:00-05:00"
                frus:doc-dateTime-min="1940-04-24T12:00:00-05:00" n="538"
                subtype="historical-document" type="document" xml:id="d538">
                <note rend="inline" type="source">611.939/300: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Swatow</hi> (<persName type="to">
                        <hi rend="italic">Yearns</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-04-24T12:00:00-05:00"
                            >April 24, 1940—noon</date>.</dateline>
                </opener>
                <p>7. Your 10, April 19, noon.<note n="77" xml:id="d538fn77">Not printed.</note>
                </p>
                <list>
                    <label>1.</label>
                    <item>Please report circumstances or details of any arrangement with shippers
                        under which Mitsui Bussan Kaisha was in position to assess an 11 percent ad
                        valorem “duty” on a shipment of American-owned cargo to Swatow.</item>
                    <label>2.</label>
                    <item>The Embassy at Peiping is requested to send to Tokyo a copy of this
                        telegram and of Swatow’s telegram under reference.</item>
                </list>
                <p>Sent to Swatow. Repeated to Peiping.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
