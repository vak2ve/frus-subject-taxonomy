                subtype="historical-document" type="document" xml:id="d1079">
                <note rend="inline" type="source">320/12–1950: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">United States Mission</gloss> at the United
                        Nations</hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1950-12-20T19:00:00-05:00"
                            >December 20, 1950—7 p. m.</date>
                    </dateline>
                </opener>
                <p>603. Re <gloss target="#t_Delga1">Delga</gloss> 453.<note n="1" xml:id="d1079fn1"
                        >Received at 8:16 p. m. on December 19, <ref target="#pg_1578">p.
                        1578</ref>.</note>
                    <gloss target="#t_Dept1">Dept</gloss> believes US shld agree with procedure and
                    timetable for Comite I advocated by Pearson. In indicating our willingness to go
                    along with proposed procedure to Entezam group, you shld point out that if Chi
                    Commies attack UN forces across 38th parallel in force we wld assume that
                    procedure wld be modified.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Webb</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
