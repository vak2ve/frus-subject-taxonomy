<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1950-10-06T04:00:00-05:00" frus:doc-dateTime-min="1950-10-06T04:00:00-05:00" n="623" subtype="historical-document" type="document" xml:id="d623">
                    <note rend="inline" type="source">795A.5/10–650: Telegram</note>
                    <head>
                        <hi rend="italic">The Chargé in Norway</hi> (<persName type="from"><hi rend="italic">Snow</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <seg rendition="#left">
                            <hi rend="smallcaps">secret</hi>
                            <lb/>
                            <hi rend="smallcaps">priority</hi>
                        </seg>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Oslo</hi></placeName>, <date calendar="gregorian" when="1950-10-06T10:00:00+01:00">October 6,
                                1950—10 a. m.</date>
                            <lb/> [Received October 6—9:53 a. m.]</dateline>
                    </opener>
                    <p>353. <gloss target="#t_Depcirtel1">Depcirtel</gloss> 9, October 5, 11 a.m.
                        Norwegian Foreign Office without information from representative in Peiping
                        re Chinese plans defense North Korea.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Snow</hi>
                        </signed>
                    </closer>
