                subtype="historical-document" type="document" xml:id="d85">
                <note rend="inline" type="source">724.34119/1284: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Argentina</hi> (<persName type="from">
                        <hi rend="italic">Weddell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1938-04-07T11:00:00-04:00"
                            >April 7, 1938—11 a.m.</date>
                        <lb/>[Received April 7—10:50 a.m.]</dateline>
                </opener>
                <p>85. Braden left for La Paz yesterday by train accompanied by Uruguayan and
                    Brazilian representatives. They expect to arrive there on Saturday.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Weddell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
