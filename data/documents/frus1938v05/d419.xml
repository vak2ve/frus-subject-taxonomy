                subtype="historical-document" type="document" xml:id="d419">
                <note rend="inline" type="source">832.00 Revolutions/599a: Telegram</note>
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to
                        President <persName type="to">Vargas</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1938-05-12">May 12,
                            1938</date>.</dateline>
                </opener>
                <p>Please accept my sincere congratulations upon your fortunate escape from the
                    attempt made upon your life. I send you my most cordial greetings and the
                    assurances of my high personal regard.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Franklin D. Roosevelt</hi>
                    </signed>
                </closer>
            </div>
        </body>
