                subtype="historical-document" type="document" xml:id="d180">
                <note rend="inline" type="source">738.39/281: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Haiti</hi> (<persName type="from">
                        <hi rend="italic">Mayer</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port-au-Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1938-01-22T14:00:00-05:00"
                            >January 22, 1938—2 p.m.</date>
                        <lb/>[Received 3:10 p.m.]</dateline>
                </opener>
                <p>24. My telegram No. 23, January 22, 1 p.m. Am informed full accord reached here.
                    Repeated to Santo Domingo.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Mayer</hi>
                    </signed>
                </closer>
            </div>
        </body>
