                subtype="historical-document" type="document" xml:id="d158">
                <note rend="inline" type="source">724.34119/1604: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Argentina</hi> (<persName type="from">
                        <hi rend="italic">Weddell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1938-09-02T16:00:00-04:00"
                            >September 2, 1938—4 p.m.</date>
                        <lb/>[Received September 2—3:15 p.m.]</dateline>
                </opener>
                <p>246. Arbitral college of the Chaco formally constituted this morning the
                    Argentine Minister for Foreign Affairs chairman.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Weddell</hi>
                    </signed>
                </closer>
            </div>
        </body>
