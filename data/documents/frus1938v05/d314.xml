                <note rend="inline" type="source">824.6363 St2/239: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Bolivia</hi> (<persName type="to">
                        <hi rend="italic">Caldwell</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1938-03-21T11:00:00-05:00"
                            >March 21, 1938—11 a.m.</date>
                    </dateline>
                </opener>
                <p>3. Your 8, March 20, noon. You should not take the step suggested by the
                    Company.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
