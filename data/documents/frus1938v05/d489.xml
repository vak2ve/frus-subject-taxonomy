                subtype="historical-document" type="document" xml:id="d489">
                <note rend="inline" type="source">839.51 Public Works Debt/134: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Cuba</hi> (<persName type="from">
                        <hi rend="italic">Beaulac</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1938-10-12T14:00:00-05:00"
                            >October 12, 1938—2 p.m.</date>
                        <lb/>[Received 2:35 p.m.]</dateline>
                </opener>
                <p>114. My 113, of October 11, 1 p.m. With reference to our recent telephone
                    conversation it would be helpful to me if I could be informed regarding your
                    conversations with the Cuban Ambassador.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Beaulac</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
