    <text>
        <body>
            <div frus:doc-dateTime-max="1872-06-21T23:59:59-05:00" frus:doc-dateTime-min="1872-06-21T00:00:00-05:00" n="158" subtype="historical-document" type="document" xml:id="d158">
                <head>No. 158.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Fish</persName> to Mr. <persName type="to">Holt</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1872-06-21">
                            <hi rend="italic">June</hi> 21,
                                        1872</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Geo. H. Holt</hi>, <hi rend="italic">Consul, Gaspe, Canada:</hi>
                </p>
                <p>Report full particulars of schooner James Bliss.</p>
                <closer>
                    <signed>HAMILTON FISH.</signed>
                </closer>
            </div>
        </body>
