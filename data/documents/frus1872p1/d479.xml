    <text>
        <body>
            <div frus:doc-dateTime-max="1872-02-15T23:59:59-05:00" frus:doc-dateTime-min="1872-02-15T00:00:00-05:00" n="479" subtype="historical-document" type="document" xml:id="d479">
                <head>No. 480.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Peixotto</persName> to Mr. <persName type="to">Hunter</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Extract.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Consulate of the United States of America</hi>,<lb/>
                            <hi rend="italic">Bucharest</hi>
                        </placeName>, <date calendar="gregorian" when="1872-02-15">
                            <hi rend="italic">February</hi> 15, 1872</date>. (Received March
                                    15.)</dateline>
                    <seg rendition="#left">No. 25.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>:</p>
                <p>* * * * *</p>
                <p>The Government has sent a special commission to investigate the
                                affairs at Ismail.</p>
                <p>I am, &amp;c., &amp;c.,</p>
                <closer>
                    <signed>BENJ. F. PEIXOTTO,<lb/>
                        <hi rend="italic">United States
                                        Consul.</hi>
                    </signed>
                </closer>
            </div>
        </body>
