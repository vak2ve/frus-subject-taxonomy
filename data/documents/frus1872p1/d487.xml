<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1872-06-13T23:59:59-05:00" frus:doc-dateTime-min="1872-06-13T00:00:00-05:00" n="487" subtype="historical-document" type="document" xml:id="d487">
                            <head>No. 488.<lb/><hi rend="italic">Mr. <persName type="from">Hunter</persName> to Mr. <persName type="to">Peixotto</persName>.</hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1872-06-13"><hi rend="italic">June</hi> 13,
                                        1872</date>.</dateline>
                                <seg rendition="#left">No. 32.]</seg>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: Your dispatch No. 31, of the 5th of
                                May last, relative to the persecution of the Hebrews in Roumania,
                                has been received.</p>
                            <pb facs="0788" n="692" xml:id="pg_692"/>
                            <p>The representations which von have made to the Roumanian government
                                upon the subject are approved.</p>
                            <p>I am, &amp;c.,</p>
                            <closer>
                                <signed>W. HUNTER.</signed>
                            </closer>
                        </div>
                        </body></text></TEI>