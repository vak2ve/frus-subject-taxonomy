    <text>
        <body>
            <div frus:doc-dateTime-max="1872-08-09T23:59:59-05:00" frus:doc-dateTime-min="1872-08-09T00:00:00-05:00" n="222" subtype="historical-document" type="document" xml:id="d222">
                <head>No. 222.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Hunter</persName> to Mr. <persName type="to">Bassett</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Extract.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                        of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1872-08-09">
                            <hi rend="italic">August</hi> 9,
                                1872</date>.</dateline>
                    <seg rendition="#left">No. 112.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Your dispatches numbered 138, 139, 140,
                            and 141 have been received.</p>
                <p>Your action in regard to the ill-usage of Mr. Eldredge, which forms the
                            subject of your dispatch No. 139, is approved.</p>
                <p>* * * * * * *</p>
                <p>I am, &amp;c.,</p>
                <closer>
                    <signed>W. HUNTER,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
