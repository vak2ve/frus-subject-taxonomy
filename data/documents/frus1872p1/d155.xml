    <text>
        <body>
            <div frus:doc-dateTime-max="1872-06-20T23:59:59-05:00" frus:doc-dateTime-min="1872-06-20T00:00:00-05:00" n="155" subtype="historical-document" type="document" xml:id="d155">
                <head>No. 155.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Holt</persName> to Mr. <persName type="to">Fish</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Gaspé</hi>
                        </placeName>, <date calendar="gregorian" when="1872-06-20">
                            <hi rend="italic">June</hi> 20,
                                        1872</date>. (Received June 20.)</dateline>
                </opener>
                <p rend="flushleft">Hon. <hi rend="smallcaps">H. Fish</hi>, <hi rend="italic">Secretary of State, Washington, D. C.:</hi>
                </p>
                <p>Schooner James Bliss, of Gloucester, seized for alleged violation of
                                fishery laws.* * * Remonstrated energetically against position of
                                flags, Dominion over American.</p>
                <closer>
                    <signed>GEO. H. HOLT.</signed>
                </closer>
            </div>
        </body>
