    <text>
        <body>
            <div frus:doc-dateTime-max="1887-04-11T23:59:59-05:00" frus:doc-dateTime-min="1887-04-11T00:00:00-05:00" n="335" subtype="historical-document" type="document" xml:id="d335">
                <head>No. 335.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName> to Sir <persName type="to">L. S. Sackville
                                    West</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1887-04-11">
                            <hi rend="italic">April</hi> 11,
                                1887</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your note of the 4th instant, accompanied by a copy of an
                            approved report of a committee of a privy council of Canada in relation
                            to the cases of the American fishing vessels <hi rend="italic">Pearl
                                Nelson</hi> and <hi rend="italic">Everett Steele</hi> which were
                            brought to your attention by my notes of October 19th and 20th last.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">T. F. Bayard.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
