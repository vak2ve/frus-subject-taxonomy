    <text>
        <body>
            <div frus:doc-dateTime-max="1886-05-16T23:59:59-05:00" frus:doc-dateTime-min="1886-05-16T00:00:00-05:00" n="469" subtype="historical-document" type="document" xml:id="d469">
                <head>No. 469.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Manning</persName> to Mr. <persName type="to">Bayard</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1886-05-16">
                            <hi rend="italic">May</hi> 16, 1886</date>.
                            (Received May 16.)</dateline>
                </opener>
                <p>Your request for remission of death penalty to Nogales offenders has been
                        presented to Mexican Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Manning.</hi>
                    </signed>
                </closer>
            </div>
        </body>
