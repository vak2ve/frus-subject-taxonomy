                <head>No. 409.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Hubbard</persName> to Mr. <persName type="to">Bayard</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Extract.]</seg>
                </opener>
                <opener>
