    <text>
        <body>
            <div frus:doc-dateTime-max="1887-03-21T23:59:59-05:00" frus:doc-dateTime-min="1887-03-21T00:00:00-05:00" n="441" subtype="historical-document" type="document" xml:id="d441">
                <head>No. 441.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Manning</persName> to Mr. <persName type="to">Bayard</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1887-03-21">
                            <hi rend="italic">March</hi> 21,
                            1887</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Bayard</hi>, <hi rend="italic">Secretary of State, Washington:</hi>
                </p>
                <p>Your dispatch reached me at Puebla; correction made to-day.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Manning.</hi>
                    </signed>
                </closer>
            </div>
        </body>
