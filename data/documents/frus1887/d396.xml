    <text>
        <body>
            <div frus:doc-dateTime-max="1887-08-20T23:59:59-05:00" frus:doc-dateTime-min="1887-08-20T00:00:00-05:00" n="396" subtype="historical-document" type="document" xml:id="d396">
                <head>No. 396.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName>
                            to Mr. <persName type="to">Stallo</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1887-08-20">
                            <hi rend="italic">August</hi> 20,
                            1887</date>.</dateline>
                    <seg rendition="#left">No. 74.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I am glad to learn by your No. 148 that the
                        request of the Department for the free entry of the consular property to
                        which it refers will doubtless receive favorable consideration at a near
                        date.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">T. F. Bayard.</hi>
                    </signed>
                </closer>
            </div>
        </body>
