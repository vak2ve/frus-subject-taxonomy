                subtype="historical-document" type="document" xml:id="d331">
                <head>No. 331.<lb/>
                    <hi rend="italic">Sir <persName type="from">L. S. Sackville West</persName> to
                        Mr. <persName type="to">Bayard</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1887-01-28">
                            <hi rend="italic">January</hi> 28, 1887</date>. (Received January
                        29.)</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of yesterday’s date, and to inform you that I have submitted the case
                    of the American schooner <hi rend="italic">Sarah H. Prior</hi> to Her Majesty’s
                    Government for investigation, as requested by you.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">L. S. Sackville West.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
