<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1887-07-06T23:59:59-05:00" frus:doc-dateTime-min="1887-07-06T00:00:00-05:00" n="622" subtype="historical-document" type="document" xml:id="d622">
                    <head>No. 622.<lb/><hi rend="italic">Mr. <persName type="from">Bayard</persName>
                            to Mr. <persName type="to">Curry</persName>.</hi></head>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department
                                    of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1887-07-06"><hi rend="italic">July</hi> 6,
                            1887</date>.</dateline>
                        <seg rendition="#left">No. 210.]</seg></opener>
                    <p><hi rend="smallcaps">Sir</hi>: I have received your No. 222, of the 22d
                        ultimo, reporting correspondence touching the extension of the commercial
                        arrangement of October 27, 1886, between the United States and Spain, to
                        December 31, 1887.</p>
                    <p>Your course in the matter is approved.</p>
                    <p>I am, etc.,</p>
                    <closer><signed><hi rend="smallcaps">T. F. Bayard.</hi></signed></closer>
                </div>
                </body></text></TEI>