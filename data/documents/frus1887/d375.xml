    <text>
        <body>
            <div frus:doc-dateTime-max="1887-08-18T23:59:59-05:00" frus:doc-dateTime-min="1887-08-18T00:00:00-05:00" n="375" subtype="historical-document" type="document" xml:id="d375">
                <head>No. 375.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName>
                            to Mr. <persName type="to">Merrill</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1887-08-18">
                            <hi rend="italic">August</hi> 18,
                            1887</date>.</dateline>
                    <seg rendition="#left">No. 58.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge, with thanks, the
                        receipt of your interesting and valuable dispatch, No. 135, of July 30,
                        1887, giving a detailed account of the recent political events in
                        Hawaii.</p>
                <p>I am etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">T. F. Bayard.</hi>
                    </signed>
                </closer>
            </div>
        </body>
