                subtype="historical-document" type="document" xml:id="d693">
                <head>No. 693.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Porter</persName> to Mr. <persName
                            type="to">Straus</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1887-08-04">
                            <hi rend="italic">August</hi> 4, 1887</date>.</dateline>
                    <seg rendition="#left">No. 33.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge with approval the receipt
                    of your dispatch No. 14, of the 18th ultimo, concerning the question of
                    interference by the Turkish authorities with colporteurs.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Jas. D. Porter</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
