                <note rend="inline" type="source">No. 107.</note>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Davis</persName> to <persName type="to">Mr.
                        Read</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1870-08-16">
                            <hi rend="italic">August</hi> 16, 1870.</date>
                    </dateline>
                </opener>
                <p>R<hi rend="smallcaps">ead,</hi>
                    <hi rend="italic">Consul General, Paris:</hi>
                </p>
                <p>Secretary Treasury says: Take gold till further ordered.</p>
                <closer>
                    <signed>DAVIS.</signed>
                </closer>
            </div>
        </body>
