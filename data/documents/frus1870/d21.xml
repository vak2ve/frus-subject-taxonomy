<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1870-07-25T23:59:59-05:00" frus:doc-dateTime-min="1870-07-25T00:00:00-05:00" n="21" subtype="historical-document" type="document" xml:id="d21">
                        <note rend="inline" type="source">No. 21.</note>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <head><persName type="from">Mr. Davis</persName> to <persName type="to">Mr.
                                E. B. Washburne</persName>.</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi><hi rend="italic"> Washington</hi></placeName>, <date calendar="gregorian" when="1870-07-25"><hi rend="italic">July</hi> 25, 1870.</date></dateline></opener>
                        <p>Take subjects of Saxony, Hesse, and Coburg under protection, France
                            consenting. * * * * * * *</p>
                        <closer>
                            <signed>DAVIS, <hi rend="italic">Acting
                            Secretary.</hi></signed></closer>
                    </div>
                    </body></text></TEI>