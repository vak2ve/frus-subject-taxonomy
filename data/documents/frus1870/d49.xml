<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1870-07-24T23:59:59-05:00" frus:doc-dateTime-min="1870-07-24T00:00:00-05:00" n="49" subtype="historical-document" type="document" xml:id="d49">
                        <note rend="inline" type="source">No. 49.</note>
                        <opener><seg rendition="#center">[Telegram.—Received July 25, 1870, at 9.30
                                a.m.]</seg></opener>
                        <head><persName type="from">Mr. E. B. Washburne</persName> to <persName type="to">Mr. Fish</persName>.</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Paris,</hi></placeName>
                                <date calendar="gregorian" when="1870-07-24"><hi rend="italic">July</hi> 24, 1870.</date></dateline></opener>
                        <p><hi rend="smallcaps">Fish,</hi>
                            <hi rend="italic">Washington:</hi></p>
                        <p>French government assents to our protecting North Germans and Saxons.
                            Hesse Grand-Ducale and Saxe-Coburg-Gotha also ask protection.</p>
                        <closer>
                            <signed>WASHBURNE.</signed></closer>
                    </div>
                    </body></text></TEI>