<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1870-09-03T23:59:59-05:00" frus:doc-dateTime-min="1870-09-03T00:00:00-05:00" n="158" subtype="historical-document" type="document" xml:id="d158">
                        <note rend="inline" type="source">No. 158.</note>
                        <opener><seg rendition="#center">[By cable.—Received 11.52 a. m., September
                                3.]</seg></opener>
                        <head><persName type="from">Mr. Bancroft</persName> to <persName type="to">Mr. Davis</persName>.</head>
                        <opener>
                            <dateline rendition="#right">
                                <date calendar="gregorian" when="1870-09-03"><hi rend="smallcaps">September</hi> 3, 1870.</date></dateline></opener>
                        <p><hi rend="smallcaps">Davis,</hi>
                            <hi rend="italic">Secretary</hi>, <hi rend="italic">Washington, D.
                                C.:</hi></p>
                        <p>MacMahon’s army capitulated. Emperor Napoleon surrendered to King William
                            without prejudice to Paris regency.</p>
                        <closer>
                            <signed>BANCROFT, <hi rend="italic">Berlin.</hi></signed></closer>
                    </div>
                    </body></text></TEI>