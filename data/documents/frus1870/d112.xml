    <text>
        <body>
            <div frus:doc-dateTime-max="1870-08-19T23:59:59-05:00" frus:doc-dateTime-min="1870-08-19T00:00:00-05:00" n="112" subtype="historical-document" type="document" xml:id="d112">
                <note rend="inline" type="source">No. 112.</note>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Read</persName> to <persName type="to">Mr.
                                Davis</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <date calendar="gregorian" when="1870-08-19">
                            <hi rend="smallcaps">August</hi> 19</date>. (Received August 20,
                                1870.)</dateline>
                </opener>
                <p>Your two telegrams of eighteenth answer satisfactorily all mine, except
                            please authorize me immediately to bank public funds daily with
                            Rothschild or Hottinguer, Baring’s correspondent, for instance. This
                            measure is essential.</p>
                <closer>
                    <signed>READ, <hi rend="italic">Paris.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
