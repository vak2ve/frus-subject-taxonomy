    <text>
        <body>
            <div frus:doc-dateTime-max="1870-09-06T23:59:59-05:00" frus:doc-dateTime-min="1870-09-06T00:00:00-05:00" n="29" subtype="historical-document" type="document" xml:id="d29">
                <note rend="inline" type="source">No. 29.</note>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Davis</persName> to <persName type="to">Mr.
                                E. B. Washburne</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic"> Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1870-09-06">
                            <hi rend="italic">September</hi> 6, 1870.</date>
                    </dateline>
                </opener>
                <p>As soon as situation in your judgment shall justify, tender the
                            congratulations of President and people of United States on the
                            successful establishment of republican government.</p>
                <closer>
                    <signed>DAVIS, <hi rend="italic">Acting
                            Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
