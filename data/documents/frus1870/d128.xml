<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1870-10-23T23:59:59-05:00" frus:doc-dateTime-min="1870-10-23T00:00:00-05:00" n="128" subtype="historical-document" type="document" xml:id="d128">
                        <note rend="inline" type="source">No. 128.</note>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <head><persName type="from">Mr. Motley</persName> to <persName type="to">Mr.
                                Fish</persName>.</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Washington,</hi> D. C.</placeName>,
                                    <date calendar="gregorian" when="1870-10-23"><hi rend="italic">October</hi> 23, 1870</date>. (Received at 1.30 p.
                                m.)</dateline></opener>
                        <p>To <hi rend="smallcaps">Fish,</hi>
                            <hi rend="italic">Secretary of State, Washington City</hi>:</p>
                        <p>Lord Granville has just informed me that her Majesty’s government have
                            urged France and Prussia to agree to an armistice with the view to the
                            constituent assembly and an eventual peace.</p>
                        <closer>
                            <signed>MOTLEY, <hi rend="italic">London.</hi></signed></closer>
                    </div>
                    </body></text></TEI>