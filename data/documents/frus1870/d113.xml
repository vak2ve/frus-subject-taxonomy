<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1870-08-20T23:59:59-05:00" frus:doc-dateTime-min="1870-08-20T00:00:00-05:00" n="113" subtype="historical-document" type="document" xml:id="d113">
                        <note rend="inline" type="source">No. 113.</note>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <head><persName type="from">Mr. Davis</persName> to <persName type="to">Mr.
                                Read</persName>.</head>
                        <opener>
                            <dateline rendition="#right">
                                <date calendar="gregorian" when="1870-08-20"><hi rend="smallcaps">August</hi> 20, 1870.</date></dateline></opener>
                        <p><hi rend="smallcaps">Read,</hi>
                            <hi rend="italic">Consul General</hi>, <hi rend="italic">Paris:</hi></p>
                        <p>Bank with Monroe &amp; Co., if necessary. Accept any funds at such
                            discount as will purchase exchange on London, without loss, and convert
                            into such exchange. Use your own discretion in emergency.</p>
                        <closer>
                            <signed>DAVIS.</signed></closer>
                    </div>
                    </body></text></TEI>