    <text>
        <body>
            <div frus:doc-dateTime-max="1870-09-05T23:59:59-05:00"
                frus:doc-dateTime-min="1870-09-05T00:00:00-05:00" n="74"
                subtype="historical-document" type="document" xml:id="d74">
                <note rend="inline" type="source">No. 74.</note>
                <head>
                    <persName type="from">Mr. E. B. Washburne</persName> to <persName type="to">Mr.
                        Fish</persName>.</head>
                <opener>
                    <seg rendition="#center">[By cable telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <date calendar="gregorian" when="1870-09-05">
                            <hi rend="italic">September</hi> 5, 1870</date>. (Received September
                        5.)</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Fish,</hi>
                    <hi rend="italic">Washington:</hi>
                </p>
                <p>Republic proclaimed from Hotel de Ville. People still hold possession Chambers.
                    Deputies Favre, Gambetta, Simon, Picard, and others, provisional government.
                    Rochefort liberated by people.</p>
                <closer>
                    <signed>WASHBURNE, <hi rend="italic">Paris.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
