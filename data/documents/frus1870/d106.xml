<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1870-08-15T23:59:59-05:00" frus:doc-dateTime-min="1870-08-15T00:00:00-05:00" n="106" subtype="historical-document" type="document" xml:id="d106">
                        <note rend="inline">CORRESPONDENCE BETWEEN THE DEPARTMENT OF STATE AND THE
                            UNITED STATES CONSULATE GENERAL AT PARIS.</note>
                        <opener><seg rendition="#left">No. 106.</seg></opener>
                        <head><persName type="from">Mr. Read</persName> to <persName type="to">Mr.
                                Fish</persName>.</head>
                        <opener><seg rendition="#center">[By cable telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Paris,</hi></placeName>
                                <date calendar="gregorian" when="1870-08-15"><hi rend="italic">August</hi> 15, 1870</date>. (Received 5.15 p. m., August
                                15.)</dateline></opener>
                        <p>Paper depreciating daily, also difference between silver and gold;
                            average daily receipts thirteen hundred francs. Very little gold in
                            circulation. What am I to do?</p>
                        <closer>
                            <signed>READ.</signed></closer>
                    </div>
                    </body></text></TEI>