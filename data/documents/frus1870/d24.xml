    <text>
        <body>
            <div frus:doc-dateTime-max="1870-08-16T23:59:59-05:00" frus:doc-dateTime-min="1870-08-16T00:00:00-05:00" n="24" subtype="historical-document" type="document" xml:id="d24">
                <note rend="inline" type="source">No. 24.</note>
                <note rend="inline" type="source">
                    <hi rend="smallcaps">No. 153.]</hi>
                </note>
                <head>
                    <persName type="from">Mr. Davis</persName> to <persName type="to">Mr.
                                E. B. Washburne</persName>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic"> Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1870-08-16">
                            <hi rend="italic">August</hi> 16, 1870.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have to acknowledge the receipt of your
                            dispatches, numbered 232 to 242, both inclusive.</p>
                <p>Your action in regard to the protection of subjects of Saxony and of
                            those of the Grand Duke of Hesse, in France, as indicated in your Nos.
                            234 and 235, is fully approved.</p>
                <closer>
                    <signed>J. C. B. DAVIS, <hi rend="italic">Acting
                                Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
