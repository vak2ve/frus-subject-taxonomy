<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1870-07-18T23:59:59-05:00" frus:doc-dateTime-min="1870-07-18T00:00:00-05:00" n="43" subtype="historical-document" type="document" xml:id="d43">
                        <note rend="inline" type="source">No. 43.</note>
                        <opener><seg rendition="#center">[Telegram.—Received July 19,
                            1870.]</seg></opener>
                        <head><persName type="from">Mr. W. Hoffman</persName> to <persName type="to">Mr. Fish</persName>.</head>
                        <opener>
                            <dateline rendition="#right">
                                <date calendar="gregorian" when="1870-07-18"><hi rend="smallcaps">July</hi> 18, 1870.</date></dateline></opener>
                        <p><hi rend="smallcaps">Fish,</hi>
                            <hi rend="italic">Washington:</hi></p>
                        <p>Consented to take North German under protection, on application of
                            ambassador, with assent of France. No answer as regards steamers.</p>
                        <p>Washburne returns immediately.</p>
                        <closer>
                            <signed>HOFFMAN, <hi rend="italic">Paris.</hi></signed></closer>
                    </div>
                    </body></text></TEI>