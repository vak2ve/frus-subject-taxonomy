    <text>
        <body>
            <div frus:doc-dateTime-max="1870-08-17T23:59:59-05:00"
                frus:doc-dateTime-min="1870-08-17T00:00:00-05:00" n="108"
                subtype="historical-document" type="document" xml:id="d108">
                <note rend="inline" type="source">No. 108.</note>
                <head>
                    <persName type="from">Mr. Read</persName> to <persName type="to">Mr.
                        Davis</persName>.</head>
                <opener>
                    <seg rendition="#center">[By cable.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1870-08-17">
                            <hi rend="italic">August</hi> 17, 1870</date>. (Received at 3.35 p. m.,
                        August 17.)</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Davis,</hi>
                    <hi rend="italic">Acting Secretary of State</hi>, <hi rend="italic"
                        >Washington:</hi>
                </p>
                <p>No gold to be had; only silver.</p>
                <closer>
                    <signed>READ, <hi rend="italic">Paris</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
