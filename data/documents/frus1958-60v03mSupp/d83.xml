                                <hi rend="italic">Orbit over <gloss target="#t_USSR_1">USSR</gloss>
                                </hi>
                            </cell>
                            <cell>
                                <hi rend="italic">Schedule</hi>
                            </cell>
                        </row>
                        <row>
                            <cell cols="5">
                                <hi rend="italic">Initial tests</hi>
                            </cell>
                        </row>
                        <row>
                            <cell>10–19 Thor</cell>
                            <cell>No</cell>
                            <cell>South Camp Cooke, Calif.</cell>
                            <cell>Yes</cell>
