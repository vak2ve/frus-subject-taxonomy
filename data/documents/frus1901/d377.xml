<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1901-09-14T23:59:59-05:00" frus:doc-dateTime-min="1901-09-14T00:00:00-05:00" n="377" subtype="historical-document" type="document" xml:id="d377">
                        <head><hi rend="italic">President <persName type="from">Romana</persName> to
                                President <persName type="to">Roosevelt</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Lima</hi></placeName>, <date calendar="gregorian" when="1901-09-14"><hi rend="italic">September 14,
                                    1901</hi></date>.</dateline></opener>
                        <p>Accept expression of condolence in my own and country’s name for the loss
                            of the great President McKinley.</p>
                        <closer><signed><hi rend="smallcaps">Romana</hi>, <hi rend="italic">President.</hi></signed></closer>
                    </div>
                    </body></text></TEI>