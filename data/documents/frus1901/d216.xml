<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1901-10-26T23:59:59-05:00" frus:doc-dateTime-min="1901-10-26T00:00:00-05:00" n="216" subtype="historical-document" type="document" xml:id="d216">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">White</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1901-10-26"><hi rend="italic">October 26,
                                1901</hi></date>.</dateline></opener>
                        <p>(Mr. Hay directs Mr. White to authorize Mr. Crane to accept, on behalf of
                            American claimants, the offer of the British Government of £6,000, in
                            full settlement.)</p>
                    </div>
                    </body></text></TEI>