    <text>
        <body>
            <div frus:doc-dateTime-max="1901-09-15T23:59:59-05:00"
                frus:doc-dateTime-min="1901-09-15T00:00:00-05:00" n="352"
                subtype="historical-document" type="document" xml:id="d352">
                <head>
                    <hi rend="italic">Mr. <persName type="from">van Roijen</persName> to Mr.
                            <persName type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Netherlands Legation</hi>,<lb/>
                            <hi rend="italic">New London, Conn.</hi>
                        </placeName>, <date calendar="gregorian" when="1901-09-15">
                            <hi rend="italic">September 15, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>I am commissioned to express to your excellency the profound sympathy felt by my
                    Government for the American people under these sorrowful circumstances.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Van Roijen.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
