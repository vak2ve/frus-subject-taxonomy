                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">White</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-12-21">
                            <hi rend="italic">December 21, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>Accept proposed settlement and hand amount over to Lillywhite against full
                    receipt.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hay</hi>.</signed>
                </closer>
            </div>
        </body>
