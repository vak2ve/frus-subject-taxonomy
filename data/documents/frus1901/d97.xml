<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1901-11-06T23:59:59-05:00" frus:doc-dateTime-min="1901-11-06T00:00:00-05:00" n="97" subtype="historical-document" type="document" xml:id="d97">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Conger</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1901-11-06"><hi rend="italic">November 6,
                                1901</hi></date>.</dateline></opener>
                        <p>(Mr. Hay directs Mr. Conger to express deepest sympathy with China in the
                            imminent loss of her great statesman.)</p>
                    </div>
