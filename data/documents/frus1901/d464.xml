                subtype="historical-document" type="document" xml:id="d464">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Leishman</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-06-18">
                            <hi rend="italic">June 18, 1901</hi>.</date>
                    </dateline>
                </opener>
                <p>(Mr. Hay acknowledges the preceding telegram, and extends cordial congratulations
                    to Mr. Leishman on the settlement of the indemnity claims, and directs that the
                    amount be remitted to the Department.)</p>
            </div>
        </body>
