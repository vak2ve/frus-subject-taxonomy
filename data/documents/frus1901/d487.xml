<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1901-09-14T23:59:59-05:00" frus:doc-dateTime-min="1901-09-14T00:00:00-05:00" n="487" subtype="historical-document" type="document" xml:id="d487">
                        <head><hi rend="italic">The <gloss type="from">President of Paraguay</gloss>
                                to the <gloss type="to">President of the United
                            States</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Ascunsion, Paraguay</hi></placeName>, <date calendar="gregorian" when="1901-09-14"><hi rend="italic">September 14, 1901</hi>.</date></dateline></opener>
                        <p>The Government and people of Paraguay join in the great American
                            sorrow.</p>
                        <closer><signed><hi rend="smallcaps">Emilio Aceval</hi>, <hi rend="italic">President</hi>.</signed></closer>
                    </div>
                    </body></text></TEI>