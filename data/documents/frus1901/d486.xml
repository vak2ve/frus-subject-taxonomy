                subtype="historical-document" type="document" xml:id="d486">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to the <gloss
                            type="to">Minister for Foreign Affairs of Uruguay</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-09-16">
                            <hi rend="italic">September 16, 1901</hi>.</date>
                    </dateline>
                </opener>
                <p>The American Government and people deeply appreciate Uruguayan sympathy.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
