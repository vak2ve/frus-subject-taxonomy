<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1901-09-21T23:59:59-05:00" frus:doc-dateTime-min="1901-09-21T00:00:00-05:00" n="525" subtype="historical-document" type="document" xml:id="d525">
                        <head><hi rend="italic">The <gloss type="from">President of
                                    Venezuela</gloss> to the <gloss type="to">President of the
                                    United States</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Caracas</hi></placeName>, <date calendar="gregorian" when="1901-09-21"><hi rend="italic">September 21,
                                    1901</hi></date>.</dateline></opener>
                        <p>The Venezuelan Government and people join in the mourning of your great
                            Republic.</p>
                        <closer><signed><hi rend="smallcaps">Castro.</hi></signed></closer>
                    </div>
                    </body></text></TEI>