                subtype="historical-document" type="document" xml:id="d161">
                <head>
                    <hi rend="italic">Mr. <persName type="from">White</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Embassy of the United States</hi>,<lb/>
                            <hi rend="italic">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1901-08-05">
                            <hi rend="italic">August 5, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>The Empress Frederick, mother of the reigning Emperor, died at Cronberg about 6
                    o’clock this afternoon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">White.</hi>
                    </signed>
                </closer>
            </div>
        </body>
