                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Griscom</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1900-12-11">
                            <hi rend="italic">December 11, 1900</hi>.</date>
                    </dateline>
                </opener>
                <p>(Mr. Hay states that the <hi rend="italic">Kentucky</hi> has been ordered by the
                    Navy Department to remain.)</p>
