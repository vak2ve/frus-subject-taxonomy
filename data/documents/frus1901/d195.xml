    <text>
        <body>
            <div frus:doc-dateTime-max="1901-01-22T23:59:59-05:00"
                frus:doc-dateTime-min="1901-01-22T00:00:00-05:00" n="195"
                subtype="historical-document" type="document" xml:id="d195">
                <head>
                    <hi rend="italic">Lord <persName type="from">Pauncefote</persName> to Mr.
                            <persName type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">British Embassy</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-01-22">
                            <hi rend="italic">January 22, 1901</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 22.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I am profoundly grieved to inform you that I have
                    received a cable message from the Marquis of Lansdowne announcing the demise of
                    the Queen this evening at 6.30.</p>
                <p>It is my melancholy duty to request that you will bring this sad intelligence to
                    the knowledge of the President and his Cabinet.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Pauncefote</hi>,</signed>
                </closer>
            </div>
        </body>
    </text>
