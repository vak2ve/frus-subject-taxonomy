                subtype="historical-document" type="document" xml:id="d35">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to <gloss type="to"
                            >Senhor Brasil</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-04-27">
                            <hi rend="italic">April 27, 1901</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 22.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to your recent interview with the
                    Assistant Secretary of State, I have the honor to say that the Secretaries of
                    the Treasury, War, and the Navy, and the governor of New York have <pb
                        facs="0108" n="28" xml:id="pg_28"/> been advised of the expected arrival of
                    the <hi rend="italic">Benjamin Constant</hi> at New York, and requested to
                    direct the authorities there to extend the customary courtesies to the
                    vessel.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
