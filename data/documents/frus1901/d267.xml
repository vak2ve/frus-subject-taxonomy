    <text>
        <body>
            <div frus:doc-dateTime-max="1901-07-27T23:59:59-05:00"
                frus:doc-dateTime-min="1901-07-27T00:00:00-05:00" n="267"
                subtype="historical-document" type="document" xml:id="d267">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hill</persName> to Signor <persName
                            type="to">Carignani</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-07-27">
                            <hi rend="italic">July 27, 1901</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 693.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 24th instant transmitting statements received by the Italian
                    consul at Erwin, Miss.</p>
                <p>A copy of your note has been forwarded to the governor of Mississippi for the
                    information of the State authorities.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">David J. Hill</hi>, <hi rend="italic">Acting
                            Secretary</hi>.</signed>
                </closer>
            </div>
        </body>
