<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1901-09-20T23:59:59-05:00" frus:doc-dateTime-min="1901-09-20T00:00:00-05:00" n="378" subtype="historical-document" type="document" xml:id="d378">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Dudley</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1901-09-20"><hi rend="italic">September 20,
                                    1901</hi>.</date></dateline></opener>
                        <p>Please convey, through proper channel, in the name of the President and
                            people, sincere appreciation of President Romana’s message of
                            condolence.</p>
                        <closer><signed><hi rend="smallcaps">John Hay.</hi></signed></closer>
                    </div>
                </body></text></TEI>