    <text>
        <body>
            <div frus:doc-dateTime-max="1901-06-15T23:59:59-05:00"
                frus:doc-dateTime-min="1901-06-15T00:00:00-05:00" n="498"
                subtype="historical-document" type="document" xml:id="d498">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Russell</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Caracas</hi>
                        </placeName>, <date calendar="gregorian" when="1901-06-15">
                            <hi rend="italic">June 15, 1901</hi>.</date>
                    </dateline>
                    <seg rendition="#left">No. 625.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your No. 415, of May 22, 1901, in regard to an expected explanation from the
                    Government of Venezuela as to the loss of the legation’s telegram to Mr. Balz
                    last October.</p>
                <p>I have directed an official communication to the foreign office on this subject,
                    but up to the present I have received no reply.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William W. Russell.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
