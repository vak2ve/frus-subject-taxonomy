                subtype="historical-document" type="document" xml:id="d456">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Griscom</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Constantinople</hi>
                        </placeName>, <date calendar="gregorian" when="1900-12-11">
                            <hi rend="italic">December 11, 1900</hi>.</date>
                    </dateline>
                </opener>
                <p>(Mr. Griscom requests that arrangements be made for the <hi rend="italic"
                        >Kentucky</hi> to remain a little longer in order that any impression of
                    hostility may be removed, and states that, with the Department’s approval, he
                    will go to Smyrna on December 13, if the affairs of the legation will
                    permit.)</p>
            </div>
        </body>
    </text>
