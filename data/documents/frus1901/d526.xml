    <text>
        <body>
            <div frus:doc-dateTime-max="1901-09-21T23:59:59-05:00"
                frus:doc-dateTime-min="1901-09-21T00:00:00-05:00" n="526"
                subtype="historical-document" type="document" xml:id="d526">
                <head>
                    <hi rend="italic">The <gloss type="from">President of the United States</gloss>
                        to the <gloss type="to">President of Venezuela</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Executive Mansion</hi>
                        </placeName>,<lb/>
                        <date calendar="gregorian" when="1901-09-21">
                            <hi rend="italic">September 21, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>The sympathy of Venezuelan Government and people is deeply appreciated.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
