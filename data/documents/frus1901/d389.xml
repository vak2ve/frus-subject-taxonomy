                subtype="historical-document" type="document" xml:id="d389">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Stourdza</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-09-16">
                            <hi rend="italic">September 16, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>Pray accept on behalf of the American Government and people grateful thanks for
                    Roumanian sympathy in their deep affliction.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
