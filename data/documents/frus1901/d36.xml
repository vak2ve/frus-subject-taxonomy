                subtype="historical-document" type="document" xml:id="d36">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to <gloss type="to"
                            >Senhor Brasil</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-06-05">
                            <hi rend="italic">June 5, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Minister</hi>: The President will be pleased to
                    receive you and the officers of the Brazilian man-of-war <hi rend="italic"
                        >Benjamin Constant</hi> on Friday morning, June 7, at 10 o’clock.</p>
                <p>Very sincerely, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
