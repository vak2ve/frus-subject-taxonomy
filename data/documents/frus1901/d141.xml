    <text>
        <body>
            <div frus:doc-dateTime-max="1901-03-09T23:59:59-05:00"
                frus:doc-dateTime-min="1901-03-09T00:00:00-05:00" n="141"
                subtype="historical-document" type="document" xml:id="d141">
                <head>
                    <hi rend="italic">Mr. <persName type="from">White</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Embassy of the United States</hi>,<lb/>
                            <hi rend="italic">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1901-03-09">
                            <hi rend="italic">March 9, 1901</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 1565.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt this
                    morning of your telegraphic instructions,<note n="a" xml:id="d141fna">Printed
                        ante.</note> and to inform you that I have at once acted in accordance with
                    the same and have communicated with Baron Richthofen, the imperial secretary of
                    state for foreign affairs.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Andrew D. White.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
