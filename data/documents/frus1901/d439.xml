    <text>
        <body>
            <div frus:doc-dateTime-max="1901-09-14T23:59:59-05:00"
                frus:doc-dateTime-min="1901-09-14T00:00:00-05:00" n="439"
                subtype="historical-document" type="document" xml:id="d439">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Grip</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Sweden and Norway</hi>,<lb/>
                            <hi rend="italic">Bar Harbor, Me.</hi>
                        </placeName>, <date calendar="gregorian" when="1901-09-14">
                            <hi rend="italic">September 14, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>I am directed by my Government to convey to the Government of the United States
                    the expressions of deep sympathy of the King and the United Kingdoms of Sweden
                    and Norway.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">A. Grip.</hi>
                    </signed>
                </closer>
            </div>
        </body>
