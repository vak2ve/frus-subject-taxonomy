<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1901-11-15T23:59:59-05:00" frus:doc-dateTime-min="1901-11-15T00:00:00-05:00" n="403" subtype="historical-document" type="document" xml:id="d403">
                        <head><hi rend="italic">The <gloss type="from">President</gloss> to the
                                    <gloss type="to">King</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Executive Mansion</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1901-11-15"><hi rend="italic">November 15,
                                    1901</hi>.</date></dateline></opener>
                        <p>I congratulate Your Majesty on this auspicious anniversary.</p>
                        <closer><signed><hi rend="smallcaps">Theodore
                            Roosevelt.</hi></signed></closer>
                    </div>
                </body></text></TEI>