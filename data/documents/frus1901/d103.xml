    <text>
        <body>
            <div frus:doc-dateTime-max="1901-09-23T23:59:59-05:00"
                frus:doc-dateTime-min="1901-09-23T00:00:00-05:00" n="103"
                subtype="historical-document" type="document" xml:id="d103">
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to
                        President <persName type="to">Marroquin</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Executive Mansion</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-09-23">
                            <hi rend="italic">September 23, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>I cordially acknowledge your message of condolence for the great loss suffered by
                    the people of the United States.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
