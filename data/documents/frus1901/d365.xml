                subtype="historical-document" type="document" xml:id="d365">
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to the
                            <gloss type="to">Shah of Persia</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Executive Mansion</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-09-23">
                            <hi rend="italic">September 23, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>I reciprocate your friendly greeting with cordial wishes for your welfare and the
                    prosperity of Persia.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
