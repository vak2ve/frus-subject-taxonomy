                subtype="historical-document" type="document" xml:id="d128">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Delcassé</persName>, minister for
                        foreign affairs, to Mr. <persName type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1901-09-14">
                            <hi rend="italic">September 14, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>I beg your excellency to accept the sincere and keen condolences of the French
                    nation and Government, who share with all their hearts in the mourning of the
                    nation and Government of the United States.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Delcassé</hi>.</signed>
                </closer>
            </div>
        </body>
