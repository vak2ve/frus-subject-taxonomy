                subtype="historical-document" type="document" xml:id="d16">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Von Callenberg</persName>, Chargé
                        d’Affaires, to Mr. <persName type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Manchester, Mass.</hi>
                        </placeName>, <date calendar="gregorian" when="1901-09-15">
                            <hi rend="italic">September 15, 1901</hi>
                        </date>.</dateline>
                </opener>
                <p>I am charged, on the occasion of the tragic death of President McKinley, to
                    convey to the Federal Government the warmest sympathy of His Imperial and Royal
                    Apostolic Majesty.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Von Callenberg</hi>,<lb/>
                        <hi rend="italic">Austro-Hungarian Chargé d’Affaires.</hi>
                    </signed>
                </closer>
            </div>
        </body>
