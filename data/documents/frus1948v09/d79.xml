    <text>
        <body>
            <div frus:doc-dateTime-max="1948-03-09T07:00:00-05:00"
                frus:doc-dateTime-min="1948-03-09T07:00:00-05:00" n="79"
                subtype="historical-document" type="document" xml:id="d79">
                <note rend="inline" type="source">710.J/3–948: Circular telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to <gloss
                            type="to">Diplomatic Representatives in the American Republics</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">restricted</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1948-03-09T07:00:00-05:00"
                            >March 9, 1948—7 a. m.</date>
                    </dateline>
                </opener>
                <p>2037. <gloss target="#t_GovBd1">Gov Bd</gloss> March 8 approved by vote 14 to 5
                    Committee report on Nicaraguan participation in <gloss target="#t_BogConf1">Bog
                        Conf</gloss> summarized <gloss target="#t_Depcirtel1">Depcirtel</gloss> Feb
                    27, 3 p. m.<note n="1" xml:id="d79fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_9">p. 9</ref>.</note> US voted
                    in favor stating this action implied no change in relations between US and <hi
                        rend="italic">de facto</hi> govt Nicaragua.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Marshall</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
