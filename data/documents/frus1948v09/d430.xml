<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Secretary of State to the
                            Embassy in Ecuador</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1948v09</bibl><bibl type="frus-document-id">d430</bibl><bibl type="frus-document-number">430</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1948-05-21T00:00:00-05:00" notAfter="1948-05-21T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1948-05-21T23:59:59-05:00" frus:doc-dateTime-min="1948-05-21T00:00:00-05:00" n="430" subtype="historical-document" type="document" xml:id="d430">
                <note rend="inline" type="source">811.516 Export-Import Bank/5–2148</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Embassy in Ecuador</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">confidential</hi>
                        <lb/> No. 67</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1948-05-21">May 21,
                            1948</date>.</dateline>
                </opener>
                <p>The Secretary of State transmits herewith for the information of the Officer in
                    Chargé an agreement, signed May 12, 1948, between the Republic of Ecuador and
                    the Export-Import Bank of Washington establishing a credit of $2,720,000 to
                    finance the cost of equipment, materials and services required in connection
                    with the construction of the Quevedo-Manta Highway.<note n="1" xml:id="d430fn1">For previous documentation on financing Ecuadoran highway development, see
                            <ref target="frus1947v08#pg_690">
                            <hi rend="italic">Foreign Relations</hi>, 1947, vol. <hi rend="smallcaps">viii</hi>, pp. 690</ref> ff.</note>
                </p>
            </div>
        </body>
    </text>
</TEI>
