<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Ambassador in Chile (
                        Bowers
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1948v09</bibl><bibl type="frus-document-id">d308</bibl><bibl type="frus-document-number">308</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1948-07-09T00:00:00-05:00" notAfter="1948-07-09T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1948-07-09T23:59:59-05:00" frus:doc-dateTime-min="1948-07-09T00:00:00-05:00" n="308" subtype="historical-document" type="document" xml:id="d308">
                <note rend="inline" type="source">825.51 Bondholders/7–948: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Chile</hi> (<persName type="from">
                        <hi rend="italic">Bowers</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santiago</hi>
                        </placeName>, <date calendar="gregorian" when="1948-07-09">July 9,
                            1948</date>.</dateline>
                </opener>
                <p>473. Chamber of Deputies last night approved law for resumption of service on
                    foreign debt by vote 44 to 11. Law was previously approved by Senate on May 18
                    (reEmbgam A–241, May 20, 1948).<note n="1" xml:id="d308fn1">Not printed.</note>
                    It is now ready for Presidential signature.<note n="2" xml:id="d308fn2">Ambassador Bowers in telegram 501, July 21, not printed, indicated that the
                        President had signed the law (825.51 Bondholders/7–2148).</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bowers</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
