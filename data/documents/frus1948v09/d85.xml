<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1948-06-08T23:59:59-05:00" frus:doc-dateTime-min="1948-06-08T00:00:00-05:00" n="85" subtype="historical-document" type="document" xml:id="d85">
                        <note rend="inline" type="source">834.00/6–548: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">Embassy in Paraguay</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#left">
                                <hi rend="smallcaps">confidential</hi>
                            </seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1948-06-08">June 8,
                                1948</date>.</dateline>
                        </opener>
                        <p>99. This Govt (<gloss target="#t_urtel1">urtel</gloss> 275 June 5<note n="1" xml:id="d85fn1">Not printed.</note> and related messages) does
                            not contemplate any interruption in our diplomatic relations with
                            Paraguay. You may inform colleagues and local officials.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Marshall</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>