                subtype="historical-document" type="document" xml:id="d85">
                <note rend="inline" type="source">834.00/6–548: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Embassy in Paraguay</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">confidential</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1948-06-08">June 8,
                            1948</date>.</dateline>
                </opener>
                <p>99. This Govt (<gloss target="#t_urtel1">urtel</gloss> 275 June 5<note n="1"
                        xml:id="d85fn1">Not printed.</note> and related messages) does not
                    contemplate any interruption in our diplomatic relations with Paraguay. You may
                    inform colleagues and local officials.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Marshall</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
