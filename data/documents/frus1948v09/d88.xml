    <teiHeader><fileDesc><titleStmt><title>The Ambassador in Peru (
                        Tittmann
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1948v09</bibl><bibl type="frus-document-id">d88</bibl><bibl type="frus-document-number">88</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1948-10-31T12:00:00-05:00" notAfter="1948-10-31T12:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1948-10-31T12:00:00-05:00" frus:doc-dateTime-min="1948-10-31T12:00:00-05:00" n="88" subtype="historical-document" type="document" xml:id="d88">
                <note rend="inline" type="source">823.01/10–3148: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Peru</hi> (<persName type="from">
                        <hi rend="italic">Tittmann</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">
                            <gloss target="#t_Niact1">niact</gloss>   priority</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1948-10-31T12:00:00-05:00">October 31, 1948—noon</date>.</dateline>
                </opener>
                <p>634. Department’s 411, October 30, 9 p. m.<note n="1" xml:id="d88fn1">Not
                        printed; Acting Secretary Lovett indicated that the Department’s policy
                        would be to act in conformity with Bogotá Resolution 35 on continuity of
                        diplomatic relations (823.01/10–3048).</note> Unless instructed to contrary,
                    I propose to establish contact with new Chief of Government and Minister of
                    Foreign Affairs within next 48 hours, basing my actions on Bogotá Resolution. If
                    asked whether such contact constitutes recognition, I propose to quote
                    paragraphs one and three of Bogotá Resolution No. 35 without comment.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Tittmann</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
