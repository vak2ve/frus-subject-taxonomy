                        <head>
                            <hi rend="italic">Mr. <persName type="from">Day</persName> to Mr.
                                    <persName type="to">Woodford</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1898-03-28"><hi rend="italic">March 28,
                                1898</hi></date>.</dateline></opener>
                        <p>Important to have prompt answer on armistice matter.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Day.</hi>
                            </signed>
                        </closer>
                    </div>
