<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-08-12T23:59:59-05:00" frus:doc-dateTime-min="1898-08-12T00:00:00-05:00" n="709" subtype="historical-document" type="document" xml:id="d709">
                        <head>
                            <hi rend="italic">The <gloss type="from">President</gloss> to Mr.
                                    <persName type="to">Day</persName>.</hi>
                        </head>
                        <p rend="flushleft"><hi rend="smallcaps">William R. Day</hi>,<lb/><hi rend="italic">Secretary of State:</hi></p>
                        <p>You are hereby authorized to sign, on the part of the United States, the
                            protocol of this date embodying the terms on which the United States and
                            Spain have agreed to treat of peace.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">William McKinley.</hi>
                            </signed>
                            <lb/>
                            <dateline rendition="#left"><hi rend="smallcaps">Executive
                                        Mansion</hi>,<lb/><placeName><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1898-08-12"><hi rend="italic">August 12,
                                1898</hi></date>.</dateline>
                        </closer>
                    </div>
                    </body></text></TEI>