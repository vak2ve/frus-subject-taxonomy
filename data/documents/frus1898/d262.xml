    <text>
        <body>
            <div frus:doc-dateTime-max="1898-03-25T23:59:59-05:00"
                frus:doc-dateTime-min="1898-03-25T00:00:00-05:00" n="262"
                subtype="historical-document" type="document" xml:id="d262">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Sherman</persName> to Mr. <persName
                            type="to">White</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-03-25">
                            <hi rend="italic">March 25, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 411.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: For use in connection with legislation
                    contemplated in Congress, you are requested to obtain and forward to the
                    Department copies of any German laws or regulations which may be in force to
                    prevent the use of the German flag for advertising purposes.</p>
                <p>Respectfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Sherman.</hi>
                    </signed>
                </closer>
            </div>
        </body>
