<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-11-19T23:59:59-05:00" frus:doc-dateTime-min="1898-11-19T00:00:00-05:00" n="840" subtype="historical-document" type="document" xml:id="d840">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Day</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1898-11-19"><hi rend="italic">November 19,
                                    1898</hi></date>.</dateline></opener>
                        <p>The President approves your proposed action. His recollection of oral
                            discussion preceding protocol coincides exactly with yours.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hay.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>