    <text>
        <body>
            <div frus:doc-dateTime-max="1898-07-20T23:59:59-05:00"
                frus:doc-dateTime-min="1898-07-20T00:00:00-05:00" n="928"
                subtype="historical-document" type="document" xml:id="d928">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Day</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-07-20">
                            <hi rend="italic">July 20, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 759.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In connection with my No. 755 of the 19th instant
                    I append on the overleaf translation of the Department’s cipher telegram of July
                    18 with further reference to the return by this Government of Spanish troops to
                    Spain.</p>
                <p>Respectfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William R. Day.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
