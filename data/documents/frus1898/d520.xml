<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1897-11-28T23:59:59-05:00" frus:doc-dateTime-min="1897-11-28T00:00:00-05:00" n="520" subtype="historical-document" type="document" xml:id="d520">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Woodford</persName> to Mr.
                                    <persName type="to">Sherman</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Legation of the United States</hi>,<lb/><hi rend="italic">Madrid</hi></placeName>, <date calendar="gregorian" when="1897-11-28"><hi rend="italic">November 28,
                                    1897</hi></date>.</dateline></opener>
                        <p>Am just informed by Spanish cabinet that no American subject remains
                            imprisoned in Cuba.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Woodford.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>