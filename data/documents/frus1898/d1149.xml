                <head>
                    <hi rend="italic">Mr. <persName type="from">Loomis</persName> to Mr. <persName
                            type="to">Sherman</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Caracas</hi>
                        </placeName>, <date calendar="gregorian" when="1898-04-29">
                            <hi rend="italic">April 29, 1898</hi>
                        </date>. (Received 2.16 p.m.)</dateline>
                </opener>
                <p>Small Spanish war vessel cruising lower Caribbean Sea stopping ships off Little
                    Curaçao.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Loomis.</hi>
                    </signed>
                </closer>
            </div>
