                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Conger</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-10-03">
                            <hi rend="italic">October 3, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>Your course is approved. Act vigorously for the protection of Americans,
                    demanding redress as well as prevention.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
