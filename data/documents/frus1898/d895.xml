    <text>
        <body>
            <div frus:doc-dateTime-max="1898-06-01T23:59:59-05:00"
                frus:doc-dateTime-min="1898-06-01T00:00:00-05:00" n="895"
                subtype="historical-document" type="document" xml:id="d895">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Day</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">London</hi>
                        </placeName>, <date calendar="gregorian" when="1898-06-01">
                            <hi rend="italic">June 1, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>British Government regret not at liberty to comply with our request to land cable
                    at Hongkong.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
