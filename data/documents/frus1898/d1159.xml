                subtype="historical-document" type="document" xml:id="d1159">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Day</persName> to Mr. <persName
                            type="to">Loomis</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-06-24">
                            <hi rend="italic">June 24, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 143]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I confirm my telegram of the 23d instant, reading
                    as follows: <quote rend="blockquote">
                        <p>No. 146 received. Suggestion informal request immediate relief approved.
                            Venezuela should revoke unjust expulsion. Department can not authorize
                            demand indemnity without proofs.</p>
                    </quote>
                </p>
                <p>Respectfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William R. Day.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
