    <text>
        <body>
            <div frus:doc-dateTime-max="1898-04-06T23:59:59-05:00"
                frus:doc-dateTime-min="1898-04-06T00:00:00-05:00" n="870"
                subtype="historical-document" type="document" xml:id="d870">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Day</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-04-06">
                            <hi rend="italic">April 6, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 554.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I append on the overleaf copy of my telegram of
                    the 5th instant with regard to the offer of the British ambassador that the
                    archives of the legation and the consulates of the United States in Spain be
                    intrusted to British diplomatic and consular officers there; and also with
                    reference to the general relations of the United States and Spain.</p>
                <p>Respectfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William R. Day</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
