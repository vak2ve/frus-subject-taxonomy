    <text>
        <body>
            <div frus:doc-dateTime-max="1898-10-19T23:59:59-05:00"
                frus:doc-dateTime-min="1898-10-19T00:00:00-05:00" n="805"
                subtype="historical-document" type="document" xml:id="d805">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Day</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1898-10-19">
                            <hi rend="italic">October 19, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 12.]</seg>
                </opener>
                <p>The conference which was to have taken place to-day postponed till Friday, on
                    request of Spanish Commissioners.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Day.</hi>
                    </signed>
                </closer>
            </div>
        </body>
