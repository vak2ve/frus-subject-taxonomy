                subtype="historical-document" type="document" xml:id="d1062">
                <head>
                    <hi rend="italic">Sir <persName type="from">Julian Pauncefote</persName> to Mr.
                            <persName type="to">Sherman</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-02-19">
                            <hi rend="italic">February 19, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that I am in
                    receipt of a telegram from the Earl of Aberdeen, Governor-General of Canada,
                    stating that the Dominion Government desire to offer to the President of the
                    United States the expression of their deep sympathy with the whole American
                    nation concerning the lamentable loss of the <hi rend="italic">Maine</hi> and of
                    so many of the officers and men of her brave crew.</p>
                <p>I request that you will be good enough to transmit the above message to its high
                    destination.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Julian Pauncefote.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
