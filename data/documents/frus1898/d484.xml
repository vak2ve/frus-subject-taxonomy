<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1899-02-10T23:59:59-05:00" frus:doc-dateTime-min="1899-02-10T00:00:00-05:00" n="484" subtype="historical-document" type="document" xml:id="d484">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Pierce</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Embassy
                                        of the United States</hi>,<lb/><hi rend="italic">St.
                                        Petersburg</hi></placeName>, <date calendar="gregorian" when="1899-02-10"><hi rend="italic">February 10,
                                    1899</hi></date>.</dateline></opener>
                        <p>Disarmament conference will be held at The Hague.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Pierce.</hi>
                            </signed>
                        </closer>
