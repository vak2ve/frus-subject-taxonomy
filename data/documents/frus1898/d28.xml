                subtype="historical-document" type="document" xml:id="d28">
                <head>
                    <hi rend="italic">The <gloss type="from">President</gloss> to the <gloss
                            type="to">Emperor of Austria</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Executive Mansion</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-09-10">
                            <hi rend="italic">September 10, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>I have heard with profound regret of the assassination of Her Majesty the Empress
                    of Austria while at Geneva, and tender to Your Majesty the deep sympathy of the
                    Government and people of the United States.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William McKinley.</hi>
                    </signed>
                </closer>
            </div>
        </body>
