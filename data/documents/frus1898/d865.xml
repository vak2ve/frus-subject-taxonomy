    <text>
        <body>
            <div frus:doc-dateTime-max="1898-12-16T23:59:59-05:00"
                frus:doc-dateTime-min="1898-12-16T00:00:00-05:00" n="865"
                subtype="historical-document" type="document" xml:id="d865">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Moore</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1898-12-16">
                            <hi rend="italic">December 16, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>Peace Commission sails by the <hi rend="italic">St. Louis</hi> from Southampton
                    Saturday and desires, on arrival at New York, to go immediately by the
                    Pennsylvania road, by special train if necessary, to Washington. The Commission
                    hopes to present the treaty to the President December 24.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Moore.</hi>
                    </signed>
                </closer>
            </div>
        </body>
