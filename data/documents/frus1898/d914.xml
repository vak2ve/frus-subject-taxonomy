    <text>
        <body>
            <div frus:doc-dateTime-max="1898-07-08T23:59:59-05:00"
                frus:doc-dateTime-min="1898-07-08T00:00:00-05:00" n="914"
                subtype="historical-document" type="document" xml:id="d914">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Day</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-07-08">
                            <hi rend="italic">July 8, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 734.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I append on the overleaf translation of my cipher
                        telegram<note n="1" xml:id="d914fn1">Inclosure printed, ante.</note> of the
                    6th instant, advising you of the report of the United States consul at Vancouver
                    that a Spanish privateer is lying in the Gulf of Georgia, and directing you to
                    inform the British Government thereof.</p>
                <p>Respectfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William R. Day.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
