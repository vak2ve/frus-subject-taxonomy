                subtype="historical-document" type="document" xml:id="d29">
                <head>
                    <hi rend="italic">The <gloss type="from">Emperor of Austria</gloss> to the
                            <gloss type="to">President</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Schoengrunn</hi>
                        </placeName>, <date calendar="gregorian" when="1898-09-11">
                            <hi rend="italic">September 11, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>Sincerely touched by the expression of condolence and sympathy which you have
                    been pleased to forward to me in the name of the Government and of the people of
                    the United States, I beg you to accept my warmest thanks.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Francis Joseph.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
