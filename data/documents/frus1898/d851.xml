                subtype="historical-document" type="document" xml:id="d851">
                <head>
                    <hi rend="italic">The <gloss type="from">President</gloss> to Mr. <persName
                            type="to">Day</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Executive Mansion</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-11-29">
                            <hi rend="italic">November 29, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>Message just received. The commissioners have my profound thanks.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William McKinley.</hi>
                    </signed>
                </closer>
            </div>
        </body>
