    <text>
        <body>
            <div frus:doc-dateTime-max="1898-07-09T23:59:59-05:00"
                frus:doc-dateTime-min="1898-07-09T00:00:00-05:00" n="916"
                subtype="historical-document" type="document" xml:id="d916">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Moore</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-07-09">
                            <hi rend="italic">July 9, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 737.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In connection with the Department’s No. 734, of
                    the 7th instant, I append on the overleaf translation of my cipher telegram<note
                        n="1" xml:id="d916fn1">Inclosure printed, ante.</note> of July 8, in further
                    relation to the reported presence of a Spanish privateer in the waters of
                    British Columbia.</p>
                <p>Respectfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">J. B. Moore</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
