                subtype="historical-document" type="document" xml:id="d649">
                <head>
                    <hi rend="italic">Memorandum from French embassy.</hi>
                </head>
                <p>Could the Department of State inform the French ambassador whether the Spanish
                    schooner <hi rend="italic">Sofia</hi> is among the number of vessels captured by
                    the Federal fleet?</p>
                <closer>
                    <dateline rendition="#left">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-04-29">
                            <hi rend="italic">April 29, 1898</hi>
                        </date>.</dateline>
                </closer>
            </div>
        </body>
    </text>
