                subtype="historical-document" type="document" xml:id="d62">
                <head>
                    <hi rend="italic">The <gloss type="from">Governor of Pennsylvania</gloss> to Mr.
                            <persName type="to">Sherman</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Harrisburg, Pa.</hi>
                        </placeName>, <date calendar="gregorian" when="1898-01-08">
                            <hi rend="italic">January 8, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>In accordance with your telegram of this date, the report of the Hazleton riots
                    will be forwarded to you on Monday next.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Daniel H. Hastings.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
