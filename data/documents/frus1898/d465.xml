                subtype="historical-document" type="document" xml:id="d465">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Day</persName> to Mr. <persName
                            type="to">Hitchcock</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>
                        </placeName>, <date calendar="gregorian" when="1898-06-23">
                            <hi rend="italic">June 23, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 90.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your No. 82
                    of the 6th instant, and approve your determination to issue no further passports
                    to Dr. Henry Michaels and to Dr. George K. Regner, without conclusive evidence
                    shown of a real intent, supported by acts, to return to the United States, there
                    to reside and perform the duties of citizenship.</p>
                <p>Respectfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William R. Day.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
