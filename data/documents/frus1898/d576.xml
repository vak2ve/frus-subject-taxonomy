<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-03-30T23:59:59-05:00" frus:doc-dateTime-min="1898-03-30T00:00:00-05:00" n="576" subtype="historical-document" type="document" xml:id="d576">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Woodford</persName> to Mr.
                                    <persName type="to">Day</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Legation of the United States</hi>,<lb/><hi rend="italic">Madrid</hi></placeName>, <date calendar="gregorian" when="1898-03-30"><hi rend="italic">March 30,
                                1898</hi></date>.</dateline></opener>
                        <p>There will be no delay beyond Thursday, March 31. If definite results are
                            not then reached, I shall close negotiations.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Woodford.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>