                subtype="historical-document" type="document" xml:id="d1063">
                <head>
                    <hi rend="italic">Sir <persName type="from">Julian Pauncefote</persName> to Mr.
                            <persName type="to">Sherman</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-02-21">
                            <hi rend="italic">February 21, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: At the request of Sir Alfred Maloney, governor of
                    the Windward Islands, I have the honor to convey the heartfelt sympathy of that
                    colony with the Government and people of the United States in the loss sustained
                    through the explosion on board the <hi rend="italic">Maine</hi>.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Julian Pauncefote.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
