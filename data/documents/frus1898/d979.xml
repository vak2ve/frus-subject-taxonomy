    <text>
        <body>
            <div frus:doc-dateTime-max="1898-03-11T23:59:59-05:00"
                frus:doc-dateTime-min="1898-03-11T00:00:00-05:00" n="979"
                subtype="historical-document" type="document" xml:id="d979">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Sherman</persName> to Mr. <persName
                            type="to">Woodford</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-03-11">
                            <hi rend="italic">March 11, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 158.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your No.
                    158, of the 25th ultimo, quoting the remarks made by you at the dinner which you
                    gave to Señor Polo de Barnabé, the recently appointed minister from Spain to the
                    United States. They are cordially approved by this Government.</p>
                <p>Respectfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Sherman.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
