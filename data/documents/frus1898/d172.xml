<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-12-02T23:59:59-05:00" frus:doc-dateTime-min="1898-12-02T00:00:00-05:00" n="172" subtype="historical-document" type="document" xml:id="d172">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Conger</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1898-12-02"><hi rend="italic">December 2,
                                1898</hi></date>.</dateline></opener>
                        <p rend="flushleft"><hi rend="smallcaps">Conger</hi>, <hi rend="italic">Minister, Peking:</hi></p>
                        <p><hi rend="italic">Boston</hi> sails soon. If marines do not return before
                            navigation closes they must remain at Peking indefinitely.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hay.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>