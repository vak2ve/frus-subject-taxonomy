                subtype="historical-document" type="document" xml:id="d886">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Day</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-06-01">
                            <hi rend="italic">June 1, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 668.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to inform you that your dispatch No. 393,
                    of the 14th ultimo, reporting further conversation of the British ambassador at
                    Madrid with the Spanish minister of foreign affairs in regard to the treaty of
                    1795 and of the Protocol of the 12th of January, 1877, and its alleged
                    abrogation by Spain, has been received.</p>
                <p>Respectfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William R. Day.</hi>
                    </signed>
                </closer>
            </div>
        </body>
