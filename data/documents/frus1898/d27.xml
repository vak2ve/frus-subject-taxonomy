                subtype="historical-document" type="document" xml:id="d27">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Ridgely</persName> to Mr. <persName
                            type="to">Day</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Geneva</hi>
                        </placeName>, <date calendar="gregorian" when="1898-09-10">
                            <hi rend="italic">September 10, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>Empress of Austria just assassinated here by Italian anarchist.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Ridgely</hi>, <hi rend="italic">Consul.</hi>
                    </signed>
                </closer>
            </div>
        </body>
