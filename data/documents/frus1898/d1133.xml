                        <head>
                            <hi rend="italic">Mr. <persName type="from">Straus</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]<note n="1" xml:id="d1133fn1">See <ref target="frus1895p2#pg_1470">Foreign Relations, 1895,
                                        Part 2, pp. 1470</ref>–<ref target="frus1895p2#pg_1471">1471</ref>.</note></seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Legation of the United States</hi>,<lb/><hi rend="italic">Constantinople</hi></placeName>, <date calendar="gregorian" when="1898-11-07"><hi rend="italic">November 7,
