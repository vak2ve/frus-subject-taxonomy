                subtype="historical-document" type="document" xml:id="d1061">
                <head>
                    <hi rend="italic">Sir <persName type="from">Julian Pauncefote</persName> to Mr.
                            <persName type="to">Sherman</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-02-17">
                            <hi rend="italic">February 17, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that I am
                    commanded by the Queen to convey to the President the expression of Her
                    Majesty’s sympathy with the American people on the occasion of the sad disaster
                    which has befallen their Navy by the loss of the battle ship <hi rend="italic"
                        >Maine</hi> and of so many members of her crew. I request that you will be
                    good enough to transmit the above message to its high destination.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Julian Pauncefote.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
