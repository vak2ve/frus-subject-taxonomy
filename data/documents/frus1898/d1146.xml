                subtype="historical-document" type="document" xml:id="d1146">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Andrade</persName> to Mr. <persName
                            type="to">Adee</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States of Venezuela</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-04-28">
                            <hi rend="italic">April 28, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your communication of yesterday, together with the three copies which
                    accompanied it, of the proclamation of the President of the United States in
                    regard to the existence of war between the United States and Spain.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">José Andrade.</hi>
                    </signed>
                </closer>
            </div>
        </body>
