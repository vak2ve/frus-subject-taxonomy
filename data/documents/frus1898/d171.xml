<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-11-30T23:59:59-05:00" frus:doc-dateTime-min="1898-11-30T00:00:00-05:00" n="171" subtype="historical-document" type="document" xml:id="d171">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Conger</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Legation of the United States</hi>,<lb/><hi rend="italic">Peking</hi></placeName>, <date calendar="gregorian" when="1898-11-30"><hi rend="italic">November 30,
                                    1898</hi></date>.</dateline></opener>
                        <p rend="flushleft"><hi rend="smallcaps">Hay</hi>, <hi rend="italic">Washington:</hi></p>
                        <p>Quiet at present, but guards should remain all the winter.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Conger.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>