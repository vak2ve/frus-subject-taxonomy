                subtype="historical-document" type="document" xml:id="d1100">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Woodford</persName> to Mr. <persName
                            type="to">Sherman</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1898-04-16">
                            <hi rend="italic">April 16, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 226.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I am this morning in receipt of telegram from Mr.
                    Bartleman, United States consul at Malaga, Spain, stating that his residence was
                    stoned last evening. I have at once asked the Spanish Government to protect all
                    United States consuls and consular offices throughout Spain.</p>
                <p>Respectfully,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stewart L. Woodford</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
