    <text>
        <body>
            <div frus:doc-dateTime-max="1898-05-14T23:59:59-05:00"
                frus:doc-dateTime-min="1898-05-14T00:00:00-05:00" n="409"
                subtype="historical-document" type="document" xml:id="d409">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Allen</persName> to Mr. <persName
                            type="to">Day</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Seoul, Korea</hi>
                        </placeName>, <date calendar="gregorian" when="1898-05-14">
                            <hi rend="italic">May 14, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 106. Diplomatic]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that, in
                    accordance with the Department’s instructions contained in your dispatch No. 63,
                    of March 29 last, I have conveyed to His Majesty the Emperor of Korea my
                    Government’s congratulations on the assumption of his new title.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Horace N. Allen.</hi>
                    </signed>
                </closer>
            </div>
        </body>
