    <text>
        <body>
            <div frus:doc-dateTime-max="1898-11-29T07:21:00-05:00"
                frus:doc-dateTime-min="1898-11-29T07:21:00-05:00" n="854"
                subtype="historical-document" type="document" xml:id="d854">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Moore</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date ana="#date_imprecise-inferred-from-document-content"
                            calendar="gregorian" when="1898-11-29T12:30:00+00:09">
                            <hi rend="italic">November 29, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 32.]</seg>
                </opener>
                <p>The American Commissioners propose to offer Spain for cession of Kusaie and
                    concession of cable-landing rights in other Spanish territory the sum of a
                    million dollars.</p>
                <closer>
                    <dateline rendition="#left">
                        <date calendar="gregorian" when="1898-11-29T12:30:00+00:09">Tuesday
                            afternoon, 12.30</date>.</dateline>
                    <lb/>
                    <signed>
                        <hi rend="smallcaps">Moore.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
