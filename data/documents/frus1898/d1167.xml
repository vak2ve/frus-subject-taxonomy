    <text>
        <body>
            <div frus:doc-dateTime-max="1898-07-23T23:59:59-05:00"
                frus:doc-dateTime-min="1898-07-23T00:00:00-05:00" n="1167"
                subtype="historical-document" type="document" xml:id="d1167">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hengelmüller</persName> to Mr.
                            <persName type="to">Day</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Imperial and Royal Austro-Hungarian Legation</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-07-23">
                            <hi rend="italic">July 23, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: I have the honor, Mr.
                    Secretary of State, to acknowledge, with thanks, the reception of the note of
                    July 15 instant, by which you make known to me the new regulations relative to
                    war vessels of neutral powers entering blockaded ports.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hengelmüller</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
