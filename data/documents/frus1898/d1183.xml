    <text>
        <body>
            <div frus:doc-dateTime-max="1898-07-25T23:59:59-05:00"
                frus:doc-dateTime-min="1898-07-25T00:00:00-05:00" n="1183"
                subtype="historical-document" type="document" xml:id="d1183">
                <head>
                    <hi rend="italic">Mr. <persName type="from">de Weckherlin</persName> to Mr.
                            <persName type="to">Day</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the Netherlands</hi>,<lb/>
                            <hi rend="italic">New York</hi>
                        </placeName>, <date calendar="gregorian" when="1898-07-25">
                            <hi rend="italic">July 25, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: I have the honor to
                    acknowledge reception of the communication which you have been pleased to
                    address to me the 15th instant on the subject of the blockade, by the United
                    States of America, of various ports of the island of Cuba, as also of other
                    blockades which have been or will be declared by the United States.</p>
                <p>Be pleased to accept, etc.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">G. de Weckherlin.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
