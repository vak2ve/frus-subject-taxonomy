<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1899-03-13T23:59:59-05:00" frus:doc-dateTime-min="1899-03-13T00:00:00-05:00" n="174" subtype="historical-document" type="document" xml:id="d174">
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Conger</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi>
                        </head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Legation of the United States</hi>,<lb/><hi rend="italic">Peking</hi></placeName>, <date calendar="gregorian" when="1899-03-13"><hi rend="italic">March 13,
                                1899</hi></date>.</dateline></opener>
                        <p rend="flushleft"><hi rend="smallcaps">Hay</hi>, <hi rend="italic">Washington:</hi></p>
                        <p>Our marines left Pekin to-day.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Conger.</hi>
                            </signed>
                        </closer>
                    </div>
