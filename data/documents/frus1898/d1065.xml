                subtype="historical-document" type="document" xml:id="d1065">
                <head>
                    <hi rend="italic">Mr. <persName type="from">White</persName> to Mr. <persName
                            type="to">Sherman</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Embassy of the United States</hi>,<lb/>
                            <hi rend="italic">London</hi>
                        </placeName>, <date calendar="gregorian" when="1898-02-19">
                            <hi rend="italic">February 19, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Sherman</hi>, <hi rend="italic">Secretary, Washington.</hi>
                </p>
                <p>Have received expression profound sympathy with our Government and Navy from Duke
                    and Duchess of York. As a sailor the Duke deeply feels terrible catastrophe to
                        <hi rend="italic">Maine</hi>. Have carried out your recent telegraphic
                    instructions.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">White.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
