                        <head>
                            <hi rend="italic">General <persName type="from">Lee</persName> to Mr.
                                    <persName type="to">Day</persName>.</hi>
                        </head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Havana</hi></placeName>, <date calendar="gregorian" when="1898-01-25"><hi rend="italic">January 25,
                                1898</hi></date>.</dateline></opener>
