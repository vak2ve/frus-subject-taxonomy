<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-11-22T23:59:59-05:00" frus:doc-dateTime-min="1898-11-22T00:00:00-05:00" n="843" subtype="historical-document" type="document" xml:id="d843">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Day</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1898-11-22"><hi rend="italic">November 22,
                                    1898</hi></date>.</dateline></opener>
                        <p>(Special.)</p>
                        <p>Your special to the President dated to-day received. Your proposed action
                            approved.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hay.</hi>
                            </signed>
                        </closer>
