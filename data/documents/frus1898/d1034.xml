    <text>
        <body>
            <div frus:doc-dateTime-max="1898-03-31T23:59:59-05:00"
                frus:doc-dateTime-min="1898-03-31T00:00:00-05:00" n="1034"
                subtype="historical-document" type="document" xml:id="d1034">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Sherman</persName> to Mr. <persName
                            type="to">Woodford</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-03-31">
                            <hi rend="italic">March 31, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 177.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I transmit herewith six copies of Senate Document
                    No. 207,<note n="2" xml:id="d1034fn2">Not printed herein.</note> Fifty-fifth
                    Congress, second session, containing the message of the President, transmitting
                    the report of the naval court of inquiry upon the destruction of the United
                    States battle ship <hi rend="italic">Maine</hi> in Habana Harbor, February 15,
                    1898, together with the testimony taken before the court.</p>
                <p>Respectfully, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Sherman.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
