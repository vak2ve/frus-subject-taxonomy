<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-07-26T23:59:59-05:00" frus:doc-dateTime-min="1898-07-26T00:00:00-05:00" n="935" subtype="historical-document" type="document" xml:id="d935">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Moore</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi></placeName>, <date calendar="gregorian" when="1898-07-26"><hi rend="italic">July
                                        26, 1898</hi></date>.</dateline></opener>
                        <p>Consul at Martinique instructed to issue safe conduct to <hi rend="italic">San Augustin</hi>, and to allow surgeons and nurses to
                            accompany ship.</p>
                        <closer>
                            <signed><hi rend="smallcaps">Moore</hi>, <hi rend="italic">Assistant.</hi></signed>
                        </closer>
                    </div>
                    </body></text></TEI>