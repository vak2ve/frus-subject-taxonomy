                subtype="historical-document" type="document" xml:id="d30">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Herdliska</persName> to Mr.
                            <persName type="to">Day</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Budisgdor</hi>
                        </placeName>, <date calendar="gregorian" when="1898-09-11">
                            <hi rend="italic">September 11, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>The Empress of Austria was assassinated last evening at Territe, Switzerland, by
                    an Italian anarchist.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Herdliska</hi>, <hi rend="italic">Chargé.</hi>
                    </signed>
                </closer>
            </div>
        </body>
