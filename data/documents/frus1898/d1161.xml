<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-06-30T23:59:59-05:00" frus:doc-dateTime-min="1898-06-30T00:00:00-05:00" n="1161" subtype="historical-document" type="document" xml:id="d1161">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Moore</persName> to Mr.
                                    <persName type="to">Loomis</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1898-06-30"><hi rend="italic">June 30,
                                1898</hi></date>.</dateline></opener>
                        <p rend="flushleft"><hi rend="smallcaps">Loomis</hi>, <hi rend="italic">Minister, Caracas:</hi></p>
                        <p>Accept offer $1,600 cash and full reimbursement property taken or
                            destroyed by Government, with liberty Scandella’s formal concurrence in
                            settlement.</p>
                        <closer>
                            <signed><hi rend="smallcaps">Moore</hi>, <hi rend="italic">Acting.</hi></signed>
                        </closer>
                    </div>
                    </body></text></TEI>