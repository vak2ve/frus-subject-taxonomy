<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-09-29T23:59:59-05:00" frus:doc-dateTime-min="1898-09-29T00:00:00-05:00" n="781" subtype="historical-document" type="document" xml:id="d781">
                        <head>
                            <hi rend="italic">The <gloss type="from">President</gloss> to Mr.
                                    <persName type="to">Day</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1898-09-29"><hi rend="italic">September 29,
                                    1898</hi></date>.</dateline></opener>
                        <p>Present my congratulations to the Commissioners upon their safe arrival
                            in good health and the auspicious beginning of their important work.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">William McKinley.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>