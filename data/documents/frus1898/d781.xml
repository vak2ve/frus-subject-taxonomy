                subtype="historical-document" type="document" xml:id="d781">
                <head>
                    <hi rend="italic">The <gloss type="from">President</gloss> to Mr. <persName
                            type="to">Day</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-09-29">
                            <hi rend="italic">September 29, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>Present my congratulations to the Commissioners upon their safe arrival in good
                    health and the auspicious beginning of their important work.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William McKinley.</hi>
                    </signed>
                </closer>
            </div>
        </body>
