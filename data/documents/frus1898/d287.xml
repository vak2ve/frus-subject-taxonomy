<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-05-12T23:59:59-05:00" frus:doc-dateTime-min="1898-05-12T00:00:00-05:00" n="287" subtype="historical-document" type="document" xml:id="d287">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Day</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1898-05-12"><hi rend="italic">May 12,
                                1898</hi></date>.</dateline></opener>
                        <p>Telegram about missionaries received. Inquire as to the fate of Mr. and
                            Mrs. L. A. McGrew, stationed about 40 miles farther interior than
                            Rotifunk.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Day.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>