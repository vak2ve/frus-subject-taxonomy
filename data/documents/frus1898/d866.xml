                subtype="historical-document" type="document" xml:id="d866">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Day</persName> to Sir <persName
                            type="to">Julian Pauncefote</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-04-05">
                            <hi rend="italic">April 5, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">
                        <hi rend="smallcaps">Confidential</hi>,<lb/>No. 966.</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to request that, in case
                    of trouble between Spain and the United States, the British consul-general at
                    Habana may take charge of the American property and papers belonging to the
                    American, consulate there, which will be turned over by General Lee to him. I
                    have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William R. Day.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
