<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-10-30T23:59:59-05:00" frus:doc-dateTime-min="1898-10-30T00:00:00-05:00" n="821" subtype="historical-document" type="document" xml:id="d821">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Day</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1898-10-30"><hi rend="italic">October 30,
                                1898</hi></date>.</dateline></opener>
                        <p>Your No. 19 received. Your proposition to assume any existing
                            indebtedness of Spain incurred for public works and improvements of a
                            pacific character in the Philippines is approved.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hay.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>