    <text>
        <body>
            <div frus:doc-dateTime-max="1898-02-16T23:59:59-05:00"
                frus:doc-dateTime-min="1898-02-16T00:00:00-05:00" n="1072"
                subtype="historical-document" type="document" xml:id="d1072">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Leger</persName> to Mr. <persName
                            type="to">Sherman</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the Republic of Haiti</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-02-16">
                            <hi rend="italic">February 16, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: The news of the sad accident
                    which has befallen the <hi rend="italic">Maine</hi> has deeply touched me, and I
                    beg leave to express my condolence and sympathy with the families of the
                    unfortunate victims. My Government can not fail to feel deep concern on account
                    of the loss which the United States have just experienced.</p>
                <p>Be pleased to accept etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">J. N. Leger.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
