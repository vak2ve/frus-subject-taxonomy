                subtype="historical-document" type="document" xml:id="d74">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Day</persName> to Mr. <persName
                            type="to">Hengelmüller</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1898-04-16">
                            <hi rend="italic">April 16, 1898</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 216.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to transmit herewith copy of the
                    report made to this Department by Hon. Henry M. Hoyt, Assistant Attorney-General
                    of the United States, of the trial of Sheriff Martin and his deputies, at
                    Wilkesbarre, Pa., on the charge of killing and wounding certain Austrian
                    subjects and others at Lattimer, Pa., on September 10, 1897.</p>
                <p>I avail myself, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William R. Day.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
