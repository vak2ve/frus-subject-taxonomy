<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-02-18T23:59:59-05:00" frus:doc-dateTime-min="1898-02-18T00:00:00-05:00" n="1037" subtype="historical-document" type="document" xml:id="d1037">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Garcia Meron</persName> to
                                Mr. <persName type="to">Sherman</persName>.</hi>
                        </head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Legation of the Argentine Republic</hi>,<lb/><hi rend="italic">Southampton</hi></placeName>, <date calendar="gregorian" when="1898-02-18"><hi rend="italic">February 18, 1898</hi></date>.</dateline></opener>
                        <p rend="flushleft">Secretary <hi rend="smallcaps">Sherman</hi>, <hi rend="italic">Washington, D. C.:</hi></p>
                        <p>I beg your excellency to accept the deepest expressions of my condolence
                            for the disaster which mourns the American nation.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Garcia Meron.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>