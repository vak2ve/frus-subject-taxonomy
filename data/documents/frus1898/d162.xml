    <text>
        <body>
            <div frus:doc-dateTime-max="1898-11-01T23:59:59-05:00"
                frus:doc-dateTime-min="1898-11-01T00:00:00-05:00" n="162"
                subtype="historical-document" type="document" xml:id="d162">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Conger</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1898-11-01">
                            <hi rend="italic">November 1, 1898</hi>
                        </date>.</dateline>
                </opener>
                <p>Have requested <hi rend="italic">Boston</hi> to send 18 marines Peking and 30
                    Tientsin.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Conger.</hi>
                    </signed>
                </closer>
            </div>
        </body>
