<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1894-07-07T23:59:59-05:00" frus:doc-dateTime-min="1894-07-07T00:00:00-05:00" n="412" subtype="historical-document" type="document" xml:id="d412">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Señor
                                    <persName type="to">Romero</persName>.</hi>
                        </head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1894-07-07"><hi rend="italic">July 7,
                                1894</hi></date>.</dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your note of the 3d instant,<note n="1" xml:id="d412fn1">Not
                                printed.</note> transmitting evidence of the Mexican citizenship of
                            Inez Ruiz and Jesus Guerra, who have been committed for extradition by
                            the United States commissioner at San Antonio, Tex.</p>
                        <p>Accept, sir,</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">W. Q. Gresham.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>