<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1898-02-18T23:59:59-05:00" frus:doc-dateTime-min="1898-02-18T00:00:00-05:00" n="1079" subtype="historical-document" type="document" xml:id="d1079">
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Chin Pom Ye</persName> to
                                Mr. <persName type="to">Sherman</persName>.</hi>
                        </head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Legation of Korea</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1898-02-18"><hi rend="italic">February 18,
                                    1898</hi></date>.</dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I hereby desire to express on behalf of
                            His Majesty the Emperor and the Government of Korea sympathy with the
                            United States on the loss of the battle ship <hi rend="italic">Maine</hi> and so many brave officers and men.</p>
                        <p>Accept, etc.,</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Chin Pom Ye.</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>