<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1866-11-16T23:59:59-05:00" frus:doc-dateTime-min="1866-11-16T00:00:00-05:00" n="167" subtype="historical-document" type="document" xml:id="d167">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName></head>
                        <opener>
                            <seg rendition="#left">No. 1875.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                                <date calendar="gregorian" when="1866-11-16"><hi rend="italic">November</hi> 16, 1866.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> I transmit for your information a printed
                            copy of an instruction<note n="*" xml:id="d167fn1">For enclosure see
                                correspondence with Mexico.</note> of the 25th ultimo, addressed to
                            Lewis D. Campbell, esq., our newly accredited minister to the republic
                            of Mexico.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>