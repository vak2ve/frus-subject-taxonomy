    <text>
        <body>
            <div frus:doc-dateTime-max="1866-10-08T23:59:59-05:00" frus:doc-dateTime-min="1866-10-08T00:00:00-05:00" n="430" subtype="historical-document" type="document" xml:id="d430">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Hale</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 48.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1866-10-08">
                            <hi rend="italic">October</hi> 8, 1866.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Your despatch of the 15th of September,
                            No. 58, has been received, and is approved.</p>
                <p>The sentiments expressed by the Spanish government, in reply to. your
                            communication therein mentioned, are in harmony with the general policy
                            of Spain, as understood here, and are very acceptable.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">John P. Hale,</hi> Esq., <hi rend="italic">&amp;c., &amp;c</hi>
                        <hi rend="italic">., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
