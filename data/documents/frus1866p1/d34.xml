                <head>
                    <persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                        Adams</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 1647.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1866-01-06">
                            <hi rend="italic">January</hi> 6, 1866.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: At the request of the Secretary of the Treasury I
                    transmit for your information, and for such use as you may deem proper, copies
                    of the monthly statement of the public debt of the United States.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>W. HUNTER, <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Charles Francis Adams, Esq., &amp;</hi>
                        <hi rend="italic">c</hi>, <hi rend="italic">&amp;c., &amp;c</hi>
                        <hi rend="smallcaps">.</hi>
                    </p>
                    <p>(Same<hi rend="italic">, mutatis mutandis,</hi> to all U. S. ministers.)</p>
                    <pb facs="0131" n="57" xml:id="pg_57"/>
