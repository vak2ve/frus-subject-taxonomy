    <text>
        <body>
            <div frus:doc-dateTime-max="1866-06-19T23:59:59-05:00"
                frus:doc-dateTime-min="1866-06-19T00:00:00-05:00" n="496"
                subtype="historical-document" type="document" xml:id="d496">
                <head>
                    <persName type="from">Mr. Motley</persName> to <persName type="to">Mr.
                        Seward</persName>.</head>
                <opener>
                    <seg rendition="#left">No. 189.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>, <hi
                                rend="italic">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1866-06-19">
                            <hi rend="italic">June</hi> 19, 1866.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge receipt of your
                    Nos. 183 to 187, inclusive, together with a copy of your note of April 25, to
                    the Marquis de Montholon.</p>
                <pb facs="0745" n="671" xml:id="pg_671"/>
                <p>I beg to thank you for the communication of this very important and interesting
                    document, and at the same time to express my sincere gratification that my
                    proceedings in regard to the volunteers for Mexico have met with the approval of
                    the President.</p>
                <p>Meantime, I have the honor to remain, sir, your obedient servant,</p>
                <closer>
                    <signed>J. LOTHROP MOTLEY</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">Secretary
                            of State, Washington, D. C.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
