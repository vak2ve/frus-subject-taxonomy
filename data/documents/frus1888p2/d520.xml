    <text>
        <body>
            <div frus:doc-dateTime-max="1888-11-28T23:59:59-05:00" frus:doc-dateTime-min="1888-11-28T00:00:00-05:00" n="520" subtype="historical-document" type="document" xml:id="d520">
                <head>No. 65.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName> to Mr. <persName type="to">Herbert</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1888-11-28">
                            <hi rend="italic">November</hi> 28,
                                    1888</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your note of the 23d instant, stating that the owners of the
                                <hi rend="italic">Ada</hi>, one of the four British vessels
                            condemned for taking seals illicitly in Behring Sea, do not object to
                            the original appraisement, and to say that I have made known the
                            contents thereof to the Attorney-General.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">T. F. Bayard.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
