                subtype="historical-document" type="document" xml:id="d394">
                <head>No. 1107.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Rives</persName> to <persName
                            type="to">Mavroyeni Bey</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1888-11-03">
                            <hi rend="italic">November</hi> 3, 1888</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge receipt of your
                    note of the 30th ultimo, explaining that the recent regulations of the Sublime
                    Porte relative to the sojourn of Jews in Palestine are only applicable to Israel
                    ites emigrating in a body, and saying that no obstacle will be raised against
                    those who do not fall within this class.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">G. L. Rives</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
