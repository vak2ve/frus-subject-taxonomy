<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1888-12-01T23:59:59-05:00" frus:doc-dateTime-min="1888-12-01T00:00:00-05:00" n="116" subtype="historical-document" type="document" xml:id="d116">
                    <head>No. 829.<lb/><hi rend="italic">Mr. <persName type="from">Bayard</persName>
                            to Mr. <persName type="to">Whitehouse</persName>.</hi></head>
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department
                                    of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1888-12-01"><hi rend="italic">December</hi> 1,
                            1888</date>.</dateline></opener>
                    <p rend="flushleft"><hi rend="smallcaps">Whitehouse</hi>,<lb/><hi rend="italic">Chargé, Mexico:</hi></p>
                    <p>The President desires you to present to President Diaz his compliments and
                        congratulations at the entrance upon a new term of administration under
                        which Mexico has so prospered.</p>
                    <closer><signed><hi rend="smallcaps">Bayard.</hi></signed></closer>
                </div>
                </body></text></TEI>