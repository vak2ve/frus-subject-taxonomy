                    <head>No. 1010.<lb/><hi rend="italic">Mr. <persName type="from">Magee</persName>
                            to Mr. <persName type="to">Bayard</persName>.</hi></head>
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Stockholm</hi></placeName>, <date calendar="gregorian" when="1888-09-09"><hi rend="italic">September</hi> 9,
                            1888</date>.</dateline></opener>
                    <p rend="flushleft"><hi rend="smallcaps">Bayard</hi>,<lb/><hi rend="italic">Secretary, Washington:</hi></p>
                    <p>Albert Erbers, <hi rend="italic">alias</hi> Eberson, is arrested.</p>
                    <closer><signed><hi rend="smallcaps">Magee.</hi></signed></closer>
