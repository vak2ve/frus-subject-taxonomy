    <text>
        <body>
            <div frus:doc-dateTime-max="1888-11-06T23:59:59-05:00" frus:doc-dateTime-min="1888-11-06T00:00:00-05:00" n="104" subtype="historical-document" type="document" xml:id="d104">
                <head>No. 817.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName>
                            to Mr. <persName type="to">Whitehouse</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1888-11-06">
                            <hi rend="italic">November</hi> 6,
                            1888</date>.</dateline>
                    <seg rendition="#left">No. 158.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have received your dispatch No. 175, of the
                        29th ultimo, relative to the case of Shields and Wilson, whose extradition
                        has been demanded, and have transmitted a copy of the same to the
                        Attorney-General for his further information.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alvey A. Adee</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
