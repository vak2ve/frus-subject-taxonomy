                subtype="historical-document" type="document" xml:id="d445">
                <head>No. 4.<lb/>
                    <hi rend="italic">Lord <persName type="from">Sackville</persName> to the <gloss
                            type="to">Marquis of Salisbury</gloss>.—</hi>(<hi rend="italic">Received
                        November</hi> 8.)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1888-10-30">
                            <hi rend="italic">October</hi> 30, 1888</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Lord</hi>: With reference to my telegram of this day’s
                    date, I have the honor to inclose copy of a note addressed to me by the
                    Secretary of State informing me that the President of the United States has
                    become convinced that, for causes known to myself and to Her Majesty’s
                    Government, my present official position in the United States is incompatible
                    with-the best interests and detrimental to the relations of both Governments,
                    and transmitting at the same time to me my passports.</p>
                <p>I have, etc.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sackville.</hi>
                    </signed>
                </closer>
                <frus:attachment>
                    <opener>
                        <seg rendition="#center">[Inclosure in No. 4.]</seg>
                    </opener>
                    <head>
                        <hi rend="italic">Mr. <persName type="from">Bayard</persName> to Lord
                                <persName type="to">Sackville</persName>, October</hi> 30,
                        1888.</head>
                    <p>(Omitted here, being printed <hi rend="italic">supra</hi>, No. 6.)</p>
                </frus:attachment>
            </div>
        </body>
    </text>
