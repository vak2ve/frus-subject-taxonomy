                subtype="historical-document" type="document" xml:id="d473">
                <head>No. 18.<lb/>
                    <hi rend="italic">Sir <persName type="from">L. S. Sackville West</persName> to
                        Mr. <persName type="to">Bayard</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">British Legation</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1887-09-29">
                            <hi rend="italic">September</hi> 29, 1887</date>. (Received September
                        29.)</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that Her Majesty’s
                    Government have been officially informed that the British vessels, mentioned in
                    your note of the 3d of February last, have not been released, and that I am
                    instructed to inquire the reason for the delay in complying with the orders sent
                    to this effect, as stated in your above-mentioned note.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">L. S. Sackville West.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
