    <text>
        <body>
            <div frus:doc-dateTime-max="1888-06-05T23:59:59-05:00" frus:doc-dateTime-min="1888-06-05T00:00:00-05:00" n="374" subtype="historical-document" type="document" xml:id="d374">
                <head>No. 1087.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName> to Mr. <persName type="to">Straus</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1888-06-05">
                            <hi rend="italic">June</hi> 5,
                            1888</date>.</dateline>
                    <seg rendition="#left">No. 107.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I desire to acknowledge the receipt of your
                        No. 80, of the 19th ultimo, in regard to the restrictions of the Sublime
                        Porte against foreign Jews resorting to Palestine, and to approve your
                        presentation of the matter to the minister for foreign affairs.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">T. F. Bayard</hi>.</signed>
                </closer>
            </div>
        </body>
