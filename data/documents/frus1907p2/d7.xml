                subtype="historical-document" type="document" xml:id="d7">
                <note rend="inline" type="source">File No. 1012/5.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Minister <persName type="to">Combs</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-02-12">
                            <hi rend="italic">February 12, 1907</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 322.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                    dispatch No. 516, of the 23d ultimo, reporting the successful use of your good
                    offices to obtain redress for a clerk of a Chinese firm, who had been arrested
                    and assaulted by a Guatemalan policeman.</p>
                <p>Your friendly intervention in behalf of this Chinese subject is approved by the
                    department.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Bacon.</hi>
                    </signed>
                </closer>
            </div>
        </body>
