                subtype="historical-document" type="document" xml:id="d299">
                <note rend="inline" type="source">File No. 7370/2 a.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Peirce</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-12-20">
                            <hi rend="italic">December 20, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>Convey to Mrs. Hauge an expression of sincere sympathy and regret over the death
                    of her husband, whose loss we shall feel deeply in America.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Root.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
