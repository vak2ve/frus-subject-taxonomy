    <text>
        <body>
            <div frus:doc-dateTime-max="1907-09-06T23:59:59-05:00"
                frus:doc-dateTime-min="1907-09-06T00:00:00-05:00" n="95"
                subtype="historical-document" type="document" xml:id="d95">
                <note rend="inline" type="source">File No. 6775/93.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Guatemalan Minister</gloss> to the
                            <gloss type="to">Acting Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Guatemala</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-09-06">
                            <hi rend="italic">September 6, 1907</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 30.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform the Department of
                    State that I received a cablegram on the 5th instant from the minister of
                    foreign relations of Guatemala in which he expresses to me the desire of my
                    Government that the Central American Peace Conference, to which invitations were
                    sent by Their Excellencies Presidents Roosevelt and Diaz, be held in Washington
                    as soon as possible.</p>
                <p>I embrace this opportunity, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Luis Toledo Herrarte.</hi>
                    </signed>
                </closer>
            </div>
        </body>
