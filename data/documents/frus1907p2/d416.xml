                <note rend="inline" type="source">File No. 4960/77.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                        Ambassador <persName type="to">Leishman</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-06-17">
                            <hi rend="italic">June 17, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>Acknowledges Mr. Irishman’s No. 48, expresses appreciation, and extends
                    congratulations.</p>
