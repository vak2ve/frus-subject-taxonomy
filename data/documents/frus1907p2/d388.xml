    <text>
        <body>
            <div frus:doc-dateTime-max="1907-12-08T23:59:59-05:00"
                frus:doc-dateTime-min="1907-12-08T00:00:00-05:00" n="388"
                subtype="historical-document" type="document" xml:id="d388">
                <note rend="inline" type="source">File No. 3123/6.</note>
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to the
                            <gloss type="to">King of Sweden</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-12-08">
                            <hi rend="italic">December 8, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>I deeply sympathize with Your Majesty and with the people of Sweden in the loss
                    of an honored father and a venerated sovereign.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
