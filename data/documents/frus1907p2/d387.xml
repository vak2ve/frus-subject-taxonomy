                <note rend="inline" type="source">File No. 3123/6.</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Graves</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Stockholm</hi>
                        </placeName>, <date calendar="gregorian" when="1907-12-08">
                            <hi rend="italic">December 8, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>King Oscar of Sweden died this morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Graves.</hi>
                    </signed>
                </closer>
            </div>
        </body>
