<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1907-04-26T23:59:59-05:00" frus:doc-dateTime-min="1907-04-26T00:00:00-05:00" n="503" subtype="historical-document" type="document" xml:id="d503">
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to Minister <persName type="to">Hill</persName>.</hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1907-04-26"><hi rend="italic">April 26,
                                        1907</hi></date>.</dateline></opener>
                            <p><hi rend="smallcaps">Sir</hi>: I have to inform you that the
                                Argentine Republic has appointed as its delegates to the Second
                                Hague Conference Messrs. Luis M. Drago, Carlos Rodriguez Larreta,
                                and Roque Saenz Peña.</p>
                            <p>I am etc.,</p>
                            <closer><signed><hi rend="smallcaps">E. Root.</hi></signed></closer>
                        </div>
                        </body></text></TEI>