<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1907-05-04T23:59:59-05:00" frus:doc-dateTime-min="1907-05-04T00:00:00-05:00" n="410" subtype="historical-document" type="document" xml:id="d410">
                        <note rend="inline" type="source">File No. 4960/54.</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Ambassador <persName type="to">Leishman</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.—Extract.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1907-05-04"><hi rend="italic">May 4,
                                1907</hi></date>.</dateline></opener>
                        <p>(Refers to Embassy’s No. 42 of May 3, and informs him that he is
                            authorized to give the adhesion of this Government to customs
                            increase.)</p>
                    </div>
                    </body></text></TEI>