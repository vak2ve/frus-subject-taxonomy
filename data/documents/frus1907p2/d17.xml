<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1907-05-01T23:59:59-05:00" frus:doc-dateTime-min="1907-05-01T00:00:00-05:00" n="17" subtype="historical-document" type="document" xml:id="d17">
                        <note rend="inline" type="source">File No. 2553/3.</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Lee</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1907-05-01"><hi rend="italic">May 1,
                                1907</hi></date>.</dateline></opener>
                        <p>Congratulate President Estrada in name of President and Government on his
                            escape.</p>
                        <closer><signed><hi rend="smallcaps">Root.</hi></signed></closer>
                    </div>
