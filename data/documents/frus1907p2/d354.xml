                <note rend="inline" type="source">File No. 4757/16–17.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Ambassador <persName type="to">Riddle</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-05-15">
                            <hi rend="italic">May 15, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>Draw for $3,000 and pay Russian Red Cross, relief famine sufferers, received from
                    American Red Cross.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bacon.</hi>
                    </signed>
                </closer>
            </div>
        </body>
