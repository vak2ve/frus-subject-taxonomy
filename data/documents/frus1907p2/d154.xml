                subtype="historical-document" type="document" xml:id="d154">
                <note rend="inline" type="source">File No. 4880/2.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Furniss</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-03-07">
                            <hi rend="italic">March 7, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>(Refers to Mr. Furniss’s cable of March 6 and directs him to take no action
                    beyond the protest authorized in the department’s cable of March 5 until further
                    instructed.)</p>
            </div>
        </body>
