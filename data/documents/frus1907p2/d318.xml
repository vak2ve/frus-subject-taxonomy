<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1907-01-11T23:59:59-05:00" frus:doc-dateTime-min="1907-01-11T00:00:00-05:00" n="318" subtype="historical-document" type="document" xml:id="d318">
                        <note rend="inline" type="source">File No. 3714/4.</note>
                        <head><hi rend="italic">The <gloss type="from">Shah of Persia</gloss> to the
                                    <gloss type="to">President of the United
                            States</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Teheran</hi></placeName>, <date calendar="gregorian" when="1907-01-11"><hi rend="italic">January 11,
                                1907</hi></date>.</dateline></opener>
                        <p>I am deeply touched by the amiable sentiments contained in Your
                            Excellency’s telegram and express to you my most sincere thanks.</p>
                        <closer><signed><hi rend="smallcaps">Mohammed Ali.</hi></signed></closer>
                    </div>
                    </body></text></TEI>