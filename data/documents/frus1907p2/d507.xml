<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1907-05-06T23:59:59-05:00" frus:doc-dateTime-min="1907-05-06T00:00:00-05:00" n="507" subtype="historical-document" type="document" xml:id="d507">
                            <head><hi rend="italic">Minister <persName type="from">Fox</persName> to
                                    the <gloss type="to">Secretary of State</gloss>.</hi></head>
                            <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Quito</hi></placeName>, <date calendar="gregorian" when="1907-05-06"><hi rend="italic">May 6,
                                    1907</hi></date>.</dateline></opener>
                            <p>(Mr. Fox reports that Ecuador will be represented at the Second Peace
                                Conference by Señor Rendon, the Ecuadorean minister to France.)</p>
                        </div>
                    </body></text></TEI>