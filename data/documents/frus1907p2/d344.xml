    <text>
        <body>
            <div frus:doc-dateTime-max="1907-04-18T23:59:59-05:00"
                frus:doc-dateTime-min="1907-04-18T00:00:00-05:00" n="344"
                subtype="historical-document" type="document" xml:id="d344">
                <note rend="inline" type="source">File No. 6200/–1.</note>
                <head>
                    <hi rend="italic">Chargé <persName type="from">Schuyler</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Bucharest</hi>
                        </placeName>, <date calendar="gregorian" when="1907-04-18">
                            <hi rend="italic">April 18, 1907</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 72.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inclose<note n="a"
                        xml:id="d344fna">Not printed.</note> herewith a copy of a part of the
                    Monitorul Oficial for to-day, which contains the original text in French and a
                    translation into Roumanian of the treaty of commerce and navigation between
                    Roumania and France, concluded at Paris on March 6, 1907, and approved by the
                    Roumanian Senate on March 9 (22), to which is appended a “Declaration” and an
                    “Arrangement” concerning the protection of works of literature and art which
                    places France and Roumania reciprocally on the footing of the most favored
                    nations.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Montgomery Schuyler.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
