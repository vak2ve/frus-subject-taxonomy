                <note rend="inline" type="source">File No. 79/118.</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Riddle</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">St. Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1907-06-16">
                            <hi rend="italic">June 16, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>Douma dissolved this morning by imperial proclamation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Riddle.</hi>
                    </signed>
                </closer>
            </div>
        </body>
