<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1907-12-22T23:59:59-05:00" frus:doc-dateTime-min="1907-12-22T00:00:00-05:00" n="144" subtype="historical-document" type="document" xml:id="d144">
                        <note rend="inline" type="source">File No. 6775/272.</note>
                        <head><hi rend="italic">The <gloss type="from">President of
                                    Nicaragua</gloss> to President <persName type="to">Roosevelt</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Translation.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Managua, Nicaragua</hi></placeName>, <date calendar="gregorian" when="1907-12-22"><hi rend="italic">December 22, 1907</hi></date>.</dateline></opener>
                        <p>I send Your Excellency earnest thanks for important participation you
                            were pleased to take in pacific settlement of Central American
                            differences happily brought to an end.</p>
                        <closer><signed><hi rend="smallcaps">J. S. Zelaya.</hi></signed></closer>
                    </div>
                    </body></text></TEI>