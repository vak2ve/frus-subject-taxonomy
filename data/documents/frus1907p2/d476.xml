                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                        Ambassador <persName type="to">Riddle</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-03-19">
                            <hi rend="italic">March 19, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Riddle is directed to make inquiries and to cable when Belgium, China, and
                    Turkey assent.)</p>
            </div>
