                <note rend="inline" type="source">File No. 79/74.</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Meyer</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">St. Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1907-01-03">
                            <hi rend="italic">January 3, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>Launitz, chief police Petersburg, assassinated to-day.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Meyer.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
