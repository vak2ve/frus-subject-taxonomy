                subtype="historical-document" type="document" xml:id="d425">
                <note rend="inline" type="source">File Not 7523.</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Leishman</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">Constantinople</hi>
                        </placeName>, <date calendar="gregorian" when="1907-06-22">
                            <hi rend="italic">June 22, 1907</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 308.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that among the
                    matters which the embassy has recently succeeded in settling has been the
                    admission of certain American patent medicines, the entry of which had
                    previously been forbidden in Turkey. I have just received a note from the
                    ministry for foreign affairs informing me that the former restrictive
                    regulations with regard thereto have now been removed.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John G. A. Leishman.</hi>
                    </signed>
                </closer>
            </div>
        </body>
