    <text>
        <body>
            <div frus:doc-dateTime-max="1907-09-12T23:59:59-05:00"
                frus:doc-dateTime-min="1907-09-12T00:00:00-05:00" n="164"
                subtype="historical-document" type="document" xml:id="d164">
                <note rend="inline" type="source">File No. 8911/–1.</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Griscom</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1907-09-12">
                            <hi rend="italic">September 12, 1907</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 167.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to transmit to you herewith
                    three copies of the Official Gazette,<note n="a" xml:id="d164fna">Not
                        printed.</note> of September 10, 1907, No. 215, containing on pages 5485,
                    5486 the declaration made between Italy and Denmark for the protection of
                    designs and industrial models, signed at Rome March 3, 1907.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lloyd C. Griscom.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
