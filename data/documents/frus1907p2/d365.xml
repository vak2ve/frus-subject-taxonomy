<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1907-01-30T23:59:59-05:00" frus:doc-dateTime-min="1907-01-30T00:00:00-05:00" n="365" subtype="historical-document" type="document" xml:id="d365">
                        <note rend="inline" type="source">File No. 79/85.</note>
                        <head><hi rend="italic">Chargé <persName type="from">Bliss</persName> to the
                                    <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Embassy</hi>,<lb/><hi rend="italic">St.
                                        Petersburg</hi></placeName>, <date calendar="gregorian" when="1907-01-30"><hi rend="italic">January 30,
                                1907</hi></date>.</dateline></opener>
                        <p>Guidema, director Vassili Ostroff prison here, assassinated this morning
                            about 11.</p>
                        <closer><signed><hi rend="smallcaps">Bliss.</hi></signed></closer>
                    </div>
                    </body></text></TEI>