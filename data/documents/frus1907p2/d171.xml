    <text>
        <body>
            <div frus:doc-dateTime-max="1908-01-03T23:59:59-05:00"
                frus:doc-dateTime-min="1908-01-03T00:00:00-05:00" n="171"
                subtype="historical-document" type="document" xml:id="d171">
                <note rend="inline" type="source">File No. 2074/17–18.</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Griscom</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1908-01-03">
                            <hi rend="italic">January 3, 1908</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 252.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: With reference to my dispatch No. 231,<note n="a"
                        xml:id="d171fna">Not printed.</note> of the 3d ultimo, relative to the new
                    treaty of commerce and navigation between Italy and Russia, I have the honor to
                    transmit herewith copies<note n="a" xml:id="d171fnb">Not printed.</note> of No.
                    370 of the Official Gazette of December 30, 1907, containing the text of the
                    said treaty.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lloyd C. Griscom.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
