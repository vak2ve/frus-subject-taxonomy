                subtype="historical-document" type="document" xml:id="d350">
                <note rend="inline" type="source">File No. 4757/1.</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Riddle</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">St. Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1907-02-22">
                            <hi rend="italic">February 22, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>Russian Red Cross is carrying on relief measures and has furnished 3,000,000
                    roubles in last six months, but would nevertheless be grateful for any outside
                    aid.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Riddle.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
