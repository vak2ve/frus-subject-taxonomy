                <note rend="inline" type="source">File No. 79/159.</note>
                <head>
                    <hi rend="italic">Chargé <persName type="from">Schuyler</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">St. Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1907-11-14">
                            <hi rend="italic">Nov. 14, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>Third Douma formally opened to-day.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schuyler.</hi>
                    </signed>
                </closer>
            </div>
        </body>
