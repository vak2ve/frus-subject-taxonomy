<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1907-04-10T23:59:59-05:00" frus:doc-dateTime-min="1907-04-10T00:00:00-05:00" n="351" subtype="historical-document" type="document" xml:id="d351">
                        <note rend="inline" type="source">File No. 4757/6–7.</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Ambassador <persName type="to">Riddle</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1907-04-10"><hi rend="italic">April 10,
                                1907</hi></date>.</dateline></opener>
                        <p>Five thousand dollars received from American National Red Cross. Draw
                            Secretary of State for same and pay to Russian Red Cross for relief
                            Russian famine sufferers.</p>
                        <closer><signed><hi rend="smallcaps">Bacon.</hi></signed></closer>
                    </div>
                    </body></text></TEI>