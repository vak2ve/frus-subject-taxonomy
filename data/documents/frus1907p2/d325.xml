                <note rend="inline" type="source">File No. 2618/3.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Minister <persName type="to">Bryan</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1907-01-26">
                            <hi rend="italic">January 26, 1907</hi>
                        </date>.</dateline>
                </opener>
                <p>Porto Rico agreement November 19, 1902, proclaimed by President 24th instant.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bacon</hi>.</signed>
                </closer>
            </div>
        </body>
