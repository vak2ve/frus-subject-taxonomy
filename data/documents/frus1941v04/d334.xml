<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1941-09-18T05:00:00-05:00" frus:doc-dateTime-min="1941-09-18T05:00:00-05:00" n="334" subtype="historical-document" type="document" xml:id="d334">
                        <note rend="inline" type="source">793.94119/763: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in Japan</hi> (<persName type="from"><hi rend="italic">Grew</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Tokyo</hi></placeName>, <date calendar="gregorian" when="1941-09-18T19:00:00+09:00">September
                                    18, 1941—7 p.m.</date>
                                <lb/> [Received September 18—10:17 a.m.]</dateline>
                        </opener>
                        <p>1482. For the Secretary and the Under Secretary only. I have just
                            received word that the Prime Minister will communicate to me in the next
                            day or two the peace terms which Japan is prepared to present to
                            China.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Grew</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>