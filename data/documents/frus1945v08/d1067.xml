    <teiHeader><fileDesc><titleStmt><title>The Ambassador in France (
                        Caffery
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945v08</bibl><bibl type="frus-document-id">d1067</bibl><bibl type="frus-document-number">1067</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-05-25T09:00:00-05:00" notAfter="1945-05-25T09:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-05-25T09:00:00-05:00" frus:doc-dateTime-min="1945-05-25T09:00:00-05:00" n="1067" subtype="historical-document" type="document" xml:id="d1067">
                <note rend="inline" type="source">890D.01/5–2545: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Caffery</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1945-05-25T16:00:00+02:00">May 25, 1945—4 p.m.</date>
                        <lb/> [Received 8:04 p.m.]</dateline>
                </opener>
                <p>2957. My tel. 2956, May 25.<note n="44" xml:id="d1067fn44">
                        <ref target="frus1945v04#pg_699">Vol. <hi rend="smallcaps">iv</hi>, p.
                            699</ref>.</note> In view of Bidault’s statement regarding Syria and
                    Lebanon I suggest that the proposal set out in Depts 2271, May 23, be held in
                    abeyance for a few days.</p>
                <p>Sent Dept as 2957, rptd London as 340.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caffery</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
