<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-10-09T23:59:59-05:00" frus:doc-dateTime-min="1945-10-09T00:00:00-05:00" n="134" subtype="historical-document" type="document" xml:id="d134">
                        <note rend="inline" type="source">868.00/10–945: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in Greece</hi> (<persName type="from"><hi rend="italic">MacVeagh</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Athens</hi></placeName>, <date calendar="gregorian" when="1945-10-09">October 9,
                                1945</date>.<lb/>[Received October 9—4:45 p.m.]</dateline>
                        </opener>
                        <p>1139. Regent accepted resignation Voulgaris Cabinet noon today.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">MacVeagh</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>