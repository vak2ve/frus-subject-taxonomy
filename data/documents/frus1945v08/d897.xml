        <body>
            <div frus:doc-dateTime-max="1945-06-28T12:00:00-05:00" frus:doc-dateTime-min="1945-06-28T12:00:00-05:00" n="897" subtype="historical-document" type="document" xml:id="d897">
                <note rend="inline" type="source">890F.248/6–2845: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Saudi Arabia</hi> (<persName type="to">
                        <hi rend="italic">Eddy</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1945-06-28T13:00:00-04:00">June 28, 1945—1 p.m.</date>
                    </dateline>
                </opener>
                <p>180. Deptel 177 June 25. For your background info during forthcoming discussions
                    with Ibn Saud you are advised that President Truman has approved recommendation
                    for construction of US military airfield at Dhahran.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
