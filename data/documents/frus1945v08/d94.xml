<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-08-18T14:00:00-05:00" frus:doc-dateTime-min="1945-08-18T14:00:00-05:00" n="94" subtype="historical-document" type="document" xml:id="d94">
                        <note rend="inline" type="source">868.00/8–1845: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Greece</hi> (<persName type="to"><hi rend="italic">MacVeagh</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1945-08-18T15:00:00-04:00">August 18,
                                    1945—3 p.m.</date>
                            </dateline>
                        </opener>
                        <p>827. Please inform Moscow by direct telegram of Greek Govts approval of
                            Allied supervision of elections as soon as conveyed to you by Greek
                            Govt.</p>
                        <p>Sent to Athens. Repeated to Moscow, Paris, London.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Byrnes</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>