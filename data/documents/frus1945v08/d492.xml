    <teiHeader><fileDesc><titleStmt><title>The Ambassador in the Soviet Union (
                        Harriman
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945v08</bibl><bibl type="frus-document-id">d492</bibl><bibl type="frus-document-number">492</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-12-23T05:00:00-05:00" notAfter="1945-12-23T05:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-12-23T05:00:00-05:00" frus:doc-dateTime-min="1945-12-23T05:00:00-05:00" n="492" subtype="historical-document" type="document" xml:id="d492">
                <note rend="inline" type="source">740.00119 Council/12–2345: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in the Soviet Union</hi> (<persName type="from">
                        <hi rend="italic">Harriman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Moscow</hi>
                        </placeName>, <date calendar="gregorian" when="1945-12-23T13:00:00+03:00">December 23, 1945—1 p.m.</date>
                        <lb/> [Received December 23—3:30 a.m.]</dateline>
                </opener>
                <p>4261. Tehran’s 342, Dec 16<note n="35" xml:id="d492fn35">Same as telegram 1136,
                        from Tehran, <ref target="#pg_499">p. 499</ref>.</note> and <ref target="#pg_359">359</ref>, Dec 20.<note n="36" xml:id="d492fn36">Same as
                        telegram 1159, from Tehran, <ref target="#pg_507">p. 507</ref>.</note>
                        Note<note n="37" xml:id="d492fn37">Dated December 22, 1945.</note> sent
                    Foreign Commissariat urging immediate issuance passes for Minor and Gagarine.
                    Secretary prefers not take up this question in Foreign Ministers Conference.</p>
                <p>Sent Tehran 186, repeated Dept 4261.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Harriman</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
