<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-12-10T23:59:59-05:00" frus:doc-dateTime-min="1945-12-10T00:00:00-05:00" n="821" subtype="historical-document" type="document" xml:id="d821">
                        <note rend="inline" type="source">867N.01/12–1045</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">British Ambassador</gloss> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1945-12-10">December 10,
                                1945</date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Dear Mr. Secretary</hi>: I have the honour, under
                            instructions from His Majesty’s Principal Secretary of State for Foreign
                            Affairs, to inform Your Excellency that His Majesty’s Government in the
                            United Kingdom are in agreement with the terms of your note of the 10th
                            December about the Joint Anglo-American Committee of Enquiry to report
                            on the position of the Jews in certain countries of Europe and in
                            Palestine.</p>
                        <p>I have the honour [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Halifax</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>