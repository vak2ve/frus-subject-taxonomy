<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-06-01T23:59:59-05:00" frus:doc-dateTime-min="1917-06-01T00:00:00-05:00" n="171" subtype="historical-document" type="document" xml:id="d171">
                    <note rend="inline" type="source">861.00/383½</note>
                    <head>
                        <hi rend="italic">President <persName type="from">Wilson</persName> to the
                                <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-06-01">
                                <hi rend="italic">1 June, 1917</hi>
                            </date>.</dateline>
                    </opener>
                    <p>
                        <hi rend="smallcaps">My Dear Mr. Secretary</hi>, I have read the attached
                        paper with the profoundest interest.<note n="23" xml:id="d171fn1">Message
                            from the Russian Minister of Foreign Affairs. Substance printed <ref target="frus1918Russiav01#pg_74">
                                <hi rend="italic">ibid.</hi>, p. 74</ref>.</note> I hope with all my
                        heart that the new forces in Russia may be guided by the principles and
                        objects it sets forth!</p>
                    <p>Faithfully Yours,</p>
                    <closer>
                        <signed>W. W.</signed>
                    </closer>
                </div>
                </body></text></TEI>