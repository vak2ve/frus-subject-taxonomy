<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-08-16T23:59:59-05:00" frus:doc-dateTime-min="1915-08-16T00:00:00-05:00" n="395" subtype="historical-document" type="document" xml:id="d395">
                        <note rend="inline" type="source">812.113/3692½</note>
                        <head>
                            <hi rend="italic">President <persName type="from">Wilson</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-08-16">
                                    <hi rend="italic">16 August, 1915</hi>
                                </date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Secretary</hi>: These figures are
                            indeed extraordinary.<note n="21" xml:id="d395fn1">See Secretary
                                Lansing’s letter of Aug. 14, 1915, <ref target="#pg_549">p.
                                    549</ref>.</note> Evidently a renewal of the embargo might be a
                            very important weapon in our hands.</p>
                        <p>Faithfully Yours,</p>
                        <closer>
                            <signed>W. W.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>