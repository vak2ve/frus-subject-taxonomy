<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-05-24T23:59:59-05:00" frus:doc-dateTime-min="1917-05-24T00:00:00-05:00" n="24" subtype="historical-document" type="document" xml:id="d24">
                        <note rend="inline" type="source">811.751/1</note>
                        <head>
                            <hi rend="italic">The Governor of New York</hi> (<persName type="from"><hi rend="italic">Whitman</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Albany, N. Y.</hi></placeName>, <date calendar="gregorian" when="1917-05-24">
                                    <hi rend="italic">May 24, 1917</hi>
                                </date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Secretary</hi>: Answering yours of May
                            19th, the measure with regard to which you write, was vetoed yesterday,
                            in conformity with what seems to me your very wise attitude in the
                            matter.</p>
                        <p>With kindest personal regards [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Charles S. Whitman</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>