                subtype="historical-document" type="document" xml:id="d232">
                <note rend="inline" type="source">793.94/240</note>
                <head>
                    <hi rend="italic">President <persName type="from">Wilson</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <date calendar="gregorian" when="1915-03-10">10 <hi rend="smallcaps"
                                >March</hi>, 1915</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: I am anxious to know whether
                    our note to Japan about the “requests” she made of China has gone forward or
                    not. The twelfth (Thursday of this week) is the day named in the despatches on
                    which China must yield or ———? It would be well to have our note in Japan’s
                    hands by that date.</p>
                <p>Faithfully Yours,</p>
                <closer>
                    <signed>W. W.</signed>
                </closer>
            </div>
        </body>
    </text>
