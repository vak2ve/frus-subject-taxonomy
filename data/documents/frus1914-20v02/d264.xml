    <text>
        <body>
            <div frus:doc-dateTime-max="1917-09-26T23:00:00-05:00"
                frus:doc-dateTime-min="1917-09-25T00:00:00-05:00" n="264"
                subtype="historical-document" type="document" xml:id="d264">
                <note rend="inline" type="source">793.94/583½</note>
                <head>
                    <hi rend="italic">President <persName type="from">Wilson</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date ana="#date_undated-inferred-from-sibling-dates"
                            calendar="gregorian" notAfter="1917-09-26T23:00:00-05:00"
                            notBefore="1917-09-25T00:00:00-05:00">
                            <hi rend="italic">undated</hi>
                        </date>.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Secretary</hi>: Thank you for letting me have
                    these. I spent half an hour with Viscount Ishii. I did most of the talking (to
                    let him see my <hi rend="underline">full</hi> thought) and he seemed to agree
                    throughout in <hi rend="underline">principle.</hi>
                </p>
                <closer>
                    <signed>W. W.</signed>
                </closer>
            </div>
        </body>
