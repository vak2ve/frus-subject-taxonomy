<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-12-21T23:59:59-05:00" frus:doc-dateTime-min="1915-12-21T00:00:00-05:00" n="342" subtype="historical-document" type="document" xml:id="d342">
                        <note rend="inline" type="source">711.21/329½a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                President <persName type="to">Wilson</persName>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1915-12-21">
                                    <hi rend="italic">December 21, 1915</hi>
                                </date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Dear Mr. President</hi>: I enclose to you herewith
                            a copy of a memorandum<note n="3" xml:id="d342fn1">Not printed.</note>
                            presented by the Colombian Minister under instructions from his
                            Government, in which he emphasizes the importance which Colombia
                            attaches to the prompt ratification of the Treaty of April 6, 1914,<note n="4" xml:id="d342fn2">
                                <ref target="frus1914#pg_163">
                                    <hi rend="italic">Foreign Relations</hi>, 1914, p.
                                163</ref>.</note> now before the United States Senate.</p>
                        <p>Faithfully yours,</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Robert Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>