<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1946-04-03T23:59:59-05:00" frus:doc-dateTime-min="1946-04-03T00:00:00-05:00" n="300" subtype="historical-document" type="document" xml:id="d300">
                        <note rend="inline" type="source">Marshall Mission Files, Lot 54–D270</note>
                        <head><hi rend="italic">Memorandum by the Chinese Minister of War</hi>
                                (<persName type="from"><hi rend="italic">Chen Cheng</hi></persName>)
                                <hi rend="italic">to Lieutenant General <persName type="to">Alvan C.
                                    Gillem, Jr.</persName></hi></head>
                        <opener>
                            <seg rendition="#center">[Translation]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">[<placeName><hi rend="smallcaps">Chungking</hi></placeName>,] <date calendar="gregorian" when="1946-04-03">April [3?] 1946</date>.</dateline>
                        </opener>
                        <p>I have the honor to inform you that I was appointed as Acting Government
                            Representative by His Excellency the Generalissimo to the Committee of
                            Three to continue the discussion during General Chang Chi Chung’s
                            absence.</p>
                        <closer><signed><hi rend="smallcaps">General Chen Cheng</hi></signed> (<hi rend="smallcaps">seal</hi>)</closer>
                    </div>
                    </body></text></TEI>