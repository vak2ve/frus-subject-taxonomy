<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1946-03-26T23:59:59-05:00" frus:doc-dateTime-min="1946-03-26T00:00:00-05:00" n="105" subtype="historical-document" type="document" xml:id="d105">
                        <note rend="inline" type="source">Marshall Mission Files, Lot 54–D270</note>
                        <head><hi rend="italic">Memorandum by the Chinese Minister of War</hi>
                                (<persName type="from"><hi rend="italic">Chen Cheng</hi></persName>)
                                <hi rend="italic">to General <persName type="to">Marshall</persName></hi><note n="40" xml:id="d105fn40">For
                                Lieutenant General Gillem in General Marshall’s
                            absence.</note></head>
                        <opener>
                            <seg rendition="#left">No. 1480</seg>
                            <dateline rendition="#right">[<placeName><hi rend="smallcaps">Chungking</hi></placeName>,] <date calendar="gregorian" when="1946-03-26">March 26, 1946</date>.</dateline>
                        </opener>
                        <p>In accordance with the provisions under Section 1, Article 4 of the Basis
                            for Military Reorganization and for the Integration of the Communist
                            Forces into the National Army, we are forwarding to you a list<note n="41" xml:id="d105fn41">Not printed.</note> of the 90 divisions to
                            be retained by the National Government <pb facs="0342" n="330" xml:id="pg_330"/> and the order of demobilization of units during
                            the first two months.<note n="42" xml:id="d105fn42">On March 31
                                Lieutenant General Gillem replied approving the Chinese
                            plan.</note></p>
                        <closer><signed><hi rend="smallcaps">General Chen
                            Cheng</hi></signed></closer>
                    </div>
                    </body></text></TEI>