                subtype="historical-document" type="document" xml:id="d711">
                <note rend="inline" type="source">123 Stuart, J. Leighton: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Stuart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1946-07-27T11:00:00+09:00"
                            >July 27, 1946—11 a.m.</date>
                        <lb/>[Received 4:01 p.m.]</dateline>
                </opener>
                <p>1215. After a long talk last evening with General Chou En-lai, I have decided to
                    leave today to join General Marshall in Kuling.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stuart</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
