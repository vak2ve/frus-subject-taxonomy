                                <del rend="strikethrough">of</del>
                                <del rend="strikethrough">their</del>
                                <del rend="strikethrough">dispatch.</del>
                                <del rend="strikethrough">He</del>
                                <del rend="strikethrough">may</del>
                                <del rend="strikethrough">also</del>
                                <del rend="strikethrough">decide</del>
                                <del rend="strikethrough">disagreements</del>
