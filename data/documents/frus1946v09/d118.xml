<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>Memorandum by General Hsu
                            Yung-chang to General Marshall</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1946v09</bibl><bibl type="frus-document-id">d118</bibl><bibl type="frus-document-number">118</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1946-04-23T00:00:00-05:00" notAfter="1946-04-23T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1946-04-23T23:59:59-05:00" frus:doc-dateTime-min="1946-04-23T00:00:00-05:00" n="118" subtype="historical-document" type="document" xml:id="d118">
                <note rend="inline" type="source">Marshall Mission Files, Lot 54–D270</note>
                <head>
                    <hi rend="italic">Memorandum by General <persName type="from">Hsu
                            Yung-chang</persName> to General <persName type="to">Marshall</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 25</seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Chungking</hi>
                        </placeName>,] <date calendar="gregorian" when="1946-04-23">23 April
                            1946</date>.</dateline>
                </opener>
                <p>I have the pleasure to inform you that his Excellency, The Generalissimo, has
                    appointed me as acting representative for the National Government on the
                    Sub-Committee of Three. Representatives of the Chinese Communist Party are, too,
                    being informed of the matter.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hsu Yung-Chang</hi>
                    </signed> (<hi rend="smallcaps">seal</hi>)<lb/>
                    <hi rend="italic">Government Representative,</hi>
                    <lb/>
                    <hi rend="italic">Sub-Committee of Three</hi>
                </closer>
            </div>
        </body>
    </text>
</TEI>
