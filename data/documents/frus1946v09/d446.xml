                subtype="historical-document" type="document" xml:id="d446">
                <note rend="inline" type="source">Marshall Mission Files, Lot 54–D270:
                    Telegram</note>
                <head>
                    <hi rend="italic">General <persName type="from">Marshall</persName> to the Chief
                        of Staff</hi> (<persName type="to">
                        <hi rend="italic">Eisenhower</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1946-05-11">11 May
                            1946</date>.</dateline>
                </opener>
                <p>679. Please deliver following by hand of an officer to hand of Secretary of State
                    or Under Secretary. “Please delay until further receipt of notice from me
                    Wedemeyer’s nomination.”</p>
            </div>
        </body>
