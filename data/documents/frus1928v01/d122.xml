                subtype="historical-document" type="document" xml:id="d122">
                <note rend="inline" type="source">711.0012Anti-War/211: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from">
                        <hi rend="italic">Fletcher</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1928-08-16T10:00:00+01:00">
                            <hi rend="italic">August 16, 1928—10 a.m.</hi>
                        </date>
                        <lb/>[Received August 16—5:44 a.m.]</dateline>
                </opener>
                <p>82. My telegram No. 81, August 4, 1 p.m.<note n="18" xml:id="d122fn18">Not
                        printed.</note> Foreign Office informs me that Grandi finds it will be
                    impossible for him to go to Paris August 27th.</p>
                <p>Italian Ambassador at Paris will sign.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Fletcher</hi>
                    </signed>
                </closer>
            </div>
        </body>
