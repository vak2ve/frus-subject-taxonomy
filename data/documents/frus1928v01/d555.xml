<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-05-23T21:00:00-05:00" frus:doc-dateTime-min="1928-05-23T21:00:00-05:00" n="555" subtype="historical-document" type="document" xml:id="d555">
                            <note rend="inline" type="source">714.1515/685: Telegram</note>
                            <head><hi rend="italic">The Minister in Guatemala</hi> (<persName type="from"><hi rend="italic">Geissler</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Guatemala</hi></placeName>, <date calendar="gregorian" when="1928-05-23T20:00:00-06:00"><hi rend="italic">May 23,
                                            1928—8 p.m.</hi></date><lb/>[Received May 24—2:15
                                    p.m.]</dateline></opener>
                            <p>70. The President has remarked to me that he believes that Washington
                                would be a suitable place for the next boundary conference but that
                                San José de Costa Rica would also be acceptable.</p>
                            <closer><signed><hi rend="smallcaps">Geissler</hi></signed></closer>
                        </div>
                        </body></text></TEI>