                <note rend="inline" type="source">724.3415/301: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in France</hi> (<persName type="to">
                        <hi rend="italic">Armour</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-12-21T16:00:00-05:00">
                            <hi rend="italic">December 21, 1928—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>430. Your 427, December 20, 8 p.m. The good offices of the Conference having been
                    accepted no further observations would appear to be required.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
