                <note rend="inline" type="source">820.7961 Dept. of Commerce Flight/14:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Argentina</hi> (<persName type="from">
                        <hi rend="italic">Bliss</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1928-01-25T11:00:00-04:00">
                            <hi rend="italic">January 25, 1928—11 a.m.</hi>
                        </date>
                        <lb/>[Received 11:35 a.m.]</dateline>
                </opener>
                <p>7. Your telegram number 1, January 7, 8 p.m. Permission accorded.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bliss</hi>
                    </signed>
                </closer>
            </div>
        </body>
