                subtype="historical-document" type="document" xml:id="d558">
                <note rend="inline" type="source">714.1515/704: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Honduras</hi> (<persName type="from">
                        <hi rend="italic">Summerlin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1928-06-06T17:00:00-06:00">
                            <hi rend="italic">June 6, 1928—5 p.m.</hi>
                        </date>
                        <lb/>[Received 9:40 p.m.]</dateline>
                </opener>
                <p>71. Your telegram number 44, June 4, 4 p.m.<note n="26" xml:id="d558fn26">See
                        footnote 23, <ref target="#pg_746">p. 746</ref>.</note> President Paz stated
                    to me this afternoon that he has instructed the Minister for Foreign Affairs to
                    accept your proposal.</p>
                <p>Repeated to Guatemala.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Summerlin</hi>
                    </signed>
                </closer>
            </div>
        </body>
