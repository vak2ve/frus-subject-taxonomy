                <note rend="inline" type="source">500.A15Franco–British/4½: Telegram</note>
                <head>
                    <hi rend="italic">President <persName type="from">Coolidge</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Superior, Wis.</hi>
                        </placeName>, <date calendar="gregorian" when="1928-08-02">
                            <hi rend="italic">August 2, 1928</hi>.</date>
                        <lb/>[Received August 2.]</dateline>
                </opener>
                <p>Please make no commitments concerning limitation of armaments.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Calvin Coolidge</hi>
                    </signed>
                </closer>
            </div>
        </body>
