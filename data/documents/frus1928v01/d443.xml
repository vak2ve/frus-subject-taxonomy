                <note rend="inline" type="source">724.3415/222: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Bolivia</hi> (<persName type="to">
                        <hi rend="italic">Kaufman</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-10-12T18:00:00-05:00">
                            <hi rend="italic">October 12, 1928—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>24. Your 46, October 12, 1 p.m. Your reply to the Bolivian officials is approved.
                    Take no further action without definite instructions.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
