<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-03-16T17:00:00-05:00" frus:doc-dateTime-min="1928-03-16T17:00:00-05:00" n="590" subtype="historical-document" type="document" xml:id="d590">
                            <note rend="inline" type="source">810.79611 Pan American Airways,
                                Inc./49: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Minister in Guatemala</hi> (<persName type="to"><hi rend="italic">Geissler</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1928-03-16T17:00:00-05:00"><hi rend="italic">March 16,
                                            1928—5 p.m.</hi></date></dateline></opener>
                            <p>21. John D. MacGregor, Vice President Pan American Airways, will
                                arrive by train March 20 for the purpose of obtaining a transport
                                concession. Please render him all possible and proper
                                assistance.</p>
                            <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                        </div>
                        </body></text></TEI>