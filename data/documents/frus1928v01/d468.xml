<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-12-12T19:00:00-05:00" frus:doc-dateTime-min="1928-12-12T19:00:00-05:00" n="468" subtype="historical-document" type="document" xml:id="d468">
                            <note rend="inline" type="source">724.3415/259: Telegram</note>
                            <head><hi rend="italic">The Ambassador in Argentina</hi> (<persName type="from"><hi rend="italic">Bliss</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Buenos Aires</hi></placeName>, <date calendar="gregorian" when="1928-12-12T20:00:00-04:00"><hi rend="italic">December 12, 1928—8
                                    p.m.</hi></date><lb/>[Received 9:20 p.m.]</dateline></opener>
                            <p>95. Foreign Minister states that the Government of Argentina is doing
                                nothing at the present time in the way of mediation and has no
                                objection to any action which the Conference may take.</p>
                            <closer><signed><hi rend="smallcaps">White</hi> for <hi rend="smallcaps">Bliss</hi></signed></closer>
                        </div>
                        </body></text></TEI>