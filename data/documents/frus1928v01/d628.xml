                <note rend="inline" type="source">810.79611 Pan American Airways, Inc./183:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Costa Rica</hi> (<persName type="from">
                        <hi rend="italic">Davis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San José</hi>
                        </placeName>, <date calendar="gregorian" when="1928-12-16T11:00:00-06:00">
                            <hi rend="italic">December 16, 1928—11 a.m.</hi>
                        </date>
                        <lb/>[Received December 17—12:33 a.m.]</dateline>
                </opener>
                <p>99. Department’s 50, December 12, noon. Permission granted.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
