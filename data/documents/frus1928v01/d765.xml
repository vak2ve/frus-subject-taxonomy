                <note rend="inline" type="source">863.51 Relief Credits/114: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName type="to">
                        <hi rend="italic">Herrick</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-05-22T13:00:00-04:00">
                            <hi rend="italic">May 22, 1928—1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>143. Reparation 49. Your Reparation 89.<note n="53" xml:id="d765fn53">
                        <hi rend="italic">Supra</hi>.</note> Department perceives no advantage in
                    mentioning United States in the preamble or decision.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
