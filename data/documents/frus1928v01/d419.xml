<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-08-07T23:59:59-05:00" frus:doc-dateTime-min="1928-08-07T00:00:00-05:00" n="419" subtype="historical-document" type="document" xml:id="d419">
                        <note rend="inline" type="source">701.2325/43</note>
                        <head><hi rend="italic">The Peruvian Ambassador</hi> (<persName type="from"><hi rend="italic">Velarde</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><seg rendition="#center">[Translation]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1928-08-07"><hi rend="italic">August 7,
                                1928</hi></date>.</dateline></opener>
                        <p><hi rend="smallcaps">Excellency</hi>: I have the honor to inform Your
                            Excellency that the Peruvian Congress has approved the Bill which was
                            introduced by the Executive Power creating an Embassy of Peru in
                            Chile.</p>
                        <p>I avail myself [etc.]</p>
                        <closer><signed><hi rend="smallcaps">Hernan Velarde</hi></signed></closer>
                    </div>
                    </body></text></TEI>