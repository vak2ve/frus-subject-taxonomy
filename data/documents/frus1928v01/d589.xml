                <note rend="inline" type="source">810.79611 Pan American Airways, Inc./48: Circular
                    telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">American Diplomatic Representatives in Costa Rica,
                            Guatemala, Panama, and Salvador</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-03-07T18:00:00-05:00">
                            <hi rend="italic">March 7, 1928—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Pan American Airways flight postponed approximately 30 days.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
