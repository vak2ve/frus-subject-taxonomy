    <text>
        <body>
            <div frus:doc-dateTime-max="1928-12-28T23:59:59-05:00"
                frus:doc-dateTime-min="1928-12-28T00:00:00-05:00" n="229"
                subtype="historical-document" type="document" xml:id="d229">
                <note rend="inline" type="source">500.A15/850</note>
                <head>
                    <hi rend="italic">The Minister in Switzerland</hi> (<persName type="from">
                        <hi rend="italic">Wilson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berne</hi>
                        </placeName>, <date calendar="gregorian" when="1928-12-28">
                            <hi rend="italic">December 28, 1928</hi>.</date>
                        <lb/>[Received January 30, 1929.]</dateline>
                    <seg rendition="#left">No. 693</seg>
                    <lb/>
                    <seg rendition="#left">L. of N. No. 1253</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to my telegram No. 132, of December 28,
                    9 a.m.,<note n="31" xml:id="d229fn31">Not printed.</note> I have the honor to
                    transmit herewith eight copies of the communication received from the League of
                        Nations<note n="31" xml:id="d229fn32">Not printed.</note> stating that Mr.
                    Loudon had convened the next session of the Preparatory Commission for April 15,
                    at 11 a.m. A copy has been forwarded to Mr. Gibson at Brussels.</p>
                <p>I have [etc.]</p>
                <closer>(For the Minister)<lb/>
                    <signed>
                        <hi rend="smallcaps">Pierrepont Moffat</hi>
                    </signed>
                    <lb/>
                    <hi rend="italic">Secretary of Legation</hi>
                </closer>
            </div>
        </body>
    </text>
