<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-12-15T05:00:00-05:00" frus:doc-dateTime-min="1928-12-15T05:00:00-05:00" n="318" subtype="historical-document" type="document" xml:id="d318">
                        <note rend="inline" type="source">511.4 A 2a/23: Telegram</note>
                        <head><hi rend="italic">The Consul at Geneva</hi> (<persName type="from"><hi rend="italic">Band</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Geneva</hi></placeName>, <date calendar="gregorian" when="1928-12-15T11:00:00+01:00"><hi rend="italic">December 15,
                                        1928—11 a.m.</hi></date><lb/>[Received December 15—10:15
                                a.m.]</dateline></opener>
                        <p>The Council of the League has appointed May<note n="83" xml:id="d318fn83">Herbert L. May, of Pittsburgh.</note> (American) a member of the
                            Central Board provided for by the Geneva Opium Convention of 1925. Full
                            report by mail.<note n="81" xml:id="d318fn81">Not printed.</note></p>
                        <closer><signed><hi rend="smallcaps">Rand</hi></signed></closer>
                    </div>
                    </body></text></TEI>