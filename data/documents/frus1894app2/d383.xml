                subtype="historical-document" type="document" xml:id="d383">
                <head>No. 36.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Macfarlane</persName> to Mr.
                            <persName type="to">Blount</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Honolulu</hi>
                        </placeName>, <date calendar="gregorian" when="1893-07-13">
                            <hi rend="italic">July 13, 1893</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In answer to your inquiry as to the rate of
                    taxation imposed upon real and personal property in the Hawaiian Kingdom
                    commencing from the reign of Kalakaua to the present time, I have the honor to
                    inform you that the rate of taxation was three-quarters of one per centum up to
                    1886, and from that time forward the rate has been 1 per centum on the assessed
                    valuation.</p>
                <p>I have the honor to be, sir, your most obedient servant,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">E. C. Macfarlane.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>His Excellency <hi rend="smallcaps">J. H. Blount</hi>,<lb/>
                        <hi rend="italic">United States Minister, etc.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
