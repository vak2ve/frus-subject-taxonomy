    <text>
        <body>
            <div frus:doc-dateTime-max="1893-03-10T23:59:59-05:00" frus:doc-dateTime-min="1893-03-10T00:00:00-05:00" n="219" subtype="historical-document" type="document" xml:id="d219">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 79.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1893-03-10">
                            <hi rend="italic">March 10,
                                        1893</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I append a copy of a telegram<note n="*" xml:id="d219fn1">See under date of March 8, 1893.</note>
                                received on 8th instant, over your signature.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. Q.
                                Gresham.</hi>
                    </signed>
                </closer>
            </div>
        </body>
