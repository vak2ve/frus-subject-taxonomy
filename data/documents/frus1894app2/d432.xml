    <text>
        <body>
            <div frus:doc-dateTime-max="1893-02-15T23:59:59-05:00" frus:doc-dateTime-min="1893-02-15T00:00:00-05:00" n="432" subtype="historical-document" type="document" xml:id="d432">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Foster</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1893-02-15">
                            <hi rend="italic">February 15,
                                        1893</hi>
                        </date>.</dateline>
                </opener>
                <p>The President tenders his heartfelt condolences by reason of your
                                great bereavement. I add my tribute of sincere sorrow.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John W.
                                Foster.</hi>
                    </signed>
                </closer>
            </div>
        </body>
