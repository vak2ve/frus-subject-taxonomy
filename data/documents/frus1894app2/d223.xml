<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1893-04-18T23:59:59-05:00" frus:doc-dateTime-min="1893-04-18T00:00:00-05:00" n="223" subtype="historical-document" type="document" xml:id="d223">
                            <head><hi rend="italic">Mr. <persName type="from">Gresham</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi></head>
                            <opener>
                                <seg rendition="#left">No. 81.]</seg>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1893-04-18"><hi rend="italic">April 18,
                                        1893</hi></date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: I have received your No. 92, of the
                                15th ultimo, relative to the Provisional Government recently
                                established in Hawaii, and the attitude of the British and Japanese
                                representatives with respect thereto.</p>
                            <p>I am, etc.,</p>
                            <closer><signed><hi rend="smallcaps">W. Q.
                                Gresham.</hi></signed></closer>
                        </div>
                        </body></text></TEI>