    <text>
        <body>
            <div frus:doc-dateTime-max="1890-11-12T23:59:59-05:00"
                frus:doc-dateTime-min="1890-11-12T00:00:00-05:00" n="420"
                subtype="historical-document" type="document" xml:id="d420">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr. <persName
                            type="to">Stevens</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 9.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1890-11-12">
                            <hi rend="italic">November 12, 1890</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir.</hi>: I have received your No. 7 of the 22d October
                    last, favoring the establishment of a coal depot at Honolulu, for the use of our
                    naval force.</p>
                <p>A copy has been sent to the Secretary of the Navy.</p>
                <p>I am, sir, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">James G. Blaine.</hi>
                    </signed>
                </closer>
            </div>
        </body>
