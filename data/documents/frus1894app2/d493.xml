    <text>
        <body>
            <div frus:doc-dateTime-max="1894-04-21T23:59:59-05:00" frus:doc-dateTime-min="1894-04-21T00:00:00-05:00" n="493" subtype="historical-document" type="document" xml:id="d493">
                <head>[Untitled]</head>
                <p rend="center">
                    <hi rend="smallcaps">April</hi> 21, 1894.—Read, referred to
                            the Committee on Foreign Relations, and ordered to be printed.</p>
                <p rend="flushleft">
                    <hi rend="italic">To the Congress:</hi>
                </p>
                <p>I transmit herewith a communication from the Secretary of State covering
                            a dispatch from the U. S. minister at Honolulu, and reply thereto.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grover Cleveland.</hi>
                    </signed>
                    <lb/>
                    <dateline rendition="#left">
                        <hi rend="smallcaps">Executive
                                        Mansion</hi>,<lb/>
                        <placeName>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-04-21">
                            <hi rend="italic">April 21,
                                1894</hi>
                        </date>.</dateline>
                </closer>
                <frus:attachment>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Department of State</hi>,<lb/>
                                <hi rend="italic">Washington</hi>
                            </placeName>, <date calendar="gregorian" when="1894-04-21">
                                <hi rend="italic">April 21,
                                        1894</hi>
                            </date>.</dateline>
                    </opener>
                    <p rend="flushleft">The <hi rend="smallcaps">President</hi>:</p>
                    <p>The Secretary of State has the honor to lay before the President
                                copies of dispatch No. 47, under date of April 5, 1894, from our
                                minister at Honolulu, and reply thereto.</p>
                    <p>Dispatch No. 46, received by the same mail, transmits the minister’s
                                salary account.</p>
                    <p>Respectfully submitted.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">W. Q.
                                Gresham.</hi>
                        </signed>
                    </closer>
                </frus:attachment>
            </div>
