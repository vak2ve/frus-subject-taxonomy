<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1889-08-22T23:59:59-05:00" frus:doc-dateTime-min="1889-08-22T00:00:00-05:00" n="108" subtype="historical-document" type="document" xml:id="d108">
                            <head><hi rend="italic">Mr. <persName type="from">Wharton</persName> to
                                    Mr. <persName type="to">Merrill</persName>.</hi></head>
                            <opener>
                                <seg rendition="#left">No. 137.]</seg>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1889-08-22"><hi rend="italic">August 22,
                                        1889</hi></date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of
                                your Nos. 243–256.</p>
                            <p>I am etc.,</p>
                            <closer><signed><hi rend="smallcaps">William F. Wharton</hi>,<lb/><hi rend="italic">Acting Secretary.</hi></signed></closer>
