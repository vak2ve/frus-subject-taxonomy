<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1889-11-04T23:59:59-05:00" frus:doc-dateTime-min="1889-11-04T00:00:00-05:00" n="119" subtype="historical-document" type="document" xml:id="d119">
                            <head><hi rend="italic">Mr. <persName type="from">Blaine</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi></head>
                            <opener>
                                <seg rendition="#left">No. 7.]</seg>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1889-11-04"><hi rend="italic">November 4,
                                        1889</hi></date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of
                                your interesting dispatch of the 17th ultimo, relating to the trial
                                of the persons concerned in the revolutionary movement of July 30
                                last, at Honolulu.</p>
                            <p>I am, etc.,</p>
                            <closer><signed><hi rend="smallcaps">James G.
                                Blaine.</hi></signed></closer>
                        </div>
                        </body></text></TEI>