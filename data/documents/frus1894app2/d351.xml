<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1893-01-16T23:59:59-05:00" frus:doc-dateTime-min="1893-01-16T00:00:00-05:00" n="351" subtype="historical-document" type="document" xml:id="d351">
                                <head>No. 4.<lb/><hi rend="italic">Mr. <persName type="from">Stevens</persName> to Mr. <persName type="to">Gifford</persName>.</hi></head>
                                <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">United States Legation</hi>,<lb/><hi rend="italic">Honolulu</hi></placeName>, <date calendar="gregorian" when="1893-01-16"><hi rend="italic">January 16, 1893</hi>.</date></dateline></opener>
                                <p rend="flushleft">Mr. W.M. <hi rend="smallcaps">Gifford</hi>:</p>
                                <p><hi rend="smallcaps">Sir</hi>: Please allow Capt. Wiltse and his
                                    men the use of the opera house hall for a fair condensation for
                                    the same.</p>
                                <p>Yours, truly,</p>
                                <closer><signed><hi rend="smallcaps">John L.
                                    Stevens.</hi></signed></closer>
                            </div>
                            </body></text></TEI>