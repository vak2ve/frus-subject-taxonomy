    <text>
        <body>
            <div frus:doc-dateTime-max="1892-12-23T23:59:59-05:00"
                frus:doc-dateTime-min="1892-12-23T00:00:00-05:00" n="189"
                subtype="historical-document" type="document" xml:id="d189">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Foster</persName> to Mr. <persName
                            type="to">Stevens</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 67.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-12-23">
                            <hi rend="italic">December 23, 1892</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                    dispatch No. 74, of the 20th of November, marked “confidential,” relative to the
                    financial and political condition of Hawaii, which has been read with
                    interest.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John W. Foster.</hi>
                    </signed>
                </closer>
            </div>
        </body>
