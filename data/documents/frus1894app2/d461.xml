                                    <cell>Post-office</cell>
                                    <cell role="num">600.00</cell>
                                    <cell/>
                                </row>
                                <row>
                                    <cell>Taxes</cell>
                                    <cell role="num">2,452.80</cell>
                                    <cell/>
                                </row>
                                <row>
                                    <cell>Crown lands</cell>
                                    <cell rendition="#border-bottom" role="num">850.00</cell>
                                    <cell/>
                                </row>
                                <row>
                                    <cell/>
                                    <cell/>
                                    <cell rendition="#border-bottom" role="num">$14,913.25</cell>
                                </row>
                                <row>
                                    <cell/>
                                    <cell/>
                                    <cell role="num">151,763.98</cell>
                                </row>
                            </table>
