                                    <cell>Available cash, as above</cell>
                                    <cell rendition="#border-bottom" role="num">147,542.73</cell>
                                </row>
                                <row>
                                    <cell/>
                                    <cell role="num">266,691.39</cell>
                                </row>
                            </table>
                            <p>This was received and placed on file.</p>
                        </frus:attachment>
                    </div>
