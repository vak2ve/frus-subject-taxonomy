                            <p rend="center"><hi rend="italic">Postal Savings Bank
                                memorandum</hi>.</p>
                            <table cols="2" rows="2">
                                <row>
                                    <cell>Notices this date of withdrawals maturing in November and
                                        December, 1893, and January and February, 1894</cell>
                                    <cell role="num">$31,474.00</cell>
                                </row>
