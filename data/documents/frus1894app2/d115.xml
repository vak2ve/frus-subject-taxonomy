    <text>
        <body>
            <div frus:doc-dateTime-max="1889-10-16T23:59:59-05:00" frus:doc-dateTime-min="1889-10-16T00:00:00-05:00" n="115" subtype="historical-document" type="document" xml:id="d115">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 5.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1889-10-16">
                            <hi rend="italic">October 16,
                                        1889</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have received your No. 2 <hi rend="italic">bis</hi>. of the 25th ultimo, and the copy which
                                you inclose of the interesting addresses made on the occasion of
                                presenting your credentials to the King of the Hawaiian Islands.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">James G.
                                Blaine.</hi>
                    </signed>
                </closer>
            </div>
        </body>
