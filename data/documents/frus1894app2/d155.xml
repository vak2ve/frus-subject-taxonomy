<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1891-03-02T23:59:59-05:00" frus:doc-dateTime-min="1891-03-02T00:00:00-05:00" n="155" subtype="historical-document" type="document" xml:id="d155">
                            <head><hi rend="italic">Mr. <persName type="from">Blaine</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi></head>
                            <opener>
                                <seg rendition="#left">No. 16.]</seg>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State,</hi><lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1891-03-02"><hi rend="italic">March 2,
                                        1891</hi></date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: I have received your Nos. 21–30, and
                                21 <hi rend="italic">bis</hi> of the old series, and Nos. 1–16 and
                                No. 18 of the new series.</p>
                            <p>I am, sir, etc.,</p>
                            <closer><signed><hi rend="smallcaps">James G.
                                Blaine.</hi></signed></closer>
                        </div>
                        </body></text></TEI>