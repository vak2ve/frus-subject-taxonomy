<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1893-02-16T23:59:59-05:00" frus:doc-dateTime-min="1893-02-16T00:00:00-05:00" n="206" subtype="historical-document" type="document" xml:id="d206">
                            <head><hi rend="italic">Mr. <persName type="from">Foster</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi></head>
                            <opener>
                                <seg rendition="#left">No. 73.]</seg>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1893-02-16"><hi rend="italic">February 16,
                                        1893</hi></date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: I append on the overleaf a copy of a
                                    telegram<note n="*" xml:id="d206fn1">See under date of February
                                    14, 1893.</note> sent to you on the 14th instant, relative to
                                the Hawaiian revolution.</p>
                            <p>I am, etc.,</p>
                            <closer><signed><hi rend="smallcaps">John W.
                                Foster.</hi></signed></closer>
                        </div>
                        </body></text></TEI>