<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1893-02-24T23:59:59-05:00" frus:doc-dateTime-min="1893-02-24T00:00:00-05:00" n="210" subtype="historical-document" type="document" xml:id="d210">
                            <head><hi rend="italic">Mr. <persName type="from">Wharton</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi></head>
                            <opener>
                                <seg rendition="#left">No. 76.]</seg>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1893-02-24"><hi rend="italic">February 24,
                                        1893</hi></date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: I append a copy of a telegram<note n="†" xml:id="d210fn1">See under date of February 22,
                                    1893.</note> sent you on 22d instant.</p>
                            <p>I am, etc.,</p>
                            <closer><signed><hi rend="smallcaps">William F. Wharton</hi>,<lb/><hi rend="italic">Acting Secretary.</hi></signed></closer>
                        </div>
