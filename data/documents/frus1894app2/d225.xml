<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1893-04-27T23:59:59-05:00" frus:doc-dateTime-min="1893-04-27T00:00:00-05:00" n="225" subtype="historical-document" type="document" xml:id="d225">
                            <head><hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr.
                                        <persName type="to">Stevens</persName>.</hi></head>
                            <opener>
                                <seg rendition="#left">No. 82.]</seg>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1893-04-27"><hi rend="italic">April 27,
                                        1893</hi></date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: I have received your dispatches
                                numbered 89 and 94, of 7th ultimo and 4th instant, and with
                                reference thereto append a copy of a telegram<note n="*" xml:id="d225fn1">See under date of April 25, 1893.</note> of
                                25th instant accepting your resignation.</p>
                            <p>I am, etc.,</p>
                            <closer><signed><hi rend="smallcaps">Alvey A. Adee</hi>,<lb/><hi rend="italic">Acting Secretary.</hi></signed></closer>
                        </div>
                        </body></text></TEI>