<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1892-10-26T23:59:59-05:00" frus:doc-dateTime-min="1892-10-26T00:00:00-05:00" n="181" subtype="historical-document" type="document" xml:id="d181">
                            <head><hi rend="italic">Mr. <persName type="from">Wharton</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi></head>
                            <opener>
                                <seg rendition="#left">No. 59.]</seg>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1892-10-26"><hi rend="italic">October 26,
                                        1892</hi></date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: I have received your dispatch No. 70,
                                of the 8th instant, in relation to the political situation in
                                Hawaii. It has been read with much interest and attention.</p>
                            <p>I am, etc.,</p>
                            <closer><signed><hi rend="smallcaps">William F. Wharton</hi>,<lb/><hi rend="italic">Acting Secretary</hi>.</signed></closer>
                        </div>
                        </body></text></TEI>