    <text>
        <body>
            <div frus:doc-dateTime-max="1893-02-01T23:59:59-05:00" frus:doc-dateTime-min="1893-02-01T00:00:00-05:00" n="197" subtype="historical-document" type="document" xml:id="d197">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Foster</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 70.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1893-02-01">
                            <hi rend="italic">Feb. 1,
                                    1893</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I append a copy of telegraphic<note n="*" xml:id="d197fn1">See Mr. Stevens’s telegram of January 18,
                                    1893, and Mr. Foster’s telegram of January 28, 1893, in
                                    reply.</note> correspondence with your legation, relative to the
                                new Government of Hawaii.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John W.
                                Foster.</hi>
                    </signed>
                </closer>
            </div>
        </body>
