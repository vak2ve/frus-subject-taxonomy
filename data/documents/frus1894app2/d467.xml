    <text>
        <body>
            <div frus:doc-dateTime-max="1893-12-14T23:59:59-05:00" frus:doc-dateTime-min="1893-12-14T00:00:00-05:00" n="467" subtype="historical-document" type="document" xml:id="d467">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Willis</persName> to Mr.
                                    <persName type="to">Gresham</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 13.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of
                                        the United States</hi>,<lb/>
                            <hi rend="italic">Honolulu,
                                        Hawaiian Islands</hi>
                        </placeName>, <date calendar="gregorian" when="1893-12-14">
                            <hi rend="italic">December 14, 1893</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of Department dispatch, No. 5, inclosing two copies of the
                            report of the electrical congress held in Chicago August 19, 1893, in
                            the matter of units of electrical measure.</p>
                <p>Very respectfully,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Albert S.
                            Willis</hi>.</signed>
                </closer>
            </div>
        </body>
