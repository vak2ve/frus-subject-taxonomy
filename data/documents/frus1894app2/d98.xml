<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1889-06-20T23:59:59-05:00" frus:doc-dateTime-min="1889-06-20T00:00:00-05:00" n="98" subtype="historical-document" type="document" xml:id="d98">
                            <head><hi rend="italic">Mr. <persName type="from">Blaine</persName> to
                                    Mr. <persName type="to">Merrill</persName>.</hi></head>
                            <opener>
                                <seg rendition="#left">No. 131.]</seg>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1889-06-20"><hi rend="italic">June 20,
                                        1889</hi></date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: Your dispatches numbered 239 to 242,
                                inclusive, have been received.</p>
                            <p>I am, sir, etc.,</p>
                            <closer><signed><hi rend="smallcaps">James G.
                                Blaine.</hi></signed></closer>
