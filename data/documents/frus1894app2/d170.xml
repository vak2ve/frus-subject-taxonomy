<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1892-03-19T23:59:59-05:00" frus:doc-dateTime-min="1892-03-19T00:00:00-05:00" n="170" subtype="historical-document" type="document" xml:id="d170">
                            <head><hi rend="italic">Mr. <persName type="from">Wharton</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi></head>
                            <opener>
                                <seg rendition="#left">No. 41.]</seg>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1892-03-19"><hi rend="italic">March 19,
                                        1892</hi></date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: The Department has received your Nos.
                                19, 46, and 42 bis.</p>
                            <p>I am, etc.,</p>
                            <closer><signed><hi rend="smallcaps">William F. Wharton</hi>,<lb/><hi rend="italic">Acting Secretary</hi>.</signed></closer>
