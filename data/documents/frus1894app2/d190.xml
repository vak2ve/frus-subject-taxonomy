<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1892-12-23T23:59:59-05:00" frus:doc-dateTime-min="1892-12-23T00:00:00-05:00" n="190" subtype="historical-document" type="document" xml:id="d190">
                            <head><hi rend="italic">Mr. <persName type="from">Foster</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi></head>
                            <opener>
                                <seg rendition="#left">No. 68.]</seg>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1892-12-23"><hi rend="italic">December 23,
                                        1892</hi></date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of
                                your dispatch No. 75, of the 28th ultimo, regarding confidential
                                dispatches.</p>
                            <p>I am, sir,</p>
                            <closer><signed><hi rend="smallcaps">John W.
                                Foster.</hi></signed></closer>
                        </div>
                        </body></text></TEI>