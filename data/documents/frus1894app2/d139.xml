    <text>
        <body>
            <div frus:doc-dateTime-max="1890-08-16T23:59:59-05:00" frus:doc-dateTime-min="1890-08-16T00:00:00-05:00" n="139" subtype="historical-document" type="document" xml:id="d139">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Wharton</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 2.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1890-08-16">
                            <hi rend="italic">August 16,
                                        1890</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I inclose for your confidential
                                information copy of a letter recently received from the Acting
                                Secretary of the Navy, transmitting one from the commander in chief
                                of the United States naval force in the Pacific station, in regard
                                to political affairs in the Hawaiian Islands. The letter in question
                                seems to confirm the general tenor of your dispatches on the same
                                subject.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William F. Wharton</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
