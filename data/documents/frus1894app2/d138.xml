<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1890-07-14T23:59:59-05:00" frus:doc-dateTime-min="1890-07-14T00:00:00-05:00" n="138" subtype="historical-document" type="document" xml:id="d138">
                            <head><hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr.
                                        <persName type="to">Stevens</persName>.</hi></head>
                            <opener>
                                <seg rendition="#left">No. 31.]</seg>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1890-07-14"><hi rend="italic">July 14,
                                        1890</hi></date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of
                                your No. 27, of the 26th ultimo, announcing a recent change in the
                                cabinet of His Majesty and communicating a sketch of its
                                members.</p>
                            <p>I am, sir, etc.,</p>
                            <closer><signed><hi rend="smallcaps">Alvey A. Adee</hi>,<lb/><hi rend="italic">Acting Secretary.</hi></signed></closer>
                        </div>
                        </body></text></TEI>