    <text>
        <body>
            <div frus:doc-dateTime-max="1892-03-03T23:59:59-05:00" frus:doc-dateTime-min="1892-03-03T00:00:00-05:00" n="168" subtype="historical-document" type="document" xml:id="d168">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Wharton</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 39.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-03-03">
                            <hi rend="italic">March 3,
                                        1892</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have received your No. 46, of 8th
                                ultimo, in which you give a careful review of the political
                                situation in Hawaii.</p>
                <p>I am, sir, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William F. Wharton</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
