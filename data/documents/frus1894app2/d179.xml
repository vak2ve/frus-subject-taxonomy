    <text>
        <body>
            <div frus:doc-dateTime-max="1892-09-29T23:59:59-05:00"
                frus:doc-dateTime-min="1892-09-29T00:00:00-05:00" n="179"
                subtype="historical-document" type="document" xml:id="d179">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Foster</persName> to Mr. <persName
                            type="to">Stevens</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 57.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-09-29">
                            <hi rend="italic">September 29, 1892</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I halve received your No. 65 (confidential) of
                    the 14th instant describing the deadlock existing between the Hawaiian
                    Legislature and the Queen over the constitution of a ministry, and have inclosed
                    a copy to the Secretary of the Navy for his confidential information.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John W. Foster.</hi>
                    </signed>
                </closer>
            </div>
        </body>
