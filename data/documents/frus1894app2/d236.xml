                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Legation of the United States</hi>,<lb/><hi rend="italic">Honolulu</hi></placeName>, <date calendar="gregorian" when="1893-11-11"><hi rend="italic">November 11, 1893</hi></date>.</dateline></opener>
