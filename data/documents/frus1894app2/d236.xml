                <head>
                    <hi rend="italic">Mr. <persName type="from">Willis</persName> to Mr. <persName
                            type="to">Gresham</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Honolulu</hi>
                        </placeName>, <date calendar="gregorian" when="1893-11-11">
                            <hi rend="italic">November 11, 1893</hi>
                        </date>.</dateline>
                </opener>
                <p>Report can be sent to Congress on 19th November.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Albert S. Willis.</hi>
                    </signed>
                </closer>
            </div>
