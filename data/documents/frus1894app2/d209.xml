<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1893-02-23T23:59:59-05:00" frus:doc-dateTime-min="1893-02-23T00:00:00-05:00" n="209" subtype="historical-document" type="document" xml:id="d209">
                            <head><hi rend="italic">Mr. <persName type="from">Wharton</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi></head>
                            <opener>
                                <seg rendition="#left">No. 75.]</seg>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1893-02-23"><hi rend="italic">February 23,
                                        1893</hi></date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">Sir</hi>: I append a copy of your telegram<note n="*" xml:id="d209fn1">See under date of February 8,
                                    1893.</note> of 8th instant on Hawaiian affairs.</p>
                            <p>I am, sir, etc.,</p>
                            <closer><signed><hi rend="smallcaps">William F.
                                Wharton.</hi></signed></closer>
                        </div>
                        </body></text></TEI>