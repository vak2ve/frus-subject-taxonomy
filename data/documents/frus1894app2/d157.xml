    <text>
        <body>
            <div frus:doc-dateTime-max="1891-03-14T23:59:59-05:00" frus:doc-dateTime-min="1891-03-14T00:00:00-05:00" n="157" subtype="historical-document" type="document" xml:id="d157">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to
                                    Mr. <persName type="to">Stevens</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 20.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1891-03-14">
                            <hi rend="italic">March 14,
                                        1891</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of
                                your No. 20, of the 22d ultimo, on the political situation in
                                Hawaii. It has been read with interest.</p>
                <p>I am, sir, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">James G.
                                Blaine.</hi>
                    </signed>
                </closer>
            </div>
        </body>
