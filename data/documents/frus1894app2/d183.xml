    <text>
        <body>
            <div frus:doc-dateTime-max="1892-11-05T23:59:59-05:00"
                frus:doc-dateTime-min="1892-11-05T00:00:00-05:00" n="183"
                subtype="historical-document" type="document" xml:id="d183">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Foster</persName> to Mr. <persName
                            type="to">Stevens</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 61.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-11-05">
                            <hi rend="italic">November 5, 1892</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have received and read with attention your
                    dispatch No. 71, of the 19th ultimo, in relation to the Hawaiian political
                    situation.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John W. Foster.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
