    <text>
        <body>
            <div frus:doc-dateTime-max="1893-01-16T23:59:59-05:00" frus:doc-dateTime-min="1893-01-16T00:00:00-05:00" n="352" subtype="historical-document" type="document" xml:id="d352">
                <head>No. 5.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Stevens</persName> to Mr. <persName type="to">Walker</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">United States Legation</hi>,<lb/>
                            <hi rend="italic">Honolulu</hi>
                        </placeName>, <date calendar="gregorian" when="1893-01-16">
                            <hi rend="italic">January 16, 1893</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Sir</hi>: Will you let Arion Hall for
                                    use for the sleeping and lodgment of the soldiers and marines of
                                    Captain Wiltse, of the U. S. <hi rend="italic">Boston</hi>, at a
                                    fair price! Let the bearer know.</p>
                <p>Yours truly,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John L. Stevens</hi>,<lb/>
                        <hi rend="italic">United States
                                    Minister.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
