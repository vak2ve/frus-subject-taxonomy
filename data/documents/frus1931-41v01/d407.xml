                subtype="historical-document" type="document" xml:id="d407">
                <note rend="inline" type="source">394.115 Panay/441: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1938-04-22T17:00:00+09:00"
                            >April 22, 1938—5 p.m.</date>
                        <lb/>[Received April 22—5:37 a.m.]</dateline>
                </opener>
                <p>264. My 262, April 22, noon.<note n="32" xml:id="d407fn32">Not printed.</note>
                    <hi rend="italic">Panay</hi> check for $2,214,007.36, payable to the order of
                    the Secretary of State of the United States of America, received at 5 p.m.
                    today.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
