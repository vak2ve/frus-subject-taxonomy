    <text>
        <body>
            <div frus:doc-dateTime-max="1905-06-01T23:59:59-05:00"
                frus:doc-dateTime-min="1905-06-01T00:00:00-05:00" n="935"
                subtype="historical-document" type="document" xml:id="d935">
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to the
                            <gloss type="to">King of Spain</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The White House</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-06-01">
                            <hi rend="italic">June 1, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>I congratulate Your Majesty upon the providential escape from the wicked attempt
                    upon Your Majesty’s safety and life.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
