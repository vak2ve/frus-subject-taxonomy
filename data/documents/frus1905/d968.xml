<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1905-11-16T23:59:59-05:00" frus:doc-dateTime-min="1905-11-16T00:00:00-05:00" n="968" subtype="historical-document" type="document" xml:id="d968">
                        <head><hi rend="italic">The <gloss type="from">Minister of Foreign Affairs
                                    of Norway</gloss> to the <gloss type="to">Secretary of
                                    State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Christiania</hi></placeName>, <date calendar="gregorian" when="1905-11-16"><hi rend="italic">November 16,
                                    1905</hi></date>.</dateline></opener>
                        <p>United States consular representatives in Norway having been recognized
                            by Norwegian Government new exequaturs for these officers are not
                            required.</p>
                        <closer><signed><hi rend="smallcaps">Löveland.</hi></signed></closer>
                    </div>
                    </body></text></TEI>