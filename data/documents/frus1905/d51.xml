                subtype="historical-document" type="document" xml:id="d51">
                <head>
                    <hi rend="italic">The <gloss type="from">President of Panama</gloss> to
                        President <persName type="to">Roosevelt</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Panama</hi>
                        </placeName>, <date calendar="gregorian" when="1905-07-01">
                            <hi rend="italic">July 1, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>The Government and people of Panama participate in the sorrow of the Government
                    and people of the United States at the death of their eminent Secretary of
                    State, Mr. John Hay.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">M. Amador Guerrero.</hi>
                    </signed>
                </closer>
            </div>
        </body>
