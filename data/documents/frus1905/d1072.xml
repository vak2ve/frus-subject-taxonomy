                <head>
                    <hi rend="italic">Minister <persName type="from">Bowen</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Caracas</hi>
                        </placeName>, <date calendar="gregorian" when="1905-02-25">
                            <hi rend="italic">February 25, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>In answer to your telegram of the 24th, I prefer to remain here for the
                    present.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bowen.</hi>
                    </signed>
                </closer>
            </div>
        </body>
