<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1905-02-25T23:59:59-05:00" frus:doc-dateTime-min="1905-02-25T00:00:00-05:00" n="1072" subtype="historical-document" type="document" xml:id="d1072">
                        <head><hi rend="italic">Minister <persName type="from">Bowen</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Legation</hi>,<lb/><hi rend="italic">Caracas</hi></placeName>, <date calendar="gregorian" when="1905-02-25"><hi rend="italic">February 25,
                                    1905</hi></date>.</dateline></opener>
                        <p>In answer to your telegram of the 24th, I prefer to remain here for the
                            present.</p>
                        <closer><signed><hi rend="smallcaps">Bowen.</hi></signed></closer>
                    </div>
                    </body></text></TEI>