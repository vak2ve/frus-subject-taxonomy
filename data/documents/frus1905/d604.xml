    <text>
        <body>
            <div frus:doc-dateTime-max="1905-12-21T23:59:59-05:00"
                frus:doc-dateTime-min="1905-12-21T00:00:00-05:00" n="604"
                subtype="historical-document" type="document" xml:id="d604">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Japanese Chargé</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-12-21">
                            <hi rend="italic">December 21, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Chargé</hi>: I beg to inclose for your information
                    copy of a note which I have addressed to Mr. Min Yeung-Tchan, Korean minister at
                        Paris,<note n="a" xml:id="d604fna">Printed under Korea, <ref
                            target="#pg_629">p. 629</ref>.</note> indicating this Government’s
                    attitude in regard to the relations between Japan and Korea.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Elihu Root.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
