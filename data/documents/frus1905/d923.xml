                subtype="historical-document" type="document" xml:id="d923">
                <head>
                    <hi rend="italic">Chargé <persName type="from">Eddy</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">St. Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1905-11-29">
                            <hi rend="italic">November 29, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Eddy reports that no further accurate information in regard to destitution
                    of the Jews and the losses sustained by them can be obtained. No Jews were
                    injured at St. Petersburg and Moscow.)</p>
            </div>
        </body>
