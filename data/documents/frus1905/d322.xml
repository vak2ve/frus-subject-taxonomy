                <head>
                    <hi rend="italic">Minister <persName type="from">Dawson</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1905-02-07">
                            <hi rend="italic">February 7, 1905</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 109.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I herewith inclose originals in English and in
                    Spanish of the protocol between the American and the Dominican Governments
                    signed by me in virtue of the full powers telegraphed on February 6 by the
                    President of the United States to the President of the Dominican Republic.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">T. C. Dawson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
