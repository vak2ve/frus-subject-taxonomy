                subtype="historical-document" type="document" xml:id="d801">
                <head>
                    <hi rend="italic">Chargé <persName type="from">Eddy</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">St. Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1905-10-28">
                            <hi rend="italic">October 28, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Eddy reports the situation unchanged. There is no rioting in St. Petersburg,
                    and all communication has ceased throughout the Empire.)</p>
            </div>
        </body>
