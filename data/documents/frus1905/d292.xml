    <text>
        <body>
            <div frus:doc-dateTime-max="1905-04-06T23:59:59-05:00"
                frus:doc-dateTime-min="1905-04-06T00:00:00-05:00" n="292"
                subtype="historical-document" type="document" xml:id="d292">
                <head>
                    <hi rend="italic">The <gloss type="from">Chief of the Bureau of Accounts</gloss>
                        to the <gloss type="to">Cuban Minister</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-04-06">
                            <hi rend="italic">April 6, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: By direction of the Acting Secretary of State I
                    have the honor to refer you to the memorandum of the Department of the 17th of
                    January last, and to your reply of the 29th ultimo, in connection with the claim
                    of Luciano Arestuche, and to inclose herewith a receipt for $500 in full payment
                    of the same, together with my check for the said amount.</p>
                <p>I will thank you to sign the receipt and return it to me.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Thomas Morrison.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
