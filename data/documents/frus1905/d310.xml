                subtype="historical-document" type="document" xml:id="d310">
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to the
                            <gloss type="to">King Elect of Norway</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-11-20">
                            <hi rend="italic">November 20, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>I felicitate Your Majesty on being chosen by the Norwegian people to succeed to
                    the throne of Haakon and Olaf—of Harold and S gurd.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
