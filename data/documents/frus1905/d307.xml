                subtype="historical-document" type="document" xml:id="d307">
                <head>
                    <hi rend="italic">Chargé <persName type="from">Lorillard</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Copenhagen</hi>
                        </placeName>, <date calendar="gregorian" when="1905-12-19">
                            <hi rend="italic">December 19, 1905</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 59.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to report that a general treaty
                    of arbitration between Denmark and Italy was signed on the 14th instant at
                    Rome.</p>
                <p>While the text of the treaty has not yet been made public, I am in a position to
                    state that by its terms all differences which may occur between the two
                    countries are to be referred to the Permanent Court of. Arbitration at The Hague
                    for final settlement.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">George L. Lorillard.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
