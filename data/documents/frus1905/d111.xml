<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1905-10-27T23:59:59-05:00" frus:doc-dateTime-min="1905-10-27T00:00:00-05:00" n="111" subtype="historical-document" type="document" xml:id="d111">
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Wilson</persName></hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1905-10-27"><hi rend="italic">October 27,
                                1905</hi></date>.</dateline></opener>
                        <p>You may sign protocol of Maritime Conference similar to that of February
                            25, last signed by Mr. Townsend.</p>
                        <closer><signed><hi rend="smallcaps">Root.</hi></signed></closer>
                    </div>
                    </body></text></TEI>