                subtype="historical-document" type="document" xml:id="d764">
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Meyer</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">St. Petersburg</hi>
                        </placeName>, <date calendar="gregorian" when="1905-07-20">
                            <hi rend="italic">July 20, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>Prize crew put on <hi rend="italic">Oldhamia</hi> May 21, not since reported.
                    Government no information. Lamsdorff promises to report when known.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Meyer.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
