                subtype="historical-document" type="document" xml:id="d217">
                <head>
                    <hi rend="italic">Minister <persName type="from">Rockhill</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1905-07-01">
                            <hi rend="italic">July 1, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Rockhill reports that orders have been issued by the Chinese foreign office
                    to all viceroys and governors to stop the attempted boycott on American goods
                    and the anti-American agitation.)</p>
            </div>
        </body>
