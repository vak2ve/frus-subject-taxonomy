                subtype="historical-document" type="document" xml:id="d109">
                <head>
                    <hi rend="italic">Minister <persName type="from">Townsend</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Brussels</hi>
                        </placeName>, <date calendar="gregorian" when="1905-03-16">
                            <hi rend="italic">March 16, 1905</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 253.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    Department’s cable of yesterday’s date. * * *</p>
                <p>In conformity with instructions, I have signed the protocol of the International
                    Maritime Conference held at Brussels, February 25 last. * * *</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lawrence Townsend.</hi>
                    </signed>
                </closer>
            </div>
        </body>
