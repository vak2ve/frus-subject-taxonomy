                subtype="historical-document" type="document" xml:id="d182">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Chargé
                            <persName type="to">Coolidge</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-03-02">
                            <hi rend="italic">March 2, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Hay informs Mr. Coolidge that the Chinese proposal relating to the payment
                    of the indemnity is acceptable to the Government of the United States.)</p>
            </div>
