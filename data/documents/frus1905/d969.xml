                subtype="historical-document" type="document" xml:id="d969">
                <head>
                    <hi rend="italic">The <gloss type="from">Norwegian Chargé</gloss> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Norway</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-11-18">
                            <hi rend="italic">November 18, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: At the request of my government I have the honor
                    to inform your excellency that to-day Prince Carl of Denmark was unanimously
                    elected King of Norway by the Storthing.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Ch. Hauge.</hi>
                    </signed>
                </closer>
            </div>
        </body>
