                subtype="historical-document" type="document" xml:id="d43">
                <head>
                    <hi rend="italic">The <gloss type="from">Korean Chargé</gloss> to the <gloss
                            type="to">Acting Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Korea</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-07-05">
                            <hi rend="italic">July 5, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I am directed by the minister of foreign affairs
                    to express, on behalf of His Majesty the Emperor and the Government of Korea,
                    the warmest sympathy and condolence with the United States on the death of Hon.
                    John Hay, Secretary of State.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Yun Chung Kim.</hi>
                    </signed>
                </closer>
            </div>
        </body>
