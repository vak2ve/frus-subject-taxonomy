                subtype="historical-document" type="document" xml:id="d40">
                <head>
                    <hi rend="italic">The <gloss type="from">Haitian Minister</gloss> to the <gloss
                            type="to">Acting Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Deer Park, Md.</hi>
                        </placeName>, <date calendar="gregorian" when="1905-07-01">
                            <hi rend="italic">July 1, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>I have heard with sorrow of the death of Hon. John Hay. In my name and in the
                    name of the Haitian Government, I beg to convey our heartfelt condolence to the
                    people and the Government of the United States.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">J. N. Léger.</hi>
                    </signed>
                </closer>
            </div>
        </body>
