    <text>
        <body>
            <div frus:doc-dateTime-max="1905-11-13T23:59:59-05:00"
                frus:doc-dateTime-min="1905-11-13T00:00:00-05:00" n="851"
                subtype="historical-document" type="document" xml:id="d851">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Chargé
                            <persName type="to">Eddy</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-11-13">
                            <hi rend="italic">November 13, 1905</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 93.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I inclose herewith, for your information, a copy
                    of a letter from the Secretary of the Navy, transmitting one from the commandant
                    of the Mare Island Navy-Yard, in which he informs the Secretary of the good
                    conduct of the officers and crew of the Russian armed transport <hi
                        rend="italic">Lena</hi> while that vessel was interned at the yard.<note
                        n="a" xml:id="d851fna">Not printed.</note>
                </p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Elihu Root.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
