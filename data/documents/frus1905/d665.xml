                subtype="historical-document" type="document" xml:id="d665">
                <head>
                    <hi rend="italic">Minister <persName type="from">Jackson</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Cettinje</hi>
                        </placeName>, <date calendar="gregorian" when="1905-10-31">
                            <hi rend="italic">October 31, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>Presented credentials to-day. Prince requested me to express gratitude to
                    President. Propose leaving Friday for Greece via Italy. Wilson in charge at
                    Athens.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Jackson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
