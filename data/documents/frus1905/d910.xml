                subtype="historical-document" type="document" xml:id="d910">
                <head>
                    <hi rend="italic">The <gloss type="from">Japanese Minister</gloss> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Japan</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-10-16">
                            <hi rend="italic">October 16, 1905</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 62.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to your conversation on Thursday, the
                    12th instant, I have the honor to inform you that I have received this morning a
                    telegram from His Majesty’s minister for foreign affairs, advising that the
                    French minister at Tokyo handed him yesterday, the 15th instant, notification
                    regarding ratification of the treaty of peace by His Majesty the Emperor of
                    Russia.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">K. Takahira.</hi>
                    </signed>
                </closer>
            </div>
        </body>
