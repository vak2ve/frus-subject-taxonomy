<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1905-12-22T23:59:59-05:00" frus:doc-dateTime-min="1905-12-22T00:00:00-05:00" n="272" subtype="historical-document" type="document" xml:id="d272">
                        <head><hi rend="italic">President <persName type="from">Roosevelt</persName>
                                to President <persName type="to">Reyes</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1905-12-22"><hi rend="italic">December 22,
                                    1905</hi></date>.</dateline></opener>
                        <p>I offer you my congratulations upon the frustration of the reported
                            attempt against your personal safety.</p>
                        <closer><signed><hi rend="smallcaps">Theodore
                            Roosevelt.</hi></signed></closer>
                    </div>
                    </body></text></TEI>