                subtype="historical-document" type="document" xml:id="d1115">
                <head>
                    <hi rend="italic">Acting Secretary of State <persName type="from"
                            >Loomis</persName> to Minister <persName type="to"
                        >Bowen</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-02-02">
                            <hi rend="italic">February 2, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>(States that the Department is unable to submit to arbitration the question
                    whether cases are or are not diplomatic, but Mr. Bowen may use his discretion
                    about communicating this government’s position to the Venezuelan
                    Government.)</p>
            </div>
        </body>
