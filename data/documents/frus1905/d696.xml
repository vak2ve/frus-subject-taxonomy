<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1905-12-04T23:59:59-05:00" frus:doc-dateTime-min="1905-12-04T00:00:00-05:00" n="696" subtype="historical-document" type="document" xml:id="d696">
                        <head><hi rend="italic">Minister <persName type="from">Collier</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Madrid</hi></placeName>, <date calendar="gregorian" when="1905-12-04"><hi rend="italic">December 4,
                                1905</hi></date>.</dateline></opener>
                        <p>Have been informed by under secretary of state Morocco conference
                            postponed until first week in January.</p>
                        <closer><signed><hi rend="smallcaps">Collier.</hi></signed></closer>
                    </div>
                    </body></text></TEI>