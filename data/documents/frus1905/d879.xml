                subtype="historical-document" type="document" xml:id="d879">
                <head>
                    <hi rend="italic">Minister <persName type="from">Griscom</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1905-06-09">
                            <hi rend="italic">June 9, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>Your telegram of the morning of the 8th received 8 p.m. to-day and presented to
                    the Japanese Government at 11 p.m. Answer follows to-night.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Griscom.</hi>
                    </signed>
                </closer>
            </div>
        </body>
