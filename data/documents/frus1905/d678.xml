                subtype="historical-document" type="document" xml:id="d678">
                <head>
                    <hi rend="italic">Minister <persName type="from">Gummeré</persName> to Acting
                        Secretary of State <persName type="to">Adee</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Tangier</hi>
                        </placeName>, <date calendar="gregorian" when="1905-08-01">
                            <hi rend="italic">August 1, 1905</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 38.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I beg to report that I have been informed by the
                    Portuguese minister that his government has accepted the invitation to take part
                    in the proposed Morocco conference. The only goverment remaining to be heard
                    from is that of Norway and Sweden.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">S. R. Gummeré.</hi>
                    </signed>
                </closer>
            </div>
        </body>
