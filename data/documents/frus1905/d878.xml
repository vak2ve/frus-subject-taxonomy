                subtype="historical-document" type="document" xml:id="d878">
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Minister <persName type="to">Griscom</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-06-08">
                            <hi rend="italic">June 8, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>Please inform Department without delay when you present my cablegram of this
                    morning to the Japanese Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Loomis.</hi>
                    </signed>
                </closer>
            </div>
        </body>
