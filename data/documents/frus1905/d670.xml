                subtype="historical-document" type="document" xml:id="d670">
                <head>
                    <hi rend="italic">Ambassador <persName type="from">McCormick</persName> to
                        Acting Secretary of State <persName type="to">Adee</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1905-07-10">
                            <hi rend="italic">July 10, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>France, with agreement of England, accepts invitation of Morocco to a conference
                    on the understanding with Germany that her rights are respected, and that her
                    arrangements with England and Spain will not be questioned nor will the
                    open-door policy be altered.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">McCormick.</hi>
                    </signed>
                </closer>
            </div>
        </body>
