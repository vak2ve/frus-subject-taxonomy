                subtype="historical-document" type="document" xml:id="d380">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                        Ambassador <persName type="to">Porter</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-06-20">
                            <hi rend="italic">June 20, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>Obtain permission to land military force under arms from Rear-Admiral Sigsbee’s
                    squadron as escort for body Paul Jones.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
