<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1905-07-29T23:59:59-05:00" frus:doc-dateTime-min="1905-07-29T00:00:00-05:00" n="768" subtype="historical-document" type="document" xml:id="d768">
                        <head><hi rend="italic">Ambassador <persName type="from">Meyer</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Embassy</hi>,<lb/><hi rend="italic">St
                                        Petersburg</hi></placeName>, <date calendar="gregorian" when="1905-07-29"><hi rend="italic">July 29,
                                1905</hi></date>.</dateline></opener>
                        <p>British embassy informs me that Russian foreign office notified them that
                            shells were found on board <hi rend="italic">Oldhamia.</hi></p>
                        <closer><signed><hi rend="smallcaps">Meyer.</hi></signed></closer>
                    </div>
                    </body></text></TEI>