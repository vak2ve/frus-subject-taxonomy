    <text>
        <body>
            <div frus:doc-dateTime-max="1905-11-04T23:59:59-05:00"
                frus:doc-dateTime-min="1905-11-04T00:00:00-05:00" n="413"
                subtype="historical-document" type="document" xml:id="d413">
                <head>
                    <hi rend="italic">The <gloss type="from">British Ambassador</gloss> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">British Embassy</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-11-04">
                            <hi rend="italic">November 4, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Secretary</hi>: I have received your note of
                    yesterday’s date respecting the preservation of Niagara Falls.</p>
                <p>I have thought it well to telegraph to Lord Lansdowne your proposal that the
                    question should be referred for investigation to the International Waterways
                    Commission.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">H. M. Durand.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
