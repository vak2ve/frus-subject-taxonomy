                subtype="historical-document" type="document" xml:id="d53">
                <head>
                    <hi rend="italic">The <gloss type="from">President of Peru</gloss> to President
                            <persName type="to">Roosevelt</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1905-07-01">
                            <hi rend="italic">July 1, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>My government participates in the sorrow of the United States at the death of the
                    illustrious Secretary Hay.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Pardo.</hi>
                    </signed>
                </closer>
            </div>
        </body>
