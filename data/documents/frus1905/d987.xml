<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1905-07-22T23:59:59-05:00" frus:doc-dateTime-min="1905-07-22T00:00:00-05:00" n="987" subtype="historical-document" type="document" xml:id="d987">
                        <head><hi rend="italic">President <persName type="from">Roosevelt</persName>
                                to the <gloss type="to">Sultan of Turkey</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">The
                                        White House</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1905-07-22"><hi rend="italic">July 22,
                                1905</hi></date>.</dateline></opener>
                        <p>I felicitate Your Majesty on your fortunate escape.</p>
                        <closer><signed><hi rend="smallcaps">Theodore
                            Roosevelt.</hi></signed></closer>
                    </div>
                </body></text></TEI>