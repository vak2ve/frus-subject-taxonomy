                subtype="historical-document" type="document" xml:id="d100">
                <head>
                    <hi rend="italic">Chargé <persName type="from">Rives</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1905-07-13">
                            <hi rend="italic">July 13, 1905</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 253.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    the Department’s instruction No. 170, bearing date of June 28, 1905, with
                    inclosures, and to say that the Department’s intentions expressed therein, as
                    well as those of the instruction No. 165, of 23d of June, 1905, have been
                    carried out to the best of my judgment.</p>
                <p rend="center">* * * * * * *</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">George Barclay Rives.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
