                subtype="historical-document" type="document" xml:id="d12">
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">Diplomatic Officers of the United States</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-07-01">
                            <hi rend="italic">July 1, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>Secretary Hay died unexpectedly at 12.25 this morning. Notify government and
                    display usual symbols of mourning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Peirce</hi>, <hi rend="italic">Acting.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
