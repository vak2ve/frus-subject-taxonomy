                subtype="historical-document" type="document" xml:id="d436">
                <head>
                    <hi rend="italic">Chargé <persName type="from">Carter</persName> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">London</hi>
                        </placeName>, <date calendar="gregorian" when="1905-12-18">
                            <hi rend="italic">December 18, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Carter conveys the thanks of Sir Edward Grey for the prompt action of the
                    Department in regard to the matter reported in his telegram of the 16th instant.
                    Equal prompt consideration will be given to Department’s recommendation
                    regarding the cutting of nets.)</p>
            </div>
        </body>
