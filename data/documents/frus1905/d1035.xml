    <text>
        <body>
            <div frus:doc-dateTime-max="1904-07-25T23:59:59-05:00"
                frus:doc-dateTime-min="1904-07-25T00:00:00-05:00" n="1035"
                subtype="historical-document" type="document" xml:id="d1035">
                <head>
                    <hi rend="italic">Acting Secretary of State <persName type="from"
                            >Adee</persName> to Minister <persName type="to">Bowen</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1904-07-25">
                            <hi rend="italic">July 25, 1904</hi>
                        </date>.<lb/>(Received July 29, 1904.)</dateline>
                </opener>
                <p>(Mr. Bowen is directed to advise the Venezuelan Government that if facts are as
                    reported the United States earnestly protests. Further instrcutions will follow
                    to-morrow.)</p>
            </div>
        </body>
