                subtype="historical-document" type="document" xml:id="d603">
                <head>
                    <hi rend="italic">The <gloss type="from">Japanese Chargé</gloss> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Japan</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-12-12">
                            <hi rend="italic">December 12, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Under instructions from His Majesty’s minister
                    for foreign affairs, I have the honor to announce hereby the withdrawal of the
                    Korean legation at Washington and the Korean consulates in this country, the
                    powers and functions of diplomatic and consular representatives of Korea having
                    already been transferred to the diplomatic and consular representatives of
                    Japan, respectively, accredited to this country in consequence of the agreement
                    concluded between Japan and Korea on November 17, 1905.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Eki Hioki.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
