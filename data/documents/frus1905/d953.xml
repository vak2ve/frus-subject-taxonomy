                subtype="historical-document" type="document" xml:id="d953">
                <head>
                    <hi rend="italic">The <gloss type="from">Minister of Foreign Affairs of
                            Norway</gloss> to the <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Christiania</hi>
                        </placeName>, <date calendar="gregorian" when="1905-11-01">
                            <hi rend="italic">November 1, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>Norwegian Government presents heartiest thanks for kind telegram 30 October.
                    Hauge ordered to go Washington immediately as chargé d’affaires.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lövland</hi>.</signed>
                </closer>
            </div>
        </body>
