<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1905-04-15T23:59:59-05:00" frus:doc-dateTime-min="1905-04-15T00:00:00-05:00" n="377" subtype="historical-document" type="document" xml:id="d377">
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to General <persName type="to">Porter</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1905-04-15"><hi rend="italic">April 15,
                                1905</hi></date>.</dateline></opener>
                        <p>The Department has great pleasure in sending cordial congratulations upon
                            your success in finding body of Paul Jones.</p>
                        <closer><signed><hi rend="smallcaps">Loomis.</hi></signed></closer>
                    </div>
                    </body></text></TEI>