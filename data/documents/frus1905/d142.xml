                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Chargé <persName type="to">Coolidge</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1905-02-27"><hi rend="italic">February 27,
