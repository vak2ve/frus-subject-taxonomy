                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Minister <persName type="to">Dawson</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-01-24">
                            <hi rend="italic">January 24, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>Cable full text of agreement signed by you and Dillingham.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Loomis.</hi>
                    </signed>
                </closer>
            </div>
