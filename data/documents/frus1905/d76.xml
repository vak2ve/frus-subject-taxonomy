                subtype="historical-document" type="document" xml:id="d76">
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        Minister <persName type="to">Beaupré</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1905-04-26">
                            <hi rend="italic">April 26, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has read with pleasure the
                    announcement contained in your dispatch No. 136, of the 16th ultimo, of the
                    resumption of diplomatic relations between the Argentine Republic and
                    Uruguay.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alvey A. Adee.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
