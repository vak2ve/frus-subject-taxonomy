<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1905-07-19T23:59:59-05:00" frus:doc-dateTime-min="1905-07-19T00:00:00-05:00" n="67" subtype="historical-document" type="document" xml:id="d67">
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">Diplomatic and Consular Officers of the United
                                    States</gloss>.</hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1905-07-19"><hi rend="italic">July 19,
                                1905</hi></date>.</dateline></opener>
                        <p><hi rend="smallcaps">Gentlemen</hi>: I have to inform you that the
                            President has appointed me to be Secretary of State of the United
                            States, and that I have this day entered upon the duties of the
                            office.</p>
                        <p>I am, gentlemen, your most obedient servant,</p>
                        <closer><signed><hi rend="smallcaps">Elihu Root.</hi></signed></closer>
                    </div>
                </body></text></TEI>