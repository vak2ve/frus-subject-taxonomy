                subtype="historical-document" type="document" xml:id="d60">
                <head>
                    <hi rend="italic">The <gloss type="from">Siamese Minister</gloss> to President
                            <persName type="to">Roosevelt</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">East Gloucester, Mass.</hi>
                        </placeName>,<lb/>
                        <date calendar="gregorian" when="1905-07-02">
                            <hi rend="italic">July 2, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>I am commanded by my sovereign to express his deepest sympathy with you and with
                    the people of the United States in the lamented death of your most distinguished
                    and universally respected statesman the Hon. John Hay.</p>
                <closer>
                    <hi rend="smallcaps">Siamese Minister.</hi>
                </closer>
            </div>
        </body>
