<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1905-07-11T23:59:59-05:00" frus:doc-dateTime-min="1905-07-11T00:00:00-05:00" n="795" subtype="historical-document" type="document" xml:id="d795">
                        <head><hi rend="italic">Ambassador <persName type="from">Meyer</persName> to
                                the <gloss type="to">Secretary of State</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Embassy</hi>,<lb/><hi rend="italic">St.
                                        Petersburg</hi></placeName>, <date calendar="gregorian" when="1905-07-11"><hi rend="italic">July 11,
                                1905</hi></date>.</dateline></opener>
                        <p>(Mr. Meyer transmits a telegram from the American consul at Moscow
                            reporting the assassination of Count Souvaloff, chief of police, and the
                            apprehension of the assassin.)</p>
                    </div>
                    </body></text></TEI>