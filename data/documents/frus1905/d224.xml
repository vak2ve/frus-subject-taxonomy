                subtype="historical-document" type="document" xml:id="d224">
                <head>
                    <hi rend="italic">Minister <persName type="from">Rockhill</persName> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1905-08-12">
                            <hi rend="italic">August 12, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Rockhill reports that he has complied with the instructions contained in
                    Department’s telegram of the 5th instant and that he has formally notified the
                    Chinese Government of its responsibility.)</p>
            </div>
        </body>
