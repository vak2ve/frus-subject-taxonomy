                <head>
                    <hi rend="italic">The <gloss type="from">President of Nicaragua</gloss> to
                        President <persName type="to">Roosevelt</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="italic">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1905-07-01">
                            <hi rend="italic">July 1, 1905</hi>
                        </date>.</dateline>
                </opener>
                <p>I regret the death of the eminent Secretary of State.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Zelaya.</hi>
                    </signed>
                </closer>
            </div>
        </body>
