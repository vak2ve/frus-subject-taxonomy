<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1905-03-14T23:59:59-05:00" frus:doc-dateTime-min="1905-03-14T00:00:00-05:00" n="108" subtype="historical-document" type="document" xml:id="d108">
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Minister <persName type="to">Townsend</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1905-03-14"><hi rend="italic">March 14,
                                1905</hi></date>.</dateline></opener>
                        <p>You may sign protocol agreeing to submit, with a view to examination,
                            projects of maritime conference.</p>
                        <closer><signed><hi rend="smallcaps">Adee.</hi></signed></closer>
                    </div>
                    </body></text></TEI>