    <text>
        <body>
            <div frus:doc-dateTime-max="1951-08-29T23:59:59-05:00"
                frus:doc-dateTime-min="1951-08-29T00:00:00-05:00" n="110"
                subtype="historical-document" type="document" xml:id="d110">
                <note rend="inline" type="source">Lot 54D423</note>
                <head>
                    <hi rend="italic">The Assistant Secretary of State for Far Eastern Affairs</hi>
                        (<persName type="from">
                        <hi rend="italic">Rusk</hi>
                    </persName>) <hi rend="italic">to the Secretary of Foreign Affairs of the
                        Philippines</hi> (<persName type="to">
                        <hi rend="italic">Romulo</hi>
                    </persName>)<note n="1" xml:id="d110fn1">Letter drafted by Mr. Dulles.</note>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1951-08-29">August 29,
                            1951</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: In connection with the Mutual
                    Defense Treaty which we are about to sign I want to confirm to you our
                    understanding that there is an interdependence between this Treaty and the
                    contemplated Japanese Peace Treaty in the sense that it is assumed that both of
                    us will sign and ratify both Treaties.</p>
                <p>Sincerely yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dean Rusk</hi>
                    </signed>
                </closer>
            </div>
        </body>
