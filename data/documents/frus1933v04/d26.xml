                subtype="historical-document" type="document" xml:id="d26">
                <note rend="inline" type="source">710.G 1A/222: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Mexico</hi> (<persName type="from">
                        <hi rend="italic">Daniels</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1933-10-09T12:00:00-06:00"
                            >October 9, 1933—noon</date>.<lb/>[Received 1:25 p.m.]</dateline>
                </opener>
                <p>205. Dr. Puig informs me that President Rodríguez approved his memorandum on the
                    Monroe Doctrine which was transmitted by air mail on Saturday with despatch 668
                    of October 7 [<hi rend="italic">6</hi>], 1933.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Daniels</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
