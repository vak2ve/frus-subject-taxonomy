<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-05-13T12:00:00-05:00" frus:doc-dateTime-min="1933-05-13T12:00:00-05:00" n="569" subtype="historical-document" type="document" xml:id="d569">
                        <note rend="inline" type="source">721.23/1713: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Peru</hi> (<persName type="to"><hi rend="italic">Dearing</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1933-05-13T13:00:00-04:00">May 13, 1933—1
                                p.m.</date></dateline>
                        </opener>
                        <p>61. Your 141, May 12, 2 p.m. Department desires you to present note
                            immediately.</p>
                        <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
