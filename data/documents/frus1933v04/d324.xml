<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-10-03T07:00:00-05:00" frus:doc-dateTime-min="1933-10-03T07:00:00-05:00" n="324" subtype="historical-document" type="document" xml:id="d324">
                        <note rend="inline" type="source">724.3415/3343: Telegram</note>
                        <head><hi rend="italic">The Consul at Geneva</hi> (<persName type="from"><hi rend="italic">Gilbert</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Geneva</hi></placeName>, <date calendar="gregorian" when="1933-10-03T13:00:00+01:00">October 3, 1933—1
                                p.m.</date><lb/>[Received October 3—9:55 a.m.]</dateline>
                        </opener>
                        <p>211. Consulate’s 208, October 2, 2 p.m., final paragraph. Council
                            Committee of Three are notifying League Chaco Commission to hold
                            themselves in readiness to proceed at an early date.</p>
                        <closer><signed><hi rend="smallcaps">Gilbert</hi></signed></closer>
                    </div>
