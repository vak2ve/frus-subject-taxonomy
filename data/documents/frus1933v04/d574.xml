<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-05-17T12:00:00-05:00" frus:doc-dateTime-min="1933-05-17T12:00:00-05:00" n="574" subtype="historical-document" type="document" xml:id="d574">
                        <note rend="inline" type="source">721.23/1730: Telegram</note>
                        <head><hi rend="italic">The Minister in Colombia</hi> (<persName type="from"><hi rend="italic">Caffery</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi><note n="81" xml:id="d574fn81">Repeated to the Minister in Switzerland, May 18, 2
                                p.m., as telegram No. 102.</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1933-05-17T12:00:00-05:00">May 17,
                                1933—noon</date>.<lb/>[Received 2 p.m.]</dateline>
                        </opener>
                        <p>53. Olaya says Lopez Lima negotiations appear to have been unsuccessful;
                            in his opinion May 10th formula “is the only hope”.</p>
                        <closer><signed><hi rend="smallcaps">Caffery</hi></signed></closer>
                    </div>
                    </body></text></TEI>