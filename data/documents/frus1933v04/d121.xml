                subtype="historical-document" type="document" xml:id="d121">
                <note rend="inline" type="source">710.G1A/321: Telegram</note>
                <head>
                    <hi rend="italic">The Chairman of the American Delegation</hi> (<persName
                        type="from">
                        <hi rend="italic">Hull</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Montevideo</hi>
                        </placeName>, <date calendar="gregorian" when="1933-12-23T11:00:00-03:00"
                            >December 23, 1933—11 a.m.</date>
                        <lb/>[Received December 23—10:30 a.m.]</dateline>
                </opener>
                <p>81. Latest plans contemplate disposing of all points on entire agenda by Tuesday
                        next.<note n="46" xml:id="d121fn46">December 26.</note> Best opinion is that
                    peace negotiations appear fairly encouraging.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
