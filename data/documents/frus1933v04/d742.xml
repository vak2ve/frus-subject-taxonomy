                subtype="historical-document" type="document" xml:id="d742">
                <note rend="inline" type="source">835.5151/123: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Argentina</hi> (<persName type="from">
                        <hi rend="italic">White</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1933-06-08T12:00:00-04:00"
                            >June 8, 1933—noon</date>.<lb/>[Received 1:40 p.m.]</dateline>
                </opener>
                <p>53. Your June 3, 3 p.m.; my 51, June 7, 6 p.m. Reliably informed that it is the
                    Argentine Government’s intention to rescind objectionable circular.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">White</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
