                subtype="historical-document" type="document" xml:id="d596">
                <note rend="inline" type="source">721.23/1915: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Peru</hi> (<persName type="from">
                        <hi rend="italic">Dearing</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1933-07-25T11:00:00-05:00"
                            >July 25, 1933—11 a.m.</date>
                        <lb/>[Received 12:45 p.m.]</dateline>
                </opener>
                <p>176. Please instruct Embassy regarding Bogotá’s 68, July 24, 2 p.m., regarding
                    initiation Colombian-Peruvian negotiations settlement Leticia dispute.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dearing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
