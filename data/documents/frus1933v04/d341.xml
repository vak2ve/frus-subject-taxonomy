                subtype="historical-document" type="document" xml:id="d341">
                <note rend="inline" type="source">724.3415/3422: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Bolivia</hi> (<persName type="from">
                        <hi rend="italic">Des Fortes</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">La Paz</hi>
                        </placeName>, <date calendar="gregorian" when="1933-12-06T16:00:00-04:00"
                            >December 6, 1933—4 p.m.</date>
                        <lb/>[Received 4:28 p.m.]</dateline>
                </opener>
                <p>94. The League Commission arrived in La Paz last night and was warmly
                    welcomed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Des Portes</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
