                <note rend="inline" type="source">721.23/669 Supp.: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Brazil</hi> (<persName type="to">
                        <hi rend="italic">Morgan</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1933-01-08T12:00:00-05:00"
                            >January 8, 1933—noon</date>.</dateline>
                </opener>
                <p>5. Following message has been received from Bogotá. (Quote No. 8, January 7, 6
                    p.m., from Bogotá.)</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Castle</hi>
                    </signed>
                </closer>
            </div>
        </body>
