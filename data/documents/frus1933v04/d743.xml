                <note rend="inline" type="source">835.5151/122: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Argentina</hi> (<persName type="to">
                        <hi rend="italic">White</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1933-06-09T14:00:00-04:00"
                            >June 9, 1933—2 p.m.</date>
                    </dateline>
                </opener>
                <p>34. Your 51, June 7, 6 p.m. You are authorized to present to the Minister for
                    Foreign Affairs an <hi rend="italic">aide-mémoire</hi> on each of these
                    subjects.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
