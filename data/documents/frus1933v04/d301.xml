<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-07-27T11:00:00-05:00" frus:doc-dateTime-min="1933-07-27T11:00:00-05:00" n="301" subtype="historical-document" type="document" xml:id="d301">
                        <note rend="inline" type="source">724.3415/3249: Telegram</note>
                        <head><hi rend="italic">The Chargé in Paraguay</hi> (<persName type="from"><hi rend="italic">Horn</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Asunción</hi></placeName>, <date calendar="gregorian" when="1933-07-27T12:00:00-04:00">July 27,
                                1933—noon</date>.<lb/>[Received 1:50 p.m.]</dateline>
                        </opener>
                        <p>79. My 78, July 26, 11 a.m. was in error in stating that the League had
                            approved the suggestion.</p>
                        <closer><signed><hi rend="smallcaps">Horn</hi></signed></closer>
                    </div>
                    </body></text></TEI>