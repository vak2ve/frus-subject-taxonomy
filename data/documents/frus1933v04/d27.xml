                <note rend="inline" type="source">710.G/263: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Brazil</hi> (<persName type="to">
                        <hi rend="italic">Gibson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1933-10-10T19:00:00-05:00"
                            >October 10, 1933—7 p.m.</date>
                    </dateline>
                </opener>
                <p>77. Your telegram No. 86, October 4, 1 p.m. Please telegraph any further
                    information you may have as to this matter.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
