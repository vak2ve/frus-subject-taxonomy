                        <note rend="inline" type="source">721.23/1150: Telegram</note>
                        <head><hi rend="italic">The Minister in Colombia</hi> (<persName type="from"><hi rend="italic">Caffery</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1933-02-15T10:00:00-05:00">February 15, 1933—10
