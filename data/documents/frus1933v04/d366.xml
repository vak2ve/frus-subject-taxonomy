                subtype="historical-document" type="document" xml:id="d366">
                <note rend="inline" type="source">724.3415/3463: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Paraguay</hi> (<persName type="from">
                        <hi rend="italic">Nicholson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Asunción</hi>
                        </placeName>, <date calendar="gregorian" when="1933-12-29T15:00:00-04:00"
                            >December 29, 1933—3 p.m.</date>
                        <lb/>[Received 5:05 p.m.]</dateline>
                </opener>
                <p>Paraguay has agreed to extension of the armistice for 8 days. Repeated to La Paz,
                    Montevideo, and Buenos Aires.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Nicholson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
