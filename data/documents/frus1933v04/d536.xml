<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-03-18T10:00:00-05:00" frus:doc-dateTime-min="1933-03-18T10:00:00-05:00" n="536" subtype="historical-document" type="document" xml:id="d536">
                        <note rend="inline" type="source">721.23/1446: Telegram</note>
                        <head><hi rend="italic">The Consul at Geneva</hi> (<persName type="from"><hi rend="italic">Gilbert</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Geneva</hi></placeName>, <date calendar="gregorian" when="1933-03-18T16:00:00+01:00">March 18, 1933—4 [<hi rend="italic">1?</hi>] p.m.</date><lb/>[Received March
                                18—9:30 a.m.]</dateline>
                        </opener>
                        <p>81. Wilson’s No. 153, March 18, 2 p.m. [<hi rend="italic">9
                                a.m.?</hi>]<note n="47" xml:id="d536fn47">Not printed.</note> Report
                            and Council resolution in Colombia-Peruvian dispute adopted unanimously
                            by the Council at meeting just terminated. Accepted by Colombia. Not
                            accepted by Peru. Details of the meeting follow.</p>
                        <closer><signed><hi rend="smallcaps">Gilbert</hi></signed></closer>
                    </div>
                    </body></text></TEI>