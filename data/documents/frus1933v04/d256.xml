<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-05-10T23:59:59-05:00" frus:doc-dateTime-min="1933-05-10T00:00:00-05:00" n="256" subtype="historical-document" type="document" xml:id="d256">
                        <note rend="inline" type="source">724.3415/3103</note>
                        <head><hi rend="italic">The Paraguayan Minister</hi> (<persName type="from"><hi rend="italic">Bordenave</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi><note n="96" xml:id="d256fn96">Acknowledged May 12.</note></head>
                        <opener>
                            <seg rendition="#center">[Translation]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1933-05-10">May 10, 1933</date>.</dateline>
                        </opener>
                        <p><hi rend="smallcaps">Mr. Secretary</hi>: I have the honor to address
                            myself to Your Excellency, for the purpose of advising you that, by a
                            Decree signed today, my Government declared the state of war with the
                            Republic of Bolivia.</p>
                        <p>I renew [etc.]</p>
                        <closer><signed><hi rend="smallcaps">Enrique
                            Bordenave</hi></signed></closer>
                    </div>
                    </body></text></TEI>