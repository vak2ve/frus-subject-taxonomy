    <text>
        <body>
            <div frus:doc-dateTime-max="1933-05-12T11:31:00-05:00"
                frus:doc-dateTime-min="1933-05-11T16:00:00-05:00" n="567"
                subtype="historical-document" type="document" xml:id="d567">
                <note rend="inline" type="source">721.23/1711: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Colombia</hi> (<persName type="from">
                        <hi rend="italic">Caffery</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bogotá</hi>
                        </placeName>, <date ana="#date_undated-inferred-from-document-content"
                            calendar="gregorian" notAfter="1933-05-12T12:31:00-04:00"
                            notBefore="1933-05-11T17:00:00-04:00">undated</date>.<lb/>[Received May
                        12, 1933—12:31 p.m.]</dateline>
                </opener>
                <p>49. Department’s 45, May 11, 5 p.m.<note n="78" xml:id="d567fn78">See footnote
                        74, <ref target="#pg_527">p. 527</ref>.</note> Note being delivered today.
                    Santos has been instructed to accept formula on behalf of the Colombian
                    Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caffery</hi>
                    </signed>
                </closer>
            </div>
        </body>
