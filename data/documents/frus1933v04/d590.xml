<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-06-27T11:00:00-05:00" frus:doc-dateTime-min="1933-06-27T11:00:00-05:00" n="590" subtype="historical-document" type="document" xml:id="d590">
                        <note rend="inline" type="source">721.23/1874: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Peru</hi> (<persName type="from"><hi rend="italic">Dearing</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Lima</hi></placeName>, <date calendar="gregorian" when="1933-06-27T11:00:00-05:00">June 27, 1933—11
                                a.m.</date><lb/>[Received 1:10 p.m.]</dateline>
                        </opener>
                        <p>168. President yesterday informed me Leticia delivered to League
                            commissioners without adverse incident and that situation
                                satisfactory.<note n="91" xml:id="d590fn91">See League of Nations,
                                    <hi rend="italic">Official Journal</hi>, July 1933, pp.
                                977–979.</note></p>
                        <closer><signed><hi rend="smallcaps">Dearing</hi></signed></closer>
                    </div>
                    </body></text></TEI>