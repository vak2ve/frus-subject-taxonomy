                subtype="historical-document" type="document" xml:id="d274">
                <note rend="inline" type="source">724.3415/3132: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Bolivia</hi> (<persName type="from">
                        <hi rend="italic">Feely</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">La Paz</hi>
                        </placeName>, <date calendar="gregorian" when="1933-05-21T18:00:00-04:00"
                            >May 21, 1933—6 p.m.</date>
                        <lb/>[Received May 22—9:25 a.m.]</dateline>
                </opener>
                <p>49. Department’s telegram 15, May 20, 3 p.m. The same reply was sent to Chile but
                    instead of being handed to the Chilean Minister here it was delivered to the
                    Chilean Foreign Office by the Bolivian Minister at Santiago.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Feely</hi>
                    </signed>
                </closer>
            </div>
        </body>
