                subtype="historical-document" type="document" xml:id="d757">
                <note rend="inline" type="source">102.81 Buenos Aires/5: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Buenos Aires</hi> (<persName type="from">
                        <hi rend="italic">Bailey</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1933-10-25T17:00:00-04:00"
                            >October 25, 1933—5 p.m.</date>
                        <lb/>[Received 5:07 p.m.]</dateline>
                </opener>
                <p>13. From Commercial Attaché for Commerce. My 12.<note n="29" xml:id="d757fn29"
                        >Telegram No. 12, October 18, 1 p.m., <ref target="#pg_751">p.
                        751</ref>.</note> Exchange Control Commission rules that prohibition against
                    granting permits applies to all funds destined to pay for merchandise imported
                    prior to February 1st, 1933, even if funds deposited in banks to meet
                    documentary drafts. For all other funds prohibition applies as of May 1st.
                    Dye.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bailey</hi>
                    </signed>
                </closer>
            </div>
        </body>
