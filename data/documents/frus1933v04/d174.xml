<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-01-20T13:00:00-05:00" frus:doc-dateTime-min="1933-01-20T13:00:00-05:00" n="174" subtype="historical-document" type="document" xml:id="d174">
                        <note rend="inline" type="source">724.3415/2802: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Uruguay</hi> (<persName type="to"><hi rend="italic">Wright</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1933-01-20T13:00:00-05:00">January 20, 1933—1
                                p.m.</date></dateline>
                        </opener>
                        <p>2. Your 4, January 18, 6 p.m. Please express to Minister of Foreign
                            Affairs the hearty appreciation of this Government for his helpful and
                            cooperative attitude in the matter.</p>
                        <closer><signed><hi rend="smallcaps">Stimson</hi></signed></closer>
                    </div>
                    </body></text></TEI>