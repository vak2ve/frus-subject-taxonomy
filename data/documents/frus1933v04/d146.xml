    <text>
        <body>
            <div frus:doc-dateTime-max="1933-01-06T09:00:00-05:00"
                frus:doc-dateTime-min="1933-01-06T09:00:00-05:00" n="146"
                subtype="historical-document" type="document" xml:id="d146">
                <note rend="inline" type="source">724.3415/2745: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from">
                        <hi rend="italic">Morgan</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1933-01-06T12:00:00-02:00"
                            >January 6, 1933—noon</date>.<lb/>[Received January 6—10:15
                        a.m.]</dateline>
                </opener>
                <p>2. Department’s telegram No. 1, January 4, 11 a.m. Brazilian Minister for Foreign
                        Affairs<note n="7" xml:id="d146fn7">Afranio de Mello Franco.</note> will
                    reply today to Neutral Commission’s inquiry.<note n="8" xml:id="d146fn8">See
                        telegram of January 11 from the Brazilian Minister for Foreign Affairs to
                        the Chairman of the Commission of Neutrals, <ref target="#pg_251">p.
                            251</ref>.</note> Answer has been delayed at the request Bolivian
                    Minister at Rio de Janeiro.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Morgan</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
