                subtype="historical-document" type="document" xml:id="d199">
                <note rend="inline" type="source">724.3415/2907: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Paraguay</hi> (<persName type="from">
                        <hi rend="italic">Wheeler</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Asunción</hi>
                        </placeName>, <date calendar="gregorian" when="1933-02-28T13:00:00-04:00"
                            >February 28, 1933—1 p.m.</date>
                        <lb/>[Received 1:05 p.m.]</dateline>
                </opener>
                <p>28. My telegram 27, February 25, 6 p.m. This Government handed its reply to the
                    ABCP representatives last night. It accepts the proposal <pb facs="0363" n="275"
                        xml:id="pg_275"/> on principle with reservations which Ayala considers minor
                    ones.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wheeler</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
