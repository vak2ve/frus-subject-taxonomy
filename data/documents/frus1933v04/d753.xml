<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-08-01T15:00:00-05:00" frus:doc-dateTime-min="1933-08-01T15:00:00-05:00" n="753" subtype="historical-document" type="document" xml:id="d753">
                        <note rend="inline" type="source">635.4131/124: Telegram</note>
                        <head><hi rend="italic">The Chargé in Argentina</hi> (<persName type="from"><hi rend="italic">White</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Acting Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Buenos
                                        Aires</hi></placeName>, <date calendar="gregorian" when="1933-08-01T16:00:00-04:00">August 1, 1933—4
                                p.m.</date><lb/>[Received 5 p.m.]</dateline>
                        </opener>
                        <p>71. My despatch No. 2052 of May 4.<note n="24" xml:id="d753fn24">Not
                                printed.</note> Principal Anglo-Argentine Commercial Convention
                            approved by both Houses Congress, time limit for supplementary agreement
                            (see clause 2, article 3) extended to September 1st.</p>
                        <closer><signed><hi rend="smallcaps">White</hi></signed></closer>
                    </div>
                    </body></text></TEI>