                subtype="historical-document" type="document" xml:id="d635">
                <note rend="inline" type="source">722.2315/749: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Peru</hi> (<persName type="from">
                        <hi rend="italic">Dearing</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1933-08-24T11:00:00-05:00"
                            >August 24, 1933—11 a.m.</date>
                        <lb/>[Received 8:32 p.m.]</dateline>
                </opener>
                <p>183. Foreign Minister informs me it has been agreed he shall endeavor to
                    negotiate boundary settlement with Ecuador with Ecuadorian Minister here
                    simultaneously with Leticia negotiations at Rio de Janeiro.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dearing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
