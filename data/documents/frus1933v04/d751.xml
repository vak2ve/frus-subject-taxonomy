                subtype="historical-document" type="document" xml:id="d751">
                <note rend="inline" type="source">835.007658a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Argentina</hi> (<persName type="to">
                        <hi rend="italic">White</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1933-07-20T13:00:00-04:00"
                            >July 20, 1933—1 p.m.</date>
                    </dateline>
                </opener>
                <p>55. Press reports announce resignation of Finance Minister Hueyo and state that
                    important changes may occur in Argentina’s financial policy. Please telegraph
                    your comment on foregoing.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
