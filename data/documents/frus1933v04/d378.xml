<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1933-01-07T17:00:00-05:00" frus:doc-dateTime-min="1933-01-07T17:00:00-05:00" n="378" subtype="historical-document" type="document" xml:id="d378">
                        <note rend="inline" type="source">721.23/669: Telegram</note>
                        <head><hi rend="italic">The Minister in Colombia</hi> (<persName type="from"><hi rend="italic">Caffery</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1933-01-07T17:00:00-05:00">January 7, 1933—5
                                p.m.</date><lb/>[Received 6:07 p.m.]</dateline>
                        </opener>
                        <p>7. For White. Olaya says he has not agreed to formula reported by Morgan.
                            Details follow.</p>
                        <closer><signed><hi rend="smallcaps">Caffery</hi></signed></closer>
                    </div>
                    </body></text></TEI>