                subtype="historical-document" type="document" xml:id="d597">
                <note rend="inline" type="source">721.23/1915: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Peru</hi> (<persName type="to">
                        <hi rend="italic">Dearing</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1933-07-26T13:00:00-04:00"
                            >July 26, 1933—1 p.m.</date>
                    </dateline>
                </opener>
                <p>75. Your 176, July 25, 11 a.m. You may transmit message. Make it clear that
                    Colombian suggestion of Washington as possible site for negotiations does not
                    emanate from this Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
