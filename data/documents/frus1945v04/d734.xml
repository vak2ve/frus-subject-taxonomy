    <teiHeader><fileDesc><titleStmt><title>The Secretary of State to the
                        French Chargé (
                        Lacoste
                    )Copy transmitted to Paris as enclosure
                        to instruction 1658, December 6, 1945 (not printed).</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945v04</bibl><bibl type="frus-document-id">d734</bibl><bibl type="frus-document-number">734</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-11-08T00:00:00-05:00" notAfter="1945-11-08T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-11-08T23:59:59-05:00" frus:doc-dateTime-min="1945-11-08T00:00:00-05:00" n="734" subtype="historical-document" type="document" xml:id="d734">
                <note rend="inline" type="source">Paris Embassy Files: Lot 55F–139 Box 2, File
                    631</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        French Chargé</hi> (<persName type="to">
                        <hi rend="italic">Lacoste</hi>
                    </persName>)<note n="91" xml:id="d734fn1">Copy transmitted to Paris as enclosure
                        to instruction 1658, December 6, 1945 (not printed).</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1945-11-08">November 8,
                            1945</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I acknowledge the receipt of your note of today’s
                    date concerning the understanding reached during our recent discussions pursuant
                    to Article VII of the Master Lend-Lease Agreement between the United States of
                    America and the Provisional Government of France dated February 28, 1945, and I
                    hereby confirm your statement of the understanding reached as therein set
                    out.</p>
                <p>Accept [etc.]</p>
                <closer>[File copy not signed]</closer>
            </div>
        </body>
    </text>
