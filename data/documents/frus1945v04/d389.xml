<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-11-15T19:00:00-05:00" frus:doc-dateTime-min="1945-11-15T19:00:00-05:00" n="389" subtype="historical-document" type="document" xml:id="d389">
                        <note rend="inline" type="source">874.00/11–1645: Telegram</note>
                        <head>
                            <hi rend="italic">The United States Representative in Bulgaria</hi>
                                (<persName type="from"><hi rend="italic">Barnes</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Sofia</hi></placeName>, <date calendar="gregorian" when="1945-11-16T02:00:00+02:00">November
                                    16, 1945—2 a.m.</date>
                                <lb/> [Received November 18—11:05 p.m.]</dateline>
                        </opener>
                        <p>694. Remytel 693, November 16, 1 a.m. Both Prime Minister and Minister of
                            Foreign Affairs promise to be in Sofia and to receive personally from me
                            contents of Department’s 373 by 1 p.m., Sofia time <pb facs="0396" n="384" xml:id="pg_384"/> November 16. Request Department release
                            communication at 12 noon Washington time November 16.<note n="11" xml:id="d389fn1">For text of Department’s press release, see
                                Department of State <hi rend="italic">Bulletin</hi>, November 18,
                                1945, p. 791.</note>
                        </p>
                        <closer>[<signed>
                                <hi rend="smallcaps">Barnes</hi>
                            </signed>]</closer>
                    </div>
                    </body></text></TEI>