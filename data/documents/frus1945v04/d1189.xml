<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-04-20T18:00:00-05:00" frus:doc-dateTime-min="1945-04-20T18:00:00-05:00" n="1189" subtype="historical-document" type="document" xml:id="d1189">
                        <note rend="inline" type="source">865.6363/4–2045: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Italy</hi> (<persName type="to"><hi rend="italic">Kirk</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1945-04-20T19:00:00-04:00">April 20,
                                    1945—7 p.m.</date>
                            </dateline>
                        </opener>
                        <p>675. The procedures recommended in your 929, April 11, 10 a.m. are
                            approved.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Stettinius</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>