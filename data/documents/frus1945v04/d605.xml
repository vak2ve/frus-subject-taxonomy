                subtype="historical-document" type="document" xml:id="d605">
                <note rend="inline" type="source">760D.6115/10–2745: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Finland</hi> (<persName type="from">
                        <hi rend="italic">Hulley</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Helsinki</hi>
                        </placeName>, <date calendar="gregorian" when="1945-10-27">October 27,
                            1945</date>.<lb/>[Received October 28—3:50 a.m.]</dateline>
                </opener>
                <p>641. Press 27th. New Petsamo border which exactly same as between Russian Empire
                    and Grand Duchy of Finland has been delineated and documents reestablishing it
                    signed Helsinki 26th.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hulley</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
