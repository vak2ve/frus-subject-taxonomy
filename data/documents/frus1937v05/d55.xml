                subtype="historical-document" type="document" xml:id="d55">
                <note rend="inline" type="source">715.1715/548: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Honduras</hi> (<persName type="from">
                        <hi rend="italic">Cramp</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1937-09-06">September 6,
                            1937</date>.<lb/>[Received 9:40 a.m.]</dateline>
                </opener>
                <p>47. The following telegram has been sent to Managua September 5, 10 a.m. Blue
                    seal showing Honduran map being placed on Foreign Office notes and all official
                    correspondence as well on all mail. Furthermore blue lapel buttons showing the
                    same map being worn.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cramp</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
