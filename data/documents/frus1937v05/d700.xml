                subtype="historical-document" type="document" xml:id="d700">
                <note rend="inline" type="source">834.00 Revolutions/25: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Paraguay</hi> (<persName type="from">
                        <hi rend="italic">Howard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Asunción</hi>
                        </placeName>, <date calendar="gregorian" when="1937-08-16T09:00:00-04:00"
                            >August 16, 1937—9 a.m.</date>
                        <lb/>[Received 10:50 a.m.]</dateline>
                </opener>
                <p>21. Felix Paivac [<hi rend="italic">Paiva</hi>], former Vice President and
                    recently professor of law, being sworn in as President 10 o’clock this morning.
                    Cabinet announcements expected shortly afterwards.</p>
                <p>Repeated to Buenos Aires.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Howard</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
