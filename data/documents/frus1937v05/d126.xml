<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1937-12-06T14:00:00-05:00" frus:doc-dateTime-min="1937-12-06T14:00:00-05:00" n="126" subtype="historical-document" type="document" xml:id="d126">
                            <note rend="inline" type="source">715.1715/1011: Telegram</note>
                            <head><hi rend="italic">The Special Representative of the President</hi>
                                    (<persName type="from"><hi rend="italic">Corrigan</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">San
                                            José</hi></placeName>, <date calendar="gregorian" when="1937-12-06T13:00:00-06:00">December 6, 1937—1
                                        p.m.</date><lb/>[Received 3:20 p.m.]</dateline>
                            </opener>
                            <p>32. The Commission is considering eliminating point number 6 (stamps)
                                on the insistence of Honduras. I have not yet agreed to this and
                                would appreciate the Department’s telegraphic instructions.</p>
                            <closer><signed><hi rend="smallcaps">Corrigan</hi></signed></closer>
                        </div>
                        </body></text></TEI>