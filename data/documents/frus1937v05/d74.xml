                subtype="historical-document" type="document" xml:id="d74">
                <note rend="inline" type="source">715.1715/623: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Honduras</hi> (<persName type="from">
                        <hi rend="italic">Erwin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1937-09-19T20:00:00-06:00"
                            >September 19, 1937—8 p.m.</date>
                        <lb/>[Received September 20—11:45 a.m.]</dateline>
                </opener>
                <p>67. The Legation has learned that the President has suggested to Colonel Brooks
                    that American “fighting pilots” be immediately employed. So far as is known no
                    action taken yet in the matter.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Erwin</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
