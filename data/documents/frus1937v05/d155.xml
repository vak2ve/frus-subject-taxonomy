<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1937-11-17T12:00:00-05:00" frus:doc-dateTime-min="1937-11-17T12:00:00-05:00" n="155" subtype="historical-document" type="document" xml:id="d155">
                        <note rend="inline" type="source">738.39/110: Telegram</note>
                        <head><hi rend="italic">The Minister in the Dominican Republic</hi>
                                (<persName type="from"><hi rend="italic">Norweb</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Ciudad
                                        Trujillo</hi></placeName>, <date calendar="gregorian" when="1937-11-17T12:00:00-05:00">November 17,
                                1937—noon</date>.<lb/>[Received 1:30 p.m.]</dateline>
                        </opener>
                        <p>46. The message from the President of Mexico was received this morning
                            and replied to in identic terms with the answer sent President
                            Roosevelt.</p>
                        <closer><signed><hi rend="smallcaps">Norweb</hi></signed></closer>
                    </div>
                    </body></text></TEI>