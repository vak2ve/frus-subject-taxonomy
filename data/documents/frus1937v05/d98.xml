                subtype="historical-document" type="document" xml:id="d98">
                <note rend="inline" type="source">715.1715/744: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Venezuela</hi> (<persName type="from">
                        <hi rend="italic">Nicholson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Caracas</hi>
                        </placeName>, <date calendar="gregorian" when="1937-10-20T16:00:00-04:30"
                            >October 20, 1937—4 p.m.</date>
                        <lb/>[Received 8:56 p.m.]</dateline>
                </opener>
                <p>100. Department’s telegram No. 57, October 19, 8 p.m.<note n="45"
                        xml:id="d98fn45">See footnote 43, <ref target="#pg_90">p. 90</ref>.</note>
                    The Minister for Foreign Affairs after consultation with the President stated
                    that the Venezuelan Government would be glad to tender its good offices as
                    suggested and expressed his cordial appreciation for this opportunity to
                    cooperate.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Nicholson</hi>
                    </signed>
                </closer>
            </div>
        </body>
