<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1937-12-11T19:00:00-05:00" frus:doc-dateTime-min="1937-12-11T19:00:00-05:00" n="131" subtype="historical-document" type="document" xml:id="d131">
                            <note rend="inline" type="source">715.1715/1024: Telegram</note>
                            <head><hi rend="italic">The Special Representative of the President</hi>
                                    (<persName type="from"><hi rend="italic">Corrigan</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">San
                                            José</hi></placeName>, <date calendar="gregorian" when="1937-12-11T18:00:00-06:00">December 11, 1937—6
                                        p.m.</date><lb/>[Received 7:50 p.m.]</dateline>
                            </opener>
                            <p>38. Referring to my telegram No. 37, December 10, 1 p.m.,<note n="62" xml:id="d131fn62">Not printed.</note> the Pact of Mutual
                                Agreements for Preservation of Peace between Honduras and Nicaragua
                                was signed today at 5:30 p.m.</p>
                            <closer><signed><hi rend="smallcaps">Corrigan</hi></signed></closer>
                        </div>
                        </body></text></TEI>