                subtype="historical-document" type="document" xml:id="d321">
                <note rend="inline" type="source">824.6363 ST 2/198: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Bolivia</hi> (<persName type="from">
                        <hi rend="italic">Caldwell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">La Paz</hi>
                        </placeName>, <date calendar="gregorian" when="1937-11-27T17:00:00-04:00"
                            >November 27, 1937—5 p.m.</date>
                        <lb/>[Received November 27—3:40 p.m.]</dateline>
                </opener>
                <p>68. Captain Calvo, Chief Counsel of Standard Oil Company, deported to the
                    Argentine Republic today. Metzger requests that New York be notified.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caldwell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
