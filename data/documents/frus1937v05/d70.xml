                <note rend="inline" type="source">715.1715/576: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Honduras</hi> (<persName type="to">
                        <hi rend="italic">Erwin</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1937-09-09T11:00:00-04:00"
                            >September 9, 1937—11 a.m.</date>
                    </dateline>
                </opener>
                <p>27. Your no. 60, September 8, 5 p.m. Department leaves to your discretion
                    procedure to be followed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
