    <text>
        <body>
            <div frus:doc-dateTime-max="1939-09-25T13:00:00-05:00"
                frus:doc-dateTime-min="1939-09-25T13:00:00-05:00" n="634"
                subtype="historical-document" type="document" xml:id="d634">
                <note rend="inline" type="source">125.981/67: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Germany</hi> (<persName type="from">
                        <hi rend="italic">Kirk</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1939-09-25T19:00:00+01:00"
                            >September 25, 1939—7 p.m.</date>
                        <lb/>[Received September 25—4:42 p.m.]</dateline>
                </opener>
                <p>1425. My 1414, September 15 [<hi rend="italic">25</hi>], 10 a.m.<note n="24"
                        xml:id="d634fn24">Not printed.</note> Consul General Davis and staff arrived
                    in Berlin this afternoon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">kirk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
