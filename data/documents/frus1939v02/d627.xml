    <text>
        <body>
            <div frus:doc-dateTime-max="1939-09-17T14:00:00-05:00"
                frus:doc-dateTime-min="1939-09-17T14:00:00-05:00" n="627"
                subtype="historical-document" type="document" xml:id="d627">
                <note rend="inline" type="source">125.981/59: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Germany</hi> (<persName type="from">
                        <hi rend="italic">Kirk</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1939-09-17T20:00:00+01:00"
                            >September 17, 1939—8 p.m.</date>
                        <lb/>[Received September 17—6 p.m.]</dateline>
                </opener>
                <p>1290. My 1281, September 17, 11 a.m. Foreign Office officials state that they
                    have no information out of Warsaw but that the German military authorities had
                    stated that they were prepared to accord <pb facs="0685" n="677" xml:id="pg_677"
                    /> protection to foreign diplomatic and consular personnel entering German
                    lines.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kirk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
