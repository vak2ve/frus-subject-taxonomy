                                        <row>
                                            <cell/>
                                            <cell role="num"><hi rend="italic">Principal</hi></cell>
                                            <cell role="num"><hi rend="italic">Interest</hi></cell>
                                            <cell role="num"><hi rend="italic">Annuity under
                                                  Moratorium Agreement</hi></cell>
                                        </row>
                                        <row>
                                            <cell rendition="#nowrap">Amount due January 1,
                                                1936</cell>
                                            <cell role="num">460,093.00</cell>
                                            <cell role="num">—</cell>
                                            <cell role="num">$34,767.23</cell>
                                        </row>
                                        <row>
                                            <cell rendition="#nowrap">Amount due January 1,
                                                1937</cell>
                                            <cell role="num">$460,093.00</cell>
                                            <cell role="num">—</cell>
                                            <cell role="num">34,767.23</cell>
                                        </row>
                                        <row>
                                            <cell rendition="#nowrap">Amount due January 1,
                                                1938</cell>
                                            <cell role="num">$460,093.00</cell>
                                            <cell role="num">—</cell>
                                            <cell role="num">34,767.23</cell>
                                        </row>
                                        <row>
                                            <cell rendition="#nowrap">Amount due January 1,
                                                1939</cell>
                                            <cell rendition="#border-bottom" role="num">$460,093.00</cell>
                                            <cell rendition="#border-bottom" role="num">—</cell>
                                            <cell rendition="#border-bottom" role="num">34,767.23</cell>
                                        </row>
                                        <row>
                                            <cell rend="padding-left: 3em">Total</cell>
                                            <cell role="num">1,840,372.00</cell>
                                            <cell role="num">—</cell>
                                            <cell role="num">139,068.92</cell>
                                        </row>
                                    </table>
                                    <table cols="2" rend="width: 99%" rows="4">
                                        <row>
                                            <cell rendition="#nowrap">Amount due January 1,
                                                1940:</cell>
                                            <cell/>
                                        </row>
                                        <row>
                                            <cell rendition="#hanging">Principal of bond No. 12,
                                                dated January 1, 1928, due January 1, 1940, under
                                                agreement of May 8, 1930, between the United States
                                                and Austria</cell>
                                            <cell role="num">$460,093.00</cell>
                                        </row>
                                        <row>
                                            <cell rendition="#hanging">Seventh annual annuity due
                                                January 1, 1940, under moratorium agreement of
                                                September 14, 1932, between the United States and
                                                Austria</cell>
                                            <cell rendition="#border-bottom" role="num">34,767.23</cell>
                                        </row>
                                        <row>
