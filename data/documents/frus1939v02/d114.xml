                subtype="historical-document" type="document" xml:id="d114">
                <note rend="inline" type="source">840.43 Refugees/1766: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName type="to">
                        <hi rend="italic">Bullitt</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1939-07-27T19:00:00-04:00"
                            >July 27, 1939—7 p.m.</date>
                    </dateline>
                </opener>
                <p>571. For Myron Taylor. Your 1385, July 27, noon.<note n="70" xml:id="d114fn70"
                        >Not printed.</note> The President authorizes me to let you know that Monday
                    and Tuesday, October 16 and 17, may be confirmed as the days upon which he will
                    hold the suggested meeting in Washington.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
