                subtype="historical-document" type="document" xml:id="d29">
                <note rend="inline" type="source">579.6AE1/40: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in the United Kingdom</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1939-02-01T17:00:00+00:00"
                            >February 1, 1939—5 p.m.</date>
                        <lb/>[Received February 1—1:11 p.m.]</dateline>
                </opener>
                <p>137. Department’s 78, January 30, 6 p.m. Foreign Office advises orally that it
                    will notify interested governments at once of the additional items which the
                    United States wishes to add to the agenda.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
