                subtype="historical-document" type="document" xml:id="d760">
                <note rend="inline" type="source">852.48/363a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName type="to">
                        <hi rend="italic">Bullitt</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1939-02-01T19:00:00-05:00"
                            >February 1, 1939—7 p.m.</date>
                    </dateline>
                </opener>
                <p>63. Please telegraph what arrangements the French Government has made with regard
                    to the entrance into France of Spanish refugees, the approximate number already
                    permitted to enter, and the estimate of the further number which will be
                    permitted entry.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
