                <note rend="inline" type="source">841.711/2868a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in the United Kingdom</hi> (<persName type="to">
                        <hi rend="italic">Johnson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-01-02T19:00:00-05:00"
                            >January 2, 1940—7 p.m.</date>
                    </dateline>
                </opener>
                <p>2. Please send Legation The Hague by mail a copy of Department’s 1664, December
                    22, 9 p.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
