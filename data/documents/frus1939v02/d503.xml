<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-10-16T06:00:00-05:00" frus:doc-dateTime-min="1939-10-16T06:00:00-05:00" n="503" subtype="historical-document" type="document" xml:id="d503">
                            <note rend="inline" type="source">851.731/143: Telegram</note>
                            <head><hi rend="italic">The Ambassador in France</hi> (<persName type="from"><hi rend="italic">Bullitt</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1939-10-16T12:00:00+01:00">October 16,
                                        1939—noon</date>.<lb/>[Received October 16—10:25
                                    a.m.]</dateline>
                            </opener>
                            <p>2481. Your 1210, October 10, 7 p.m., and my 2415, October 11, 11 a.m.
                                Bern authorities have approved the six codes mentioned in my 2203
                                and communication companies have been so informed effective
                                today.</p>
                            <closer><signed><hi rend="smallcaps">Bullitt</hi></signed></closer>
                        </div>
                    </body></text></TEI>