    <text>
        <body>
            <div frus:doc-dateTime-max="1939-09-17T05:00:00-05:00"
                frus:doc-dateTime-min="1939-09-17T05:00:00-05:00" n="626"
                subtype="historical-document" type="document" xml:id="d626">
                <note rend="inline" type="source">125.981/58: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Germany</hi> (<persName type="from">
                        <hi rend="italic">Kirk</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1939-09-17T11:00:00+01:00"
                            >September 17, 1939—11 a.m.</date>
                        <lb/>[Received September 17—10:06 a.m.]</dateline>
                </opener>
                <p>1281. Department’s 522, 16th.<note n="17" xml:id="d626fn17">See footnote 10, <ref
                            target="#pg_674">p. 674</ref>.</note> I am asking Foreign Office and War
                    Office if any information is available as to welfare and present whereabouts of
                    Davis and staff.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kirk</hi>
                    </signed>
                </closer>
            </div>
        </body>
