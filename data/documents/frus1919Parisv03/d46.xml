                        <note rend="inline" type="source">Paris Peace Conf. 180.03101/16</note>
                        <note rend="inline" type="source">BC–9</note>
                        <head>Secretary’s Notes of a Conversation Held in M. Pichon’s Room at the
                            Quai d’Orsay on Friday, January 24, 1919, at 12:15 O’clock p.m.</head>
                        <dateline>
                            <date ana="#date_undated-inferred-from-document-head" calendar="gregorian" type="conversation-or-meeting-date" when="1919-01-24T12:15:00+00:00">January 24, 1919, 12:15 p.m.</date>
                        </dateline>
                        <list type="participants">
                            <item><hi rend="smallcaps">Present</hi>
                                <list>
                                    <item><hi rend="smallcaps">America, United States of</hi>
                                        <list>
                                            <item>President Wilson</item>
                                            <item>Mr. It. Lansing</item>
                                            <item>Mr. A. H. Frazier</item>
                                            <item>Mr. L. Harrison</item>
                                            <item>Col. U. S. Grant</item>
                                        </list></item>
