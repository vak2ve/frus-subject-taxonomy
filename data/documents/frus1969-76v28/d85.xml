    <text>
        <body>
            <div frus:doc-dateTime-max="1976-05-06T23:59:59-05:00"
                frus:doc-dateTime-min="1976-05-06T00:00:00-05:00" n="85"
                subtype="historical-document" type="document" xml:id="d85">
                <head>85. National Security Decision Memorandum 330<note n="1" type="source"
                        xml:id="d85fn1">Source: <persName corresp="#p_FGR_1">Ford</persName>
                        Library, National Security Council, Institutional Files, Box 65, <gloss
                            target="#t_NSDM_1">NSDM</gloss> 330. Secret. A copy was sent to the
                        Chairman of the Export-Import Bank.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1976-05-06">May 6, 1976</date>.</dateline>
                </opener>
                <list type="to">
                    <head>TO</head>
                    <item>The Secretary of State</item>
                    <item>The Secretary of Treasury</item>
                    <item>The Secretary of Defense</item>
                    <item>The Secretary of Commerce</item>
                    <item>The Director of Central Intelligence</item>
                    <item>The Acting Executive Director, Council on International Economic
                        Policy</item>
                </list>
                <list type="subject">
                    <head>SUBJECT</head>
                    <item>United States Policy on Export-Import Bank Loans for South Africa</item>
                </list>
                <p>The President has reviewed the response to <gloss target="#t_NSSM_1">NSSM</gloss>
                        236,<note n="2" xml:id="d85fn2">See <ref target="#d83fn3">footnote 3,
                            Document 83</ref>.</note> and has approved the recommendation that there
                    be no change in Export-Import Bank policy on loans to South Africa.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SBC_1">
                            <hi rend="strong">Brent Scowcroft</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
