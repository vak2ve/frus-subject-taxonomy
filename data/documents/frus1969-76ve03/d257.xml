                subtype="historical-document" type="document" xml:id="d257">
                <head>257. Telegram 45319 From the Department of State to All Posts<note n="1"
                        type="source" xml:id="d257fn1">Source: National Archives, RG 59, Central
                        Foreign Policy Files, 045319. Unclassified; Priority. Drafted by <persName
                            corresp="#p_PRD1">Palmer</persName>; cleared in <gloss
                            target="#t_AIDPPC1">AID/PPC</gloss>, <gloss target="#t_AIDGC1"
                            >AID/GC</gloss>, <gloss target="#t_SP1">S/P</gloss>, <gloss
                            target="#t_PM1">PM</gloss>, <gloss target="#t_EA1">EA</gloss>, <gloss
                            target="#t_AF1">AF</gloss>, <gloss target="#t_NEA1">NEA</gloss>, <gloss
                            target="#t_EUR1">EUR</gloss>, <gloss target="#t_ARA1">ARA</gloss>,
                            <gloss target="#t_T1">T</gloss>, <gloss target="#t_LHR1">L/HR</gloss>,
                            <gloss target="#t_DHA1">D/HA</gloss>, <gloss target="#t_H1">H</gloss>,
                            <gloss target="#t_LPM1">L/PM</gloss>, <gloss target="#t_PMSAS1"
                            >PM/SAS</gloss>, <gloss target="#t_EBIFDODF1">EB/IFD/ODF</gloss>, <gloss
                            target="#t_IOUNP1">IO/UNP</gloss>, and <gloss target="#t_L1">L</gloss>;
                        and approved by <persName corresp="#p_IRS1">Ingersoll</persName>. Repeated
                        for information to Geneva <gloss target="#t_USUN1">USUN</gloss>, <gloss
                            target="#t_SECDEF1">SECDEF</gloss>, <gloss target="#t_USCINCEUR1"
                            >USCINCEUR</gloss>, <gloss target="#t_CINCLANT1">CINCLANT</gloss>,
                            <gloss target="#t_USCINCSO1">USCINCSO</gloss>, <gloss
                            target="#t_CINCPAC1">CINCPAC</gloss>.</note>
                    <note n="2" type="summary" xml:id="d257fn2">The telegram informed posts of the
                        importance placed on country human rights reports and issued additional
                        instructions concerning submission of 1976 reports.</note>
                </head>
                <dateline>
                    <placeName>Washington</placeName>, <date calendar="gregorian"
                        when="1976-02-25T16:27:00+00:00">February 25, 1976, 1627Z</date>
                </dateline>
                <note rend="inline">[<hi rend="italic">Document not declassified in time for
                        publication</hi>]</note>
            </div>
