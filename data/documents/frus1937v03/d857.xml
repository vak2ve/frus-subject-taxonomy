<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1937-12-06T18:00:00-05:00" frus:doc-dateTime-min="1937-12-06T18:00:00-05:00" n="857" subtype="historical-document" type="document" xml:id="d857">
                            <note rend="inline" type="source">793.94/11494: Telegram</note>
                            <head><hi rend="italic">The Second Secretary of Embassy in China</hi>
                                    (<persName type="from"><hi rend="italic">Atcheson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Nanking</hi></placeName>, <date calendar="gregorian" when="1937-12-07T07:00:00+08:00">December 7, 1937—7
                                        a.m.</date><lb/>[Received December 6—11:10 p.m.]</dateline>
                            </opener>
                            <p>1004. General and Mrs. Chiang Kai Shek left at 6 this morning by
                                plane for the interior.</p>
                            <p>Sent to the Department. Repeated to Hankow, Peiping, Shanghai.</p>
                            <closer><signed><hi rend="smallcaps">Atcheson</hi></signed></closer>
                        </div>
                        </body></text></TEI>