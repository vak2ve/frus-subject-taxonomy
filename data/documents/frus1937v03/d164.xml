                subtype="historical-document" type="document" xml:id="d164">
                <note rend="inline" type="source">793.94/8770: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1937-07-15T22:00:00+09:00"
                            >July 15, 1937—10 p.m.</date>
                        <lb/>[Received July 15—10:15 a.m.]</dateline>
                </opener>
                <p>202. My 201, July 15, 9 p.m. It has just been announced that the Cabinet has
                    decided to despatch to North China reenforcements of undisclosed number of
                    troops.</p>
                <p>Repeated to Peiping.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
