    <text>
        <body>
            <div frus:doc-dateTime-max="1937-03-03T02:00:00-05:00"
                frus:doc-dateTime-min="1937-03-03T02:00:00-05:00" n="29"
                subtype="historical-document" type="document" xml:id="d29">
                <note rend="inline" type="source">893.00/14025: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1937-03-03T15:00:00+08:00"
                            >March 3, 1937—3 p.m.</date>
                        <lb/>[Received March 3—2:30 p.m.]</dateline>
                </opener>
                <p>103. My 96, February 27, 10 a.m.</p>
                <list>
                    <label>1.</label>
                    <item>The Central Political Committee this morning accepted resignation of
                        Foreign Minister Chang Chun and Minister of Communications <pb facs="0040"
                            n="33" xml:id="pg_33"/> Ku Meng Yu and made following appointments: Wang
                        Chung Hui to be Minister for Foreign Affairs; Chang Chun to be Secretary
                        General of the Central Political Committee and Chairman of the Foreign
                        Relations Committee of the Political Committee; Tsing Chung King, former
                        Vice Minister of Railways under Wang Ching Wei, to be Deputy Secretary
                        General of the Central Political Committee; Yu Fei Peng, Vice Minister of
                        Communications, to be Minister of Communications.</item>
                    <label>2.</label>
                    <item>To Department and Peiping.</item>
                </list>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
