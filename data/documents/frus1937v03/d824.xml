    <text>
        <body>
            <div frus:doc-dateTime-max="1937-12-01T23:00:00-05:00"
                frus:doc-dateTime-min="1937-12-01T23:00:00-05:00" n="824"
                subtype="historical-document" type="document" xml:id="d824">
                <note rend="inline" type="source">793.94/11409: Telegram</note>
                <head>
                    <hi rend="italic">The Second Secretary of Embassy in China</hi> (<persName
                        type="from">
                        <hi rend="italic">Atcheson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1937-12-02T12:00:00+08:00"
                            >December 2, 1937—noon</date>.<lb/>[Received December 2—7:20
                        a.m.]</dateline>
                </opener>
                <p>982. Our 978, December 1, 3 p.m.</p>
                <list>
                    <label>1.</label>
                    <item>German Ambassador arrived here on Chinese customs cruiser. We are reliably
                        informed that Chiang will inform him that China, cannot consider any peace
                        proposals which do not give recognition to her full sovereignty.</item>
                    <label>2.</label>
                    <item>Repeated to Hankow, Peiping. Peiping please repeat to Tokyo.</item>
                </list>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Atcheson</hi>
                    </signed>
                </closer>
            </div>
        </body>
