                subtype="historical-document" type="document" xml:id="d1045">
                <note rend="inline" type="source">793.94/8585: Telegram</note>
                <head>
                    <hi rend="italic">The Counselor of Embassy in China</hi> (<persName type="from">
                        <hi rend="italic">Lockhart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1937-04-19T11:00:00+08:00"
                            >April 19, 1937—11 a.m.</date>
                        <lb/>[Received April 19—12:01 a.m.]</dateline>
                </opener>
                <p>124. The following message has been received from Mukden: <quote
                        rend="blockquote">
                        <p>“April 17, 11 a.m. My despatch No. 16 [<hi rend="italic">96</hi>], March
                            19th. Information contained in second and third paragraphs is verified
                            by authoritative French military source which adds that Second and
                            Fourth Divisions are being sent from Japan to Manchuria not as
                            replacements.</p>
                        <p>Repeated to Tokyo.[”]</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lockhart</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
