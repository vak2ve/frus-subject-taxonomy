<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1937-12-03T01:00:00-05:00" frus:doc-dateTime-min="1937-12-03T01:00:00-05:00" n="1084" subtype="historical-document" type="document" xml:id="d1084">
                        <note rend="inline" type="source">852.01/309: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Japan</hi> (<persName type="from"><hi rend="italic">Grew</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Tokyo</hi></placeName>, <date calendar="gregorian" when="1937-12-03T15:00:00+09:00">December 3, 1937—3
                                p.m.</date><lb/>[Received December 3—7 a.m.]</dateline>
                        </opener>
                        <p>591. Our 583, November 30, 8 p.m.<note n="70" xml:id="d1084fn70">Not
                                printed.</note> It was officially announced yesterday that,
                            following recognition by Japan of the Franco regime, there occurred
                            yesterday at Tokyo an exchange of notes between the Manchukuo Ambassador
                            and the Franco representative mutually extending recognition.</p>
                        <closer><signed><hi rend="smallcaps">Grew</hi></signed></closer>
                    </div>
                    </body></text></TEI>