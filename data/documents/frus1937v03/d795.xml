<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1937-11-27T00:00:00-05:00" frus:doc-dateTime-min="1937-11-27T00:00:00-05:00" n="795" subtype="historical-document" type="document" xml:id="d795">
                            <note rend="inline" type="source">124.93/390: Telegram</note>
                            <head><hi rend="italic">The Ambassador in China</hi> (<persName type="from"><hi rend="italic">Johnson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Hankow</hi> (U. S. S. “<hi rend="smallcaps">Luzon</hi>”)</placeName>, <date calendar="gregorian" when="1937-11-27T13:00:00+08:00">November 27, 1937—1
                                        p.m.</date><lb/>[Received November 27—10 a.m.]</dateline>
                            </opener>
                            <p>5. My 1, November 22, 4 p.m. I arrived Hankow this morning. My
                                colleagues have also arrived. Minister for Foreign Affairs is
                                expected here tomorrow. Two Vice Ministers are already in
                                Hankow.</p>
                            <closer><signed><hi rend="smallcaps">Johnson</hi></signed></closer>
                        </div>
                        </body></text></TEI>