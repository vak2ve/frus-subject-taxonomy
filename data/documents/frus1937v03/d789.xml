                subtype="historical-document" type="document" xml:id="d789">
                <note rend="inline" type="source">793.94/11282: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Japan</hi> (<persName type="to">
                        <hi rend="italic">Grew</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1937-11-24T18:00:00-05:00"
                            >November 24, 1937—6 p.m.</date>
                    </dateline>
                </opener>
                <p>315. The Department is informed that the Standard Oil Company of New York has
                    received a telegram from its Shanghai representative stating that its Shanghai
                    representative has learned that Japan will declare war on China on December
                    1.</p>
                <p>The Department would welcome your comments.<note n="52" xml:id="d789fn52">A
                        similar telegram, No. 576, November 24, 6 p.m., was sent to the Consul
                        General at Shanghai.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
