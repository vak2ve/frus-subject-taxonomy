                subtype="historical-document" type="document" xml:id="d871">
                <note rend="inline" type="source">124.93/403a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Second Secretary of Embassy in China</hi> (<persName type="to">
                        <hi rend="italic">Atcheson</hi>
                    </persName>), <hi rend="italic">at Nanking</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1937-12-09T17:00:00-05:00"
                            >December 9, 1937—5 p.m.</date>
                    </dateline>
                </opener>
                <p>372. Your 1021, December 9, 10 a.m<note n="93" xml:id="d871fn93">
                        <ref target="frus1937v04#pg_392">Vol. <hi rend="smallcaps">iv</hi>, p.
                            392</ref>.</note> You will of course keep in mind and be guided by the
                    statement made in the Department’s 368, November 30, 2 p.m., to the effect that
                    you and staff should not expose yourselves to imminent and serious danger.<note
                        n="94" xml:id="d871fn94">For correspondence concerning the Japanese attack
                        on the U. S. S. <hi rend="italic">Panay</hi>, December 12, see <ref
                            target="frus1937v04#pg_485">
                            <hi rend="italic">ibid</hi>., pp. 485</ref> ff.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
