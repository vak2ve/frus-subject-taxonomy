<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1937-07-11T09:00:00-05:00" frus:doc-dateTime-min="1937-07-11T09:00:00-05:00" n="114" subtype="historical-document" type="document" xml:id="d114">
                            <note rend="inline" type="source">793.94/8698: Telegram</note>
                            <head><hi rend="italic">The Ambassador in China</hi> (<persName type="from"><hi rend="italic">Johnson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Peiping</hi></placeName>, <date calendar="gregorian" when="1937-07-11T22:00:00+08:00">July 11, 1937—10
                                        p.m.</date><lb/>[Received July 11—11:20 a.m.]</dateline>
                            </opener>
                            <p>218. Following from Mukden: <quote rend="blockquote">
                                    <p>“July 11, 4 p.m. I have just learned from Japanese military
                                        here that traffic between Mukden-Tientsin has been
                                        suspended, I assume in order to clear line for military
                                        use.</p>
                                    <p>Repeated to Tokyo.”</p>
                                </quote></p>
                            <closer><signed><hi rend="smallcaps">Johnson</hi></signed></closer>
                        </div>
                        </body></text></TEI>