                subtype="historical-document" type="document" xml:id="d444">
                <note rend="inline" type="source">893.00/10–1446: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Caffery</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1946-10-14T00:00:00+01:00"
                            >October 14, 1946—midnight</date>.<lb/>[Received October 14—10:05
                        p.m.]</dateline>
                </opener>
                <p>5169. For Acheson and Vincent from the Secretary.<note n="71" xml:id="d444fn71"
                        >Secretary of State Byrnes was attending Meeting of Foreign Ministers in
                        Paris.</note> Bevin<note n="72" xml:id="d444fn72">Ernest Bevin, British
                        Secretary of State for Foreign Affairs.</note> has told me that British have
                    received request from Chinese for purchase of arms. Bevin has issued
                    instructions that sales are not to be made. [Byrnes.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caffery</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
