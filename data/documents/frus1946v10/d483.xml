    <text>
        <body>
            <div frus:doc-dateTime-max="1946-02-03T21:00:00-05:00"
                frus:doc-dateTime-min="1946-02-03T21:00:00-05:00" n="483"
                subtype="historical-document" type="document" xml:id="d483">
                <note rend="inline" type="source">893.85/2–446: Telegram</note>
                <head>
                    <hi rend="italic">The Counselor of Embassy in China</hi> (<persName type="from">
                        <hi rend="italic">Smyth</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chungking</hi>
                        </placeName>, <date calendar="gregorian" when="1946-02-04T09:00:00+07:00"
                            >February 4, 1946—9 a.m.</date>
                        <lb/> [Received 2:46 p.m.]</dateline>
                </opener>
                <p>211. From General Marshall for Colonel Davis. [Apparent omission] two additional
                    Liberties approved if WSA representative Shanghai (reference your telegram 185,
                    January 30) concurs in essentiality Chinese need. [Marshall.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Smyth</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
