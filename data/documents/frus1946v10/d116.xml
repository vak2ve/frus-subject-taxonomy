<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>President Truman to General
                            Marshall</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1946v10</bibl><bibl type="frus-document-id">d116</bibl><bibl type="frus-document-number">116</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1946-09-26T00:00:00-05:00" notAfter="1946-09-26T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1946-09-26T23:59:59-05:00" frus:doc-dateTime-min="1946-09-26T00:00:00-05:00" n="116" subtype="historical-document" type="document" xml:id="d116">
                <note rend="inline" type="source">Marshall Mission Files, Lot 54–D270:
                    Telegram</note>
                <head>
                    <hi rend="italic">President <persName type="from">Truman</persName> to General
                            <persName type="to">Marshall</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1946-09-26">26 September,
                            1946</date>.</dateline>
                </opener>
                <p>81554. Personal for General Marshall from the President.</p>
                <quote rend="blockquote">
                    <p>“<hi rend="smallcaps">Dear General Marshall</hi>: Have read your 1549 of
                        September 23d with great interest. I have the utmost confidence in you. I
                        know you can ‘pull the chestnut out of the cross fire.’ If it can be done at
                        all. The President.”</p>
                </quote>
            </div>
        </body>
    </text>
