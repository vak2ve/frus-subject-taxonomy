            <div frus:doc-dateTime-max="1946-01-04T16:00:00-05:00" frus:doc-dateTime-min="1946-01-04T16:00:00-05:00" n="628" subtype="historical-document" type="document" xml:id="d628">
                <note rend="inline" type="source">893.51/1–446: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Embassy in China</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1946-01-04T16:00:00-05:00">January 4, 1946—4 p.m.</date>
                    </dateline>
                </opener>
                <p>18. For General Marshall.<note n="2" xml:id="d628fn2">General of the Army George
                        C. Marshall, Special Representative of President Truman in China.</note>
                    Board of Directors of Eximbank<note n="3" xml:id="d628fn3">Export–Import Bank of
                        Washington.</note> approved Jan 3 a line of credit of $33,000,000 to finance
                    shipments of cotton to China.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Byrnes</hi>
                    </signed>
                </closer>
            </div>
