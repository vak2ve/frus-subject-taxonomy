                subtype="historical-document" type="document" xml:id="d763">
                <note rend="inline" type="source">Marshall Mission Files, Lot 54–D270:
                    Telegram</note>
                <head>
                    <hi rend="italic">General <persName type="from">Marshall</persName> to Colonel
                            <persName type="to">Marshall S. Carter</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>,] <date calendar="gregorian" when="1946-05-04">4 May
                            1946</date>.</dateline>
                </opener>
                <p>640. I concur with State and Treasury regarding maintenance of our present
                    position with respect to offset principle. Your 85205 refers. Please keep me
                    informed of any future proposals to obtain reversal of agreements previously
                    reached with me.<note n="17" xml:id="d763fn17">See telegram No. 294, February
                        14, 11 a.m., from the Counselor of Embassy in China, <ref target="#pg_939"
                            >p. 939</ref>.</note>
                </p>
            </div>
        </body>
