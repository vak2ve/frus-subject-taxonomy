                subtype="historical-document" type="document" xml:id="d471">
                <note rend="inline" type="source">Marshall Mission Files, Lot 54–D270:
                    Telegram</note>
                <head>
                    <hi rend="italic">General <persName type="from">Marshall</persName> to Colonel
                            <persName type="to">Marshall S. Carter</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>,] <date calendar="gregorian" when="1946-08-11">11 August
                            1946</date>.</dateline>
                </opener>
                <p>1293. Delivery should not be completed reference 96621<note n="21"
                        xml:id="d471fn21">
                        <hi rend="italic">Supra.</hi>
                    </note> at this time, on the 8–⅓ Air Group Program through surplus property
                    channels. Just how long delivery should be delayed I am not prepared to state at
                    this time.</p>
            </div>
        </body>
