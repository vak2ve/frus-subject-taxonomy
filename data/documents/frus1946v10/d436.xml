                subtype="historical-document" type="document" xml:id="d436">
                <note rend="inline" type="source">811.79693/9–1446: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Stuart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1946-09-14T17:00:00+09:00"
                            >September 14, 1946—5 p.m.</date>
                        <lb/> [Received September 15—1:40 a.m.]</dateline>
                </opener>
                <p>1485. General Marshall approved Embassy’s telegram 1477, September 13, 1 p.m.,
                    which was despatched before Department’s telegram <pb facs="0770" n="760"
                        xml:id="pg_760"/> 736, September 10, 7 p.m., was decoded. In these
                    circumstances, is Department content to await results of action already
                    taken?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stuart</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
