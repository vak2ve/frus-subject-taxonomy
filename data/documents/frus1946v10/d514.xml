    <text>
        <body>
            <div frus:doc-dateTime-max="1946-11-29T23:59:59-05:00"
                frus:doc-dateTime-min="1946-11-29T00:00:00-05:00" n="514"
                subtype="historical-document" type="document" xml:id="d514">
                <note rend="inline" type="source">Marshall Mission Files, Lot 54–D270</note>
                <head>
                    <hi rend="italic">Memorandum by Colonel <persName type="from">J. Hart
                            Caughey</persName>
                    </hi>
                    <note n="81a" xml:id="d514fn81a">Executive Officer on General Marshall’s staff
                        at Nanking.</note>
                    <hi rend="italic">to the Minister-Counselor of Embassy in China</hi> (<persName
                        type="to">
                        <hi rend="italic">Butterworth</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">OSE 606</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1946-11-29">29 November
                            1946</date>.</dateline>
                </opener>
                <p>Reference is made to 1779, 18 November 1946, copy of which was furnished to you.
                    Colonel Carter has now advised us that he has arranged for the temporary
                    suspension of actual transfer of the subject escort carriers to the Chinese.</p>
                <closer>
                    <signed>J. <hi rend="smallcaps">Hart Caughey</hi>
                    </signed>
                </closer>
            </div>
        </body>
