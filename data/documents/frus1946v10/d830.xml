        <body>
            <div frus:doc-dateTime-max="1946-02-09T23:59:59-05:00" frus:doc-dateTime-min="1946-02-09T00:00:00-05:00" n="830" subtype="historical-document" type="document" xml:id="d830">
                <note rend="inline" type="source">893.60/2–946: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Embassy in China</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1946-02-09">February 9,
                            1946</date>.</dateline>
                </opener>
                <p>260. Please discuss the immediately following telegram<note n="16" xml:id="d830fn16">See footnote 17, below.</note> in regard to Manchurian
                    industrial enterprises with General Marshall and be guided by his advice in
                    taking action.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Byrnes</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
