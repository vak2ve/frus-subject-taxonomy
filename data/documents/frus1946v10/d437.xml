<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Acting Secretary of State to
                        the Ambassador in China (
                        Stuart
                    )</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1946v10</bibl><bibl type="frus-document-id">d437</bibl><bibl type="frus-document-number">437</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1946-09-16T16:00:00-05:00" notAfter="1946-09-16T16:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1946-09-16T16:00:00-05:00" frus:doc-dateTime-min="1946-09-16T16:00:00-05:00" n="437" subtype="historical-document" type="document" xml:id="d437">
                <note rend="inline" type="source">893.24/9–1046: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Stuart</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1946-09-16T17:00:00-04:00">September 16, 1946—5 p.m.</date>
                    </dateline>
                </opener>
                <p>755. Reurtel 1448, Sep 10,<note n="64" xml:id="d437fn64">Not printed; it
                        requested on behalf of T. V. Soong, President of the Chinese Executive Yuan,
                        a breakdown of post V–J Day military lend-lease.</note> breakdown post V–J
                    Day military lend-lease aid to China given below. Period covered Sep 2, 1945
                    through Jul 31, 1946. Note that time lag in reporting makes figures
                    incomplete.</p>
                <table cols="2" rend="width: 75%" rendition="#center-block" rows="8">
                    <row>
                        <cell>
                            <hi rend="italic">Category</hi>
                        </cell>
                        <cell>
                            <hi rend="italic">$ million of aid</hi>
                        </cell>
                    </row>
                    <row>
                        <cell>Ordnance &amp; ordnance stores</cell>
                        <cell role="num">64. 1</cell>
                    </row>
                    <row>
                        <cell>Aircraft &amp; Aeronautical material</cell>
                        <cell role="num">11. 3</cell>
                    </row>
                    <row>
                        <cell>Tanks &amp; other vehicles</cell>
                        <cell role="num">88. 6</cell>
                    </row>
                    <row>
                        <cell>Miscellaneous military equipment</cell>
                        <cell role="num">41. 9</cell>
                    </row>
                    <row>
                        <cell>Agricultural, industrial &amp; other commod.</cell>
                        <cell role="num">21. 0</cell>
                    </row>
                    <row>
                        <cell>Services &amp; expenses</cell>
                        <cell rendition="#underline" role="num">398. 3</cell>
                    </row>
                    <row>
                        <cell rendition="#right">Total</cell>
                        <cell role="num">625. 2</cell>
                    </row>
                </table>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Clayton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
