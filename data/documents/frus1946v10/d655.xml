                subtype="historical-document" type="document" xml:id="d655">
                <note rend="inline" type="source">893.51/2–1446: Telegram</note>
                <head>
                    <hi rend="italic">The Counselor of Embassy in China</hi> (<persName type="from">
                        <hi rend="italic">Smyth</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chungking</hi>
                        </placeName>, <date calendar="gregorian" when="1946-02-14T11:00:00+07:00"
                            >February 14, 1946—11 a.m.</date>
                        <lb/> [Received 5:48 p.m.]</dateline>
                </opener>
                <p>294. From Adler to the Secretary of the Treasury. After a conversation with
                    General Marshall, T. V. Soong agreed (re your telegram 85 of January 14) to
                    accept the offset principle with respect to Chinese requisitions of surplus
                    property. [Adler.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Smyth</hi>
                    </signed>
                </closer>
            </div>
        </body>
