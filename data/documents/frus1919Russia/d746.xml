                subtype="historical-document" type="document" xml:id="d746">
                <note rend="inline" type="source">861.00/5358</note>
                <head>
                    <hi rend="italic">The Russian Military Attaché</hi> (<persName type="from">
                        <hi rend="italic">Nikolaieff</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">War Department</gloss>
                    </hi>
                    <note n="66" xml:id="d746fn66">Copy transmitted to the Department of State by
                        the War Department Sept. 24.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-09-18">
                            <hi rend="italic">September 18, 1919</hi>
                        </date>.</dateline>
                </opener>
                <p rend="center">
                    <hi rend="smallcaps">Memorandum</hi>
                </p>
                <p>
                    <persName corresp="#p_MGELK1">General Miller</persName>, Russian Army, Commander
                    in Chief at Archangel, cabled on September 11th to the Russian Ambassador at
                    Washington to the following effect: The people of Archangel are anxious to send
                    a delegation to the United States with the purpose of finding volunteers among
                    the Russians residing in this country as well as among the American citizens,
                    who would like to go to the Northern Front, which is very much weakened on
                    account of the withdrawal of all the allied troops, and to fight the
                    bolsheviki.</p>
                <p>
                    <persName corresp="#p_MGELK1">General Miller</persName> would like to be
                    informed, whether such a recruiting could be successful and whether the sending
                    of the above mentioned delegation would be advisable.</p>
            </div>
        </body>
