                subtype="historical-document" type="document" xml:id="d828">
                <note rend="inline" type="source">861.00/5420: Telegram</note>
                <head>
                    <hi rend="italic">The Vice Consul at Viborg</hi> (<persName type="from">
                        <hi rend="italic">Imbrie</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Viborg</hi>
                        </placeName>, <date calendar="gregorian" when="1919-10-18">
                            <hi rend="italic">October 18, 1919</hi>
                        </date>.<lb/>[Received 9:36 p.m.]</dateline>
                </opener>
                <p>119. Finnish General Staff officially communicates to representative of
                    Northwestern Government here that the White Forces have occupied Petrograd. The
                    White flag is flying from Kronstadt.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Imbrie</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
