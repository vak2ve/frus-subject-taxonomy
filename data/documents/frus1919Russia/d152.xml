    <text>
        <body>
            <div frus:doc-dateTime-max="1919-03-08T17:00:00-05:00"
                frus:doc-dateTime-min="1919-03-08T17:00:00-05:00" n="152"
                subtype="historical-document" type="document" xml:id="d152">
                <note rend="inline" type="source">811.20261/27: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Sweden</hi> (<persName corresp="#p_MRS1" type="to">
                        <hi rend="italic">Morris</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-03-08T17:00:00-05:00">
                            <hi rend="italic">March 8, 1919, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1556. Your 3699, March 5, 5 p.m.<note n="42" xml:id="d152fn42">Not
                        printed.</note> Have <persName>Larsen</persName> use every unofficial effort
                    to secure release of <persName>Tredwell</persName> and Kalamatiano.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
