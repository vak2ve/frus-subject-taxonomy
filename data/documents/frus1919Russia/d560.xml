                subtype="historical-document" type="document" xml:id="d560">
                <note rend="inline" type="source">861.00/5273: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Consul General at Irkutsk</hi> (<persName corresp="#p_HEL1" type="to">
                        <hi rend="italic">Harris</hi>
                    </persName>), <hi rend="italic">temporarily at Omsk</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-09-26T18:00:00-04:00">
                            <hi rend="italic">September 26, 1919, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your 398, September 24, noon. <persName corresp="#p_GMGWS1">General
                        Graves</persName> has been instructed to deliver rifles immediately in
                    fulfilment of contract.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PW1">
                            <hi rend="smallcaps">Phillips</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
