    <text>
        <body>
            <div frus:doc-dateTime-max="1919-09-03T05:00:00-05:00"
                frus:doc-dateTime-min="1919-09-03T05:00:00-05:00" n="740"
                subtype="historical-document" type="document" xml:id="d740">
                <note rend="inline" type="source">861.00/5145: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Russia</hi> (<persName corresp="#p_CF1"
                        type="from">
                        <hi rend="italic">Cole</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Archangel</hi>
                        </placeName>, <date calendar="gregorian" when="1919-09-03T13:00:00+03:00">
                            <hi rend="italic">September 3, 1919, 1 p.m.</hi>
                        </date>
                        <lb/>[Received September 4, 7:34 a.m.]</dateline>
                </opener>
                <p>1403. All American private individuals have now left Archangel except several
                    officers detailed for special work in Archangel by <persName corresp="#p_RBGWP1"
                        >General Richardson</persName>.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_CF1">
                            <hi rend="smallcaps">Cole</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
