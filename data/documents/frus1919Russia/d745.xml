<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-09-14T01:00:00-05:00" frus:doc-dateTime-min="1919-09-14T01:00:00-05:00" n="745" subtype="historical-document" type="document" xml:id="d745">
                        <note rend="inline" type="source">123 C 673/38: Telegram</note>
                        <head><hi rend="italic">The Chargé in Russia</hi> (<persName corresp="#p_CF1" type="from"><hi rend="italic">Cole</hi></persName>)
                                <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Archangel</hi></placeName>, <date calendar="gregorian" when="1919-09-14T09:00:00+03:00"><hi rend="italic">September 14,
                                        1919, 9 a.m.</hi></date><lb/>[Received 11:55
                                p.m.]</dateline></opener>
                        <p>1417. Leaving this morning to London with Flack and Strother. Please
                            inform families.</p>
                        <closer><signed><persName corresp="#p_CF1"><hi rend="smallcaps">Cole</hi></persName></signed></closer>
                    </div>
