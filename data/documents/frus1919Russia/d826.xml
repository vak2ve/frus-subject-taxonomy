                <note rend="inline" type="source">861.00/5397: Telegram</note>
                <head>
                    <hi rend="italic">The Commissioner at Helsingfors</hi> (<persName type="from">
                        <hi rend="italic">Haynes</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Helsingfors</hi>
                        </placeName>, <date calendar="gregorian" when="1919-10-16T16:00:00+01:39">
                            <hi rend="italic">October 16, 1919—4 p.m.</hi>
                        </date>
                        <lb/>[Received 11:45 p.m.]</dateline>
                </opener>
                <p>467. Reported Petrograd and Cronstadt taken.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Haynes</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
