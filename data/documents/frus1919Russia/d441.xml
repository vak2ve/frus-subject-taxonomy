    <text>
        <body>
            <div frus:doc-dateTime-max="1919-08-24T23:59:59-05:00"
                frus:doc-dateTime-min="1919-08-24T00:00:00-05:00" n="441"
                subtype="historical-document" type="document" xml:id="d441">
                <note rend="inline" type="source">123M832/34: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName corresp="#p_RPS1"
                        type="from">
                        <hi rend="italic">Reinsch</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1919-08-24">
                            <hi rend="italic">August 24, 1919</hi>
                        </date>.<lb/>[Received 8:22 a.m.]</dateline>
                </opener>
                <p>From [<persName corresp="#p_HEL1">Harris</persName> at] Omsk.</p>
                <p>“356, August 23, 1 p.m. <persName corresp="#p_MRS1">Morris</persName> and
                        <persName corresp="#p_GMGWS1">Graves</persName> leave for Vladivostok today.
                    I am remaining Omsk for the purpose of evacuating Red Cross and other American
                    interests if necessary. <persName corresp="#p_HEL1">Harris</persName>.[”]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_RPS1">
                            <hi rend="smallcaps">Reinsch</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
