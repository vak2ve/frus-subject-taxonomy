                subtype="historical-document" type="document" xml:id="d2">
                <note rend="inline" type="source">861.00/3526: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">Commission to Negotiate Peace</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-12-27T20:00:00-05:00">
                            <hi rend="italic">December 27, 1918, 8 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>14. For Secretary <persName corresp="#p_LR1">Lansing</persName>. Referring
                    telegram 24th from Legation Stockholm regarding peace proposal of the Russian
                    Federative Republic of Soviets. The Department believes it to be a matter for
                    consideration by the Associated Governments and therefore, requests instructions
                    as to what action, if any, should be taken by the Department here.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
