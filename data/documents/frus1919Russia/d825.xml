<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-10-16T08:21:00-05:00" frus:doc-dateTime-min="1919-10-16T08:21:00-05:00" n="825" subtype="historical-document" type="document" xml:id="d825">
                        <note rend="inline" type="source">861.00/5404: Telegram</note>
                        <head><hi rend="italic">The Commissioner at Helsingfors</hi> (<persName type="from"><hi rend="italic">Haynes</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Helsingfors</hi></placeName>, <date calendar="gregorian" when="1919-10-16T15:00:00+01:39"><hi rend="italic">October 16,
                                        1919—3 p.m.</hi></date><lb/>[Received October 17, 1:43
                                a.m.]</dateline></opener>
                        <p>465. Reported Gatchina taken by Northwestern Army and Petrograd likely to
                            fall in few days.</p>
                        <closer><signed><persName><hi rend="smallcaps">Haynes</hi></persName></signed></closer>
                    </div>
