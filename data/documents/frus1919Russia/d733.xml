                <note rend="inline" type="source">861.01/110: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Russia</hi> (<persName corresp="#p_CF1" type="to">
                        <hi rend="italic">Cole</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-08-15T16:00:00-04:00">
                            <hi rend="italic">August 15, 1919—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>736. For <persName corresp="#p_CF1">Cole</persName>.</p>
                <p>Your 1379, August 13th, 8 p.m. approved.<note n="57" xml:id="d733fn57"
                        >Transmitted in telegram from the Ambassador in Great Britain, no. 2793,
                        Aug. 14, 6 p.m., <hi rend="italic">supra.</hi>
                    </note>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
