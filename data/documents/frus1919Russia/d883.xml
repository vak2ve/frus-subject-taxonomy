                subtype="historical-document" type="document" xml:id="d883">
                <note rend="inline" type="source">861.00/4441: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Commission to Negotiate Peace</gloss>
                        to the <gloss type="to">Acting Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date ana="#date_undated-inferred-from-document-content"
                            calendar="gregorian" notAfter="1919-05-07T11:54:00-04:00"
                            notBefore="1919-05-05T18:00:00+02:00">
                            <hi rend="italic">undated</hi>
                        </date>.<lb/>[Received May 7, 1919, 11:54 a.m.]</dateline>
                </opener>
                <p>2026. From Sta[tion] Nav[al, Constantinople:] <quote rend="blockquote">
                        <p>“May 5, 6 p.m. From <persName corresp="#p_JWL1">Jenkins</persName>.</p>
                        <p>Repeat to Department. Evacuation of Sebastopol completed. Bolsheviki in
                            control. Kertch still held by Volunteer Army.</p>
                        <p rend="right">
                            <persName>Ravndal</persName>, <hi rend="italic">American Consul
                                General</hi>”</p>
                    </quote>
                </p>
                <closer>
                    <hi rend="smallcaps">American Mission</hi>
                </closer>
            </div>
        </body>
