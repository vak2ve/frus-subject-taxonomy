    <text>
        <body>
            <div frus:doc-dateTime-max="1919-11-18T13:00:00-05:00"
                frus:doc-dateTime-min="1919-11-18T13:00:00-05:00" n="295"
                subtype="historical-document" type="document" xml:id="d295">
                <note rend="inline" type="source">861.77/1211b: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Vladivostok</hi> (<persName corresp="#p_MDB1" type="to">
                        <hi rend="italic">Macgowan</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-11-18T13:00:00-05:00">
                            <hi rend="italic">November 18, 1919, 1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>For <persName corresp="#p_SCH1">Smith</persName>.</p>
                <p>Please consult <persName corresp="#p_SJF1">Stevens</persName> and telegraph
                    urgently: <list>
                        <label>1st,</label>
                        <item>amounts contributed to date to the support of the Inter-Allied Railway
                            plan by Japan and other associated powers.</item>
                        <label>2d,</label>
                        <item>estimated money needs for continuing operations on present basis
                            during the calendar year 1920.</item>
                        <label>3d,</label>
                        <item>portion of this amount which you think United States should equitably
                            furnish.</item>
                    </list>
                </p>
                <pb facs="0383" n="271" xml:id="pg_271"/>
                <p>Please add any recommendations concerning the future of the work which you may
                    care to make.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
