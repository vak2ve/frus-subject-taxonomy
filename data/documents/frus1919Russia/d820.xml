                subtype="historical-document" type="document" xml:id="d820">
                <note rend="inline" type="source">861.00/5383: Telegram</note>
                <head>
                    <hi rend="italic">The Vice Consul at Viborg</hi> (<persName type="from">
                        <hi rend="italic">Imbrie</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Viborg</hi>
                        </placeName>, <date calendar="gregorian" when="1919-10-14">
                            <hi rend="italic">October 14, 1919</hi>
                        </date>.<lb/>[Received 3:49 p.m.]</dateline>
                </opener>
                <p>115. The Russ Northwestern Corps has started an offensive and the cities, Pskof
                    and Yamburg, have been retaken.</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Imbrie</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
