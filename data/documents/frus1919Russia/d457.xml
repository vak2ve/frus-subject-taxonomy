    <text>
        <body>
            <div frus:doc-dateTime-max="1919-09-27T05:03:00-05:00"
                frus:doc-dateTime-min="1919-09-26T00:07:00-05:00" n="457"
                subtype="historical-document" type="document" xml:id="d457">
                <note rend="inline" type="source">861.00/5283: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName type="from">
                        <hi rend="italic">Tenney</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date ana="#date_undated-inferred-from-document-content"
                            calendar="gregorian" notAfter="1919-09-27T06:03:00-04:00"
                            notBefore="1919-09-26T10:00:00+04:53">
                            <hi rend="italic">undated</hi>
                        </date>.<lb/>[Received September 27, 1919, 6:03 a.m.]</dateline>
                </opener>
                <p>From [<persName corresp="#p_HEL1">Harris</persName> at] Omsk.</p>
                <p>“400. September 26, 10 a.m. Department’s September 19, 5 p.m.<note n="72"
                        xml:id="d457fn72">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_424">p. 424</ref>.</note> has
                    created very favorable impression with Omsk Government. <persName
                        corresp="#p_HEL1">Harris</persName>.”</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Tenney</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
