    <text>
        <body>
            <div frus:doc-dateTime-max="1919-07-25T12:06:00-05:00"
                frus:doc-dateTime-min="1919-07-25T00:07:00-05:00" n="549"
                subtype="historical-document" type="document" xml:id="d549">
                <note rend="inline" type="source">861.00/4911: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName corresp="#p_RPS1"
                        type="from">
                        <hi rend="italic">Reinsch</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date ana="#date_undated-inferred-from-document-content"
                            calendar="gregorian" notAfter="1919-07-25T13:06:00-04:00"
                            notBefore="1919-07-25T10:00:00+04:53">
                            <hi rend="italic">undated</hi>
                        </date>.<lb/>[Received July 25, 1919, 1:06 p.m.]</dateline>
                </opener>
                <p>From [<persName corresp="#p_HEL1">Harris</persName> at] Omsk.</p>
                <p>[“]336, July 25, 10 a.m. Referring to Department’s July 15, 5 a.m. [<hi
                        rend="italic">July 16, 6 p.m.?</hi>] General <persName>Horvath</persName>
                    has been definitely retired and Rozanoff sent Vladivostok to replace him.
                        <persName corresp="#p_HEL1">Harris</persName>.”</p>
                <closer>
                    <signed>
                        <persName corresp="#p_RPS1">
                            <hi rend="smallcaps">Reinsch</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
