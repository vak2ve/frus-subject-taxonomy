<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-10-22T23:59:59-05:00" frus:doc-dateTime-min="1919-10-22T00:00:00-05:00" n="831" subtype="historical-document" type="document" xml:id="d831">
                        <note rend="inline" type="source">861.00/5452: Telegram</note>
                        <head><hi rend="italic">The Vice Consul at Viborg</hi> (<persName type="from"><hi rend="italic">Imbrie</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Viborg</hi></placeName>, <date calendar="gregorian" when="1919-10-22"><hi rend="italic">October 22,
                                1919</hi></date>.<lb/>[Received October 23, 5:33
                            a.m.]</dateline></opener>
                        <p>124. Fighting continues outskirts of Petrograd. Whites unable to advance.
                            Bolsheviks bringing up reinforcements.</p>
                        <closer><signed><persName><hi rend="smallcaps">Imbrie</hi></persName></signed></closer>
                    </div>
                    </body></text></TEI>