                subtype="historical-document" type="document" xml:id="d796">
                <note rend="inline" type="source">861.48/918: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName corresp="#p_WHC1" type="to">
                        <hi rend="italic">Wallace</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-08-08T15:00:00-04:00">
                            <hi rend="italic">August 8, 1919, 3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>9019. For <persName corresp="#p_HHC1">Hoover</persName>.</p>
                <p>Your 854, undated.<note n="35" xml:id="d796fn35">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_698">p. 698</ref>.</note>
                </p>
                <p>American Commissioner, Helsingfors, directed to issue necessary instructions to
                    American Vice Consul at Viborg regarding Russian supplies, as you request.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
