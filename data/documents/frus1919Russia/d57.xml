<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-03-08T23:59:59-05:00" frus:doc-dateTime-min="1919-03-08T00:00:00-05:00" n="57" subtype="historical-document" type="document" xml:id="d57">
                        <note rend="inline" type="source">861.00/4039: Telegram</note>
                        <head><hi rend="italic">The Vice Consul at Viborg</hi> (<persName type="from"><hi rend="italic">Imbrie</hi></persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                                    State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Viborg</hi></placeName>, <date calendar="gregorian" when="1919-03-08"><hi rend="italic">March 8,
                                1919</hi></date>.<lb/>[Received March 9, 2:45
                            p.m.]</dateline></opener>
                        <p>6. <persName corresp="#p_BWC1">William Bullitt</persName> and party from
                            American Mission Paris crossed border into Russia today at 1 p.m.</p>
                        <closer><signed><persName><hi rend="smallcaps">Imbrie</hi></persName></signed></closer>
