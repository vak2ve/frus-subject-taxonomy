    <text>
        <body>
            <div frus:doc-dateTime-max="1919-05-12T23:59:59-05:00"
                frus:doc-dateTime-min="1919-05-12T00:00:00-05:00" n="775"
                subtype="historical-document" type="document" xml:id="d775">
                <note rend="inline" type="source">Paris Peace Conference 184.01502/27:
                    Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Denmark</hi> (<persName type="from">
                        <hi rend="italic">Grant-Smith</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Commission to Negotiate
                            Peace</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Copenhagen</hi>
                        </placeName>, <date calendar="gregorian" when="1919-05-12">
                            <hi rend="italic">May 12, 1919</hi>
                        </date>.<lb/>[Received in Paris, 9:30 p.m.]</dateline>
                </opener>
                <p>366. Following from <persName corresp="#p_GLCW1">Greene</persName>, Libau.</p>
                <p>“<persName corresp="#p_GLCW1">Greene</persName>, 31, May 11: Actual distribution
                    American food begun under Major Brookings in Libau, May 9, through Municipal
                    Council. <pb facs="0789" n="677" xml:id="pg_677"/> Flour also <hi rend="italic"
                        >en route</hi> Windau and shortly to Mitau and Tuckum. All distribution
                    through Municipal Councils as no national government. As privation exists mainly
                    in cities this relieves situation.</p>
                <p rend="center">. . . . . . .</p>
                <p rend="right">
                    <persName corresp="#p_GLCW1">Greene</persName>”</p>
                <closer>
                    <signed>
                        <persName>
                            <hi rend="smallcaps">Grant-Smith</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
