<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-02-27T16:00:00-05:00" frus:doc-dateTime-min="1919-02-27T16:00:00-05:00" n="273" subtype="historical-document" type="document" xml:id="d273">
                        <note rend="inline" type="source">861.77/690: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Consul at Vladivostok</hi> (<persName corresp="#p_CJK1" type="to"><hi rend="italic">Caldwell</hi></persName>)</head>
                        <opener><seg rendition="#center">[Extract]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-02-27T16:00:00-05:00"><hi rend="italic">February 27,
                                        1919, 4 p.m.</hi></date></dateline></opener>
                        <p>For <persName corresp="#p_MRS1">Morris</persName>.</p>
                        <p>Your February 24, 10 a.m. Please transmit following message to <persName corresp="#p_SCH1">Smith</persName><note n="58" xml:id="d273fn58">See
                                telegram from the Ambassador in Japan, Feb. 6, 1919, 4 p.m., <ref target="#pg_249">p. 249</ref>.</note> from Department: <quote rend="blockquote">
                                <p>“You are hereby appointed American representative on the
                                    Inter-Allied Committee organized to undertake the supervision of
                                    the Siberian Railways …”</p>
                            </quote></p>
                        <p rend="center">. . . . . . .</p>
                        <closer><signed><persName corresp="#p_PFL"><hi rend="smallcaps">Polk</hi></persName></signed></closer>
                    </div>
                    </body></text></TEI>