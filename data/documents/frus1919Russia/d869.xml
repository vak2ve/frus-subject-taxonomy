                subtype="historical-document" type="document" xml:id="d869">
                <note rend="inline" type="source">125.677/5a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Russia</hi> (<persName corresp="#p_PDC1" type="to">
                        <hi rend="italic">Poole</hi>
                    </persName>)<note n="1" xml:id="d869fn1">At Archangel.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-01-25T18:00:00-05:00">
                            <hi rend="italic">January 25, 1919—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>461. Your 762, January 20.<note n="2" xml:id="d869fn2">Not printed.</note> Consul
                        <persName corresp="#p_JWL1">William Jenkins</persName> with Randolph,
                    Doolittle, Lehrs and Burri, is proceeding Odessa to open office and keep in
                    touch matters South Russia. <persName corresp="#p_SCH1">Smith</persName> to
                    Tiflis. For your confidential information <persName corresp="#p_SCH1"
                        >Smith</persName> intends resign after arrival Tiflis.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
