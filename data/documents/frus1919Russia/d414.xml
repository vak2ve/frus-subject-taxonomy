                subtype="historical-document" type="document" xml:id="d414">
                <note rend="inline" type="source">123.M832/32: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName corresp="#p_MRS1">
                        <hi rend="italic">Morris</hi>
                    </persName>), <hi rend="italic">temporarily at Vladivostok, to the <gloss
                            type="to">Acting Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vladivostok</hi>
                        </placeName>, <date calendar="gregorian" when="1919-07-10T20:00:00+08:47">
                            <hi rend="italic">July 10, 1919, 8 p.m.</hi>
                        </date>
                        <lb/>[Received 11:50 p.m.]</dateline>
                </opener>
                <p>I arrived Vladivostok this morning and have arranged to proceed to Omsk tomorrow,
                    July 11. <persName corresp="#p_GMGWS1">General Graves</persName> will accompany
                    me. Until further notice please send message through <persName corresp="#p_CJK1"
                        >Caldwell</persName>, who will be advised of my movements.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MRS1">
                            <hi rend="smallcaps">Morris</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
