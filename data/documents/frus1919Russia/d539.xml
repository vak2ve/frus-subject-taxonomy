                subtype="historical-document" type="document" xml:id="d539">
                <note rend="inline" type="source">861.01/58: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">Commission to Negotiate Peace</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-06-03T18:00:00-04:00">
                            <hi rend="italic">June 3, 1919, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>2182. For the Secretary of State and <persName>McCormick</persName>:</p>
                <p>Text of telegram from <persName>Semenoff</persName> to <persName
                        corresp="#p_KAAV1">Admiral Kolchak</persName> submitted to Department by
                    Russian Embassy here. <persName>Semenoff</persName> recognizes <persName
                        corresp="#p_KAAV1">Kolchak</persName> and submits unconditionally to his
                    command.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
