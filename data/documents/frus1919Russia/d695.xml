    <text>
        <body>
            <div frus:doc-dateTime-max="1919-04-18T08:29:00-05:00"
                frus:doc-dateTime-min="1919-04-18T08:29:00-05:00" n="695"
                subtype="historical-document" type="document" xml:id="d695">
                <note rend="inline" type="source">861.00/4318: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Russia</hi> (<persName corresp="#p_PDC1"
                        type="from">
                        <hi rend="italic">Poole</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Archangel</hi>
                        </placeName>, <date calendar="gregorian" when="1919-04-18T17:00:00+03:31">
                            <hi rend="italic">April 18, 1919, 5 p.m.</hi>
                        </date>
                        <lb/>[Received April 19, 5:49 a.m.]</dateline>
                </opener>
                <p>1091. <persName corresp="#p_RBGWP1">General Richardson</persName>
                    <note n="32" xml:id="d695fn32">
                        <persName corresp="#p_RBGWP1">Brig. Gen. Wilds P. Richardson</persName>,
                        U.S.A., commanding American troops in northern Russia.</note> arrived
                    yesterday. I had a very satisfactory talk with him this morning. There is every
                    reason to anticipate hearty co-operation.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PDC1">
                            <hi rend="smallcaps">Poole</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
