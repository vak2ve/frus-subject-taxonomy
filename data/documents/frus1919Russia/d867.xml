    <text>
        <body>
            <div frus:doc-dateTime-max="1919-12-31T14:00:00-05:00"
                frus:doc-dateTime-min="1919-12-31T14:00:00-05:00" n="867"
                subtype="historical-document" type="document" xml:id="d867">
                <note rend="inline" type="source">861.48/1061: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Commissioner at Riga</hi> (<persName corresp="#p_GJA1" type="to">
                        <hi rend="italic">Gade</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1919-12-31T14:00:00-05:00">
                            <hi rend="italic">December 31, 1919—2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your 320, December 25, 10 a.m.<note n="82" xml:id="d867fn82">Not printed.</note>
                </p>
                <p>
                    <persName corresp="#p_MGELK1">Miller</persName>, Reval, telegraphs that due to
                    difficulty transshipping food supplies from Viborg to Reval, he desires to use
                    1,000 tons now at Reval for general and army relief. Department sees no
                    objection thereto, and if you concur, so instruct <persName corresp="#p_MGELK1"
                        >Miller</persName>.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
