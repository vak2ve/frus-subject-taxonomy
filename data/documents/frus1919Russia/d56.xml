                <note rend="inline" type="source">861.00/3980: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Commission to Negotiate Peace</gloss>
                        to the <gloss type="to">Acting Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1919-03-01T18:00:00+01:00">
                            <hi rend="italic">March 1, 1919, 6 p.m.</hi>
                        </date>
                        <lb/>[Received 6:37 p.m.]</dateline>
                </opener>
                <p>986. Your 900, February 27th, 7 p.m. Stockholm advised.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                    <hi rend="smallcaps">Am</hi>[<hi rend="smallcaps">erican</hi>] <hi
                        rend="smallcaps">Mission</hi>
                </closer>
            </div>
