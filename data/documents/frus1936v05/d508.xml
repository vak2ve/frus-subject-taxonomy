                subtype="historical-document" type="document" xml:id="d508">
                <note rend="inline" type="source">611.1431/166: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Guatemala</hi> (<persName type="from">
                        <hi rend="italic">O’Donoghue</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guatemala</hi>
                        </placeName>, <date calendar="gregorian" when="1936-03-23T11:00:00-06:00"
                            >March 23, 1936—11 a.m.</date>
                        <lb/>[Received 1:40 p.m.]</dateline>
                </opener>
                <p>25. Department’s 16, March 21, 2 p.m.</p>
                <list>
                    <label>1.</label>
                    <item>Minister of Hacienda agrees to change wording quoted in Legation’s No. 24,
                        March 21, 10 a.m., to read “made in the country of export”. Also delete
                        “original”.</item>
                    <label>2.</label>
                    <item>Minister agrees to use of “other” in notes 1 and 2.</item>
                </list>
                <closer>
                    <signed>
                        <hi rend="smallcaps">O’Donoghue</hi>
                    </signed>
                </closer>
            </div>
        </body>
