    <text>
        <body>
            <div frus:doc-dateTime-max="1936-02-26T23:59:59-05:00"
                frus:doc-dateTime-min="1936-02-26T00:00:00-05:00" n="741"
                subtype="historical-document" type="document" xml:id="d741">
                <note rend="inline" type="source">711.1928/507a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Fiscal Agent of the Republic of Panama</hi> (<persName type="to">
                        <hi rend="italic">Cromwell</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-02-26">February 26,
                            1936</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department encloses herewith copy of the
                    Comptroller General’s settlement certificate No. 0391039 dated February 26,
                    1936, and check on the Treasurer of the United States, No. 48,769, dated
                    February 26, 1936, payable to your order as Fiscal Agent of the Republic of
                    Panama, for $250,000.00, in settlement of the annuity due the Republic of Panama
                    on February 26, 1936, under Treaty of November 18, 1903.</p>
                <p>Please sign the enclosed receipt and return it to the Department for its
                    files.</p>
                <p>Very truly yours,</p>
                <closer>For the Secretary of State:<lb/>
                    <signed>
                        <hi rend="smallcaps">Wilbur J. Carr</hi>
                    </signed>
                    <lb/>
                    <hi rend="italic">Assistant Secretary</hi>
                </closer>
            </div>
        </body>
