<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-11-27T17:00:00-05:00" frus:doc-dateTime-min="1936-11-27T17:00:00-05:00" n="737" subtype="historical-document" type="document" xml:id="d737">
                        <note rend="inline" type="source">810.00B/106a: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Chargé in Nicaragua</hi> (<persName type="to"><hi rend="italic">Ray</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1936-11-27T17:00:00-05:00">November 27, 1936—5
                                p.m.</date></dateline>
                        </opener>
                        <p>132. Your 234, November 26, noon.<note n="88" xml:id="d737fn88">Not
                                printed.</note> Make no reply to Nicaragua note until receipt of
                            instructions from the Department. Transmit to the Department a copy of
                            the note if you have not already done so.</p>
                        <closer><signed><hi rend="smallcaps">Moore</hi></signed></closer>
                    </div>
                    </body></text></TEI>