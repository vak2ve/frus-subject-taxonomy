                subtype="historical-document" type="document" xml:id="d262">
                <note rend="inline" type="source">832.5151/793a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Brazil</hi> (<persName type="to">
                        <hi rend="italic">Gibson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-01-11T17:00:00-05:00"
                            >January 11, 1936—5 p.m.</date>
                    </dateline>
                </opener>
                <p>11. For the purpose of determining the maturities of the notes to be issued under
                    the American agreement please endeavor to obtain <pb facs="0387" n="288"
                        xml:id="pg_288"/> as definite information as possible as to the maturities
                    of the British frozen credit obligations.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
