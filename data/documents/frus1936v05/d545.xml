                subtype="historical-document" type="document" xml:id="d545">
                <note rend="inline" type="source">838.51/3117: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Haiti</hi> (<persName type="from">
                        <hi rend="italic">Gordon</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port-au-Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1936-03-12T13:00:00-05:00"
                            >March 12, 1936—1 p.m.</date>
                        <lb/>[Received 2:40 p.m.]</dateline>
                </opener>
                <p>12. My 8, March 2 [<hi rend="italic">6</hi>], 3 p.m.,<note n="50"
                        xml:id="d545fn50">Not printed.</note> and 11, March 10, 9 p.m. [<hi
                        rend="italic">a.m.</hi>]. President has received another telegram from
                    Mayard to the effect that Quai d’Orsay declines conversations which do not
                    contain precise proposals and will give him until tomorrow to submit them. The
                    Foreign Minister says he does not propose to send any new instructions to
                    Mayard.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gordon</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
