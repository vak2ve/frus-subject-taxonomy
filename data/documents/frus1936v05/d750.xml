                subtype="historical-document" type="document" xml:id="d750">
                <note rend="inline" type="source">834.01/2: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Argentina</hi> (<persName type="to">
                        <hi rend="italic">Weddell</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-02-20T15:00:00-05:00"
                            >February 20, 1936—3 p.m.</date>
                    </dateline>
                </opener>
                <p>22. Your 43, February 19, 6 p.m. Please inform Dr. Saavedra Lamas that this
                    Government shares the opinions he expressed to you and that it will welcome the
                    opportunity of consulting with the Argentine Government and the neutral
                    governments represented on the Chaco Peace Conference before reaching any
                    decision concerning recognition of the new regime in Paraguay.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
