    <text>
        <body>
            <div frus:doc-dateTime-max="1936-06-03T23:59:59-05:00"
                frus:doc-dateTime-min="1936-06-03T00:00:00-05:00" n="624"
                subtype="historical-document" type="document" xml:id="d624">
                <note rend="inline" type="source">812.0145/18</note>
                <head>
                    <hi rend="italic">The Chargé in Mexico</hi> (<persName type="from">
                        <hi rend="italic">Boal</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 3646</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1936-06-03">June 3,
                            1936</date>.<lb/>[Received June 10.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the Department’s
                    instruction No. 1110 of May 23, 1936 on the above-mentioned subject and to
                    enclose herewith a copy of the note which the Department directed the Embassy to
                    transmit to the Foreign Office.<note n="66" xml:id="d624fn66">Note No. 1635,
                        June 3, not printed.</note> It will be observed that the Embassy’s note
                    follows as closely as possible the wording of the Department’s instruction.</p>
                <p>Respectfully yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Pierre de L. Boal</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
