<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1937-01-01T13:00:00-05:00" frus:doc-dateTime-min="1937-01-01T13:00:00-05:00" n="735" subtype="historical-document" type="document" xml:id="d735">
                        <note rend="inline" type="source">817.001 Somoza, Anastasio/11:
                            Telegram</note>
                        <head><hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from"><hi rend="italic">Long</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Managua</hi></placeName>, <date calendar="gregorian" when="1937-01-01T12:00:00-06:00">January 1,
                                1937—noon</date>.<lb/>[Received 3:50 p.m.]</dateline>
                        </opener>
                        <p>1. Somoza and Navarro inaugurated this morning without incident as
                            President and Vice President respectively.</p>
                        <closer><signed><hi rend="smallcaps">Long</hi></signed></closer>
                    </div>
                </body></text></TEI>