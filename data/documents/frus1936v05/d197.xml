                subtype="historical-document" type="document" xml:id="d197">
                <note rend="inline" type="source">824.00/761: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Bolivia</hi> (<persName type="from">
                        <hi rend="italic">Muccio</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">La Paz</hi>
                        </placeName>, <date calendar="gregorian" when="1936-05-22T19:00:00-04:00"
                            >May 22, 1936—7 p.m.</date>
                        <lb/>[Received 8:43 p.m.]</dateline>
                </opener>
                <p>27. Composition of Junta settled this evening to consist of six military, two
                    Socialist, two Republican Socialists, one Labor, with Toro as President of
                    Junta.</p>
                <p>Repeated to Buenos Aires.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Muccio</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
