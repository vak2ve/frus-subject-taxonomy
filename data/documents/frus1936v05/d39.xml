    <text>
        <body>
            <div frus:doc-dateTime-max="1936-02-07T19:00:00-05:00"
                frus:doc-dateTime-min="1936-02-07T19:00:00-05:00" n="39"
                subtype="historical-document" type="document" xml:id="d39">
                <note rend="inline" type="source">724.34119/373: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Paraguay</hi> (<persName type="from">
                        <hi rend="italic">Howard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Asunción</hi>
                        </placeName>, <date calendar="gregorian" when="1936-02-07T20:00:00-04:00"
                            >February 7, 1936—8 p.m.</date>
                        <lb/>[Received 10:25 p.m.]</dateline>
                </opener>
                <p>11. My 10, Feb. 6, 8 p.m.<note n="15" xml:id="d39fn15">Not printed.</note> The
                    agreement was approved by the Chamber of Deputies this evening. This constitutes
                    final action by the Paraguayan Congress.</p>
                <p>Repeated to Buenos Aires.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Howard</hi>
                    </signed>
                </closer>
            </div>
        </body>
