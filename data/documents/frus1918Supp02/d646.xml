<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-06-05T14:00:00-05:00" frus:doc-dateTime-min="1918-06-05T14:00:00-05:00" n="646" subtype="historical-document" type="document" xml:id="d646">
                        <note rend="inline" type="source">File No. 860c.48/84f</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Minister in the Netherlands</hi> (<persName corresp="#p_GJW1" type="to"><hi rend="italic">Garrett</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-06-05T15:00:00-04:00">
                                    <hi rend="italic">June 5, 1918, 3 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>1393. Inform authorities and Relief Committee all receipt forms for
                            relief moneys must bear indications that such moneys come from United
                            States.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_PFL1">
                                    <hi rend="smallcaps">Polk</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>