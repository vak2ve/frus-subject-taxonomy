                subtype="historical-document" type="document" xml:id="d653">
                <note rend="inline" type="source">File No. 860c.48/146</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Switzerland</hi> (<persName corresp="#p_SPA1" type="to">
                        <hi rend="italic">Stovall</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-10-22T19:00:00-04:00">
                            <hi rend="italic">October 22, 1918, 7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3181. Your 5036. Red Cross advises that milk could be forwarded in powdered form
                    in paper-lined wooden cases.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
