<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-05-29T23:59:59-05:00" frus:doc-dateTime-min="1918-05-29T00:00:00-05:00" n="705" subtype="historical-document" type="document" xml:id="d705">
                        <note rend="inline" type="source">File No. 891.48/60a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Persia</hi> (<persName corresp="#p_CJL1" type="to"><hi rend="italic">Caldwell</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-05-29">
                                    <hi rend="italic">May 29, 1918</hi></date>.</dateline>
                        </opener>
                        <p>60. Draw on Secretary of State $15,000 deposited by Joint Distribution
                            Committee by method most advantageous to save exchange, consult
                            Committee Bienfaisance Israelite, Teheran, Alliance Israelite, Hamadan,
                            and British Consul, Ispahan, and other leaders, Jewish community
                            especially, and distribute money relieving Jewish <pb facs="0652" n="568" xml:id="pg_568"/> distress. Send detailed reports from local
                            committees for Joint Distribution Committee at earliest opportunity.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>