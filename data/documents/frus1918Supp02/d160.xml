                subtype="historical-document" type="document" xml:id="d160">
                <note rend="inline" type="source">File No. 763.72115/3107</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in China</hi> (<persName corresp="#p_RPS1" type="to">
                        <hi rend="italic">Reinsch</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-21T17:00:00-05:00">
                            <hi rend="italic">April 21, 1917, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your telegram, April 19. No enemy alien allowed to enter this country without
                    special permit of Department of Justice. Do not visa passports of Germans
                    proposing to come to this country without previously reporting facts fully and
                    obtaining special authorization in each case.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
