                subtype="historical-document" type="document" xml:id="d791">
                <note rend="inline" type="source">File No. 811.142/2575</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to">
                        <hi rend="italic">Page</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-11-17">
                            <hi rend="italic">November 17, 1917</hi>
                        </date>.</dateline>
                </opener>
                <p>5846. Your 7714, 16th. Please acknowledge to Foreign Office and state that no
                    scheme, if any, will be presented which would interfere with the military
                    necessities of the Allies. Matter is held in abeyance pending clearing up of
                    political situation as regards Russia’s attitude.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
