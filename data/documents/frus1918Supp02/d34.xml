    <text>
        <body>
            <div frus:doc-dateTime-max="1918-02-05T13:41:00-05:00"
                frus:doc-dateTime-min="1918-02-03T11:00:00-05:00" n="34"
                subtype="historical-document" type="document" xml:id="d34">
                <note rend="inline" type="source">File No. 763.72114/3269</note>
                <head>
                    <hi rend="italic">The Minister in the Netherlands</hi> (<persName
                        corresp="#p_GJW1" type="from">
                        <hi rend="italic">Garrett</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Hague</hi>
                        </placeName>, <date
                            ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                            calendar="gregorian" notAfter="1918-02-05T19:00:00+00:19"
                            notBefore="1918-02-03T17:00:00+01:00">
                            <hi rend="italic">undated</hi>
                        </date>. <lb/> [<hi rend="italic">Received February 5, 1918, 7
                        p.m.</hi>]</dateline>
                </opener>
                <p>2004. Your January 8.<note n="1" xml:id="d34fn1">See footnote 1, <hi
                            rend="italic">ante</hi>, <ref target="#pg_18">p. 18</ref>.</note>
                    Foreign Office states that Netherlands Government will pass free of postage
                    letters and parcels to or from military and civilian prisoners of war.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Garrett</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
