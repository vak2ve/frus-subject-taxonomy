    <text>
        <body>
            <div frus:doc-dateTime-max="1917-12-31T15:00:00-05:00"
                frus:doc-dateTime-min="1917-12-31T15:00:00-05:00" n="497"
                subtype="historical-document" type="document" xml:id="d497">
                <note rend="inline" type="source">File No. No. 763.72112/5970</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Costa Rica</hi> (<persName corresp="#p_JS1" type="to">
                        <hi rend="italic">Johnson</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-12-31T15:00:00-05:00">
                            <hi rend="italic">December 31, 1917, 3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your December 20, 2 p.m.<note n="1" xml:id="d497fn1">Not printed.</note> War
                    Trade Board advises German subjects in neutral countries not doing business in
                    enemy territory <pb facs="0513" n="429" xml:id="pg_429"/> not enemies merely
                    because of German birth and trade with them not restricted unless they are on
                    enemy trading list or unless bankers there have reasonable cause to believe them
                    enemies or acting for enemies or allies of enemies.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
