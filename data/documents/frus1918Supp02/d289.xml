    <text>
        <body>
            <div frus:doc-dateTime-max="1917-12-22T11:00:00-05:00"
                frus:doc-dateTime-min="1917-12-22T11:00:00-05:00" n="289"
                subtype="historical-document" type="document" xml:id="d289">
                <note rend="inline" type="source">File No. 371.11/220</note>
                <head>
                    <hi rend="italic">The Chargé in Switzerland</hi> (<persName corresp="#p_WHR1"
                        type="from">
                        <hi rend="italic">Wilson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berne</hi>
                        </placeName>, <date calendar="gregorian" when="1917-12-22T17:00:00+01:00">
                            <hi rend="italic">December 22, 1917, 5 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received December 21, 4.30 a.m.</hi>]</dateline>
                </opener>
                <p>2289. Department’s 1227, December 15, 5 p.m.<note n="2" xml:id="d289fn2">Not
                        printed; see telegram No. 1076, Oct. 31, <hi rend="italic">ante</hi>, <ref
                            target="#pg_266">p. 266</ref>.</note> Spanish Embassy, Berlin, wires as
                    follows: <pb facs="0357" n="273" xml:id="pg_273"/>
                    <quote rend="blockquote">
                        <p>German Government informs me, in note just received, that their
                            Liquidation of American oil properties in Roumania has not yet been
                            effected but that this liquidation will be effected surely in the event
                            of news of the liquidation of German properties in the United
                            States.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_WHR1">
                            <hi rend="smallcaps">Wilson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
