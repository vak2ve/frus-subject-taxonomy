<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-03-23T17:00:00-05:00" frus:doc-dateTime-min="1917-03-23T17:00:00-05:00" n="525" subtype="historical-document" type="document" xml:id="d525">
                        <note rend="inline" type="source">File No. 863.852/12</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Austria-Hungary</hi> (<persName corresp="#p_PFC1" type="to"><hi rend="italic">Penfield</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-03-23T17:00:00-05:00">
                                    <hi rend="italic">March 23, 1917, 5 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>1617. Your March 20, 4 p.m. Inform steamship company that, Department’s
                            regulations being now more strictly adhered to than in 1915,<note n="1" xml:id="d525fn1">See <ref target="frus1915Supp#pg_711">
                                    <hi rend="italic">Foreign Relations</hi>, 1915, Supplement, p.
                                    711</ref>.</note> message will not be forwarded.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>