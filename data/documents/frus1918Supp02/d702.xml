                <note rend="inline" type="source">File No. 891.48/45</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Persia</hi> (<persName corresp="#p_CJL1" type="to">
                        <hi rend="italic">Caldwell</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-05-10T18:00:00-04:00">
                            <hi rend="italic">May 10, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>53. Report situation of Jews throughout all Persia.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
