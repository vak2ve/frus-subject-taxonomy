<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-03-18T23:59:59-05:00" frus:doc-dateTime-min="1918-03-18T00:00:00-05:00" n="637" subtype="historical-document" type="document" xml:id="d637">
                        <note rend="inline" type="source">File No. 860c.48/12a</note>
                        <head>
                            <hi rend="italic">The Assistant to the Third Assistant Secretary of
                                State</hi> (<persName type="from"><hi rend="italic">Ruddock</hi></persName>) <hi rend="italic">to <persName type="to">John B. Denvir, jr.</persName>, of the Bureau of Enenmy Trade,
                                War Trade Board</hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-03-18">
                                    <hi rend="italic">March 18, 1918</hi>.</date>
                            </dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Dear Mr. <persName>Denvir</persName></hi>:
                            Confirming our telephone conversation of this morning, I beg to state
                            that the President has authorized the transmission of the following
                            relief remittances:</p>
                        <p rend="center">
                            <hi rend="smallcaps">Poland, and Turkey not under British
                                Occupation</hi>
                        </p>
                        <table cols="6" rows="5">
                            <row>
                                <cell>Poland</cell>
                                <cell role="num">$300,000</cell>
                                <cell>per month,</cell>
                                <cell>of which</cell>
                                <cell role="num">$200,000</cell>
                                <cell>general relief</cell>
                            </row>
                            <row>
                                <cell/>
                                <cell/>
                                <cell/>
                                <cell/>
                                <cell role="num">100,000</cell>
                                <cell>individual</cell>
                            </row>
                            <row>
                                <cell>Turkey</cell>
                                <cell role="num">$150,000</cell>
                                <cell>per month</cell>
                                <cell/>
                                <cell/>
                                <cell/>
                            </row>
                            <row>
                                <cell cols="3">which may be properly divided into</cell>
                                <cell/>
                                <cell role="num">$100,000</cell>
                                <cell>general relief</cell>
                            </row>
                            <row>
                                <cell/>
                                <cell/>
                                <cell/>
                                <cell/>
                                <cell role="num">50,000</cell>
                                <cell>individual</cell>
                            </row>
                        </table>
                        <p>I should be happy to receive from you, if convenient, a statement of the
                            proposed allotments.</p>
                        <p>Very sincerely yours,</p>
                        <closer>
                            <signed>
                                <persName>
                                    <hi rend="smallcaps">A. B. Ruddock</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>