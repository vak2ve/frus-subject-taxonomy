    <text>
        <body>
            <div frus:doc-dateTime-max="1917-12-31T12:00:00-05:00"
                frus:doc-dateTime-min="1917-12-31T12:00:00-05:00" n="26"
                subtype="historical-document" type="document" xml:id="d26">
                <note rend="inline" type="source">File No. 763.72114/3147</note>
                <head>
                    <hi rend="italic">The Chargé in Switzerland</hi> (<persName corresp="#p_WHR1"
                        type="from">
                        <hi rend="italic">Wilson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berne</hi>
                        </placeName>, <date calendar="gregorian" when="1917-12-31T18:00:00+01:00">
                            <hi rend="italic">December 31, 1917, 6 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received January 2, 1918, 11.45
                        p.m.</hi>]</dateline>
                </opener>
                <p>Department’s 1143, November 21. Swiss Post Office notifies Legation Germany has
                    assented to proposal for transmission to Germany through France and Switzerland
                    of individual parcels up to 5 kilograms for prisoners. Service can start
                    immediately as Switzerland has notified French Post Office and completed local
                    arrangements.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WHR1">
                            <hi rend="smallcaps">Wilson</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
