<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-05-10T14:00:00-05:00" frus:doc-dateTime-min="1918-05-10T14:00:00-05:00" n="863" subtype="historical-document" type="document" xml:id="d863">
                    <note rend="inline" type="source">File No. 811.203/21</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                    <opener>
                        <seg rendition="#center">[Telegram]</seg>
                    </opener>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-05-10T15:00:00-04:00">
                                <hi rend="italic">May 10, 1918, 3 p.m.</hi>
                            </date>
                        </dateline>
                    </opener>
                    <p>7668. Your 9101, March 18, 11 p.m. You may inform British Government
                        regulations set forth in your telegram are acceptable to this
                        Government.</p>
                    <closer>
                        <signed>
                            <persName corresp="#p_LR1">
                                <hi rend="smallcaps">Lansing</hi>
                            </persName>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>