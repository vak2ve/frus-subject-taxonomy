    <text>
        <body>
            <div frus:doc-dateTime-max="1917-11-22T23:59:59-05:00"
                frus:doc-dateTime-min="1917-11-22T00:00:00-05:00" n="281"
                subtype="historical-document" type="document" xml:id="d281">
                <note rend="inline" type="source">File No. 763.72113/405</note>
                <head>
                    <hi rend="italic">The Minister in the Netherlands</hi> (<persName
                        corresp="#p_GJW1" type="from">
                        <hi rend="italic">Garrett</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Hague</hi>
                        </placeName>, <date calendar="gregorian" when="1917-11-22">
                            <hi rend="italic">November 22, 1917</hi>
                        </date>. <lb/> [<hi rend="italic">Received 7.37 p.m.</hi>]</dateline>
                </opener>
                <p>1672. <hi rend="italic">Reichsofnzeiger</hi> announces that provisions relative
                    to compulsory registration of enemy property in Germany have been made
                    applicable to United States commencing with November 30.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GJW1">
                            <hi rend="smallcaps">Garrett</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
