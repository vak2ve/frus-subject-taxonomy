                subtype="historical-document" type="document" xml:id="d101">
                <note rend="inline" type="source">File No. 763.72114/3635a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Spain</hi> (<persName corresp="#p_WJE1" type="to">
                        <hi rend="italic">Willard</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-05-15T16:00:00-04:00">
                            <hi rend="italic">May 15, 1918, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1126. Bequest Spanish Government to inquire whether German Government will be
                    disposed to nominate delegates to hold a conference at Berne at an early date
                    with American delegates for the purpose of concluding a reciprocal agreement
                    covering matters pertaining to the maintenance, treatment, and exchange of
                    prisoners of war, similar to conferences already held with representatives of
                    British and French Governments, the American delegates to be announced and a
                    date chosen after acceptance by German Government of this proposal.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
