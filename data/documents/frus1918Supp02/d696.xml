                subtype="historical-document" type="document" xml:id="d696">
                <note rend="inline" type="source">File No. 891.48/30</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Persia</hi> (<persName corresp="#p_CJL1" type="to">
                        <hi rend="italic">Caldwell</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-01-10T18:00:00-05:00">
                            <hi rend="italic">January 10, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>23. Your December 10, 9 a.m. If American Red Cross undertakes to furnish relief
                    for famine how could relief supplies best be purchased and distributed?</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
