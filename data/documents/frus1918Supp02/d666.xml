                subtype="historical-document" type="document" xml:id="d666">
                <note rend="inline" type="source">File No. 867.48/576</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Turkey</hi> (<persName corresp="#p_EAI1" type="to">
                        <hi rend="italic">Elkus</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-03T17:00:00-05:00">
                            <hi rend="italic">April 3, 1917, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3481. Your 2563, March 23. Spanish Government has offered to furnish ship to
                    transport relief supplies from New York and Alexandria to Syria, and also
                    medical supplies to Palestine. Department has accepted offer with thanks and
                    inquired whether this ship will be available to remove Americans from Syria and
                    Palestine.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
