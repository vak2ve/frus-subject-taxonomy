<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-07-12T18:00:00-05:00" frus:doc-dateTime-min="1918-07-12T18:00:00-05:00" n="726" subtype="historical-document" type="document" xml:id="d726">
                        <note rend="inline" type="source">File No. 860d.48/98a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Minister in Sweden</hi> (<persName corresp="#p_MIN1" type="to"><hi rend="italic">Morris</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-07-12T19:00:00-04:00">
                                    <hi rend="italic">July 12, 1918, 7 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>936. Inform Finnish representatives that Doctor <persName corresp="#p_IK1">Ignatius</persName>, Food Commissioner of the
                            Finnish Senate, has engaged passage and will sail from New York for
                            Scandinavia the first week in August to return home unless instructed
                            otherwise.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_PFL1">
                                    <hi rend="smallcaps">Polk</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>