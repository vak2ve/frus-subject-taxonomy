<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-10-22T15:00:00-05:00" frus:doc-dateTime-min="1918-10-22T15:00:00-05:00" n="417" subtype="historical-document" type="document" xml:id="d417">
                            <note rend="inline" type="source">File No. No. 763.72113/664</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in Guatemala</hi> (<persName corresp="#p_LWH1" type="to"><hi rend="italic">Leavell</hi></persName>)<note n="2" xml:id="d417fn2">The same, <hi rend="italic">mutatis
                                        mutandis</hi>, on the same date, to the Minister in Honduras
                                    and the Minister in Nicaragua. (File Nos.
                                    763.72113/684.704.)</note>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-10-22T16:00:00-04:00">
                                        <hi rend="italic">October 22, 1918, 4 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Your August 2, 4 p.m.<note n="3" xml:id="d417fn3">Not printed.</note>
                                Department at request of War Trade Board has designated
                                    <persName>Edward</persName> to act as special agent for the
                                Department of State to give advice in connection with the management
                                of alien property administration in Guatemala, Honduras, and
                                Nicaragua. Mr. <persName>Ames</persName> will leave for Guatemala
                                toward the end of the month.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                    </body></text></TEI>