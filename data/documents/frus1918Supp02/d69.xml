    <text>
        <body>
            <div frus:doc-dateTime-max="1918-02-23T17:00:00-05:00"
                frus:doc-dateTime-min="1918-02-23T17:00:00-05:00" n="69"
                subtype="historical-document" type="document" xml:id="d69">
                <note rend="inline" type="source">File No. 763.72114/3315</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Switzerland</hi> (<persName corresp="#p_WHR1" type="to">
                        <hi rend="italic">Wilson</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-02-23T17:00:00-05:00">
                            <hi rend="italic">February 23, 1918, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1488. Your 2672, February 19, 10 a.m.<note n="2" xml:id="d69fn2">Not
                        printed.</note> Swiss Legation, Washington, has not received despatch of
                    German Government regarding <pb facs="0125" n="41" xml:id="pg_41"/> pay of
                    officers. Please telegraph summary of important points of this despatch
                    immediately.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
