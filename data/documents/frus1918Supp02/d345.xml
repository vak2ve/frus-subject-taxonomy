<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-07-25T13:00:00-05:00" frus:doc-dateTime-min="1917-07-25T13:00:00-05:00" n="345" subtype="historical-document" type="document" xml:id="d345">
                        <note rend="inline" type="source">File No. 811.54262/137</note>
                        <head>
                            <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_SWG1" type="from"><hi rend="italic">Sharp</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1917-07-25T19:00:00+01:00">
                                    <hi rend="italic">July 25, 1917, 7 p.m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received July 27, 8.53
                                a.m.</hi>]</dateline>
                        </opener>
                        <p>2326. Your 2361, June 16.<note n="1" xml:id="d345fn1">See footnote 1, <hi rend="italic">ante</hi>, <ref target="#pg_321">p.
                                321</ref>.</note> Have today received verbal assurances from Foreign
                            Office that remittances for patent rights will be permitted to pass
                            without detention by the censors.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_SWG1">
                                    <hi rend="smallcaps">Sharp</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>