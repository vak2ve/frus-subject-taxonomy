<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-10-24T01:00:00-05:00" frus:doc-dateTime-min="1917-10-24T01:00:00-05:00" n="510" subtype="historical-document" type="document" xml:id="d510">
                        <note rend="inline" type="source">File No. 763.72112/5228</note>
                        <head>
                            <hi rend="italic">The Minister in China</hi> (<persName corresp="#p_RPS1" type="from"><hi rend="italic">Reinsch</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1917-10-24T14:00:00+08:00">
                                    <hi rend="italic">October 24, 1917, 2 p.m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received October 24, 12
                                noon.</hi>]</dateline>
                        </opener>
                        <p>Does United States enemy trading legislation apply to transactions with
                            Germans and Austrians resident in China?</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_RPS1">
                                    <hi rend="smallcaps">Reinsch</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>