                subtype="historical-document" type="document" xml:id="d110">
                <note rend="inline" type="source">File No. 763.72114/3750</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Switzerland</hi> (<persName corresp="#p_SPA1" type="to">
                        <hi rend="italic">Stovall</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-07-01T14:00:00-04:00">
                            <hi rend="italic">July 1, 1918, 2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>2211. Your 3786, June 26, 8 p.m. Request Spanish Ambassador, Berlin, to inform
                    German Government that this Government will await a definite proposal from the
                    German Government of a date for the prisoner-of-war conference and hopes that it
                    may be arranged as soon as possible.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
