<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-06-26T15:00:00-05:00" frus:doc-dateTime-min="1918-06-26T15:00:00-05:00" n="403" subtype="historical-document" type="document" xml:id="d403">
                            <note rend="inline" type="source">File No. No. 814.01B</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in Guatemala</hi> (<persName corresp="#p_LWH1" type="to"><hi rend="italic">Leavell</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-06-26T16:00:00-04:00">
                                        <hi rend="italic">June 26, 1918, 4 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Your June 24, 11 a.m. Yes. If Government of Guatemala has decided to
                                appoint such an official, Department would see no objection to
                                    <persName>Hodgsdon</persName>.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>