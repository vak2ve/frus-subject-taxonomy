    <text>
        <body>
            <div frus:doc-dateTime-max="1917-01-08T05:00:00-05:00"
                frus:doc-dateTime-min="1917-01-08T05:00:00-05:00" n="656"
                subtype="historical-document" type="document" xml:id="d656">
                <note rend="inline" type="source">File No. 867.48/517</note>
                <head>
                    <hi rend="italic">The Ambassador in Turkey</hi> (<persName corresp="#p_EAI1"
                        type="from">
                        <hi rend="italic">Elkus</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Constantinople</hi>
                        </placeName>, <date calendar="gregorian" when="1917-01-08T12:00:00+02:00">
                            <hi rend="italic">January 8, 1917, noon</hi>
                        </date>. <lb/> [<hi rend="italic">Received January 10, 8
                        a.m.</hi>]</dateline>
                </opener>
                <p>2387. <persName corresp="#p_DP2">Djemal Pasha</persName>
                    <note n="1" xml:id="d656fn1">Turkish Minister of Marine.</note> requests that
                    three-fourths of <hi rend="italic">
                        <persName>Caesar</persName>’s</hi> supplies be landed at Beirut for
                    distribution to Palestine poor and one-fourth at Jaffa.<note n="2"
                        xml:id="d656fn2">See Department’s circular telegram of Dec. 19, 1916, <ref
                            target="frus1916Supp#pg_940">
                            <hi rend="italic">Foreign Relations</hi>, 1916, Supplement, p.
                        940</ref>.</note> Does Department approve?</p>
                <closer>
                    <signed>
                        <persName corresp="#p_EAI1">
                            <hi rend="smallcaps">Elkus</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
