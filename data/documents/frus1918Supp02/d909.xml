<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-05-17T23:59:59-05:00" frus:doc-dateTime-min="1918-05-17T00:00:00-05:00" n="909" subtype="historical-document" type="document" xml:id="d909">
                        <note rend="inline" type="source">File No. 763.72116/557</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Switzerland</hi> (<persName corresp="#p_SPA1" type="to"><hi rend="italic">Stovall</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-05-17">
                                    <hi rend="italic">May 17, 1918</hi></date>.</dateline>
                        </opener>
                        <p>1926. Your 3275, May 7, 4 p.m. You may present note to President of
                            International Red Cross suggested by French Ambassador as outlined in
                            your 3072, April 13, 3 p.m., regarding use of asphyxiating and poisonous
                            gases in warfare.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>