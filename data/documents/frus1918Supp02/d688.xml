<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-04-15T16:00:00-05:00" frus:doc-dateTime-min="1918-04-15T16:00:00-05:00" n="688" subtype="historical-document" type="document" xml:id="d688">
                        <note rend="inline" type="source">File No. 867.48/740</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Sweden</hi> (<persName corresp="#p_MIN1" type="to"><hi rend="italic">Morris</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-04-15T17:00:00-04:00">
                                    <hi rend="italic">April 15, 1918, 5 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>708. Your 1452<note n="1" xml:id="d688fn1">Not printed.</note> and 1635.
                            Plan for forwarding gold from Sweden to Constantinople definitely
                            disapproved. Cancel check for $50,000.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>