<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-02-15T16:00:00-05:00" frus:doc-dateTime-min="1917-02-15T16:00:00-05:00" n="658" subtype="historical-document" type="document" xml:id="d658">
                        <note rend="inline" type="source">File No. 867.48/542</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Turkey</hi> (<persName corresp="#p_EAI1" type="to"><hi rend="italic">Elkus</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-02-15T16:00:00-05:00">
                                    <hi rend="italic">February 15, 1917, 4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>3352. Your 2457.<note n="4" xml:id="d658fn4">Not printed.</note> Prior to
                            severing diplomatic relations with Germany, Department had desired
                            consent of Turkish Government <pb facs="0623" n="539" xml:id="pg_539"/>
                            for <persName>
                                <hi rend="italic">Caesar</hi>
                            </persName> to enter Mersine. Both <hi rend="italic">Des Moines</hi> and <persName>
                                <hi rend="italic">Caesar</hi></persName>, however, have been ordered
                            to remain Alexandria until further notice.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>