<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-10-31T18:00:00-05:00" frus:doc-dateTime-min="1917-10-31T18:00:00-05:00" n="278" subtype="historical-document" type="document" xml:id="d278">
                        <note rend="inline" type="source">File No. 371.11/207</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in Switzerland</hi> (<persName corresp="#p_WHR1" type="to"><hi rend="italic">Wilson</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-10-31T18:00:00-05:00">
                                    <hi rend="italic">October 31, 1917, 6 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>1076. For Berlin:</p>
                        <p>It has been reported to this Government that the German Government
                            intends shortly to auction American oil properties in Roumania. Please
                            use your utmost endeavors to ascertain immediately if this report is
                            correct, and reply by telegraph.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>