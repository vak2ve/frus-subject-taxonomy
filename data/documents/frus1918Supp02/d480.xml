    <text>
        <body>
            <div frus:doc-dateTime-max="1917-06-01T15:00:00-05:00"
                frus:doc-dateTime-min="1917-06-01T15:00:00-05:00" n="480"
                subtype="historical-document" type="document" xml:id="d480">
                <note rend="inline" type="source">File No. No. 862.20222/21</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Panama</hi> (<persName corresp="#p_PWJ1" type="to">
                        <hi rend="italic">Price</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-06-01T15:00:00-05:00">
                            <hi rend="italic">June 1, 1917, 3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your April 13, 2 p.m.<note n="1" xml:id="d480fn1">Not printed.</note> All
                    trading, directly, indirectly, with, for or on behalf of, or for benefit of
                    persons in Germany should be prevented, <pb facs="0503" n="419" xml:id="pg_419"
                    /> and ships engaged in it should be penalized or held or controlled by refusal
                    of necessary supplies. The proposed enemy trading act and exports control act,
                    it is expected, will give United States authority to do this in United States
                    ports.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
