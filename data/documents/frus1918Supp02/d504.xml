    <text>
        <body>
            <div frus:doc-dateTime-max="1917-04-13T22:00:00-05:00"
                frus:doc-dateTime-min="1917-04-13T22:00:00-05:00" n="504"
                subtype="historical-document" type="document" xml:id="d504">
                <note rend="inline" type="source">File No. No. 763.72112/3494</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName corresp="#p_RPS1"
                        type="from">
                        <hi rend="italic">Reinsch</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1917-04-14T11:00:00+08:00">
                            <hi rend="italic">April 14, 1917, 11 a.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received April 6.30 a.m.</hi>]</dateline>
                </opener>
                <p>I beg to request instructions as to the permissibility of commercial relations
                    [between] Americans and Germans in China.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_RPS1">
                            <hi rend="smallcaps">Reinsch</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
