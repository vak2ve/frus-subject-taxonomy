<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-12-29T17:00:00-05:00" frus:doc-dateTime-min="1917-12-29T17:00:00-05:00" n="423" subtype="historical-document" type="document" xml:id="d423">
                            <note rend="inline" type="source">File No. No. 763.72112Aml/10</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in Honduras</hi> (<persName corresp="#p_EJ1" type="to"><hi rend="italic">Ewing</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-12-29T17:00:00-05:00">
                                        <hi rend="italic">December 29, 1917, 5 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Department informed that port of Amapala closed. Report immediately
                                by cable and give all details regard to excelling, of
                                    <persName>Kohncke</persName> as agents Pacific Mail referred to
                                in your December 28, noon.<note n="1" xml:id="d423fn1">Not
                                    printed.</note>
                            </p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>