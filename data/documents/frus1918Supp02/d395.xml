    <text>
        <body>
            <div frus:doc-dateTime-max="1918-09-20T11:29:00-05:00"
                frus:doc-dateTime-min="1918-09-20T11:29:00-05:00" n="395"
                subtype="historical-document" type="document" xml:id="d395">
                <note rend="inline" type="source">File No. No. 763.72113/692</note>
                <head>
                    <hi rend="italic">The Minister in Cuba</hi> (<persName corresp="#p_GWE1"
                        type="from">
                        <hi rend="italic">Gonzales</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1918-09-20T11:00:00-05:29">
                            <hi rend="italic">September 20, 1918, 11 a.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 2.45 p.m.</hi>]</dateline>
                </opener>
                <p>Doctor <persName>Sánchez de Bustamante</persName>, the eminent lawyer, has taken
                    charge of office as custodian of enemy property.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GWE1">
                            <hi rend="smallcaps">Gonzales</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
