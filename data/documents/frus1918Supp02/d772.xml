    <text>
        <body>
            <div frus:doc-dateTime-max="1918-11-08T18:00:00-05:00"
                frus:doc-dateTime-min="1918-11-08T18:00:00-05:00" n="772"
                subtype="historical-document" type="document" xml:id="d772">
                <note rend="inline" type="source">File No. 763.72114/4139</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Special Agent in Corfu</hi> (<persName corresp="#p_DHP2" type="to">
                        <hi rend="italic">Dodge</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-08T18:00:00-05:00">
                            <hi rend="italic">November 8, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your October 31, 4 p.m.<note n="1" xml:id="d772fn1">Not printed.</note>
                    Department assumes the request for additional assistance for Serbian prisoners
                    of war, referred to in second paragraph of your October 5, 10 a.m., may be
                    disregarded in view of capitulation of Austria-Hungary and Bulgaria.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
