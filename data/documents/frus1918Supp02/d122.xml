<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-09-17T23:59:59-05:00" frus:doc-dateTime-min="1918-09-17T00:00:00-05:00" n="122" subtype="historical-document" type="document" xml:id="d122">
                        <note rend="inline" type="source">File No. 763.72114A/168</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in France</hi> (<persName corresp="#p_SWG1" type="to"><hi rend="italic">Sharp</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-09-17">
                                    <hi rend="italic">September 17, 1918</hi></date>.</dateline>
                        </opener>
                        <p>5642. For <persName corresp="#p_GJW1">Garrett</persName>:</p>
                        <p>Your 3, September 13. Your attitude is cordially approved.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>