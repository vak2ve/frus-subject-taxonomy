                    <term ref="recSaEMkYGbM62K53" type="topic" category="foreign-economic-policy" subcategory="energy-and-natural-resources" subject="oil" lcsh-uri="http://id.loc.gov/authorities/subjects/sh85064698" lcsh-match="lcsh_rejected">Oil</term>
                </keywords>
