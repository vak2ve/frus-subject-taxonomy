<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-12-20T18:00:00-05:00" frus:doc-dateTime-min="1945-12-20T18:00:00-05:00" n="913" subtype="historical-document" type="document" xml:id="d913">
                        <note rend="inline" type="source">124.61/10–1245: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Ambassador in the Soviet Union</hi>
                                (<persName type="to"><hi rend="italic">Harriman</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1945-12-20T18:00:00-05:00">December
                                    20, 1945—6 p.m.</date>
                            </dateline>
                        </opener>
                        <p>2592. ReDeptel 2133, Oct. 12, 1945. It is understood that progress is
                            being made in case of Mrs. Kemp Tolley. Please do anything possible to
                            expedite her departure as soon as she receives permission to leave the
                            Soviet Union.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Acheson</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>