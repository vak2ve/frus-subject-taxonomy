    <text>
        <body>
            <div frus:doc-dateTime-max="1865-05-22T23:59:59-05:00"
                frus:doc-dateTime-min="1865-05-22T00:00:00-05:00" n="232"
                subtype="historical-document" type="document" xml:id="d232">
                <head>
                    <persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                        Adams</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 1417.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-05-22">
                            <hi rend="italic">May</hi> 22, 1865</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Your despatch of the 21st ultimo, No. 933,
                    expressive of your sympathy with the Secretary of State upon the occasion of the
                    accident which befel him on the 5th of last month, has been received.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>W. HUNTER, <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic"
                            >&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
