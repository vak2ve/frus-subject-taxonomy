<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-04-10T23:59:59-05:00" frus:doc-dateTime-min="1865-04-10T00:00:00-05:00" n="166" subtype="historical-document" type="document" xml:id="d166">
                        <head><persName type="from">Mr. F. W. Seward</persName> to <persName type="to">Mr. Adams</persName></head>
                        <opener>
                            <seg rendition="#left">No. 1346.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1865-04-10"><hi rend="italic">April</hi> 10, 1865</date>.</dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> Your despatch No. 903, of the 23d ultimo,
                            together with its accompanying copies of a correspondence between
                            yourself and Lord Russell upon the subject of the discontinuance of the
                            reciprocity treaty, has been received, and is approved.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>F.W.SEWARD, <hi rend="italic">Acting
                            Secretary.</hi></signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>