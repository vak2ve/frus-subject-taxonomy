<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-05-05T23:59:59-05:00" frus:doc-dateTime-min="1865-05-05T00:00:00-05:00" n="206" subtype="historical-document" type="document" xml:id="d206">
                        <head><persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                                Adams</persName></head>
                        <opener>
                            <seg rendition="#left">No. 1392.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1865-05-05"><hi rend="italic">May</hi> 5, 1865</date>.</dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> I have to acknowledge the receipt of your
                            despatch of the 20th April, No. 932, transmitting a copy of a letter
                            from the United States consul at Teneriffe, concerning the arrival of
                            the Stonewall at that place on the 31st of March last, and her departure
                            therefrom on the day following.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>W. HUNTER, <hi rend="italic">Acting
                            Secretary.</hi></signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>