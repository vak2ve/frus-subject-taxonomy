    <text>
        <body>
            <div frus:doc-dateTime-max="1865-06-03T23:59:59-05:00" frus:doc-dateTime-min="1865-06-03T00:00:00-05:00" n="253" subtype="historical-document" type="document" xml:id="d253">
                <head>
                    <persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                                Adams</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 1437.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-06-03">
                            <hi rend="italic">June</hi> 3, 1865</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have received your despatch of the 18th
                            ultimo, No. 956, transmitting from various parts of the kingdom of Great
                            Britain a large number of addresses and resolutions which have been
                            called forth by the late deplorable events, together with an appended
                            list of the same.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>W. HUNTER, <hi rend="italic">Acting
                            Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
