<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-06-27T23:59:59-05:00" frus:doc-dateTime-min="1865-06-27T00:00:00-05:00" n="274" subtype="historical-document" type="document" xml:id="d274">
                        <head><persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                                Adams</persName></head>
                        <opener>
                            <seg rendition="#left">No. 1467.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1865-06-27"><hi rend="italic">June</hi> 27, 1865</date>.</dateline></opener>
                        <p><hi rend="smallcaps">Sir:</hi> I Have to acknowledge the receipt of your
                            despatch of the 8th of June, No. 983, transmitting a copy of the London
                            Gazette of the 6th instant, containing Earl Russell’s note to the lords
                            commissioners of the admiralty, announcing the withdrawal of the
                            recognition by her Majesty’s government of belligerent rights to the
                            rebels.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>W. HUNTER, <hi rend="italic">Acting
                            Secretary.</hi></signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>