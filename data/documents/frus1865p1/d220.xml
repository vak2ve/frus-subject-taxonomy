    <text>
        <body>
            <div frus:doc-dateTime-max="1865-05-15T23:59:59-05:00" frus:doc-dateTime-min="1865-05-15T00:00:00-05:00" n="220" subtype="historical-document" type="document" xml:id="d220">
                <head>
                    <persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                                Adams</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 1403.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-05-15">
                            <hi rend="italic">May</hi> 15, 1865</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have to acknowledge the receipt of your
                            despatch of the 28th ultimo, No. 938, transmitting a copy of a note from
                            Earl Russell which he addressed to you, giving the result of an
                            investigation made at Bermuda on the character of certain steamers which
                            had arrived there.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>W. HUNTER, <hi rend="italic">Acting
                            Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
