    <text>
        <body>
            <div frus:doc-dateTime-max="1865-10-31T23:59:59-05:00"
                frus:doc-dateTime-min="1865-10-31T00:00:00-05:00" n="362"
                subtype="historical-document" type="document" xml:id="d362">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Adams</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 1573.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-10-31">
                            <hi rend="italic">October</hi> 31, 1865</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Your despatch of the 12th instant, No. 1064, with
                    the accompanying copies of your correspondence with Earl Russell upon the
                    subject of our claims against Great Britain, and the Morning Post of the 11th,
                    have been received.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Charles Francis Adams</hi>, Esq., <hi rend="italic"
                            >&amp;c.,&amp;c.,&amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
