    <text>
        <body>
            <div frus:doc-dateTime-max="1865-04-17T23:59:59-05:00" frus:doc-dateTime-min="1865-04-17T00:00:00-05:00" n="178" subtype="historical-document" type="document" xml:id="d178">
                <head>
                    <persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                                Adams</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-04-17">
                            <hi rend="italic">April</hi> 17, 1865</date>.</dateline>
                </opener>
                <p>It is hereby ordered that, in honor to the memory of our late illustrious
                            Chief Magistrate, all officers and others subject to the orders of the
                            Secretary of State wear crape upon the left arm for the period of six
                            months.</p>
                <closer>
                    <signed>W. HUNTER, <hi rend="italic">Acting
                            Secretary.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>(Same, <hi rend="italic">mutatis mutandis,</hi> to all our ministers
                                and consuls abroad.)</p>
                </postscript>
            </div>
        </body>
    </text>
