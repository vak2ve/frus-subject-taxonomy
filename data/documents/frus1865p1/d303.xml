    <text>
        <body>
            <div frus:doc-dateTime-max="1865-08-05T23:59:59-05:00" frus:doc-dateTime-min="1865-08-05T00:00:00-05:00" n="303" subtype="historical-document" type="document" xml:id="d303">
                <head>
                    <persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                                Adams</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 1503.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-08-05">
                            <hi rend="italic">August</hi> 5, 1865</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> Your despatch of the 21st of July, No.
                            1019, enclosing a resolution of condolence on the assassination of the
                            late President, adopted by the Northern Presbytery of Antrim, at a
                            meeting held on the 6th ultimo, has been received.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>W. HUNTER, <hi rend="italic">Acting
                            Secretary,</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Charles Francis Adams,</hi> Esq.,<hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
