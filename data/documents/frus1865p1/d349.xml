<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1865-10-03T23:59:59-05:00" frus:doc-dateTime-min="1865-10-03T00:00:00-05:00" n="349" subtype="historical-document" type="document" xml:id="d349">
                        <head><persName type="from">Mr. Hunter</persName> to <persName type="to">Mr.
                                Adams</persName></head>
                        <opener>
                            <seg rendition="#left">No. 1559.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1865-10-03"><hi rend="italic">October</hi> 3, 1865</date>.</dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: Your despatch of the 21st ultimo, No.
                            1051, enclosing a copy of Lord Russell’s note, relative to the slave
                            trade in Cuba, has been received.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>W. HUNTER, <hi rend="italic">Acting
                            Secretary</hi>.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Charles Francis Adams</hi>, Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>