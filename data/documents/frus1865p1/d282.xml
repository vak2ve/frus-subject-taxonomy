    <text>
        <body>
            <div frus:doc-dateTime-max="1865-07-13T23:59:59-05:00" frus:doc-dateTime-min="1865-07-13T00:00:00-05:00" n="282" subtype="historical-document" type="document" xml:id="d282">
                <head>
                    <persName type="from">Mr. Adams</persName> to <persName type="to">Mr.
                                Hunter</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 1010.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States,</hi>
                            <hi rend="italic">London,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-07-13">
                            <hi rend="italic">
                                        July</hi> 13, 1865</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to transmit further
                            resolutions of condolence—one from, the Annual Association of
                            Independent Ministers of the counties of Carmarthen, Cardigan, and
                            Pembroke; the other from the representatives of the General Baptist
                            churches of England, and also an address from the Freedmen’s Aid Society
                            of London.</p>
                <p>I have the honor to be, sir, your obedient servant,</p>
                <closer>
                    <signed>CHARLES FRANCIS ADAMS.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">William Hunter,</hi> Esq., <hi rend="italic">Acting Secretary of State, Washington, D. C.</hi>
                    </p>
                    <p>[For enclosures see Appendix, separate volume.]</p>
                </postscript>
            </div>
        </body>
    </text>
