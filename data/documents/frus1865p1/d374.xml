    <text>
        <body>
            <div frus:doc-dateTime-max="1865-11-15T23:59:59-05:00" frus:doc-dateTime-min="1865-11-15T00:00:00-05:00" n="374" subtype="historical-document" type="document" xml:id="d374">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 1589.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic"> Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1865-11-15">
                            <hi rend="italic">November</hi> 15, 1865</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir;</hi> Your despatch of the 25th of May last, No.
                            966, together with its accompanying copy of a note addressed to you by
                            Earl Russell, relative to the steamer Tallahassee, has been
                            received.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Charles Francis Adams</hi>, Esq<hi rend="italic">, <hi rend="italic">&amp;c.,&amp;c.,&amp;c.</hi>
                        </hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
