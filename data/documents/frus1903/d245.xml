                subtype="historical-document" type="document" xml:id="d245">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Loomis</persName> to Mr. <persName
                            type="to">Ehrman</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1903-11-10">
                            <hi rend="italic">November 10, 1903</hi>
                        </date>. (Sent 3.42 p.m.)</dateline>
                </opener>
                <p>Keep in touch with commander of United States naval forces at Panama, advising
                    him concerning news bearing on military situation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Loomis.</hi>
                    </signed>
                </closer>
            </div>
        </body>
