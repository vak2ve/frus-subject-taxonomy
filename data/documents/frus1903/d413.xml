                subtype="historical-document" type="document" xml:id="d413">
                <head>
                    <hi rend="italic">
                        <persName type="from">Freiherr von dem Btissehe-Haddenhausen</persName> to
                        Mr. <persName type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Imperial German Embassy</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1903-04-04">
                            <hi rend="italic">April 4, 1903</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Hay</hi>: The German, British, and Italian
                    Governments, having agreed on the terms of a protocol to be signed by the
                    representatives of those three powers, of Venezuela, and of the other powers
                    interested about the submission of the question of preferential or separate
                    treatment of the blockading powers to The Hague tribunal, I have the honor to
                    submit to your excellency the draft of the said protocol.<note n="a"
                        xml:id="d413fna">See Protocol, <ref target="#pg_439">page 439</ref>.</note>
                </p>
                <p>Believe me, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bussche.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
