                subtype="historical-document" type="document" xml:id="d251">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Loomis</persName> to Mr. <persName
                            type="to">Malmros</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1903-11-03">
                            <hi rend="italic">November 3, 1903</hi>
                        </date>. (Sent 8.45 p.m.)</dateline>
                </opener>
                <p>The troops which landed from the <hi rend="italic">Cartagena</hi> should not
                    proceed to Panama.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Loomis.</hi>
                    </signed>
                </closer>
            </div>
        </body>
