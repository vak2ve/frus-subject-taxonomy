                subtype="historical-document" type="document" xml:id="d163">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Loomis</persName> to Mr. <persName
                            type="to">Beaupré</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1903-08-13">
                            <hi rend="italic">August 13, 1903</hi>
                        </date>.</dateline>
                </opener>
                <p>Have you received Department cable of July 31? Amendments suggested in your cable
                    of the 5th would be fatal to treaty.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Loomis.</hi>
                    </signed>
                </closer>
            </div>
        </body>
