    <text>
        <body>
            <div frus:doc-dateTime-max="1903-11-06T23:59:59-05:00"
                frus:doc-dateTime-min="1903-11-06T00:00:00-05:00" n="241"
                subtype="historical-document" type="document" xml:id="d241">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Ehrman</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Panama</hi>
                        </placeName>, <date calendar="gregorian" when="1903-11-06">
                            <hi rend="italic">November 6, 1903</hi>.</date>
                        <lb/>(Received 7.23 p.m.)</dateline>
                </opener>
                <p>Felipe Bunau-Varilla has been appointed envoy extraordinary and minister
                    plenipotentiary to the United States of America. Perfect quiet.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Ehrman</hi>.</signed>
                </closer>
            </div>
        </body>
