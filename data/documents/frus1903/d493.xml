                subtype="historical-document" type="document" xml:id="d493">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Choate</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1903-04-30">
                            <hi rend="italic">April 30, 1903</hi>
                        </date>.</dateline>
                </opener>
                <p>By agreement of both parties the cases are to be delivered here and in London
                    to-morrow, so as to catch Saturday’s steamer.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
