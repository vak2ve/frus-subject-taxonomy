    <text>
        <body>
            <div frus:doc-dateTime-max="1903-11-05T23:59:59-05:00"
                frus:doc-dateTime-min="1903-11-05T00:00:00-05:00" n="261"
                subtype="historical-document" type="document" xml:id="d261">
                <head>[Telegram.—Translation.]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Panama</hi>
                        </placeName>, <date calendar="gregorian" when="1903-11-05">
                            <hi rend="italic">November 5, 1903</hi>.</date>
                        <lb/>(Received 8.48 p.m.)</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Secretary of State</hi>, <hi rend="italic">Washington:</hi>
                </p>
                <p>We notify you that we have appointed Señor Philippe Bunau-Varilla confidential
                    agent of the Republic of Panama near your Government and Dr. Francisco V. de la
                    Espriella minister of foreign affairs.</p>
                <closer>
                    <signed>
                        <list>
                            <item>
                                <hi rend="smallcaps">Arango.</hi>
                            </item>
                            <item>
                                <hi rend="smallcaps">Boyd.</hi>
                            </item>
                            <item>
                                <hi rend="smallcaps">Arias.</hi>
                            </item>
                        </list>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
