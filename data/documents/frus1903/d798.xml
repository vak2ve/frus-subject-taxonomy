<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1902-12-10T23:59:59-05:00" frus:doc-dateTime-min="1902-12-10T00:00:00-05:00" n="798" subtype="historical-document" type="document" xml:id="d798">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Bowen</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1902-12-10"><hi rend="italic">December 10,
                                    1902</hi></date>.</dateline></opener>
                        <p>(Mr. Hay states that if Venezuela proposes arbitration and Great Britain
                            and Germany acquiesce, Mr. Bowen may act as an arbitrator on the part of
                            Venezuela.)</p>
                    </div>
                    </body></text></TEI>