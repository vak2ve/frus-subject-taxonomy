                subtype="historical-document" type="document" xml:id="d817">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Bowen</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Caracas</hi>
                        </placeName>, <date calendar="gregorian" when="1902-12-16">
                            <hi rend="italic">December 16, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Bowen reports that he has been requested by the Italian minister, who will
                    leave Caracas on December 17, to take charge of Italian interests.)</p>
            </div>
