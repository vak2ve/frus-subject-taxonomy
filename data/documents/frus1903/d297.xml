                <head>[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Colon</hi>
                        </placeName>, <date calendar="gregorian" when="1903-11-05T21:41:00-05:19">
                            <hi rend="italic">November 5, 1903—9.41 p.m</hi>
                        </date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Secretary of the Navy</hi>, <hi rend="italic">Washington,
                        D. C.:</hi>
                </p>
                <p>British man-of-war <hi rend="italic">Amphion</hi> is protecting American
                    interests at Panama. Reported bombardment much exaggerated.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hubbard.</hi>
                    </signed>
                </closer>
            </div>
