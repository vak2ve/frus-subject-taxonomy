    <text>
        <body>
            <div frus:doc-dateTime-max="1903-11-16T23:59:59-05:00"
                frus:doc-dateTime-min="1903-11-16T00:00:00-05:00" n="645"
                subtype="historical-document" type="document" xml:id="d645">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Clayton</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Embassy of the United States</hi>,<lb/>
                            <hi rend="italic">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1903-11-16">
                            <hi rend="italic">November 16, 1903</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Clayton reports that the requisition for the extradition of Kratz has been
                    made by him, and that the promises expressed therein as required by Mexican law
                    are satisfactory to the Mexican Government.)</p>
            </div>
        </body>
