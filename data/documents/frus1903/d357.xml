    <text>
        <body>
            <div frus:doc-dateTime-max="1903-11-05T23:59:59-05:00"
                frus:doc-dateTime-min="1903-11-05T00:00:00-05:00" n="357"
                subtype="historical-document" type="document" xml:id="d357">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Powell</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Santo Domingo City</hi>
                        </placeName>, <date calendar="gregorian" when="1903-11-05">
                            <hi rend="italic">November 5, 1903</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 641, Santo Domingo Series.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform the Department that
                    the United States naval vessel <hi rend="italic">Baltimore</hi>, Commander
                    Briggs, arrived here this morning at 7 o’clock, and left for Samana Bay to
                    convoy the steamship <hi rend="italic">Cherokee</hi>, and if she has left will
                    proceed to Puerto Plata.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. F. Powell.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
