    <text>
        <body>
            <div frus:doc-dateTime-max="1903-08-07T23:59:59-05:00"
                frus:doc-dateTime-min="1903-08-07T00:00:00-05:00" n="533"
                subtype="historical-document" type="document" xml:id="d533">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Choate</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1903-08-07">
                            <hi rend="italic">August 7, 1903</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 53.]</seg>
                </opener>
                <p>Referring to your telegram of the 5th [4th] August, it is agreed that tribunal
                    shall meet on September 3.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Choate.</hi>
                    </signed>
                </closer>
            </div>
        </body>
