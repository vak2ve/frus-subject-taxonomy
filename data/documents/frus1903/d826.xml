                subtype="historical-document" type="document" xml:id="d826">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Bowen</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-12-23">
                            <hi rend="italic">December 23, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Hay states that the formal request of the powers that the President of the
                    United States act as arbitrator has not yet been received, and that Mr. Bowen
                    will be advised when it is received.)</p>
            </div>
        </body>
