                <head>[Translation.]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Panama</hi>
                        </placeName>, <date calendar="gregorian" when="1903-11-07T19:40:00-05:19">
                            <hi rend="italic">November 7, 1903, 7.40 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Secretary of the Navy</hi>, <hi rend="italic">Washington,
                        D. C.:</hi>
                </p>
                <p>All quiet; traffic undisturbed; message to prevent received.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Diehl.</hi>
                    </signed>
                </closer>
