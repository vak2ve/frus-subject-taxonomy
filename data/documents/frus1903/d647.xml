                <head>
                    <hi rend="italic">Mr. <persName type="from">McCreery</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Embassy of the United States</hi>,<lb/>
                            <hi rend="italic">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1903-12-26">
                            <hi rend="italic">December 26, 1903</hi>
                        </date>.</dateline>
                </opener>
                <p>Note just received from foreign office stating President has granted extradition
                    Kratz.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">McCreery.</hi>
                    </signed>
                </closer>
            </div>
        </body>
