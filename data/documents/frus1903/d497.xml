<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1903-05-21T23:59:59-05:00" frus:doc-dateTime-min="1903-05-21T00:00:00-05:00" n="497" subtype="historical-document" type="document" xml:id="d497">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Choate</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1903-05-21"><hi rend="italic">May 21,
                                1903</hi></date>.</dateline></opener>
                        <p>We will waive formalties of the treaty as to production of papers, but
                            should have early notice of those desired.</p>
                        <closer><signed><hi rend="smallcaps">Hay.</hi></signed></closer>
                    </div>
                    </body></text></TEI>