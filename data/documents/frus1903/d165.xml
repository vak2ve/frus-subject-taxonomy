                <head>
                    <hi rend="italic">Mr. <persName type="from">Loomis</persName> to Mr. <persName
                            type="to">Beaupré</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>
                        </placeName>,<lb/>
                        <date calendar="gregorian" when="1903-08-15">
                            <hi rend="italic">August 15, 1903</hi>.</date>
                    </dateline>
                </opener>
                <p>Cable additional information concerning rejection of treaty as soon as
                    possible.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Loomis.</hi>
                    </signed>
                </closer>
            </div>
