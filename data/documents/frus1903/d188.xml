<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1903-09-22T23:59:59-05:00" frus:doc-dateTime-min="1903-09-22T00:00:00-05:00" n="188" subtype="historical-document" type="document" xml:id="d188">
                        <head><hi rend="italic">Mr. <persName type="from">Beaupré</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">United
                                        States Legation</hi>,<lb/><hi rend="italic">Bogotá</hi></placeName>, <date calendar="gregorian" when="1903-09-22"><hi rend="italic">September 22,
                                    1903</hi></date>. (Received 1.36 p.m., 23.)</dateline></opener>
                        <p>September 22, 5 p.m. The proposed law concerning the canal treaty has not
                            been discussed since the first reading. No new developments.</p>
                        <closer><signed><hi rend="smallcaps">Beaupré.</hi></signed></closer>
                    </div>
                    </body></text></TEI>