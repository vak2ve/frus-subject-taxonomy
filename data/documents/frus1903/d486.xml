                subtype="historical-document" type="document" xml:id="d486">
                <head>
                    <hi rend="italic">Sir <persName type="from">M. H. Herbert</persName> to Mr.
                            <persName type="to">Loomis.</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">British Embassy</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1903-03-19">
                            <hi rend="italic">March 19, 1903</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 59.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In accordance with instructions which I have
                    received from the Marquis of Lansdowne, I have the honor to inform you that the
                    lord chief justice of England, His Honor Sir Louis Aimable Jetté, K.C.M.G.,
                    retired judge of the supreme court of Quebec, and the Hon. John Douglas Armour,
                    judge of the supreme court of Canada, have been selected as the British members
                    of the Alaska boundary tribunal.</p>
                <p>I have the honor to be, with highest consideration, sir,</p>
                <p>Your most obedient humble servant,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Michael H. Herbert.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
