<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1903-11-03T23:59:59-05:00" frus:doc-dateTime-min="1903-11-03T00:00:00-05:00" n="227" subtype="historical-document" type="document" xml:id="d227">
                            <head>[Telegram.]</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1903-11-03"><hi rend="italic">November 3,
                                        1903</hi></date>. (Sent 3.40 p.m.)</dateline></opener>
                            <p>Uprising on Isthmus reported. Keep Department promptly and fully
                                informed.</p>
                            <closer><signed><hi rend="smallcaps">Loomis.</hi></signed></closer>
                        </div>
                        </body></text></TEI>