                <head>[Translation.]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington, D. C.,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1903-11-06">
                            <hi rend="italic">November 6, 1903</hi>.</date>
                    </dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Maine</hi>, <hi rend="italic">Woods Hole, Mass.:</hi>
                </p>
                <p>Proceed at once to Colon, coaling wherever necessary to expedite your arrival.
                    Acknowledge.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Moody.</hi>
                    </signed>
                </closer>
            </div>
        </body>
