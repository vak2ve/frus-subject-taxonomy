    <text>
        <body>
            <div frus:doc-dateTime-max="1903-06-28T23:59:59-05:00"
                frus:doc-dateTime-min="1903-06-28T00:00:00-05:00" n="515"
                subtype="historical-document" type="document" xml:id="d515">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Raikes</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Personal.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">British Embassy</hi>,<lb/>
                            <hi rend="italic">Newport, R. I.</hi>
                        </placeName>, <date calendar="gregorian" when="1903-06-28">
                            <hi rend="italic">June 28, 1903</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Secretary</hi>: I beg to acknowledge the receipt
                    of your note of the 26th instant inclosing a memorandum relative to the
                    application of His Majesty’s Government for an extension of time for the
                    presentation of the British counter case before the Alaskan Boundary
                    Tribunal.</p>
                <p>I am, dear Mr. Secretary, yours, very truly,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Arthur S. Raikes.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
