                subtype="historical-document" type="document" xml:id="d679">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">McCormick,</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1903-10-22">
                            <hi rend="italic">October 22, 1903</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 56.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: To enable the Department to answer several
                    inquiries it has received I shall be pleased if you will ascertain whether
                    Jewish divorces granted by Jewish rabbis are recognized by Russian law. If such
                    a law is in force a translation of its text is desired.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
