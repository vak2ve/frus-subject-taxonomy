                subtype="historical-document" type="document" xml:id="d17">
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to Prince
                            <persName type="to">Ferdinand</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">White House</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1903-09-21">
                            <hi rend="italic">September 21, 1903</hi>
                        </date>.</dateline>
                </opener>
                <p>I cordially appreciate the friendly message of Your Royal Highness and share your
                    good wishes.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
