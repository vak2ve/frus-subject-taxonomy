                subtype="historical-document" type="document" xml:id="d73">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Conger</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1903-08-03">
                            <hi rend="italic">August 3, 1903</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Conger reports that he held a conference on August 3 with the Prince on the
                    subject of Mr. Hay’s telegram of July 26. The Prince promises to reply very
                    soon.)</p>
            </div>
