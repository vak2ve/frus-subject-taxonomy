                <head>[Translation.]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Colon</hi>
                        </placeName>, <date calendar="gregorian" when="1903-11-05">
                            <hi rend="italic">November 5</hi>.</date>
                    </dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Secretary of the Navy</hi>, <hi rend="italic">Washington,
                        D. C.:</hi>
                </p>
                <p>Atlas Line’s steamer, with large body of troops, reported sailing from Cartagena,
                    Colombia.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hubbard.</hi>
                    </signed>
                </closer>
            </div>
