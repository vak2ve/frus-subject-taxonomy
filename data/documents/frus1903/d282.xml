                subtype="historical-document" type="document" xml:id="d282">
                <head>[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Navy Department</hi>,<lb/>
                            <hi rend="italic">Washington, D. C.</hi>
                        </placeName>, <date calendar="gregorian" when="1903-11-03">
                            <hi rend="italic">November 3, 1903</hi>
                        </date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Cruiser Atlanta</hi>, <hi rend="italic">Kingston,
                        Jamaica:</hi>
                </p>
                <p>Proceed with all possible dispatch to Colon. Acknowledge immediately. When will
                    you sail?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Darling</hi>, <hi rend="italic">Acting.</hi>
                    </signed>
                </closer>
            </div>
        </body>
