                subtype="historical-document" type="document" xml:id="d287">
                <head>[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Navy Department</hi>,<lb/>
                            <hi rend="italic">Washington, D. C.</hi>
                        </placeName>, <date calendar="gregorian" when="1903-11-05">
                            <hi rend="italic">November 5, 1903</hi>.</date>
                    </dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Nashville</hi>, <hi rend="italic">Colon:</hi>
                </p>
                <p>Prevent any armed force of either side from landing at Colon, Porto Bello, or
                    vicinity.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Moody.</hi>
                    </signed>
                </closer>
            </div>
        </body>
