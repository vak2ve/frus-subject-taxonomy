<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1903-11-05T23:59:59-05:00" frus:doc-dateTime-min="1903-11-05T00:00:00-05:00" n="237" subtype="historical-document" type="document" xml:id="d237">
                            <head><hi rend="italic">Mr. <persName type="from">Ehrman</persName> to
                                    Mr. <persName type="to">Hay</persName>.</hi></head>
                            <opener><seg rendition="#center">[Telegram.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Panama</hi></placeName>, <date calendar="gregorian" when="1903-11-05"><hi rend="italic">November 5,
                                        1903</hi>.</date><lb/>(Received 9.42
                                p.m.)</dateline></opener>
                            <p>Colombian troops reembarked per Royal Mail for Carthagena. <hi rend="italic">Bogotá</hi> supposed at Buenaventura. Quiet
                                prevails.</p>
                            <closer><signed><hi rend="smallcaps">Ehrman.</hi></signed></closer>
                        </div>
                        </body></text></TEI>