<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1903-11-03T23:59:59-05:00" frus:doc-dateTime-min="1903-11-03T00:00:00-05:00" n="228" subtype="historical-document" type="document" xml:id="d228">
                            <head><hi rend="italic">Mr. <persName type="from">Ehrman</persName> to
                                    Mr. <persName type="to">Hay</persName>.</hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Panama</hi></placeName>, <date calendar="gregorian" when="1903-11-03"><hi rend="italic">November 3,
                                        1903</hi>.</date><lb/>(Received 8.15
                                p.m.)</dateline></opener>
                            <p>No uprising yet. Reported will be in the night. Situation is
                                critical.</p>
                            <closer><signed><hi rend="smallcaps">Ehrman.</hi></signed></closer>
                        </div>
                        </body></text></TEI>