                subtype="historical-document" type="document" xml:id="d718">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Leishman</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1903-03-05">
                            <hi rend="italic">March 5, 1903</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Hay directs Mr. Leishman to express to the Sultan, when granted an audience,
                    the President’s gratification at the issuance of iradé in regard to Beirut
                    examinations.)</p>
            </div>
