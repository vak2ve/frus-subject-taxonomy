<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1903-10-30T23:59:59-05:00" frus:doc-dateTime-min="1903-10-30T00:00:00-05:00" n="209" subtype="historical-document" type="document" xml:id="d209">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Beaupré</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1903-10-30"><hi rend="italic">October 30,
                                1903</hi></date>.</dateline></opener>
                        <p>You may avail yourself of leave of absence under authorization cabled to
                            you July 9.</p>
                        <closer><signed><hi rend="smallcaps">Hay.</hi></signed></closer>
                    </div>
                    </body></text></TEI>