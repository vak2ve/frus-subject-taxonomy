<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1903-03-18T23:59:59-05:00" frus:doc-dateTime-min="1903-03-18T00:00:00-05:00" n="106" subtype="historical-document" type="document" xml:id="d106">
                        <head><hi rend="italic">Mr. <persName type="from">Loomis</persName> to Mr.
                                    <persName type="to">Beaupré</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1903-03-18"><hi rend="italic">March 18,
                                1903</hi></date>.</dateline></opener>
                        <p>Inform Colombian Government Senate yesterday approved canal convention
                            without amendment.</p>
                        <closer><signed><hi rend="smallcaps">Loomis</hi>, <hi rend="italic">Acting.</hi></signed></closer>
                    </div>
                    </body></text></TEI>