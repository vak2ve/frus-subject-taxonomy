                subtype="historical-document" type="document" xml:id="d494">
                <note rend="inline" type="source">893.515/1103a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at Shanghai</hi> (<persName type="to">
                        <hi rend="italic">Gauss</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1936-06-05T19:00:00-04:00"
                            >June 5, 1936—7 p.m.</date>
                    </dateline>
                </opener>
                <p>154. At request of Treasury Department, please report not later than morning of
                    June 8 information available at Shanghai in regard to the currency situation in
                    South China and the financial and monetary <pb facs="0582" n="487"
                        xml:id="pg_487"/> aspects of the recent conference held at Canton between
                    the Nanking delegation and Southwest leaders.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
