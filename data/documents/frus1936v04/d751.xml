                subtype="historical-document" type="document" xml:id="d751">
                <note rend="inline" type="source">894.00/584: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1936-02-29T18:00:00+09:00"
                            >February 29, 1936—6 p.m.</date>
                        <lb/>[Received February 29—7:19 a.m.]</dateline>
                </opener>
                <p>50. Excellent order has been maintained in Tokyo throughout the recent incident
                    and no injury or molestation to American citizens has been reported to the
                    Embassy except the inconveniences necessarily caused by the precautionary
                    measures of the authorities.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
