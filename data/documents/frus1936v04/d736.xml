                subtype="historical-document" type="document" xml:id="d736">
                <note rend="inline" type="source">894.00/570: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1936-02-26T23:00:00+09:00"
                            >February 26, 1936—11 p.m.</date>
                        <lb/>[Received February 26—2 p.m.]</dateline>
                </opener>
                <p>39. 1. The Tokyo <hi rend="italic">Nichi Nichi</hi> in an extra tonight states
                    that Home Minister Goto has been appointed as temporary acting Premier.</p>
                <p>2. The Embassy has learned from a reliable informant who talked with Count Makino
                    this evening that Makino was neither killed nor wounded.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
