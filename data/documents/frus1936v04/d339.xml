    <text>
        <body>
            <div frus:doc-dateTime-max="1936-10-15T23:59:59-05:00"
                frus:doc-dateTime-min="1936-10-15T00:00:00-05:00" n="339"
                subtype="historical-document" type="document" xml:id="d339">
                <note rend="inline" type="source">793.94/8346</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 778</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1936-10-15">October 15,
                            1936</date>.<lb/>[Received November 16.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to transmit herewith a copy of
                    despatch No. 66 of October 9, 1936, from the Consulate at Tsinan<note n="36"
                        xml:id="d339fn36">Not printed.</note> in which Consul Allison reports the
                    opinion of the Secretary of the German Embassy in Tokyo to the effect that Japan
                    is not ready to engage in war at this time for the following reasons: <list>
                        <label>1.</label>
                        <item>The economic and financial situation in Japan is extremely
                            serious.</item>
                        <label>2.</label>
                        <item>The Japanese Army is not in sufficiently good condition.</item>
                        <label>3.</label>
                        <item>Japan has no international agreements which would be of assistance in
                            case of war.</item>
                    </list>
                </p>
                <p>Respectfully yours,</p>
                <closer>For the Ambassador:<lb/>
                    <signed>
                        <hi rend="smallcaps">George R. Merrell, Jr.</hi>
                    </signed>
                    <lb/>
                    <hi rend="italic">First Secretary of Embassy</hi>
                </closer>
            </div>
        </body>
