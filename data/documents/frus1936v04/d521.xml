    <text>
        <body>
            <div frus:doc-dateTime-max="1936-03-10T20:00:00-05:00"
                frus:doc-dateTime-min="1936-03-10T20:00:00-05:00" n="521"
                subtype="historical-document" type="document" xml:id="d521">
                <note rend="inline" type="source">893.00/13394: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peiping</hi>
                        </placeName>, <date calendar="gregorian" when="1936-03-11T09:00:00+08:00"
                            >March 11, 1936—9 a.m.</date>
                        <lb/>[Received March 10—11:50 p.m.]</dateline>
                </opener>
                <p>124. Following from American Consul General at Hankow.</p>
                <quote rend="blockquote">
                    <p>“March 10, 6 p.m. My March 7, 1 p.m. Situation in vicinity Hwangshihkong has
                        cleared and <hi rend="italic">Tutuila</hi> returned Hankow today.”</p>
                </quote>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
