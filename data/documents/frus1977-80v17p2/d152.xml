                <head>152. Summary of Conclusions of a Special Coordination Committee Meeting<note
                        n="1" type="source" xml:id="d152fn1">Source: Carter Library, National
                        Security Affairs, Staff Material, Office, Box 33, INT documents:
                        4300s–4400s, 7–8/78. Secret. The meeting took place in the White House
                        Situation Room.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1978-07-13T17:00:00-04:00">July 13, 1978, 5 p.m.</date>
                    </dateline>
                </opener>
                <list type="subject">
                    <head>SUBJECT</head>
                    <item>Security Assistance for Kenya</item>
                </list>
                <list type="participants">
                    <head>PARTICIPANTS</head>
                    <item>
                        <list>
                            <item>
                                <hi rend="italic">State</hi>
                            </item>
                            <item>Deputy Secretary of State <persName corresp="#p_CWM_1">Warren
                                    Christopher</persName>
                            </item>
                            <item>Lucy Benson, Under Secretary for Security Assistance, Science and
                                Technology</item>
                            <item>
                                <persName corresp="#p_HWC_1">William Harrop</persName>, Deputy
                                Assistant Secretary for Africa</item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <head>
                                <hi rend="italic">Defense</hi>
                            </head>
                            <item>
                                <persName corresp="#p_MDE_2">David McGiffert</persName>, Assistant
                                Secretary for International Security Affairs</item>
                            <item>Major General <persName corresp="#p_HJG_1">John G.
                                Hill</persName>, Survey Team Chief, Kenya</item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <head>
                                <hi rend="italic">
                                    <gloss target="#t_CIA_1">CIA</gloss>
                                </hi>
                            </head>
                            <item>William Parmenter, NIO, Africa</item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <head>
                                <hi rend="italic">
                                    <gloss target="#t_JCS_1">JCS</gloss>
                                </hi>
                            </head>
                            <item>Lt. General William Y. Smith, Assistant to the Chairman</item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <head>
                                <hi rend="italic">
                                    <gloss target="#t_ACDA_1">ACDA</gloss>
                                </hi>
                            </head>
                            <item>Dr. Barry Blechman, Assistant Director, Weapons Evaluation and
                                Control Bureau</item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <head>
                                <hi rend="italic">
                                    <gloss target="#t_OMB_1">OMB</gloss>
                                </hi>
                            </head>
