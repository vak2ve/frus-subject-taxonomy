    <text>
        <body>
            <div frus:doc-dateTime-max="1947-01-06T04:00:00-05:00"
                frus:doc-dateTime-min="1947-01-06T04:00:00-05:00" n="382"
                subtype="historical-document" type="document" xml:id="d382">
                <note rend="inline" type="source">693.0023/1–647: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Stuart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1947-01-06T17:00:00+08:00"
                            >January 6, 1947—5 p.m.</date>
                        <lb/> [Received January 6—6 a.m.]</dateline>
                </opener>
                <p>28. Note delivered Foreign Minister<note n="5" xml:id="d382fn1">Wang
                        Shih-chieh.</note> (reference Department’s telegram 1252, December 31<note
                        n="6" xml:id="d382fn2">
                        <ref target="frus1946v10#pg_1200">
                            <hi rend="italic">Foreign Relations</hi>, 1946, vol. <hi
                                rend="smallcaps">x</hi>, p. 1200</ref>.</note>) 5 p.m., Nanking time
                    January 6 with alteration suggested Department’s telegram 9, January 2.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stuart</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
