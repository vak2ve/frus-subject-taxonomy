<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1947-11-10T23:59:59-05:00" frus:doc-dateTime-min="1947-11-10T00:00:00-05:00" n="1037" subtype="historical-document" type="document" xml:id="d1037">
                    <note rend="inline" type="source">811.42793 SE/11–1047: Telegram</note>
                    <head>
                        <hi rend="italic">The Ambassador in China</hi> (<persName type="from"><hi rend="italic">Stuart</hi></persName>) <hi rend="italic">to the
                                <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Nanking</hi></placeName>, <date calendar="gregorian" when="1947-11-10">November 10,
                            1947</date>.<lb/>[Received November 10—3:39 p.m.]</dateline>
                    </opener>
                    <p>2225. Reference Embtel 2205, November 6.<note n="29" xml:id="d1037fn1">Not
                            printed (811.42793SE/11–647); it gave the text of a proposed Embassy
                            press release which was worded similarly to the one issued by the
                            Department on November 10, printed in Department of State <hi rend="italic">Bulletin</hi>, November 23, 1947, p. 1005.</note>
                        Fulbright Bill Agreement signed 4:30 p.m., November 10.<note n="30" xml:id="d1037fn2">For text, see Department of State Treaties and Other
                            International Acts Series No. 1687, or 61 Stat. (pt. 4) 3582.</note>
                    </p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Stuart</hi>
                        </signed>
                    </closer>
                </div>
            </body></text></TEI>