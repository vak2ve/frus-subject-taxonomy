                subtype="historical-document" type="document" xml:id="d65">
                <note rend="inline" type="source">893.00/3–1747: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Stuart</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1947-03-18T19:00:00-05:00"
                            >March 18, 1947—7 p.m.</date>
                    </dateline>
                </opener>
                <p>321. Before repeating Shanghai’s 659 Mar 17, 2 p.m. to Secretary Marshall Dept
                    would appreciate receiving your comments thereon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Acheson</hi>
                    </signed>
                </closer>
            </div>
        </body>
