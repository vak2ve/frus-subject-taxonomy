<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1947-04-17T13:00:00-05:00" frus:doc-dateTime-min="1947-04-17T13:00:00-05:00" n="768" subtype="historical-document" type="document" xml:id="d768">
                    <note rend="inline" type="source">893.00/4–1647: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss>
                            to the Ambassador in the Soviet Union</hi> (<persName type="to"><hi rend="italic">Smith</hi></persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1947-04-17T13:00:00-05:00">April 17,
                                1947—1 p.m.</date>
                        </dateline>
                    </opener>
                    <p>959. <hi rend="smallcaps">Moskco</hi> 65 For the Secretary. We will be guided
                        by <hi rend="smallcaps">Kosmos</hi> 43 as amended by <hi rend="smallcaps">Kosmos</hi> 47<note n="47" xml:id="d768fn1">
                            <hi rend="italic">Supra</hi>.</note> substance of which is being
                        repeated to Nanking.<note n="48" xml:id="d768fn2">Substance repeated in
                            Department’s telegram No. 441, April 17, 1 p.m.</note>
                    </p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Acheson</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>