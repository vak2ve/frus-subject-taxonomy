                subtype="historical-document" type="document" xml:id="d644">
                <note rend="inline" type="source">893.243/4–1147: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Stuart</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1947-04-11T18:00:00-05:00"
                            >April 11, 1947—6 p.m.</date>
                    </dateline>
                </opener>
                <p>427. Dept now perceives no objection to transfer (Embtel 790 Apr 11) small arms
                    and ammunition to Maritime Customs preventive service. Navy informed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Acheson</hi>
                    </signed>
                </closer>
            </div>
        </body>
