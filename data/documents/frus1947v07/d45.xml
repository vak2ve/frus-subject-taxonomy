<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Minister-Counselor of Embassy in China (
                        Butterworth
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1947v07</bibl><bibl type="frus-document-id">d45</bibl><bibl type="frus-document-number">45</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1947-02-28T20:00:00-05:00" notAfter="1947-02-28T20:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1947-02-28T20:00:00-05:00" frus:doc-dateTime-min="1947-02-28T20:00:00-05:00" n="45" subtype="historical-document" type="document" xml:id="d45">
                <note rend="inline" type="source">893.00/3–147: Telegram</note>
                <head>
                    <hi rend="italic">The Minister-Counselor of Embassy in China</hi> (<persName type="from">
                        <hi rend="italic">Butterworth</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1947-03-01T09:00:00+08:00">March 1, 1947—9 a.m.</date>
                        <lb/> [Received February 28—9:45 p.m.]</dateline>
                </opener>
                <p>403. I am confidentially and reliably informed that T. V. Soong<note n="83" xml:id="d45fn1">President of the Chinese Executive Yuan.</note> offered his
                    resignation to the Generalissimo<note n="84" xml:id="d45fn2">Chiang Kai-shek,
                        President of the National Government of the Republic of China.</note> last
                    evening and the latter accepted.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Butterworth</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
