<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1947-12-15T21:00:00-05:00" frus:doc-dateTime-min="1947-12-15T21:00:00-05:00" n="806" subtype="historical-document" type="document" xml:id="d806">
                    <note rend="inline" type="source">893.34/12–947: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss>
                            to the Ambassador in China</hi> (<persName type="to"><hi rend="italic">Stuart</hi></persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1947-12-15T21:00:00-05:00">December 15,
                                1947—9 p.m.</date>
                        </dateline>
                    </opener>
                    <p>1513. Neither Emb nor any member Emb staff should confirm in writing informal
                        and oral assurances (Urtel 2362, Dec 9) already supplied ChiGovt re supply
                        of Naval ammo.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Lovett</hi>
                        </signed>
                    </closer>
                </div>
            </body></text></TEI>