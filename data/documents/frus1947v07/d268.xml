<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1947-10-28T23:59:59-05:00" frus:doc-dateTime-min="1947-10-28T00:00:00-05:00" n="268" subtype="historical-document" type="document" xml:id="d268">
                        <note rend="inline" type="source">893.00/10–2847: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in China</hi> (<persName type="from"><hi rend="italic">Stuart</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Nanking</hi></placeName>, <date calendar="gregorian" when="1947-10-28">October 28,
                                1947</date>.<lb/>[Received October 28—8:12 a.m.]</dateline>
                        </opener>
                        <p>2157. Reference Embtel 2149, October 28. Shanghai afternoon papers report
                            Lo Lung-chi, Democratic League leader, hiding in American Embassy. These
                            reports have no foundation in fact.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Stuart</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>