<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1947-12-08T11:00:00-05:00" frus:doc-dateTime-min="1947-12-08T11:00:00-05:00" n="803" subtype="historical-document" type="document" xml:id="d803">
                    <note rend="inline" type="source">893.34/12–747: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss>
                            to the Ambassador in China</hi> (<persName type="to"><hi rend="italic">Stuart</hi></persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1947-12-08T11:00:00-05:00">December 8,
                                1947—11 a.m.</date>
                        </dateline>
                    </opener>
                    <p>1483. In light Urtel 2346 December 7 Navy agreeable to release text of
                        agreement and exchange of notes.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Lovett</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>