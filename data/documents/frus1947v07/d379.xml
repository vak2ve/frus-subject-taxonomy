            <div frus:doc-dateTime-max="1947-01-02T19:00:00-05:00" frus:doc-dateTime-min="1947-01-02T19:00:00-05:00" n="379" subtype="historical-document" type="document" xml:id="d379">
                <note rend="inline" type="source">693.0023/1–247: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the Soviet Union</hi> (<persName type="to">
                        <hi rend="italic">Smith</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1947-01-02T19:00:00-05:00">January 2, 1947—7 p.m.</date>
                    </dateline>
                </opener>
                <p>7. Concur (urtel 3 Jan 2) your proposal re Dairen note. Nanking informed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Byrnes</hi>
                    </signed>
                </closer>
            </div>
        </body>
