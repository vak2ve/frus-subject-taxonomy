<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Acting Secretary of State to
                        the Ambassador in China (
                        Stuart
                    )</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1947v07</bibl><bibl type="frus-document-id">d840</bibl><bibl type="frus-document-number">840</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1947-11-22T17:00:00-05:00" notAfter="1947-11-22T17:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1947-11-22T17:00:00-05:00" frus:doc-dateTime-min="1947-11-22T17:00:00-05:00" n="840" subtype="historical-document" type="document" xml:id="d840">
                <note rend="inline" type="source">893.6359/11–2247: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Stuart</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1947-11-22T17:00:00-05:00">November 22, 1947—5 p.m.</date>
                    </dateline>
                </opener>
                <p>1421. Revised draft submitted your telegram 2265<note n="20" xml:id="d840fn1">
                        <hi rend="italic">Supra</hi>.</note> now under consideration. Department and
                    AEC much appreciate work done by Embassy and Keiser in this matter.</p>
                <p>AEC believes that consideration of draft and any further steps in implementation
                    of it would be facilitated by Keiser’s presence here and his direct return
                    travel is therefore authorized as soon as practicable without waiting for the
                    Generalissimo’s reaction.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lovett</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
