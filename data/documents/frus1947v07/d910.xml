<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1947-05-13T16:00:00-05:00" frus:doc-dateTime-min="1947-05-13T16:00:00-05:00" n="910" subtype="historical-document" type="document" xml:id="d910">
                    <note rend="inline" type="source">102.1/5–1347: Telegram</note>
                    <head>
                        <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            Ambassador in China</hi> (<persName type="to"><hi rend="italic">Stuart</hi></persName>)</head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1947-05-13T17:00:00-04:00">May 13, 1947—5
                                p.m.</date>
                        </dateline>
                    </opener>
                    <p>571. For Adler from Treasury. Approve completion arrangements for purchase
                        yuan (reurtel 1022, May 11) at Hong Kong cross-rate as of date of purchase.
                        Navy concurs. [Treasury.]</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Marshall</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>