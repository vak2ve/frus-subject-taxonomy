<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1947-12-08T23:59:59-05:00" frus:doc-dateTime-min="1947-12-08T00:00:00-05:00" n="804" subtype="historical-document" type="document" xml:id="d804">
                    <note rend="inline" type="source">893.34/12–847: Telegram</note>
                    <head>
                        <hi rend="italic">The Ambassador in China</hi> (<persName type="from"><hi rend="italic">Stuart</hi></persName>) <hi rend="italic">to the
                                <gloss type="to">Secretary of State</gloss>
                        </hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Nanking</hi></placeName>, <date calendar="gregorian" when="1947-12-08">December 8,
                            1947</date>.<lb/>[Received December 8—7:32 p.m.]</dateline>
                    </opener>
                    <p>2350. Agreement concerning transfer naval vessels signed today, 4 p.m.<note n="79" xml:id="d804fn1">For text, see Department of State Treaties and
                            Other International Acts Series No. 1691, or 61 Stat. (pt. 4)
                            3618.</note>
                    </p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">Stuart</hi>
                        </signed>
                    </closer>
                </div>
                </body></text></TEI>