    <teiHeader><fileDesc><titleStmt><title>The Ambassador in China (
                        Stuart
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1947v07</bibl><bibl type="frus-document-id">d28</bibl><bibl type="frus-document-number">28</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1947-02-11T06:00:00-05:00" notAfter="1947-02-11T06:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1947-02-11T06:00:00-05:00" frus:doc-dateTime-min="1947-02-11T06:00:00-05:00" n="28" subtype="historical-document" type="document" xml:id="d28">
                <note rend="inline" type="source">893.00/2–1147: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Stuart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1947-02-11T19:00:00+08:00">February 11, 1947—7 p.m.</date>
                        <lb/> [Received—9:20 p.m.]</dateline>
                </opener>
                <p>250. The Government this afternoon notified Communist delegation in Nanking that
                    its presence is no longer desired here.<note n="61" xml:id="d28fn1">For
                        documentation on withdrawal of Chinese Communist representatives, see <ref target="frus1946v10#pg_705">
                            <hi rend="italic">Foreign Relations</hi>, 1946, vol. <hi rend="smallcaps">x</hi>, p. 705</ref> ff.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stuart</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
