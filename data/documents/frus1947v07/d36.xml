<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1947-02-21T21:00:00-05:00" frus:doc-dateTime-min="1947-02-21T21:00:00-05:00" n="36" subtype="historical-document" type="document" xml:id="d36">
                        <note rend="inline" type="source">893.00/2–2247: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in China</hi> (<persName type="from"><hi rend="italic">Stuart</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Nanking</hi></placeName>, <date calendar="gregorian" when="1947-02-22T10:00:00+08:00">February
                                    22, 1947—10 a.m.</date>
                                <lb/> [Received February 22—5:40 a.m.]</dateline>
                        </opener>
                        <p>339. Generalissimo informed me yesterday that reorganization of Govt
                            would be undertaken in closing days of this month.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Stuart</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>