                subtype="historical-document" type="document" xml:id="d800">
                <note rend="inline" type="source">893.34/12–547: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Stuart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1947-12-05T16:00:00+08:00"
                            >December 5, 1947—4 p.m.</date>
                        <lb/> [Received December 5—2:24 p.m.]</dateline>
                </opener>
                <p>2340. Re agreement for transfer naval vessels, Chinese concur in modifications
                    outlined paragraph 2 Deptel 1459, December 3.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stuart</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
