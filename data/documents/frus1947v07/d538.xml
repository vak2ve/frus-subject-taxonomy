        <body>
            <div frus:doc-dateTime-max="1947-07-12T02:00:00-05:00" frus:doc-dateTime-min="1947-07-12T02:00:00-05:00" n="538" subtype="historical-document" type="document" xml:id="d538">
                <note rend="inline" type="source">121.893/7–1247: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Stuart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1947-07-12T16:00:00+09:00">July 12, 1947—4 p.m.</date>
                        <lb/> [Received July 12—8:20 a.m.]</dateline>
                </opener>
                <p>1520. Message contained in Deptel 857, July 11, was conveyed afternoon July 12 to
                    Generalissimo who indicated his approval.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stuart</hi>
                    </signed>
                </closer>
            </div>
        </body>
