    <text>
        <body>
            <div frus:doc-dateTime-max="1948-03-26T13:00:00-05:00"
                frus:doc-dateTime-min="1948-03-26T13:00:00-05:00" n="126"
                subtype="historical-document" type="document" xml:id="d126">
                <note rend="inline" type="source">501.AA/3–2648: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Belgium</hi> (<persName type="from">
                        <hi rend="italic">Millard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Brussels</hi>
                        </placeName>, <date calendar="gregorian" when="1948-03-26T19:00:00+01:00"
                            >March 26, 1948—7 p. m.</date>
                    </dateline>
                </opener>
                <p>618. Loridan<note n="1" xml:id="d126fn1">Walter Loridan, Director-General of
                        Political Affairs, Belgian Ministry of Foreign Affairs.</note> confirms
                    instruction sent Belgian representative <gloss target="#t_UN1">UN</gloss> as he
                    recommended (reported Embassy’s telegram 596, March 24<note n="2"
                        xml:id="d126fn2">Not printed.</note>), i.e., for admission Italy,
                    Transjordan, and Finland and againt Bulgaria, Rumania, and Hungary.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Millard</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
