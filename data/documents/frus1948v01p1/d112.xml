    <teiHeader><fileDesc><titleStmt><title>The Ambassador in France (
                        Caffery
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1948v01p1</bibl><bibl type="frus-document-id">d112</bibl><bibl type="frus-document-number">112</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1948-03-15T15:00:00-05:00" notAfter="1948-03-15T15:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1948-03-15T15:00:00-05:00" frus:doc-dateTime-min="1948-03-15T15:00:00-05:00" n="112" subtype="historical-document" type="document" xml:id="d112">
                <note rend="inline" type="source">501.AA/3–1548: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Caffery</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                        <lb/>
                        <hi rend="smallcaps">us urgent</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1948-03-15T21:00:00+01:00">March 15, 1948—9 p. m.</date>
                    </dateline>
                </opener>
                <p>1371. Following are French Foreign Office responses to numbered questions
                    contained <gloss target="#t_Deptel1">Deptel</gloss> 791, March 12 regarding
                    Italian application <gloss target="#t_UN1">UN</gloss> membership: <list>
                        <label>1.</label>
                        <item>Yes.</item>
                        <label>2.</label>
                        <item>Yes.</item>
                        <label>3.</label>
                        <item>Subject will have to be given further study since in principle French
                            state they have always believed in largest possible number admissions.
                            On Finland they are “not unfavorable”.</item>
                        <label>4–A.</label>
                        <item>Yes,4–B Yes.</item>
                    </list>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caffery</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
