                subtype="historical-document" type="document" xml:id="d97">
                <note rend="inline" type="source">
                    <gloss target="#t_IO1">IO</gloss> Files: US(P)/A/143</note>
                <head>
                    <hi rend="italic">United States Delegation Position Paper</hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">confidential</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>,] <date calendar="gregorian" when="1948-10-07">October 7,
                            1948</date>.</dateline>
                </opener>
                <p rend="center">
                    <hi rend="smallcaps">United States Slate for the Security Council and the
                        Economic and Social Council</hi>
                </p>
                <p rend="center">
                    <hi rend="smallcaps">1. security council</hi>
                </p>
                <p>The United States Representative should vote for the following:</p>
                <list>
                    <label>
                        <hi rend="italic">a</hi>.</label>
                    <item>Norway</item>
                    <label>
                        <hi rend="italic">b</hi>.</label>
                    <item>Cuba</item>
                    <label>
                        <hi rend="italic">c</hi>.</label>
                    <item>Egypt (on the first ballot)</item>
                </list>
                <p rend="center">
                    <hi rend="smallcaps">2. economic and social council</hi>
                </p>
                <p>The United States Representative should vote for:</p>
                <list>
                    <label>
                        <hi rend="italic">a</hi>.</label>
                    <item>China</item>
                    <label>
                        <hi rend="italic">b</hi>.</label>
                    <item>France</item>
                    <label>
                        <hi rend="italic">c</hi>.</label>
                    <item>Chile</item>
                    <label>
                        <hi rend="italic">d</hi>.</label>
                    <item>Peru</item>
                    <label>
                        <hi rend="italic">e</hi>.</label>
                    <item>Belgium</item>
                    <label>
                        <hi rend="italic">f</hi>.</label>
                    <item>India</item>
                </list>
            </div>
        </body>
    </text>
