    <text>
        <body>
            <div frus:doc-dateTime-max="1963-08-16T23:59:59-05:00"
                frus:doc-dateTime-min="1963-08-16T00:00:00-05:00" n="114"
                subtype="historical-document" type="document" xml:id="d114">
                <head>114. Letter From President <persName corresp="#p_KJF2" type="from"
                        >Kennedy</persName> to Chairman <persName corresp="#p_KNS2" type="to"
                        >Khrushchev</persName>
                    <note n="0" type="source" xml:id="d114fn0">Source: Department of State,
                        Presidential Correspondence: Lot 66 D 204. No classification marking.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1963-08-16">August 16, 1963</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Chairman</hi>: I send you many thanks for your
                    generous message of sympathy.<note n="1" xml:id="d114fn1">See <ref
                            target="#d113">Document 113</ref>.</note> You were very kind to think of
                    us at this difficult time, and your message was a comfort to us.
                        Mrs.<persName>Kennedy</persName> and I are very grateful to you.</p>
                <p>Sincerely,</p>
                <closer>
                    <signed>
                        <persName corresp="#p_KJF2">
                            <hi rend="strong">John Kennedy</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
