<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Minister-Counselor of Embassy in China (
                        Clark
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1949v07p2</bibl><bibl type="frus-document-id">d354</bibl><bibl type="frus-document-number">354</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1949-07-26T20:00:00-05:00" notAfter="1949-07-26T20:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1949-07-26T20:00:00-05:00" frus:doc-dateTime-min="1949-07-26T20:00:00-05:00" n="354" subtype="historical-document" type="document" xml:id="d354">
                <note rend="inline" type="source">890.20/7–2749: Telegram</note>
                <head>
                    <hi rend="italic">The Minister-Counselor of Embassy in China</hi> (<persName type="from">
                        <hi rend="italic">Clark</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Canton</hi>
                        </placeName>, <date calendar="gregorian" when="1949-07-27T09:00:00+08:00">July 27, 1949—9 a. m.</date>
                    </dateline>
                </opener>
                <p>
                    <gloss target="#t_Cantel1">Cantel</gloss> 828. Foreign Office informs me
                    discussions regarding Far East pact still in most preliminary stages and
                    confined still to China, Philippines. I gather practically no progress is being
                    made.</p>
                <pb facs="0591" n="1177" xml:id="pg_1177"/>
                <p>Sent Department, repeated Nanking 554, Shanghai 464, Manila 24, Taipei 83, Seoul
                    9.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Clark</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
