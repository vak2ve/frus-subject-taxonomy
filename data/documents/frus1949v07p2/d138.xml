                <note rend="inline" type="source">893.01/9–1749</note>
                <head>
                    <hi rend="italic">Memorandum of Conversation, by the Secretary of State</hi>
                </head>
                <note rend="inline" type="source">Extract</note>
                <note n="1" xml:id="d138fn1">Other portions of this memorandum are printed in <ref
                        target="frus1949v09#pg_88">vol. <hi rend="smallcaps">ix</hi>, pp.
                        88</ref>–<ref target="frus1949v09#pg_91">91</ref>.</note>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1949-09-17">September 17,
                            1949</date>.</dateline>
                </opener>
                <p rend="flushleft">Subject: Conversations with Mr. Bevin and Mr. Schuman on Far
                    East</p>
                <table>
                    <row>
                        <cell>Participants:</cell>
                        <cell/>
                    </row>
                    <row>
                        <cell/>
                        <cell>Mr. Bevin</cell>
                    </row>
                    <row>
                        <cell/>
                        <cell>Mr. Barclay</cell>
                    </row>
                    <row>
                        <cell/>
                        <cell>Mr. Dening</cell>
                    </row>
                    <row>
                        <cell/>
                        <cell>Mr. Schuman</cell>
                    </row>
                    <row>
                        <cell/>
                        <cell>Ambassador Bonnet</cell>
                    </row>
