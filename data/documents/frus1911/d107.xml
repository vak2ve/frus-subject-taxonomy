    <text>
        <body>
            <div frus:doc-dateTime-max="1911-05-08T23:59:59-05:00"
                frus:doc-dateTime-min="1911-05-08T00:00:00-05:00" n="107"
                subtype="historical-document" type="document" xml:id="d107">
                <note rend="inline" type="source">File No. 611.3731/28.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">American Minister</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1911-05-08">
                            <hi rend="italic">May 8, 1911</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 305.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has received your No. 748 of the
                    14th ultimo [etc.].</p>
                <p>In reply you are referred to the third paragraph of the Department’s instruction
                    to you, No. 270, of March 21 last.<note n="2" xml:id="d107fn9">See article on
                        “Reciprocity treaty,” <ref target="#pg_94">p. 94</ref>.</note>
                </p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">P. C. Knox.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
