                subtype="historical-document" type="document" xml:id="d711">
                <note rend="inline" type="source">File No. 812.00/1619.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">American Ambassador</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1911-05-16">
                            <hi rend="italic">May 16, 1911</hi>.</date>
                    </dateline>
                    <seg rendition="#left">No. 344.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has received your No. 509, of the
                    29th ultimo, transmitting copies of two notes in which you requested the foreign
                    office to cause American citizens and property at Parral to be protected, with
                    one of which you inclosed a copy of a letter from the manager of the West
                    Mexican Mines (Ltd.).</p>
                <p>Your action in addressing these notes to the foreign office is approved by the
                    Department.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">P. C. Knox.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
