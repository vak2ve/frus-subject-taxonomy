    <text>
        <body>
            <div frus:doc-dateTime-max="1908-04-02T23:59:59-05:00"
                frus:doc-dateTime-min="1908-04-02T00:00:00-05:00" n="799"
                subtype="historical-document" type="document" xml:id="d799">
                <note rend="inline" type="source">File No. 8172/83.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Ambassador</gloss> to the
                            <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1908-04-02">
                            <hi rend="italic">April 2, 1908</hi>
                        </date>.</dateline>
                </opener>
                <p>Your telegram March 4 and instruction 421, March 5. This Government concedes all
                    asked.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Thompson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
