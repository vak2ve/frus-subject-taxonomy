    <text>
        <body>
            <div frus:doc-dateTime-max="1911-06-30T23:59:59-05:00"
                frus:doc-dateTime-min="1911-06-30T00:00:00-05:00" n="451"
                subtype="historical-document" type="document" xml:id="d451">
                <note rend="inline" type="source">File No. 882.51/217.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">German Ambassador</gloss> to the <gloss
                            type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Imperial German Embassy</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1911-06-30">
                            <hi rend="italic">June 30, 1911</hi>
                        </date>.</dateline>
                </opener>
                <p>Mr. <hi rend="smallcaps">Secretary of State</hi>: In reply to your note of the
                    29th instant, serial No. 470, I have the honor respectfully to say that I am
                    authorized by the Imperial Government to accept the amendments to the loan
                    agreement with Liberia as proposed in the aforesaid note.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">J. Bernstorff.</hi>
                    </signed>
                </closer>
            </div>
        </body>
