                subtype="historical-document" type="document" xml:id="d412">
                <note rend="inline" type="source">File No. 11675/59a.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Italian Ambassador</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1910-01-29">
                            <hi rend="italic">January 29, 1910</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Ambassador</hi>: I beg to inclose for your
                    information and use three copies of Senate Document No. 321, Sixty-first
                    Congress, second session, containing the request made to Congress for provision
                    that will enable this Government to participate in the two international
                    expositions to be held at Rome and Turin next year.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">P. C. Knox.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
