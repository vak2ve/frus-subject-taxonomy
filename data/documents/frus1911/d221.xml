<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1911-11-20T23:59:59-05:00" frus:doc-dateTime-min="1911-11-20T00:00:00-05:00" n="221" subtype="historical-document" type="document" xml:id="d221">
                        <note rend="inline" type="source">File No. 839.001/3.</note>
                        <head><hi rend="italic">The <gloss type="from">President of the United
                                    States</gloss> to Madame <persName type="to">Caceres</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">The
                                        White House</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1911-11-20"><hi rend="italic">November 20,
                                    1911</hi></date>.</dateline></opener>
                        <p>Please accept my heartfelt sympathies in your great affliction.</p>
                        <closer><signed><hi rend="smallcaps">Wm H. Taft.</hi></signed></closer>
                    </div>
                    </body></text></TEI>