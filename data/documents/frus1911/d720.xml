                subtype="historical-document" type="document" xml:id="d720">
                <note rend="inline" type="source">File No. 812.00/1879.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Mexican Ambassador</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1911-05-20">
                            <hi rend="italic">May 20, 1911</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Ambassador</hi>: Referring to your request<note
                        n="1" xml:id="d720fn1">Oral.</note> of this morning I hasten to inform you
                    that the soldiers detained by our military authorities at San Diego are now all
                    to be released under orders already issued by the War Department.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">P. C. Knox.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
