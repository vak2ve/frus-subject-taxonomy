                <head>[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1911-08-01">
                            <hi rend="italic">August 1, 1911</hi>
                        </date>.</dateline>
                </opener>
                <p>A complete reconciliation between Diaz and Mena took place in my presence
                    to-day.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gunther.</hi>
                    </signed>
                </closer>
            </div>
