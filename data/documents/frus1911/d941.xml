                subtype="historical-document" type="document" xml:id="d941">
                <note rend="inline" type="source">File No. 817.00/1556.</note>
                <head>[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>
                        </placeName>, <date calendar="gregorian" when="1911-04-21">
                            <hi rend="italic">April 21, 1911</hi>.</date>
                    </dateline>
                    <seg rendition="#left">No. 16.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has received and has read with
                    attention your No. 21 of the 27th ultimo in relation to political conditions in
                    Nicaragua. In this connection you are referred to the department’s telegram of
                    April 8 expressive of its views regarding the situation.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Huntington Wilson.</hi>
                    </signed>
                </closer>
            </div>
        </body>
