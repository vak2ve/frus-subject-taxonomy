                subtype="historical-document" type="document" xml:id="d1029">
                <note rend="inline" type="source">File No. 892.001/65.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the <gloss type="to">American Minister to Siam</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1911-10-25">
                            <hi rend="italic">October 25, 1911</hi>
                        </date>.</dateline>
                </opener>
                <p>Letter accrediting you as President’s special representative at coronation mailed
                    to-day.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Adee.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
