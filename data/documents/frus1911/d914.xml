                <note rend="inline" type="source">File No. 417.00/65.</note>
                <head>[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1911-08-07">
                            <hi rend="italic">August 7, 1911</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 101.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inclose herewith a
                    confirmation copy of the mixed commission amendatory decree in the form in which
                    President Diaz is willing to approve it.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">F. M. Gunther.</hi>
                    </signed>
                </closer>
            </div>
        </body>
