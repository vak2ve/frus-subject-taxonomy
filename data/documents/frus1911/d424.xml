                subtype="historical-document" type="document" xml:id="d424">
                <note rend="inline" type="source">File No. 895.52/1a.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">American Ambassador</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington, D. C.</hi>
                        </placeName>, <date calendar="gregorian" when="1911-01-23">
                            <hi rend="italic">January 23, 1911</hi>
                        </date>.</dateline>
                </opener>
                <p>Have you made progress in the matter of property rights of foreigners in
                    Korea?</p>
            </div>
