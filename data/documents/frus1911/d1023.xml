                subtype="historical-document" type="document" xml:id="d1023">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">American Minister to Siam</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1911-02-28">
                            <hi rend="italic">February 28, 1911</hi>
                        </date>.</dateline>
                </opener>
                <p>You will attend ceremonies connected with the cremation of late Chulalongkorn as
                    the special representative of the President. I have so cabled minister for
                    foreign affairs.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Knox.</hi>
                    </signed>
                </closer>
            </div>
        </body>
