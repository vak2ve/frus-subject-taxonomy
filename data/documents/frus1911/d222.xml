                subtype="historical-document" type="document" xml:id="d222">
                <note rend="inline" type="source">File No. 839.001/3.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">American Chargé d’Affaires</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1911-11-20T13:00:00-05:00">
                            <hi rend="italic">November 20, 1911—1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Appropriately express to the foreign office the sincere sympathy of the
                    Government of the United States for the Dominican people on account of the
                    calamity which has befallen them. Report fully by cable.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Knox.</hi>
                    </signed>
                </closer>
            </div>
        </body>
