                subtype="historical-document" type="document" xml:id="d400">
                <note rend="inline" type="source">File No. 815.00/1326.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Chargé d’Affaires</gloss> to
                        the <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>,<lb/>
                            <hi rend="italic">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1911-07-25">
                            <hi rend="italic">July 25, 1911</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 211.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to report that the period of
                    martial law, extended by presidential decree on May 19, was to-day declared
                    terminated by public proclamation as of date of July 20.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">J. Butler Wright.</hi>
                    </signed>
                </closer>
            </div>
        </body>
