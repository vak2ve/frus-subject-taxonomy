                subtype="historical-document" type="document" xml:id="d440">
                <note rend="inline" type="source">File No. 882.51/178.</note>
                <head>
                    <hi rend="italic">The <gloss type="from">American Minister to Liberia</gloss> to
                        the <gloss type="to">Secretary of State</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1911-01-27">
                            <hi rend="italic">January 27, 1911</hi>
                        </date>.</dateline>
                </opener>
                <p>The Kanre-Lahun boundary agreement has been ratified by the senate.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Crum.</hi>
                    </signed>
                </closer>
            </div>
        </body>
