<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1911-11-17T23:59:59-05:00" frus:doc-dateTime-min="1911-11-17T00:00:00-05:00" n="1031" subtype="historical-document" type="document" xml:id="d1031">
                        <note rend="inline" type="source">File No. 892.001/77a.</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">American Minister to Siam</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1911-11-17"><hi rend="italic">November 17,
                                    1911</hi></date>.</dateline></opener>
                        <p>You are accredited as special representative of the President at
                            coronation. This gives rank of ambassador extraordinary and
                            plenipotentiary.</p>
                        <closer><signed><hi rend="smallcaps">Knox.</hi></signed></closer>
                    </div>
                    </body></text></TEI>