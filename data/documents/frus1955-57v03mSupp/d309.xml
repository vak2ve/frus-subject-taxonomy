            <div frus:doc-dateTime-max="1955-10-24T23:59:59-05:00"
                frus:doc-dateTime-min="1955-10-24T00:00:00-05:00" n="309"
                subtype="historical-document" type="document" xml:id="d309">
                <head>309. Telegram 980 to Geneva<note n="1" type="source" xml:id="d309fn1">Source:
                        Department of State, Central Files, 611.93/10–2055. Official Use Only.
                        Drafted by <persName corresp="#p_MWP_1">McConaughy</persName>; cleared by
                        Henderson.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1955-10-24">October 24, 1955, 6:59 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d309-1" n="1" type="facsimile" xml:id="d309-1"/>
                <p>980. For <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>Your 915. USIA detailing Lawrence Howse, Press Attache at Paris, as your press
                    officer.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HH_1">
                            <hi rend="strong">Hoover</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
