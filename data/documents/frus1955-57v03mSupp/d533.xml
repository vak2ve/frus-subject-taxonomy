        <body>
            <div frus:doc-dateTime-max="1956-03-12T23:59:59-05:00"
                frus:doc-dateTime-min="1956-03-12T00:00:00-05:00" n="533"
                subtype="historical-document" type="document" xml:id="d533">
                <head>533. Telegram 1750 to Geneva<note n="1" type="source" xml:id="d533fn1">Source:
                        Department of State, Central Files, 611.93/3–1256. Confidential; Priority.
                        Drafted by <persName corresp="#p_CRN_1">Clough</persName>.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1956-03-12">March 12, 1956, 6:47 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d533-1" n="1" type="facsimile" xml:id="d533-1"/>
                <p>1750. For <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>Code Room: Please repeat Colombo’s Secto 43, Control 6696, March 11, 1956.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HH_1">
                            <hi rend="strong">Hoover</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
