        <body>
            <div frus:doc-dateTime-max="1956-01-26T23:59:59-05:00"
                frus:doc-dateTime-min="1956-01-26T00:00:00-05:00" n="467"
                subtype="historical-document" type="document" xml:id="d467">
                <head>467. Telegram 1425 from Geneva<note n="1" type="source" xml:id="d467fn1"
                        >Source: Department of State, Central Files, 611.93/1–2656. Official Use
                        Only.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Geneva</placeName>, <date calendar="gregorian" when="1956-01-26"
                            >January 26, 1956, 10 a.m.</date>
                    </dateline>
                </opener>
                <pb facs="d467-1" n="1" type="facsimile" xml:id="d467-1"/>
                <p>1425. From <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>Following list handed me by <persName corresp="#p_WP_1">Wang</persName> 34th
                    meeting January 25:</p>
                <p>[<hi rend="italic">text not declassified</hi>]</p>
                <pb facs="d467-2" n="2" type="facsimile" xml:id="d467-2"/>
                <closer>
                    <signed>
                        <persName corresp="#p_GFC_1">
                            <hi rend="strong">Gowen</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
