<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1956-03-04T23:59:59-05:00" frus:doc-dateTime-min="1956-03-04T00:00:00-05:00" n="518" subtype="historical-document" type="document" xml:id="d518">
                        <head>518. Telegram Tosec 3 to Karachi<note n="1" type="source" xml:id="d518fn1">Source: Department of State, Central Files,
                                611.93/3–456. Official Use Only; Priority. Drafted by <persName corresp="#p_MWP_1">McConaughy</persName>; cleared by Sherwood
                                (S/S).</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Washington</placeName>, <date calendar="gregorian" when="1956-03-04">March 4, 1956, 5:54
                                    p.m.</date></dateline>
                        </opener>
                        <pb facs="d518-1" n="1" type="facsimile" xml:id="d518-1"/>
                        <p>Tosec 3. DCT please repeat Geneva’s 1587 Mar 4, 4 pm Control 2083 to
                            Karachi captioned</p>
                        <p>For the Secretary and <persName corresp="#p_RWS_1">Robertson</persName>.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_HH_1"><hi rend="strong">Hoover</hi></persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>