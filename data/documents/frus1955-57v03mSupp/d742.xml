    <text>
        <body>
            <div frus:doc-dateTime-max="1956-11-01T23:59:59-05:00"
                frus:doc-dateTime-min="1956-11-01T00:00:00-05:00" n="742"
                subtype="historical-document" type="document" xml:id="d742">
                <head>742. Telegram 453 from Geneva<note n="1" type="source" xml:id="d742fn1"
                        >Source: Department of State, Central Files, 611.93/11–156. Secret;
                        Priority; Limit Distribution.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Geneva</placeName>, <date calendar="gregorian" when="1956-11-01"
                            >November 1, 1956, 10 a.m.</date>
                    </dateline>
                </opener>
                <pb facs="d742-1" n="1" type="facsimile" xml:id="d742-1"/>
                <p>453. From <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>No repeat no reply yet from <persName corresp="#p_WP_1">Wang</persName>. Am
                    departing for Prague this morning. Have aranged to keep in touch en route with
                    Osborn who will keep Department informed of developments.</p>
                <p>Drafts requested papers going forward today’s pouch.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GFC_1">
                            <hi rend="strong">Gowen</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
