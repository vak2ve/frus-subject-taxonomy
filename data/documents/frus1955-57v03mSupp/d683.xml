    <text>
        <body>
            <div frus:doc-dateTime-max="1956-07-23T23:59:59-05:00"
                frus:doc-dateTime-min="1956-07-23T00:00:00-05:00" n="683"
                subtype="historical-document" type="document" xml:id="d683">
                <head>683. Telegram 70 to Geneva<note n="1" type="source" xml:id="d683fn1">Source:
                        Department of State, Central Files, 611.93/7–2356. Confidential. Drafted by
                            <persName corresp="#p_CRN_1">Clough</persName>.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1956-07-23">July 23, 1956, 4:02 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d683-1" n="1" type="facsimile" xml:id="d683-1"/>
                <p>70. For <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>Chinese convict Lu Ping Yeou No. 25 on list released from prison July 20. Four
                    released 30 remain.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HH_1">
                            <hi rend="strong">Hoover</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
