<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1957-03-13T23:59:59-05:00" frus:doc-dateTime-min="1957-03-13T00:00:00-05:00" n="794" subtype="historical-document" type="document" xml:id="d794">
                        <head>794. Telegram 874 from Geneva<note n="1" type="source" xml:id="d794fn1">Source: </note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Geneva</placeName>, <date calendar="gregorian" when="1957-03-13">March 13, 1957, 10
                                    a.m.</date></dateline>
                        </opener>
                        <pb facs="d794-1" n="1" type="facsimile" xml:id="d794-1"/>
                        <p>874. From <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                        <p>Would appreciate info whether Lee Li-chuen departed February 23 as
                            mentioned para 6 Deptel 815.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_GFC_1"><hi rend="strong">Gowen</hi></persName>
                            </signed>
                        </closer>
                    </div>
