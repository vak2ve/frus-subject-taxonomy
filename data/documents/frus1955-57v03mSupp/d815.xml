    <text>
        <body>
            <div frus:doc-dateTime-max="1957-07-12T23:59:59-05:00"
                frus:doc-dateTime-min="1957-07-12T00:00:00-05:00" n="815"
                subtype="historical-document" type="document" xml:id="d815">
                <head>815. Telegram 37 from Geneva<note n="1" type="source" xml:id="d815fn1">Source:
                        Department of State, Central Files, 611.93/7–1257. Confidential;
                        Priority.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Geneva</placeName>, <date calendar="gregorian" when="1957-07-12"
                            >July 12, 1957, 10 a.m.</date>
                    </dateline>
                </opener>
                <pb facs="d815-1" n="1" type="facsimile" xml:id="d815-1"/>
                <p>37. Reference Hong Kong Niact to Department 62, repeated Information London 5,
                    Geneva 2.</p>
                <pb facs="1437" n="1390" type="typeset" xml:id="pg_1390"/>
                <p>
                    <persName corresp="#p_JUA_1">Johnson</persName>-<persName corresp="#p_WP_1"
                        >Wang</persName> Talks.</p>
                <p>
                    <persName corresp="#p_JUA_1">Johnson</persName> left Geneva by air for Prague
                    this morning. Reference telegram repeated Prague.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GFC_1">
                            <hi rend="strong">Gowen</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
