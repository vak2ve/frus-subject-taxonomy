<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1955-08-16T23:59:59-05:00" frus:doc-dateTime-min="1955-08-16T00:00:00-05:00" n="93" subtype="historical-document" type="document" xml:id="d93">
                        <head>93. Telegram 523 to Geneva<note n="1" type="source" xml:id="d93fn1">Source: Department of State, Central Files, 611.93/8–1655.
                                Confidential. Drafted by <persName corresp="#p_MWP_1">McConaughy</persName>; cleared by Bond (IO).</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Washington</placeName>, <date calendar="gregorian" when="1955-08-16">August 16, 1955, 5:18
                                    p.m.</date></dateline>
                        </opener>
                        <pb facs="d93-1" n="1" type="facsimile" xml:id="d93-1"/>
                        <p>523. For <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                        <p>Code Room: Please repeat USUN’s 112 of August 15, 1955, Control Number
                            7865.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_DJF_1"><hi rend="strong">Dulles</hi></persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>