<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1955-09-19T23:59:59-05:00" frus:doc-dateTime-min="1955-09-19T00:00:00-05:00" n="201" subtype="historical-document" type="document" xml:id="d201">
                        <head>201. Telegram 750 to Geneva<note n="1" type="source" xml:id="d201fn1">Source: Department of State, Central Files, 611.93/9–955. Official
                                Use Only. Drafted by <persName corresp="#p_MWP_1">McConaughy</persName>.</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Washington</placeName>, <date calendar="gregorian" when="1955-09-19">September 19, 1955, 6:39
                                    p.m.</date></dateline>
                        </opener>
                        <pb facs="d201-1" n="1" type="facsimile" xml:id="d201-1"/>
                        <p>750. For <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                        <p>For completion our records forward exact text statements released by you
                            and <persName corresp="#p_WP_1">Wang</persName> to press September
                            14.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_DJF_1"><hi rend="strong">Dulles</hi></persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>