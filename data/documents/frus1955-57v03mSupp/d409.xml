    <text>
        <body>
            <div frus:doc-dateTime-max="1955-12-12T23:59:59-05:00"
                frus:doc-dateTime-min="1955-12-12T00:00:00-05:00" n="409"
                subtype="historical-document" type="document" xml:id="d409">
                <head>409. Telegram 1376 to Geneva<note n="1" type="source" xml:id="d409fn1">Source:
                        Department of State, Central Files, 611.93/12–855. Official Use Only.
                        Drafted by Smigel (IAD); cleared by Strother (FBIS) and in substance by
                        Stanley (DRF).</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1955-12-12">December 12, 1955, 3:48 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d409-1" n="1" type="facsimile" xml:id="d409-1"/>
                <p>1376. For <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>Urtel 1262. Failure receive significant flow FBIS due paucity pertinent items.
                    Requirements under review however to ensure coverage your interest.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DJF_1">
                            <hi rend="strong">Dulles</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
