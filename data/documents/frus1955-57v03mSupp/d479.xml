                        <head>479. Telegram 1457 from Geneva<note n="1" type="source" xml:id="d479fn1">Source: Department of State, Central Files,
                                611.93/2–656. Official Use Only.</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Geneva</placeName>, <date calendar="gregorian" when="1956-02-06">February 6, 1956, 2
                                    p.m.</date></dateline>
                        </opener>
                        <pb facs="d479-1" n="1" type="facsimile" xml:id="d479-1"/>
                        <p>1457. From <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                        <p>Fol list handed me by <persName corresp="#p_WP_1">Wang</persName> 35th
                            meeting Feb. 4:</p>
                        <p>[<hi rend="italic">text not declassified</hi>]</p>
                        <pb facs="d479-2" n="2" type="facsimile" xml:id="d479-2"/>
                        <closer>
                            <signed>
                                <persName corresp="#p_GFC_1"><hi rend="strong">Gowen</hi></persName>
                            </signed>
                        </closer>
