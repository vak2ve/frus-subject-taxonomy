    <text>
        <body>
            <div frus:doc-dateTime-max="1955-11-07T23:59:59-05:00"
                frus:doc-dateTime-min="1955-11-07T00:00:00-05:00" n="347"
                subtype="historical-document" type="document" xml:id="d347">
                <head>347. Telegram 2561 to London<note n="1" type="source" xml:id="d347fn1">Source:
                        Department of State, Central Files, 611.93/11–755. Official Use Only;
                        Priority. Repeated Priority to Geneva for <persName corresp="#p_JUA_1"
                            >Johnson</persName> as telegram 1142. Drafted by <persName
                            corresp="#p_CRN_1">Clough</persName>; cleared in draft by Beale
                        (BNA).</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1955-11-07">November 7, 1955, 4:29 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d347-1" n="1" type="facsimile" xml:id="d347-1"/>
                <p>2561. Your 1877.</p>
                <p>Cable priority unclassified to <persName corresp="#p_JUA_1">Johnson</persName>
                    full text Daily Worker story. Repeat Department.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HH_1">
                            <hi rend="strong">Hoover</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
