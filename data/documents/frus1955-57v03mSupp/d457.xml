        <body>
            <div frus:doc-dateTime-max="1956-01-10T23:59:59-05:00"
                frus:doc-dateTime-min="1956-01-10T00:00:00-05:00" n="457"
                subtype="historical-document" type="document" xml:id="d457">
                <head>457. Telegram 1405 from Geneva<note n="1" type="source" xml:id="d457fn1"
                        >Source: Department of State, Central Files, 611.93/1–1056. Official Use
                        Only.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Geneva</placeName>, <date calendar="gregorian" when="1956-01-10"
                            >January 10, 1956, 1 a.m.</date>
                    </dateline>
                </opener>
                <pb facs="d457-1" n="1" type="facsimile" xml:id="d457-1"/>
                <p>1405. From <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>Fol is list handed me by <persName corresp="#p_WP_1">Wang</persName> at board
                        [<hi rend="italic">33rd</hi>?] meeting:</p>
                <p>[<hi rend="italic">text not declassified</hi>]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GFC_1">
                            <hi rend="strong">Gowen</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
