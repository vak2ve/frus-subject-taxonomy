                <head>543. Telegram 1771 to Geneva<note n="1" type="source" xml:id="d543fn1">Source:
                        Department of State, Central Files, 611.93/3–1956. Secret. Drafted by
                            <persName corresp="#p_MWP_1">McConaughy</persName>.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1956-03-19">March 19, 1956, 6:51 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d543-1" n="1" type="facsimile" xml:id="d543-1"/>
                <p>1771. For <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>(Code room: Please repeat Taipei’s 848, March 18, Control 10953.) Re: Summary of
                    Conferences with President Chiang.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HH_1">
                            <hi rend="strong">Hoover</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
