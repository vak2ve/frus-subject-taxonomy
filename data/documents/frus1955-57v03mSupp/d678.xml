    <text>
        <body>
            <div frus:doc-dateTime-max="1956-07-11T23:59:59-05:00"
                frus:doc-dateTime-min="1956-07-11T00:00:00-05:00" n="678"
                subtype="historical-document" type="document" xml:id="d678">
                <head>678. Telegram 25 from Geneva<note n="1" type="source" xml:id="d678fn1">Source:
                        Department of State, Central Files, 611.93/7–1156. Official Use Only.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Geneva</placeName>, <date calendar="gregorian" when="1956-07-11"
                            >July 11, 1956, 11 a.m.</date>
                    </dateline>
                </opener>
                <pb facs="d678-1" n="1" type="facsimile" xml:id="d678-1"/>
                <p>25. From <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>At 53rd meeting Ambassador <persName corresp="#p_WP_1">Wang</persName> introduced
                    new adviser, <persName>Wang Ning</persName> (Matthews 7037, 4724) who takes
                    place of <persName>Wang Pao Liu</persName>.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GFC_1">
                            <hi rend="strong">Gowen</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
