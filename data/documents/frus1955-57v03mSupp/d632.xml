<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1956-05-31T23:59:59-05:00" frus:doc-dateTime-min="1956-05-31T00:00:00-05:00" n="632" subtype="historical-document" type="document" xml:id="d632">
                        <head>632. Telegram 730 to Taipei<note n="1" type="source" xml:id="d632fn1">Source: Department of State, Central Files, 611.93/5–3156. Secret.
                                Drafted by <persName corresp="#p_MWP_1">McConaughy</persName>;
                                cleared in SOA. Also sent to London as telegram 7256 and New Delhi
                                as telegram 2925.</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Washington</placeName>, <date calendar="gregorian" when="1956-05-31">May 31, 1956, 8:29
                                    p.m.</date></dateline>
                        </opener>
                        <pb facs="d632-1" n="1" type="facsimile" xml:id="d632-1"/>
                        <p>730. (CODE ROOM: Please repeat Department’s 2066 to Geneva, Control
                            13989, May 29.)</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_HH_1"><hi rend="strong">Hoover</hi></persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>