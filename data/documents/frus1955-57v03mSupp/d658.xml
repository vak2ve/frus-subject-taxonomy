                <head>658. Telegram 53 from Geneva to Prague<note n="1" type="source"
                        xml:id="d658fn1">Source: Department of State, Central Files, 611.93/6–1356.
                        Official Use Only. Repeated to the Department of State as telegram
                        2041.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Geneva</placeName>, <date calendar="gregorian" when="1956-06-13"
                            >June 13, 1956, noon</date>
                    </dateline>
                </opener>
                <pb facs="d658-1" n="1" type="facsimile" xml:id="d658-1"/>
                <p>53. From Osborn. Sending <persName corresp="#p_WP_1">Wang</persName> copies
                    Department’s release number 315.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GFC_1">
                            <hi rend="strong">Gowen</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
