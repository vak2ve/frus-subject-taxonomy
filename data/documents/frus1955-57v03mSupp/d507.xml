    <text>
        <body>
            <div frus:doc-dateTime-max="1956-02-29T23:59:59-05:00"
                frus:doc-dateTime-min="1956-02-29T00:00:00-05:00" n="507"
                subtype="historical-document" type="document" xml:id="d507">
                <head>507. Telegram 1697 to Geneva<note n="1" type="source" xml:id="d507fn1">Source:
                        Department of State, Central Files, 611.93/2–2956. Secret; Priority; Limit
                        Distribution. Drafted by <persName corresp="#p_MWP_1">McConaughy</persName>.
                        The time of transmission is illegible.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1956-02-29">February 29, 1956</date>
                    </dateline>
                </opener>
                <pb facs="d507-1" n="1" type="facsimile" xml:id="d507-1"/>
                <p>1697. For <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>Our 1693 first paragraph.</p>
                <p>In citing arrivals Chinese in Communist China from US you may make further
                    itemization. Our records show minimum 67 arrivals between September 10 and
                    December 20 and 35 since December 20.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DJF_1">
                            <hi rend="strong">Dulles</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
