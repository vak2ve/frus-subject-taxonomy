    <text>
        <body>
            <div frus:doc-dateTime-max="1955-09-09T23:59:59-05:00"
                frus:doc-dateTime-min="1955-09-09T00:00:00-05:00" n="177"
                subtype="historical-document" type="document" xml:id="d177">
                <head>177. Telegram 705 to Geneva<note n="1" type="source" xml:id="d177fn1">Source:
                        Department of State, Central Files, 611.93/9–955. Confidential; Priority.
                        Drafted by <persName corresp="#p_MWP_1">McConaughy</persName>; cleared by
                            <persName corresp="#p_RWS_1">Robertson</persName>.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1955-09-09">September 9, 1955, 7:39 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d177-1" n="1" type="facsimile" xml:id="d177-1"/>
                <p>705. For <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>Your 700. Following is text of revised press background talking paper. Now
                    planned for Suydam rather than <persName corresp="#p_RWS_1">Robertson</persName>
                    meet with Press September 10.</p>
                <p>Code room: Please repeat Department’s Tel. ________ omitting first paragraph and
                    submitting the above paragraph.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HH_1">
                            <hi rend="strong">Hoover</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
