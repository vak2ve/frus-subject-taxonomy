<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1957-01-19T23:59:59-05:00" frus:doc-dateTime-min="1957-01-19T00:00:00-05:00" n="777" subtype="historical-document" type="document" xml:id="d777">
                        <head>777. Telegram 712 from Geneva<note n="1" type="source" xml:id="d777fn1">Source: Department of State, Central Files,
                                611.93/1–1957. Official Use Only; Limit Distribution.</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Geneva</placeName>, <date calendar="gregorian" when="1957-01-19">January 19, 1957, 6
                                    p.m.</date></dateline>
                        </opener>
                        <pb facs="d777-1" n="1" type="facsimile" xml:id="d777-1"/>
                        <p>712. From <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                        <p>Minutes 64th meeting being pouched leaving Geneva January 20.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_GFC_1"><hi rend="strong">Gowen</hi></persName>
                            </signed>
                        </closer>
