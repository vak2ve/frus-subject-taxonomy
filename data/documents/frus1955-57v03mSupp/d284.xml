<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1955-10-14T23:59:59-05:00" frus:doc-dateTime-min="1955-10-14T00:00:00-05:00" n="284" subtype="historical-document" type="document" xml:id="d284">
                        <head>284. Telegram 864 from Geneva<note n="1" type="source" xml:id="d284fn1">Source: Department of State, Central Files,
                                611.93/10–1455. Confidential.</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Geneva</placeName>, <date calendar="gregorian" when="1955-10-14">October 14, 1955, 9
                                    a.m.</date></dateline>
                        </opener>
                        <pb facs="d284-1" n="1" type="facsimile" xml:id="d284-1"/>
                        <p>864. From <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                        <p>Would appreciate prompt extension by Defense of Colonel Ekvall’s orders
                            which expired September 20.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_GFC_1"><hi rend="strong">Gowen</hi></persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>