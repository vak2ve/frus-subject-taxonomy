    <text>
        <body>
            <div frus:doc-dateTime-max="1956-02-27T23:59:59-05:00"
                frus:doc-dateTime-min="1956-02-27T00:00:00-05:00" n="502"
                subtype="historical-document" type="document" xml:id="d502">
                <head>502. Telegram 1558 from Geneva<note n="1" type="source" xml:id="d502fn1"
                        >Source: Department of State, Central Files, 611.93/2–2756. Official Use
                        Only.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Geneva</placeName>, <date calendar="gregorian" when="1956-02-27"
                            >February 27, 1956, 7 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d502-1" n="1" type="facsimile" xml:id="d502-1"/>
                <p>1558. From <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>Fol list names handed me by <persName corresp="#p_WP_1">Wang</persName> 38th
                    meeting February 24:</p>
                <p>[<hi rend="italic">text not declassified</hi>]</p>
                <pb facs="d502-2" n="2" type="facsimile" xml:id="d502-2"/>
                <closer>
                    <signed>
                        <persName corresp="#p_GFC_1">
                            <hi rend="strong">Gowen</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
