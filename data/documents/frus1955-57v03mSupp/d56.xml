                subtype="historical-document" type="document" xml:id="d56">
                <head>56. Telegram 439 to Geneva<note n="1" type="source" xml:id="d56fn1">Source:
                        Department of State, Central Files, 611.93/8–1055. Secret. Drafted by
                            <persName corresp="#p_DJF_1">Dulles</persName>; cleared by <persName
                            corresp="#p_RWS_1">Robertson</persName>. The time of transmission is
                        illegible.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1955-08-10">August 10, 1955</date>
                    </dateline>
                </opener>
                <pb facs="d56-1" n="1" type="facsimile" xml:id="d56-1"/>
                <p>439. For <persName corresp="#p_JUA_1">Johnson</persName>. Your 362.</p>
                <p>While it is useful to be thinking ahead we doubt that it is useful to attempt now
                    to crystallize our thinking.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DJF_1">
                            <hi rend="strong">Dulles</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
