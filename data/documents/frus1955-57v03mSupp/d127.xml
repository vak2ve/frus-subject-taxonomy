<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1955-08-23T23:59:59-05:00" frus:doc-dateTime-min="1955-08-23T00:00:00-05:00" n="127" subtype="historical-document" type="document" xml:id="d127">
                        <head>127. Telegram 616 to Geneva<note n="1" type="source" xml:id="d127fn1">Source: Department of State, Central Files, 611.93/8–2355. Secret.
                                Drafted by <persName corresp="#p_MWP_1">McConaughy</persName>.</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Washington</placeName>, <date calendar="gregorian" when="1955-08-23">August 23, 1955, 7:38
                                    p.m.</date></dateline>
                        </opener>
                        <pb facs="d127-1" n="1" type="facsimile" xml:id="d127-1"/>
                        <p>616. For <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                        <p>FYI. Secretary has sent following to U Nu in response to inquiry from
                            latter:</p>
                        <p>QUOTE (Code Room: Please recite here text of letter contained in
                            Department’s 150 to Rangoon) QUOTE</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_DJF_1"><hi rend="strong">Dulles</hi></persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>