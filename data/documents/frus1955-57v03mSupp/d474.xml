        <body>
            <div frus:doc-dateTime-max="1956-02-02T23:59:59-05:00"
                frus:doc-dateTime-min="1956-02-02T00:00:00-05:00" n="474"
                subtype="historical-document" type="document" xml:id="d474">
                <head>474. Telegram 1573 to Geneva<note n="1" type="source" xml:id="d474fn1">Source:
                        Department of State, Central Files, 611.93/2–156. Secret; Priority; Limit
                        Distribution. Drafted by <persName corresp="#p_MWP_1">McConaughy</persName>;
                        cleared by Sebald.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1956-02-02">February 2, 1956, 10:23 a.m.</date>
                    </dateline>
                </opener>
                <pb facs="d474-1" n="1" type="facsimile" xml:id="d474-1"/>
                <p>1573. For <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>Your 1440. You are authorized your discretion handle Chinese names as you suggest
                    provided <persName corresp="#p_WP_1">Wang</persName> afforded no grounds for
                    misinterpretation.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DJF_1">
                            <hi rend="strong">Dulles</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
