                <head>6. Telegram 238 from Geneva<note n="1" type="source" xml:id="d6fn1">Source:
                        Department of State, Central Files, 611.93/8–155. Confidential; No
                        Distribution.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Geneva</placeName>, <date calendar="gregorian" when="1955-08-01"
                            >August 1, 1955, 8 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d6-1" n="1" type="facsimile" xml:id="d6-1"/>
                <p>238. For Assistant Secretary McCardle From <persName corresp="#p_GFC_1"
                        >Gowen</persName>. Your 310.</p>
                <p>Garnish has been made available to <persName corresp="#p_JUA_1"
                        >Johnson</persName>. Garnish reported here only today.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GFC_1">
                            <hi rend="strong">Gowen</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
