                        <head>430. Telegram 194 to Prague<note n="1" type="source" xml:id="d430fn1">Source: Department of State, Central Files, 611.93/12–2855.
                                Confidential. Drafted by Nagoski; cleared by <persName corresp="#p_JUA_1">Johnson</persName> (EE).</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Washington</placeName>, <date calendar="gregorian" when="1955-12-30">December 30, 1955, 3:26
                                    p.m.</date></dateline>
                        </opener>
                        <pb facs="d430-1" n="1" type="facsimile" xml:id="d430-1"/>
                        <p>194. For Ambassador.</p>
                        <p>(Code Room: Please repeat Geneva’s 1320, December 28; control 13398)</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_DJF_1"><hi rend="strong">Dulles</hi></persName>
                            </signed>
                        </closer>
