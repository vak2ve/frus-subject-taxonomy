    <text>
        <body>
            <div frus:doc-dateTime-max="1955-10-14T23:59:59-05:00"
                frus:doc-dateTime-min="1955-10-14T00:00:00-05:00" n="290"
                subtype="historical-document" type="document" xml:id="d290">
                <head>290. Telegram 886 to Geneva<note n="1" type="source" xml:id="d290fn1">Source:
                        Department of State, Central Files, 611.93/10–1455. Confidential. Drafted by
                            <persName corresp="#p_CRN_1">Clough</persName>.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1955-10-14">October 14, 1955, 6:20 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d290-1" n="1" type="facsimile" xml:id="d290-1"/>
                <p>886. For <persName corresp="#p_JUA_1">Johnson</persName>. Your 864.</p>
                <p>Defense arranging assign <persName corresp="#p_ELCRB_1">Ekvall</persName>
                    European post and detail Geneva for duration talks. Letter from Godel
                    enroute.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DJF_1">
                            <hi rend="strong">Dulles</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
