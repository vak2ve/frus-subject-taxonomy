<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1956-06-12T23:59:59-05:00" frus:doc-dateTime-min="1956-06-12T00:00:00-05:00" n="655" subtype="historical-document" type="document" xml:id="d655">
                        <head>655. Telegram 2033 from Geneva<note n="1" type="source" xml:id="d655fn1">Source: Department of State, Central Files,
                                611.93/6–1256. Official Use Only; Priority. Repeated to Prague as
                                telegram 51.</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Geneva</placeName>, <date calendar="gregorian" when="1956-06-12">June 12, 1956,
                                    noon</date></dateline>
                        </opener>
                        <pb facs="d655-1" n="1" type="facsimile" xml:id="d655-1"/>
                        <p>2033. From Osborn. CHICOMS have just announced press conference for 3:30
                            our time.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_GFC_1"><hi rend="strong">Gowen</hi></persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>