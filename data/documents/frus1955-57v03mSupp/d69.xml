                <head>69. Telegram 425 from Geneva<note n="1" type="source" xml:id="d69fn1">Source:
                        Department of State, Central Files, 611.93/8–1255. Official Use Only.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Geneva</placeName>, <date calendar="gregorian" when="1955-08-12"
                            >August 12, 1955, 3 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d69-1" n="1" type="facsimile" xml:id="d69-1"/>
                <p>425. From <persName corresp="#p_JUA_1">Johnson</persName>. Reference:
                    McConaughy’s August 10 letter.</p>
                <p>
                    <persName corresp="#p_MEW_1">Martin</persName> departing August 16.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GFC_1">
                            <hi rend="strong">Gowen</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
