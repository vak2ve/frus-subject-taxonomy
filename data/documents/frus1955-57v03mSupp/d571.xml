    <text>
        <body>
            <div frus:doc-dateTime-max="1956-04-10T23:59:59-05:00"
                frus:doc-dateTime-min="1956-04-10T00:00:00-05:00" n="571"
                subtype="historical-document" type="document" xml:id="d571">
                <head>571. Telegram 1856 to Geneva<note n="1" type="source" xml:id="d571fn1">Source:
                        Department of State, Central Files, 611.93/4–856. Official Use Only. Drafted
                        by Serey (FE/EX); cleared in substance by <persName corresp="#p_CRN_1"
                            >Clough</persName> and Manning (R).</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1956-04-10">April 10, 1956, 6:32 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d571-1" n="1" type="facsimile" xml:id="d571-1"/>
                <p>1856. For <persName corresp="#p_JUA_1">Johnson</persName>. Your 1736.</p>
                <p>Holdridge departing Paris for Geneva April 13 flight 738 Air France. Stanley to
                    depart as planned.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DJF_1">
                            <hi rend="strong">Dulles</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
