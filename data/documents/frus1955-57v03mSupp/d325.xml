<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1955-10-29T23:59:59-05:00" frus:doc-dateTime-min="1955-10-29T00:00:00-05:00" n="325" subtype="historical-document" type="document" xml:id="d325">
                        <head>325. Telegram Tedul 28 to Geneva<note n="1" type="source" xml:id="d325fn1">Source: Department of State, Central Files,
                                611.93/10–2955. Secret. Drafted by McAuliffe (S/S).</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Washington</placeName>, <date calendar="gregorian" when="1955-10-29">October 29, 1955, 5:10
                                    p.m.</date></dateline>
                        </opener>
                        <pb facs="d325-1" n="1" type="facsimile" xml:id="d325-1"/>
                        <p>Tedul 28. Secretary should see Deptels 1052 and 1053 to Geneva FOR
                            JOHNSON.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_HH_1"><hi rend="strong">Hoover</hi></persName>
                            </signed>
                        </closer>
                    </div>
