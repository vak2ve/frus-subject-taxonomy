    <text>
        <body>
            <div frus:doc-dateTime-max="1956-03-20T23:59:59-05:00"
                frus:doc-dateTime-min="1956-03-20T00:00:00-05:00" n="545"
                subtype="historical-document" type="document" xml:id="d545">
                <head>545. Telegram 1772 to Geneva<note n="1" type="source" xml:id="d545fn1">Source:
                        Department of State, Central Files, 611.93/3–2056. Secret; Priority. Drafted
                        by <persName corresp="#p_MWP_1">McConaughy</persName>.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1956-03-20">March 20, 1956, 3:44 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d545-1" n="1" type="facsimile" xml:id="d545-1"/>
                <p>1772. For <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>(Code room: Please repeat Colombo Dulte 22, March 11, Control 6737)</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HH_1">
                            <hi rend="strong">Hoover</hi>
                        </persName>
                    </signed>
                </closer>
                <postscript>
                    <p>Re: Summary of views Nehru expressed to Secretary.</p>
                </postscript>
            </div>
        </body>
