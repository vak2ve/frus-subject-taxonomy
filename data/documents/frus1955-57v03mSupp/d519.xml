                <head>519. Telegram Tosec 7 to Karachi<note n="1" type="source" xml:id="d519fn1"
                        >Source: Department of State, Central Files, 611.93/3–156. Secret; Priority;
                        Limit Distribution. Drafted by <persName corresp="#p_MWP_1"
                            >McConaughy</persName>.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1956-03-05">March 5, 1956, 1:56 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d519-1" n="1" type="facsimile" xml:id="d519-1"/>
                <p>Tosec 7. (Code room: Please repeat Geneva’s 1574, March 1, Control No. 540.)</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HH_1">
                            <hi rend="strong">Hoover</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
