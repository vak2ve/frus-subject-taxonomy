    <text>
        <body>
            <div frus:doc-dateTime-max="1955-12-14T23:59:59-05:00"
                frus:doc-dateTime-min="1955-12-14T00:00:00-05:00" n="414"
                subtype="historical-document" type="document" xml:id="d414">
                <head>414. Telegram 1393 to Geneva<note n="1" type="source" xml:id="d414fn1">Source:
                        Department of State, Central Files, 611.93/12–1355. Secret; Priority; Limit
                        Distribution. Drafted by <persName corresp="#p_MWP_1">McConaughy</persName>;
                        cleared by Sebald and in substance by Yager.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1955-12-14">December 14, 1955, 1:12 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d414-1" n="1" type="facsimile" xml:id="d414-1"/>
                <p>1393. For <persName corresp="#p_JUA_1">Johnson</persName>. Your 1283.</p>
                <p>Department’s intention is that proposed recess begin after December 15 meeting.
                    Re Our 1366 <persName corresp="#p_CPW_1">Colm</persName> may leave immediately
                    after next meeting assuming recess agreed to.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HH_1">
                            <hi rend="strong">Hoover</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
