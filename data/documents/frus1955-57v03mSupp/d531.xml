                subtype="historical-document" type="document" xml:id="d531">
                <head>531. Telegram Tosec 54 to Djakarta<note n="1" type="source" xml:id="d531fn1"
                        >Source: Department of State, Central Files, 611.93/3–1156. Official Use
                        Only. Drafted by <persName corresp="#p_MWP_1">McConaughy</persName> and an
                        officer in DCT. Also sent to Prague for <persName corresp="#p_JUA_1"
                            >Johnson</persName> as telegram 289.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1956-03-11">March 11, 1956, 5:51 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d531-1" n="1" type="facsimile" xml:id="d531-1"/>
                <p>Tosec 54. For Secretary and <persName corresp="#p_RWS_1"
                    >Robertson</persName>.</p>
                <p>(Code room: Repeat text Geneva’s 1621 control 6674.)</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HH_1">
                            <hi rend="strong">Hoover</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
