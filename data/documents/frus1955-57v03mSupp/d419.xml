                subtype="historical-document" type="document" xml:id="d419">
                <head>419. Telegram 1295 from Geneva<note n="1" type="source" xml:id="d419fn1"
                        >Source: Department of State, Central Files, 611.93/12–1655.
                        Confidential.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Geneva</placeName>, <date calendar="gregorian" when="1955-12-16"
                            >December 16, 1955, 1 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d419-1" n="1" type="facsimile" xml:id="d419-1"/>
                <p>1295. From <persName corresp="#p_JUA_1">Johnson</persName>. Re Mytel 1289.</p>
                <p>Paragraph 21 second sentence to end should read: “As he had specifically stated
                    in advance reaching agreement on return civilians, Americans who had broken law
                    must be handled in accordance Chinese legal procedures and this could by no
                    means be hastened by setting deadline. Such is matter Chinese sovereign
                    rights.”</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GFC_1">
                            <hi rend="strong">Gowen</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
