<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1956-03-09T23:59:59-05:00" frus:doc-dateTime-min="1956-03-09T00:00:00-05:00" n="527" subtype="historical-document" type="document" xml:id="d527">
                        <head>527. Telegram 1617 from Geneva<note n="1" type="source" xml:id="d527fn1">Source: Department of State, Central Files,
                                611.93/3–956. Official Use Only.</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Geneva</placeName>, <date calendar="gregorian" when="1956-03-09">March 9, 1956, 4
                                    p.m.</date></dateline>
                        </opener>
                        <pb facs="d527-1" n="1" type="facsimile" xml:id="d527-1"/>
                        <p>1617. From <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                        <p>Following list five names handed me by <persName corresp="#p_WP_1">Wang</persName> 40th meeting March 8.</p>
                        <p>[<hi rend="italic">text not declassified</hi>]</p>
                        <pb facs="d527-2" n="2" type="facsimile" xml:id="d527-2"/>
                        <closer>
                            <signed>
                                <persName corresp="#p_GFC_1"><hi rend="strong">Gowen</hi></persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>