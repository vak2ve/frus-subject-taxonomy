                <head>141. Telegram 628 from Geneva<note n="1" type="source" xml:id="d141fn1"
                        >Source: Department of State, Central Files, 611.93/8–2655. Confidential;
                        Priority.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Geneva</placeName>, <date calendar="gregorian" when="1955-08-26"
                            >August 26, 1955, 11 a.m.</date>
                    </dateline>
                </opener>
                <pb facs="d141-1" n="1" type="facsimile" xml:id="d141-1"/>
                <p>628. From <persName corresp="#p_JUA_1">Johnson</persName>. Deptel 633.</p>
                <p>I have requested next meeting Wednesday, August 31, 10 a.m.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GFC_1">
                            <hi rend="strong">Gowen</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
