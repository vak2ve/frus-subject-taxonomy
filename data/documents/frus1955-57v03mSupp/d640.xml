                        <head>640. Telegram 2099 to Geneva<note n="1" type="source" xml:id="d640fn1">Source: Department of State, Central Files, 611.93/6–656.
                                Confidential; Limit Distribution. Drafted by <persName corresp="#p_MWP_1">McConaughy</persName>.</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Washington</placeName>, <date calendar="gregorian" when="1956-06-06">June 6, 1956, 6:45
                                    p.m.</date></dateline>
                        </opener>
                        <pb facs="d640-1" n="1" type="facsimile" xml:id="d640-1"/>
                        <p>2099. For <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                        <p>Following Chinese note dated June 3 transmitted for your confidential
                            background:</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_DJF_1"><hi rend="strong">Dulles</hi></persName>
                            </signed>
                        </closer>
