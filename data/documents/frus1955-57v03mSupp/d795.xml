                        <head>795. Telegram 899 to Geneva<note n="1" type="source" xml:id="d795fn1">Source: Department of State, Central Files, 611.93/3–1357.
                                Confidential; Priority; Drafted by Seward (FE/CA/RA).</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Washington</placeName>, <date calendar="gregorian" when="1957-03-13">March 13, 1957, 4:52
                                    p.m.</date></dateline>
                        </opener>
                        <pb facs="d795-1" n="1" type="facsimile" xml:id="d795-1"/>
