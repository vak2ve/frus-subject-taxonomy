                <head>643. Telegram 2102 to Geneva<note n="1" type="source" xml:id="d643fn1">Source:
                        Department of State, Central Files, 611.93/6–656. Secret; Priority; Limit
                        Distribution. Drafted by <persName corresp="#p_MWP_1"
                        >McConaughy</persName>.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1956-06-06">June 6, 1956, 7:15 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d643-1" n="1" type="facsimile" xml:id="d643-1"/>
                <p>2102. For <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                <p>(CODE ROOM: Please repeat Taipei’s 1080, June 4, Control 1662)</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DJF_1">
                            <hi rend="strong">Dulles</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
