                <head>743. Telegram 456 from Geneva<note n="1" type="source" xml:id="d743fn1"
                        >Source: Department of State, Central Files, 611.93/11–156. Confidential;
                        Priority; Limit Distribution.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Geneva</placeName>, <date calendar="gregorian" when="1956-11-01"
                            >November 1, 1956, 3 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d743-1" n="1" type="facsimile" xml:id="d743-1"/>
                <p>456. From Osborn.</p>
                <p>
                    <persName corresp="#p_WP_1">Wang</persName> agreed next meeting November 15.
                    Usual announcement press, postponement “for administrative reasons”.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_GFC_1">
                            <hi rend="strong">Gowen</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
