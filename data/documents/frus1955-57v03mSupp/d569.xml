<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1956-04-09T23:59:59-05:00" frus:doc-dateTime-min="1956-04-09T00:00:00-05:00" n="569" subtype="historical-document" type="document" xml:id="d569">
                        <head>569. Telegram 1742 from Geneva<note n="1" type="source" xml:id="d569fn1">Source: Department of State, Central Files,
                                611.93/4–956. Official Use Only.</note></head>
                        <opener>
                            <dateline rendition="#right"><placeName>Geneva</placeName>, <date calendar="gregorian" when="1956-04-09">April 9, 1956, 7
                                    p.m.</date></dateline>
                        </opener>
                        <pb facs="d569-1" n="1" type="facsimile" xml:id="d569-1"/>
                        <p>1742. From <persName corresp="#p_JUA_1">Johnson</persName>.</p>
                        <p>Departing for Prague morning April 10 returning Geneva April 17.</p>
                        <p>Have no comments on today’s meeting other than those contained my
                            telegram 1737.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_GFC_1"><hi rend="strong">Gowen</hi></persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>