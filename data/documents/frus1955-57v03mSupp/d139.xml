    <text>
        <body>
            <div frus:doc-dateTime-max="1955-08-25T23:59:59-05:00"
                frus:doc-dateTime-min="1955-08-25T00:00:00-05:00" n="139"
                subtype="historical-document" type="document" xml:id="d139">
                <head>139. Telegram 92 to USUN<note n="1" type="source" xml:id="d139fn1">Source:
                        Department of State, Central Files, 611.93/8–2555. Confidential; Niact.
                        Drafted by <persName corresp="#p_BRG_1">Barnes</persName>. Brackets are in
                        the original.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date calendar="gregorian"
                            when="1955-08-25">August 25, 1955, 5:14 p.m.</date>
                    </dateline>
                </opener>
                <pb facs="d139-1" n="1" type="facsimile" xml:id="d139-1"/>
                <p>92. For Ambassador Lodge.</p>
                <p>Please make the following two telegrams from Ambassador <persName
                        corresp="#p_JUA_1">Johnson</persName> in Geneva available to Secretary this
                    evening.</p>
                <p>616 [Code Room: Please repeat 616 from Geneva, control 13384]</p>
                <p>617 [Code Room: Please repeat 617 from Geneva, control 13389]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DJF_1">
                            <hi rend="strong">Dulles</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
