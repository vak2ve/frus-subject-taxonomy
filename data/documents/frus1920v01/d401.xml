                subtype="historical-document" type="document" xml:id="d401">
                <note rend="inline" type="source">824.00/156: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from">
                        <hi rend="italic">Morgan</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1920-12-17T11:00:00-03:00">
                            <hi rend="italic">December 17, 1920—11 a.m.</hi>
                        </date>
                        <lb/>[Received 11:15 a.m.]</dateline>
                </opener>
                <p>124. Department’s December 9, 2 p.m. After consulting President, Foreign Minister
                    informed me yesterday Brazilian Government is in accord with the decision of the
                    American Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Morgan</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
