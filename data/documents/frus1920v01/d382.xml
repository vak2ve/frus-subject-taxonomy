                <note rend="inline" type="source">824.00/70: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Bolivia</hi> (<persName type="to">
                        <hi rend="italic">Maginnis</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-07-23T19:00:00-04:00">
                            <hi rend="italic">July 23, 1920—7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>49. Your July 21, noon.</p>
                <p>You are instructed to refrain from taking charge of the private property of any
                    Bolivian citizens.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
