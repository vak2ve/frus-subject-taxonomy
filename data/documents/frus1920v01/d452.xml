<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-07-18T23:00:00-05:00" frus:doc-dateTime-min="1920-07-18T23:00:00-05:00" n="452" subtype="historical-document" type="document" xml:id="d452">
                            <note rend="inline" type="source">893.00/3396: Telegram</note>
                            <head><hi rend="italic">The Consul General at Tientsin</hi> (<persName type="from"><hi rend="italic">Fuller</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Tientsin</hi></placeName>, <date calendar="gregorian" when="1920-07-19T12:00:00+08:00"><hi rend="italic">July 19,
                                            1920—noon</hi></date>.<lb/>[Received July 19—8:18
                                    a.m.]</dateline></opener>
                            <p>Foreign military contingents expect to send military train through to
                                Peking July 19, 3 p.m.</p>
                            <closer><signed><hi rend="smallcaps">Fuller</hi></signed></closer>
                        </div>
                        </body></text></TEI>