    <text>
        <body>
            <div frus:doc-dateTime-max="1920-07-20T23:59:59-05:00"
                frus:doc-dateTime-min="1920-07-20T00:00:00-05:00" n="413"
                subtype="historical-document" type="document" xml:id="d413">
                <note rend="inline" type="source">711.428/600</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        British Ambassador</hi> (<persName type="to">
                        <hi rend="italic">Geddes</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-07-20">
                            <hi rend="italic">July 20, 1920</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to refer to your note No.
                    354 of June 10, 1920, relative to the publication of the report of the
                    International Fisheries Commission.</p>
                <p>I have the honor to inform you that this Government consents to the publication
                    of the report in question, on July 26, 1920.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bainbridge Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
