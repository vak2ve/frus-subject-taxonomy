                subtype="historical-document" type="document" xml:id="d525">
                <note rend="inline" type="source">893.51/2851: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Crane</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1920-06-26T12:00:00+08:00">
                            <hi rend="italic">June 26, 1920—noon</hi>
                        </date>.<lb/>[Received June 26—6:47 a.m.]</dateline>
                </opener>
                <p>149. Japanese Minister demands formal approval of all governments concerned to
                    notes exchanged between Lamont and Japanese group before the same are
                    communicated to the Chinese Government. Please telegraph approval. If no reply
                    is received by July 3d the Legation will assume that the notes are approved.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Crane</hi>
                    </signed>
                </closer>
            </div>
        </body>
