                subtype="historical-document" type="document" xml:id="d264">
                <note rend="inline" type="source">862.00/856: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Commissioner at Berlin</hi> (<persName type="to">
                        <hi rend="italic">Dresel</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-03-23T16:00:00-05:00">
                            <hi rend="italic">March 23, 1920—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>75. Your 210, March 21, 3 p.m.</p>
                <p>Department believes that telegram from Department, No. 71, March 22, 4 p.m., is
                    all that should be said at present time in regard <pb facs="0368" n="270"
                        xml:id="pg_270"/> to Bolshevist danger. Your informal statement repeated in
                    your cable 209, March 21, 1 p.m., is approved.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
