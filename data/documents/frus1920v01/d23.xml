<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-05-26T06:41:00-05:00" frus:doc-dateTime-min="1920-05-26T06:41:00-05:00" n="23" subtype="historical-document" type="document" xml:id="d23">
                        <note rend="inline" type="source">500.C114/22: Telegram</note>
                        <head><hi rend="italic">The Minister in the Netherlands</hi> (<persName type="from"><hi rend="italic">Phillips</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">The
                                        Hague</hi></placeName>, <date calendar="gregorian" when="1920-05-26T13:00:00+01:19"><hi rend="italic">May 26,
                                        1920—1 p.m.</hi></date><lb/>[Received 5:54
                            p.m.]</dateline></opener>
                        <p>88. My 87 May 25th. Please advise in what capacity Mr. Root attends
                            forthcoming international conference at The Hague.</p>
                        <closer><signed><hi rend="smallcaps">Phillips</hi></signed></closer>
                    </div>
                    </body></text></TEI>