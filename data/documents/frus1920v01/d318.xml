                subtype="historical-document" type="document" xml:id="d318">
                <note rend="inline" type="source">714.1515/319: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Guatemala</hi> (<persName type="to">
                        <hi rend="italic">McMillin</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-07-02T17:00:00-04:00">
                            <hi rend="italic">July 2, 1920—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>57. Department’s 13 February 28, 1 p.m.<note n="64" xml:id="d318fn64">See
                        footnote 61, <ref target="#pg_313">p. 313</ref>.</note> Please ascertain
                    discreetly President Herrera’s attitude towards proposal.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
