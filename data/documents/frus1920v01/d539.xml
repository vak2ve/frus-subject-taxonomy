<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-07-20T13:00:00-05:00" frus:doc-dateTime-min="1920-07-20T13:00:00-05:00" n="539" subtype="historical-document" type="document" xml:id="d539">
                            <note rend="inline" type="source">893.51/2879: Telegram</note>
                            <head><hi rend="italic">The Ambassador in France</hi> (<persName type="from"><hi rend="italic">Wallace</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1920-07-20T19:00:00+01:00"><hi rend="italic">July 20,
                                            1920—7 p.m.</hi></date><lb/>[Received 7:40
                                    p.m.]</dateline></opener>
                            <p>1414. Your 1227.<note n="63" xml:id="d539fn63">See footnote 35, <ref target="#pg_548">p. 548</ref>.</note> The French Government
                                has instructed its representative at Tokyo to notify the Japanese
                                Government of its approval of the contents of letters exchanged
                                between Lamont and the Japanese banking group.</p>
                            <closer><signed><hi rend="smallcaps">Wallace</hi></signed></closer>
                        </div>
                        </body></text></TEI>