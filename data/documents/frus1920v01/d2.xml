                subtype="historical-document" type="document" xml:id="d2">
                <note rend="inline" type="source">763.72119/8937: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName type="to">
                        <hi rend="italic">Davis</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-02-09T17:00:00-05:00">
                            <hi rend="italic">February 9, 1920—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>124. Your 205 of February 6. The President does not wish you to attend London
                    meeting of Premiers in any capacity even if you should be invited.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
