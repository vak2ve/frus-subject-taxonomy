                subtype="historical-document" type="document" xml:id="d848">
                <note rend="inline" type="source">893.00/3323: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName type="from">
                        <hi rend="italic">Tenney</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1920-03-31T12:00:00+08:00">
                            <hi rend="italic">March 31, 1920—12 noon</hi>
                        </date>.<lb/>[Received March 31—7:05 a.m.]</dateline>
                </opener>
                <p>70. Your telegram 69, March 26, 2 p.m. News exaggerated, no casualties. Reporting
                    by mail.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Tenney</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
