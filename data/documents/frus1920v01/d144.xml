                subtype="historical-document" type="document" xml:id="d144">
                <note rend="inline" type="source">862.73/22: Telegram</note>
                <head>
                    <hi rend="italic">The Commissioner at Berlin</hi> (<persName type="from">
                        <hi rend="italic">Dresel</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName> [<date
                            ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                            calendar="gregorian" notAfter="1920-10-29T09:47:00-05:00"
                            notBefore="1920-10-28T18:00:00-05:00">
                            <hi rend="italic">undated</hi>
                        </date>].<lb/>[Received October 29, 1920—9:47 a.m.]</dateline>
                </opener>
                <p>1241. From Stewart, Hamburg: <quote rend="blockquote">
                        <p>“Your 1610, October 25, 1 p.m. Cables were laid direct from Emden to
                            Azores without touching any intermediate port, no part in operation at
                            present. Operatives in Azores were Germans. There are 12 cables from
                            Emden to England, 6 of them to Bacton and 6 Lowestoft. Number now in
                            operation is unknown but repairs on those out of service are being
                            rushed.”</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dresel</hi>
                    </signed>
                </closer>
            </div>
        </body>
