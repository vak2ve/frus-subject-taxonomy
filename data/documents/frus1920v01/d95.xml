<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-08-13T07:00:00-05:00" frus:doc-dateTime-min="1920-08-13T07:00:00-05:00" n="95" subtype="historical-document" type="document" xml:id="d95">
                            <note rend="inline" type="source">551.A1/34: Telegram</note>
                            <head><hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from"><hi rend="italic">Davis</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1920-08-13T13:00:00+01:00"><hi rend="italic">August
                                            13, 1920—1 p.m.</hi></date><lb/>[Received August 13—9:50
                                    a.m.]</dateline></opener>
                            <p>1222. My 1015, July 2, noon.<note n="69" xml:id="d95fn69">Not
                                    printed.</note> Drummond now informs me date of Brussels
                                International Financial Conference has been fixed for September
                                24th.</p>
                            <closer><signed><hi rend="smallcaps">Davis</hi></signed></closer>
                        </div>
                        </body></text></TEI>