<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-11-24T03:00:00-05:00" frus:doc-dateTime-min="1919-11-24T03:00:00-05:00" n="797" subtype="historical-document" type="document" xml:id="d797">
                            <note rend="inline" type="source">761.93/134: Telegram</note>
                            <head><hi rend="italic">The Chargé in China</hi> (<persName type="from"><hi rend="italic">Tenney</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1919-11-24T16:00:00+08:00"><hi rend="italic">November
                                            24, 1919—4 p.m.</hi></date><lb/>[Received November
                                    24—10:40 a.m.]</dateline></opener>
                            <p>By Presidential mandate dated November 22nd the independence of Outer
                                Mongolia has been canceled and status of Mongolia has been
                                restored.</p>
                            <closer><signed><hi rend="smallcaps">Tenney</hi></signed></closer>
                        </div>
                        </body></text></TEI>