<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-08-12T16:00:00-05:00" frus:doc-dateTime-min="1920-08-12T16:00:00-05:00" n="131" subtype="historical-document" type="document" xml:id="d131">
                            <note rend="inline" type="source">574.D1/103: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in Great Britain</hi>
                                    (<persName type="to"><hi rend="italic">Davis</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1920-08-12T17:00:00-04:00"><hi rend="italic">August
                                            12, 1920—5 p.m.</hi></date></dateline></opener>
                            <p>878. Your 1192, August 9th, 4 p.m.</p>
                            <p>This Government concurs with British Government’s suggestion that
                                Main Conference be postponed and date of its convocation be
                                determined by agreement at Preliminary Conference.</p>
                            <closer><signed><hi rend="smallcaps">Colby</hi></signed></closer>
                        </div>
                        </body></text></TEI>