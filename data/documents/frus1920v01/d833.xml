                <note rend="inline" type="source">893.102H/319: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in China</hi> (<persName type="to">
                        <hi rend="italic">Reinsch</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-10-05T17:00:00-05:00">
                            <hi rend="italic">October 5, 1917—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your October 1, 8 p.m. Requested authority to negotiate is granted.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
