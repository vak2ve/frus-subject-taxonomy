                subtype="historical-document" type="document" xml:id="d50">
                <note rend="inline" type="source">760c.61/66: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Czechoslovakia</hi> (<persName type="to">
                        <hi rend="italic">Crane</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-06-18T18:00:00-04:00">
                            <hi rend="italic">June 18, 1920—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>77. Recent reports indicate that trains of ammunition presumably bought by Polish
                    Government have been held in Czechoslovakia. <pb facs="0141" n="43"
                        xml:id="pg_43"/> You are instructed to very discreetly obtain facts.
                    Department’s information is not sufficiently full to warrant direct
                    inquiries.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
