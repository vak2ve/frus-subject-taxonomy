<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-11-17T18:00:00-05:00" frus:doc-dateTime-min="1919-11-17T18:00:00-05:00" n="231" subtype="historical-document" type="document" xml:id="d231">
                            <note rend="inline" type="source">860c.48/282a: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the <gloss type="to">Commission to
                                        Negotiate Peace</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1919-11-17T18:00:00-05:00"><hi rend="italic">November
                                            17, 1919—6 p.m.</hi></date></dateline></opener>
                            <p>3797. For Polk.</p>
                            <p>President authorized Julius H. Barnes, United States Wheat Director
                                and President Grain Corporation, to sell to Polish Government on
                                credit or otherwise 100,000 tons of wheat and wheat flour. Please
                                inform Warsaw.</p>
                            <closer><signed><hi rend="smallcaps">Lansing</hi></signed></closer>
                        </div>
                        </body></text></TEI>