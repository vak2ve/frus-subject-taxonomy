    <text>
        <body>
            <div frus:doc-dateTime-max="1920-01-10T23:59:59-05:00"
                frus:doc-dateTime-min="1920-01-10T00:00:00-05:00" n="15"
                subtype="historical-document" type="document" xml:id="d15">
                <note rend="inline" type="source">763.72119/8622: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Wallace</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1920-01-10">
                            <hi rend="italic">January 10, 1920</hi>
                        </date>.<lb/>[Received January 11—12:17 a.m.]</dateline>
                </opener>
                <p>90. Mission. It was decided this morning that the first meeting of the Council of
                    League of Nations will be held at the Quai d’Orsay. Friday, January 16th, at
                    10:30 a.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wallace</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
