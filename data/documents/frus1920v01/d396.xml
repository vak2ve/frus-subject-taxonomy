                subtype="historical-document" type="document" xml:id="d396">
                <note rend="inline" type="source">824.00/150: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Bolivia</hi> (<persName type="from">
                        <hi rend="italic">Maginnis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">La Paz</hi>
                        </placeName>, <date calendar="gregorian" when="1920-11-23T15:00:00-04:32">
                            <hi rend="italic">November 23, 1920—3 p.m.</hi>
                        </date>
                        <lb/>[Received 10:30 p.m.]</dateline>
                </opener>
                <p>147. Italy recognized yesterday. Only countries of importance that have not
                    recognized to date are United States, Brazil, Chile, Argentine, and Colombia.
                    Understand that representatives of all these countries are strongly recommending
                    recognition and their Governments are awaiting our action.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Maginnis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
