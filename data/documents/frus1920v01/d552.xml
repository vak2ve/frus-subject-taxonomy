                subtype="historical-document" type="document" xml:id="d552">
                <note rend="inline" type="source">893.51/2912: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in France</hi> (<persName type="from">
                        <hi rend="italic">Harrison</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1920-08-03T18:00:00+01:00">
                            <hi rend="italic">August 3, 1920—6 p.m.</hi>
                        </date>
                        <lb/>[Received 10:18 p.m.]</dateline>
                </opener>
                <p>1499. Your 1320, July 31st, 6 p.m. In accordance with your request Foreign Office
                    made no announcement.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Harrison</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
