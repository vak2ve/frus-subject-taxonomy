<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-12-24T15:00:00-05:00" frus:doc-dateTime-min="1920-12-24T15:00:00-05:00" n="587" subtype="historical-document" type="document" xml:id="d587">
                            <note rend="inline" type="source">893.51/3154: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Minister in China</hi> (<persName type="to"><hi rend="italic">Crane</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1920-12-24T15:00:00-05:00"><hi rend="italic">December
                                            24, 1920—3 p.m.</hi></date></dateline></opener>
                            <p>392. Your 460, December 22, 9 p.m.<note n="41" xml:id="d587fn41">Not
                                    printed.</note></p>
                            <p>Department accepts suggestion of British Legation that additional
                                confidential correspondence including American texts which are to be
                                made public should be communicated to Chinese Government before
                                publication.</p>
                            <closer><signed><hi rend="smallcaps">Davis</hi></signed></closer>
                        </div>
                        </body></text></TEI>