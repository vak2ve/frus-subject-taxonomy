                subtype="historical-document" type="document" xml:id="d854">
                <note rend="inline" type="source">393.116/205: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Crane</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1920-06-19T15:00:00+08:00">
                            <hi rend="italic">June 19, 1920—3 p.m.</hi>
                        </date>
                        <lb/>[Received June 19—9:45 a.m.]</dateline>
                </opener>
                <p>140. Your June 17, 5 p.m.<note n="53" xml:id="d854fn53">“Telegraph name of
                        murdered missionary.” (File no. 393.116/204.)</note> Name of murdered
                    missionary William A. Reimert of the Reform Church.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Crane</hi>
                    </signed>
                </closer>
            </div>
        </body>
