<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-08-13T08:00:00-05:00" frus:doc-dateTime-min="1920-08-13T08:00:00-05:00" n="556" subtype="historical-document" type="document" xml:id="d556">
                            <note rend="inline" type="source">893.51/2926: Telegram</note>
                            <head><hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from"><hi rend="italic">Davis</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1920-08-13T14:00:00+01:00"><hi rend="italic">August
                                            13, 1920—2 p.m.</hi></date><lb/>[Received August
                                    13—10:47 a.m.]</dateline></opener>
                            <p>1225. My 1216, August 12, 5 p.m.<note n="79" xml:id="d556fn79">Not
                                    printed.</note> Foreign Office has now telegraphed Peking its
                                approval of draft text of announcement to Chinese Government
                                concerning consortium. Paris informed.</p>
                            <closer><signed><hi rend="smallcaps">Davis</hi></signed></closer>
                        </div>
                        </body></text></TEI>