                subtype="historical-document" type="document" xml:id="d395">
                <note rend="inline" type="source">824.00/145: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Bolivia</hi> (<persName type="to">
                        <hi rend="italic">Maginnis</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-11-22T18:00:00-05:00">
                            <hi rend="italic">November 22, 1920—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>75. Your November 15, 4 p.m.</p>
                <p>Please cable at once full report of election returns and all available
                    information which you have been able to obtain regarding conduct of the
                    elections. Has any date been set as yet for the next session of Congress.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
