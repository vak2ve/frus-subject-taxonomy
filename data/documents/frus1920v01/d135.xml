    <text>
        <body>
            <div frus:doc-dateTime-max="1920-09-15T23:59:59-05:00"
                frus:doc-dateTime-min="1920-09-15T00:00:00-05:00" n="135"
                subtype="historical-document" type="document" xml:id="d135">
                <note rend="inline" type="source">574.D1/139a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Japanese Ambassador</hi> (<persName type="to">
                        <hi rend="italic">Shidehara</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-09-15">
                            <hi rend="italic">September 15, 1920</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to inform you that, at
                    the instance of the French Government, and owing to the fact that the French
                    delegation, as well as the English delegation, will not arrive at Washington in
                    time for the Preliminary Conference on Communications scheduled for September
                    fifteen, it has been found necessary to postpone the opening of this Conference
                    until October eight.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bainbridge Colby</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
