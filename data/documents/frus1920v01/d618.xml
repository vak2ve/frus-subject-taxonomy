<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-02-12T17:00:00-05:00" frus:doc-dateTime-min="1920-02-12T17:00:00-05:00" n="618" subtype="historical-document" type="document" xml:id="d618">
                            <note rend="inline" type="source">893.51/2658: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Chargé in China</hi> (<persName type="to"><hi rend="italic">Tenney</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1920-02-12T17:00:00-05:00"><hi rend="italic">February
                                            12, 1920—5 p.m.</hi></date></dateline></opener>
                            <p>39. Your 37, February 10, 6 p.m.</p>
                            <p>Department fully approves your insistence upon joint negotiations and
                                joint signature of the loan agreement by the four national
                                groups.</p>
                            <closer><signed><hi rend="smallcaps">Lansing</hi></signed></closer>
                        </div>
                        </body></text></TEI>