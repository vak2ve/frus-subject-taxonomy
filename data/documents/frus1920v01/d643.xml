<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-08-03T23:00:00-05:00" frus:doc-dateTime-min="1920-08-03T23:00:00-05:00" n="643" subtype="historical-document" type="document" xml:id="d643">
                            <note rend="inline" type="source">893.51/2913: Telegram</note>
                            <head><hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">Crane</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1920-08-04T12:00:00+08:00"><hi rend="italic">August 4,
                                            1920—noon</hi></date>.<lb/>[Received August 4—5:08
                                    a.m.]</dateline></opener>
                            <p>212. Your July 29th, 10 p.m. to Tokyo repeated Peking. Shall I
                                consider this an [instruction] to present telegraphed text to
                                Chinese Foreign Office?</p>
                            <closer><signed><hi rend="smallcaps">Crane</hi></signed></closer>
                        </div>
                        </body></text></TEI>