    <text>
        <body>
            <div frus:doc-dateTime-max="1920-12-21T22:00:00-05:00"
                frus:doc-dateTime-min="1920-12-21T22:00:00-05:00" n="672"
                subtype="historical-document" type="document" xml:id="d672">
                <note rend="inline" type="source">893.51/3150: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Crane</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1920-12-22T11:00:00+08:00">
                            <hi rend="italic">December 22, 1920—11 a.m.</hi>
                        </date>
                        <lb/>[Received December 22—6:30 a.m.]</dateline>
                </opener>
                <p>453. Your 356, December 4, 3 p.m. Minister of Finance formally states that
                    Chinese American Bank of Commerce has already been instructed to remit interest
                    in full.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Crane</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
