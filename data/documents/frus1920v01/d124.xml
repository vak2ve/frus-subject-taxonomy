    <text>
        <body>
            <div frus:doc-dateTime-max="1920-05-30T23:00:00-05:00"
                frus:doc-dateTime-min="1920-05-30T23:00:00-05:00" n="124"
                subtype="historical-document" type="document" xml:id="d124">
                <note rend="inline" type="source">574.D1/51: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Japan</hi> (<persName type="from">
                        <hi rend="italic">Bell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1920-05-31T13:00:00+09:00">
                            <hi rend="italic">May 31, 1920—1 p.m.</hi>
                        </date>
                        <lb/>[Received May 31—4:36 a.m.]</dateline>
                </opener>
                <p>271. Department’s 133, April 8, 5 p.m.<note n="98" xml:id="d124fn98">Not printed;
                        see note of Apr. 8 to the British Chargé, <ref target="#pg_116">p.
                        116</ref>.</note> Japanese Government has decided to send a representative
                    to Preliminary Conference August 1st, provided that the majority of the
                    Principal Allied and Associated Governments participate in Preliminary
                    Conference.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
