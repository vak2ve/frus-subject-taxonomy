                subtype="historical-document" type="document" xml:id="d526">
                <note rend="inline" type="source">893.51/2851: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in China</hi> (<persName type="to">
                        <hi rend="italic">Crane</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1920-06-28T17:00:00-04:00">
                            <hi rend="italic">June 28, 1920—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>156. Your 149, June 26, noon.</p>
                <p>Notes approved by this Government on March 30th. Tokyo is being instructed to
                    repeat to you Department’s 112, March 30, 5 p.m.<note n="32" xml:id="d526fn32">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_521">p. 521</ref>.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Davis</hi>
                    </signed>
                </closer>
            </div>
        </body>
