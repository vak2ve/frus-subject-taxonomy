<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1947-02-13T18:00:00-05:00" frus:doc-dateTime-min="1947-02-13T18:00:00-05:00" n="297" subtype="historical-document" type="document" xml:id="d297">
                        <note rend="inline" type="source">740.00119 PW/2–1347: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                General of the Army <persName type="to">Douglas
                                MacArthur</persName>, at Tokyo</hi>
                        </head>
                        <opener>
                            <seg rendition="#left">
                                <hi rend="smallcaps">secret</hi>
                            </seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1947-02-13T18:00:00-05:00">February
                                    13, 1947—6 p.m.</date>
                            </dateline>
                        </opener>
                        <p>48. Personal for General MacArthur from Ambassador Atcheson. Understand
                            that advanced transfer paper introduced today in <gloss target="#t_FEC1">FEC</gloss> against background of US Govt decision to issue interim
                            directive if Commission does not act favorably on paper in question
                            within approximately 2 weeks.<note n="35" xml:id="d297fn35">For report
                                on action taken, see telegram 54 (<gloss target="#t_FEC1">FEC</gloss> 8), February 19, to Tokyo, <ref target="#pg_359">p.
                                    359</ref>.</note> [Atcheson.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Marshall</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>