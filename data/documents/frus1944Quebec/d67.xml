<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1944-09-12T23:59:59-05:00" frus:doc-dateTime-min="1944-09-12T00:00:00-05:00" n="67" subtype="historical-document" type="document" xml:id="d67">
                        <note rend="inline" type="source">Roosevelt Papers: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">President</gloss> to the War
                                Shinning Administrator</hi> (<persName type="to"><hi rend="italic">Land</hi></persName>)<note n="1" xml:id="d67fn1">Sent to the
                                White House Map Room at Washington. The message was delivered to
                                Land by Major Henry W. Putnam of the Map Room staff on the evening
                                of September 12.</note></head>
                        <opener>
                            <dateline rendition="#right">[<placeName><hi rend="smallcaps">Quebec</hi></placeName>,] <date calendar="gregorian" when="1944-09-12">12 September 1944</date>.</dateline>
                        </opener>
                        <p>Please come to Quebec without delay.</p>
                    </div>
                    </body></text></TEI>