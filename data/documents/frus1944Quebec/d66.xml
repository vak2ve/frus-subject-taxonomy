                subtype="historical-document" type="document" xml:id="d66">
                <note rend="inline" type="source">Roosevelt Papers: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">President</gloss> to the Secretary of
                        the Treasury</hi> (<persName type="to">
                        <hi rend="italic">Morgenthau</hi>
                    </persName>)<note n="1" xml:id="d66fn1">Sent to the White House Map Room at
                        Washington. The message was delivered to Morgenthau at his farm at Fishkill,
                        New York, by a Secret Service agent on the evening of September 12.</note>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Quebec</hi>
                        </placeName>,] <date calendar="gregorian" when="1944-09-12">12 September
                            1944</date>.</dateline>
                </opener>
                <p>Please be in Quebec by Thursday, 14 September, Noon.</p>
            </div>
        </body>
    </text>
