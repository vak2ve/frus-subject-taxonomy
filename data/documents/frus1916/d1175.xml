<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-01-24T11:23:00-05:00" frus:doc-dateTime-min="1916-01-24T11:23:00-05:00" n="1175" subtype="historical-document" type="document" xml:id="d1175">
                        <note rend="inline" type="source">File No. 812.113/3885</note>
                        <head>
                            <hi rend="italic">Consul <persName type="from">Hostetter</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Hermosillo</hi></placeName>, <date calendar="gregorian" when="1916-01-24T09:00:00-07:23">
                                    <hi rend="italic">January 24, 1916, 9 a.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Department’s January 21, 6 p.m. Shipments referred to in no danger at
                            present time of falling into wrong hands.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hostetter</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>