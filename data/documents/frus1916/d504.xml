                <note rend="inline" type="source">File No. 365.117/469</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Penfield</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1916-12-02">
                            <hi rend="italic">December 2, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>1559. The Austro-Hungarian Government has consented to repatriation Frank Ghiloni
                    via Switzerland and France. War Office expresses the hope necessary arrangements
                    be made for his uninterrupted return.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Penfield</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
