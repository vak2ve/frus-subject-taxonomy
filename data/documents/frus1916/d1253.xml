                subtype="historical-document" type="document" xml:id="d1253">
                <note rend="inline" type="source">File No. 817.812/224</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Chargé d’Affaires of Nicaragua</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-06-21">
                            <hi rend="italic">June 21, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 18th instant in which you inform me of your readiness to effect
                    the exchange of ratifications of the treaty signed on August 5, 1914 between the
                    United States and Nicaragua and request the designation of the time when the
                    exchange may take place.</p>
                <p>In reply I have the honor to inform you that I shall be happy to receive you for
                    the purpose of consummating this formality on Thursday, the 22d instant, at
                    two-thirty o’clock p.m.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
