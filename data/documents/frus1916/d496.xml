                subtype="historical-document" type="document" xml:id="d496">
                <note rend="inline" type="source">File No. 365.117/395</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Penfield</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1916-08-02">
                            <hi rend="italic">August 2, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>1366. German passport office now state under instructions its Government unable
                    visé passport Ghiloni. Facts case were fully explained. Requests
                    instructions.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Penfield</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
