                subtype="historical-document" type="document" xml:id="d541">
                <note rend="inline" type="source">File No. 751.8215/83</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Curtis</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1916-03-17T11:00:00-00:43">
                            <hi rend="italic">March 17, 1916, 11 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="italic">Chester</hi> arrived yesterday with arms and ammunition,
                    delivered this morning Secretary of War, designated for such purpose by me.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Curtis</hi>
                    </signed>
                </closer>
            </div>
        </body>
