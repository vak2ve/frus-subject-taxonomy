<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-11-25T16:00:00-05:00" frus:doc-dateTime-min="1916-11-25T16:00:00-05:00" n="867" subtype="historical-document" type="document" xml:id="d867">
                        <note rend="inline" type="source">File No. 124.123/130</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Mr. <persName type="to">Thurston</persName>, in
                                charge of American interests</hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1916-11-25T16:00:00-05:00">
                                    <hi rend="italic">November 25, 1916, 4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Action reported your 577 approved.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Polk</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>