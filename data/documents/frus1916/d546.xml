<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-06-05T16:00:00-05:00" frus:doc-dateTime-min="1916-06-05T16:00:00-05:00" n="546" subtype="historical-document" type="document" xml:id="d546">
                        <note rend="inline" type="source">File No. 882.51/694a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Curtis</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1916-06-05T16:00:00-05:00">
                                    <hi rend="italic">June 5, 1916, 4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Department hears Liberian Government proposes to discontinue payment loan
                            interest after July 1. Cable facts.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>