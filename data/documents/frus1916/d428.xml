<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-07-12T13:49:00-05:00" frus:doc-dateTime-min="1916-07-12T13:49:00-05:00" n="428" subtype="historical-document" type="document" xml:id="d428">
                        <note rend="inline" type="source">File No. 838.77/135</note>
                        <head>
                            <hi rend="italic">Minister <persName type="from">Blanchard</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Legation</hi>, <lb/>
                                    <hi rend="italic">Port au Prince</hi></placeName>, <date calendar="gregorian" when="1916-07-12T14:00:00-04:49">
                                    <hi rend="italic">July 12, 1916, 2 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Your July 11, 4 p.m. Minister of Foreign Affairs states information, not
                            instructions, with reference to National Railroad asked for by Minister
                            Ménos is being prepared by Department of Public Works and will be
                            forwarded at the earliest possible moment.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Blanchard</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>