<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-07-17T17:00:00-05:00" frus:doc-dateTime-min="1916-07-17T17:00:00-05:00" n="1030" subtype="historical-document" type="document" xml:id="d1030">
                        <note rend="inline" type="source">File No. 812.48/3322</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to Consul <persName type="to">Garrett</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1916-07-17T17:00:00-05:00">
                                    <hi rend="italic">July 17, 1916, 5 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>You are authorized to employ messenger, and to furnish destitute
                            Americans at Chamal transportation in accordance with Department’s July
                            13, 6 p.m.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Polk</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>