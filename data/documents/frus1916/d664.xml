                subtype="historical-document" type="document" xml:id="d664">
                <note rend="inline" type="source">File No. 312.115 C 96/151</note>
                <head>
                    <hi rend="italic">Consul <persName type="from">Letcher</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">El Paso</hi>
                        </placeName>, <date calendar="gregorian" when="1916-04-23T12:00:00-07:00">
                            <hi rend="italic">April 23, 1916, noon</hi>
                        </date>.</dateline>
                </opener>
                <p>General Gutierrez informs me that Pablo Lopez was brought from Santa Ysabel last
                    night and is now in penitentiary here, and that he has confessed to massacre of
                    Americans at Santa Ysabel on January 10 last.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Letcher</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
