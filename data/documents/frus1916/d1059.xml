<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-05-07T13:36:00-05:00" frus:doc-dateTime-min="1916-05-07T13:36:00-05:00" n="1059" subtype="historical-document" type="document" xml:id="d1059">
                        <note rend="inline" type="source">File No. 812.512/1187</note>
                        <head>
                            <hi rend="italic">Special Representative <persName type="from">Rodgers</persName> to the <gloss type="to">Secretary of
                                    State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Mexico City</hi></placeName>, <date calendar="gregorian" when="1916-05-07T12:00:00-06:36">
                                    <hi rend="italic">May 7, 1916, noon</hi></date>.</dateline>
                        </opener>
                        <p>46. Department’s 70, May 6, 6 p.m. Mining law effective May 1,
                            practically same as that transmitted with mail despatch 25. Minor
                            modifications only.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Rodgers</hi>
                            </signed>
                        </closer>
                    </div>
