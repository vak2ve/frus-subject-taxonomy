                subtype="historical-document" type="document" xml:id="d133">
                <note rend="inline" type="source">File No. 893.811/230</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Reinsch</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-07-03">
                            <hi rend="italic">July 3, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>Your June 26. See cable of International Corporation to Gatrell of June 29.
                    Cooperate with Gatrell along lines mentioned.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
