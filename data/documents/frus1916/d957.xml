                subtype="historical-document" type="document" xml:id="d957">
                <note rend="inline" type="source">File No. 312.11/8255</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Vice
                        Consul <persName type="to">Blocker</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-12-08T17:00:00-05:00">
                            <hi rend="italic">December 8, 1916, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Continue to exert your very best efforts to obtain definite information regarding
                    Americans at Parral, Jimenez and Santa Rosalia, and keep Department promptly
                    informed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
