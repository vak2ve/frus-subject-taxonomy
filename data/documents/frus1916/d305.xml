<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-03-04T23:59:59-05:00" frus:doc-dateTime-min="1916-03-04T00:00:00-05:00" n="305" subtype="historical-document" type="document" xml:id="d305">
                        <note rend="inline" type="source">File No. 351.117/71</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Ambassador <persName type="to">Sharp</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1916-03-04">
                                    <hi rend="italic">March 4, 1916</hi></date>.</dateline>
                        </opener>
                        <p>1406. Louis Levy, born in New York City March 10, 1882, of French father,
                            is applying for removal his name from French military rolls. Extend good
                            offices his behalf.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>