<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-11-22T23:59:59-05:00" frus:doc-dateTime-min="1916-11-22T00:00:00-05:00" n="29" subtype="historical-document" type="document" xml:id="d29">
                        <note rend="inline" type="source">File No. 863.001P85/8</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Chargé d’Affaires of
                                    Austria-Hungary</gloss> to the <gloss type="to">Secretary of
                                    State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Translation]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Austro-Hungarian Embassy</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1916-11-22">
                                    <hi rend="italic">November 22, 1916</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Excellency</hi>: I have the sad duty of informing
                            your excellency that His Imperial and Royal Apostolic Majesty Franz
                            Joseph I, my most gracious master, died at 5 minutes after 9 o’clock in
                            the evening of November 21, after a short illness. I am instructed to
                            request your excellency to bring this sad news to the knowledge of His
                            Excellency the President of the United States.</p>
                        <p>Accept [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">E. Zwiedinek</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>