                subtype="historical-document" type="document" xml:id="d511">
                <note rend="inline" type="source">File No. 761.94/96</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Guthrie</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1916-06-30T12:00:00+09:00">
                            <hi rend="italic">June 30, 1916, noon</hi>
                        </date>.</dateline>
                </opener>
                <p>I am informed that the Privy Council yesterday approved Russo-Japanese convention
                    and that Foreign Office states that announcement will be made simultaneously at
                    Petrograd and Tokyo and that terms given by papers are incorrect.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Guthrie</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
