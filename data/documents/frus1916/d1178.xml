<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-05-01T23:59:59-05:00" frus:doc-dateTime-min="1916-05-01T00:00:00-05:00" n="1178" subtype="historical-document" type="document" xml:id="d1178">
                        <note rend="inline" type="source">File No. 812.113/4115</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Adjutant General</gloss> to
                                General <persName type="to">Funston</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">War Department</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1916-05-01">
                                    <hi rend="italic">May 1, 1916</hi></date>.</dateline>
                        </opener>
                        <p>Secretary of War directs until further orders have been issued stop all
                            arms and munitions of war from going into Mexico.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">McCain</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>