                <note rend="inline" type="source">File No. 351.117/95</note>
                <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>
                        </placeName>, <lb/>
                        <date calendar="gregorian" when="1916-09-15">
                            <hi rend="italic">September 15, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>1600. Have ascertained regiment of Garrot and will report result of investigation
                    which I am today requesting of Foreign Office.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bliss</hi>
                    </signed>
                </closer>
            </div>
        </body>
