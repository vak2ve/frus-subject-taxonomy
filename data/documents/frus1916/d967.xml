                subtype="historical-document" type="document" xml:id="d967">
                <note rend="inline" type="source">File No. 312.11/7388</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Collector
                            <persName type="to">Cobb</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-03-10T16:00:00-05:00">
                            <hi rend="italic">March 10, 1916, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your March 9, 2 p.m. Advise Mormons to take every possible precautionary measure
                    for their safety.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
