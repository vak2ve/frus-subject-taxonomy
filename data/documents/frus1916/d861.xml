<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-09-20T20:36:00-05:00" frus:doc-dateTime-min="1916-09-20T20:36:00-05:00" n="861" subtype="historical-document" type="document" xml:id="d861">
                        <note rend="inline" type="source">File No. 812.516/135</note>
                        <head>
                            <hi rend="italic">Mr. <persName type="from">Parker</persName>,
                                representing American interests, to the <gloss type="to">Secretary
                                    of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Mexico City</hi></placeName>, <date calendar="gregorian" when="1916-09-20T19:00:00-06:36">
                                    <hi rend="italic">September 20, 1916, 7 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>408. My 388, September 10, 10 p.m. The banks mentioned were forced to pay
                            the four hundred thousand pesos in specie.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Parker</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>