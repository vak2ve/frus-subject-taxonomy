<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-12-28T23:59:59-05:00" frus:doc-dateTime-min="1916-12-28T00:00:00-05:00" n="506" subtype="historical-document" type="document" xml:id="d506">
                        <note rend="inline" type="source">File No. 365.117/475</note>
                        <head>
                            <hi rend="italic">Ambassador <persName type="from">Sharp</persName> to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Embassy</hi>, <lb/>
                                    <hi rend="italic">Paris</hi></placeName>, <date calendar="gregorian" when="1916-12-28">
                                    <hi rend="italic">December 28, 1916</hi></date>.</dateline>
                        </opener>
                        <p>1765. Your 1871, December 8. Foreign Office informs me matter has been
                            referred to competent department of the Government which has not yet
                            replied. Will hasten answer as much as possible.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Sharp</hi>
                            </signed>
                        </closer>
                    </div>
                </body></text></TEI>