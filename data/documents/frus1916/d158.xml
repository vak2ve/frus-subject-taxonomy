                subtype="historical-document" type="document" xml:id="d158">
                <note rend="inline" type="source">File No. 893.77/1494</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Reinsch</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1915-12-17T16:00:00-05:00">
                            <hi rend="italic">December 17, 1915, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your cipher telegram of November 26, 3 p.m. Use of template and spacing machines
                    makes all spans exact duplicates. This with inspection by consulting engineer
                    should be sufficient. Full reply by mail.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
