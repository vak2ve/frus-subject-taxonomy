<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1915-12-29T17:00:00-05:00" frus:doc-dateTime-min="1915-12-29T17:00:00-05:00" n="836" subtype="historical-document" type="document" xml:id="d836">
                        <note rend="inline" type="source">File No. 812.516/113</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Special Agent <persName type="to">Silliman</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Extract]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1915-12-29T17:00:00-05:00">
                                    <hi rend="italic">December 29, 1915, 5 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Your suggestion regarding commission representing banking interests
                            meeting General Carranza has been communicated to Parker.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>