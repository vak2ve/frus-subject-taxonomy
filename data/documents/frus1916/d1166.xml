<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-09-11T16:00:00-05:00" frus:doc-dateTime-min="1916-09-11T16:00:00-05:00" n="1166" subtype="historical-document" type="document" xml:id="d1166">
                        <note rend="inline" type="source">File No. 312.115/274</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Vice Consul <persName type="to">Blocker</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1916-09-11T16:00:00-05:00">
                                    <hi rend="italic">September 11, 1916, 4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Your telegram June 20, 10 a.m. Parker, Mexico City, telegraphs Foreign
                            Office denies confiscation property on American ranches along
                            border.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>