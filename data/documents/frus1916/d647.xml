                subtype="historical-document" type="document" xml:id="d647">
                <note rend="inline" type="source">File No. 812.00/17907</note>
                <head>
                    <hi rend="italic">General <persName type="from">Funston</persName> to the <gloss
                            type="to">Adjutant General</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Fort Sam Houston</hi>
                        </placeName>, <date calendar="gregorian" when="1916-04-16">
                            <hi rend="italic">April 16, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>Following is from General Pershing: <quote rend="blockquote">
                        <p>Report Villa has gone southwest San Borja. No food, no forage of any
                            description vicinity Santa Cruz where troops now are. Shall withdraw
                            them by easy marches in direction of Satevo. Can not supply them from
                            San Antonio. I am <hi rend="italic">en route</hi> to Namiquipa.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Funston</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
