                <note rend="inline" type="source">File No. 812.48/3218a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                            <persName type="to">Canada</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-06-24T17:00:00-05:00">
                            <hi rend="italic">June 24, 1916, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Ward Line has instructed its Vera Cruz agent regarding transportation of refugees
                    on <hi rend="italic">Monterey</hi>. Confer with agent.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
