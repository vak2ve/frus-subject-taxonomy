                subtype="historical-document" type="document" xml:id="d365">
                <note rend="inline" type="source">File No. 838.51/461</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Blanchard</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>. <lb/>
                            <hi rend="italic">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1916-01-06T17:00:00-04:49">
                            <hi rend="italic">January 6, 1916, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your December 31, 1 p.m.<note n="2" xml:id="d365fn2">
                        <ref target="frus1915#pg_537">For. Rel. 1915, p. 537</ref>.</note> After
                    conference with Minister for Foreign Affairs and Minister of Finance reforms
                    desired agreed to by the Government and instructions now being carried out by
                    the Admiral.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blanchard</hi>
                    </signed>
                </closer>
            </div>
        </body>
