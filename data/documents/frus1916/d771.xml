                <note rend="inline" type="source">File No. 812.00/18689b</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                            <persName type="to">Dawson</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-07-01T13:00:00-05:00">
                            <hi rend="italic">July 1, 1916, 1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Cable full information regarding U. S. Naval launch being fired upon by Carranza
                    soldiers and mail any affidavits obtainable.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
