                subtype="historical-document" type="document" xml:id="d691">
                <note rend="inline" type="source">File No. 812.00/18073</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Vice
                        Consul <persName type="to">Blocker</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-05-07">
                            <hi rend="italic">May 7, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>Your May 7. Cooperate with Collector Customs and military commander, Eagle Pass,
                    in every way possible, in order to facilitate recovery of bodies of murdered
                    Americans and to provide such measure of safety as is possible for the families
                    of the victims. Keep Department fully and promptly informed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
