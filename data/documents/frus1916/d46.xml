                subtype="historical-document" type="document" xml:id="d46">
                <note rend="inline" type="source">File No. 711.9321/3</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Reinsch</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1916-06-30">
                            <hi rend="italic">June 30, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>Exchange of notes effected today terminating as from tomorrow the sentences
                    specified in your telegram April 21.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Reinsch</hi>
                    </signed>
                </closer>
            </div>
        </body>
