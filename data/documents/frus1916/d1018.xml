<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-06-28T18:00:00-05:00" frus:doc-dateTime-min="1916-06-28T18:00:00-05:00" n="1018" subtype="historical-document" type="document" xml:id="d1018">
                        <note rend="inline" type="source">File No. 312.11/7911</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Collector <persName type="to">Cobb</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1916-06-28T18:00:00-05:00">
                                    <hi rend="italic">June 28, 1916, 6 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Following telegram to-day being sent to American Consuls still in Mexico,
                            including border Consuls: [Telegram to Consul Dawson, June 28, 1916,
                            follows.]</p>
                        <p>Act in accordance therewith.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>