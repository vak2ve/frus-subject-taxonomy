    <text>
        <body>
            <div frus:doc-dateTime-max="1916-02-28T23:59:59-05:00"
                frus:doc-dateTime-min="1916-02-28T00:00:00-05:00" n="564"
                subtype="historical-document" type="document" xml:id="d564">
                <note rend="inline" type="source">File No. 123 R 61/167a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                        General <persName type="to">Rodgers</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-02-28">
                            <hi rend="italic">February 28, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: You are hereby instructed to proceed to Mexico
                    for duty as Special Representative of the Department of State near the <hi
                        rend="italic">de facto</hi> Government of Mexico, for the purpose of
                    carrying out the instructions which have been orally given to you at the
                    Department and such other instructions as may from time to time be issued to
                    you.</p>
                <p>You are authorized to travel to such points in Mexico as you may find necessary
                    in the carrying out of these instructions and your actual and necessary expenses
                    will be paid by the Department upon rendition by you of a separate account
                    supported by proper vouchers.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
