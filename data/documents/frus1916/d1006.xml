                subtype="historical-document" type="document" xml:id="d1006">
                <note rend="inline" type="source">File No. 812.48/3205</note>
                <head>
                    <hi rend="italic">Consul <persName type="from">Guyant</persName> to the <gloss
                            type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Consulate</hi>, <lb/>
                            <hi rend="italic">Progreso</hi>
                        </placeName>, <date calendar="gregorian" when="1916-06-22">
                            <hi rend="italic">June 22, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>Can get Porto Ricans out on freighter <hi rend="italic">New Orleans</hi>
                    seventeen dollars each, sailing probably Sunday. Wire authorization, if
                    approved, and make necessary arrangements, quarantine authorities establish
                    camp. Quickest action necessary.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Guyant</hi>
                    </signed>
                </closer>
            </div>
        </body>
