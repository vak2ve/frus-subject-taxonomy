                subtype="historical-document" type="document" xml:id="d1172">
                <note rend="inline" type="source">File No. 812.113/3884a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Consul
                            <persName type="to">Simpich</persName>
                    </hi>
                    <note n="2" xml:id="d1172fn2">Same to American Consuls, Juarez, Hermosillo,
                        Ensenada.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-01-21">
                            <hi rend="italic">January 21, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>Advise Department by telegraph, briefly and confidentially, from time to time,
                    whether, in your judgment, permission for shipments <pb facs="0864" n="788"
                        xml:id="pg_788"/> of munitions of war for industrial purposes to points in
                    your district should be withheld. Consideration should be given to the
                    possibility of such supplies falling into the hands of persons who might make
                    improper use of them.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
