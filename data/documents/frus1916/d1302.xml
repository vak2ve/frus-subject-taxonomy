                <head ana="#head_untitled-inferred-from-preceding-sibling-head">[Untitled]</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Panama</hi>
                        </placeName>, <date calendar="gregorian" when="1916-05-20T20:00:00-05:00">
                            <hi rend="italic">May 20, 1916, 8 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Delivery rifles in accordance with my telegram of May 15, completed. * * *</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Price</hi>
                    </signed>
                </closer>
