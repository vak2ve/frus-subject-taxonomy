                        <note rend="inline" type="source">File No. 812.00/18324</note>
                        <head>
                            <hi rend="italic">Special Representative <persName type="from">Rodgers</persName> to the <gloss type="to">Secretary of
                                    State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegrams]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Mexico City</hi></placeName>, <date calendar="gregorian" when="1916-06-06T15:00:00-06:36">
                                    <hi rend="italic">June 6, 1916, 3 p.m.</hi>
                                </date>
