<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-04-14T13:00:00-05:00" frus:doc-dateTime-min="1916-04-14T13:00:00-05:00" n="1242" subtype="historical-document" type="document" xml:id="d1242">
                        <note rend="inline" type="source">File No. 817.812/190</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Minister <persName type="to">Jefferson</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram—Extract]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1916-04-14T13:00:00-05:00">
                                    <hi rend="italic">April 14, 1916, 1 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Your April 11, 1 p.m. Department gratified to learn of the ratification
                            of Treaty by Nicaraguan Congress.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>