<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-03-11T16:00:00-05:00" frus:doc-dateTime-min="1916-03-11T16:00:00-05:00" n="970" subtype="historical-document" type="document" xml:id="d970">
                        <note rend="inline" type="source">File No. 312.11/7393</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Consul <persName type="to">Edwards</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1916-03-11T16:00:00-05:00">
                                    <hi rend="italic">March 11, 1916, 4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Request appropriate authorities to furnish adequate escort for Mormons
                            who may wish to withdraw from Casas Grandes.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>