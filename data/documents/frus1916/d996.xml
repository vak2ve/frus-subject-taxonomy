<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-06-20T17:00:00-05:00" frus:doc-dateTime-min="1916-06-20T17:00:00-05:00" n="996" subtype="historical-document" type="document" xml:id="d996">
                        <note rend="inline" type="source">File No. 312.11/7820a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the <gloss type="to">British Consul, Salina Cruz</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1916-06-20T17:00:00-05:00">
                                    <hi rend="italic">June 20, 1916, 5 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Situation demands you advise all Americans in your district to withdraw
                            from Mexico. Please act accordingly.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>