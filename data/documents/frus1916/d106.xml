                subtype="historical-document" type="document" xml:id="d106">
                <note rend="inline" type="source">File No. 893.00/2535</note>
                <head>
                    <hi rend="italic">Minister <persName type="from">Reinsch</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Legation</hi>, <lb/>
                            <hi rend="italic">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1916-10-31T01:00:00+08:00">
                            <hi rend="italic">October 31, 1916, 1 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>General Feng Kuo Chang elected Vice President by National Assembly on third
                    ballot with harmonizing effect.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Reinsch</hi>
                    </signed>
                </closer>
            </div>
        </body>
