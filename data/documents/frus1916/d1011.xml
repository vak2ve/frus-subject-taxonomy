<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-06-24T16:23:00-05:00" frus:doc-dateTime-min="1916-06-24T16:23:00-05:00" n="1011" subtype="historical-document" type="document" xml:id="d1011">
                        <note rend="inline" type="source">File No. 812.48/3212</note>
                        <head>
                            <hi rend="italic">Consul <persName type="from">Simpich</persName> to the
                                    <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Nogales, Arizona</hi></placeName>, <date calendar="gregorian" when="1916-06-24T14:00:00-07:23">
                                    <hi rend="italic">June 24, 1916, 2 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Does Department authorize furnishing transportation to destitutes from
                            border to homes in States, very few cases.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Simpich</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>