                subtype="historical-document" type="document" xml:id="d499">
                <note rend="inline" type="source">File No. 365.117/418</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Minister
                            <persName type="to">Stovall</persName>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1916-09-06">
                            <hi rend="italic">September 6, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>298. Department requesting permission Austrian authorities allow Frank Ghiloni
                    now detained Austria to return United States via Switzerland. If permission
                    granted Ghiloni will surrender passport now held and apply your office for
                    emergency passport return United States via France. Issue. He will explain
                    case.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
