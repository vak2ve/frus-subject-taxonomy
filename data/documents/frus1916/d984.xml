<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-05-11T17:00:00-05:00" frus:doc-dateTime-min="1916-05-11T17:00:00-05:00" n="984" subtype="historical-document" type="document" xml:id="d984">
                        <note rend="inline" type="source">File No. 312.11/7673</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Special Representative <persName type="to">Rodgers</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1916-05-11T17:00:00-05:00">
                                    <hi rend="italic">May 11, 1916, 5 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>75. If emergency should arise, every effort will be made to provide
                            facilities, at all Mexican coast ports, for accommodation American
                            refugees.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>