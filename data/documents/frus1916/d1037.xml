<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-11-20T23:59:59-05:00" frus:doc-dateTime-min="1916-11-20T00:00:00-05:00" n="1037" subtype="historical-document" type="document" xml:id="d1037">
                        <note rend="inline" type="source">File No. 312.11/8236</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                Vice Consul <persName type="to">Coen</persName>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State</hi>, <lb/>
                                    <hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1916-11-20">
                                    <hi rend="italic">November 20, 1916</hi></date>.</dateline>
                        </opener>
                        <p>Advise Americans in your district to withdraw from Mexico.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>