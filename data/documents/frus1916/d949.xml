<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1916-11-14T19:36:00-05:00" frus:doc-dateTime-min="1916-11-14T19:36:00-05:00" n="949" subtype="historical-document" type="document" xml:id="d949">
                        <note rend="inline" type="source">File No. 812.00/19865</note>
                        <head>
                            <hi rend="italic">Consul <persName type="from">Canada</persName> to the
                                    <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegrams]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">American Consulate</hi>, <lb/>
                                    <hi rend="italic">Vera Cruz</hi></placeName>, <date calendar="gregorian" when="1916-11-14T18:00:00-06:36">
                                    <hi rend="italic">November 14, 1916, 6 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Doctor E. L. Byrd badly, E. B. Parker and W. P. Gavin slightly injured,
                            Robert Du Boise dead from Inter-Oceanic Railway accident. Other names
                            not yet obtainable.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Canada</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>