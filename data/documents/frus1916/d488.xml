    <text>
        <body>
            <div frus:doc-dateTime-max="1916-06-19T23:59:59-05:00"
                frus:doc-dateTime-min="1916-06-19T00:00:00-05:00" n="488"
                subtype="historical-document" type="document" xml:id="d488">
                <note rend="inline" type="source">File No. 365.117/362</note>
                <head>
                    <hi rend="italic">Ambassador <persName type="from">Penfield</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>, <lb/>
                            <hi rend="italic">Vienna</hi>
                        </placeName>, <date calendar="gregorian" when="1916-06-19">
                            <hi rend="italic">June 19, 1916</hi>
                        </date>.</dateline>
                </opener>
                <p>1308. Your 1215, May 8. Frank Ghiloni released and delivered to Embassy. Returns
                    via Scandinavia. Name of steamer and date of sailing will be reported when
                    ascertained. Request telegraphic authority to draw hundred dollars necessary
                    expenses.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Penfield</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
