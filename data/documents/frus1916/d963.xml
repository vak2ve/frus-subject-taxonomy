                subtype="historical-document" type="document" xml:id="d963">
                <note rend="inline" type="source">File No. 312.11/8313</note>
                <head>
                    <hi rend="italic">Vice Consul <persName type="from">Dickinson</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Consulate</hi>, <lb/>
                            <hi rend="italic">San Luis Potosi</hi>
                        </placeName>, <date calendar="gregorian" when="1916-12-25T13:00:00-06:36">
                            <hi rend="italic">December 25, 1916, 1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>American citizens from Magistral, Durango, J. T. Critchett, W. H. Seamon, Arthur
                    Heuser, William Kirchner, Karl Kirchner, <pb facs="0758" n="682" xml:id="pg_682"
                    /> Niebolar Kuig and wife, Charles Biekofsky, reported in Villista hands,
                    arrived here to-day.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dickinson</hi>
                    </signed>
                </closer>
            </div>
        </body>
