                subtype="historical-document" type="document" xml:id="d1101">
                <note rend="inline" type="source">103.9151/11–845: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Peru</hi> (<persName type="to">
                        <hi rend="italic">Trueblood</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1945-11-10T13:00:00-05:00"
                            >November 10, 1945—1 p.m.</date>
                    </dateline>
                </opener>
                <p>1012. Your 1126 November 8. Endeavor to persuade Foreign Minister to have suits
                    against Rubber Development Corporation suspended pending efforts to effect
                    reasonable direct settlements. Further instructions will follow.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Byrnes</hi>
                    </signed>
                </closer>
            </div>
        </body>
