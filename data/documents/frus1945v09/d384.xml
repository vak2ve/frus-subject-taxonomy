<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-10-24T23:59:59-05:00" frus:doc-dateTime-min="1945-10-24T00:00:00-05:00" n="384" subtype="historical-document" type="document" xml:id="d384">
                        <note rend="inline" type="source">835.918/10–2445: Telegram</note>
                        <head>
                            <hi rend="italic">The Chargé in Argentina</hi> (<persName type="from"><hi rend="italic">Cabot</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Buenos Aires</hi></placeName>, <date calendar="gregorian" when="1945-10-24">October 24,
                                1945</date>.<lb/>[Received 2:52 p.m.]</dateline>
                        </opener>
                        <p>2639. Yesterday <hi rend="italic">Time</hi> Magazine and <hi rend="italic">La Vanguardia</hi> refused by Post Office. I
                            complained about former to Foreign Office.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Cabot</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>