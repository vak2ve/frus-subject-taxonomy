<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>President Roosevelt to the
                        President of Paraguay (
                        Morínigo
                    )</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945v09</bibl><bibl type="frus-document-id">d1039</bibl><bibl type="frus-document-number">1039</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-02-08T00:00:00-05:00" notAfter="1945-02-08T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-02-08T23:59:59-05:00" frus:doc-dateTime-min="1945-02-08T00:00:00-05:00" n="1039" subtype="historical-document" type="document" xml:id="d1039">
                <note rend="inline" type="source">740.0011 E.W./2–845: Telegram</note>
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to the
                        President of Paraguay</hi> (<persName type="to">
                        <hi rend="italic">Morínigo</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1945-02-08">February 8,
                            1945</date>.</dateline>
                </opener>
                <p>Paraguay’s declaration of the existence of a state of war with the Axis is
                    further testimony of western hemisphere unity in the United Nations war against
                    aggression. Please accept my personal best wishes.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Franklin D. Roosevelt</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
