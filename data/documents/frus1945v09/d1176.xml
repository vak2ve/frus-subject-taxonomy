<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-10-27T17:00:00-05:00" frus:doc-dateTime-min="1945-10-27T17:00:00-05:00" n="1176" subtype="historical-document" type="document" xml:id="d1176">
                        <note rend="inline" type="source">831.01/10–2745: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Venezuela</hi> (<persName type="to"><hi rend="italic">Corrigan</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1945-10-27T17:00:00-05:00">October
                                    27, 1945—5 p.m.</date>
                            </dateline>
                        </opener>
                        <p>697. You are requested to address a note to the new Venezuelan FonMin for
                            presentation Tues, Oct 30 extending recognition of the new govt.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Byrnes</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>