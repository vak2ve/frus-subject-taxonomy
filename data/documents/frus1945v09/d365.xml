<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Ambassador in Argentina (
                        Braden
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945v09</bibl><bibl type="frus-document-id">d365</bibl><bibl type="frus-document-number">365</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-06-05T20:00:00-05:00" notAfter="1945-06-05T20:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-06-05T20:00:00-05:00" frus:doc-dateTime-min="1945-06-05T20:00:00-05:00" n="365" subtype="historical-document" type="document" xml:id="d365">
                <note rend="inline" type="source">835.918/6–545: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Argentina</hi> (<persName type="from">
                        <hi rend="italic">Braden</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1945-06-05T22:00:00-03:00">June 5, 1945—10 p.m.</date>
                        <lb/> [Received June 5—8:21 p.m.]</dateline>
                </opener>
                <p>1162. Arnaldo Cortesi<note n="5" xml:id="d365fn5">Correspondent for the <hi rend="italic">New York Times.</hi>
                    </note> warned this afternoon by Minister of Interior<note n="6" xml:id="d365fn6">Rear Adm. Alberto Teisaire.</note> that his dispatch to <hi rend="italic">N.Y. Times</hi> May 31 had caused Govt, great embarrassment,
                    that he should not be surprised at whatever might happen to him, and that Govt,
                    would not tolerate such articles in future.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Braden</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
