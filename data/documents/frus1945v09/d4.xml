<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-01-12T14:00:00-05:00" frus:doc-dateTime-min="1945-01-12T14:00:00-05:00" n="4" subtype="historical-document" type="document" xml:id="d4">
                            <note rend="inline" type="source">710 Conference W And PW/1–1245:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The Chargé in Costa Rica</hi> (<persName type="from"><hi rend="italic">Washington</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">San Jose</hi></placeName>, <date calendar="gregorian" when="1945-01-12T13:00:00-06:00">January 12, 1945—1 p.m.</date>
                                    <lb/> [Received 5:15 p.m.]</dateline>
                            </opener>
                            <p>34. Reference Department’s circular January 11, 7 p.m. Costa Rican
                                Foreign Minister<note n="5" xml:id="d4fn5">Julio Acosta
                                    García.</note> has informed me that he is in complete accord
                                with the agenda outlined in Department’s circular of January 5.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Washington</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>