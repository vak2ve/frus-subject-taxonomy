            <div frus:doc-dateTime-max="1945-11-16T23:59:59-05:00" frus:doc-dateTime-min="1945-11-16T00:00:00-05:00" n="502" subtype="historical-document" type="document" xml:id="d502">
                <note rend="inline" type="source">832.24/11–545: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Brazil</hi> (<persName type="to">
                        <hi rend="italic">Berle</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1945-11-16">November 16,
                            1945</date>.</dateline>
                </opener>
                <p>2628. Reurtel 3348, Nov. 5.<note n="82" xml:id="d502fn82">Not printed.</note>
                    Ahlers and Kidd<note n="83" xml:id="d502fn83">J. D. Ahlers and Philip C. Kidd,
                        officials of the Office of the Foreign Liquidation Commissioner.</note> are
                    to report directly to Foreign Liquidation Commissioner in Washington using same
                    communications facilities as Embassy in absence of War Dept. facilities. They
                    are to look to Foreign Liquidation Commissioner in Washington for directions
                    with respect to their function, but in all political matters will be guided by
                    Embassy.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Byrnes</hi>
                    </signed>
                </closer>
            </div>
