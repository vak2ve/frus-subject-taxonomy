<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1939-12-29T17:00:00-05:00" frus:doc-dateTime-min="1939-12-29T17:00:00-05:00" n="704" subtype="historical-document" type="document" xml:id="d704">
                        <note rend="inline" type="source">893.51/7017: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in the United Kingdom</hi> (<persName type="to"><hi rend="italic">Johnson</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1939-12-29T17:00:00-05:00">December
                                    29, 1939—5 p.m.</date>
                            </dateline>
                        </opener>
                        <p>1692. Your 2680, December 20. American group informs Hornbeck news
                            received of satisfactory settlement. Hornbeck proposes congratulations
                            to Butterworth.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                </body></text></TEI>