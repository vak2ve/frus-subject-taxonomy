                subtype="historical-document" type="document" xml:id="d21">
                <note rend="inline" type="source">762.94/319: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Japan</hi> (<persName type="from">
                        <hi rend="italic">Grew</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1939-04-19T16:00:00+09:00"
                            >April 19, 1939—4 p.m.</date>
                        <lb/> [Received April 19—3:46 a.m.]</dateline>
                </opener>
                <p>186. During the last few days I have received informal and personal assurances
                    from several well informed Japanese, of unimpeachable reliability, that I need
                    no longer worry over the possibility of Japan entering into a general alliance
                    with Germany and Italy.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grew</hi>
                    </signed>
                </closer>
            </div>
        </body>
