                <note rend="inline" type="source">740.00111A Arms Control-Transshipments/5:
                    Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName type="to">
                        <hi rend="italic">Bullitt</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1939-09-16T18:00:00-04:00"
                            >September 16, 1939—6 p.m.</date>
                    </dateline>
                </opener>
                <p>963. Your No. 1965, September 14, 5 p.m. The situation is clear. No further
                    explanation is necessary.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
