                subtype="historical-document" type="document" xml:id="d279">
                <note rend="inline" type="source">793.94119/G09: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Bullitt</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1939-11-09T18:00:00+00:00"
                            >November 9, 1939—6 p.m.</date>
                        <lb/> [Received November 9—2:52 p.m.]</dateline>
                </opener>
                <p>2706. My No. 2534, October 25 [<hi rend="italic">20</hi>], 5 p.m. Li Yu-ying
                    called on me this morning and stated that he had just received a personal
                    message from Chiang Kai-shek informing him that there was absolutely no truth in
                    the report that Germany had made any attempt to bring about peace between Japan
                    and China.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bullitt</hi>
                    </signed>
                </closer>
            </div>
        </body>
