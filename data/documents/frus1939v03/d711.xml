                subtype="historical-document" type="document" xml:id="d711">
                <note rend="inline" type="source">893.24/539: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Bullitt</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1939-02-22T00:00:00+00:00"
                            >February 22, 1939—midnight</date>.<lb/>[Received February 23—8:45
                        a.m.]</dateline>
                </opener>
                <p>341. Mandel, Minister of Colonies, stated to me last night that at the present
                    time there were no restrictions whatsoever on shipments of any sort over the
                    railroad through Indo-China.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bullitt</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
