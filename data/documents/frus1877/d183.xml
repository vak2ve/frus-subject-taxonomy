    <text>
        <body>
            <div frus:doc-dateTime-max="1877-09-20T23:59:59-05:00" frus:doc-dateTime-min="1877-09-20T00:00:00-05:00" n="183" subtype="historical-document" type="document" xml:id="d183">
                <head>No. 183.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Seward</persName> to Count <persName type="to">Litta</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1877-09-20">
                            <hi rend="italic">September</hi> 20,
                                    1877</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Count</hi>: I have the honor to acknowledge the
                            receipt of your note of the 15th instant, giving notice of a desire on
                            the part of the Government of Italy to terminate the consular convention
                            concluded with the United States February 8, 1868, in accordance with
                            the provisions of article 17 of the treaty. Be pleased to accept,
                            &amp;c.</p>
                <closer>
                    <signed>F. W. SEWAED,<lb/>
                        <hi rend="italic">Acting
                                Secretary</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
