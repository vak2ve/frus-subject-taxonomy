<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1876-12-04T23:59:59-05:00" frus:doc-dateTime-min="1876-12-04T00:00:00-05:00" n="149" subtype="historical-document" type="document" xml:id="d149">
                        <head>No. 149.<lb/><hi rend="italic">Mr. <persName type="from">Pierrepont</persName> to Mr. <persName type="to">Fish</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1876-12-04"><hi rend="italic">December</hi> 4,
                                1876</date>.</dateline></opener>
                        <p rend="flushleft"><hi rend="smallcaps">Fish</hi>, <hi rend="italic">Secretary, Washington:</hi></p>
                        <p>Brent arrested; heard; committed. Extradition-warrant will issue after
                            fifteen days. He says will not contest warrant. I shall appoint man to
                            take him.</p>
                        <p rend="center">* * * * * * *</p>
                        <closer><signed>PIERREPONT.</signed></closer>
                    </div>
                    </body></text></TEI>