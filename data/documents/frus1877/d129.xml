    <text>
        <body>
            <div frus:doc-dateTime-max="1876-11-06T23:59:59-05:00"
                frus:doc-dateTime-min="1876-11-06T00:00:00-05:00" n="129"
                subtype="historical-document" type="document" xml:id="d129">
                <head>No. 129.<lb/>
                    <hi rend="italic">Sir <persName type="from">Edward Thornton</persName> to Mr.
                            <persName type="to">Fish</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1876-11-06">
                            <hi rend="italic">November</hi> 6, 1876</date>. (Received November
                        7.)</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 2d instant, relative to the case of Peter Martin, held for
                    trial in British Columbia for an offense committed within the jurisdiction of
                    the United States, and to inform you that I have transmitted a copy of your note
                        <pb facs="0315" n="267" xml:id="pg_267"/> to the governor-general of the
                    Dominion of Canada, in order that inquiries may be made into the circumstances
                    of the case and such action taken as may be proper.</p>
                <p>I have the honor, &amp;c.,</p>
                <closer>
                    <signed>EDW’D THORNTON.</signed>
                </closer>
            </div>
        </body>
    </text>
