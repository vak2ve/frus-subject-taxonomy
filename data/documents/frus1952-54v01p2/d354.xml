                <head>
                    <hi rend="italic">Minutes of the Cabinet Meeting, Held at the White House, 10
                        a.m., January 29, 1954</hi>
                    <note n="1" xml:id="d354fn1">Prepared by Minnich.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">confidential</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>Washington</placeName>, <date
                            ana="#date_undated-inferred-from-document-head" calendar="gregorian"
                            when="1954-01-29T10:00:00-05:00">January 29, 1954, 10 a.m.</date>
                    </dateline>
                </opener>
                <list type="participants">
                    <item>The following were present: <list>
                            <item>President Eisenhower</item>
                            <item>Vice President Nixon</item>
                            <item>Under <gloss target="#t_SEC1">Sec</gloss>. of State W. B. Smith
                                (for <gloss target="#t_SEC1">Sec</gloss>. Dulles)</item>
                            <item>
                                <gloss target="#t_SEC1">Sec</gloss>. of Treasury Humphrey,
                                and</item>
                            <item>Under <gloss target="#t_SEC1">Sec</gloss>. Folsom</item>
                            <item>
                                <gloss target="#t_SEC1">Sec</gloss>. of Defense Wilson</item>
                            <item>Attorney General Brownell</item>
                            <item>Postmaster General</item>
                            <item>Summerfield</item>
                            <item>Deputy PMG Charles R.</item>
                            <item>Hook, Jr.</item>
                            <item>Asst. PMG for Personnel</item>
                            <item>Eugene Lyons</item>
                            <item>
                                <gloss target="#t_SEC1">Sec</gloss>. of Interior McKay</item>
                            <item>
