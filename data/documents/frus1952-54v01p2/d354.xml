                            <item>Under <gloss target="#t_SEC1">Sec</gloss>. of HEW Nelson</item>
                            <item>Rockefeller (for <gloss target="#t_SEC1">Sec</gloss>.
                                Hobby)</item>
                            <item>Deputy Director of Budget</item>
                            <item>Rowland R. Hughes (for Mr. Dodge)</item>
                            <item>Mr. Flemming</item>
                            <item>Gov. Stassen</item>
                            <item>Chairman Young</item>
                            <item>Amb. Lodge</item>
                            <item>Gov. Adams</item>
                            <item>Gen. Persons</item>
                            <item>Mr. Shanley</item>
                            <item>Mr. Rabb</item>
                            <item>Messrs. Morgan, Martin and Hauge (at intervals)</item>
