                                        <item>
                                                <list>
                                                  <head>
                                                  <hi rend="italic">
                                                  <gloss target="#t_NSC_1">NSC</gloss> Staff</hi>
                                                  </head>
                                                  <item>Lt. Gen. <persName corresp="#p_SBA_1">Brent
                                                  Scowcroft</persName>
                                                  </item>
                                                  <item>
                                                  <persName corresp="#p_LJM_1">Jan Lodal</persName>
                                                  </item>
                                                  <item>Dr. <persName corresp="#p_EDD_1">David
                                                  Elliott</persName>
                                                  </item>
                                                  <item>
                                                  <persName corresp="#p_HSJ_1">Stephen
                                                  Hadley</persName>
                                                  </item>
                                                  <item>
                                                  <persName corresp="#p_BJG_1">James
                                                  Barnum</persName>
                                                  </item>
