                                                  <head>
                                                  <hi rend="italic">
                                                  <gloss target="#t_ERDA_1">ERDA</gloss>
                                                  </hi>
                                                  </head>
                                                  <item>Dr. <persName corresp="#p_SRC_1">Robert
                                                  Seamans</persName>
                                                  </item>
                                                  <item>Dr. <persName corresp="#p_GE_1">Edward
                                                  Giller</persName>
                                                  </item>
