                subtype="historical-document" type="document" xml:id="d557">
                <note rend="inline" type="source">320/12–1251: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        United States Representative at the United Nations</hi> (<persName type="to">
                        <hi rend="italic">Austin</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                        <lb/>
                        <hi rend="smallcaps">priority</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1951-12-13T16:05:00-05:00"
                            >December 13, 1951—7:05 p.m.</date>
                    </dateline>
                </opener>
                <p>
                    <gloss target="#t_Gadel2">Gadel</gloss> 443. Re <gloss target="#t_Delga1"
                        >Delga</gloss> 623, Dec 12. Indians South Africa. <gloss target="#t_Dept1"
                        >Dept</gloss> endorses proposal develop strong backstage support to get
                    parties talking but believes in light considerations outlined <gloss
                        target="#t_Gadel2">Gadel</gloss> 442 Dec 13, particularly desire not further
                    alienate South Africans from <gloss target="#t_UN1">UN</gloss>, Del shld avoid
                    unduly emphasizing <gloss target="#t_HR2">HR</gloss> issue.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Acheson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
