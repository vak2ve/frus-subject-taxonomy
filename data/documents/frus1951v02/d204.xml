    <text>
        <body>
            <div frus:doc-dateTime-max="1951-10-31T19:21:00-05:00"
                frus:doc-dateTime-min="1951-10-31T19:21:00-05:00" n="204"
                subtype="historical-document" type="document" xml:id="d204">
                <note rend="inline" type="source">320/10–3151: Telegram</note>
                <head>
                    <hi rend="italic">The Acting <gloss type="from">Secretary of State</gloss> to
                        the United States Representative at the United Nations</hi> (<persName
                        type="to">
                        <hi rend="italic">Austin</hi>
                    </persName>)<note n="1" xml:id="d204fn1">Repeated for information to London as
                        2274.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                        <lb/>
                        <hi rend="smallcaps">priority</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1951-10-31T19:21:00-05:00"
                            >October 31, 1951—7:21 p.m.</date>
                    </dateline>
                </opener>
                <p>
                    <gloss target="#t_Gadel2">Gadel</gloss> 35. Re last para <gloss
                        target="#t_Delga1">Delga</gloss> 22 Oct 31 you are authorized discuss Chi
                    Rep issue carefully selected list key Dels such as you have indicated, stressing
                    that at same time US is seeking reach precise agreement UK on procedural details
                    and that these may require some last-minute modification.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Webb</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
