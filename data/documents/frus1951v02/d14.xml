                            <note rend="inline" type="source">320/10–1551</note>
                            <head>
                                <hi rend="italic">Operational and Topical Assignments for the
                                    Advisory Staff of the United States Delegation to the General
                                    Assembly, Paris, November 6, 1951</hi><note n="1" xml:id="d14fn1">Source text was Tab C of memorandum of October
                                    15 from Assistant Secretary Hickerson to the Secretary of State,
                                    not printed (320/10–1551).</note>
                            </head>
                            <dateline>
