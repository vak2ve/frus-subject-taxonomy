                subtype="historical-document" type="document" xml:id="d543">
                <note rend="inline" type="source">320/1–352: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        United States Representative at the United Nations</hi> (<persName type="to">
                        <hi rend="italic">Austin</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">restricted</hi>
                        <lb/>
                        <hi rend="smallcaps">priority</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1952-01-03T16:52:00+01:00"
                            >January 3, 1952—4:52 p.m.</date>
                    </dateline>
                </opener>
                <p>
                    <gloss target="#t_Gadel2">Gadel</gloss> 581. Re <gloss target="#t_Delga1"
                        >Delga</gloss> 828 and 829 January 3 you are auth ur discretion to abstain
                    on Res Third Comite auth HC appeal for asst funds.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Acheson</hi>
                    </signed>
                </closer>
            </div>
        </body>
