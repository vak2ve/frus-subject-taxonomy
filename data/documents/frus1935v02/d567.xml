                subtype="historical-document" type="document" xml:id="d567">
                <note rend="inline" type="source">611.5231/965: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Spain</hi> (<persName type="from">
                        <hi rend="italic">Bowers</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1935-04-29T13:00:00+00:00"
                            >April 29, 1935—1 p.m.</date>
                        <lb/>[Received April 29—11:20 a.m.]</dateline>
                </opener>
                <p>24. Department’s telegram No. 19, April 24, 1 p.m. Fact that Franco-Spanish
                    commercial negotiations have again been broken off makes present moment
                    singularly opportune to hasten our own negotiations.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bowers</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
