                <note rend="inline" type="source">611.5231/962</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Spanish Embassy</gloss> to the <gloss
                            type="to">Department of State</gloss>
                    </hi>
                </head>
                <p rend="center">
                    <hi rend="smallcaps">Foreign Trade of Spain</hi>
                </p>
