                subtype="historical-document" type="document" xml:id="d658">
                <note rend="inline" type="source">811.5034/170</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the Swiss
                        Minister</hi> (<persName type="to">
                        <hi rend="italic">Peter</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1935-01-22">January 22,
                            1935</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of January 8, 1935, presenting the views of your Government concerning
                    the interpretation of the meaning of the word “citizen” in Article 2 of
                    Paragraph 2 of the Convention of Friendship and Commerce between the Swiss
                    Confederation and the United States of America, signed November 25, 1850. The
                    statements contained in your note will receive the Department’s careful
                    consideration.</p>
                <p>Accept [etc.]</p>
                <closer>For the Secretary of State:<lb/>
                    <signed>R. <hi rend="smallcaps">Walton Moore</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
