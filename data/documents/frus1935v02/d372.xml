                subtype="historical-document" type="document" xml:id="d372">
                <note rend="inline" type="source">868.00/833: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Greece</hi> (<persName type="from">
                        <hi rend="italic">MacVeagh</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Athens</hi>
                        </placeName>, <date calendar="gregorian" when="1935-04-24T11:00:00+02:00"
                            >April 24, 1935—11 a.m.</date>
                        <lb/>[Received April 24—6:39 a.m.]</dateline>
                </opener>
                <p>56. My 55, April 23, 7 p.m. Generals were shot at dawn this morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">MacVeagh</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
