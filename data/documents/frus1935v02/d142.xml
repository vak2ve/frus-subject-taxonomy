<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-02-13T06:00:00-05:00" frus:doc-dateTime-min="1935-02-13T06:00:00-05:00" n="142" subtype="historical-document" type="document" xml:id="d142">
                            <note rend="inline" type="source">659.116/95: Telegram</note>
                            <head><hi rend="italic">The Minister in Denmark</hi> (<persName type="from"><hi rend="italic">Owen</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Copenhagen</hi></placeName>, <date calendar="gregorian" when="1935-02-13T12:00:00+01:00">February 13,
                                        1935—noon</date>.<lb/>[Received February 13—9:50
                                    a.m.]</dateline>
                            </opener>
                            <p>2. Department’s telegram No. 2 February 11, 7 p.m. In view of the
                                psychology of local situation I respectfully request that I be
                                authorized to present note with last 10 words omitted conveying
                                their content verbally.<note n="5" xml:id="d142fn5">By telegram No.
                                    3, February 13, 1935, 6 p.m., the Minister was informed of the
                                    Department’s approval.</note></p>
                            <closer><signed><hi rend="smallcaps">Owen</hi></signed></closer>
                        </div>
                        </body></text></TEI>