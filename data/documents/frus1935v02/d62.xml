<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-12-15T01:00:00-05:00" frus:doc-dateTime-min="1935-12-15T01:00:00-05:00" n="62" subtype="historical-document" type="document" xml:id="d62">
                            <note rend="inline" type="source">611.47H31/86: Telegram</note>
                            <head><hi rend="italic">The Consul General at Wellington</hi> (<persName type="from"><hi rend="italic">Bucklin</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Wellington</hi></placeName>, <date calendar="gregorian" when="1935-12-15T18:00:00+12:00">December 15, 1935—6
                                        p.m.</date><lb/>[Received December 16—3:42 a.m.]</dateline>
                            </opener>
                            <p>May assurance be given New Zealand Government that it will receive
                                advantages of Canadian-American Trade Agreement regarding butter if
                                most favored nation treatment is hereafter accorded the United
                                States under the New Zealand-Belgian Treaty reported by despatch No.
                                442, March 14, 1934?<note n="18" xml:id="d62fn18">Not
                                    printed.</note></p>
                            <closer><signed><hi rend="smallcaps">Bucklin</hi></signed></closer>
                        </div>
                        </body></text></TEI>