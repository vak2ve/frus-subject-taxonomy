<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-07-11T03:00:00-05:00" frus:doc-dateTime-min="1934-07-11T03:00:00-05:00" n="405" subtype="historical-document" type="document" xml:id="d405">
                            <note rend="inline" type="source">868.151/121: Telegram</note>
                            <head><hi rend="italic">The Minister in Greece</hi> (<persName type="from"><hi rend="italic">MacVeagh</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Athens</hi></placeName>, <date calendar="gregorian" when="1934-07-11T10:00:00+02:00">July 11, 1934—10
                                        a.m.</date><lb/>[Received July 11—6:46 a.m.]</dateline>
                            </opener>
                            <p>70. Your 42, July 6, 3 p.m. The Minister for Foreign Affairs assures
                                that no action will be taken against Ulen and Company in the matter
                                of the $100,000 before the arrival of Gausmann.</p>
                            <closer><signed><hi rend="smallcaps">MacVeagh</hi></signed></closer>
                        </div>
                        </body></text></TEI>