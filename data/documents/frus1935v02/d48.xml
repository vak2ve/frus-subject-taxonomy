                subtype="historical-document" type="document" xml:id="d48">
                <note rend="inline" type="source">611.4331/58: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at St. John’s</hi> (<persName type="to">
                        <hi rend="italic">Quarton</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1935-04-16T18:00:00-05:00"
                            >April 16, 1935—6 p.m.</date>
                    </dateline>
                </opener>
                <p>Your April 9, 5 p.m. Consideration is being given to the question of announcing
                    intention to negotiate with Newfoundland. Upon determination thereof you will be
                    informed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
