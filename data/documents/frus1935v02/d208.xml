    <text>
        <body>
            <div frus:doc-dateTime-max="1935-10-02T05:00:00-05:00"
                frus:doc-dateTime-min="1935-10-02T05:00:00-05:00" n="208"
                subtype="historical-document" type="document" xml:id="d208">
                <note rend="inline" type="source">811.512351/275: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in France</hi> (<persName type="from">
                        <hi rend="italic">Marriner</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1935-10-02T11:00:00+01:00"
                            >October 2, 1935—11 a.m.</date>
                        <lb/>[Received October 2—7:18 a.m.]</dateline>
                </opener>
                <p>842. My 840, October 1, 6 p.m.<note n="52" xml:id="d208fn52">Not printed.</note>
                    The decree promulgating double taxation convention, dated yesterday appears in
                    today’s <hi rend="italic">Journal Officiel</hi> making the convention effective
                    as of January 1, 1936.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Marriner</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
