<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1902-09-25T23:59:59-05:00" frus:doc-dateTime-min="1902-09-25T00:00:00-05:00" n="897" subtype="historical-document" type="document" xml:id="d897">
                        <head><hi rend="italic">Mr. <persName type="from">Adee</persName> to Señor
                                    <persName type="to">Ojeda</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1902-09-25"><hi rend="italic">September 25,
                                    1902</hi></date>.</dateline></opener>
                        <p>Your sympathetic telegram has been communicated to the President, who
                            charges me to thank you.</p>
                        <closer><signed><hi rend="smallcaps">Alvey A. Adee</hi>,<lb/><hi rend="italic">Acting Secretary.</hi></signed></closer>
                    </div>
                </body></text></TEI>