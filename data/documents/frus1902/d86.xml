    <text>
        <body>
            <div frus:doc-dateTime-max="1902-11-19T23:59:59-05:00"
                frus:doc-dateTime-min="1902-11-19T00:00:00-05:00" n="86"
                subtype="historical-document" type="document" xml:id="d86">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Townsend</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Brussels</hi>
                        </placeName>, <date calendar="gregorian" when="1902-11-19">
                            <hi rend="italic">November 19, 1902</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 165.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    Department’s cable, dated November 17, 1902.</p>
                <p>In conformity with instructions, I called personally upon the minister for
                    foreign affairs to request him to kindly convey to the King the sincere
                    congratulations of the President and people of the United States upon His
                    Majesty’s providential escape from harm.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lawrence Townsend.</hi>
                    </signed>
                </closer>
            </div>
        </body>
