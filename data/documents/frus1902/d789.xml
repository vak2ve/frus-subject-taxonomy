    <text>
        <body>
            <div frus:doc-dateTime-max="1902-09-05T23:59:59-05:00"
                frus:doc-dateTime-min="1902-09-05T00:00:00-05:00" n="789"
                subtype="historical-document" type="document" xml:id="d789">
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to
                        President <persName type="to">Diaz</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">White House</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-09-05">
                            <hi rend="italic">September 5, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>I highly esteem your congratulations upon my fortunate escape.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
