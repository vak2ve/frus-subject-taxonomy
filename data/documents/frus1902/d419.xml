                subtype="historical-document" type="document" xml:id="d419">
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to the
                            <gloss type="to">German Emperor</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">White House</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-09-04">
                            <hi rend="italic">September 4, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>I warmly appreciate Your Majesty’s sympathetic message.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt</hi>.</signed>
                </closer>
            </div>
        </body>
