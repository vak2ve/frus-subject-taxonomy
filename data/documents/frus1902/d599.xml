                subtype="historical-document" type="document" xml:id="d599">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hill</persName> to Mr. <persName
                            type="to">Powell</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-05-16">
                            <hi rend="italic">May 16, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Hill directs Mr. Powell to carefully avoid taking sides in the existing
                    contentions in Haiti, but to enter into necessary business relations with the de
                    facto government.)</p>
            </div>
