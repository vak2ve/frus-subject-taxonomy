    <text>
        <body>
            <div frus:doc-dateTime-max="1902-05-30T23:59:59-05:00"
                frus:doc-dateTime-min="1902-05-30T00:00:00-05:00" n="834"
                subtype="historical-document" type="document" xml:id="d834">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Loomis</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Lisbon</hi>
                        </placeName>, <date calendar="gregorian" when="1902-05-30">
                            <hi rend="italic">May 30, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I beg leave to acknowledge the receipt of your
                        telegram<note n="a" xml:id="d834fna">Printed, <ref target="#pg_6">page
                            6</ref>.</note> of May 24.</p>
                <p>The permission was asked and granted within six hours, and the consuls have been
                    notified.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Francis B. Loomis.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
