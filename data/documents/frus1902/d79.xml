                subtype="historical-document" type="document" xml:id="d79">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr. <persName
                            type="to">Winthrop</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-09-20">
                            <hi rend="italic">September 20, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Adee directs Mr. Winthrop to express, on behalf of the President and
                    Government of the United States, feelings of sincere sorrow and condolence by
                    reason of the death of Her Majesty the Queen.)</p>
            </div>
