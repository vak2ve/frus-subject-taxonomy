<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1902-06-24T23:59:59-05:00" frus:doc-dateTime-min="1902-06-24T00:00:00-05:00" n="506" subtype="historical-document" type="document" xml:id="d506">
                        <head><hi rend="italic">Mr. <persName type="from">Choate</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">American Embassy</hi>,<lb/><hi rend="italic">London</hi></placeName>, <date calendar="gregorian" when="1902-06-24"><hi rend="italic">June 24,
                                1902</hi></date>.</dateline></opener>
                        <p>Coronation has just been indefinitely postponed owing to the King’s
                            indisposition. * * *</p>
                        <closer><signed><hi rend="smallcaps">Choate.</hi></signed></closer>
                    </div>
                    </body></text></TEI>