<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1902-09-04T23:59:59-05:00" frus:doc-dateTime-min="1902-09-04T00:00:00-05:00" n="309" subtype="historical-document" type="document" xml:id="d309">
                        <head><hi rend="italic">President <persName type="from">Roosevelt</persName>
                                to President <persName type="to">Palma</persName></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Oyster
                                        Bay</hi></placeName>, <date calendar="gregorian" when="1902-09-04"><hi rend="italic">September 4,
                                    1902</hi></date>.</dateline></opener>
                        <p>I thank you for your solicitous message.</p>
                        <closer><signed><hi rend="smallcaps">Theodore
                            Roosevelt</hi>.</signed></closer>
                    </div>
                </body></text></TEI>