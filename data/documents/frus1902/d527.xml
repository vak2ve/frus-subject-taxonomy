<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1902-05-12T23:59:59-05:00" frus:doc-dateTime-min="1902-05-12T00:00:00-05:00" n="527" subtype="historical-document" type="document" xml:id="d527">
                        <head><hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr.
                                    <persName type="to">Choate</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1902-05-12"><hi rend="italic">May 12,
                                1902</hi></date>.</dateline></opener>
                        <p>Express to British Government the sympathy of the President and the
                            people of this country in the affliction which has befallen St. Vincent,
                            and our desire to share in the work of aid and rescue.</p>
                        <closer><signed><hi rend="smallcaps">Hay</hi>.</signed></closer>
                    </div>
                    </body></text></TEI>