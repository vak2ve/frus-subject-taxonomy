                subtype="historical-document" type="document" xml:id="d298">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Squiers</persName> to Mr. <persName
                            type="to">Hay</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1902-06-10">
                            <hi rend="italic">June 10, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>Amnesty has been granted by Cuban Government crimes committed American citizens
                    during intervention period.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Squiers.</hi>
                    </signed>
                </closer>
            </div>
        </body>
