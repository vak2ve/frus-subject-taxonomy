                subtype="historical-document" type="document" xml:id="d1017">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Bowen</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Caracas</hi>
                        </placeName>, <date calendar="gregorian" when="1902-06-19">
                            <hi rend="italic">June 19, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Bowen reports that he has been advised by the Venezuelan minister for
                    foreign affairs that Ciudad Bolivar is in the hands of revolutionists and that
                    the Orinoco River is not blockaded.)</p>
            </div>
        </body>
