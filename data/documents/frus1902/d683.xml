                <head>
                    <hi rend="italic">Mr. <persName type="from">Meyer</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Embassy of the United States</hi>,<lb/>
                            <hi rend="italic">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1902-05-31">
                            <hi rend="italic">May 31, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>Italian Government grants request as to American consuls and Cuban interests in
                    Italy.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Meyer.</hi>
                    </signed>
                </closer>
            </div>
        </body>
