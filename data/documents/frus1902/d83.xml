                <head>
                    <hi rend="italic">Mr. <persName type="from">Townsend</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Brussels</hi>
                        </placeName>, <date calendar="gregorian" when="1902-11-15">
                            <hi rend="italic">November 15, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Townsend reports that two shots were fired by a man in the street at the
                    King, without inflicting any injury.)</p>
            </div>
