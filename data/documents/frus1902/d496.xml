                <head>
                    <hi rend="italic">Mr. <persName type="from">Choate</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">American Embassy</hi>,<lb/>
                            <hi rend="italic">London</hi>
                        </placeName>, <date calendar="gregorian" when="1902-08-21">
                            <hi rend="italic">August 21, 1902</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 923.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: With reference to my note of the 28th ultimo, I
                    have the honor to inclose herewith a list of prisoners of war at St. Helena, who
                    are citizens of the United States, which I have just received from the foreign
                    office.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Joseph H. Choate.</hi>
                    </signed>
                </closer>
                <pb facs="0576" n="496" xml:id="pg_496"/>
                <frus:attachment>
