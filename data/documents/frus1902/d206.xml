                subtype="historical-document" type="document" xml:id="d206">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr. <persName
                            type="to">Conger</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-09-27">
                            <hi rend="italic">September 27, 1902</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 569.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your No.
                    1070, of the 16th ultimo, in regard to the complaints made by certain Chinese
                    residents in Honolulu against the actions of the Chinese consul there and the
                    consequent vicarious punishment of their relatives in China.</p>
                <p>Your note on this subject, addressed to the Chinese Government in compliance with
                    instructions No. 541, of July 2, is approved by the Department.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alvey A. Adee</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
