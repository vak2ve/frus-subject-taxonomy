    <text>
        <body>
            <div frus:doc-dateTime-max="1902-08-26T23:59:59-05:00"
                frus:doc-dateTime-min="1902-08-26T00:00:00-05:00" n="991"
                subtype="historical-document" type="document" xml:id="d991">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Leishman</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Constantinople</hi>
                        </placeName>, <date calendar="gregorian" when="1902-08-26">
                            <hi rend="italic">August 26, 1902</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 256.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your unnumbered instruction of August 12, 1902.</p>
                <p>I shall lose no time in acquainting the Sublime Porte with the contents of the
                    circular instruction<note n="a" xml:id="d991fna">Printed under Austria, <ref
                            target="#pg_42">page 42</ref>.</note> therein inclosed which deals with
                    the situation of the Jews in Roumania.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John G. A. Leishman.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
