                subtype="historical-document" type="document" xml:id="d660">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Powell</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1902-09-28">
                            <hi rend="italic">September 28, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Powell reports that the manager of the Haytian Company requests that a
                    United States naval vessel be sent to Port de Paix on account of impending
                    danger to American interests; that the national troops are to land at that place
                    on September 29.)</p>
            </div>
        </body>
