    <text>
        <body>
            <div frus:doc-dateTime-max="1902-05-31T23:59:59-05:00"
                frus:doc-dateTime-min="1902-05-31T00:00:00-05:00" n="544"
                subtype="historical-document" type="document" xml:id="d544">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Raikes</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-05-31">
                            <hi rend="italic">May 31, 1902</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 138.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have received the commands of the King, my
                    gracious sovereign, to convey to the President His Majesty’s high appreciation
                    of the signs of respect which the President himself as well as the United States
                    Government showed to the memory of Lord Pauncefote during the recent ceremonies
                    at this capital.</p>
                <p rend="center">* * * * * * *</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Arthur S. Raikes.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
