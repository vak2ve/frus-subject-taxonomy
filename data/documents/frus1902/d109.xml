                subtype="historical-document" type="document" xml:id="d109">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Hutchinson</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-11-13">
                            <hi rend="italic">November 13, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Hay directs Mr. Hutchinson to accept return, by Chilean Government, of the
                    money paid for cleaning the U. S. S. <hi rend="italic">Iowa</hi>, and to express
                    thanks for the generous courtesy.)</p>
            </div>
        </body>
