    <text>
        <body>
            <div frus:doc-dateTime-max="1902-09-17T23:59:59-05:00"
                frus:doc-dateTime-min="1902-09-17T00:00:00-05:00" n="913"
                subtype="historical-document" type="document" xml:id="d913">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr. <persName
                            type="to">Hardy</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-09-17">
                            <hi rend="italic">September 17, 1902</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 46.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Your No. 72 of the 1st instant has been received,
                    and your refusal to issue to Bernhard Kaufmann a passport under the
                    circumstances detailed in the dispatch is commended.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alvey A. Adee</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
