                subtype="historical-document" type="document" xml:id="d139">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Conger</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1902-05-03">
                            <hi rend="italic">May 3, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Conger reports serious disturbances in southern portion of the province of
                    Chihli; that the first troops sent were overpowered, and a larger force is being
                    sent by the viceroy.)</p>
            </div>
