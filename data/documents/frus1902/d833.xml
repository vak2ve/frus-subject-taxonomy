    <text>
        <body>
            <div frus:doc-dateTime-max="1902-09-05T23:59:59-05:00"
                frus:doc-dateTime-min="1902-09-05T00:00:00-05:00" n="833"
                subtype="historical-document" type="document" xml:id="d833">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Señor <persName
                            type="to">Calderon</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-09-05">
                            <hi rend="italic">September 5, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>The President charges me to thank you for the congratulations you offer him on
                    behalf of the President and people of Peru.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alvey A. Adee</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
