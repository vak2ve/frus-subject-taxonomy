                subtype="historical-document" type="document" xml:id="d733">
                <head>
                    <hi rend="italic">The <gloss type="from">Emperor of Korea</gloss> to President
                            <persName type="to">Roosevelt</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Seoul</hi>
                        </placeName>, <date calendar="gregorian" when="1902-09-16">
                            <hi rend="italic">September 16, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>I regret exceedingly your excellency’s recent carriage accident, and heartily
                    congratulate you on your happy escape. I trust you will speedily recover from
                    the effects of the collision.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hiung</hi>, <hi rend="italic">Emperor Daicher of
                            Daihan.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
