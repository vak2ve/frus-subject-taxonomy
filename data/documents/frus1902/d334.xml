    <text>
        <body>
            <div frus:doc-dateTime-max="1902-09-24T23:59:59-05:00"
                frus:doc-dateTime-min="1902-09-24T00:00:00-05:00" n="334"
                subtype="historical-document" type="document" xml:id="d334">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Vasquez</persName> to Mr. <persName
                            type="to">Hay</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the Dominican Republic</hi>,<lb/>
                            <hi rend="italic">New York</hi>
                        </placeName>, <date calendar="gregorian" when="1902-09-24">
                            <hi rend="italic">September 24, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>Sincerely regret accident to President Roosevelt, and hope there is no danger for
                    him.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">F. L. Vasquez</hi>,<lb/>
                        <hi rend="italic">Chargé d’Affaires.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
