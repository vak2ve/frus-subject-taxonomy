    <text>
        <body>
            <div frus:doc-dateTime-max="1901-12-24T23:59:59-05:00"
                frus:doc-dateTime-min="1901-12-24T00:00:00-05:00" n="65"
                subtype="historical-document" type="document" xml:id="d65">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Baron <persName
                            type="to">Moncheur</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-12-24">
                            <hi rend="italic">December 24, 1901</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 14.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your memorandum of the 20th instant, relating further to the fine imposed in
                    March or April on the owners of the steamship <hi rend="italic">Belgika</hi>,
                    and to inform you that I have once more called the attention of the Secretary of
                    War to the matter, with the request that he cause a report of the proper
                    authorities in the Philippine Islands to be made and sent to me.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
