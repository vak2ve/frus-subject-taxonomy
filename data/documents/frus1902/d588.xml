    <text>
        <body>
            <div frus:doc-dateTime-max="1902-06-05T23:59:59-05:00"
                frus:doc-dateTime-min="1902-06-05T00:00:00-05:00" n="588"
                subtype="historical-document" type="document" xml:id="d588">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Bailey</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Guatemala and Honduras, Guatemala</hi>
                        </placeName>, <date calendar="gregorian" when="1902-06-05">
                            <hi rend="italic">June 5, 1902</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 644.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to confirm the Department’s
                        cablegram<note n="a" xml:id="d588fna">Printed, <ref target="#pg_6">p.
                            6</ref>.</note> of May 24, 1902.</p>
                <p>Permission has been granted in accordance with the request made in the above
                    cable by the Governments of Guatemala and Honduras. I have notified United
                    States consuls.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">James G. Bailey.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
