                subtype="historical-document" type="document" xml:id="d418">
                <head>
                    <hi rend="italic">The <gloss type="from">German Emperor</gloss> to President
                            <persName type="to">Roosevelt</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Posen</hi>
                        </placeName>, <date calendar="gregorian" when="1902-09-04">
                            <hi rend="italic">September 4, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>With all Americans I praise Providence that saved your life from the terrible
                    accident.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William I. R.</hi>
                    </signed>
                </closer>
            </div>
        </body>
