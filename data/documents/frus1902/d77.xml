                subtype="historical-document" type="document" xml:id="d77">
                <head>
                    <hi rend="italic">The <gloss type="from">President</gloss> to the <gloss
                            type="to">King of the Belgians</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">White House</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-09-06">
                            <hi rend="italic">September 6, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>I cordially esteem Your Majesty’s solicitous sympathy.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
