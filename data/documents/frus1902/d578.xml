    <text>
        <body>
            <div frus:doc-dateTime-max="1902-06-21T23:59:59-05:00"
                frus:doc-dateTime-min="1902-06-21T00:00:00-05:00" n="578"
                subtype="historical-document" type="document" xml:id="d578">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Wilson</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Athens</hi>
                        </placeName>, <date calendar="gregorian" when="1902-06-21">
                            <hi rend="italic">June 21, 1902</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 77, Greek series.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that I have
                    received permission from the Greek Government for the United States consular
                    officers in that country to use their good offices in the representation of Cuba
                    and of its citizens until Cuban consuls shall have been appointed, and I have
                    notified the United States consuls in Greece to that effect.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Charles S. Wilson</hi>,<lb/>
                        <hi rend="italic">Chargé d’Affaires ad interim.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
