    <text>
        <body>
            <div frus:doc-dateTime-max="1902-06-24T23:59:59-05:00"
                frus:doc-dateTime-min="1902-06-24T00:00:00-05:00" n="550"
                subtype="historical-document" type="document" xml:id="d550">
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to King
                            <persName type="to">Edward VII</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">White House</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-06-24">
                            <hi rend="italic">June 24, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>I ask Your Majesty to accept my sincere assurance of sympathy and wishes for
                    speedy convalescence.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt</hi>.</signed>
                </closer>
            </div>
        </body>
