    <text>
        <body>
            <div frus:doc-dateTime-max="1902-09-05T23:59:59-05:00"
                frus:doc-dateTime-min="1902-09-05T00:00:00-05:00" n="41"
                subtype="historical-document" type="document" xml:id="d41">
                <head>
                    <hi rend="italic">The <gloss type="from">Emperor of Austria</gloss> to the
                            <gloss type="to">President</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Vienna, Schoenbrunn</hi>
                        </placeName>, <date calendar="gregorian" when="1902-09-05">
                            <hi rend="italic">September 5, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>I have received the news of your dangerous accident with deep sympathy and
                    express to you, Mr. President, my heartiest congratulations upon your escape
                    from this serious danger to life.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Franz Joseph.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
