                subtype="historical-document" type="document" xml:id="d71">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Townsend</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Brussels</hi>
                        </placeName>, <date calendar="gregorian" when="1902-05-06">
                            <hi rend="italic">May 6, 1902</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 135.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform the Department that
                    the Chamber of Representatives of Belgium yesterday unanimously ratified the
                    text of the recent sugar convention which was signed at Brussels on March 5,
                    1902.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lawrence Townsend.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
