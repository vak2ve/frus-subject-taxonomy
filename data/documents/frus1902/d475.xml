                subtype="historical-document" type="document" xml:id="d475">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">White</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-10-30">
                            <hi rend="italic">October 30, 1901</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 758.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Your No. 687, of the 19th instant, regarding the
                    reported release of three German prisoners of war who were detained on Ceylon,
                    has been received. The matter is commended to your attention.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
