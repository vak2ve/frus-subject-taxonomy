<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1902-12-04T23:59:59-05:00" frus:doc-dateTime-min="1902-12-04T00:00:00-05:00" n="726" subtype="historical-document" type="document" xml:id="d726">
                        <head><hi rend="italic">Mr. <persName type="from">Ferguson</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Legation of the United States</hi>,<lb/><hi rend="italic">Tokyo</hi></placeName>, <date calendar="gregorian" when="1902-12-04"><hi rend="italic">December 4,
                                1902</hi></date>.</dateline></opener>
                        <p>It is my painful duty to announce the sudden death to-day of Minister
                            Buck. * * *</p>
                        <closer><signed><hi rend="smallcaps">Ferguson.</hi></signed></closer>
                    </div>
                    </body></text></TEI>