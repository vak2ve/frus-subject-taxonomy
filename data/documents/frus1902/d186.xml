    <text>
        <body>
            <div frus:doc-dateTime-max="1902-04-30T23:59:59-05:00"
                frus:doc-dateTime-min="1902-04-30T00:00:00-05:00" n="186"
                subtype="historical-document" type="document" xml:id="d186">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Conger</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-04-30">
                            <hi rend="italic">April 30, 1902</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 512.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your No.
                    950, of the 19th ultimo, reporting that the Chinese Government declines to issue
                    passports for Thibet upon the applications of Messrs. Ruhl and Snyder, American
                    missionaries.</p>
                <p>Your action in declining to urge their request upon the Chinese Government is
                    approved.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay</hi>.</signed>
                </closer>
            </div>
        </body>
