                        <head><hi rend="italic">Mr. <persName type="from">Powell</persName> to Mr.
                                    <persName type="to">Hay</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.—Paraphrase.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Legation of the United States</hi>,<lb/><hi rend="italic">Port au Prince</hi></placeName>, <date calendar="gregorian" when="1902-05-28"><hi rend="italic">May 28,
                                1902</hi></date>.</dateline></opener>
