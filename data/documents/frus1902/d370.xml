    <text>
        <body>
            <div frus:doc-dateTime-max="1902-05-10T23:59:59-05:00"
                frus:doc-dateTime-min="1902-05-10T00:00:00-05:00" n="370"
                subtype="historical-document" type="document" xml:id="d370">
                <head>
                    <hi rend="italic">President <persName type="from">Roosevelt</persName> to
                        President <persName type="to">Loubet</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Executive Mansion</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-05-10">
                            <hi rend="italic">May 10, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>I pray Your Excellency to accept the profound sympathy of the American people in
                    the appalling calamity which has come upon the people of Martinique.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Theodore Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
