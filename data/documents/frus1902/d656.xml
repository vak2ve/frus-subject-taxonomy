                subtype="historical-document" type="document" xml:id="d656">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Powell</persName> to Mr. <persName
                            type="to">Hay</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.—Paraphrase.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1902-09-22">
                            <hi rend="italic">September 22, 1902</hi>
                        </date>.</dateline>
                </opener>
                <p>(Mr. Powell reports that it is stated by the Government that a chartered vessel
                    is cruising at each blockaded place, and suggests that this statement be
                    verified by the <hi rend="italic">Montgomery</hi>).</p>
            </div>
        </body>
