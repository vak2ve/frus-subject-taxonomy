                subtype="historical-document" type="document" xml:id="d771">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Clayton</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-03-04">
                            <hi rend="italic">March 4, 1902</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 656.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                    dispatch No. 1274, of the 21st ultimo, containing a report on the arrest of
                    American citizens employed on railroads in Mexico, for negligence in causing
                    accidents.</p>
                <p>In view of your comprehensive investigation and report, it is unnecessary for you
                    to pursue the subject further, unless you are hereafter so instructed.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
