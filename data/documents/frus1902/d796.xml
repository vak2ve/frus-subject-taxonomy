    <text>
        <body>
            <div frus:doc-dateTime-max="1901-12-10T23:59:59-05:00"
                frus:doc-dateTime-min="1901-12-10T00:00:00-05:00" n="796"
                subtype="historical-document" type="document" xml:id="d796">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Merry</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1901-12-10">
                            <hi rend="italic">December 10, 1901</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 429.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to instruction No. 425, of October 25
                    last, I inclose herewith for your information a copy of a note<note n="d"
                        xml:id="d796fnd">Printed, <ref target="#pg_366">p. 366</ref>.</note> from
                    the Danish minister stating that his Government will issue a notice to Danish
                    subjects in Salvador that they have been placed under the protection of the
                    United States as soon as it is informed that the Salvadorean Government assents
                    to such protection.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
