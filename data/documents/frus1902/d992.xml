<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1902-09-01T23:59:59-05:00" frus:doc-dateTime-min="1902-09-01T00:00:00-05:00" n="992" subtype="historical-document" type="document" xml:id="d992">
                        <head><hi rend="italic">President <persName type="from">Roosevelt</persName>
                                to the <gloss type="to">Sultan of Turkey</gloss>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">White
                                        House</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1902-09-01"><hi rend="italic">September 1,
                                    1902</hi></date>.</dateline></opener>
                        <p>I ask Your Majesty to accept my congratulations upon the anniversary of
                            your accession to the Ottoman throne.</p>
                        <closer><signed><hi rend="smallcaps">Theodore
                            Roosevelt.</hi></signed></closer>
                    </div>
                    </body></text></TEI>