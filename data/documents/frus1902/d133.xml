    <text>
        <body>
            <div frus:doc-dateTime-max="1902-01-31T23:59:59-05:00"
                frus:doc-dateTime-min="1902-01-31T00:00:00-05:00" n="133"
                subtype="historical-document" type="document" xml:id="d133">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Hay</persName> to Mr. <persName
                            type="to">Conger</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1902-01-31">
                            <hi rend="italic">January 31, 1902</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 448.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I inclose herewith for your information a copy of
                    a dispatch<note n="b" xml:id="d133fnb">Printed under Russia, <ref
                            target="#pg_918">page 918</ref>.</note> from the United States
                    ambassador to Russia, reporting the view taken by the Russian Government
                    respecting the recent conflict between seamen of the United States Navy and the
                    Russian police at Niuchwang.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John Hay</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
