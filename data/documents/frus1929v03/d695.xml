                subtype="historical-document" type="document" xml:id="d695">
                <note rend="inline" type="source">817.00/6428: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Hanna</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1929-10-17T13:00:00-05:45"
                            >October 17, 1929—1 p.m.</date>
                        <lb/>[Received 2:08 p.m.]</dateline>
                </opener>
                <p>254. My 244, October 4, noon. I understand that the Nicaraguans in reference were
                    refused entrance to Mexico and are proceeding to San Francisco.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hanna</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
