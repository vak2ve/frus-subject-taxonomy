                subtype="historical-document" type="document" xml:id="d784">
                <note rend="inline" type="source">417.00/329: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Hanna</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1929-06-20T15:00:00-05:45"
                            >June 20, 1929—3 p.m.</date>
                        <lb/>[Received 6:25 p.m.]</dateline>
                </opener>
                <p>171. My 157, June 8, noon. Minister of Hacienda has formally requested the
                    directing boards of the Liberal and Conservative Parties to name five candidates
                    each, in order that President Moncada may appoint the respective representatives
                    of those parties on the Claims Commission.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hanna</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
