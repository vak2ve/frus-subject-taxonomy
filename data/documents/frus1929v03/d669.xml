<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-07-11T11:00:00-05:00" frus:doc-dateTime-min="1929-07-11T11:00:00-05:00" n="669" subtype="historical-document" type="document" xml:id="d669">
                        <note rend="inline" type="source">817.00/6492a: Telegram</note>
                        <head><hi rend="italic">The Vice Consul at Progreso</hi> (<persName type="from"><hi rend="italic">Lane</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Progreso</hi></placeName>, <date calendar="gregorian" when="1929-07-11T10:00:00-06:00">July 11, 1929—10
                                a.m.</date><lb/>[Received 7 p.m.]</dateline></opener>
                        <p>Sandino arrived at Progreso this morning; proceeded to Merida.</p>
                        <closer><signed><hi rend="smallcaps">Lane</hi></signed></closer>
                    </div>
                    </body></text></TEI>