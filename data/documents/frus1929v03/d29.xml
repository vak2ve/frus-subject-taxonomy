<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-08-27T14:00:00-05:00" frus:doc-dateTime-min="1929-08-27T14:00:00-05:00" n="29" subtype="historical-document" type="document" xml:id="d29">
                        <note rend="inline" type="source">867n.404Wailing Wall/47: Telegram</note>
                        <head><hi rend="italic">The Consul General at Jerusalem</hi> (<persName type="from"><hi rend="italic">Knabenshue</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Jerusalem</hi></placeName>, <date calendar="gregorian" when="1929-08-27T21:00:00+02:00">August 27, 1929—9
                                p.m.</date><lb/>[Received 9:57 p.m.]</dateline></opener>
                        <p>All American citizens at Hebron as listed in my August 26, 10 p.m., now
                            safe in Jerusalem. Please notify relatives.</p>
                        <closer><signed><hi rend="smallcaps">Knabenshue</hi></signed></closer>
                    </div>
                    </body></text></TEI>