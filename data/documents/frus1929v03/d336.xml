                subtype="historical-document" type="document" xml:id="d336">
                <note rend="inline" type="source">882.5048/121: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Liberia</hi> (<persName type="from">
                        <hi rend="italic">Wharton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1929-11-08T12:00:00-00:44"
                            >November 8, 1929—noon</date>.<lb/>[Received 10:30 p.m.]</dateline>
                </opener>
                <p>60. Referring to Department’s telegram No. 45, November 6, 5 p.m. President’s
                    message recommended that slavery convention of 1926 be ratified during the
                    present session.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wharton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
