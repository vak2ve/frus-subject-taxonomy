                subtype="historical-document" type="document" xml:id="d601">
                <note rend="inline" type="source">881.512/73: Telegram</note>
                <head>
                    <hi rend="italic">The Diplomatic Agent and Consul General at Tangier</hi>
                        (<persName type="from">
                        <hi rend="italic">Blake</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tangier</hi>
                        </placeName>, <date calendar="gregorian" when="1929-02-14T17:00:00+00:00"
                            >February 14, 1929—5 p.m.</date>
                        <lb/>[Received February 14—1:15 p.m.]</dateline>
                </opener>
                <p>5. Note in pursuance of instruction number 505 of January 29, 1929, on the
                    “padlock law” was addressed today to the French Resident General at Rabat.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blake</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
