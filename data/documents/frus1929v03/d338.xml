    <text>
        <body>
            <div frus:doc-dateTime-max="1929-11-17T04:44:00-05:00"
                frus:doc-dateTime-min="1929-11-17T04:44:00-05:00" n="338"
                subtype="historical-document" type="document" xml:id="d338">
                <note rend="inline" type="source">882.5048/123: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Liberia</hi> (<persName type="from">
                        <hi rend="italic">Wharton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Monrovia</hi>
                        </placeName>, <date calendar="gregorian" when="1929-11-17T09:00:00-00:44"
                            >November 17, 1929—9 a.m.</date>
                        <lb/>[Received 3:20 p.m.]</dateline>
                </opener>
                <p>64. Senator Tubman<note n="33" xml:id="d338fn33">Senator William V. S. Tubman,
                        Maryland County, Liberia.</note> informs me slavery convention ratified by
                    Senate last Wednesday.<note n="34" xml:id="d338fn34">November 13, 1929.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wharton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
