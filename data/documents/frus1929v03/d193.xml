                <note rend="inline" type="source">838.00/2613: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the High
                        Commissioner in Haiti</hi> (<persName type="to">
                        <hi rend="italic">Russell</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1929-12-05T15:00:00-05:00"
                            >December 5, 1929—3 p.m.</date>
                    </dateline>
                </opener>
                <p>61. Your 91, December 4, 2 p.m. Please withhold proclamation. I am sending you a
                    long personal message with my views later this afternoon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Russell</hi>
                    </signed>
                </closer>
            </div>
        </body>
