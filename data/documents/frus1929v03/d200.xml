                subtype="historical-document" type="document" xml:id="d200">
                <note rend="inline" type="source">838.00/2624: Telegram</note>
                <head>
                    <hi rend="italic">The High Commissioner in Haiti</hi> (<persName type="from">
                        <hi rend="italic">Russell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port-au-Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1929-12-07T11:00:00-05:00"
                            >December 7, 1929—11 a.m.</date>
                        <lb/>[Received 4:08 p.m.]</dateline>
                </opener>
                <p>97. Department’s 63, December 6, 11 a.m. Verbal order to the brigade commander
                    has been issued for the strict compliance with the instructions contained in the
                    above-mentioned telegram.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Russell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
