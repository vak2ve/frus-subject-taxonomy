    <text>
        <body>
            <div frus:doc-dateTime-max="1929-03-04T23:59:59-05:00"
                frus:doc-dateTime-min="1929-03-04T00:00:00-05:00" n="376"
                subtype="historical-document" type="document" xml:id="d376">
                <note rend="inline" type="source">612.0023/91</note>
                <head>
                    <hi rend="italic">The Mexican Ambassador</hi> (<persName type="from">
                        <hi rend="italic">Téllez</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1929-03-04">March 4,
                            1929</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary</hi>: With reference to my note of this date
                    I have the honor to inform Your Excellency in compliance with special
                    instructions which I have received from my Government that the closing of all
                    frontier ports of the State of Sonora has been decreed.</p>
                <p>I avail myself [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Manuel C. Téllez</hi>
                    </signed>
                </closer>
            </div>
        </body>
