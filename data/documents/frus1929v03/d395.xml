<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-03-09T23:59:59-05:00" frus:doc-dateTime-min="1929-03-09T00:00:00-05:00" n="395" subtype="historical-document" type="document" xml:id="d395">
                        <note rend="inline" type="source">612.0023/86</note>
                        <head><hi rend="italic">The Mexican Ambassador</hi> (<persName type="from"><hi rend="italic">Téllez</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><seg rendition="#center">[Translation]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1929-03-09">March 9, 1929</date>.</dateline></opener>
                        <p><hi rend="smallcaps">Mr. Secretary</hi>: In compliance with special
                            instructions which I have received from my Government I have the honor
                            to inform <pb facs="0473" n="355" xml:id="pg_355"/> Your Excellency that
                            the Federal authorities of Mexico have decreed the closing of the
                            customhouses on the frontier of Chihuahua because military garrisons of
                            that State are in revolution.</p>
                        <p>I avail myself [etc.]</p>
                        <closer><signed><hi rend="smallcaps">Manuel C. Téllez</hi></signed></closer>
                    </div>
                    </body></text></TEI>