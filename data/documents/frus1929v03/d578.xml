                subtype="historical-document" type="document" xml:id="d578">
                <note rend="inline" type="source">452.11/219: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Spain</hi> (<persName type="from">
                        <hi rend="italic">Hammond</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1929-06-19T17:00:00+01:00"
                            >June 19, 1929—5 p.m.</date>
                        <lb/>[Received June 19—2:50 p.m.]</dateline>
                </opener>
                <p>41. Your 29, June 11, 7 p.m. Have twice seen Pla who is now in the Foreign
                    Office, who tells me recent Blake-Jordana agreement is satisfactory to the
                    Director of Moroccan Affairs and he hopes that the Government will soon approve
                    it.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hammond</hi>
                    </signed>
                </closer>
            </div>
        </body>
