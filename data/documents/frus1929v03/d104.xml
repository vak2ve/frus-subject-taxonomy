<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-05-16T17:00:00-05:00" frus:doc-dateTime-min="1929-05-16T17:00:00-05:00" n="104" subtype="historical-document" type="document" xml:id="d104">
                        <note rend="inline" type="source">868.76/15½: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in Greece</hi> (<persName type="to"><hi rend="italic">Goold</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1929-05-16T18:00:00-04:00">May 16, 1929—6
                                p.m.</date></dateline></opener>
                        <p>25. Your 36, May 15, 6 p.m. Department approves action taken by you.</p>
                        <p>Please inform Minister of Communications through Foreign Office that Mr.
                            Durham left Paris for Athens on today’s Orient Express.</p>
                        <closer><signed><hi rend="smallcaps">Stimson</hi></signed></closer>
                    </div>
                    </body></text></TEI>