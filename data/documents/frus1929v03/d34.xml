<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-08-30T15:00:00-05:00" frus:doc-dateTime-min="1929-08-30T15:00:00-05:00" n="34" subtype="historical-document" type="document" xml:id="d34">
                        <note rend="inline" type="source">867n.404Wailing Wall/130: Telegram</note>
                        <head><hi rend="italic">The Consul General at Jerusalem</hi> (<persName type="from"><hi rend="italic">Knabenshue</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Jerusalem</hi></placeName>, <date calendar="gregorian" when="1929-08-30T22:00:00+02:00">August 30, 1929—10
                                p.m.</date><lb/>[Received August 31—1:22 a.m.]</dateline></opener>
                        <p>Department’s August 28, 8 p.m.<note n="43" xml:id="d34fn43">Not printed;
                                it transmitted text of telegram No. 230 of August 28, midnight, to
                                the Ambassador in Great Britain, <ref target="#pg_53">p.
                                53</ref>.</note> Four British troops stationed today at the
                            consulate general for its protection.</p>
                        <closer><signed><hi rend="smallcaps">Knabenshue</hi></signed></closer>
                    </div>
                    </body></text></TEI>