    <text>
        <body>
            <div frus:doc-dateTime-max="1930-01-07T23:59:59-05:00"
                frus:doc-dateTime-min="1930-01-07T00:00:00-05:00" n="563"
                subtype="historical-document" type="document" xml:id="d563">
                <note rend="inline" type="source">711.12155/358</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Mexican Ambassador</hi> (<persName type="to">
                        <hi rend="italic">Téllez</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1930-01-07">January 7,
                            1930</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Ambassador</hi>: Referring to a telephone
                    conversation on the fourth instant between a member of your staff and an officer
                    of this Department, with reference to your note of May 31, 1929, I desire to
                    inform you that this Government has determined to hold the matter of selecting a
                    site for a federal building in El Paso in abeyance for the time being.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>J. P. <hi rend="smallcaps">Cotton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
