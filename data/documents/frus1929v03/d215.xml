<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-12-18T13:00:00-05:00" frus:doc-dateTime-min="1929-12-18T13:00:00-05:00" n="215" subtype="historical-document" type="document" xml:id="d215">
                        <note rend="inline" type="source">838.42/88: Telegram</note>
                        <head><hi rend="italic">The High Commissioner in Haiti</hi> (<persName type="from"><hi rend="italic">Russell</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Port-au-Prince</hi></placeName>, <date calendar="gregorian" when="1929-12-18T13:00:00-05:00">December 18, 1929—1
                                p.m.</date><lb/>[Received 2:50 p.m.]</dateline></opener>
                        <p>120. All quiet. Educational system of Service Technique being
                            reestablished but progress very slow.</p>
                        <closer><signed><hi rend="smallcaps">Russell</hi></signed></closer>
                    </div>
                    </body></text></TEI>