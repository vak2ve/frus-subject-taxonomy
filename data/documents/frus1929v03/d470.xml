<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-04-16T18:00:00-05:00" frus:doc-dateTime-min="1929-04-16T18:00:00-05:00" n="470" subtype="historical-document" type="document" xml:id="d470">
                        <note rend="inline" type="source">812.00Sonora/700: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Mexico</hi> (<persName type="from"><hi rend="italic">Morrow</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Mexico</hi></placeName>, <date calendar="gregorian" when="1929-04-16T17:00:00-06:00">April 16, 1929—5
                                p.m.</date><lb/>[Received 6:34 p.m.]</dateline></opener>
                        <p>210. Your 288, April 15, 7 p.m.<note n="50" xml:id="d470fn50">See
                                footnote 48.</note> I have addressed a formal note to the Minister
                            for Foreign Affairs in accordance with your instructions and will also
                            speak to the President on the subject this afternoon.</p>
                        <closer><signed><hi rend="smallcaps">Morrow</hi></signed></closer>
                    </div>
                    </body></text></TEI>