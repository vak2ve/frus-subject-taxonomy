                                    </row>
                                    <row>
                                        <cell>Tenth</cell>
                                        <cell>“</cell>
                                        <cell>“</cell>
                                        <cell>“</cell>
                                        <cell cols="3">(Tarik Br[<hi rend="italic">Er</hi>?]–Rad)</cell>
                                        <cell role="num">2,777.75</cell>
                                        <cell>“</cell>
                                    </row>
                                    <row>
                                        <cell>Third</cell>
                                        <cell>“</cell>
                                        <cell cols="5">Raisuni</cell>
                                        <cell role="num">12,000.00</cell>
                                        <cell>“</cell>
                                    </row>
                                    <row>
                                        <cell cols="7">(For claim that precedes the accepted
                                            increase accorded by the High Commissioner)</cell>
                                        <cell/>
                                        <cell/>
                                    </row>
                                    <row>
                                        <cell cols="7">First claim, Mohamed Oknin</cell>
                                        <cell rendition="#border-bottom" role="num">8,333.35</cell>
