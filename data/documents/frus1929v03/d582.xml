                                        <cell role="num">555.55</cell>
                                        <cell>“</cell>
                                    </row>
                                    <row>
                                        <cell>Second</cell>
                                        <cell>“</cell>
                                        <cell cols="5">Mohamed Oknin</cell>
                                        <cell role="num">4,188.25</cell>
                                        <cell>“</cell>
                                    </row>
                                    <row>
                                        <cell cols="9"><hi rend="italic">b</hi>) For damages to
                                            farms:</cell>
                                    </row>
                                    <row>
                                        <cell>Second</cell>
                                        <cell>claim,</cell>
                                        <cell>Tahami</cell>
                                        <cell>Selaui</cell>
                                        <cell cols="3">(El Minza)</cell>
                                        <cell role="num">23,083.35</cell>
