                                        <cell>claim,</cell>
                                        <cell cols="3">S. &amp; J. Cohen</cell>
                                        <cell role="num">4,140.00</cell>
                                    </row>
                                    <row>
                                        <cell>Third</cell>
                                        <cell>”</cell>
                                        <cell>Rahamin</cell>
                                        <cell>[<hi rend="italic">Rahamim?</hi>]</cell>
                                        <cell>Muyal</cell>
                                        <cell role="num">17,035.50</cell>
                                    </row>
                                    <row>
                                        <cell>Fourth</cell>
                                        <cell>”</cell>
                                        <cell>”</cell>
