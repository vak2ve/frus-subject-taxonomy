<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1929-04-26T15:00:00-05:00" frus:doc-dateTime-min="1929-04-26T15:00:00-05:00" n="268" subtype="historical-document" type="document" xml:id="d268">
                        <note rend="inline" type="source">811.3394/88: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in Japan</hi> (<persName type="to"><hi rend="italic">Neville</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1929-04-26T15:00:00-05:00">April 26, 1929—3
                                p.m.</date></dateline></opener>
                        <p>36. Your 43, April 24.<note n="37" xml:id="d268fn37">Not printed.</note>
                            Advise Foreign Office informally and orally that <hi rend="italic">Asheville</hi> will not visit any Japanese mandated islands on her
                            return to the United States from Manila.</p>
                        <closer><signed><hi rend="smallcaps">Stimson</hi></signed></closer>
                    </div>
                    </body></text></TEI>