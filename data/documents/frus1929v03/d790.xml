                subtype="historical-document" type="document" xml:id="d790">
                <note rend="inline" type="source">417.00/338: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Hanna</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1929-07-24T15:00:00-05:45"
                            >July 24, 1929—3 p.m.</date>
                        <lb/>[Received 4:33 p.m.]</dateline>
                </opener>
                <p>201. My 188, July 12, 3 p.m. second paragraph. Conservative Party selected five
                    candidates yesterday and the President told me this morning that he will appoint
                    one of these [as] Conservative member of the Claims Commission.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hanna</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
