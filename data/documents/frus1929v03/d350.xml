                subtype="historical-document" type="document" xml:id="d350">
                <note rend="inline" type="source">882.124A/43: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in France</hi> (<persName type="from">
                        <hi rend="italic">Armour</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1929-07-19T16:00:00+01:00"
                            >July 19, 1929—4 p.m.</date>
                        <lb/>[Received July 19—2:08 p.m.]</dateline>
                </opener>
                <p>342. Department’s 228, July 11, 2 p.m. Foreign Office states French Consulate at
                    Monrovia has been requested to support representations made by our
                    representative there.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Armour</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
