    <text>
        <body>
            <div frus:doc-dateTime-max="1929-05-07T23:59:59-05:00"
                frus:doc-dateTime-min="1929-05-07T00:00:00-05:00" n="504"
                subtype="historical-document" type="document" xml:id="d504">
                <note rend="inline" type="source">612.0023/90</note>
                <head>
                    <hi rend="italic">The Mexican Ambassador</hi> (<persName type="from">
                        <hi rend="italic">Téllez</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1929-05-07">May 7,
                            1929</date>.</dateline>
                    <seg rendition="#left">No. 2822</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary</hi>: I have the honor to inform Your
                    Excellency that according to instructions received from my Government the
                    Customhouses at Nogales, Agua Prieta, and Guaymas, have been newly reopened to
                    international traffic.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Manuel C. Téllez</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
