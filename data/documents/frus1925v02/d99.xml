                subtype="historical-document" type="document" xml:id="d99">
                <note rend="inline" type="source">890d.01/226: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Herrick</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1925-11-09T12:00:00+00:00">
                            <hi rend="italic">November 9, 1925—noon</hi>
                        </date>.<lb/>[Received November 9—8:53 a.m.]</dateline>
                </opener>
                <p>554. Senator Henry de Jouvenel, the editor of <hi rend="italic">Le Matin</hi>,
                    has been appointed High Commissioner in Syria and will leave this week for his
                    post.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Herrick</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
