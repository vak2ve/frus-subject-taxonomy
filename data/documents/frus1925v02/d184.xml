                subtype="historical-document" type="document" xml:id="d184">
                <note rend="inline" type="source">867n.01/446: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Houghton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1925-11-24T10:00:00+00:00">
                            <hi rend="italic">November 24, 1925—10 a.m.</hi>
                        </date>
                        <lb/>[Received November 24—7:09 a.m.]</dateline>
                </opener>
                <p>356. Department’s 344, November 23, 3 p.m.<note n="42" xml:id="d184fn42">Not
                        printed.</note> Informally advised by Foreign Office that I may expect reply
                    to Embassy’s note based on Department’s instruction number 224, October 13th, to
                    be somewhat further delayed due to inundation of work on Treaty Department
                    caused by recent royal death.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Houghton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
