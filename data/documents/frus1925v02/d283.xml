                subtype="historical-document" type="document" xml:id="d283">
                <note rend="inline" type="source">815.00/3721: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Houghton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1925-05-18T16:00:00+01:00">
                            <hi rend="italic">May 18, 1925—4 p.m.</hi>
                        </date>
                        <lb/>[Received May 18—10:58 (?) a.m.]</dateline>
                </opener>
                <p>148. Department’s number 154, dated May 16, 4 p.m. Foreign Office has assured me
                    that it will issue proper instructions.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Houghton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
