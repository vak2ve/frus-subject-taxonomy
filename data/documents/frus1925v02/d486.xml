                subtype="historical-document" type="document" xml:id="d486">
                <note rend="inline" type="source">817.00/3307: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Eberhardt</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1925-09-01T14:00:00-05:45">
                            <hi rend="italic">September 1, 1925—2 p.m.</hi>
                        </date>
                        <lb/>[Received 9:55 p.m.]</dateline>
                </opener>
                <p>135. Referring to the Legation’s No. 134, August 29, 5 p.m. Martial law declared
                    in Managua yesterday. Railroad communication resumed, otherwise situation
                    remains unchanged.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Eberhardt</hi>
                    </signed>
                </closer>
            </div>
        </body>
