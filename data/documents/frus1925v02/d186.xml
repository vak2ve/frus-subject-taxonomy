                <note rend="inline" type="source">867n.01/448: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Houghton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1925-12-03T16:00:00+00:00">
                            <hi rend="italic">December 3, 1925—4 p.m.</hi>
                        </date>
                        <lb/>[Received December 3—3:42 p.m.]</dateline>
                </opener>
                <p>370. My 366, November 30, 6 p.m.<note n="43" xml:id="d186fn43">Not
                        printed.</note> Ratifications exchanged this afternoon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Houghton</hi>
                    </signed>
                </closer>
            </div>
        </body>
