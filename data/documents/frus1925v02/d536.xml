<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1925-11-24T09:50:00-05:00" frus:doc-dateTime-min="1925-11-24T09:50:00-05:00" n="536" subtype="historical-document" type="document" xml:id="d536">
                        <note rend="inline" type="source">334.334 R 33/8: Telegram</note>
                        <head><hi rend="italic">The Minister in Paraguay</hi> (<persName type="from"><hi rend="italic">Kreeck</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Asunción</hi></placeName>, <date calendar="gregorian" when="1925-11-24T11:00:00-03:50"><hi rend="italic">November 24,
                                        1925—11 a.m.</hi></date><lb/>[Received 11:40
                                p.m.]</dateline></opener>
                        <p>21. Paraguayan Government accepts jewels to be delivered here. How shall
                            this Legation proceed?</p>
                        <closer><signed><hi rend="smallcaps">Kreeck</hi></signed></closer>
                    </div>
                    </body></text></TEI>