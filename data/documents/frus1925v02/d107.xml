                subtype="historical-document" type="document" xml:id="d107">
                <note rend="inline" type="source">890d.00/259: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Beirut</hi> (<persName type="to">
                        <hi rend="italic">Knabenshue</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1925-11-17T19:00:00-05:00">
                            <hi rend="italic">November 17, 1925—7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Department has no intention at present of withdrawing destroyers in view of
                    situation set forth in your telegram of November 16, 7 p.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
