<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1925-11-04T17:00:00-05:00" frus:doc-dateTime-min="1925-11-04T17:00:00-05:00" n="20" subtype="historical-document" type="document" xml:id="d20">
                        <note rend="inline" type="source">211.37/30: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in Cuba</hi> (<persName type="to"><hi rend="italic">Crowder</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1925-11-04T17:00:00-05:00"><hi rend="italic">November 4,
                                        1925—5 p.m.</hi></date></dateline></opener>
                        <p>120. Draft extradition treaty enclosed in your No. 1217, October 22, is
                            satisfactory …</p>
                        <p>Department will send you full powers.<note n="35" xml:id="d20fn35">Full
                                powers were sent the Ambassador on Nov. 7, 1925.</note></p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>