<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1925-11-09T18:45:00-05:00" frus:doc-dateTime-min="1925-11-09T18:45:00-05:00" n="496" subtype="historical-document" type="document" xml:id="d496">
                        <note rend="inline" type="source">817.00/3343: Telegram</note>
                        <head><hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from"><hi rend="italic">Eberhardt</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Managua</hi></placeName>, <date calendar="gregorian" when="1925-11-09T18:00:00-05:45"><hi rend="italic">November 9,
                                        1925—6 p.m.</hi></date><lb/>[Received 8:47
                            p.m.]</dateline></opener>
                        <p>165. Minister of Honduras advises me that Vice President Sacasa fleeing
                            from Leon has arrived at La Union, Honduras.</p>
                        <closer><signed><hi rend="smallcaps">Eberhardt</hi></signed></closer>
                    </div>
                    </body></text></TEI>