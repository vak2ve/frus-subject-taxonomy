    <text>
        <body>
            <div frus:doc-dateTime-max="1926-07-09T23:59:59-05:00"
                frus:doc-dateTime-min="1926-07-09T00:00:00-05:00" n="395"
                subtype="historical-document" type="document" xml:id="d395">
                <note rend="inline" type="source">611.60 m 31/18</note>
                <head>
                    <hi rend="italic">The Lithuanian Minister</hi> (<persName type="from">
                        <hi rend="italic">Bizauskas</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1926-07-09">
                            <hi rend="italic">July 9, 1926</hi>
                        </date>.<lb/>[Received July 10.]</dateline>
                    <seg rendition="#left">No. 2334</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to inform you that the <hi
                        rend="italic">modus vivendi</hi> concluded between the Government of
                    Lithuania and the Government of the United States by the exchange of notes on
                    December 23, 1925, was ratified by the Lithuanian Seimas on March 24, 1926.</p>
                <p>Accept [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">K. Bizauskas</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
