    <text>
        <body>
            <div frus:doc-dateTime-max="1925-07-20T23:59:59-05:00"
                frus:doc-dateTime-min="1925-07-20T00:00:00-05:00" n="593"
                subtype="historical-document" type="document" xml:id="d593">
                <note rend="inline" type="source">703.5867/86</note>
                <head>
                    <hi rend="italic">The Chargé in Sweden</hi> (<persName type="from">
                        <hi rend="italic">Magruder</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Stockholm</hi>
                        </placeName>, <date calendar="gregorian" when="1925-07-20">
                            <hi rend="italic">July 20, 1925</hi>
                        </date>.<lb/>[Received August 13.]</dateline>
                    <seg rendition="#left">No. 528</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: With reference to the Department’s instruction
                    No. 134 of June 24, 1925 (File No. 703.5867/85), respecting the discontinuance
                    of the representation of American interests in Turkey by the Swedish Government,
                    I have the honor to report that I am in receipt of a note from the Swedish
                    Ministry for Foreign Affairs, a copy and translation of which are herewith
                        enclosed,<note n="7" xml:id="d593fn7">Not printed.</note> to the effect that
                    the Swedish Minister at Constantinople has been instructed to discontinue such
                    representation and to turn over to the American High Commissioner any records
                    and other property of the United States that may be in his charge.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Alexander R. Magruder</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
