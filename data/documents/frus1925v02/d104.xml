                subtype="historical-document" type="document" xml:id="d104">
                <note rend="inline" type="source">890d.00/256: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Beirut</hi> (<persName type="from">
                        <hi rend="italic">Knabenshue</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Beirut</hi>
                        </placeName>, <date calendar="gregorian" when="1925-11-15T13:00:00+02:00">
                            <hi rend="italic">November 15, 1925—1 p.m.</hi>
                        </date>
                        <lb/>[Received November 14—9:20 p.m.]</dateline>
                </opener>
                <p>Reference telegram from Embassy at Paris to the Department, number 561, November
                    13, noon. Situation rapidly growing more serious generally and in Lebanon in
                    particular. Need for destroyers even more necessary now [than] heretofore.
                    Please postpone action on Embassy’s telegram until receipt of details in
                    telegrams following out a few hours later.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Knabenshue</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
