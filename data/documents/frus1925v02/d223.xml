                <note rend="inline" type="source">841.612/25: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Kellogg</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1924-12-30T16:00:00+00:00">
                            <hi rend="italic">December 30, 1924—4 p.m.</hi>
                        </date>
                        <lb/>[Received December 30—1:25 p.m.]</dateline>
                </opener>
                <p>542. Your 488, December 29, 4 p.m. Canadian potatoes not prohibited. Am making
                    representations as instructed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
