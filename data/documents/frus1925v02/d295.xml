                subtype="historical-document" type="document" xml:id="d295">
                <note rend="inline" type="source">815.00/3788: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Salvador</hi> (<persName type="from">
                        <hi rend="italic">Engert</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Salvador</hi>
                        </placeName>, <date calendar="gregorian" when="1925-07-06T09:00:00-06:00">
                            <hi rend="italic">July 6, 1925—9 a.m.</hi>
                        </date>
                        <lb/>[Received 5:45 p.m.]</dateline>
                </opener>
                <p>38. Legation’s 23, May 29th.<note n="31" xml:id="d295fn31">Not printed.</note>
                    Ferrera arrived here yesterday from Guatemala and the Minister for Foreign
                    Affairs assures me that he will be kept under strict surveillance.</p>
                <p>Repeated Tegucigalpa and Guatemala.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Engert</hi>
                    </signed>
                </closer>
            </div>
        </body>
