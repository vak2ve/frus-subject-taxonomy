                subtype="historical-document" type="document" xml:id="d489">
                <note rend="inline" type="source">817.00/3310: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Eberhardt</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1925-09-07T20:00:00-05:45">
                            <hi rend="italic">September 7, 1925—8 p.m.</hi>
                        </date>
                        <lb/>[Received September 8—10:08 a.m.]</dateline>
                </opener>
                <p>140. President Solorzano has just requested me to ask the Department to be good
                    enough to despatch an American war vessel to Bluefields and another to Corinto
                    immediately.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Eberhardt</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
