<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1925-08-01T16:45:00-05:00" frus:doc-dateTime-min="1925-08-01T16:45:00-05:00" n="484" subtype="historical-document" type="document" xml:id="d484">
                        <note rend="inline" type="source">124.1718/139: Telegram</note>
                        <head><hi rend="italic">The Chargé in Nicaragua</hi> (<persName type="from"><hi rend="italic">Thurston</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Managua</hi></placeName>, <date calendar="gregorian" when="1925-08-01T16:00:00-05:45"><hi rend="italic">August 1,
                                        1925—4 p.m.</hi></date><lb/>[Received 11:15
                            p.m.]</dateline></opener>
                        <p>126. The Legation guard left Managua this morning and arrived at Corinto
                            this afternoon.</p>
                        <closer><signed><hi rend="smallcaps">Thurston</hi></signed></closer>
                    </div>
                </body></text></TEI>