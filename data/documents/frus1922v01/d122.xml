<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1922-06-09T12:00:00-05:00" frus:doc-dateTime-min="1922-06-09T12:00:00-05:00" n="122" subtype="historical-document" type="document" xml:id="d122">
                        <note rend="inline" type="source">800.51 W 89 Poland/3: Telegram</note>
                        <head><hi rend="italic">The Minister in Poland</hi> (<persName type="from"><hi rend="italic">Gibson</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Warsaw</hi></placeName>, <date calendar="gregorian" when="1922-06-09T18:00:00+01:00"><hi rend="italic">June 9,
                                        1922—6 p.m.</hi></date><lb/>[Received June 10—7:47
                                p.m.]</dateline></opener>
                        <p>59. Department’s June 3, 10 a.m. Foreign Office states Gliwic<note n="21" xml:id="d122fn21">Hipolit Gliwic, commercial counselor of the Polish
                                Legation at Washington.</note> instructed by the Minister of Finance
                            on May 6 to represent Poland in the World War Foreign Debt
                            Commission.</p>
                        <closer><signed><hi rend="smallcaps">Gibson</hi></signed></closer>
                    </div>
