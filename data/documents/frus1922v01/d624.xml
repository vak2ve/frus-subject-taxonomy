    <text>
        <body>
            <div frus:doc-dateTime-max="1923-01-05T03:00:00-05:00"
                frus:doc-dateTime-min="1923-01-05T03:00:00-05:00" n="624"
                subtype="historical-document" type="document" xml:id="d624">
                <note rend="inline" type="source">500. A 4e/150: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Schurman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1923-01-05T16:00:00+08:00">
                            <hi rend="italic">January 5, 1923—4 p.m.</hi>
                        </date>
                        <lb/>[Received 4:45 p.m.]</dateline>
                </opener>
                <p>10. My 1, January 2, 3 p.m.<note n="92" xml:id="d624fn92">Not printed.</note>
                    Ministry of Foreign Affairs has notified Diplomatic Body that as each power
                    concerned has conveyed to the Chinese Government its approval of revised import
                    tariff it has been decided to bring it into effect on January 17th and syndicate
                    notifications to that effect were issued on January 3rd.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schurman</hi>
                    </signed>
                </closer>
            </div>
        </body>
