    <text>
        <body>
            <div frus:doc-dateTime-max="1921-10-29T23:59:59-05:00"
                frus:doc-dateTime-min="1921-10-29T00:00:00-05:00" n="807"
                subtype="historical-document" type="document" xml:id="d807">
                <note rend="inline" type="source">211.18/15</note>
                <head>
                    <hi rend="italic">The Chargé in Costa Rica</hi> (<persName type="from">
                        <hi rend="italic">Thurston</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San José</hi>
                        </placeName>, <date calendar="gregorian" when="1921-10-29">
                            <hi rend="italic">October 29, 1921</hi>
                        </date>.<lb/>[Received November 16.]</dateline>
                    <seg rendition="#left">No. 231</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Complementing my despatch number 230 of October
                    27, I have the honor to inform the Department that I have received a note from
                    the Minister for Foreign Affairs withdrawing his proposed amendment of the
                    Treaty of Extradition regarding the death penalty, and requesting that his other
                    proposed alterations of text be submitted to the Department.</p>
                <p>A copy and translation of the note from the Minister for Foreign Affairs are
                    attached hereto.<note n="8" xml:id="d807fn8">Not printed.</note>
                </p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Walter C. Thurston</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
