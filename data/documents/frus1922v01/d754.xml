                subtype="historical-document" type="document" xml:id="d754">
                <note rend="inline" type="source">861.77/2769: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Herrick</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1922-10-13T17:00:00+00:00">
                            <hi rend="italic">October 13, 1922—5 p.m.</hi>
                        </date>
                        <lb/>[Received October 13—1:58 p.m.]</dateline>
                </opener>
                <p>398. Note just received from Foreign Office, dated October 11th gives formal
                    adherence of French Government to your proposals regarding Chinese Eastern
                    Railway.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Herrick</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
