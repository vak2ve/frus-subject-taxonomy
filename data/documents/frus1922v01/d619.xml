                subtype="historical-document" type="document" xml:id="d619">
                <note rend="inline" type="source">500. A 4e/106: Telegram</note>
                <head>
                    <hi rend="italic">The Chairman of the American Delegation, China Tariff Revision
                        Commission</hi> (<persName type="from">
                        <hi rend="italic">Arnold</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName> [<date ana="#date_undated-inferred-from-document-content"
                            calendar="gregorian" when="1922-09-18">
                            <hi rend="italic">undated</hi>
                        </date>].<lb/>[Received September 28, 1922—8:57 a.m.]</dateline>
                </opener>
                <p>Tariff Commission completed work and adjourned 28th.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Arnold</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
