    <text>
        <body>
            <div frus:doc-dateTime-max="1922-12-01T23:59:59-05:00"
                frus:doc-dateTime-min="1922-12-01T00:00:00-05:00" n="142"
                subtype="historical-document" type="document" xml:id="d142">
                <note rend="inline" type="source">800.51 W 89 Latvia/3</note>
                <head>
                    <hi rend="italic">The Secretary of the World War Foreign Debt Commission</hi>
                        (<persName type="from">
                        <hi rend="italic">Wadsworth</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1922-12-01">
                            <hi rend="italic">December 1, 1922</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: I am enclosing herewith for
                    your information a memorandum of an interview with Mr. Charles Louis Seya,
                    Chargé d’Affaires of the Latvian Legation in Washington.<note n="36"
                        xml:id="d142fn36">Not printed.</note>
                </p>
                <p>Pursuant to action taken at the meeting of the Commission on November 22, 1922,
                    Mr. Seya has been notified that his suggestion as to the postponement of the
                    negotiations between his government and the Commission until January 1, 1923,
                    meets with the approval of the Commission.</p>
                <p>Very truly yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Eliot Wadsworth</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
