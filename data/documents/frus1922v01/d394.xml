                subtype="historical-document" type="document" xml:id="d394">
                <note rend="inline" type="source">832.607B/36: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Brazil</hi> (<persName type="to">
                        <hi rend="italic">Morgan</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1921-11-02T18:00:00-05:00">
                            <hi rend="italic">November 2, 1921—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>46. Department’s 45, October 27, 6 p.m.<note n="12" xml:id="d394fn12">Not
                        printed.</note>
                </p>
                <p>President today signed joint resolution of Congress accepting the invitation of
                    the Republic of Brazil to take part in international exposition to be held in
                    Rio de Janeiro in 1922.<note n="13" xml:id="d394fn13">42 Stat. 209.</note>
                    Inform Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
