<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1922-07-01T00:00:00-05:00" frus:doc-dateTime-min="1922-07-01T00:00:00-05:00" n="717" subtype="historical-document" type="document" xml:id="d717">
                        <note rend="inline" type="source">861.77/2594: Telegram</note>
                        <head><hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">Schurman</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1922-07-01T13:00:00+08:00"><hi rend="italic">July 1,
                                        1922—1 p.m.</hi></date><lb/>[Received July 1—4:36
                                a.m.]</dateline></opener>
                        <p>291. Press carries today announcement by Board of Directors, Chinese
                            Eastern Railway, of issue July 1st 5-year 10 percent bonds value
                            3,000,000 roubles. Stevens and Tokyo informed.</p>
                        <closer><signed><hi rend="smallcaps">Schurman</hi></signed></closer>
                    </div>
                    </body></text></TEI>