<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1922-07-24T07:00:00-05:00" frus:doc-dateTime-min="1922-07-24T07:00:00-05:00" n="512" subtype="historical-document" type="document" xml:id="d512">
                        <note rend="inline" type="source">893.113/318: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Italy</hi> (<persName type="from"><hi rend="italic">Child</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Rome</hi></placeName>, <date calendar="gregorian" when="1922-07-24T13:00:00+01:00"><hi rend="italic">July 24,
                                        1922—1 p.m.</hi></date><lb/>[Received July 24—12:40
                                p.m.]</dateline></opener>
                        <p>121. Department’s 98, July 14, 7 [<hi rend="italic">4</hi>] p.m. After
                            repeated inquiries Foreign Office now professes inability to reply
                            pending resigned ministerial crisis.</p>
                        <closer><signed><hi rend="smallcaps">Child</hi></signed></closer>
                    </div>
                    </body></text></TEI>