                <note rend="inline" type="source">893.113/318: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Italy</hi> (<persName type="to">
                        <hi rend="italic">Child</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1922-08-15T17:00:00-04:00">
                            <hi rend="italic">August 15, 1922—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>122. Your 121, July 24, 1 p.m.</p>
                <p>Cannot Italian Government now give definite reply to proposal contained in
                    Department’s 98 of July 14, 4 p.m.?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
