                <note rend="inline" type="source">623.2515/1034: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Peru</hi> (<persName type="from">
                        <hi rend="italic">Sterling</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1922-09-12T23:00:00-05:00">
                            <hi rend="italic">September 12, 1922—11 p.m.</hi>
                        </date>
                        <lb/>[Received 11:45 p.m.]</dateline>
                </opener>
                <p>70. My telegram number 69. Congress ratified protocol and complementary act
                    tonight.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sterling</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
