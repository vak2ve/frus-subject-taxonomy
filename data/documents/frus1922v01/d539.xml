                subtype="historical-document" type="document" xml:id="d539">
                <note rend="inline" type="source">893.34/182: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Herrick</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1922-07-05T16:00:00+01:00">
                            <hi rend="italic">July 5, 1922—4 p.m.</hi>
                        </date>
                        <lb/>[Received July 5—12:50 p.m.]</dateline>
                </opener>
                <p>277. Your 131, May 4, 2 p.m.<note n="97" xml:id="d539fn97">See footnote 91, <ref
                            target="#pg_748">p. 748</ref>.</note> Am officially notified French
                    Government prepared to subscribe to agreement relative to Bethlehem Steel
                    Corporation contract with China.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Herrick</hi>
                    </signed>
                </closer>
            </div>
        </body>
