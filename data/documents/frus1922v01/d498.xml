                subtype="historical-document" type="document" xml:id="d498">
                <note rend="inline" type="source">893.113/249: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from">
                        <hi rend="italic">Child</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1922-04-18T15:00:00+01:00">
                            <hi rend="italic">April 18, 1922—3 p.m.</hi>
                        </date>
                        <lb/>[Received April 19—1:34 a.m.]</dateline>
                </opener>
                <p>60. Department’s number 50, April 15, 2 p.m. Foreign Office states that no more
                    deliveries will be made under contracts before or after joint declaration.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Child</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
