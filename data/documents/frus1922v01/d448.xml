<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1922-05-06T00:00:00-05:00" frus:doc-dateTime-min="1922-05-06T00:00:00-05:00" n="448" subtype="historical-document" type="document" xml:id="d448">
                        <note rend="inline" type="source">893.00/4338: Telegram</note>
                        <head><hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">Schurman</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1922-05-06T13:00:00+08:00"><hi rend="italic">May 6, 1922—1
                                        p.m.</hi></date><lb/>[Received May 6—7:25
                            a.m.]</dateline></opener>
                        <p>202. My 197, May 4th. Marines arrived at Tientsin May 5, 4 p.m.</p>
                        <closer><signed><hi rend="smallcaps">Schurman</hi></signed></closer>
                    </div>
