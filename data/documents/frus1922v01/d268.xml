                subtype="historical-document" type="document" xml:id="d268">
                <note rend="inline" type="source">833.73/45: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Uruguay</hi> (<persName type="from">
                        <hi rend="italic">Armour</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Montevideo</hi>
                        </placeName>, <date calendar="gregorian" when="1922-03-14T16:00:00-04:00">
                            <hi rend="italic">March 14, 1922—4 p.m.</hi>
                        </date>
                        <lb/>[Received 8:05 p.m.]</dateline>
                </opener>
                <p>18. Referring to the Department’s number 5.<note n="48" xml:id="d268fn48">See
                        last paragraph of telegram no. 6, Mar. 13, to the Ambassador in Argentina,
                        printed <hi rend="italic">supra.</hi>
                    </note> No reply received from the Uruguayan Government [relative to] the
                    representations of Western representative.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Armour</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
