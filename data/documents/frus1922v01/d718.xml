                <note rend="inline" type="source">861.77/2596a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in China</hi> (<persName type="to">
                        <hi rend="italic">Schurman</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1922-07-01T14:00:00-04:00">
                            <hi rend="italic">July 1, 1922—2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>163. Please report regarding any negotiations between Chinese Government and
                    Moscow or Chita representatives as to Chinese Eastern Railway, with special
                    reference to status of the Inter-Allied Technical Board.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
