                subtype="historical-document" type="document" xml:id="d467">
                <note rend="inline" type="source">893.00/4412: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Schurman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1922-06-02T16:00:00+08:00">
                            <hi rend="italic">June 2, 1922—4 p.m.</hi>
                        </date>
                        <lb/>[Received June 2—10:35 a.m.]</dateline>
                </opener>
                <p>243. My 241, May 31, 9 p.m.<note n="46" xml:id="d467fn46">
                        <hi rend="italic">Post</hi>, <ref target="#pg_770">p. 770</ref>.</note>
                    President Hsu resigned this morning and left Peking at half past 3 o’clock this
                    afternoon for Tientsin.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schurman</hi>
                    </signed>
                </closer>
            </div>
        </body>
