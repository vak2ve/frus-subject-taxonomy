                subtype="historical-document" type="document" xml:id="d313">
                <note rend="inline" type="source">811.114 Gt. Brit/47</note>
                <head>
                    <hi rend="italic">The British Ambassador</hi> (<persName type="from">
                        <hi rend="italic">Geddes</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1922-09-29">
                            <hi rend="italic">September 29, 1922</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: With reference to the Cabinet’s
                    recent ruling against seizures outside the three-mile limit, except in cases
                    where the vessel concerned can be shown to have been in illegal communication
                    with the shore through her own boats, I should be most grateful if you could
                    inform me whether it is the intention to make this ruling retrospective so as to
                    apply to the case of vessels already seized.</p>
                <p>Believe me [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">A. C. Geddes</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
