    <text>
        <body>
            <div frus:doc-dateTime-max="1922-09-30T23:34:00-05:00"
                frus:doc-dateTime-min="1922-09-30T23:34:00-05:00" n="750"
                subtype="historical-document" type="document" xml:id="d750">
                <note rend="inline" type="source">861 A.01/364: Telegram</note>
                <head>
                    <hi rend="italic">The President of the Technical Board</hi> (<persName
                        type="from">
                        <hi rend="italic">Stevens</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Harbin</hi>
                        </placeName>, <date calendar="gregorian" when="1922-10-01T13:00:00+08:26">
                            <hi rend="italic">October 1, 1922—1 p.m.</hi>
                        </date>
                        <lb/>[Received October 1—11:04 a.m.]</dateline>
                </opener>
                <p>Your Sept. 29, 6 p.m.<note n="93" xml:id="d750fn93">Not printed.</note> Japanese
                    Army completed evacuation Chinese Eastern zone September 26th excepting about
                    eight of a military mission.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stevens</hi>
                    </signed>
                </closer>
            </div>
        </body>
