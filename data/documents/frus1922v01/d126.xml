<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1922-07-06T11:00:00-05:00" frus:doc-dateTime-min="1922-07-06T11:00:00-05:00" n="126" subtype="historical-document" type="document" xml:id="d126">
                        <note rend="inline" type="source">800.51 W 89 Finland/2: Telegram</note>
                        <head><hi rend="italic">The Minister in Finland</hi> (<persName type="from"><hi rend="italic">Kagey</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Helsingfors</hi></placeName>, <date calendar="gregorian" when="1922-07-06T18:00:00+02:00"><hi rend="italic">July 6,
                                        1922—6 p.m.</hi></date><lb/>[Received July
                                6—noon.]</dateline></opener>
                        <p>13. Referring to the Department’s circular through Paris, April 21, noon.
                            Finnish Minister at Washington has been instructed to negotiate with
                            World War Foreign Debt Commission.</p>
                        <closer><signed><hi rend="smallcaps">Kagey</hi></signed></closer>
                    </div>
