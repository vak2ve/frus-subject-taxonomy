<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1922-11-03T11:00:00-05:00" frus:doc-dateTime-min="1922-11-03T11:00:00-05:00" n="547" subtype="historical-document" type="document" xml:id="d547">
                        <note rend="inline" type="source">893.113/384: Telegram</note>
                        <head><hi rend="italic">The Ambassador in France</hi> (<persName type="from"><hi rend="italic">Herrick</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1922-11-03T16:00:00+00:00"><hi rend="italic">November 3,
                                        1922—4 p.m.</hi></date><lb/>[Received 7:55
                            p.m.]</dateline></opener>
                        <p>446. Your 319, October 17, 5 p.m.<note n="7" xml:id="d547fn7">See
                                footnote 4, <ref target="#pg_757">p. 757</ref>.</note> Foreign
                            Office informs me it concurs with the views of the United States
                            Government relative to requesting the adhesion of those powers
                            participating in or adhering to the arms embargo of 1919.</p>
                        <closer><signed><hi rend="smallcaps">Herrick</hi></signed></closer>
                    </div>
                    </body></text></TEI>