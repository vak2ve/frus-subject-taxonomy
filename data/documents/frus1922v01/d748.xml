                subtype="historical-document" type="document" xml:id="d748">
                <note rend="inline" type="source">861.77/2693: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName type="from">
                        <hi rend="italic">Harvey</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1922-09-11T18:00:00+01:00">
                            <hi rend="italic">September 11, 1922—6 p.m.</hi>
                        </date>
                        <lb/>[Received September 11—1:55 p.m.]</dateline>
                </opener>
                <p>398. Your number 264, of August 28, 3 p.m. via Paris.<note n="91"
                        xml:id="d748fn91">Not printed; see telegram no. 95, Aug. 28, to the
                        Ambassador in Japan, <ref target="#pg_913">p. 913</ref>.</note> British
                    Government concurs in the suggestion of the Japanese Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Harvey</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
