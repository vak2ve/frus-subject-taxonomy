                subtype="historical-document" type="document" xml:id="d450">
                <note rend="inline" type="source">893.00/4355: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Schurman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1922-05-10T22:00:00+08:00">
                            <hi rend="italic">May 10, 1922—10 p.m.</hi>
                        </date>
                        <lb/>[Received May 10—8:15 p.m.]</dateline>
                </opener>
                <p>212. Mandate issued this afternoon deprives Chang Tso-lin of all offices; another
                    mandate abolishes office of Inspector General of Manchuria.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schurman</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
