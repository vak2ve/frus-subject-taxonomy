                subtype="historical-document" type="document" xml:id="d615">
                <note rend="inline" type="source">500. A 4e/89a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to Mr.
                            <persName type="to">Henry Blackwood</persName>, Special Deputy Collector
                        of Customs, Seattle</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1922-05-27">
                            <hi rend="italic">May 27, 1922</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: You are hereby appointed an Associate Member of
                    the American Delegation on the International Commission to revise the Chinese
                    Customs Tariff provided for in the treaty relating to Chinese Customs Tariff,
                    signed at Washington February 6, 1922.</p>
                <p rend="center">. . . . . . . . . . . . . .</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Charles E. Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
