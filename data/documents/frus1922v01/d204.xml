                subtype="historical-document" type="document" xml:id="d204">
                <note rend="inline" type="source">723.2515/830: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Peru</hi> (<persName type="to">
                        <hi rend="italic">Sterling</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1922-01-30T16:00:00-05:00">
                            <hi rend="italic">January 30, 1922—4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>10. Your January 28, 2 p.m. The simple announcement that Peru and Chile have both
                    accepted the President’s invitation has been made, but the Department has not
                    published and will not publish the replies received from either Government.</p>
                <pb facs="0581" n="461" xml:id="pg_461"/>
                <p>[The remainder of the telegram is the same, <hi rend="italic">mutatis
                        mutandis</hi>, as telegram no. 12 to the Ambassador in Chile, <hi
                        rend="italic">supra</hi>, beginning with the second paragraph.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
