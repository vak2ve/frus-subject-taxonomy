    <text>
        <body>
            <div frus:doc-dateTime-max="1922-12-04T04:00:00-05:00"
                frus:doc-dateTime-min="1922-12-04T04:00:00-05:00" n="657"
                subtype="historical-document" type="document" xml:id="d657">
                <note rend="inline" type="source">893.74/255: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Schurman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1922-12-04T17:00:00+08:00">
                            <hi rend="italic">December 4, 1922—5 p.m.</hi>
                        </date>
                        <lb/>[Received December 4—4:10 p.m.]</dateline>
                </opener>
                <p>475. Department’s 279 November 29, 5 p.m. Protest filed with Minister for Foreign
                    Affairs and Minister of Communications on basis of monopolistic clause in
                    supplementary letter to Mitsui wireless contract.<note n="21" xml:id="d657fn21"
                        >See telegram no. 92, Feb. 18, 1821, from the Minister in China, <ref
                            target="frus1921v01#pg_416">
                            <hi rend="italic">Foreign Relations</hi>, 1921, vol. <hi
                                rend="smallcaps">i</hi>, p. 416</ref>.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schurman</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
