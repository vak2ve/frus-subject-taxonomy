<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1922-04-10T21:00:00-05:00" frus:doc-dateTime-min="1922-04-10T21:00:00-05:00" n="612" subtype="historical-document" type="document" xml:id="d612">
                        <note rend="inline" type="source">500. A 4e/23: Telegram</note>
                        <head><hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from"><hi rend="italic">Cunningham</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Shanghai</hi></placeName>, <date calendar="gregorian" when="1922-04-11T10:00:00+08:00"><hi rend="italic">April 11,
                                        1922—10 a.m.</hi></date><lb/>[Received April 10—11:27
                                p.m.]</dateline></opener>
                        <p>4. From Arnold.</p>
                        <p>Recommend the appointment W. A. Burns manager of the American Trading
                            Company Shanghai member American delegation Tariff Revision Commission
                            without remuneration. American Chamber of Commerce endorses.</p>
                        <closer><signed><hi rend="smallcaps">Cunningham</hi></signed></closer>
                    </div>
                    </body></text></TEI>