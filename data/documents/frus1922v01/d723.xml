                <note rend="inline" type="source">861.77/2603: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Harbin</hi> (<persName type="to">
                        <hi rend="italic">Hanson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1922-07-12T18:00:00-04:00">
                            <hi rend="italic">July 12, 1922—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>For Stevens. Your July 8, 6 p.m. Matter has been brought to attention Chinese
                    Foreign Office by Legation Peking.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
