<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1922-07-12T17:00:00-05:00" frus:doc-dateTime-min="1922-07-12T17:00:00-05:00" n="723" subtype="historical-document" type="document" xml:id="d723">
                        <note rend="inline" type="source">861.77/2603: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Consul at Harbin</hi> (<persName type="to"><hi rend="italic">Hanson</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1922-07-12T18:00:00-04:00"><hi rend="italic">July 12,
                                        1922—6 p.m.</hi></date></dateline></opener>
                        <p>For Stevens. Your July 8, 6 p.m. Matter has been brought to attention
                            Chinese Foreign Office by Legation Peking.</p>
                        <closer><signed><hi rend="smallcaps">Hughes</hi></signed></closer>
                    </div>
                    </body></text></TEI>