<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1922-11-12T23:00:00-05:00" frus:doc-dateTime-min="1922-11-12T23:00:00-05:00" n="549" subtype="historical-document" type="document" xml:id="d549">
                        <note rend="inline" type="source">893.113/388: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Japan</hi> (<persName type="from"><hi rend="italic">Warren</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Tokyo</hi></placeName>, <date calendar="gregorian" when="1922-11-13T13:00:00+09:00"><hi rend="italic">November 13,
                                        1922—1 p.m.</hi></date><lb/>[Received November 13—2:46
                                a.m.]</dateline></opener>
                        <p>195. Your 118, October 17, 6 p.m. The Japanese Government has no
                            objection to your proposal and request[s] American Government to
                            communicate with other governments.</p>
                        <closer><signed><hi rend="smallcaps">Warren</hi></signed></closer>
                    </div>
                    </body></text></TEI>