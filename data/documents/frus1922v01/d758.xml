                subtype="historical-document" type="document" xml:id="d758">
                <note rend="inline" type="source">861.77/2776: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Herrick</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1922-10-24T11:00:00+00:00">
                            <hi rend="italic">October 24, 1922—11 a.m.</hi>
                        </date>
                        <lb/>[Received October 24—10 a.m.]</dateline>
                </opener>
                <p>424. Foreign Office agrees to proposals contained in Department’s telegram 311,
                    October 13, 7 p.m., and states that the necessary instructions will be sent to
                    its Missions at Peking and Tokio as soon as this Embassy informs it of the
                    adhesion of the British and Japanese Governments.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Herrick</hi>
                    </signed>
                </closer>
            </div>
        </body>
