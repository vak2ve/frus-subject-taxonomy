                subtype="historical-document" type="document" xml:id="d67">
                <head>67. Memorandum From <persName type="from">A. Denis Clift</persName> of the
                    National Security Council Staff to Secretary of State <persName
                        corresp="#p_KHA1" type="to">Kissinger</persName>
                    <note n="1" type="source" xml:id="d67fn1">Source: Ford Library, National
                        Security Advisor, <persName corresp="#p_KHA1">Kissinger</persName>-<persName
                            corresp="#p_SB3">Scowcroft</persName> West Wing Office Files, Box 25,
                        United Kingdom-Diego Garcia. Top Secret; Sensitive; Eyes Only. Urgent; sent
                        for action. No action indicated, but <persName corresp="#p_SB3"
                            >Scowcroft</persName> signed the memorandum to Executive Secretary
                        George Springsteen attached at Tab B. The British telegram appears at Tab
                        C.</note>
                </head>
                <dateline>
                    <placeName>Washington</placeName>, <date calendar="gregorian" when="1974-02-02"
                        >February 2, 1974</date>.</dateline>
                <p>8 pages not declassified in time for publication.</p>
            </div>
