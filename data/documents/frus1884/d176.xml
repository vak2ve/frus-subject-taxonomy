    <text>
        <body>
            <div frus:doc-dateTime-max="1884-07-21T23:59:59-05:00" frus:doc-dateTime-min="1884-07-21T00:00:00-05:00" n="176" subtype="historical-document" type="document" xml:id="d176">
                <head>No. 176.<lb/>
                    <hi rend="italic">The <gloss type="from">Queen</gloss> to
                                the <gloss type="to">President</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1884-07-21">
                            <hi rend="italic">July</hi> 21,
                                1884</date>.</dateline>
                </opener>
                <p>To the <hi rend="smallcaps">President of the United States</hi>,<lb/>
                    <hi rend="italic">Washington:</hi>
                </p>
                <p>The Queen heartily congratulates the President and people of the United
                            States on the rescue of Lieutenant Greely and the gallant survivors of
                            the Arctic expedition.</p>
                <p>She trusts that favorable reports have been received of the
                            sufferers.</p>
                <closer>THE QUEEN,<lb/>
                    <hi rend="italic">Windsor Castle.</hi>
                </closer>
            </div>
        </body>
