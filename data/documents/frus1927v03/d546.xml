    <text>
        <body>
            <div frus:doc-dateTime-max="1924-07-26T02:27:00-05:00"
                frus:doc-dateTime-min="1924-07-24T17:00:00-05:00" n="546"
                subtype="historical-document" type="document" xml:id="d546">
                <note rend="inline" type="source">891.51A/173: Telegram</note>
                <head>
                    <hi rend="italic">The Administrator General of the Finances of Persia</hi>
                        (<persName type="from">
                        <hi rend="italic">Millspaugh</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Teheran</hi>
                        </placeName> [<date
                            ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                            calendar="gregorian" notAfter="1924-07-26T03:27:00-04:00"
                            notBefore="1924-07-24T18:00:00-04:00">
                            <hi rend="italic">undated</hi>
                        </date>].<lb/>[Received July 26, 1924—3:27 a.m.]</dateline>
                </opener>
                <p>American Financial Mission have asked settlement in view of violation of
                    contracts.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Millspaugh</hi>
                    </signed>
                </closer>
            </div>
        </body>
