<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-08-04T04:35:00-05:00" frus:doc-dateTime-min="1927-08-04T04:35:00-05:00" n="571" subtype="historical-document" type="document" xml:id="d571">
                        <note rend="inline" type="source">891.51A/378: Telegram</note>
                        <head><hi rend="italic">The Minister in Persia</hi> (<persName type="from"><hi rend="italic">Philip</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Teheran</hi></placeName>, <date calendar="gregorian" when="1927-08-04T13:00:00+03:25"><hi rend="italic">August 4,
                                        1927—1 p.m.</hi></date><lb/>[Received August 4—9:35
                                a.m.]</dateline></opener>
                        <p>51. Millspaugh left today, due New York via Italian vessel first week
                            September.</p>
                        <closer><signed><hi rend="smallcaps">Philip</hi></signed></closer>
