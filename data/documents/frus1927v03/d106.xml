                subtype="historical-document" type="document" xml:id="d106">
                <note rend="inline" type="source">033.1138/18: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Haiti</hi> (<persName type="from">
                        <hi rend="italic">Gross</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1927-03-17T14:00:00-05:00">
                            <hi rend="italic">March 17, 1927—2 p.m.</hi>
                        </date>
                        <lb/>[Received March 18—10:15 a.m.]</dateline>
                </opener>
                <p>17. Haitian Minister to Santo Domingo has telegraphed to President Borno that
                    Senator King has decided not to enter Haiti. The incident appears closed.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gross</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
