                subtype="historical-document" type="document" xml:id="d278">
                <note rend="inline" type="source">817.00/4590: Telegram</note>
                <head>
                    <hi rend="italic">The Second Secretary of Legation in Nicaragua</hi> (<persName
                        type="from">
                        <hi rend="italic">Dermis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1927-02-18T17:00:00-05:45">
                            <hi rend="italic">February 18, 1927—5 p.m.</hi>
                        </date>
                        <lb/>[Received 8:20 p.m.]</dateline>
                </opener>
                <p>48. Minister went to Corinto today for conference tomorrow with Admiral
                    Latimer.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dennis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
