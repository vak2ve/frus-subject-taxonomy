                subtype="historical-document" type="document" xml:id="d331">
                <note rend="inline" type="source">817.00/4782: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Eberhardt</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1927-05-16T11:00:00-05:45">
                            <hi rend="italic">May 16, 1927—11 a.m.</hi>
                        </date>
                        <lb/>[Received 1 p.m.]</dateline>
                </opener>
                <p>135. Mr. and Mrs. Stimson and Dawson left here for Corinto this morning. Will
                    sail this afternoon U. S. S. <hi rend="italic">Trenton</hi> for Hampton
                    Roads.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Eberhardt</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
