                <note rend="inline" type="source">819.6156 T 61/4: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Panama</hi> (<persName type="to">
                        <hi rend="italic">South</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1927-02-19T17:00:00-05:00">
                            <hi rend="italic">February 19, 1927—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>8. Your 21, February 17, 10 a.m. Please present note as suggested.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
