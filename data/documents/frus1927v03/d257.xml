<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-01-06T19:45:00-05:00" frus:doc-dateTime-min="1927-01-06T19:45:00-05:00" n="257" subtype="historical-document" type="document" xml:id="d257">
                        <note rend="inline" type="source">817.00/4377: Telegram</note>
                        <head><hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from"><hi rend="italic">Eberhardt</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Managua</hi></placeName>, <date calendar="gregorian" when="1927-01-06T19:00:00-05:45"><hi rend="italic">January 6,
                                        1927—7 p.m.</hi></date><lb/>[Received January 7—11:10
                                a.m.]</dateline></opener>
                        <p>8. Legation guard arrived here at noon and it is now on duty.</p>
                        <closer><signed><hi rend="smallcaps">Eberhardt</hi></signed></closer>
                    </div>
                    </body></text></TEI>