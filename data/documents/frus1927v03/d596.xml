<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-05-23T03:35:00-05:00" frus:doc-dateTime-min="1927-05-23T03:35:00-05:00" n="596" subtype="historical-document" type="document" xml:id="d596">
                        <note rend="inline" type="source">791.003/21: Telegram</note>
                        <head><hi rend="italic">The Minister in Persia</hi> (<persName type="from"><hi rend="italic">Philip</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Teheran</hi></placeName>, <date calendar="gregorian" when="1927-05-23T12:00:00+03:25"><hi rend="italic">May 23,
                                        1927—noon</hi></date>.<lb/>[Received May 23—10:33
                                a.m.]</dateline></opener>
                        <p>35. Note bearing date of May 17 has been delivered to Persian Government
                            in accordance with Department’s instruction No. 22 of May 21.<note n="41" xml:id="d596fn41">Not printed; but see Department’s telegram
                                No. 21, May 18, <hi rend="italic">supra.</hi></note> My trip to
                            Tabriz has been postponed.</p>
                        <closer><signed><hi rend="smallcaps">Philip</hi></signed></closer>
                    </div>
                    </body></text></TEI>