<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-09-11T16:45:00-05:00" frus:doc-dateTime-min="1927-09-11T16:45:00-05:00" n="348" subtype="historical-document" type="document" xml:id="d348">
                        <note rend="inline" type="source">817.00/5026: Telegram</note>
                        <head><hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from"><hi rend="italic">Eberhardt</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Managua</hi></placeName>, <date calendar="gregorian" when="1927-09-11T16:00:00-05:45"><hi rend="italic">September 11,
                                        1927—4 p.m.</hi></date><lb/>[Received 9
                            p.m.]</dateline></opener>
                        <p>238. My September 1, 4 p.m. Chamorro’s resignation as Minister to France
                            has not been accepted.</p>
                        <closer><signed><hi rend="smallcaps">Eberhardt</hi></signed></closer>
                    </div>
                    </body></text></TEI>