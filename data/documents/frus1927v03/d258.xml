<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-01-07T19:00:00-05:00" frus:doc-dateTime-min="1927-01-07T19:00:00-05:00" n="258" subtype="historical-document" type="document" xml:id="d258">
                        <note rend="inline" type="source">317.55/orig.: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Nicaragua</hi> (<persName type="to"><hi rend="italic">Eberhardt</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1927-01-07T19:00:00-05:00"><hi rend="italic">January 7,
                                        1927—7 p.m.</hi></date></dateline></opener>
                        <p>11. The Belgian Ambassador has requested on behalf of his Government that
                            the United States Government afford protection to Belgian lives and
                            property in Nicaragua.<note n="8" xml:id="d258fn8">Request not
                                printed.</note> You may accord such protection to Belgian nationals
                            as may be possible and proper under the circumstances.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>