<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-03-04T17:00:00-05:00" frus:doc-dateTime-min="1927-03-04T17:00:00-05:00" n="34" subtype="historical-document" type="document" xml:id="d34">
                        <note rend="inline" type="source">668.113C.P./2: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Minister in Greece</hi> (<persName type="to"><hi rend="italic">Skinner</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1927-03-04T17:00:00-05:00"><hi rend="italic">March 4,
                                        1927—5 p.m.</hi></date></dateline></opener>
                        <p>8. Emergency Fleet Corporation has been informed by operators of Shipping
                            Board vessels that Greek Government has or is about to promulgate
                            further restriction import regulations on flour. Please investigate and
                            report by telegraph.</p>
                        <closer><signed><hi rend="smallcaps">Grew</hi></signed></closer>
                    </div>
                    </body></text></TEI>