<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-08-24T18:45:00-05:00" frus:doc-dateTime-min="1927-08-24T18:45:00-05:00" n="342" subtype="historical-document" type="document" xml:id="d342">
                        <note rend="inline" type="source">817.00/5001: Telegram</note>
                        <head><hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from"><hi rend="italic">Eberhardt</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Managua</hi></placeName>, <date calendar="gregorian" when="1927-08-24T18:00:00-05:45"><hi rend="italic">August 24,
                                        1927—6 p.m.</hi></date><lb/>[Received 10
                            p.m.]</dateline></opener>
                        <p>209. McCoy and party arrived today; Munro is expected to arrive 27th.</p>
                        <closer><signed><hi rend="smallcaps">Eberhardt</hi></signed></closer>
                    </div>
