<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-11-02T18:00:00-05:00" frus:doc-dateTime-min="1927-11-02T18:00:00-05:00" n="426" subtype="historical-document" type="document" xml:id="d426">
                        <note rend="inline" type="source">817.51/1849: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in Nicaragua</hi> (<persName type="to"><hi rend="italic">Munro</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1927-11-02T18:00:00-05:00"><hi rend="italic">November 2,
                                        1927—6 p.m.</hi></date></dateline></opener>
                        <p>178. Your 311, November 1, noon. Department will bear expenses of
                            Cumberland’s visit to Nicaragua.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>