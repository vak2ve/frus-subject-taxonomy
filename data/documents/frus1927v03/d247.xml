    <text>
        <body>
            <div frus:doc-dateTime-max="1927-05-02T23:59:59-05:00"
                frus:doc-dateTime-min="1927-05-02T00:00:00-05:00" n="247"
                subtype="historical-document" type="document" xml:id="d247">
                <note rend="inline" type="source">862i.73/84</note>
                <head>
                    <hi rend="italic">The British Ambassador</hi> (<persName type="from">
                        <hi rend="italic">Howard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1927-05-02">
                            <hi rend="italic">May 2, 1927</hi>.</date>
                    </dateline>
                    <seg rendition="#left">No. 302</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: With reference to my note No. 213 of March 31st,
                    last, I have the honour to inform you, under instructions from His Majesty’s
                    Principal Secretary of State for Foreign Affairs, that His Majesty’s Government
                    consider that the Yap–Menado cable should be handed over at once to the
                    Netherlands Government without waiting for the resumption of the work of the
                    First Committee of the Washington Conference of 1920.</p>
                <p>I have [etc.]</p>
                <closer>(For the Ambassador)<lb/>
                    <signed>
                        <hi rend="smallcaps">H. G. Chilton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
