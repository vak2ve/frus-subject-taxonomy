                        <note rend="inline" type="source">417.00/280: Telegram</note>
                        <head><hi rend="italic">The Chargé in Nicaragua</hi> (<persName type="from"><hi rend="italic">Munro</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
