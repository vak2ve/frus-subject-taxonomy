                subtype="historical-document" type="document" xml:id="d496">
                <note rend="inline" type="source">417.00/280: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Munro</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1927-11-08T14:00:00-05:45">
                            <hi rend="italic">November 8, 1927—2 p.m.</hi>
                        </date>
                        <lb/>[Received 3:50 p.m.]</dateline>
                </opener>
                <p>323. Aguado took office on the Claims Commission yesterday.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Munro</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
