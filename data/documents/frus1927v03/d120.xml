    <text>
        <body>
            <div frus:doc-dateTime-max="1927-10-19T23:59:59-05:00"
                frus:doc-dateTime-min="1927-10-19T00:00:00-05:00" n="120"
                subtype="historical-document" type="document" xml:id="d120">
                <note rend="inline" type="source">711.152/9</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Honduras</hi> (<persName type="to">
                        <hi rend="italic">Summerlin</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1927-10-19">
                            <hi rend="italic">October 19, 1927</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 198</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: In accordance with the suggestion contained in
                    your No. 442 of September 9, 1927, the proposed Treaty of Friendship, Commerce
                    and Consular Eights between the United States and Honduras has been prepared at
                    the Department in form for signature and the two copies thereof are herewith
                        enclosed.<note n="13a" xml:id="d120fn13a">See signed treaty, <ref
                            target="#pg_101">p. 101</ref>.</note> The copy tied with red, white and
                    blue ribbon is intended to be the United States original and should be signed by
                    you first and forwarded to the Department by the first pouch after
                    signature.</p>
                <p>I am [etc.]</p>
                <closer>For the Secretary of State:<lb/>
                    <signed>
                        <hi rend="smallcaps">Francis White</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
