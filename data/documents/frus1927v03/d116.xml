                subtype="historical-document" type="document" xml:id="d116">
                <note rend="inline" type="source">711.152/5: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Honduras</hi> (<persName type="from">
                        <hi rend="italic">Summerlin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1926-08-14T12:00:00-06:00">
                            <hi rend="italic">August 14, 1926—noon</hi>
                        </date>.<lb/>[Received 1:47 p.m.]</dateline>
                </opener>
                <p>50. Department’s instruction number 77, July 28. Draft of treaty was submitted to
                    the Foreign Office this morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Summerlin</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
