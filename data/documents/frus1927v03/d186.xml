<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-11-17T19:00:00-05:00" frus:doc-dateTime-min="1927-11-17T19:00:00-05:00" n="186" subtype="historical-document" type="document" xml:id="d186">
                        <note rend="inline" type="source">812.6363/2425: Telegram</note>
                        <head><hi rend="italic">The Ambassador in Mexico</hi> (<persName type="from"><hi rend="italic">Morrow</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Mexico</hi></placeName>, <date calendar="gregorian" when="1927-11-17T18:00:00-06:00"><hi rend="italic">November 17,
                                        1927—6 p.m.</hi></date><lb/>[Received 8: 58
                            p.m.]</dateline></opener>
                        <p>412. The Supreme Court rendered decision today which is reported to hold
                            articles 14 and 15 of petroleum law unconstitutional. Will report fully
                            when copy of decision is obtained.</p>
                        <closer><signed><hi rend="smallcaps">Morrow</hi></signed></closer>
                    </div>
                    </body></text></TEI>