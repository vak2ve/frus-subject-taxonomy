<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-09-26T10:00:00-05:00" frus:doc-dateTime-min="1927-09-26T10:00:00-05:00" n="349" subtype="historical-document" type="document" xml:id="d349">
                        <note rend="inline" type="source">817.00/5046: Telegram</note>
                        <head><hi rend="italic">The Minister in Panama</hi> (<persName type="from"><hi rend="italic">South</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Panama</hi></placeName>, <date calendar="gregorian" when="1927-09-26T10:00:00-05:00"><hi rend="italic">September 26,
                                        1927—10 a.m.</hi></date><lb/>[Received 2:08
                            p.m.]</dateline></opener>
                        <p>93. Brigadier General McCoy sailed on <hi rend="italic">Pastores</hi>
                            yesterday, will arrive New York City October 2nd. Please advise Fort
                            Hoyle.</p>
                        <closer><signed><hi rend="smallcaps">South</hi></signed></closer>
                    </div>
                    </body></text></TEI>