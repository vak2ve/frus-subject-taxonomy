    <text>
        <body>
            <div frus:doc-dateTime-max="1923-02-13T23:59:59-05:00"
                frus:doc-dateTime-min="1923-02-13T00:00:00-05:00" n="7"
                subtype="historical-document" type="document" xml:id="d7">
                <note rend="inline" type="source">862P.01/22</note>
                <head>
                    <hi rend="italic">The Ambassador in France</hi> (<persName type="from">
                        <hi rend="italic">Herrick</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1923-02-13">
                            <hi rend="italic">February 13, 1923</hi>
                        </date>.<lb/>[Received February 28.]</dateline>
                    <seg rendition="#left">No. 2857</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to transmit under separate cover
                    the original texts of the Franco-American Conventions regarding the French
                    Mandates over Togoland<note n="11" xml:id="d7fn11">Not printed; the convention
                        relating to Togoland is the same, <hi rend="italic">mutatis mutandis</hi>,
                        as that relating to the Cameroons, and was signed, ratified, and proclaimed
                        on the same dates.</note> and the Cameroons which were signed to-day by M.
                    Poincaré and myself.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Myron T. Herrick</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
