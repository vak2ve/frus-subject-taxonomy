<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1923-09-03T15:00:00-05:00" frus:doc-dateTime-min="1923-09-03T15:00:00-05:00" n="490" subtype="historical-document" type="document" xml:id="d490">
                        <note rend="inline" type="source">123 Su 6/113: Telegram</note>
                        <head><hi rend="italic">The Chargé in Mexico</hi> (<persName type="from"><hi rend="italic">Summerlin</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Mexico
                                        City</hi></placeName>, <date calendar="gregorian" when="1923-09-03T13:00:00-07:00"><hi rend="italic">September 3,
                                        1923—1 p.m.</hi></date><lb/>[Received 6:50
                            p.m.]</dateline></opener>
                        <p>91. Your telegram no. 129, August 31, noon.<note n="28" xml:id="d490fn28">Not printed.</note> Your telegraphic letter of credence was
                            presented to and accepted by Mexican Minister for Foreign Affairs at
                            noon today.</p>
                        <closer><signed><hi rend="smallcaps">Summerlin</hi></signed></closer>
                    </div>
