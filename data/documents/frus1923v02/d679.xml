                subtype="historical-document" type="document" xml:id="d679">
                <note rend="inline" type="source">816.51/290: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Salvador</hi> (<persName type="from">
                        <hi rend="italic">Schwyler</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Salvador</hi>
                        </placeName>, <date calendar="gregorian" when="1923-08-29T13:00:00-06:00">
                            <hi rend="italic">August 29, 1923—1 p.m.</hi>
                        </date>
                        <lb/>[Received 8:22 p.m.]</dateline>
                </opener>
                <p>50. National Assembly this morning approved all pending loan decrees with only
                    one dissenting vote.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Schuyler</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
