<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1923-01-09T17:00:00-05:00" frus:doc-dateTime-min="1923-01-09T17:00:00-05:00" n="677" subtype="historical-document" type="document" xml:id="d677">
                        <note rend="inline" type="source">816.51/222: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in Salvador</hi> (<persName type="to"><hi rend="italic">Hewes</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1923-01-09T17:00:00-05:00"><hi rend="italic">January 9,
                                        1923—5 p.m.</hi></date></dateline></opener>
                        <p>2. Department’s December 30, 5 p.m.<note n="2" xml:id="d677fn2">Not
                                printed.</note> Department has now informed bankers that it has no
                            objection to their proceeding under loan contract of June 24 last.</p>
                        <closer><signed><hi rend="smallcaps">Hughes</hi></signed></closer>
                    </div>
                    </body></text></TEI>