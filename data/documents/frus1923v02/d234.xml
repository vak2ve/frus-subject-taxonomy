<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1923-04-27T04:00:00-05:00" frus:doc-dateTime-min="1923-04-27T04:00:00-05:00" n="234" subtype="historical-document" type="document" xml:id="d234">
                        <note rend="inline" type="source">868.48/439: Telegram</note>
                        <head><hi rend="italic">The High Commissioner at Constantinople</hi>
                                (<persName type="from"><hi rend="italic">Bristol</hi></persName>)
                                <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Constantinople</hi></placeName>, <date calendar="gregorian" when="1923-04-27T11:00:00+02:00"><hi rend="italic">April 27,
                                        1923—11 a.m.</hi></date><lb/>[Received April 27—9:14
                                a.m.]</dateline></opener>
                        <p>125. Department’s 61, April 6, 3 p.m. and my 105, April 12, 4 p.m.<note n="17" xml:id="d234fn17">Latter not printed.</note> Red Crescent,
                            Constantinople, has been authorized by Angora to pass Near East Relief
                            food supplies through customs free of duty. Details being worked out now
                            and satisfactory solution of difficulties most probable.</p>
                        <closer><signed><hi rend="smallcaps">Bristol</hi></signed></closer>
                    </div>
                    </body></text></TEI>