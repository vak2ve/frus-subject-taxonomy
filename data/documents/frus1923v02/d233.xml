    <text>
        <body>
            <div frus:doc-dateTime-max="1923-04-26T23:59:59-05:00"
                frus:doc-dateTime-min="1923-04-26T00:00:00-05:00" n="233"
                subtype="historical-document" type="document" xml:id="d233">
                <note rend="inline" type="source">868.51 Refugee Settlement Commission/37</note>
                <head>
                    <hi rend="italic">The Italian Ambassador</hi> (<persName type="from">
                        <hi rend="italic">Caetani</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Translation<note n="15" xml:id="d233fn15">File
                            translation revised.</note>]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1923-04-26">
                            <hi rend="italic">April 26, 1923</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Mr. Secretary of State</hi>: By direction of Signor
                    Mussolini, and with reference to the note which Your Excellency sent me under
                    date of March 31st last,<note n="16" xml:id="d233fn16">See footnote 11, <ref
                            target="#pg_329">p. 329</ref>.</note> I have the honor to assure Your
                    Excellency that the Italian Government is ready to consider with the most
                    benevolent interest the American proposal concerning systematic provision for
                    the refugees from Asia Minor.</p>
                <p>I welcome [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Caetani</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
