    <text>
        <body>
            <div frus:doc-dateTime-max="1923-03-03T23:59:59-05:00"
                frus:doc-dateTime-min="1923-03-03T00:00:00-05:00" n="145"
                subtype="historical-document" type="document" xml:id="d145">
                <note rend="inline" type="source">175.1/37</note>
                <head>
                    <hi rend="italic">The Vice Consul at Jerusalem</hi> (<persName type="from">
                        <hi rend="italic">Cobb</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Jerusalem</hi>
                        </placeName>, <date calendar="gregorian" when="1923-03-03">
                            <hi rend="italic">March 3, 1923</hi>
                        </date>.<lb/>[Received March 29.]</dateline>
                    <seg rendition="#left">No. 1104</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    the Department’s instruction of December 28, 1922, concerning certain
                    modifications in the provisional arrangement between this Consulate and the
                    Legal Secretary of the Palestine Government as regards the procedure to be
                    followed in civil and criminal cases in Palestine in which American citizens are
                    the defendants.</p>
                <p>The Chief Secretary of the Palestine Government has agreed to the modifications,
                    which were outlined in the Department’s abovementioned instruction, and has
                    issued instructions to the Palestinian Courts that they be put into effect.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">George C. Cobb</hi>
                    </signed>
                </closer>
            </div>
        </body>
