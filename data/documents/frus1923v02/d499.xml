                <note rend="inline" type="source">812.24/200: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Guatemala</hi> (<persName type="to">
                        <hi rend="italic">Geissler</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1923-12-29T11:00:00-05:00">
                            <hi rend="italic">December 29, 1923—11 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>71. Your 101, December 28, noon.</p>
                <p>In the understanding that the sales are to be made to the recognized Government
                    of Mexico, the Department perceives no objection.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hughes</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
