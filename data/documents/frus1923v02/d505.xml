                subtype="historical-document" type="document" xml:id="d505">
                <note rend="inline" type="source">311.1254 V 65/1</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Clerk of the Superior Court of Essex Comity,
                            Massachusetts</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1923-07-14">
                            <hi rend="italic">July 14, 1923</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I beg to request that you be good enough to
                    forward to the Department, for its information, a copy of the recent decision of
                    Justice William Cushing Wait in the case of the <hi rend="italic">United States
                        of Mexico</hi> v. <hi rend="italic">Mariano Viamonte y Fernandez.</hi>
                </p>
                <p>I am [etc.]</p>
                <closer>For the Secretary of State:<lb/>
                    <signed>
                        <hi rend="smallcaps">William Phillips</hi>
                    </signed>
                    <lb/>
                    <hi rend="italic">Under Secretary</hi>
                </closer>
            </div>
        </body>
    </text>
