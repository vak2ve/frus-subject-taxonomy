<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1923-03-27T18:00:00-05:00" frus:doc-dateTime-min="1923-03-27T18:00:00-05:00" n="643" subtype="historical-document" type="document" xml:id="d643">
                        <note rend="inline" type="source">361.1153 In 8/24: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Consul at Vladivostok</hi> (<persName type="to"><hi rend="italic">Tuck</hi></persName>)</head>
                        <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1923-03-27T18:00:00-05:00"><hi rend="italic">March 27,
                                        1923—6 p.m.</hi></date></dateline></opener>
                        <p>Under circumstances reported in your telegram no. 12, March 26, 1 p.m.,
                            you must use greatest care. Do not file further protests without
                            explicit instructions from the Department.</p>
                        <closer><signed><hi rend="smallcaps">Hughes</hi></signed></closer>
                    </div>
                    </body></text></TEI>