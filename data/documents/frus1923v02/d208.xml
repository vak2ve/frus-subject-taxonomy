<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1923-11-03T09:00:00-05:00" frus:doc-dateTime-min="1923-11-03T09:00:00-05:00" n="208" subtype="historical-document" type="document" xml:id="d208">
                        <note rend="inline" type="source">711.419/45: Telegram</note>
                        <head><hi rend="italic">The Chargé in Great Britain</hi> (<persName type="from"><hi rend="italic">Wheeler</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><seg rendition="#center">[Extract—Paraphrase]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1923-11-03T14:00:00+00:00"><hi rend="italic">November 3,
                                        1923—2 p.m.</hi></date><lb/>[Received 6:22
                            p.m.]</dateline></opener>
                        <p>485. Following from Ambassador Harvey at Southampton.</p>
                        <quote rend="blockquote">
                            <p>“… Curzon was not available at the time I left London but I signed a
                                    letter<note n="15a" xml:id="d208fn15a">Not printed.</note>
                                setting forth your proposals respecting Newcastle consulate, which
                                was delivered to the Foreign Office. … Unless they change their
                                minds the result in the case will be satisfactory to you.
                                Harvey.”</p>
                        </quote>
                        <closer><signed><hi rend="smallcaps">Wheeler</hi></signed></closer>
                    </div>
                    </body></text></TEI>