                subtype="historical-document" type="document" xml:id="d460">
                <note rend="inline" type="source">894.51 Or 4/27: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Japan</hi> (<persName type="from">
                        <hi rend="italic">Wilson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Extract—Paraphrase]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tokyo</hi>
                        </placeName>, <date calendar="gregorian" when="1923-03-26T15:00:00+09:00">
                            <hi rend="italic">March 26, 1923—3 p.m.</hi>
                        </date>
                        <lb/>[Received March 26—9:18 a.m.]</dateline>
                </opener>
                <p>29. … Farnham as agent for the National City Company on March 24 signed a
                    contract with the Oriental Development Company for a loan of $19,900,000, which
                    is the equivalent of 40,000,000 yen. …</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Wilson</hi>
                    </signed>
                </closer>
            </div>
        </body>
