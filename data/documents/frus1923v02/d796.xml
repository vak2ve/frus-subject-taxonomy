<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1922-12-30T18:00:00-05:00" frus:doc-dateTime-min="1922-12-30T18:00:00-05:00" n="796" subtype="historical-document" type="document" xml:id="d796">
                            <note rend="inline" type="source">767.68119F&amp;M/3: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the <gloss type="to">Special Mission at
                                        Lausanne</gloss></hi></head>
                            <opener><seg rendition="#center">[Paraphrase]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1922-12-30T18:00:00-05:00"><hi rend="italic">December
                                            30, 1922—6 p.m.</hi></date></dateline></opener>
                            <p>70. Mission’s 157 of December 28, 3 p.m. Your statement on
                                capitulations is approved. Continue use of your influence to secure
                                a settlement giving adequate guarantees.</p>
                            <closer><signed><hi rend="smallcaps">Hughes</hi></signed></closer>
                        </div>
                        </body></text></TEI>