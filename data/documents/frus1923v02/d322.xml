<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1923-01-18T14:00:00-05:00" frus:doc-dateTime-min="1923-01-18T14:00:00-05:00" n="322" subtype="historical-document" type="document" xml:id="d322">
                        <note rend="inline" type="source">838.51/1489: Telegram</note>
                        <head><hi rend="italic">The High Commissioner in Haiti</hi> (<persName type="from"><hi rend="italic">Russell</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Port au
                                        Prince</hi></placeName>, <date calendar="gregorian" when="1923-01-18T14:00:00-05:00"><hi rend="italic">January 18,
                                        1923—2 p.m.</hi></date><lb/>[Received January 19—11:25
                                a.m.]</dateline></opener>
                        <p>8. Department’s 10, January 16, 11 a.m.<note n="33" xml:id="d322fn33">Not
                                printed.</note> Instructions have been sent to Haitian Legation,
                            Paris, to publish redemption notice of 1910 bonds at once.</p>
                        <closer><signed><hi rend="smallcaps">Russell</hi></signed></closer>
                    </div>
                    </body></text></TEI>