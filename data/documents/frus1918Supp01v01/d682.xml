                subtype="historical-document" type="document" xml:id="d682">
                <note rend="inline" type="source">File No. 763.72/10977</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Chile</hi> (<persName corresp="#p_SJH1" type="to">
                        <hi rend="italic">Shea</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-08-12T19:00:00-04:00">
                            <hi rend="italic">August 12, 1918, 7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your August 9, 2 p.m. Department very interested in attitude of Chilean
                    Government that you report. You may intimate that you will be glad to receive
                    more specific information on this subject. If you deem it advisable, you may
                    also state that United States Government would be glad to consider making a
                    contract with the Chilean Government for the use of ex-German ships in Chile.
                    …</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
