                subtype="historical-document" type="document" xml:id="d755">
                <note rend="inline" type="source">File No. 763.72119/1410</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Rumania</hi> (<persName corresp="#p_VCJ1" type="to">
                        <hi rend="italic">Vopicka</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-08T14:00:00-05:00">
                            <hi rend="italic">March 8, 1918, 2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>176. Your 31 [<hi rend="italic">46</hi>], 1st. Department does not wish you to
                    join in representations regarding peace but you may reiterate assurances already
                    given.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
