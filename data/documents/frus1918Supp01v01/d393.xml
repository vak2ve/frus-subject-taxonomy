    <text>
        <body>
            <div frus:doc-dateTime-max="1918-11-06T23:59:59-05:00"
                frus:doc-dateTime-min="1918-11-06T00:00:00-05:00" n="393"
                subtype="historical-document" type="document" xml:id="d393">
                <note rend="inline" type="source">File No. 763.72119/2499</note>
                <head>
                    <hi rend="italic">The Chargé in the Netherlands</hi> (<persName
                        corresp="#p_BRW1" type="from">
                        <hi rend="italic">Bliss</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Hague</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-06">
                            <hi rend="italic">November 6, 1918</hi>
                        </date>. <lb/> [<hi rend="italic">Received 6.40 p.m.</hi>]</dateline>
                </opener>
                <p>4962. <persName>Wolff</persName> despatch, Berlin, states German delegation to
                    conclude armistice and open peace negotiations left this afternoon for the
                    west.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BRW1">
                            <hi rend="smallcaps">Bliss</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
