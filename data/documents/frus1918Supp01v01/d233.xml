<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-07-31T15:00:00-05:00" frus:doc-dateTime-min="1918-07-31T15:00:00-05:00" n="233" subtype="historical-document" type="document" xml:id="d233">
                            <note rend="inline" type="source">File No. 763.72/10783</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Diplomatic Agent at Cairo</hi>
                                    (<persName corresp="#p_GH1" type="to"><hi rend="italic">Gary</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-07-31T16:00:00-04:00">
                                        <hi rend="italic">July 31, 1918, 4 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Your 107, July 22, 5 p.m. Make appropriate representation to British
                                authorities and Jewish battalion to prevent further display by
                                Jewish battalion of American flag in Egypt and Palestine.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_PFL1">
                                        <hi rend="smallcaps">Polk</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>