<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-10-08T15:00:00-05:00" frus:doc-dateTime-min="1917-10-08T15:00:00-05:00" n="785" subtype="historical-document" type="document" xml:id="d785">
                        <note rend="inline" type="source">File No. 701.7311/3</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in France</hi> (<persName corresp="#p_SWG1" type="to"><hi rend="italic">Sharp</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-10-08T15:00:00-05:00">
                                    <hi rend="italic">October 8, 1917, 3 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>2702. Your despatch 5622, August 22.<note n="1" xml:id="d785fn1">Not
                                printed.</note> Inform Mr. <persName>Popovitch</persName> Government
                            of United States has learned of proposed establishment by Montenegrin
                            Government of legation at Washington and will be happy to receive an
                            accredited minister from that Government.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>