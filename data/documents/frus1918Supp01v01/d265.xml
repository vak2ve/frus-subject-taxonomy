<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-09-28T10:00:00-05:00" frus:doc-dateTime-min="1918-09-28T10:00:00-05:00" n="265" subtype="historical-document" type="document" xml:id="d265">
                            <note rend="inline" type="source">File No. 763.72119/1957</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in Switzerland</hi> (<persName corresp="#p_SPA1" type="to"><hi rend="italic">Stovall</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-09-28T11:00:00-04:00">
                                        <hi rend="italic">September 28, 1918, 11 a.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>3013. For <persName corresp="#p_MDI1">Murphy</persName>, Sofia:</p>
                            <p>Department desires you to return immediately to Sofia and to take no
                                part whatsoever in present situation without instructions.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>