    <text>
        <body>
            <div frus:doc-dateTime-max="1918-03-30T23:59:59-05:00"
                frus:doc-dateTime-min="1918-03-30T00:00:00-05:00" n="465"
                subtype="historical-document" type="document" xml:id="d465">
                <note rend="inline" type="source">File No. 103.97/127</note>
                <head>
                    <hi rend="italic">The Food Administration Representative at London</hi>
                        (<persName corresp="#p_SLP1" type="from">
                        <hi rend="italic">Sheldon</hi>
                    </persName>) <hi rend="italic">to the Food Administrator</hi> (<persName
                        corresp="#p_HHC1" type="to">
                        <hi rend="italic">Hoover</hi>
                    </persName>)<note n="1" xml:id="d465fn1">Transmitted by the Ambassador in Great
                        Britain to the Secretary of State (No. 9290) for <persName corresp="#p_HHC1"
                            >Hoover</persName>.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-30">
                            <hi rend="italic">March 30, 1918</hi>
                        </date>. <lb/> [<hi rend="italic">Received 11.41 a.m.</hi>]</dateline>
                </opener>
                <p>139. <persName corresp="#p_RDATL1">Rhondda</persName> communicates following for
                    you:</p>
                <p>The willingness of the American people voluntarily to reduce their consumption of
                    wheat products and the new measures you are taking to meet the emergency and
                    provide the Allies with bread are deeply appreciated. Such self-sacrifice and
                    whole-hearted effort inspire us with renewed determination.</p>
                <closer>
                    <signed>[<persName corresp="#p_SLP1">
                            <hi rend="smallcaps">Sheldon</hi>
                        </persName>]</signed>
                </closer>
            </div>
        </body>
