                subtype="historical-document" type="document" xml:id="d787">
                <note rend="inline" type="source">File No. 701.7341/1</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PWH1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1917-10-25T17:00:00+00:00">
                            <hi rend="italic">October 25, 1917, 5 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received October 26, 1.45 a.m.</hi>]</dateline>
                </opener>
                <p>7521. Your 5655, October 24, 3 p.m. British Government has received a request
                    from Montenegrin Government to recognize as its minister here a British subject.
                    The Foreign Office has replied that they will willingly receive a minister but
                    that he must be a Montenegrin subject.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PWH1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
