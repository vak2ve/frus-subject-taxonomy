<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-10-04T23:59:59-05:00" frus:doc-dateTime-min="1918-10-04T00:00:00-05:00" n="277" subtype="historical-document" type="document" xml:id="d277">
                            <note rend="inline" type="source">File No. 763.72/11630</note>
                            <head>
                                <hi rend="italic">The Chargé in the Netherlands</hi> (<persName corresp="#p_BRW1" type="from"><hi rend="italic">Bliss</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">The Hague</hi></placeName>, <date calendar="gregorian" when="1918-10-04">
                                        <hi rend="italic">October 4, 1918</hi></date>. <lb/> [<hi rend="italic">Received 9.10 p.m.</hi>]</dateline>
                            </opener>
                            <p>4650. Dutch press, 4th. <hi rend="italic">Nieuwe Rotterdamsche</hi>
                                <persName>Wolff</persName> telegram: <quote rend="blockquote">
                                    <p>
                                        <persName corresp="#p_BPMo1">Prince Max [of
                                            Baden]</persName> has been appointed Chancellor. At
                                        ordinary sitting Reichstag on 5th he will disclose
                                        Government program. <persName corresp="#p_GH2">Groeber</persName> and <persName corresp="#p_SP1">Scheidemann</persName> appointed secretaries without
                                        portfolios. <persName corresp="#p_WM2">Wallraf</persName>,
                                        Interior Secretary, has tendered resignation and will be
                                        replaced by Centrist. Fischbeck will be Prussian Minister
                                        for Commerce.</p>
                                </quote>
                            </p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_BRW1">
                                        <hi rend="smallcaps">Bliss</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>