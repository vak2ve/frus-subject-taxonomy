                subtype="historical-document" type="document" xml:id="d51">
                <note rend="inline" type="source">File No. 763.72119/8155</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Switzerland</hi> (<persName corresp="#p_WHR1" type="to">
                        <hi rend="italic">Wilson</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-02-04T14:00:00-05:00">
                            <hi rend="italic">February 4, 1918, 2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1449. Your 2544, January 31, 4 p.m. Withhold this information from French and
                    British chiefs of mission.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
