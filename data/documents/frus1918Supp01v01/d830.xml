                subtype="historical-document" type="document" xml:id="d830">
                <note rend="inline" type="source">File No. 763.72119/1854a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Special Agent at Corfu</hi> (<persName corresp="#p_DHP1" type="to">
                        <hi rend="italic">Dodge</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-08-07T18:00:00-04:00">
                            <hi rend="italic">August 7, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Department desires from time to time confidential reports on Serbian Government’s
                    position as to character of relation to be established between Serbia and
                    Jugo-Slav portion of Austria-Hungary if latter secure their liberty.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
