<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-09-02T18:00:00-05:00" frus:doc-dateTime-min="1918-09-02T18:00:00-05:00" n="521" subtype="historical-document" type="document" xml:id="d521">
                            <note rend="inline" type="source">File No. 103.94/361</note>
                            <head>
                                <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1918-09-03T00:00:00+01:00">
                                        <hi rend="italic">September 3, 1918, 12 a.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 1.27 p.m.</hi>]</dateline>
                            </opener>
                            <p>1571. For <persName corresp="#p_BBM1">Baruch</persName> from
                                    <persName corresp="#p_SLL1">Summers</persName>:</p>
                            <p>Representatives of the French and the Italian Governments have signed
                                inter-Allied tin agreement. <persName>Armsby</persName>.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_PWH1">
                                        <hi rend="smallcaps">Page</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>