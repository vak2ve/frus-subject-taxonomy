    <text>
        <body>
            <div frus:doc-dateTime-max="1918-11-04T17:00:00-05:00"
                frus:doc-dateTime-min="1918-11-04T17:00:00-05:00" n="711"
                subtype="historical-document" type="document" xml:id="d711">
                <note rend="inline" type="source">File No. 862.85/617</note>
                <head>
                    <hi rend="italic">The Ambassador in Chile</hi> (<persName corresp="#p_SJH1"
                        type="from">
                        <hi rend="italic">Shea</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santiago</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-04T18:00:00-04:00">
                            <hi rend="italic">November 4, 1918, 6 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 9.5 p.m.</hi>]</dateline>
                </opener>
                <p>Reported from authentic sources all German vessels in Chilean ports occupied
                    early this morning by Chilean marines.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SJH1">
                            <hi rend="smallcaps">Shea</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
