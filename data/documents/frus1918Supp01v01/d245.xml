<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-09-11T15:00:00-05:00" frus:doc-dateTime-min="1918-09-11T15:00:00-05:00" n="245" subtype="historical-document" type="document" xml:id="d245">
                            <note rend="inline" type="source">File No. 763.72/11349</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in Belgium</hi> (<persName corresp="#p_WB1" type="to"><hi rend="italic">Whitlock</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-09-11T16:00:00-04:00">
                                        <hi rend="italic">September 11, 1918, 4 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>310. Your 140, September 9, 7 p.m. This Government does not consider
                                that Count <persName>de Torring</persName>’s letter merits favorable
                                consideration</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>