                subtype="historical-document" type="document" xml:id="d324">
                <note rend="inline" type="source">File No. 763.72119/2251</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Switzerland</hi> (<persName corresp="#p_SPA1" type="to">
                        <hi rend="italic">Stovall</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-10-22T12:00:00-04:00">
                            <hi rend="italic">October 22, 1918, noon</hi>
                        </date>.</dateline>
                </opener>
                <p>5173. Your 5277, October 18, 6 p.m.<note n="1" xml:id="d324fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_369">p. 369</ref>.</note>
                    Department cannot authorize discussions with anyone representing Emperor
                        <persName>Charles</persName>, either in official or unofficial capacity.
                    Refer to this Government’s reply of October 18 [<hi rend="italic">19</hi>]<note
                        n="2" xml:id="d324fn2">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_368">p. 368</ref>.</note> to
                    Austrian peace proposal.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
