<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-03-14T18:00:00-05:00" frus:doc-dateTime-min="1918-03-14T18:00:00-05:00" n="428" subtype="historical-document" type="document" xml:id="d428">
                            <note rend="inline" type="source">File No. 654.51251/1</note>
                            <head>
                                <hi rend="italic">The Ambassador in Great Britain</hi> (<persName corresp="#p_PWH1" type="from"><hi rend="italic">Page</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram—Extract]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1918-03-14T23:00:00+00:00">
                                        <hi rend="italic">March 14, 1918, 11 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received 11.55 p.m.</hi>]</dateline>
                            </opener>
                            <p>9060. For the Acting Secretary only [from <persName corresp="#p_SRB1">Stevens</persName>]:</p>
                            <p>Delegates of Allied Powers in session as Allied Maritime Transport
                                Council have unanimously agreed upon dispositions, making possible
                                to send to Italy amount of coal absolutely for military and civil
                                requirements. … <persName corresp="#p_SRB1">Stevens</persName>.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_PWH1">
                                        <hi rend="smallcaps">Page</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>