    <text>
        <body>
            <div frus:doc-dateTime-max="1918-08-09T13:00:00-05:00"
                frus:doc-dateTime-min="1918-08-09T13:00:00-05:00" n="681"
                subtype="historical-document" type="document" xml:id="d681">
                <note rend="inline" type="source">File No. 763.72/10977</note>
                <head>
                    <hi rend="italic">The Ambassador in Chile</hi> (<persName corresp="#p_SJH1"
                        type="from">
                        <hi rend="italic">Shea</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santiago</hi>
                        </placeName>, <date calendar="gregorian" when="1918-08-09T14:00:00-04:00">
                            <hi rend="italic">August 9, 1918, 2 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received 9 p.m.</hi>]</dateline>
                </opener>
                <p>I am informed, through sources generally reliable, that Chilean Government is
                    willing to directly negotiate with Embassy terms for seizing ships and breaking
                    relations with Germany. …</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SJH1">
                            <hi rend="smallcaps">Shea</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
