<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-11-04T11:00:00-05:00" frus:doc-dateTime-min="1918-11-04T11:00:00-05:00" n="390" subtype="historical-document" type="document" xml:id="d390">
                            <note rend="inline" type="source">File No. 763.72/12094</note>
                            <head>
                                <hi rend="italic">The Minister in Switzerland</hi> (<persName corresp="#p_SPA1" type="from"><hi rend="italic">Stovall</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Berne</hi></placeName>, <date calendar="gregorian" when="1918-11-04T17:00:00+01:00">
                                        <hi rend="italic">November 4, 1918, 5 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received November 6, 4.17
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>5579. <persName>Baron [de] Vaux</persName>, Counselor Austrian
                                Legation, called on <persName>Francis McNutt</persName>, American
                                citizen, and impressed on him immediate danger of Bolshevik menace
                                in Austria and her insistence that American troops be sent to occupy
                                Vienna to prevent disorders, at the same time that a statement be
                                made explaining that they came in friendly spirit to safeguard the
                                peace.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_SPA1">
                                        <hi rend="smallcaps">Stovall</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>