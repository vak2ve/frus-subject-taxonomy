    <text>
        <body>
            <div frus:doc-dateTime-max="1918-11-09T17:00:00-05:00"
                frus:doc-dateTime-min="1918-11-09T17:00:00-05:00" n="412"
                subtype="historical-document" type="document" xml:id="d412">
                <note rend="inline" type="source">File No. 763.72119/2491</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Norway</hi> (<persName corresp="#p_SAG1" type="to">
                        <hi rend="italic">Schmedeman</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-09T17:00:00-05:00">
                            <hi rend="italic">November 9, 1918, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your November 5, 2 p.m.<note n="1" xml:id="d412fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_471">p. 471</ref>
                    </note> Department prefers to make no answer to message of Bolshevik Minister
                    for Foreign Affairs and is not prepared to negotiate with Bolshevik
                    authorities.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
