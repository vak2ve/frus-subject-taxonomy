<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-05-18T18:00:00-05:00" frus:doc-dateTime-min="1918-05-18T18:00:00-05:00" n="647" subtype="historical-document" type="document" xml:id="d647">
                            <note rend="inline" type="source">File No. 763.72/10059</note>
                            <head>
                                <hi rend="italic">The Minister in Haiti</hi> (<persName corresp="#p_BBA1" type="from"><hi rend="italic">Bailly-Blanchard</hi></persName>) <hi rend="italic">to the
                                        <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Port au Prince</hi></placeName>, <date calendar="gregorian" when="1918-05-18T18:00:00-05:00">
                                        <hi rend="italic">May 18, 1918, 6 p.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received May 19, 3.30
                                    p.m.</hi>]</dateline>
                            </opener>
                            <p>Your confidential May 10, 2 p.m. Instructions complied with.
                                President in perfect accord, and states that declaration will be
                                made after adoption of constitution.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_BBA1">
                                        <hi rend="smallcaps">Blanchard</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>