                subtype="historical-document" type="document" xml:id="d708">
                <note rend="inline" type="source">File No. 611.326/137</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Brazil</hi> (<persName corresp="#p_MEV1" type="to">
                        <hi rend="italic">Morgan</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-10-10T16:00:00-04:00">
                            <hi rend="italic">October 10, 1918, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your October 9, 5 p.m. You may confidentially inform President that as a special
                    concession to his wishes announcement will be withheld until Monday morning,
                    October 14, but that it will be impossible to hold it any longer.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
