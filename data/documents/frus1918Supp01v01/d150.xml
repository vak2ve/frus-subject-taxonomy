<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-04-18T23:59:59-05:00" frus:doc-dateTime-min="1918-04-18T00:00:00-05:00" n="150" subtype="historical-document" type="document" xml:id="d150">
                            <note rend="inline" type="source">File No. 763.72/9617</note>
                            <head>
                                <hi rend="italic">The British Ambassador on Special Mission</hi>
                                    (<persName corresp="#p_RERDI1" type="from"><hi rend="italic">Reading</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#left">No. 415</seg>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-04-18">
                                        <hi rend="italic">April 18, 1918</hi></date>. <lb/> [<hi rend="italic">Received April 19.</hi>]</dateline>
                            </opener>
                            <p>
                                <hi rend="smallcaps">Sir</hi>: I have the honour to inform you,
                                under instructions from His Majesty’s Government, that the French
                                Government have agreed to General <persName corresp="#p_FF1">Foch</persName>’s receiving the designation of
                                commander-in-chief of the Allied armies in France.</p>
                            <p>I have [etc.]</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_RERDI1">
                                        <hi rend="smallcaps">Reading</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>