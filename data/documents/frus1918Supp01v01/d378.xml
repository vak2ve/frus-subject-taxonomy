<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-11-04T12:00:00-05:00" frus:doc-dateTime-min="1918-11-04T12:00:00-05:00" n="378" subtype="historical-document" type="document" xml:id="d378">
                            <note rend="inline" type="source">File No. 763.72/12098a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in the Netherlands</hi> (<persName corresp="#p_BRW1" type="to"><hi rend="italic">Bliss</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-11-04T12:00:00-05:00">
                                        <hi rend="italic">November 4, 1918,
                                    noon</hi></date>.</dateline>
                            </opener>
                            <p>2334. Cable at once full text of constitutional amendments passed by
                                Reichstag and Bundesrat.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>