<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-09-06T13:00:00-05:00" frus:doc-dateTime-min="1917-09-06T13:00:00-05:00" n="784" subtype="historical-document" type="document" xml:id="d784">
                        <note rend="inline" type="source">File No. 701.7311/2</note>
                        <head>
                            <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_SWG1" type="from"><hi rend="italic">Sharp</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1917-09-06T19:00:00+01:00">
                                    <hi rend="italic">September 6, 1917, 7 p.m.</hi>
                                </date>
                                <lb/> [<hi rend="italic">Received 11.20 p.m.</hi>]</dateline>
                        </opener>
                        <p>2462. Your 2606, September 5, 3 p.m. Montenegrin Minister for Foreign
                            Affairs requested me to ask whether it would be agreeable to the
                            American Government that the King of Montenegro create a legation in
                            Washington. Copy of his letter forwarded in my despatch 5622 of August
                                22.<note n="1" xml:id="d784fn1">Not printed.</note>
                        </p>
                        <closer>
                            <signed>
                                <persName corresp="#p_SWG1">
                                    <hi rend="smallcaps">Sharp</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>