<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-10-21T16:00:00-05:00" frus:doc-dateTime-min="1918-10-21T16:00:00-05:00" n="321" subtype="historical-document" type="document" xml:id="d321">
                            <note rend="inline" type="source">File No. 763.72/11569</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in the Netherlands</hi> (<persName corresp="#p_BRW1" type="to"><hi rend="italic">Bliss</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-10-21T17:00:00-04:00">
                                        <hi rend="italic">October 21, 1918, 5 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>2269. Your 4595<note n="1" xml:id="d321fn1">
                                    <hi rend="italic">Ante</hi>, <ref target="#pg_327">p.
                                    327</ref>.</note> regarding pamphlet entitled <hi rend="italic">The League of Nations the Way to Peace</hi>, by <persName corresp="#p_EM1">Erzberger</persName>. Department desires to be
                                furnished with copies of this pamphlet as soon as it appears.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>