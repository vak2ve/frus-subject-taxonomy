<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-09-05T15:00:00-05:00" frus:doc-dateTime-min="1917-09-05T15:00:00-05:00" n="783" subtype="historical-document" type="document" xml:id="d783">
                        <note rend="inline" type="source">File No. 701.7311/1a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in France</hi> (<persName corresp="#p_SWG1" type="to"><hi rend="italic">Sharp</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-09-05T15:00:00-05:00">
                                    <hi rend="italic">September 5, 1917, 3 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>2606. Italian Embassy informs Department Montenegrin Government desirous
                            of establishing legation in Washington, and that inquiry was made
                            through you. Have you received such inquiry from Montenegrin
                            Government?</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_LR1">
                                    <hi rend="smallcaps">Lansing</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>