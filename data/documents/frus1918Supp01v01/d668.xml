    <text>
        <body>
            <div frus:doc-dateTime-max="1918-06-24T06:00:00-05:00"
                frus:doc-dateTime-min="1918-06-24T06:00:00-05:00" n="668"
                subtype="historical-document" type="document" xml:id="d668">
                <note rend="inline" type="source">File No. 611.326/64</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName corresp="#p_PTN1"
                        type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1918-06-24T13:00:00+02:00">
                            <hi rend="italic">June 24, 1918, 1 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received June 25, 9.52 a.m.</hi>]</dateline>
                </opener>
                <p>1763. Your 1475, June 21, 3 p.m.<note n="2" xml:id="d668fn2">Not printed; see
                        footnote 1, <hi rend="italic">ante</hi>, <ref target="#pg_697">p.
                        697</ref>.</note> In conversation this morning with Minister of Foreign
                    Affairs he states that I am authorized to say that he will act in entire harmony
                    with the other Allies.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PTN1">
                            <hi rend="smallcaps">Nelson Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
