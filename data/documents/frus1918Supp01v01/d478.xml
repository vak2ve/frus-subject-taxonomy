<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-06-12T23:59:59-05:00" frus:doc-dateTime-min="1918-06-12T00:00:00-05:00" n="478" subtype="historical-document" type="document" xml:id="d478">
                            <note rend="inline" type="source">Food Administrator’s File</note>
                            <head>
                                <hi rend="italic">The British Ambassador on Special Mission</hi>
                                    (<persName corresp="#p_RERDI1" type="from"><hi rend="italic">Reading</hi></persName>) <hi rend="italic">to the Food
                                    Administrator</hi> (<persName corresp="#p_HHC1" type="to"><hi rend="italic">Hoover</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-06-12">
                                        <hi rend="italic">June 12, 1918</hi></date>.</dateline>
                            </opener>
                            <p>
                                <hi rend="smallcaps">My Dear Mr. <persName corresp="#p_HHC1">Hoover</persName></hi>: I have just received a telegram
                                from Mr. <persName corresp="#p_BAJ1">Balfour</persName> asking me to
                                convey to you an invitation from His Majesty’s Government to be
                                their guest during your forthcoming visit to England.</p>
                            <p>I hope that you will feel that this invitation is from the British
                                people as much as from the British Government, and I trust that you
                                may be able to authorize me to inform Mr. <persName corresp="#p_BAJ1">Balfour</persName> that you will be able to
                                accept it.</p>
                            <p>Believe me [etc.]</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_RERDI1">
                                        <hi rend="smallcaps">Reading</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>