<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-01-23T23:59:59-05:00" frus:doc-dateTime-min="1918-01-23T00:00:00-05:00" n="456" subtype="historical-document" type="document" xml:id="d456">
                            <note rend="inline" type="source">Food Administrator’s File</note>
                            <head>
                                <hi rend="italic">The Food Administrator</hi> (<persName corresp="#p_HHC1" type="from"><hi rend="italic">Hoover</hi></persName>) <hi rend="italic">to the Food
                                    Administration Representative at London</hi> (<persName corresp="#p_SLP1" type="to"><hi rend="italic">Sheldon</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-01-23">
                                        <hi rend="italic">January 23, 1918</hi></date>.</dateline>
                            </opener>
                            <p>Inform <persName corresp="#p_RDATL1">Rhondda</persName>, your cable,
                                we will export every grain of wheat that the American people save
                                from their normal consumption. We shall appeal to them for greater
                                endeavor and have already introduced <pb facs="0629" n="537" xml:id="pg_537"/> stronger measures and we believe our people
                                will not fail to meet the emergency.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_HHC1">
                                        <hi rend="smallcaps">Hoover</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>