<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-10-31T16:00:00-05:00" frus:doc-dateTime-min="1918-10-31T16:00:00-05:00" n="602" subtype="historical-document" type="document" xml:id="d602">
                            <note rend="inline" type="source">File No. 763.72119/2457a</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Japan</hi> (<persName corresp="#p_MRS1" type="to"><hi rend="italic">Morris</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-10-31T16:00:00-05:00">
                                        <hi rend="italic">October 31, 1918—4 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Cable brief summary of essential points of Okuma’s<note n="2" xml:id="d602fn2">Marquis Shigenobu Okuma, Japanese Prime
                                    Minister 1914–16.</note> views on peace terms as published in
                                recent number of <hi rend="italic">Kokumin</hi>. Promptly <pb facs="0753" n="661" xml:id="pg_661"/> mail full translation,
                                also three copies translation of <persName>Ozaki</persName>’s book
                                on democracy.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_LR1">
                                        <hi rend="smallcaps">Lansing</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>