                subtype="historical-document" type="document" xml:id="d920">
                <note rend="inline" type="source">File No. 761.91/55</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Persia</hi> (<persName corresp="#p_CJL1" type="to">
                        <hi rend="italic">Caldwell</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-08-07T18:00:00-04:00">
                            <hi rend="italic">August 7, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>72. Your August 4, 11 a.m. [Avoid taking any action or committing this Government
                    for present. Keep Department fully and promptly informed and await
                    developments.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
