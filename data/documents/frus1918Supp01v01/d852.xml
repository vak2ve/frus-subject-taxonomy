<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-10-24T19:00:00-05:00" frus:doc-dateTime-min="1918-10-24T19:00:00-05:00" n="852" subtype="historical-document" type="document" xml:id="d852">
                            <note rend="inline" type="source">File No. 861.00/3041</note>
                            <head>
                                <hi rend="italic">The Ambassador in France</hi> (<persName corresp="#p_SWG1" type="from"><hi rend="italic">Sharp</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1918-10-25T00:00:00+00:00">
                                        <hi rend="italic">October 25, 1918, 12 a.m.</hi>
                                    </date>
                                    <lb/> [<hi rend="italic">Received October 26, 1.57
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>5569. French Government recognized Czecho-Slovak Provisional
                                Government 15th instant, Italian Government 21st instant.</p>
                            <closer>
                                <signed>
                                    <persName corresp="#p_SWG1">
                                        <hi rend="smallcaps">Sharp</hi>
                                    </persName>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>