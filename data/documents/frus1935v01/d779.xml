<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-10-12T14:00:00-05:00" frus:doc-dateTime-min="1935-10-12T14:00:00-05:00" n="779" subtype="historical-document" type="document" xml:id="d779">
                                <note rend="inline" type="source">765.84/1761: Telegram</note>
                                <head>
                                    <hi rend="italic">The <gloss type="from">Secretary of
                                            State</gloss> to the Ambassador in Italy</hi> (<persName type="to"><hi rend="italic">Long</hi></persName>)</head>
                                <opener>
                                    <dateline rendition="#right">
                                        <placeName>
                                            <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1935-10-12T14:00:00-05:00">October 12, 1935—2 p.m.</date>
                                    </dateline>
                                </opener>
                                <p>170. Your 697, October 12, 1 p.m. You may make on humanitarian
                                    grounds oral representations similar to but not exceeding those
                                    made by your colleagues.</p>
                                <closer>
                                    <signed>
                                        <hi rend="smallcaps">Hull</hi>
                                    </signed>
                                </closer>
                            </div>
                            </body></text></TEI>