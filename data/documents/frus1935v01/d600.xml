                <note rend="inline" type="source">765.84/442: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Ethiopia</hi> (<persName type="from">
                        <hi rend="italic">George</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Addis Ababa</hi>
                        </placeName>, <date calendar="gregorian" when="1935-07-06T19:00:00+02:35"
                            >July 6, 1935—7 p.m.</date>
                        <lb/> [Received July 6—2:10 p.m.]</dateline>
                </opener>
                <p>55. Department’s telegram No. 31.<note n="44" xml:id="d600fn44">July 5, 5 p.m.,
                            <ref target="#pg_725">p. 725</ref>.</note> Note delivered July 6, 7
                    p.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">George</hi>
                    </signed>
                </closer>
            </div>
