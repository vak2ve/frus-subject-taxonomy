<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-01-15T18:00:00-05:00" frus:doc-dateTime-min="1935-01-15T18:00:00-05:00" n="900" subtype="historical-document" type="document" xml:id="d900">
                            <note rend="inline" type="source">867.24/56: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Turkey</hi> (<persName type="to"><hi rend="italic">Skinner</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1935-01-15T18:00:00-05:00">January 15, 1935—6 p.m.</date>
                                </dateline>
                            </opener>
                            <p>4. Your 1, January 14, noon. I should view with disfavor assistance
                                by any agency of this Government in the financing of the sale of
                                arms and implements of war to any foreign government.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>