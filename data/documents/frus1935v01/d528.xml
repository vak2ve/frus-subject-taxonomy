                subtype="historical-document" type="document" xml:id="d528">
                <note rend="inline" type="source">765.84/1087: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName type="from">
                        <hi rend="italic">Long</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1935-09-09T21:00:00+01:00"
                            >September 9, 1935—9 p.m.</date>
                        <lb/> [Received September 9—4:40 p.m.]</dateline>
                </opener>
                <p>563. Following telegram has been received from the Legation at Addis Ababa:
                        <quote rend="blockquote">
                        <p>90, September 9, noon. Italian Consulates in Northern Ethiopia have been
                            closed and personnel withdrawn. All wives of Italian Legation officials
                            have departed. Exceptional military activities reliably reported from
                            Eritrean border point to imminence of Italian offensive. Engert.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Long</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
