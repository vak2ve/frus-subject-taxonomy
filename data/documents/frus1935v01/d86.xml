                subtype="historical-document" type="document" xml:id="d86">
                <note rend="inline" type="source">500.A15A5/440a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Japan</hi> (<persName type="to">
                        <hi rend="italic">Grew</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1935-07-13T16:00:00-04:00"
                            >July 13, 1935—4 p.m.</date>
                    </dateline>
                </opener>
                <p>106. Our Embassy at Berlin was told in strict confidence by the German Ministry
                    of Marine that Japan objects to German participation in the next Naval
                    Conference on the pretext that this would increase the representation of the
                    white races as against the yellow. Have you any confirmatory information?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
