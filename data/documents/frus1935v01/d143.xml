<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-11-06T17:00:00-05:00" frus:doc-dateTime-min="1935-11-06T17:00:00-05:00" n="143" subtype="historical-document" type="document" xml:id="d143">
                        <note rend="inline" type="source">500.A15A5/531: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Ambassador in the United Kingdom</hi>
                                (<persName type="to"><hi rend="italic">Bingham</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1935-11-06T17:00:00-05:00">November
                                    6, 1935—5 p.m.</date>
                            </dateline>
                        </opener>
                        <p>327. Your 555, November 6, 10 a.m.</p>
                        <list>
                            <label>(1)</label>
                            <item>We interpose no objection to the British Government’s inviting a
                                League observer to the Naval Conference in the same manner and under
                                the same conditions as in 1930.</item>
                            <label>(2)</label>
                            <item>You are authorized formally to inform the British Government that
                                the Government of the United States accepts the invitation to the
                                Naval Conference.</item>
                        </list>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Phillips</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>