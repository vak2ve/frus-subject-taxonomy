<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-08-17T15:00:00-05:00" frus:doc-dateTime-min="1935-08-17T15:00:00-05:00" n="620" subtype="historical-document" type="document" xml:id="d620">
                                <note rend="inline" type="source">765.84/858: Telegram</note>
                                <head>
                                    <hi rend="italic">The Chargé in Italy</hi> (<persName type="from"><hi rend="italic">Kirk</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                            State</gloss>
                                    </hi>
                                </head>
                                <opener>
                                    <dateline rendition="#right">
                                        <placeName>
                                            <hi rend="smallcaps">Rome</hi></placeName>, <date calendar="gregorian" when="1935-08-17T21:00:00+01:00">August 17, 1935—9 p.m.</date>
                                        <lb/> [Received August 17—5:06 p.m.]</dateline>
                                </opener>
                                <p>494. Department’s 135, August 17, 2 p.m. Request for audience
                                    presented and I expect a reply tomorrow morning.</p>
                                <closer>
                                    <signed>
                                        <hi rend="smallcaps">Kirk</hi>
                                    </signed>
                                </closer>
                            </div>
                            </body></text></TEI>