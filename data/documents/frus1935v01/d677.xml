                subtype="historical-document" type="document" xml:id="d677">
                <note rend="inline" type="source">711.00111 Armament Control/65: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to President
                            <persName type="to">Roosevelt</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1935-10-05T18:20:00-05:00"
                            >October 5, 1935—6:20 p.m.</date>
                    </dateline>
                </opener>
                <p>Your message authorizing immediate action received. I am preparing to act tonight
                    but awaiting any possible further comment or suggestions in reply to my long 3
                    section message of this afternoon.<note n="13" xml:id="d677fn13">
                        <hi rend="italic">Infra.</hi>
                    </note> If no message received from you, will act tonight.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
