<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-02-08T03:00:00-05:00" frus:doc-dateTime-min="1935-02-08T03:00:00-05:00" n="439" subtype="historical-document" type="document" xml:id="d439">
                            <note rend="inline" type="source">883.05/529: Telegram (part air)</note>
                            <head>
                                <hi rend="italic">The Minister in Egypt</hi> (<persName type="from"><hi rend="italic">Fish</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Cairo</hi></placeName>, <date calendar="gregorian" when="1935-02-08T10:00:00+02:00">February 8, 1935—10 a.m.</date>
                                    <lb/> [Received February 11—12:46 p.m.]</dateline>
                            </opener>
                            <p>6. Legation’s 4, January 25, 10 a.m. Egyptian Foreign Office in a
                                note received today requests that the American Government be good
                                enough to expedite Government reply to circular note No. 27, October
                                12, 1934.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Fish</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>