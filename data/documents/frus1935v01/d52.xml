<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-03-30T12:00:00-05:00" frus:doc-dateTime-min="1935-03-30T12:00:00-05:00" n="52" subtype="historical-document" type="document" xml:id="d52">
                            <note rend="inline" type="source">500.A15A4 General Committee
                                (Arms)/186: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the American Delegate</hi> (<persName type="to"><hi rend="italic">Wilson</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1935-03-30T12:00:00-05:00">March
                                        30, 1935—noon</date>.</dateline>
                            </opener>
                            <p>493. Your No. 1028, March 29, 10 a.m. We entirely approve of the
                                position you have assumed.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>