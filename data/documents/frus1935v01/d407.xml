<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-09-28T08:00:00-05:00" frus:doc-dateTime-min="1935-09-28T08:00:00-05:00" n="407" subtype="historical-document" type="document" xml:id="d407">
                        <note rend="inline" type="source">500.C111/887: Telegram</note>
                        <head>
                            <hi rend="italic">The Consul at Geneva</hi> (<persName type="from"><hi rend="italic">Gilbert</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Geneva</hi></placeName>, <date calendar="gregorian" when="1935-09-28T14:00:00+01:00">September
                                    28, 1935—2 p.m.</date>
                                <lb/> [Received September 28—1:45 p.m.]</dateline>
                        </opener>
                        <p>391. My 380, September 26, 4 p.m.<note n="4" xml:id="d407fn4">See
                                footnote 2, <ref target="#pg_521">p. 521</ref>.</note> The report
                            and resolutions of the Second Committee were adopted by the Assembly
                            without discussion today.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Gilbert</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>