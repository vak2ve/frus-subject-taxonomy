<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1936-01-13T15:00:00-05:00" frus:doc-dateTime-min="1936-01-13T15:00:00-05:00" n="445" subtype="historical-document" type="document" xml:id="d445">
                            <note rend="inline" type="source">883.05/554: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in Egypt</hi> (<persName type="to"><hi rend="italic">Fish</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1936-01-13T15:00:00-05:00">January 13, 1936—3 p.m.</date>
                                </dateline>
                            </opener>
                            <p>2. Your 1, January 7, 11 a.m. You may advise the Foreign Office that
                                this Government accepts the proposed amendment to the Regulations
                                for the Judicial Organization, the text of which was set forth in
                                the note of the Minister for Foreign Affairs of July 10, 1935.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Hull</hi>
                                </signed>
                            </closer>
                        </div>
                    </body></text></TEI>