    <text>
        <body>
            <div frus:doc-dateTime-max="1935-08-01T05:00:00-05:00"
                frus:doc-dateTime-min="1935-08-01T05:00:00-05:00" n="611"
                subtype="historical-document" type="document" xml:id="d611">
                <note rend="inline" type="source">765.84/697: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in the United Kingdom</hi> (<persName type="from">
                        <hi rend="italic">Atherton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1935-08-01T11:00:00+01:00"
                            >August 1, 1935—11 a.m.</date>
                        <lb/> [Received August 1—6:11 a.m.]</dateline>
                </opener>
                <p>349. Foreign Office expresses appreciation for advance information contained in
                    your 198, July 31, 11 p.m., and knows of no reason for delaying statement.<note
                        n="51" xml:id="d611fn51">Statement was issued to the press by the President
                        on August 1 at 11:30 a.m.; see Department of State, <hi rend="italic">Press
                            Releases</hi>, August 10, 1935, p. 119.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Atherton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
