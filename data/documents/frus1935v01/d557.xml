                subtype="historical-document" type="document" xml:id="d557">
                <note rend="inline" type="source">765.84/1778: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Ethiopia</hi> (<persName type="from">
                        <hi rend="italic">Engert</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Addis Ababa</hi>
                        </placeName>, <date calendar="gregorian" when="1935-10-12T17:00:00+02:35"
                            >October 12, 1935—5 p.m.</date>
                        <lb/> [Received October 13—6:12 a.m.]</dateline>
                </opener>
                <p>126. My 125, October 12, noon. Italian Minister has just been removed from his
                    Legation and is being held virtually a prisoner by the Ethiopian Government.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Engert</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
