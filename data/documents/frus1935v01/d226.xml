                subtype="historical-document" type="document" xml:id="d226">
                <note rend="inline" type="source">811.113/582</note>
                <head>
                    <hi rend="italic">Memorandum by President Roosevelt for the Secretary of
                        State</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1935-02-23">February 23,
                            1935</date>.</dateline>
                </opener>
                <p>After you get back will you speak with me about the advisability of a message on
                    war profits and kindred subjects. I enclose a memorandum, but I do not know who
                    it is from.<note n="1" xml:id="d226fn1">Undated memorandum by Bernard M. Baruch,
                        not printed.</note>
                </p>
                <closer>
                    <signed>F[<hi rend="smallcaps">ranklin</hi>] D. R[<hi rend="smallcaps"
                            >oosevelt</hi>]</signed>
                </closer>
            </div>
        </body>
    </text>
