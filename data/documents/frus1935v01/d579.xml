<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-12-13T04:25:00-05:00" frus:doc-dateTime-min="1935-12-13T04:25:00-05:00" n="579" subtype="historical-document" type="document" xml:id="d579">
                                <note rend="inline" type="source">765.84/3049: Telegram</note>
                                <head>
                                    <hi rend="italic">The Chargé in Ethiopia</hi> (<persName type="from"><hi rend="italic">Engert</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                            State</gloss>
                                    </hi>
                                </head>
                                <opener>
                                    <dateline rendition="#right">
                                        <placeName>
                                            <hi rend="smallcaps">Addis Ababa</hi></placeName>, <date calendar="gregorian" when="1935-12-13T12:00:00+02:35">December 13, 1935—noon</date>.<lb/>[Received 2:55
                                        p.m.]</dateline>
                                </opener>
                                <p>225. Anglo-French proposals were submitted this morning and will
                                    be forwarded to the Emperor at Dessie by plane. Precise terms
                                    not yet known here.</p>
                                <closer>
                                    <signed>
                                        <hi rend="smallcaps">Engert</hi>
                                    </signed>
                                </closer>
                            </div>
                            </body></text></TEI>