<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-10-04T10:00:00-05:00" frus:doc-dateTime-min="1935-10-04T10:00:00-05:00" n="669" subtype="historical-document" type="document" xml:id="d669">
                                <note rend="inline" type="source">765.84/1556: Telegram</note>
                                <head>
                                    <hi rend="italic">The Ambassador in the United Kingdom</hi>
                                        (<persName type="from"><hi rend="italic">Bingham</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                    </hi>
                                </head>
                                <opener>
                                    <dateline rendition="#right">
                                        <placeName>
                                            <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1935-10-04T16:00:00+01:00">October 4, 1935—4 p.m.</date>
                                        <lb/> [Received October 4—11:10 a.m.]</dateline>
                                </opener>
                                <p>493. My 492, October 4, noon. His Majesty’s Government do not
                                    consider a state of war exists. They have promised to keep in
                                    touch with me on this question.</p>
                                <closer>
                                    <signed>
                                        <hi rend="smallcaps">Bingham</hi>
                                    </signed>
                                </closer>
                            </div>
                            </body></text></TEI>