    <text>
        <body>
            <div frus:doc-dateTime-max="1867-09-20T23:59:59-05:00"
                frus:doc-dateTime-min="1867-09-20T00:00:00-05:00" n="146"
                subtype="historical-document" type="document" xml:id="d146">
                <opener>
                    <seg rendition="#center">[Telegram per cable.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Adams</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1867-09-20">
                            <hi rend="italic">September</hi> 20, 1867</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic"
                        >&amp;c., &amp;c., &amp;c.</hi>
                </p>
                <p>Obtain definite answer about Warren and Nagle.</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
            </div>
        </body>
    </text>
