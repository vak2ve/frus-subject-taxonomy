    <text>
        <body>
            <div frus:doc-dateTime-max="1867-03-14T23:59:59-05:00" frus:doc-dateTime-min="1867-03-14T00:00:00-05:00" n="337" subtype="historical-document" type="document" xml:id="d337">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr. de Stoeckl</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1867-03-14">
                            <hi rend="italic">March</hi> 14, 1867</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to communicate, to
                                you, for the information of your government, a copy of the
                                correspondence which has taken place between the government of the
                                United States and those of Spain, Peru, Chili, Bolivia, and Ecuador,
                                in regard to the pacification of questions at issue between Spain on
                                the one hand and the allied republics above named on the other.<note n="*" xml:id="d337fn1">For enclosures see correspondence with
                                    the countries mentioned.</note> Accept, sir, a renewed assurance
                                of my highest consideration.</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>Mr. <hi rend="smallcaps">Edward de Stoeckl</hi>, <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
