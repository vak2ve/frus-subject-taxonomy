<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1867-09-13T23:59:59-05:00" frus:doc-dateTime-min="1867-09-13T00:00:00-05:00" n="134" subtype="historical-document" type="document" xml:id="d134">
                        <note rend="inline" type="source">[Telegram per cable. ]</note>
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName></head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State,Washington,</hi>
                                </placeName>
                                <date calendar="gregorian" when="1867-09-13"><hi rend="italic">September</hi> 13, 1867</date>.</dateline>
                        </opener>
                        <p><hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        <p>Collector of customs at New York reports the Fenian episode of your 1428a
                            mere sensational fiction.</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>