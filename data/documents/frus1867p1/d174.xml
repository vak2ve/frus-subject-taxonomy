<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1867-11-15T23:59:59-05:00" frus:doc-dateTime-min="1867-11-15T00:00:00-05:00" n="174" subtype="historical-document" type="document" xml:id="d174">
                        <opener>
                            <seg rendition="#center">[Telegram per cable.]</seg>
                        </opener>
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName></head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Department of State,Washington,</hi>
                                </placeName>
                                <date calendar="gregorian" when="1867-11-15"><hi rend="italic">November</hi> 15, 1867,</date>
                            </dateline>
                        </opener>
                        <p><hi rend="smallcaps">Charles Francis Adams,</hi> Esq., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic">c.</hi></p>
                        <p>Delay judgment or execution Warren’s case.</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>