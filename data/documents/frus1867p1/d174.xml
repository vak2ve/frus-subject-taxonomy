                <opener>
                    <seg rendition="#center">[Telegram per cable.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Adams</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1867-11-15">
                            <hi rend="italic">November</hi> 15, 1867,</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Charles Francis Adams,</hi> Esq., &amp;<hi rend="italic"
                        >c</hi>., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic">c.</hi>
                </p>
                <p>Delay judgment or execution Warren’s case.</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
            </div>
        </body>
