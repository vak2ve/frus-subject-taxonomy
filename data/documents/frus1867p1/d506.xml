                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. F. W. Seward</persName> to <persName type="to">Count
                        Wydenbruck.</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1867-06-22">
                            <hi rend="italic">June</hi> 22, 1867</date>.</dateline>
                </opener>
                <p>To Count <hi rend="smallcaps">Wydenbruck</hi>, <hi rend="italic">Oakland,
                        Alleghany county, Maryland :</hi>
                </p>
                <p>Your telegram of yesterday received, and its request complied with.</p>
                <closer>
                    <signed>F. W. SEWARD.</signed>
                </closer>
            </div>
        </body>
    </text>
