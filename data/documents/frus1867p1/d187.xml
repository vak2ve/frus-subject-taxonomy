<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1867-12-02T23:59:59-05:00" frus:doc-dateTime-min="1867-12-02T00:00:00-05:00" n="187" subtype="historical-document" type="document" xml:id="d187">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Adams</persName></head>
                        <opener>
                            <seg rendition="#left">No. 2103.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1867-12-02"><hi rend="italic">December</hi> 2, 1867</date>.</dateline>
                        </opener>
                        <p><hi rend="smallcaps">Sir:</hi> You will be expected to give to Lord
                            Stanley a copy of my No. 2102. I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed>
                        </closer>
                        <postscript>
                            <p><hi rend="smallcaps">Charles Frangís Adams,</hi> Esq., &amp;<hi rend="italic">c.</hi>, &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic">c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>