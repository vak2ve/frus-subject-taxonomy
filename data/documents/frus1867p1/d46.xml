    <text>
        <body>
            <div frus:doc-dateTime-max="1867-03-20T23:59:59-05:00" frus:doc-dateTime-min="1867-03-20T00:00:00-05:00" n="46" subtype="historical-document" type="document" xml:id="d46">
                <head>
                    <persName type="from">Mr. Stanton</persName> to <persName type="to">Mr. Seward.</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">War Department</hi>, <hi rend="italic">Washington City</hi>,</placeName>
                        <date calendar="gregorian" when="1867-03-20">
                            <hi rend="italic">March</hi> 20, 1867</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to transmit, for the
                            consideration of the Department of State, a copy of a communication,
                            dated March 4, received from the commanding general of the military
                            department of Dakota, respecting the pursuit of hostile Indians in her
                            Britannic Majesty’s dominions.</p>
                <p>Very respectfully, your obedient servant,</p>
                <closer>
                    <signed>EDWIN M. STANTON, <hi rend="italic">Secretary of
                                War.</hi>
                    </signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">Secretary of State</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
