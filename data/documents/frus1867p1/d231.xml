<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1866-12-11T23:59:59-05:00" frus:doc-dateTime-min="1866-12-11T00:00:00-05:00" n="231" subtype="historical-document" type="document" xml:id="d231">
                        <head><persName type="from">Mr. Stanton</persName> to <persName type="to">Mr. Seward</persName></head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">War Department</hi>, <hi rend="italic">Washington City,</hi></placeName>
                                <date calendar="gregorian" when="1866-12-11"><hi rend="italic">December</hi> 11, 1866</date>.</dateline>
                        </opener>
                        <p><hi rend="smallcaps">Sir:</hi> I have the honor to submit the
                            accompanying telegraphic report from General Sheridan to General
                            [Grant,] relating to the present condition of affairs on the Rio
                            Grande.</p>
                        <p>Yours, truly,</p>
                        <closer>
                            <signed>EDWIN M. STANTON.</signed>
                        </closer>
                        <postscript>
                            <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">Secretary of State.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>