    <text>
        <body>
            <div frus:doc-dateTime-max="1867-06-01T23:59:59-05:00"
                frus:doc-dateTime-min="1867-06-01T00:00:00-05:00" n="255"
                subtype="historical-document" type="document" xml:id="d255">
                <opener>
                    <seg rendition="#center">[Telegram per cable.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Dix</persName> to <persName type="to">Mr.
                        Seward</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>, <hi
                                rend="italic">Paris,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1867-06-01">
                            <hi rend="italic">June</hi> 1, 1867</date>.</dateline>
                </opener>
                <p>By special request of the Emperor I use the telegraph to express his earnest wish
                    that the government of the United States will exert all its influence to have
                    Maximilian spared by his captors.</p>
                <closer>
                    <signed>JOHN A. DIX.</signed>
                </closer>
                <postscript>
                    <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">Secretary
                            of State, Washington, D. C.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
