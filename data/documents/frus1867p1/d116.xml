    <text>
        <body>
            <div frus:doc-dateTime-max="1867-08-13T23:59:59-05:00"
                frus:doc-dateTime-min="1867-08-13T00:00:00-05:00" n="116"
                subtype="historical-document" type="document" xml:id="d116">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Adams</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 2038.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1867-08-13">
                            <hi rend="italic">August</hi> 13, 1867</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have to give you for your information and
                    guidance a copy of’ an instruction<note n="*" xml:id="d116fn1">For enclosure see
                        instructions to United States minister to Nicaragua.</note> of this date,
                    which has been transmitted to Mr. Dickinson, minister of the United States of
                    Nicaragua, concerning a question which has arisen between that government and
                    the government of Great Britain.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Charles Francis Adams,</hi> Esq., <hi rend="italic"
                            >&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
