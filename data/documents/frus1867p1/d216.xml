<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1867-08-22T23:59:59-05:00" frus:doc-dateTime-min="1867-08-22T00:00:00-05:00" n="216" subtype="historical-document" type="document" xml:id="d216">
                            <opener>
                                <seg rendition="#center">[Telegram per cable.]</seg>
                            </opener>
                            <head><persName type="from">Sir F. Bruce</persName> to <persName type="to">Lord Stanley</persName></head>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington,</hi>
                                    </placeName>
                                    <date calendar="gregorian" when="1867-08-22"><hi rend="italic">August</hi> 22, 1867</date>.</dateline>
                            </opener>
                            <p>Right Hon. Lord <hi rend="smallcaps">Stanley,</hi> &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic">c</hi>., &amp;<hi rend="italic">c</hi>.<hi rend="italic">:</hi></p>
                            <p>I think it advisable to release Nagle and Warren.</p>
                            <closer>
                                <signed>BRUCE.</signed>
                            </closer>
                        </div>
                        </body></text></TEI>