    <text>
        <body>
            <div frus:doc-dateTime-max="1867-06-21T23:59:59-05:00" frus:doc-dateTime-min="1867-06-21T00:00:00-05:00" n="504" subtype="historical-document" type="document" xml:id="d504">
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Count Wydenhruck.</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1867-06-21">
                            <hi rend="italic">June</hi> 21, 1867</date>.</dateline>
                </opener>
                <p>The good offices requested by the Emperor of Austria have been
                                rendered.</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>Count <hi rend="smallcaps">Wydenbruck</hi>, <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                </postscript>
            </div>
        </body>
