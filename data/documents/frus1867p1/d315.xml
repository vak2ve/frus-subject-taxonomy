    <text>
        <body>
            <div frus:doc-dateTime-max="1866-12-20T23:59:59-05:00"
                frus:doc-dateTime-min="1866-12-20T00:00:00-05:00" n="315"
                subtype="historical-document" type="document" xml:id="d315">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Fox</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic"
                                >Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1866-12-20">
                            <hi rend="italic">December</hi> 20, 1866</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have received your communication of the 17th
                    instant, and its accompaniments-, which M. Pogodin, requested you to present to
                    some national institute or museum in this city. I have placed them among the
                    archives of the department, and I beg that you will accept my thanks for your
                    kindness in allowing me the privilege of disposing of these interesting
                    autographs.</p>
                <p>I am, sir, your obedient servant.</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>G. V. Fox, Esq, <hi rend="italic">Portsmouth, New Hampshire.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
