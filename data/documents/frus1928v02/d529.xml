                <note rend="inline" type="source">493.11/1381: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in China</hi> (<persName type="to">
                        <hi rend="italic">MacMurray</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-10-16T15:00:00-05:00">
                            <hi rend="italic">October 16, 1928—3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>351. Your 772, October 15, 7 p.m. Your proposal is approved.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Clark</hi>
                    </signed>
                </closer>
            </div>
        </body>
