                subtype="historical-document" type="document" xml:id="d56">
                <note rend="inline" type="source">711.4215 Air Pollution/84: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Canada</hi> (<persName type="to">
                        <hi rend="italic">Newson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-08-07T15:00:00-04:00">
                            <hi rend="italic">August 7, 1928—3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>108. Your 171, August 4, 1 p.m. By letter dated today<note n="65"
                        xml:id="d56fn65">Not printed.</note> Department submitting Trail Smelter
                    matter to International Joint Commission in accordance with agreement.</p>
                <p>Please express to Canadian Government this Government’s appreciation of its
                    cooperation in this matter.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
