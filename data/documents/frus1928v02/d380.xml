                subtype="historical-document" type="document" xml:id="d380">
                <note rend="inline" type="source">693.003/858: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in China</hi> (<persName type="to">
                        <hi rend="italic">MacMurray</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-12-11T14:00:00-05:00">
                            <hi rend="italic">December 11, 1928—2 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>404. Your 864, December 8, 5 p.m.</p>
                <list>
                    <item>Paragraph 2. Particulars of tariff schedules not necessary but information
                        concerning attitude of other governments and any steps contemplated or taken
                        by them are desired.</item>
                    <item>Paragraph 4. Noted and approved.</item>
                </list>
                <p>It is assumed that Commercial Attaché will give Department of Commerce complete
                    information.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
