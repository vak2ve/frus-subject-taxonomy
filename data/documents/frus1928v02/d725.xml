                subtype="historical-document" type="document" xml:id="d725">
                <note rend="inline" type="source">811.841/298: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Norway</hi> (<persName type="from">
                        <hi rend="italic">Swenson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Oslo</hi>
                        </placeName>, <date calendar="gregorian" when="1926-10-05T12:00:00+01:00">
                            <hi rend="italic">October 5, 1926—noon</hi>.</date>
                        <lb/>[Received 3:15 p.m.]</dateline>
                </opener>
                <p>23. Referring to the Department’s No. 11, October 4, 4 p.m. Tonnage duties in
                    Norwegian ports are uniform for all countries including Norway.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Swenson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
