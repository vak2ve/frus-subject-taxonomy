<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-09-22T12:00:00-05:00" frus:doc-dateTime-min="1928-09-22T12:00:00-05:00" n="551" subtype="historical-document" type="document" xml:id="d551">
                        <note rend="inline" type="source">493.11/1358: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in China</hi> (<persName type="to"><hi rend="italic">Perkins</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1928-09-22T13:00:00-04:00"><hi rend="italic">September 22,
                                        1928—1 p.m.</hi></date></dateline></opener>
                        <p>324. Your 700, September 11, 7 p.m. Your paragraphs 2 and 3 approved.
                            Legation should, however, inform the Minister for Foreign Affairs that
                            this is to be regarded as an emergency measure pending a formal
                            arrangement.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>