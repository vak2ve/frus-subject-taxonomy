    <text>
        <body>
            <div frus:doc-dateTime-max="1928-12-05T23:59:59-05:00"
                frus:doc-dateTime-min="1928-12-05T00:00:00-05:00" n="956"
                subtype="historical-document" type="document" xml:id="d956">
                <note rend="inline" type="source">800.014 Antarctic/2</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Personal Representative of Commander <persName>Richard E. Byrd</persName>
                    </hi> (<persName type="to">
                        <hi rend="italic">Railey</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-12-05">
                            <hi rend="italic">December 5, 1928</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: The Department has received your letter dated
                    October 10, 1928, in which you request to be informed concerning the attitude of
                    this Department with respect to the right to claim on behalf of the United
                    States any lands which may be discovered by the Flight Division of the Byrd
                    Antarctic Expedition.</p>
                <p>Your letter has been noted carefully and if the occasion should arise the
                    Department will be pleased to indicate to you its conclusions in the matter.</p>
                <p>I am [etc.]</p>
                <closer>For the Secretary of State:<lb/>
                    <signed>
                        <hi rend="smallcaps">J. Reuben Clark</hi>, Jr.</signed>
                    <lb/>
                    <hi rend="italic">Under Secretary</hi>
                </closer>
            </div>
        </body>
    </text>
