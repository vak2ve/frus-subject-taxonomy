                subtype="historical-document" type="document" xml:id="d588">
                <note rend="inline" type="source">821.6363/363: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Colombia</hi> (<persName type="to">
                        <hi rend="italic">Piles</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-02-21T18:00:00-05:00">
                            <hi rend="italic">February 21, 1928—6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>10. Your 12, February 20, 10 a.m. and 13, February 20, 5 p.m.<note n="1a"
                        xml:id="d588fn1a">Not printed.</note> Colombian Minister, who has been
                    attending Habana conference, is not expected in Washington before March 1st. In
                    these circumstances you should not delay your interview with the President.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
