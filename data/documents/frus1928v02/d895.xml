    <text>
        <body>
            <div frus:doc-dateTime-max="1928-12-29T23:59:59-05:00"
                frus:doc-dateTime-min="1928-12-29T00:00:00-05:00" n="895"
                subtype="historical-document" type="document" xml:id="d895">
                <note rend="inline" type="source">662.11173 Barley/76</note>
                <head>
                    <hi rend="italic">The Ambassador in Germany</hi> (<persName type="from">
                        <hi rend="italic">Schurman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1928-12-29">
                            <hi rend="italic">December 29, 1928</hi>
                        </date>.<lb/>[Received January 28, 1929.]</dateline>
                    <seg rendition="#left">No. 4205</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: With reference to the Embassy’s despatch No. 4102
                    of November 13, 1928,<note n="54" xml:id="d895fn54">Not printed.</note> I have
                    the honor to inform the Department that according to the <hi rend="italic"
                        >Reichsanzeiger</hi> of December 28, 1928, the ordinance of September 27,
                    1928, governing the importation of barley from the United States into Germany,
                    has been extended to February 28, 1929.</p>
                <p>A further report is being prepared on the future prospects of American barley in
                    the German market which will be forwarded to the Department shortly.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Jacob Gould Schurman</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
