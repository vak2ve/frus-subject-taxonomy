                <note rend="inline" type="source">393.11/828: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in China</hi> (<persName type="to">
                        <hi rend="italic">MacMurray</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-06-12T17:00:00-04:00">
                            <hi rend="italic">June 12, 1928—5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>186. Your telegram 457, June 12, 7 p.m. Department adopts your view.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Olds</hi>
                    </signed>
                </closer>
            </div>
        </body>
