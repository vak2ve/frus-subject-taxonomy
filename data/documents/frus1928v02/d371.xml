<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-03-08T18:00:00-05:00" frus:doc-dateTime-min="1928-03-08T18:00:00-05:00" n="371" subtype="historical-document" type="document" xml:id="d371">
                        <note rend="inline" type="source">693.003/808: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in China</hi> (<persName type="to"><hi rend="italic">Mayer</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1928-03-08T18:00:00-05:00"><hi rend="italic">March 8,
                                        1928—6 p.m.</hi></date></dateline></opener>
                        <p>87. Your 142, March 6, 5 p.m.</p>
                        <list>
                            <label>1.</label>
                            <item>Department is prepared to approve 5 per cent ad valorem basis for
                                disputed items. Commerce Department concurs.</item>
                            <label>2.</label>
                            <item>Department assumes duty paying value will be determined as
                                provided in Rule 1 attached to the Revised Import Tariff of
                                    1922.<note n="75" xml:id="d371fn75">See <hi rend="italic">The
                                        China Year Book</hi>, 1923, pp. 525, 544.</note> If
                                otherwise inform Department.</item>
                        </list>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>