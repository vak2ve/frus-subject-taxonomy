<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-03-12T18:00:00-05:00" frus:doc-dateTime-min="1928-03-12T18:00:00-05:00" n="816" subtype="historical-document" type="document" xml:id="d816">
                        <note rend="inline" type="source">851.6363 Import Law/14: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Ambassador in France</hi> (<persName type="to"><hi rend="italic">Herrick</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1928-03-12T18:00:00-05:00"><hi rend="italic">March 12,
                                        1928—6 p.m.</hi></date></dateline></opener>
                        <p>70. Your 60, March 9, 1 p.m. The Department approves your informal
                            representations and desires that you continue to follow developments
                            closely.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>