                subtype="historical-document" type="document" xml:id="d555">
                <note rend="inline" type="source">493.11/1378: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">MacMurray</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1928-10-12T19:00:00+08:00">
                            <hi rend="italic">October 12, 1928—7 p.m.</hi>
                        </date>
                        <lb/>[Received October 12—9:10 a.m.]</dateline>
                </opener>
                <p>769. Legation’s 744, October 3, 6 p.m., third paragraph. I have paid to Lo
                    Chia-lun installment for September.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">MacMurray</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
