<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-05-03T16:00:00-05:00" frus:doc-dateTime-min="1928-05-03T16:00:00-05:00" n="153" subtype="historical-document" type="document" xml:id="d153">
                        <note rend="inline" type="source">893.00 Tsinan/5: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in China</hi> (<persName type="to"><hi rend="italic">MacMurray</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1928-05-03T17:00:00-04:00"><hi rend="italic">May 3, 1928—5
                                        p.m.</hi></date></dateline></opener>
                        <p>144. Your 303, May 3, 6 p.m.<note n="39" xml:id="d153fn39">Not
                                printed.</note> Can you ascertain and inform Department by telegram
                            present situation with regard to American Consul and other Americans at
                            Tsinan?</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>