                <note rend="inline" type="source">711.93/191</note>
                <head>
                    <hi rend="italic">President <persName type="from">Coolidge</persName> to the
                            <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Superior, Wis.</hi>
                        </placeName>, <date calendar="gregorian" when="1928-07-12">
                            <hi rend="italic">July 12, 1928</hi>
                        </date>.<lb/>[Received July 16.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Secretary</hi>: I approve the program which you
                    set out in your letter of July 11th regarding the matter of the treaty
                    negotiations with China.</p>
                <p>Very truly yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Calvin Coolidge</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
