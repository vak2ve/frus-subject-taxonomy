                subtype="historical-document" type="document" xml:id="d858">
                <note rend="inline" type="source">462.00 R 296/2262: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName type="to">
                        <hi rend="italic">Herrick</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-06-07T10:00:00-04:00">
                            <hi rend="italic">June 7, 1928—10 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>160. Reparation 53. Your Reparation 97, June 4, 4 p.m.<note n="34"
                        xml:id="d858fn34">Not printed.</note> Wilson is authorized to sign protocol
                    substantially conforming to draft transmitted with letter of May 9.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Kellogg</hi>
                    </signed>
                </closer>
            </div>
        </body>
