<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-09-04T23:59:59-05:00" frus:doc-dateTime-min="1928-09-04T00:00:00-05:00" n="76" subtype="historical-document" type="document" xml:id="d76">
                        <note rend="inline" type="source">611.424 Milk/39: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                    State</gloss> to the Consul General at Montreal</hi> (<persName type="to"><hi rend="italic">Halstead</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1928-09-04"><hi rend="italic">September 4,
                                    1928</hi></date>.</dateline></opener>
                        <p>Embargo on milk and its products from Montreal and vicinity lifted by
                            Department of Agriculture September 4.</p>
                        <closer><signed><hi rend="smallcaps">Clark</hi></signed></closer>
                    </div>
                </body></text></TEI>