                <note rend="inline" type="source">611.424 Milk/39: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Consul General at Montreal</hi> (<persName type="to">
                        <hi rend="italic">Halstead</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1928-09-04">
                            <hi rend="italic">September 4, 1928</hi>
                        </date>.</dateline>
                </opener>
                <p>Embargo on milk and its products from Montreal and vicinity lifted by Department
                    of Agriculture September 4.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Clark</hi>
                    </signed>
                </closer>
            </div>
        </body>
