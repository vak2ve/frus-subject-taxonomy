                subtype="historical-document" type="document" xml:id="d807">
                <note rend="inline" type="source">611.5131/749: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in France</hi> (<persName type="from">
                        <hi rend="italic">Armour</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1928-10-31T19:00:00+00:00">
                            <hi rend="italic">October 31, 1928—7 p.m.</hi>
                        </date>
                        <lb/>[Received 8:40 p.m.]</dateline>
                </opener>
                <p>336. Department’s 367, October 30, 7 p.m. I have informed Foreign Office of
                    Department’s publication and made oral representations as outlined in last
                    paragraph of instruction. Despatch follows.<note n="29" xml:id="d807fn29">Not
                        printed.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Armour</hi>
                    </signed>
                </closer>
            </div>
        </body>
