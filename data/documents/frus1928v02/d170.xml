<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1928-05-29T13:00:00-05:00" frus:doc-dateTime-min="1928-05-29T13:00:00-05:00" n="170" subtype="historical-document" type="document" xml:id="d170">
                        <note rend="inline" type="source">893.00/10004: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in China</hi> (<persName type="to"><hi rend="italic">MacMurray</hi></persName>)</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1928-05-29T14:00:00-04:00"><hi rend="italic">May 29,
                                        1928—2 p.m.</hi></date></dateline></opener>
                        <p>174. Your 399, May 26, 9 p.m. Department approves your action and is
                            gratified over the results.</p>
                        <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>