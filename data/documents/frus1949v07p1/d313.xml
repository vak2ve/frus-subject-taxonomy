<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-06-24T16:00:00-05:00" frus:doc-dateTime-min="1949-06-24T16:00:00-05:00" n="313" subtype="historical-document" type="document" xml:id="d313">
                            <note rend="inline" type="source">501.BC Indonesia/6–2449:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the <gloss type="to">Consulate General at Batavia</gloss>
                                </hi><note n="1" xml:id="d313fn1">Repeated as 552 to The
                                    Hague.</note>
                            </head>
                            <opener>
                                <seg rendition="#left">
                                    <hi rend="smallcaps">confidential   priority</hi>
                                </seg>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1949-06-24T17:00:00-04:00">June
                                        24, 1949—5 p. m.</date>
                                </dateline>
                            </opener>
                            <p>346. <gloss target="#t_Usgoc1">Usgoc</gloss> 390. <gloss target="#t_Gocus1">Gocus</gloss> 739.<note n="2" xml:id="d313fn2">Telegram 563, June 24, not printed.</note>
                                <gloss target="#t_ECA1">ECA</gloss> prepared discuss all aspects aid
                                program for all <gloss target="#t_Indo1">Indo</gloss> once
                                satisfactory political settlement reached. However, on strength
                                views <gloss target="#t_Gocus1">Gocus</gloss> 725,<note n="3" xml:id="d313fn3">Telegram 532, June 13, <ref target="#pg_427">p.
                                        427</ref>.</note> no resumption under present conditions now
                                being contemplated.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Acheson</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>