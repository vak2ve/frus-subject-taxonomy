<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-05-03T16:00:00-05:00" frus:doc-dateTime-min="1949-05-03T16:00:00-05:00" n="275" subtype="historical-document" type="document" xml:id="d275">
                            <note rend="inline" type="source">501.BC Indonesia/5–349:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the <gloss type="to">Consulate General at Batavia</gloss>
                                </hi><note n="1" xml:id="d275fn1">Repeated as 382 to The
                                    Hague.</note>
                            </head>
                            <opener>
                                <seg rendition="#left">
                                    <hi rend="smallcaps">restricted   us urgent</hi>
                                </seg>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1949-05-03T17:00:00-04:00">May 3,
                                        1949—5 p. m.</date>
                                </dateline>
                            </opener>
                            <p>253. <gloss target="#t_Usgoc1">Usgoc</gloss> 359. Despite US
                                opposition <gloss target="#t_Indo1">Indo</gloss> item transferred to
                                    <gloss target="#t_UNGA1">UNGA</gloss> Ad Hoc Comite May 2. This
                                means full debate <gloss target="#t_Indo1">Indo</gloss> question may
                                begin any time.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Acheson</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>