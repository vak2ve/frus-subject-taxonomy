<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-11-04T13:00:00-05:00" frus:doc-dateTime-min="1949-11-04T13:00:00-05:00" n="389" subtype="historical-document" type="document" xml:id="d389">
                            <note rend="inline" type="source">501.BC Indonesia/11–449:
                                Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the <gloss type="to">Embassy in the Netherlands</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#left">
                                    <hi rend="smallcaps">secret</hi>
                                </seg>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1949-11-04T13:00:00-05:00">November 4, 1949—1 p. m.</date>
                                </dateline>
                            </opener>
                            <p>982. <gloss target="#t_Ushic1">Ushic</gloss> 46. Ur 634 July 27.<note n="1" xml:id="d389fn1">Not printed.</note> Wld it not be
                                desirable for you solicit Hatta’s views on desirability <gloss target="#t_IMF1">IMF</gloss> mission to <gloss target="#t_Indo1">Indo</gloss>. It occurs to <pb facs="0578" n="564" xml:id="pg_564"/>
                                <gloss target="#t_Dept1">Dept</gloss> presence such mission in
                                    <gloss target="#t_Indo1">Indo</gloss> might be extremely helpful
                                in connection monetary and currency reforms which <gloss target="#t_Indo1">Indo</gloss> Govt must undertake in near
                                future.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Acheson</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>