<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1867-01-02T23:59:59-05:00" frus:doc-dateTime-min="1867-01-02T00:00:00-05:00" n="227" subtype="historical-document" type="document" xml:id="d227">
                        <opener>
                            <seg rendition="#center">[Telegram.]</seg>
                        </opener>
                        <head><persName type="from">Mr. Campbell</persName> to <persName type="to">Mr. Seward</persName></head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">New Orleans</hi>,</placeName>
                                <date calendar="gregorian" when="1867-01-02"><hi rend="italic">January</hi> 2, 1867</date>.</dateline>
                        </opener>
                        <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">Secretary of State, Washington, D. C.</hi></p>
                        <p>Your communication of December 27th received. I now propose to visit my
                            sick family and there await further orders. Is this satisfactory? Please
                            answer immediately.</p>
                        <closer>
                            <signed>LEWIS D. CAMPBELL.</signed>
                        </closer>
                    </div>
                    </body></text></TEI>