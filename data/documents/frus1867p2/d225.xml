<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1866-12-29T23:59:59-05:00" frus:doc-dateTime-min="1866-12-29T00:00:00-05:00" n="225" subtype="historical-document" type="document" xml:id="d225">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Campbell</persName></head>
                        <opener>
                            <seg rendition="#left">No. 12.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1866-12-29"><hi rend="italic">December</hi> 29, 1866</date>.</dateline>
                        </opener>
                        <p><hi rend="smallcaps">Sir:</hi> Your despatch No, 7, of the 24th instant,
                            has been received. The proceedings to which it refers are approved. We
                            adhere to the directions given you in the telegram of the 25th
                            instant.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILIAM H. SEWARD.</signed>
                        </closer>
                        <postscript>
                            <p><hi rend="smallcaps">Lewis D. Campbell</hi>, Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>