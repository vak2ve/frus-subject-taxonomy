    <text>
        <body>
            <div frus:doc-dateTime-max="1867-04-02T23:59:59-05:00" frus:doc-dateTime-min="1867-04-02T00:00:00-05:00" n="264" subtype="historical-document" type="document" xml:id="d264">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Campbell</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 25.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1867-04-02">
                            <hi rend="italic">April</hi> 2, 1867</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir:</hi> I have to inform you that the department
                            has commenced negotiations with the minister of Mexico in this country
                            for a treaty, whereby citizens of the United States residing in Mexico
                            are to be exempted from all forced loans or military exactions or
                            requisitions.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Lewis D. Campbell,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
