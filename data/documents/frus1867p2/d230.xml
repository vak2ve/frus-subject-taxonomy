    <text>
        <body>
            <div frus:doc-dateTime-max="1867-01-07T23:59:59-05:00" frus:doc-dateTime-min="1867-01-07T00:00:00-05:00" n="230" subtype="historical-document" type="document" xml:id="d230">
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Campbell</persName> to <persName type="to">Mr. Seward</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">New Orleans</hi>,</placeName>
                        <date calendar="gregorian" when="1867-01-07">
                            <hi rend="italic">January</hi> 7, 1867</date>.</dateline>
                </opener>
                <p>Hon. <hi rend="smallcaps">William H. Seward</hi>, <hi rend="italic">Secretary of State, Washington, D. C.</hi>
                </p>
                <p>If proper, please inform me about how long you will require me to remain
                            here.</p>
                <closer>
                    <signed>LEWIS D. CAMPBELL.</signed>
                </closer>
            </div>
        </body>
    </text>
