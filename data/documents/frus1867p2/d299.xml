<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1867-06-15T23:59:59-05:00" frus:doc-dateTime-min="1867-06-15T00:00:00-05:00" n="299" subtype="historical-document" type="document" xml:id="d299">
                        <note rend="inline" type="source">[Telegram.—Extract. ]</note>
                        <head><persName type="from">Mr. Campbell</persName> to <persName type="to">Mr. Seward</persName></head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">New Orleans,</hi>
                                </placeName>
                                <date calendar="gregorian" when="1867-06-15"><hi rend="italic">June</hi> 15, 1867</date>.</dateline>
                        </opener>
                        <p>Your telegram of this day received. I send formal resignation by mail and
                            start for Ohio Tuesday. * * *</p>
                        <closer>
                            <signed>LEWIS D. CAMPBELL.</signed>
                        </closer>
                        <postscript>
                            <p>Hon. <hi rend="smallcaps">William H. Seward,</hi>
                                <hi rend="italic">Secretary of State, Washington, D. C.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>