    <text>
        <body>
            <div frus:doc-dateTime-max="1867-06-11T23:59:59-05:00" frus:doc-dateTime-min="1867-06-11T00:00:00-05:00" n="295" subtype="historical-document" type="document" xml:id="d295">
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Campbell</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 36.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1867-06-11">
                            <hi rend="italic">June</hi> 11, 1867</date>.</dateline>
                </opener>
                <p>Your despatch received. The President desires you to proceed to Mexico
                            without delay according to previous instructions.</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Lewis D. Campbell,</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c., New Orleans.</hi>
                    </p>
                </postscript>
            </div>
        </body>
