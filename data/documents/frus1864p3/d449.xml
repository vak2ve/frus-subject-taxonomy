    <text>
        <body>
            <div frus:doc-dateTime-max="1864-10-17T23:59:59-05:00" frus:doc-dateTime-min="1864-10-17T00:00:00-05:00" n="449" subtype="historical-document" type="document" xml:id="d449">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Burlingame</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 89.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                        <date calendar="gregorian" when="1864-10-17">
                            <hi rend="italic">October</hi> 17, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge your despatch of the
                            25th of June, No. 87, relative to the organization of a tribunal to sit
                            in confiscation cases. I shall give the subject my attention.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Anson Burlingame</hi>, Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
