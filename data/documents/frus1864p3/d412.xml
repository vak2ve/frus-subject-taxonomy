    <text>
        <body>
            <div frus:doc-dateTime-max="1864-04-25T23:59:59-05:00"
                frus:doc-dateTime-min="1864-04-25T00:00:00-05:00" n="412"
                subtype="historical-document" type="document" xml:id="d412">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Burlingame</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 58.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1864-04-25">
                            <hi rend="italic">April</hi> 25, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to acknowledge, with much gratification,
                    your interesting despatch of the 4th of January, No. 61, which gives the
                    important results of Mr. Pumpelly’s examination of the coal districts of
                    Si-Sham.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Anson Burlingame,</hi> Esq., <hi rend="italic">&amp;c.,
                            &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
