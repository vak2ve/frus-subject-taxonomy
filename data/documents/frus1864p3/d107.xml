<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1864-05-04T23:59:59-05:00" frus:doc-dateTime-min="1864-05-04T00:00:00-05:00" n="107" subtype="historical-document" type="document" xml:id="d107">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Dayton</persName></head>
                        <opener>
                            <seg rendition="#left">No. 540.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1864-05-04"><hi rend="italic">May</hi> 4, 1864.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: Your despatch of the 18th ultimo, No. 452,
                            enclosing a printed translation of a convention between France and the
                            Archduke Maximilian in regard to Mexico, has been received.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">William L. Dayton</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>