    <text>
        <body>
            <div frus:doc-dateTime-max="1864-10-24T23:59:59-05:00"
                frus:doc-dateTime-min="1864-10-24T00:00:00-05:00" n="299"
                subtype="historical-document" type="document" xml:id="d299">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Geofroy</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1864-10-24">
                            <hi rend="italic">October</hi> 24, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 17th instant, which relates to the proceedings of the military
                    authorities of the United States in the department of the Gulf, in regard to the
                    forces of Cortinas, and in reply to inform you that your comments and
                    suggestions on the subject will receive due attention.</p>
                <p>Accept, sir, a renewed assurance of my highest consideration.</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>Mr. <hi rend="smallcaps">L. de Geofroy,</hi>
                        <hi rend="italic">&amp;c., &amp;c., &amp;c</hi>.</p>
                </postscript>
            </div>
        </body>
    </text>
