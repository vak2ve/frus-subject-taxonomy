<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1864-10-17T23:59:59-05:00" frus:doc-dateTime-min="1864-10-17T00:00:00-05:00" n="527" subtype="historical-document" type="document" xml:id="d527">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Pruyn</persName></head>
                        <opener>
                            <seg rendition="#left">No. 82.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                                <date calendar="gregorian" when="1864-10-17"><hi rend="italic">October</hi> 17, 1864.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: Your telegraphic despatch from San
                            Francisco, of the 14th instant, informing this department of the
                            disgrace attached to the ambassadors who made the French convention, has
                            been received.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Robert H. Pruyn</hi>, Esq., <hi rend="italic">&amp;c., &amp;c., Kanagawa.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>