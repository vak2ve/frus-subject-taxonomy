    <text>
        <body>
            <div frus:doc-dateTime-max="1864-03-22T23:59:59-05:00" frus:doc-dateTime-min="1864-03-22T00:00:00-05:00" n="78" subtype="historical-document" type="document" xml:id="d78">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Dayton</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 508.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1864-03-22">
                            <hi rend="italic">March</hi> 22, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Your despatch of the 4th instant, No. 428,
                            has been received. Your proceedings respecting the case of Mr.
                            Mansfield, therein reported, are approved.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">William L. Dayton</hi> Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
