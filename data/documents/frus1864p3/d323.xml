<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1864-06-17T23:59:59-05:00" frus:doc-dateTime-min="1864-06-17T00:00:00-05:00" n="323" subtype="historical-document" type="document" xml:id="d323">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Clay</persName></head>
                        <opener>
                            <seg rendition="#left">No 72.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State,</hi>
                                    <hi rend="italic">Washington,</hi></placeName>
                                <date calendar="gregorian" when="1864-06-17"><hi rend="italic">June</hi> 17, 1864.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I transmit, for your information, three
                            printed copies of a correspondence between the honorable Z. Chandler,
                            chairman of the Committee on Commerce of the Senate, and this
                            department, relative to the intercontinental telegraph connecting the
                            eastern and western hemispheres, by way of Behring’s straits, proposed
                            by Perry McDonough Collins, esq.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Cassius M. Clay</hi>, Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>