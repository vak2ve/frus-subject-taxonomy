<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1864-09-20T23:59:59-05:00" frus:doc-dateTime-min="1864-09-20T00:00:00-05:00" n="441" subtype="historical-document" type="document" xml:id="d441">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Burlingame</persName></head>
                        <opener>
                            <seg rendition="#left">No. 76.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                                <date calendar="gregorian" when="1864-09-20"><hi rend="italic">September</hi> 20, 1864.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: Your despatch of the 3d of June last, No.
                            79, relating to the question of jurisdiction at Shanghai, has been
                            received, and is approved.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Anson Burlingame</hi>, Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                    </body></text></TEI>