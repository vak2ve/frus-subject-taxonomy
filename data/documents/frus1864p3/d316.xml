    <text>
        <body>
            <div frus:doc-dateTime-max="1864-01-06T23:59:59-05:00" frus:doc-dateTime-min="1864-01-06T00:00:00-05:00" n="316" subtype="historical-document" type="document" xml:id="d316">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Clay</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 56.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1864-01-06">
                            <hi rend="italic">January</hi> 6, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Your despatch of November 4, No. 33, has
                            been received, and it has been read with deep interest, as all of the
                            papers are in which you enlighten this government concerning the
                            political, social, and material conditions of Russia.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">Cassius M. Clay</hi>, Esq.,<hi rend="italic">
                                    &amp;c., &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
