<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1864-11-18T23:59:59-05:00" frus:doc-dateTime-min="1864-11-18T00:00:00-05:00" n="450" subtype="historical-document" type="document" xml:id="d450">
                        <head><persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                                Burlingame</persName></head>
                        <opener>
                            <seg rendition="#left">No. 94.]</seg>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">Department of State</hi>, <hi rend="italic">Washington</hi>,</placeName>
                                <date calendar="gregorian" when="1864-11-18"><hi rend="italic">November</hi> 18, 1864.</date></dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: Your despatch and its accompaniments of
                            the 15th of August last, No. 90, relative to the fall of Nanking, and
                            your correspondence with the imperial government regarding the matter,
                            have been received with great satisfaction.</p>
                        <p>I am, sir, your obedient servant,</p>
                        <closer>
                            <signed>WILLIAM H. SEWARD.</signed></closer>
                        <postscript>
                            <p><hi rend="smallcaps">Anson Burlingame</hi>, Esq., <hi rend="italic">&amp;c., &amp;c., &amp;c.</hi></p>
                        </postscript>
                    </div>
                </body></text></TEI>