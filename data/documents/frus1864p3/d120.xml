    <text>
        <body>
            <div frus:doc-dateTime-max="1864-05-21T23:59:59-05:00"
                frus:doc-dateTime-min="1864-05-21T00:00:00-05:00" n="120"
                subtype="historical-document" type="document" xml:id="d120">
                <head>
                    <persName type="from">Mr. Seward</persName> to <persName type="to">Mr.
                        Dayton</persName>
                </head>
                <opener>
                    <seg rendition="#left">No. 561.]</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State,</hi>
                            <hi rend="italic">Washington,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1864-05-21">
                            <hi rend="italic">May</hi> 21, 1864.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your despatch of May 2, No. 461, and to approve of your proceedings therein
                    mentioned. We learn that Mr. Corwin, our minister plenipotentiary to Mexico, is
                    at Havana, on his return to the United States, under leave of absence.</p>
                <p>I am, sir, your obedient servant,</p>
                <closer>
                    <signed>WILLIAM H. SEWARD.</signed>
                </closer>
                <postscript>
                    <p>
                        <hi rend="smallcaps">William L. Dayton</hi> Esq., <hi rend="italic">&amp;c.,
                            &amp;c., &amp;c.</hi>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
