    <text>
        <body>
            <div frus:doc-dateTime-max="1894-11-01T23:59:59-05:00" frus:doc-dateTime-min="1894-11-01T00:00:00-05:00" n="543" subtype="historical-document" type="document" xml:id="d543">
                <head>
                    <hi rend="italic">Prince <persName type="from">Cantacuzene</persName>
                                to Mr. <persName type="to">Gresham</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Russian
                                        Imperial Legation</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-11-01">
                            <hi rend="italic">November 1,
                                1894</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Secretary</hi>: I just received the
                            following dispatch from Mr. de Giers: <quote rend="blockquote">
                        <p>It has pleased our Lord to recall to Him our much beloved
                                    sovereign. Emperor Alexander the Third died at Livadia this
                                    afternoon, the 20th October (1st November) at 2:15.</p>
                        <p rend="right">
                            <hi rend="smallcaps">Giers.</hi>
                        </p>
                    </quote>
                </p>
                <p>In deep grief, very sincerely, yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cantacuzène.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
