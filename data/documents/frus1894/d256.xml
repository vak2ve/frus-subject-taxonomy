    <text>
        <body>
            <div frus:doc-dateTime-max="1894-06-19T23:59:59-05:00"
                frus:doc-dateTime-min="1894-06-19T00:00:00-05:00" n="256"
                subtype="historical-document" type="document" xml:id="d256">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Sir <persName
                            type="to">Julian Pauncefote</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-06-19">
                            <hi rend="italic">June 19, 1894</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: Referring to your note of the 14th ultimo,
                    and to my reply of the 25th ultimo, I have the honor to inclose herewith two
                    copies of “An act to adopt regulations for preventing collisions at sea,”
                    approved by the President May 28, 1894.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edwin F. Uhl.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
