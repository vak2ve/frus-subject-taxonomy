                <head>
                    <hi rend="italic">Mr. <persName type="from">Denby</persName> to Mr.
                                    <persName type="to">Jernigan.</persName>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <date calendar="gregorian" when="1894-08-25">
                            <hi rend="smallcaps">August</hi> 25,
                                    1894</date>.</dateline>
                </opener>
                <p>Dispatch concerning spies not received. Telegraph anything you have to
                            add to previous telegrams.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Denby.</hi>
                    </signed>
                </closer>
            </div>
