    <text>
        <body>
            <div frus:doc-dateTime-max="1894-02-21T23:59:59-05:00" frus:doc-dateTime-min="1894-02-21T00:00:00-05:00" n="401" subtype="historical-document" type="document" xml:id="d401">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Mr.
                                    <persName type="to">Romero</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-02-21">
                            <hi rend="italic">February 21,
                                    1894</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your note of the 9th instant, apprising me that the Mexican
                            Boundary Commission <pb facs="0463" n="413" xml:id="pg_413"/> has been
                            authorized to proceed with the demarcation of the boundary line between
                            the United States and Mexico on the bridges between El Paso and El Paso
                            del Norte in strict conformity with the conventions of November 12,
                            1884, and March 1, 1889.</p>
                <p>I have so advised the commissioner on the part of this Government.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. Q. Gresham.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
