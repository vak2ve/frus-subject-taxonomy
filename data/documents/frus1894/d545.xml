    <text>
        <body>
            <div frus:doc-dateTime-max="1894-11-02T23:59:59-05:00" frus:doc-dateTime-min="1894-11-02T00:00:00-05:00" n="545" subtype="historical-document" type="document" xml:id="d545">
                <head>
                    <hi rend="italic">The <gloss type="from">President</gloss> to the
                                    <gloss type="to">Emperor of Russia</gloss>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-11-02">
                            <hi rend="italic">November 2,
                                1894</hi>
                        </date>.</dateline>
                </opener>
                <p rend="flushleft">His Majesty <hi rend="smallcaps">Nicolas
                                II,</hi>
                    <lb/>
                    <hi rend="italic">Emperor of Russia, Livadia:</hi>
                </p>
                <p>I hasten to express my heartfelt sympathy and the sympathy of my
                            countrymen with the Imperial family and the Russian people in their
                            affliction by reason of the death of your honored father.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Grover
                            Cleveland.</hi>
                    </signed>
                </closer>
            </div>
        </body>
