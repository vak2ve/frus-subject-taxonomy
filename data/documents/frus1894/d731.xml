<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1894-12-24T23:59:59-05:00" frus:doc-dateTime-min="1894-12-24T00:00:00-05:00" n="731" subtype="historical-document" type="document" xml:id="d731">
                        <head><hi rend="italic">Mr. <persName type="from">Gresham</persName> to Mr.
                                    <persName type="to">Terrell</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1894-12-24"><hi rend="italic">December 24,
                                    1894</hi></date>.</dateline></opener>
                        <p>Sultan having refused permission Jewett to go you will not press
                            further.</p>
                        <closer><signed><hi rend="smallcaps">Gresham.</hi></signed></closer>
                    </div>
                    </body></text></TEI>