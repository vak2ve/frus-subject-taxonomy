<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1894-07-12T23:59:59-05:00" frus:doc-dateTime-min="1894-07-12T00:00:00-05:00" n="591" subtype="historical-document" type="document" xml:id="d591">
                        <head><hi rend="italic">Mr. <persName type="from">Gresham</persName> to Mr.
                                    <persName type="to">Taylor</persName>.</hi></head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1894-07-12"><hi rend="italic">July 12,
                                1894</hi></date>.</dateline></opener>
                        <p>Referring to your No. 193, 23d ultimo; have you received Caroline
                            indemnity?</p>
                        <closer><signed><hi rend="smallcaps">Gresham.</hi></signed></closer>
                    </div>
                    </body></text></TEI>