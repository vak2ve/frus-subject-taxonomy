    <text>
        <body>
            <div frus:doc-dateTime-max="1894-05-26T23:59:59-05:00"
                frus:doc-dateTime-min="1894-05-26T00:00:00-05:00" n="289"
                subtype="historical-document" type="document" xml:id="d289">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Mr. <persName
                            type="to">Alexander</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-05-26">
                            <hi rend="italic">May 26, 1894</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 23.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to the Department’s instruction to you,
                    No. 21, of the 16th instant, I transmit to you herewith a full power authorizing
                    you to negotiate, conclude, and sign a convention between the United States and
                    Greece for the reciprocal protection of trade-marks and trade labels.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edwin F. Uhl</hi>,<lb/>
                        <hi rend="italic">Acting Secretary</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
