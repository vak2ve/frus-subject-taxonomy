                <head>
                    <hi rend="italic">Mr. <persName type="from">Taylor</persName> to Mr. <persName
                            type="to">Gresham</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1894-07-13">
                            <hi rend="italic">July 13, 1894</hi>
                        </date>.</dateline>
                </opener>
                <p>Indemnity paid and draft mailed to-day.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Taylor.</hi>
                    </signed>
                </closer>
            </div>
