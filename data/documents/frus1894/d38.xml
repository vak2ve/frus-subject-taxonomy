    <text>
        <body>
            <div frus:doc-dateTime-max="1894-08-27T23:59:59-05:00" frus:doc-dateTime-min="1894-08-27T00:00:00-05:00" n="38" subtype="historical-document" type="document" xml:id="d38">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Mr.
                                    <persName type="to">Moonlight</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-08-27">
                            <hi rend="italic">August 27,
                                1894</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 26.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have received your No. 36, of the 19th
                            ultimo, concerning the case of Romulo Fortún, of the Bolivian army, and
                            desire to approve your explanatory note to the minister of foreign
                            affairs touching the same.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. Q. Gresham.</hi>
                    </signed>
                </closer>
            </div>
        </body>
