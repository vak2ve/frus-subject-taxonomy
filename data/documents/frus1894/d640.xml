                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Mr.
                                    <persName type="to">Taylor</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
