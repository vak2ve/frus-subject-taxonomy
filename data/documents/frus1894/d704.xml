                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Constantinople</hi></placeName>, <date calendar="gregorian" when="1894-09-21"><hi rend="italic">September 21,
                                    1894</hi></date>.</dateline></opener>
