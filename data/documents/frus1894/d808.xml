    <text>
        <body>
            <div frus:doc-dateTime-max="1894-05-30T23:59:59-05:00" frus:doc-dateTime-min="1894-05-30T00:00:00-05:00" n="808" subtype="historical-document" type="document" xml:id="d808">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Bartleman</persName> to
                                Mr. <persName type="to">Gresham</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Caracas</hi>
                        </placeName>, <date calendar="gregorian" when="1894-05-30">
                            <hi rend="italic">May 30, 1894</hi>
                        </date>.
                                (Received June 7.)</dateline>
                    <seg rendition="#left">No. 154.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to append on the overleaf
                            a copy of a telegram received on the 24th instant, in which it is stated
                            that the American steamer <hi rend="italic">Bolivar</hi> has been
                            cleared by the collector of customs and all authorities.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">R. M. Bartleman.</hi>
                    </signed>
                </closer>
                <frus:attachment>
                    <opener>
                        <seg rendition="#center">[Copy of telegram in No.
                                154.]</seg>
                    </opener>
                    <head>
                        <hi rend="italic">Mr. <persName type="from">Carpenter</persName>
                                    to Mr. <persName type="to">Bartleman</persName>.</hi>
                    </head>
                    <opener>
                        <dateline rendition="#right">
                            <placeName>
                                <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                                <hi rend="italic">Ciudad Bolivar</hi>
                            </placeName>, <date calendar="gregorian" when="1894-05-22">
                                <hi rend="italic">May
                                            22, 1894</hi>
                            </date>.</dateline>
                    </opener>
                    <p>
                        <hi rend="italic">Bolivar</hi> cleared by collector arid all
                                authorities.</p>
                    <closer>
                        <signed>
                            <hi rend="smallcaps">A. L.
                                Carpenter.</hi>
                        </signed>
                    </closer>
                </frus:attachment>
            </div>
        </body>
    </text>
