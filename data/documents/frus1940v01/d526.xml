                subtype="historical-document" type="document" xml:id="d526">
                <note rend="inline" type="source">740.0011 European War 1939/5269: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Rumania</hi> (<persName type="from">
                        <hi rend="italic">Gunther</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bucharest</hi>
                        </placeName>, <date calendar="gregorian" when="1940-08-26T16:00:00+02:00"
                            >August 26, 1940—4 p.m.</date>
                        <lb/> [Received 10:30 p.m.]</dateline>
                </opener>
                <p>474. My 464, August 21, 8 p.m.<note n="90" xml:id="d526fn90">Not printed.</note>
                    There have been no further flights of Russian planes over Moldavia. Discussing
                    this matter with the Prime Minister yesterday he seemed to feel that relations
                    with Russia might be quiescent for the present.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gunther</hi>
                    </signed>
                </closer>
            </div>
        </body>
