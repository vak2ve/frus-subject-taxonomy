    <text>
        <body>
            <div frus:doc-dateTime-max="1940-04-19T11:40:00-05:00"
                frus:doc-dateTime-min="1940-04-19T11:40:00-05:00" n="126"
                subtype="historical-document" type="document" xml:id="d126">
                <note rend="inline" type="source">740.0011 European War 1939/2343: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in the Netherlands</hi> (<persName type="from">
                        <hi rend="italic">Gordon</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">The Hague</hi>
                        </placeName>, <date calendar="gregorian" when="1940-04-19T17:00:00+00:20"
                            >April 19, 1940—5 p.m.</date>
                        <lb/> [Received April 19—4:12 p.m.]</dateline>
                </opener>
                <p>129. My 117, April 15, 3 p.m.<note n="49" xml:id="d126fn49">Not printed.</note>
                    In radio address this afternoon Prime Minister<note n="49a" xml:id="d126fn49a"
                        >D. J. de Geer.</note> announced that the entire country has now been placed
                    under martial law.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gordon</hi>
                    </signed>
                </closer>
            </div>
        </body>
