<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-07-12T17:00:00-05:00" frus:doc-dateTime-min="1940-07-12T17:00:00-05:00" n="887" subtype="historical-document" type="document" xml:id="d887">
                        <note rend="inline" type="source">710.Consultation (2)/263: Telegram</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Minister in Costa Rica</hi> (<persName type="to"><hi rend="italic">Hornibrook</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1940-07-12T18:00:00-04:00">July 12,
                                    1940—6 p.m.</date>
                            </dateline>
                        </opener>
                        <p>64. Your 86, July 11, 11 a.m. If you have not already done so, please
                            give the Foreign Minister a copy of my statement in this regard as
                            quoted in Radio Bulletin No. 164, July 11.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Hull</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>