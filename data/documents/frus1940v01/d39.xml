                subtype="historical-document" type="document" xml:id="d39">
                <note rend="inline" type="source">121.866A/25: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Italy</hi> (<persName type="to">
                        <hi rend="italic">Phillips</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1940-02-16T18:00:00-05:00"
                            >February 16, 1940—6 p.m.</date>
                    </dateline>
                </opener>
                <p>39. Your 109, February 16, Noon. Mr. Taylor’s credentials are in the form of a
                    personal letter from the President. He will not make a formal address.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
