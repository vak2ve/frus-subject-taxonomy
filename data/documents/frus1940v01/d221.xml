                subtype="historical-document" type="document" xml:id="d221">
                <note rend="inline" type="source">740.0011 European War 1939/3848: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Germany</hi> (<persName type="from">
                        <hi rend="italic">Heath</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Berlin</hi>
                        </placeName>, <date calendar="gregorian" when="1940-06-15">June 15,
                            1940</date>.<lb/>[Received June 17—1 a.m.]</dateline>
                </opener>
                <p>1889. Following message from American Embassy in Paris has just been orally
                    communicated by German military authorities: “The occupation of Paris took place
                    entirely without disorder or loss of life. All members of this mission are in
                    excellent health. Bullitt.”</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Heath</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
