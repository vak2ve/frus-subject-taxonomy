<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-06-26T15:30:00-05:00" frus:doc-dateTime-min="1940-06-26T15:30:00-05:00" n="862" subtype="historical-document" type="document" xml:id="d862">
                        <note rend="inline" type="source">740.00111 A.R.–Subs/12: Telegram</note>
                        <head>
                            <hi rend="italic">The Minister in Uruguay</hi> (<persName type="from"><hi rend="italic">Wilson</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Montevideo</hi></placeName>, <date calendar="gregorian" when="1940-06-26T17:00:00-03:30">June 26,
                                    1940—5 p.m.</date>
                                <lb/> [Received 8:40 p.m.]</dateline>
                        </opener>
                        <p>131. My 111, June 14th.<note n="28" xml:id="d862fn28">Not printed.</note>
                            The decree excluding belligerent submarines was issued last night.<note n="29" xml:id="d862fn29">Decree of June 19, 1940, Pan American
                                Union, Law and Treaty Series No. 15, p. 4.</note>
                        </p>
                        <p>Repeated to Rio de Janeiro.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Wilson</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>