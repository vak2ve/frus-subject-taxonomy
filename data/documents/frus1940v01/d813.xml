<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-05-18T14:00:00-05:00" frus:doc-dateTime-min="1940-05-18T14:00:00-05:00" n="813" subtype="historical-document" type="document" xml:id="d813">
                        <note rend="inline" type="source">740.00111 A.R./1095: Telegram</note>
                        <head>
                            <hi rend="italic">The Ambassador in Panama</hi> (<persName type="from"><hi rend="italic">Dawson</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Panama</hi></placeName>, <date calendar="gregorian" when="1940-05-18T14:00:00-05:00">May 18,
                                    1940—2 p.m.</date>
                                <lb/> [Received 2:55 p.m.]</dateline>
                        </opener>
                        <p>69. My telegram number 67.<note n="75" xml:id="d813fn75">May 18, 10 a.m.,
                                    <ref target="#pg_741">p. 741</ref>.</note> Doctor Garay is
                            releasing joint declaration for publication this afternoon in papers
                            appearing not before 5 o’clock.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Dawson</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>