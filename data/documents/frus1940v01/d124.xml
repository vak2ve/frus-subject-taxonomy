<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1940-04-16T05:40:00-05:00" frus:doc-dateTime-min="1940-04-16T05:40:00-05:00" n="124" subtype="historical-document" type="document" xml:id="d124">
                        <note rend="inline" type="source">740.0011 European War 1939/2248:
                            Telegram</note>
                        <head>
                            <hi rend="italic">The Minister in the Netherlands</hi> (<persName type="from"><hi rend="italic">Gordon</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">The Hague</hi></placeName>, <date calendar="gregorian" when="1940-04-16T11:00:00+00:20">April 16,
                                    1940—11 a.m.</date>
                                <lb/> [Received April 16—8:40 a.m.]</dateline>
                        </opener>
                        <p>119. On Sunday Dutch anti-aircraft batteries and pursuit planes were in
                            action against British, French and German planes over Netherlands
                            territory.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Gordon</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>