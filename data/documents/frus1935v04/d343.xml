    <text>
        <body>
            <div frus:doc-dateTime-max="1935-12-02T13:00:00-05:00"
                frus:doc-dateTime-min="1935-12-02T13:00:00-05:00" n="343"
                subtype="historical-document" type="document" xml:id="d343">
                <note rend="inline" type="source">611.3231/1088: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from">
                        <hi rend="italic">Gibson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1935-12-02T15:00:00-03:00"
                            >December 2, 1935—3 p.m.</date>
                        <lb/>[Received 3:35 p.m.]</dateline>
                </opener>
                <p>332. My 323, November 29, 5 p.m. Ratification exchanged this afternoon as
                    planned. Brazilian ratification dated November 30.<note n="22" xml:id="d343fn22"
                        >This agreement was proclaimed by the President of the United States
                        December 2, 1935, effective January 1, 1936.</note>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gibson</hi>
                    </signed>
                </closer>
            </div>
        </body>
