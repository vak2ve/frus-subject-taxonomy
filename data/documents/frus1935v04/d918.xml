    <text>
        <body>
            <div frus:doc-dateTime-max="1935-08-13T23:59:59-05:00"
                frus:doc-dateTime-min="1935-08-13T00:00:00-05:00" n="918"
                subtype="historical-document" type="document" xml:id="d918">
                <note rend="inline" type="source">633.113/10</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Uruguay</hi> (<persName type="to">
                        <hi rend="italic">Lay</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">No. 17</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1935-08-13">August 13,
                            1935</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: There is enclosed a copy of a letter, dated
                    August 5, 1935,<note n="7" xml:id="d918fn7">Not printed.</note> received from
                    the American Manufacturers Export Association, of 330 West Forty-second Street,
                    New York, New York, reporting a rumor that the Uruguayan Government has
                    increased customs duties on all articles imported from the United States by 30%,
                    whereas for other countries the duties were raised by only 15%.</p>
                <p>You are requested to investigate the matter and if your investigation shows that
                    there is customs discrimination against the United <pb facs="1048" n="955"
                        xml:id="pg_955"/> States, you are authorized to take the matter up with the
                    Uruguayan Minister for Foreign Affairs and ask that the discrimination be
                    removed.</p>
                <p>Very truly yours,</p>
                <closer>For the Secretary of State:<lb/>
                    <signed>
                        <hi rend="smallcaps">Sumner Welles</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
