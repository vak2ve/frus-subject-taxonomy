<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-09-17T09:00:00-05:00" frus:doc-dateTime-min="1935-09-17T09:00:00-05:00" n="231" subtype="historical-document" type="document" xml:id="d231">
                        <note rend="inline" type="source">721.23/2497: Telegram</note>
                        <head><hi rend="italic">The Minister in Colombia</hi> (<persName type="from"><hi rend="italic">Dawson</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1935-09-17T09:00:00-05:00">September 17, 1935—9
                                    a.m.</date><lb/>[Received 1:05 p.m.]</dateline>
                        </opener>
                        <p>81. Chamber of Representatives yesterday approved Rio de Janeiro protocol
                            in decisive second reading by a vote of 95 to 4.</p>
                        <closer><signed><hi rend="smallcaps">Dawson</hi></signed></closer>
                    </div>
                    </body></text></TEI>