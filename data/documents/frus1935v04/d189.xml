                subtype="historical-document" type="document" xml:id="d189">
                <note rend="inline" type="source">724.34119/278: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Argentina</hi> (<persName type="from">
                        <hi rend="italic">Weddell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1935-11-13T18:00:00-03:00"
                            >November 13, 1935—6 p.m.</date>
                        <lb/>[Received 6:21 p.m.]</dateline>
                </opener>
                <p>274. Braden<note n="11" xml:id="d189fn11">Spruille Braden, additional U. S.
                        delegate to the Chaco Peace Conference.</note> arrived this afternoon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Weddell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
