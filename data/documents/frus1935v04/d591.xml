                subtype="historical-document" type="document" xml:id="d591">
                <note rend="inline" type="source">611.1431/97c: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Guatemala</hi> (<persName type="to">
                        <hi rend="italic">Hanna</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1935-04-18T18:00:00-05:00"
                            >April 18, 1935—6 p.m.</date>
                    </dateline>
                </opener>
                <p>9. Please report by air mail whether you expect any action by the Guatemalan
                    Government on the trade agreement in the near future and if no action appears
                    imminent, whether there is any feasible way in your opinion whereby progress can
                    be expedited?</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
