<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-12-20T17:00:00-05:00" frus:doc-dateTime-min="1935-12-20T17:00:00-05:00" n="204" subtype="historical-document" type="document" xml:id="d204">
                            <note rend="inline" type="source">724.34119/316: Telegram</note>
                            <head><hi rend="italic">The Ambassador in Argentina</hi> (<persName type="from"><hi rend="italic">Weddell</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Buenos
                                            Aires</hi></placeName>, <date calendar="gregorian" when="1935-12-20T19:00:00-03:00">December 20, 1935—7
                                        p.m.</date><lb/>[Received 7:35 p.m.]</dateline>
                            </opener>
                            <p>300. From Braden. Department’s 178, December 18, noon. Rodriguez
                                Alves, Podestá Costa, Nieto Del Rio, Rivarola, Dawson and I leaving
                                for Asunción tomorrow morning, returning Monday.<note n="20" xml:id="d204fn20">December 23.</note> [Braden.]</p>
                            <closer><signed><hi rend="smallcaps">Weddell</hi></signed></closer>
                        </div>
                        </body></text></TEI>