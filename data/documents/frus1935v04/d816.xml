                <note rend="inline" type="source">611.1731/123: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Nicaragua</hi> (<persName type="to">
                        <hi rend="italic">Lane</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1935-08-26T11:00:00-04:00"
                            >August 26, 1935—11 a.m.</date>
                    </dateline>
                </opener>
                <p>38. Tour telegram No. 63, August 22, 6 p.m. List may be furnished in
                    confidence.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
