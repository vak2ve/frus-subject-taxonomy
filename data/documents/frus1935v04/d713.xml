<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-04-10T13:00:00-05:00" frus:doc-dateTime-min="1935-04-10T13:00:00-05:00" n="713" subtype="historical-document" type="document" xml:id="d713">
                        <note rend="inline" type="source">838.516/346: Telegram</note>
                        <head><hi rend="italic">The Chargé in Haiti</hi> (<persName type="from"><hi rend="italic">Chapin</hi></persName>) <hi rend="italic">to the
                                    <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Port-au-Prince</hi></placeName>, <date calendar="gregorian" when="1935-04-10T13:00:00-05:00">April 10, 1935—1
                                p.m.</date><lb/>[Received 1:55 p.m.]</dateline>
                        </opener>
                        <p>28. My despatch No. 584, April 4.<note n="16" xml:id="d713fn16">Not
                                printed.</note> De la Rue sailing today S. S. <hi rend="italic">Cristobal</hi> for the purpose of pursuing on behalf of Haitian
                            Government direct negotiations with National City Bank for completion of
                            bank purchase contract.</p>
                        <closer><signed><hi rend="smallcaps">Chapin</hi></signed></closer>
                    </div>
                    </body></text></TEI>