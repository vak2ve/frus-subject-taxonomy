<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-02-07T17:00:00-05:00" frus:doc-dateTime-min="1935-02-07T17:00:00-05:00" n="367" subtype="historical-document" type="document" xml:id="d367">
                        <note rend="inline" type="source">611.3231/779a: Telegram</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the Chargé in Brazil</hi> (<persName type="to"><hi rend="italic">Gordon</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1935-02-07T17:00:00-05:00">February 7, 1935—5
                                p.m.</date></dateline>
                        </opener>
                        <p>17. Department’s 15, February 4, 7 p.m.<note n="48" xml:id="d367fn48">Not
                                printed.</note> Cable whether Exchange Control has resumed
                            allotments of official exchange for imports from United States in
                            accordance with the terms of the exchange of notes.<note n="49" xml:id="d367fn49"><hi rend="italic">Supra</hi>.</note></p>
                        <closer><signed><hi rend="smallcaps">Hull</hi></signed></closer>
                    </div>
