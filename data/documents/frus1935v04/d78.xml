    <text>
        <body>
            <div frus:doc-dateTime-max="1935-06-12T12:00:00-05:00"
                frus:doc-dateTime-min="1935-06-12T12:00:00-05:00" n="78"
                subtype="historical-document" type="document" xml:id="d78">
                <note rend="inline" type="source">723.3415/4962: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Argentina</hi> (<persName type="from">
                        <hi rend="italic">Weddell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Buenos Aires</hi>
                        </placeName>, <date calendar="gregorian" when="1935-06-12T13:00:00-04:00"
                            >June 12, 1935—1 p.m.</date>
                        <lb/>[Received 1:42 p.m.]</dateline>
                </opener>
                <p>76. Peace pact signed Foreign Ministers of Bolivia and Paraguay and by members of
                    Mediation Commission as witnesses today at 12:45 p.m. Repeated to Asunción and
                    La Paz.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Weddell</hi>
                    </signed>
                </closer>
            </div>
        </body>
