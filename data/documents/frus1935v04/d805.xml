    <text>
        <body>
            <div frus:doc-dateTime-max="1935-07-05T23:59:59-05:00"
                frus:doc-dateTime-min="1935-07-05T00:00:00-05:00" n="805"
                subtype="historical-document" type="document" xml:id="d805">
                <note rend="inline" type="source">611.1731/108</note>
                <head>
                    <hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from">
                        <hi rend="italic">Lane</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 917</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Managua</hi>
                        </placeName>, <date calendar="gregorian" when="1935-07-05">July 5,
                            1935</date>.<lb/>[Received July 11.]</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Acknowledging the receipt of the Department’s
                    telegram No. 28 of July 3, 6 p.m., 1935, in regard to the trade agreement to be
                    negotiated with Nicaragua, I have the honor to inform the Department that this
                    morning I called upon the Minister for Foreign Affairs, handed him personally
                    one English and one Spanish copy of the general provisions supplied with the
                    Department’s instruction No. 232 of March 28, 1935,<note n="16"
                        xml:id="d805fn16">Not printed.</note> and reserved the right to make further
                    changes.</p>
                <p>Respectfully yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Arthur Bliss Lane</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
