                subtype="historical-document" type="document" xml:id="d11">
                <note rend="inline" type="source">724.3415/4562: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Paraguay</hi> (<persName type="from">
                        <hi rend="italic">Thurston</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Asunción</hi>
                        </placeName>, <date calendar="gregorian" when="1935-02-23T18:00:00-04:00"
                            >February 23, 1935—6 p.m.</date>
                        <lb/>[Received 7:45 p.m.]</dateline>
                </opener>
                <p>14. My telegram No. 12, February 21, 3 p.m. I have just been informed by
                    telephone by the Foreign Office that a communication has been transmitted to the
                    League announcing Paraguay’s withdrawal.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Thurston</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
