<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1935-09-27T17:00:00-05:00" frus:doc-dateTime-min="1935-09-27T17:00:00-05:00" n="232" subtype="historical-document" type="document" xml:id="d232">
                        <note rend="inline" type="source">721.23/2503: Telegram</note>
                        <head><hi rend="italic">The Minister in Colombia</hi> (<persName type="from"><hi rend="italic">Dawson</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Bogotá</hi></placeName>, <date calendar="gregorian" when="1935-09-27T17:00:00-05:00">September 27, 1935—5
                                    p.m.</date><lb/>[Received 5:40 p.m.]</dateline>
                        </opener>
                        <p>86. Department’s telegram No. 70 of September 26, 7 p.m., and my telegram
                            No. 85 of September 27, 9 a.m.<note n="10" xml:id="d232fn10">Neither
                                printed.</note> Ratifications of the Rio de Janeiro protocol were
                            exchanged this afternoon.</p>
                        <closer><signed><hi rend="smallcaps">Dawson</hi></signed></closer>
                    </div>
                    </body></text></TEI>