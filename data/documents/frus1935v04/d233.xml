                subtype="historical-document" type="document" xml:id="d233">
                <note rend="inline" type="source">721.23/2507: Telegram (part air)</note>
                <head>
                    <hi rend="italic">The Consul at Geneva</hi> (<persName type="from">
                        <hi rend="italic">Gilbert</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Geneva</hi>
                        </placeName>, <date calendar="gregorian" when="1935-09-30T15:00:00+01:00"
                            >September 30, 1935—3 p.m.</date>
                        <lb/>[Received October 2—6:52 a.m.]</dateline>
                </opener>
                <p>401. Secretary General is in receipt of a communication from the Colombian
                    Foreign Minister stating that the ratifications of the Rio de Janeiro protocols
                    May 1932 [<hi rend="italic">1934</hi>] were deposited on September 27.</p>
                <p>This is regarded here as technically closing the Colombia–Peru dispute as before
                    the League.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gilbert</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
