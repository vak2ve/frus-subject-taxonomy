                subtype="historical-document" type="document" xml:id="d230">
                <note rend="inline" type="source">721.23/2488: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Colombia</hi> (<persName type="from">
                        <hi rend="italic">Dawson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Bogotá</hi>
                        </placeName>, <date calendar="gregorian" when="1935-08-22T10:00:00-05:00"
                            >August 22, 1935—10 a.m.</date>
                        <lb/>[Received 11:40 a.m.]</dateline>
                </opener>
                <p>78. Colombian Senate yesterday approved Rio de Janeiro protocol in second reading
                    which under Colombian practice is definitive. Protocol has still to be
                    considered by Chamber of Representatives.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dawson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
