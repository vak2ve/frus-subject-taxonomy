<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-12-03T14:00:00-05:00" frus:doc-dateTime-min="1927-12-03T14:00:00-05:00" n="193" subtype="historical-document" type="document" xml:id="d193">
                        <note rend="inline" type="source">500.A15/606: Telegram</note>
                        <head><hi rend="italic">The Chief of the American Representation on the
                                Preparatory Commission</hi> (<persName type="from"><hi rend="italic">Wilson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Geneva</hi></placeName>, <date calendar="gregorian" when="1927-12-03T20:00:00+01:00"><hi rend="italic">December 3,
                                        1927—8 p.m.</hi></date><lb/>[Received December 3—10:30
                                a.m.]</dateline></opener>
                        <p>5. Fourth session Preparatory Commission closed today. Security Committee
                            meets on or about February 20th, Preparatory Commission March 15th.</p>
                        <closer><signed><hi rend="smallcaps">Wilson</hi></signed></closer>
                    </div>
                </body></text></TEI>