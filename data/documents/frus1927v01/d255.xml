<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-10-06T18:00:00-05:00" frus:doc-dateTime-min="1927-10-06T18:00:00-05:00" n="255" subtype="historical-document" type="document" xml:id="d255">
                            <note rend="inline" type="source">717.2114/53: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Chargé in Nicaragua</hi> (<persName type="to"><hi rend="italic">Munro</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1927-10-06T18:00:00-05:00"><hi rend="italic">October
                                            6, 1927—6 p.m.</hi></date></dateline></opener>
                            <p>151. Your 260, October 4, 2 p.m. It has been necessary to consult
                                another Department in connection with this question and your
                                instructions have been delayed pending receipt of reply. It is hoped
                                that it may be possible to send instructions to you before long.</p>
                            <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                        </div>
                        </body></text></TEI>