<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-09-14T16:00:00-05:00" frus:doc-dateTime-min="1927-09-14T16:00:00-05:00" n="253" subtype="historical-document" type="document" xml:id="d253">
                            <note rend="inline" type="source">717.2114/51: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Chargé in Nicaragua</hi> (<persName type="to"><hi rend="italic">Munro</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1927-09-14T17:00:00-04:00"><hi rend="italic">September
                                            14, 1927—5 p.m.</hi></date></dateline></opener>
                            <p>141. Your 241 September 13, 5 p.m. Department is giving serious
                                consideration to this question and instructions will be forwarded to
                                you in the near future.</p>
                            <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                        </div>
                        </body></text></TEI>