<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-05-23T23:59:59-05:00" frus:doc-dateTime-min="1927-05-23T00:00:00-05:00" n="41" subtype="historical-document" type="document" xml:id="d41">
                        <note rend="inline" type="source">500.A15 a 1/244a</note>
                        <head><hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the British Ambassador</hi> (<persName type="to"><hi rend="italic">Howard</hi></persName>)<note n="37" xml:id="d41fn37">An identic
                                note was sent on the same date to the Japanese
                            Ambassador.</note></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1927-05-23"><hi rend="italic">May 23,
                                1927</hi></date>.</dateline></opener>
                        <p><hi rend="smallcaps">Excellency</hi>: In accordance with informal
                            conversations on this subject, I now have the honor to confirm the
                            arrangement that the Three Power Naval Conference at Geneva will open at
                            four o’clock on Monday, June 20, 1927.</p>
                        <p>Accept [etc.]</p>
                        <closer><signed><hi rend="smallcaps">Frank B. Kellogg</hi></signed></closer>
                    </div>
                    </body></text></TEI>