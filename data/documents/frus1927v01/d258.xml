<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1927-11-11T19:00:00-05:00" frus:doc-dateTime-min="1927-11-11T19:00:00-05:00" n="258" subtype="historical-document" type="document" xml:id="d258">
                            <note rend="inline" type="source">717.2114/57: Telegram</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Chargé in Nicaragua</hi> (<persName type="to"><hi rend="italic">Munro</hi></persName>)</head>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1927-11-11T19:00:00-05:00"><hi rend="italic">November
                                            11, 1927—7 p.m.</hi></date></dateline></opener>
                            <p>190. Your 327, November 11, 11 a.m. Department expects to be able to
                                give you an answer next week.</p>
                            <closer><signed><hi rend="smallcaps">Kellogg</hi></signed></closer>
                        </div>
                    </body></text></TEI>