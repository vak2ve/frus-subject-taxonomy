                subtype="historical-document" type="document" xml:id="d129">
                <head>No. 124.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Evarts</persName> to Mr. <persName
                            type="to">Hitt</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1878-07-19">
                            <hi rend="italic">July</hi> 19, 1878</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Hitt</hi>, <hi rend="italic">Chargé Paris:</hi>
                </p>
                <p>Request French Government to issue invitations to powers accepting monetary
                    conference for meeting at Paris tenth August.</p>
                <p rend="center">* * * * * * *</p>
                <closer>
                    <signed>EVARTS, <hi rend="italic">Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
