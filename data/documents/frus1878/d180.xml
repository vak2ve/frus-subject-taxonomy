    <text>
        <body>
            <div frus:doc-dateTime-max="1878-04-16T23:59:59-05:00" frus:doc-dateTime-min="1878-04-16T00:00:00-05:00" n="180" subtype="historical-document" type="document" xml:id="d180">
                <head>No. 175.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Evarts</persName>
                            to Mr. <persName type="to">Welsh</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1878-04-16">
                            <hi rend="italic">April</hi> 16,
                            1878</date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Welsh</hi>, <hi rend="italic">Minister,
                            London:</hi>
                </p>
                <p>This government does not consider attendance upon the conference as
                        committing any nation beyond a consultation upon the subject, leaving each
                        free in its conclusions and further action.</p>
                <closer>
                    <signed>EVARTS, <hi rend="italic">Secretary</hi>.</signed>
                </closer>
            </div>
        </body>
