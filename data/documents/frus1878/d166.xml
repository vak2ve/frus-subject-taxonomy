    <text>
        <body>
            <div frus:doc-dateTime-max="1878-10-18T23:59:59-05:00"
                frus:doc-dateTime-min="1878-10-18T00:00:00-05:00" n="166"
                subtype="historical-document" type="document" xml:id="d166">
                <head>No. 161.<lb/>
                    <hi rend="italic">Mr. <persName type="from">von Schlözer</persName> to Mr.
                            <persName type="to">Evarts</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Imperial German Legation</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1878-10-18">
                            <hi rend="italic">October</hi> 18, 1878</date>. (Received October
                        19.)</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: His Majesty the Emperor of Germany has sent to me
                    3,000 marks as relief for the suffering German people in the yellow-fever
                    districts. I therefore inclose herewith $705, and beg you, respectfully, to be
                    kind enough to cause the distribution of this money among such sufferers.</p>
                <p>Accept, &amp;c.,</p>
                <closer>
                    <signed>SCHLÖZER.</signed>
                </closer>
            </div>
        </body>
