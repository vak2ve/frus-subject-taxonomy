<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1878-06-09T23:59:59-05:00" frus:doc-dateTime-min="1878-06-09T00:00:00-05:00" n="123" subtype="historical-document" type="document" xml:id="d123">
                    <head>No. 118.<lb/><hi rend="italic">Mr. <persName type="from">Hitt</persName>
                            to Mr. <persName type="to">Evarts</persName></hi>.</head>
                    <opener><dateline rendition="#center">[Telegram.—Received <date calendar="gregorian" type="received-date" when="1878-06-09">June 9,
                                1878</date>.]</dateline></opener>
                    <p rend="flushleft"><hi rend="smallcaps">Evarts</hi>, <hi rend="italic">Secretary, Washington:</hi></p>
                    <p>France answers. Ready to take part in monetary conference. Italy assents.
                        Waddington proposes Paris as place.</p>
                    <closer><signed>HITT,<lb/><hi rend="italic">Chargé.</hi></signed></closer>
                </div>
                </body></text></TEI>