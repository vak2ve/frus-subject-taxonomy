<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1878-06-03T23:59:59-05:00" frus:doc-dateTime-min="1878-06-03T00:00:00-05:00" n="448" subtype="historical-document" type="document" xml:id="d448">
                    <head>No. 443.<lb/><hi rend="italic">Mr. <persName type="from">Hoffman</persName> to Mr. <persName type="to">Evarts</persName></hi>.</head>
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">St.
                                    Petersburg</hi></placeName>.</dateline></opener>
                    <p rend="flushleft"><hi rend="smallcaps">Evarts</hi>, <hi rend="italic">Washington, United States:</hi></p>
                    <p>Russia accepts Congress condition, study question only. Reserves liberty of
                        action as regards further measures. Prefers European city.</p>
                    <closer><signed>HOFFMAN.</signed>
                        <lb/>
                        <dateline rendition="#left">Received <date calendar="gregorian" type="received-date" when="1878-06-03">June 3,
                            1878</date>.</dateline>
                    </closer>
                </div>
                </body></text></TEI>