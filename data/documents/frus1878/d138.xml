        <body>
            <div frus:doc-dateTime-max="1878-10-17T23:59:59-05:00" frus:doc-dateTime-min="1878-10-17T00:00:00-05:00" n="138" subtype="historical-document" type="document" xml:id="d138">
                <head>No. 133.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Noyes</persName>
                            to Mr. <persName type="to">Evarts</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#center">[Telegram.—Received <date calendar="gregorian" type="received-date" when="1878-10-17">October
                                17, 1878</date>.]</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Evarts</hi>, <hi rend="italic">Washington:</hi>
                </p>
                <p>Four thousand dollars more with Munroe, your credit for yellow fever.</p>
                <closer>
                    <signed>NOYES</signed>,<lb/>
                    <hi rend="italic">Paris.</hi>
                </closer>
            </div>
        </body>
