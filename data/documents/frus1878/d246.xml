                subtype="historical-document" type="document" xml:id="d246">
                <head>No. 241.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Read</persName> to Mr. <persName
                            type="to">Evarts</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Athens</hi>
                        </placeName>, <date calendar="gregorian" when="1878-04-12">
                            <hi rend="italic">April</hi> 12, 1878</date>.</dateline>
                </opener>
                <p rend="flushleft">To Secretary <hi rend="smallcaps">Evarts</hi>,<lb/>
                    <hi rend="italic">Washington:</hi>
                </p>
                <p>Greece accepts our invitation, and will send representative to the bi-metallic
                    conference.</p>
                <closer>
                    <signed>READ.</signed>
                </closer>
            </div>
        </body>
