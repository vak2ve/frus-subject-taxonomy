<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1878-09-24T23:59:59-05:00" frus:doc-dateTime-min="1878-09-24T00:00:00-05:00" n="134" subtype="historical-document" type="document" xml:id="d134">
                    <head>No. 129.<lb/><hi rend="italic">Mr. <persName type="from">Noyes</persName>
                            to Mr. <persName type="to">Evarts</persName></hi>.</head>
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Paris</hi></placeName>, <date calendar="gregorian" when="1878-09-24"><hi rend="italic">September</hi> 24, 1878</date>.
                            (Received September 24.)</dateline></opener>
                    <p><hi rend="smallcaps">Evarts</hi>, <hi rend="italic">Washington:</hi></p>
                    <p>Four thousand dollars more yellow fever fund sent your credit New York,
                        including five thousand francs from Marshal and Madame Mac-Mahon.</p>
                    <closer><signed>NOYES.</signed></closer>
                </div>
                </body></text></TEI>