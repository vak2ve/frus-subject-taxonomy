                subtype="historical-document" type="document" xml:id="d130">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Wharton</persName> to Mr. <persName
                            type="to">Egan</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1891-06-01">
                            <hi rend="italic">June 1, 1891</hi>
                        </date>.</dateline>
                </opener>
                <p>Mr. Wharton instructs Mr. Egan that, prompted solely by a desire to restore
                    peace, and entirely disinterested, the President desires him to <pb facs="0238"
                        n="132" xml:id="pg_132"/> informally and discreetly ascertain whether the
                    good offices of this Government can in any way be used for the termination of
                    the conflict in Chile.</p>
            </div>
        </body>
