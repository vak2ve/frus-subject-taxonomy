    <text>
        <body>
            <div frus:doc-dateTime-max="1891-08-10T00:55:59-05:00" frus:doc-dateTime-min="1891-08-08T00:56:00-05:00" n="87" subtype="historical-document" type="document" xml:id="d87">
                <head>
                    <hi rend="italic">Señor <persName type="from">Galindo</persName> to
                                Mr. <persName type="to">Blaine</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Ministry of Foreign Affairs</hi>,<lb/>
                            <hi rend="italic">San
                                        Salvador</hi>
                        </placeName>, [<date ana="#date_undated-inferred-from-document-content-and-sibling-dates" calendar="gregorian" notAfter="1891-08-09T23:59:59-05:56" notBefore="1891-08-08T00:00:00-05:56">undated</date>.] (Received
                                August 9, 1891.)</dateline>
                </opener>
                <p>
                    <hi rend="italic">City of Panama</hi> has sailed from the territory of
                            the Union without permission from captain of port, and, pending a trial,
                            sentence was yesterday pronounced by the court of first instance
                            declaring her confiscated.</p>
                <p>Your obedient servant,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Galindo</hi>,<lb/>
                        <hi rend="italic">Minister of Foreign Relations</hi>.</signed>
                </closer>
            </div>
        </body>
