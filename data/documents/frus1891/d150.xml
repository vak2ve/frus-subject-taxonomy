                subtype="historical-document" type="document" xml:id="d150">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Egan</persName> to Mr. <persName
                            type="to">Blaine</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Santiago</hi>
                        </placeName>, <date calendar="gregorian" when="1891-07-16">
                            <hi rend="italic">July 16, 1891</hi>.</date> (Received September
                        26.)</dateline>
                    <seg rendition="#left">No. 180.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to-day received your telegram informing me
                    that the Central and South American Telegraph Company expects to connect cables
                    in the free sea, between Callao and Valparaiso, about the 20th instant, which
                    information I have duly conveyed to the Chilean Government.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Patrick Egan</hi>.</signed>
                </closer>
            </div>
        </body>
