            <div frus:doc-dateTime-max="1891-09-01T23:59:59-05:00" frus:doc-dateTime-min="1891-09-01T00:00:00-05:00" n="170" subtype="historical-document" type="document" xml:id="d170">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Wharton</persName> to Mr.
                                <persName type="to">Egan</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1891-09-01">
                            <hi rend="italic">September 1,
                            1891</hi>
                        </date>.</dateline>
                </opener>
                <p>Mr. Wharton instructs Mr. Egan to send at once by cable a full statement of
                        the condition of affairs now existing.</p>
            </div>
