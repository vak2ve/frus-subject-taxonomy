                    <head><hi rend="italic">Mr. <persName type="from">Phelps</persName> to Mr.
                                <persName type="to">Blaine</persName></hi>.</head>
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Legation of
                                    the United States</hi>,<lb/><hi rend="italic">Berlin</hi></placeName>, <date calendar="gregorian" when="1891-09-12"><hi rend="italic">September 12,
                            1891</hi></date>.</dateline></opener>
                    <p>Pork admitted on American inspection certificate. Germany imposes no other
                        condition.</p>
                    <closer><signed><hi rend="smallcaps">Phelps</hi>.</signed></closer>
