                subtype="historical-document" type="document" xml:id="d134">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Egan</persName> to Mr. <persName
                            type="to">Blaine</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Santiago</hi>
                        </placeName>, <date calendar="gregorian" when="1891-06-03">
                            <hi rend="italic">June 3, 1891</hi>.</date> (Received July
                        16.)</dateline>
                    <seg rendition="#left">No. 170.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge receipt of your
                    telegram of June 1, respecting the <hi rend="italic">Itata</hi>, on yesterday,
                    and have communicated the contents to the minister of foreign relations.</p>
                <p>I remain, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Patrick Egan</hi>.</signed>
                </closer>
            </div>
        </body>
