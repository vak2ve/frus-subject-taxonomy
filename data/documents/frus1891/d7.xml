    <text>
        <body>
            <div frus:doc-dateTime-max="1891-03-30T23:59:59-05:00" frus:doc-dateTime-min="1891-03-30T00:00:00-05:00" n="7" subtype="historical-document" type="document" xml:id="d7">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr.
                                <persName type="to">Pitkin</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1891-03-30">
                            <hi rend="italic">March 30,
                            1891</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 111.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have received your No. 94, of the 5th
                        ultimo, inclosing copy of your protest to the Argentine Government against
                        the law discriminating against foreign life-insurance companies in the
                        Argentine Republic.</p>
                <p>Your very thorough presentation of the case is approved by the
                        Department.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">James G. Blaine</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
