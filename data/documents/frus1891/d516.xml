                <head>
                    <hi rend="italic">Sir <persName type="from">Julian
                                    Pauncefote</persName> to Mr. <persName type="to">Wharton</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Newport, R. I</hi>.</placeName>, <date calendar="gregorian" when="1891-08-26">
                            <hi rend="italic">August 26,
                                1891</hi>
                        </date>.</dateline>
                </opener>
                <p>Your note of 22d. Important letter posted to-day.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Pauncefote</hi>.</signed>
                </closer>
