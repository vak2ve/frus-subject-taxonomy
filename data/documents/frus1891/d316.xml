                <head>
                    <hi rend="italic">Left with Secretary December 3, 1891, by Señor
                                Montt</hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santiago</hi>
                        </placeName>, <date calendar="gregorian" when="1891-12-01">
                            <hi rend="italic">December 1,
                                1891</hi>
                        </date>.</dateline>
                </opener>
                <p rend="flushleft">
                    <hi rend="smallcaps">Pedro Montt</hi>,<lb/>
                    <hi rend="italic">1329 M street, Washington, D. C.:</hi>
                </p>
                <p>Preliminary examination not yet finished on account of proceedings
                            necessary to secure the statements of experts. Egan’s testimony was
                            asked for twenty days ago.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Matta</hi>.</signed>
                </closer>
            </div>
        </body>
