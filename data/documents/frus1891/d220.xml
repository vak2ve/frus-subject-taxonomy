<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1891-11-03T23:59:59-05:00" frus:doc-dateTime-min="1891-11-03T00:00:00-05:00" n="220" subtype="historical-document" type="document" xml:id="d220">
                    <head><hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr.
                                <persName type="to">McCreery</persName></hi>.</head>
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department
                                    of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1891-11-03"><hi rend="italic">November 3,
                            1891</hi></date>.</dateline></opener>
                    <p>Give me all the facts you have and all the information you can get relative
                        to riot. Use naval cipher.</p>
                </div>
                </body></text></TEI>