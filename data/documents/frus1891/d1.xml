                <head>
                    <hi rend="italic">Mr. <persName type="from">Blaine</persName> to Mr. <persName
                            type="to">Pitkin</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1891-01-05">
                            <hi rend="italic">January 5, 1891</hi>
                        </date>.</dateline>
                </opener>
                <p>Protest against levying exceptionally large tax on foreign life-insurance
                    companies doing business in the Argentine.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blaine</hi>.</signed>
                </closer>
            </div>
