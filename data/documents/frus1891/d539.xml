                subtype="historical-document" type="document" xml:id="d539">
                <head>
                    <hi rend="italic">Sir <persName type="from">Julian Pauncefote</persName> to Mr.
                            <persName type="to">Blaine</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">British Legation</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1892-01-16">
                            <hi rend="italic">January 16, 1892</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. Blaine</hi>: I have just received a telegram to
                    the effect that Sir G. Baden-Powell leaves Liverpool this day by the <hi
                        rend="italic">Etruria</hi> for New York, whence he will proceed to Ottawa
                    for a few days, and then come to Washington with Dr. Dawson. They hope to be
                    here on the 20th instant.</p>
                <p>Believe me, yours, very truly,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Julian Pauncefote</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
