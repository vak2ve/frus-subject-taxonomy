                subtype="historical-document" type="document" xml:id="d413">
                <head>
                    <hi rend="italic">The <gloss type="from">Chinese consul-general</gloss> to Mr.
                            <persName type="to">Tsui</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Francisco</hi>
                        </placeName>, <date calendar="gregorian" when="1891-07-24">
                            <hi rend="italic">July 24, 1891</hi>
                        </date>.</dateline>
                </opener>
                <p>The Chinese merchants at Vallejo, Cal., have recently been repeatedly outraged,
                    robbed, and murdered. Please communicate with the State Department, with a
                    request that instructions be sent by telegraph to extend protection to them.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Li Yung Yew</hi>.</signed>
                </closer>
            </div>
        </body>
