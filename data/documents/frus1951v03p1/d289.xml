                            <figure>
                                <graphic url="figure_0588"/>
                                <p>Secretary of Defense Marshall, President <persName corresp="#p_THS1">Truman</persName>, and Secretary of State
                                        <persName corresp="#p_ADG1">Acheson</persName> see General
                                        <persName corresp="#p_E1">Eisenhower</persName> off on his
                                    trip to Europe, January 6, 1951.</p>
                            </figure>
                            <figure>
                                <graphic url="figure_0588a"/>
