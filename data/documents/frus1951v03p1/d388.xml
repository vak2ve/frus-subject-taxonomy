                    </list>
                    <pb facs="0740" n="702" xml:id="pg_702"/>
                    <list>
                        <item>
                            <hi rend="italic">United States</hi>
                        </item>
                        <item>Secretary of State <persName corresp="#p_ADG1">Acheson</persName>
                        </item>
                        <item>Ambassador <persName corresp="#p_BDKE1">Bruce</persName>
                        </item>
                        <item>Ambassador <persName corresp="#p_GWS1">Gifford</persName>
                        </item>
                        <item>Ambassador <persName corresp="#p_JPC1">Jessup</persName>
                        </item>
                        <item>Mr. <persName corresp="#p_PGW1">Perkins</persName>
                        </item>
                        <item>Mr. <persName corresp="#p_RGH1">Raynor</persName>
                        </item>
                        <item>Mr. <persName corresp="#p_KRB1">Knight</persName> (for part of the
                            meeting)</item>
                        <item>Mr. <persName>Lewis Jones</persName> (for part of the meeting)</item>
