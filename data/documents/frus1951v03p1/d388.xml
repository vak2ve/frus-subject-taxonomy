                        </item>
                        <item>Mr. <persName corresp="#p_DBF1">Dixon</persName>
                        </item>
                        <item>Mr. <persName corresp="#p_SCAE1">Shuckburgh</persName>
                        </item>
                        <item>Mr. <persName corresp="#p_BRJ1">Bowker</persName>
                        </item>
                        <item>Mr. <persName corresp="#p_JG1">Jebb</persName>
                        </item>
                        <item>Mr. <persName corresp="#p_PCC1">Parrott</persName>
                        </item>
                        <item>Ambassador <persName corresp="#p_HSOC1">Harvey</persName>
