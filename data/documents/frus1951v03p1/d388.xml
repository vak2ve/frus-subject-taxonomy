                <note rend="inline" type="source">Conference files, lot 59 D 95, CF 96</note>
                <head>
                    <hi rend="italic">United States Minutes of the Tripartite Foreign Ministers
                        Meeting at the French Foreign Office, Tuesday, November 6, 1951, 10:30
                        a.m.</hi>
                    <note n="1" xml:id="d388fn1">In the records of the U.S. Delegation that
                        accompanied the Secretary of State, these minutes were designated as Nov T
                        M–l.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Extract]</seg>
                </opener>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1951-11-06">November 6,
                            1951</date>.]</dateline>
                </opener>
                <p rend="center">
                    <hi rend="smallcaps">Present</hi>
                </p>
