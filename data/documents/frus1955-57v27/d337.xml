    <text>
        <body>
            <div frus:doc-dateTime-max="1957-10-29T23:59:59-05:00"
                frus:doc-dateTime-min="1957-10-29T00:00:00-05:00" n="337"
                subtype="historical-document" type="document" xml:id="d337">
                <head>337. Letter From Secretary of State <persName corresp="#p_DJF1" type="from"
                        >Dulles</persName> to Foreign Secretary <persName corresp="#p_LSJSB1"
                        type="to">Lloyd</persName>
                    <note n="1" type="source" xml:id="d337fn1">Source: Department of State,
                        Conference Files: Lot 62 D 181, CF 928. Top Secret. Drafted by <persName
                            corresp="#p_GJNJ1">Greene</persName>.</note>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <hi rend="italic">
                            <placeName>Washington</placeName>, <date calendar="gregorian"
                                when="1957-10-29">October 29, 1957</date>.</hi>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Selwyn</hi>: Thank you for your letter of October 25,
                        1957,<note n="2" xml:id="d337fn2">
                        <ref target="#d336">
                            <hi rend="italic">Supra.</hi>
                        </ref>
                    </note> confirming that the present Government of the United Kingdom will not
                    seek or support, without prior agreement with the United States Government, any
                    change in regard to the representation of China in the United Nations, its
                    dependent agencies and other international organizations in which this question
                    may arise.</p>
                <p>Sincerely yours,</p>
                <closer>
                    <signed>
                        <persName corresp="#p_DJF1">
                            <hi rend="strong">John Foster Dulles</hi>
                        </persName>
                        <note n="3" xml:id="d337fn3">Printed from a copy that bears this stamped
                            signature.</note>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
