    <text>
        <body>
            <div frus:doc-dateTime-max="1942-01-11T23:59:59-05:00"
                frus:doc-dateTime-min="1942-01-11T00:00:00-05:00" n="207"
                subtype="historical-document" type="document" xml:id="d207">
                <note rend="inline" type="source">Hopkins Papers</note>
                <head>
                    <hi rend="italic">Memorandum by the President’s Special Assistant</hi> (<hi
                        rend="italic">Hopkins</hi>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1942-01-11">January 11,
                            1942</date>.</dateline>
                </opener>
                <p rend="center">
                    <hi rend="smallcaps">Problems To Be Settled</hi>
                    <note n="1" xml:id="d207fn1">For other excerpts from this memorandum, see <hi
                            rend="italic">ante</hi>, <ref target="#pg_229">p. 229</ref>.</note>
                </p>
                <list>
                    <label>1.</label>
                    <item>Consideration of an organization to plan the joint use of the merchant
                        ships of the world.</item>
                    <label>2.</label>
                    <item>Consideration of an appropriate machine to control the raw materials
                        available to the United Nations.</item>
                </list>
                <p rend="center">. . . . . . . . . . . . . .</p>
                <list>
                    <label>4.</label>
                    <item>A joint machinery which would be set up for the distribution of
                        manufactured munitions of war to various theaters.</item>
                </list>
            </div>
        </body>
