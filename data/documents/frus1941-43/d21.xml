                subtype="historical-document" type="document" xml:id="d21">
                <note rend="inline" type="source">Roosevelt Papers</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">President</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1941-12-18">December 18,
                            1941</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Dear Mr. President</hi>: I have your letter of December
                    eighteenth relative to the important question of a meeting with the British and
                    the Dutch concerning raw materials.</p>
                <pb facs="0095" n="21" xml:id="pg_21"/>
                <p>In accord with your request I am glad to assign Mr. Thomas K. Finletter as a
                    member of the group and have advised him accordingly.</p>
                <p>Sincerely yours,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cordell Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
