                        </row>
                        <row>
                            <cell/>
                            <cell>Mr. Cabot</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>Mr. Barrett<note n="3" xml:id="d89fn3">Edward W. Barrett,
                                    Assistant Secretary of State for Public Affairs.</note>
                            </cell>
                        </row>
