    <teiHeader><fileDesc><titleStmt><title>The Consul General at Shanghai (
                        Cabot
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1948v08</bibl><bibl type="frus-document-id">d615</bibl><bibl type="frus-document-number">615</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1948-09-28T06:00:00-05:00" notAfter="1948-09-28T06:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1948-09-28T06:00:00-05:00" frus:doc-dateTime-min="1948-09-28T06:00:00-05:00" n="615" subtype="historical-document" type="document" xml:id="d615">
                <note rend="inline" type="source">893.24 FLC/9–2848: Telegram</note>
                <head>
                    <hi rend="italic">The Consul General at Shanghai</hi> (<persName type="from">
                        <hi rend="italic">Cabot</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Shanghai</hi>
                        </placeName>, <date calendar="gregorian" when="1948-09-28T20:00:00+09:00">September 28, 1948—8 p.m.</date>
                        <lb/>[Received September 28—5:49 a.m.]</dateline>
                </opener>
                <p>2097. [To Nanking:] Cite SFLC 3311, reur 848.<note n="39" xml:id="d615fn39">See
                        footnote 37, above.</note> Clark’s minutes accord my understanding tentative
                    agreement. Fruitless delay to <pb facs="0734" n="724" xml:id="pg_724"/> argue
                    minutes. Tung Ling version unworkable and unacceptable. Request Foreign Office
                    meeting soonest. Signed Luboshez.</p>
                <p>Sent Nanking 1598, repeated Department 2097.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Cabot</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
