<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Ambassador in China (
                        Stuart
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1948v08</bibl><bibl type="frus-document-id">d774</bibl><bibl type="frus-document-number">774</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1948-10-28T05:00:00-05:00" notAfter="1948-10-28T05:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1948-10-28T05:00:00-05:00" frus:doc-dateTime-min="1948-10-28T05:00:00-05:00" n="774" subtype="historical-document" type="document" xml:id="d774">
                <note rend="inline" type="source">893.111/10–2848: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Stuart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1948-10-28T18:00:00+08:00">October 28, 1948—6 p.m.</date>
                        <lb/>[Received October 29—1 a.m.]</dateline>
                </opener>
                <p>2029. In view generally deteriorating military situation North China, overcrowded
                    transport facilities and critical food and housing shortage, we recommend in
                    strongest terms that authorization for travel to that area, particularly Peiping
                    and Tientsin, not be authorized for military or other US Government personnel or
                    dependents except on official business or in unusual circumstances.</p>
                <p>Sent Tokyo 98, sent Seoul 36, sent Manila 21, repeated Department.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stuart</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
