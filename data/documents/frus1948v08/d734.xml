<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1948-08-13T04:00:00-05:00" frus:doc-dateTime-min="1948-08-13T04:00:00-05:00" n="734" subtype="historical-document" type="document" xml:id="d734">
                        <note rend="inline" type="source">393.1115/8–1348: Telegram</note>
                        <head><hi rend="italic">The Ambassador in China</hi> (<persName type="from"><hi rend="italic">Stuart</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Nanking</hi></placeName>, <date calendar="gregorian" when="1948-08-13T18:00:00+09:00">August 13, 1948—6
                                p.m.</date><lb/>[Received August 13—10:09 a.m.]</dateline>
                        </opener>
                        <p>1509. ReDeptel 101, January 22. Number Americans critical areas, China,
                            as of August is as follows: <list>
                                <item>Mukden 21</item>
                                <item>Tientsin 168</item>
                                <item>Chahar 2</item>
                                <item>Peiping 633</item>
                                <item>Hopei (outside Peiping and Tientsin) 18</item>
                                <item>Suiyuan 11</item>
                                <item>Shensi 4</item>
                                <item>Kansu 43</item>
                                <item>Hupeh 294</item>
                                <item>Shantung (outside Tsingtao) 9</item>
                                <item>Shensi 29</item>
                                <item>Honan 10.</item>
                            </list></p>
                        <closer><signed><hi rend="smallcaps">Stuart</hi></signed></closer>
                    </div>
