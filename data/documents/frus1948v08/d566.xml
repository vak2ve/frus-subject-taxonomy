    <text>
        <body>
            <div frus:doc-dateTime-max="1948-12-17T22:00:00-05:00"
                frus:doc-dateTime-min="1948-12-17T22:00:00-05:00" n="566"
                subtype="historical-document" type="document" xml:id="d566">
                <note rend="inline" type="source">893.50 Recovery/12–1748: Telegram</note>
                <head>
                    <hi rend="italic">The Deputy ECA Administrator</hi> (<persName type="from">
                        <hi rend="italic">Bruce</hi>
                    </persName>) <hi rend="italic">to the Chief of the ECA China Mission</hi>
                        (<persName type="to">
                        <hi rend="italic">Lapham</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1948-12-17T22:00:00-05:00"
                            >December 17, 1948—10 p.m.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Ecato</hi> 768. Reur <hi rend="smallcaps">Toeca</hi> 621,
                    following based on discussion with Acting Sec of State.</p>
                <list>
                    <label>1.</label>
                    <item>Re para <hi rend="italic">c</hi>. Plans for continued shipment not yet
                        made here and will depend on general decisions highest levels
                        Washington.</item>
                    <label>2.</label>
                    <item>Re para <hi rend="italic">f</hi>. No personal views or assurances should
                        be given to any <hi rend="italic">de facto</hi> authorities. Any discussions
                        re distribution should be confined strictly to supplies already on hand in
                        China.</item>
                    <label>3.</label>
                    <item>Instructions paras <hi rend="italic">a</hi> and <hi rend="italic">b</hi>
                        okay.</item>
                </list>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bruce</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
