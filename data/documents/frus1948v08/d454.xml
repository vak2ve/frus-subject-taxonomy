<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1948-06-21T03:00:00-05:00" frus:doc-dateTime-min="1948-06-21T03:00:00-05:00" n="454" subtype="historical-document" type="document" xml:id="d454">
                        <note rend="inline" type="source">893.50 Recovery/6–2148: Telegram</note>
                        <head><hi rend="italic">The Ambassador in China</hi> (<persName type="from"><hi rend="italic">Stuart</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Nanking</hi></placeName>, <date calendar="gregorian" when="1948-06-21T17:00:00+09:00">June 21, 1948—5
                                p.m.</date><lb/>[Received June 21—6:36 a.m.]</dateline>
                        </opener>
                        <p>1105. ReDeptel 861, June 9. Embassy anxiously awaiting promised revised
                            text of article III of bilateral for presentation to Chinese.</p>
                        <p>Repeated to Shanghai 501.</p>
                        <closer><signed><hi rend="smallcaps">Stuart</hi></signed></closer>
                    </div>
                    </body></text></TEI>