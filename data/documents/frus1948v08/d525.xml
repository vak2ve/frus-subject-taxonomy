    <teiHeader><fileDesc><titleStmt><title>The Ambassador in China (
                        Stuart
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1948v08</bibl><bibl type="frus-document-id">d525</bibl><bibl type="frus-document-number">525</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1948-06-29T04:00:00-05:00" notAfter="1948-06-29T04:00:00-05:00"/></setting></settingDesc>            <textClass>
