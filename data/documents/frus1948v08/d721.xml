        <body>
            <div frus:doc-dateTime-max="1948-05-28T10:00:00-05:00" frus:doc-dateTime-min="1948-05-28T10:00:00-05:00" n="721" subtype="historical-document" type="document" xml:id="d721">
                <note rend="inline" type="source">893.00/5–2748: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Stuart</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1948-05-28T11:00:00-04:00">May 28, 1948—11 a.m.</date>
                    </dateline>
                </opener>
                <p>799. In light of conditions reported Embtel 962 May 27 authorization hereby given
                    to issue warning to American residents Peiping–Tientsin area along lines
                    indicated.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lovett</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
