    <text>
        <body>
            <div frus:doc-dateTime-max="1948-06-29T21:00:00-05:00"
                frus:doc-dateTime-min="1948-06-29T21:00:00-05:00" n="494"
                subtype="historical-document" type="document" xml:id="d494">
                <note rend="inline" type="source">893.50 Recovery/6–3048: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Stuart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1948-06-30T11:00:00+09:00"
                            >June 30, 1948—11 a.m.</date>
                        <lb/>[Received June 30—1:02 a.m.]</dateline>
                </opener>
                <p>1181. Embassy greatly appreciates contents and speed Deptel 950, June 29. Embassy
                    will await final communication with Lapham or Gilpatric prior closing. Only
                    points Embassy now awaiting Department reply appear to be: <list>
                        <label>(1)</label>
                        <item>Query contained Embtel 1172, June 28 regarding article II, paragraph
                            2.</item>
                        <label>(2)</label>
                        <item>Possible NAC insistence hinted last sentence Deptel 930, June 26
                            regarding article V, paragraph 5.</item>
                        <label>(3)</label>
                        <item>Query contained Embtel 1170, June 28.</item>
                        <label>(4)</label>
                        <item>Receipt full powers.</item>
                    </list>
                </p>
                <p>Sent Department 1181, repeated Shanghai 550.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stuart</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
