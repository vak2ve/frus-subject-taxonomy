        <body>
            <div frus:doc-dateTime-max="1948-06-09T20:00:00-05:00" frus:doc-dateTime-min="1948-06-09T20:00:00-05:00" n="698" subtype="historical-document" type="document" xml:id="d698">
                <note rend="inline" type="source">893.796A/6–1048: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in China</hi> (<persName type="from">
                        <hi rend="italic">Stuart</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Nanking</hi>
                        </placeName>, <date calendar="gregorian" when="1948-06-10T10:00:00+09:00">June 10, 1948—10 a.m.</date>
                        <lb/>[Received June 10—4:45 a.m.]</dateline>
                </opener>
                <p>1049. Embassy perceives no objection to plan outlined Deptel sent Nanking 843,
                    repeated Shanghai 1027 June 4. Information contained therein will be conveyed
                    Tai, CCAA.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Stuart</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
