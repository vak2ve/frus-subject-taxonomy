<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Acting Secretary of State to
                        the Ambassador in China (
                        Stuart
                    )</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1948v08</bibl><bibl type="frus-document-id">d786</bibl><bibl type="frus-document-number">786</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1948-11-04T17:00:00-05:00" notAfter="1948-11-04T17:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1948-11-04T17:00:00-05:00" frus:doc-dateTime-min="1948-11-04T17:00:00-05:00" n="786" subtype="historical-document" type="document" xml:id="d786">
                <note rend="inline" type="source">393.0015/11–448: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in China</hi> (<persName type="to">
                        <hi rend="italic">Stuart</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1948-11-04T17:00:00-05:00">November 4, 1948—5 p.m.</date>
                    </dateline>
                </opener>
                <p>1548. Dept has refrained from representing to Navy desirability of following
                    course of action such as recommended by Clubb (Peiping’s tel to Nanking 609, Oct
                        29<note n="40" xml:id="d786fn40">Sent to the Department as telegram No. 410,
                            <ref target="#pg_869">p. 869</ref>.</note>) pending receipt statement
                    from Emb action taken locally.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lovett</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
