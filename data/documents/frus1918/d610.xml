<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-01-05T11:36:00-05:00" frus:doc-dateTime-min="1918-01-05T11:36:00-05:00" n="610" subtype="historical-document" type="document" xml:id="d610">
                        <note rend="inline" type="source">File No. 312.11/8525</note>
                        <head>
                            <hi rend="italic">The Chargé in Mexico</hi> (<persName type="from"><hi rend="italic">Summerlin</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Mexico</hi></placeName>, <date calendar="gregorian" when="1918-01-05T10:00:00-06:36">
                                    <hi rend="italic">January 5, 1918, 10 a.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>671. Department’s 660, December 22, 7 p.m.<note n="1" xml:id="d610fn1">
                                <ref target="frus1917#pg_1037">
                                    <hi rend="italic">Foreign Relations</hi>, 1917, p.
                                1037</ref>.</note> Foreign Office informs me that the military
                            commander in the region of Yaqui Valley had been ordered to afford
                            protection to the persons and property of American citizens commensurate
                            with the exigencies of the campaign.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Summerlin</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>