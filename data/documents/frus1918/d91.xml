<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-09-05T23:59:59-05:00" frus:doc-dateTime-min="1918-09-05T00:00:00-05:00" n="91" subtype="historical-document" type="document" xml:id="d91">
                            <note rend="inline" type="source">File No. 893.001H85/1</note>
                            <head>
                                <hi rend="italic">The Chinese Minister</hi> (<persName type="from"><hi rend="italic">Koo</hi></persName>) <hi rend="italic">to
                                    the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#left">No. 74</seg>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-09-05">
                                        <hi rend="italic">September 5, 1918</hi></date>.</dateline>
                            </opener>
                            <p>
                                <hi rend="smallcaps">Sir</hi>: I have the honor to inform you, in
                                pursuance of instructions from my Government, that His Excellency
                                Hsü Shih-ch’ang has been elected President of the Republic of China
                                for the next term in accordance with the laws of the Republic.</p>
                            <p>Accept [etc.]</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Vi Kyuin Wellington Koo</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>