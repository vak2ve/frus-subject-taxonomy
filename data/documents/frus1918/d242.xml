                <note rend="inline" type="source">File No. 818.00/335</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Port Limon</hi> (<persName type="to">
                        <hi rend="italic">McMillin</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-02-28T18:00:00-05:00">
                            <hi rend="italic">February 28, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your cables February 24, 2 p.m. and February 25, 4 p.m. Keep Department fully
                    advised by cable in regard to situation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
