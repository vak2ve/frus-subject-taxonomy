<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-01-06T23:00:00-05:00" frus:doc-dateTime-min="1918-01-06T23:00:00-05:00" n="114" subtype="historical-document" type="document" xml:id="d114">
                            <note rend="inline" type="source">File No. 893.51/1861</note>
                            <head>
                                <hi rend="italic">The Minister in China</hi> (<persName type="from"><hi rend="italic">Reinsch</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1918-01-07T12:00:00+08:00">
                                        <hi rend="italic">January 7, 1918, noon.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Your January 5, 2 p.m. British Government misinformed. Loan signed
                                yesterday.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Reinsch</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>