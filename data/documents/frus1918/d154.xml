<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-10-08T01:00:00-05:00" frus:doc-dateTime-min="1918-10-08T01:00:00-05:00" n="154" subtype="historical-document" type="document" xml:id="d154">
                            <note rend="inline" type="source">File No. 893.51/2027</note>
                            <head>
                                <hi rend="italic">The Chargé in China</hi> (<persName type="from"><hi rend="italic">MacMurray</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1918-10-08T14:00:00+08:00">
                                        <hi rend="italic">October 8, 1918, 2 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Your September 24, 3 p.m. Ministry of Finance declined to communicate
                                texts of Kirin forestry agreement and notes.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">MacMurray</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>