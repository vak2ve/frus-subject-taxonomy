                subtype="historical-document" type="document" xml:id="d320">
                <note rend="inline" type="source">File No. 837.51/247a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Cuba</hi> (<persName type="to">
                        <hi rend="italic">Gonzales</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-06-18T17:00:00-05:00">
                            <hi rend="italic">June 18, 1917, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Mail Department full translation of provisions of decree authorizing loan of
                    thirty million pesos and for increased revenues, reported in <hi rend="italic"
                        >La Lucha</hi> of May 27 last.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
