<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-03-21T11:29:00-05:00" frus:doc-dateTime-min="1918-03-21T11:29:00-05:00" n="318" subtype="historical-document" type="document" xml:id="d318">
                            <note rend="inline" type="source">File No. 837.00/1474</note>
                            <head>
                                <hi rend="italic">The Minister in Cuba</hi> (<persName type="from"><hi rend="italic">Gonzales</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Habana</hi></placeName>, <date calendar="gregorian" when="1918-03-21T11:00:00-05:29">
                                        <hi rend="italic">March 21, 1918, 11 a.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>My March 19, 4 p.m. José Miguel Gomez, former President of Cuba,
                                released under amnesty bill.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Gonzales</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>