<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-04-11T15:00:00-05:00" frus:doc-dateTime-min="1918-04-11T15:00:00-05:00" n="131" subtype="historical-document" type="document" xml:id="d131">
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Ambassador in Great Britain</hi> (<persName type="to"><hi rend="italic">Page</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-04-11T16:00:00-04:00">
                                        <hi rend="italic">April 11, 1918, 4 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>7231. Your 9411, April 9, 10 p.m. Action has been deferred pending
                                developments here and in China. It is doubtful whether group will be
                                organized in the near future.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Lansing</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>