<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-05-06T11:45:00-05:00" frus:doc-dateTime-min="1918-05-06T11:45:00-05:00" n="726" subtype="historical-document" type="document" xml:id="d726">
                            <note rend="inline" type="source">File No. 417.00/254</note>
                            <head>
                                <hi rend="italic">The Minister in Nicaragua</hi> (<persName type="from"><hi rend="italic">Jefferson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram—Extract]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Managua</hi></placeName>, <date calendar="gregorian" when="1918-05-06T11:00:00-05:45">
                                        <hi rend="italic">May 6, 1918, 11 a.m</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>… In accordance with instructions contained in Department’s April 3,
                                4 p.m., I have informed Nicaraguan Government and High Commission to
                                proceed with the payments.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Jefferson</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>