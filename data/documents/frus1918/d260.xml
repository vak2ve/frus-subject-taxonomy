<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-04-07T13:36:00-05:00" frus:doc-dateTime-min="1918-04-07T13:36:00-05:00" n="260" subtype="historical-document" type="document" xml:id="d260">
                            <note rend="inline" type="source">File No. 818.00/387</note>
                            <head>
                                <hi rend="italic">The Chargé in Costa Rica</hi> (<persName type="from"><hi rend="italic">Johnson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                </hi>
                            </head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">San José</hi></placeName>, <date calendar="gregorian" when="1918-04-07T13:00:00-05:36">
                                        <hi rend="italic">April 7, 1918, 1 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Volio expedition has arrived on Costa Rican soil near Panaman
                                border.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Johnson</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>