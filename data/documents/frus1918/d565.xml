    <text>
        <body>
            <div frus:doc-dateTime-max="1918-01-05T13:36:00-05:00"
                frus:doc-dateTime-min="1918-01-05T13:36:00-05:00" n="565"
                subtype="historical-document" type="document" xml:id="d565">
                <note rend="inline" type="source">File No. 612.119/697</note>
                <head>
                    <hi rend="italic">The Chargé in Mexico</hi> (<persName type="from">
                        <hi rend="italic">Summerlin</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1918-01-05T12:00:00-06:36">
                            <hi rend="italic">January 5, 1918, noon.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>673. The statement contained in your telegram No. 676 was given to the press late
                    yesterday afternoon and was printed in all of today’s papers except the <hi
                        rend="italic">Universal.</hi>
                </p>
                <p>Press comments on this announcement will be promptly telegraphed as they
                    appear.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Summerlin</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
