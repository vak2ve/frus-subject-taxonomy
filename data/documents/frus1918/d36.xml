    <text>
        <body>
            <div frus:doc-dateTime-max="1918-09-02T17:48:00-05:00"
                frus:doc-dateTime-min="1918-09-02T17:48:00-05:00" n="36"
                subtype="historical-document" type="document" xml:id="d36">
                <note rend="inline" type="source">File No. 715.1715/62</note>
                <head>
                    <hi rend="italic">The Chargé in Honduras</hi> (<persName type="from">
                        <hi rend="italic">Curtis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Tegucigalpa</hi>
                        </placeName>, <date calendar="gregorian" when="1918-09-02T17:00:00-05:48">
                            <hi rend="italic">September 2, 1918, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your August 28, 6 p.m. The Honduran representative will be Bonilla, Honduran
                    envoy extraordinary and minister plenipotentiary on special mission now in the
                    United States. Documents, etc., will probably be sent by next mail.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Curtis</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
