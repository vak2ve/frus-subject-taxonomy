                subtype="historical-document" type="document" xml:id="d429">
                <note rend="inline" type="source">File No. 422.11G93/959</note>
                <head>
                    <hi rend="italic">The Minister in Ecuador</hi> (<persName type="from">
                        <hi rend="italic">Hartman</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Quito</hi>
                        </placeName>, <date calendar="gregorian" when="1918-06-23T11:00:00-05:14">
                            <hi rend="italic">June 23, 1918, 11 a.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Department’s June 19, 2 p.m. Matter unofficially delivered yesterday. No
                    answer.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hartman</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
