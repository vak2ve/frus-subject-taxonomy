                subtype="historical-document" type="document" xml:id="d489">
                <note rend="inline" type="source">File No. 882.51/817A</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Liberia</hi> (<persName type="to">
                        <hi rend="italic">Bundy</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-08-12T18:00:00-04:00">
                            <hi rend="italic">August 12, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Department still endeavoring to arrange financial assistance for Liberia.</p>
                <p>Cable what, if any, aid Liberia has lately received from Bank British West
                    Africa.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
