                subtype="historical-document" type="document" xml:id="d172">
                <note rend="inline" type="source">File 893.51/1923m</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Japan</hi> (<persName type="to">
                        <hi rend="italic">Morris</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-07-23T17:00:00-04:00">
                            <hi rend="italic">July 23, 1918, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Please communicate to the Foreign Office the substance of the Department’s
                    telegram of July 11, 4 p.m., and say that the American Government would be glad
                    to know that the Imperial Japanese Government agrees in principle to
                    cooperate.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Polk</hi>
                    </signed>
                </closer>
            </div>
        </body>
