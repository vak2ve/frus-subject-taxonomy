                subtype="historical-document" type="document" xml:id="d179">
                <note rend="inline" type="source">File No. 893.51/1945b</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in China</hi> (<persName type="to">
                        <hi rend="italic">MacMurray</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-07-31T17:00:00-04:00">
                            <hi rend="italic">July 31, 1918, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Chinese Minister here some days ago promised to inquire of his Government the
                    amount of loan desired, for what purposes, and upon what security. No reply thus
                    far received. Please obtain the information which is needed by the banking group
                    here prepared to lend.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Polk</hi>
                    </signed>
                </closer>
            </div>
        </body>
