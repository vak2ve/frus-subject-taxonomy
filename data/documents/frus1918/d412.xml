    <text>
        <body>
            <div frus:doc-dateTime-max="1918-06-19T23:59:59-05:00"
                frus:doc-dateTime-min="1918-06-19T00:00:00-05:00" n="412"
                subtype="historical-document" type="document" xml:id="d412">
                <note rend="inline" type="source">File No. 704.9339/5</note>
                <head>
                    <hi rend="italic">The Minister in the Dominican Republic</hi> (<persName
                        type="from">
                        <hi rend="italic">Russell</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">No. 354</seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santo Domingo</hi>
                        </placeName>, <date calendar="gregorian" when="1918-06-19">
                            <hi rend="italic">June 19, 1918</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to my telegram of May 30, 8 a.m., and
                    to the Department’s reply thereto of June 4, 6 p.m., I have the honor to report
                    that I requested and obtained from the Military Government permission for the
                    diplomatic and consular representatives of the United States in this Republic to
                    take charge of Chinese interests and issue passports to Chinese citizens.</p>
                <p>I have [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William W. Russell</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
