                <note rend="inline" type="source">File No. 711.0021/133</note>
                <head>
                    <hi rend="italic">The Ambassador in Spain</hi> (<persName type="from">
                        <hi rend="italic">Willard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Madrid</hi>
                        </placeName>, <date calendar="gregorian" when="1918-12-30">
                            <hi rend="italic">December 30, 1918</hi>
                        </date>.</dateline>
                </opener>
                <p>2268. Department’s 1930. Date inserted was May 8, 1919.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Willard</hi>
                    </signed>
                </closer>
