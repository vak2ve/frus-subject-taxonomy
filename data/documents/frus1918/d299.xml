<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-11-19T12:00:00-05:00" frus:doc-dateTime-min="1918-11-19T12:00:00-05:00" n="299" subtype="historical-document" type="document" xml:id="d299">
                            <note rend="inline" type="source">File No. 711.18/7</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in Costa Rica</hi> (<persName type="to"><hi rend="italic">Johnson</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-11-19T12:00:00-05:00">
                                        <hi rend="italic">November 19, 1918, noon.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Cable Department exact text of your “brief remarks to crowd.”</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Lansing</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>