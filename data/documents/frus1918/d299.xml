                <note rend="inline" type="source">File No. 711.18/7</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in Costa Rica</hi> (<persName type="to">
                        <hi rend="italic">Johnson</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-19T12:00:00-05:00">
                            <hi rend="italic">November 19, 1918, noon.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Cable Department exact text of your “brief remarks to crowd.”</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
