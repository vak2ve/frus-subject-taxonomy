<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-12-27T17:00:00-05:00" frus:doc-dateTime-min="1918-12-27T17:00:00-05:00" n="687" subtype="historical-document" type="document" xml:id="d687">
                            <note rend="inline" type="source">File No. 812.032/43</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Ambassador in Mexico</hi> (<persName type="to"><hi rend="italic">Fletcher</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-12-27T17:00:00-05:00">
                                        <hi rend="italic">December 27, 1918, 5 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>1752. Your 1860. Department approves of making urgent representations
                                in the sense you outline in a separate communication to be sent to
                                Foreign Office simultaneously with communication to be submitted in
                                compliance with Department’s instruction, 797.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Polk</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>