                subtype="historical-document" type="document" xml:id="d657">
                <note rend="inline" type="source">File No. 812.512/1963</note>
                <head>
                    <hi rend="italic">The Ambassador in Mexico</hi> (<persName type="from">
                        <hi rend="italic">Fletcher</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Mexico</hi>
                        </placeName>, <date calendar="gregorian" when="1918-05-17T12:00:00-06:36">
                            <hi rend="italic">May 17, 1918, noon.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1078. My 1070, May 14, 2 p.m. Minister for Foreign Affairs informs me that time
                    for filing manifests called for by Article 14 of the petroleum decree of
                    February 14 [19] last has been entered [extended?] until July 31 next and that
                    Cabinet has decided to give the representatives of petroleum interests an
                    opportunity to be heard, and I have so advised Garfield.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Fletcher</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
