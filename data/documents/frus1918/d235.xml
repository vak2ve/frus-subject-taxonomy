                subtype="historical-document" type="document" xml:id="d235">
                <note rend="inline" type="source">File No. 818.00/330</note>
                <head>
                    <hi rend="italic">The Chargé in Costa Rica</hi> (<persName type="from">
                        <hi rend="italic">Johnson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port Limon</hi>
                        </placeName>, <date
                            ana="#date_undated-inferred-from-document-content-and-sibling-dates"
                            calendar="gregorian" when="1918-02-24">
                            <hi rend="italic">undated</hi>
                        </date>. <lb/> [<hi rend="italic">Received February 24, 1918, 8.07
                        p.m.</hi>]</dateline>
                </opener>
                <p>Other factions movement have cut railway Limon; communication difficult; none by
                    cable. Movement growing.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Johnson</hi>
                    </signed>
                </closer>
            </div>
        </body>
