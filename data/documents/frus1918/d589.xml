<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-07-11T11:36:00-05:00" frus:doc-dateTime-min="1918-07-11T11:36:00-05:00" n="589" subtype="historical-document" type="document" xml:id="d589">
                        <note rend="inline" type="source">File No. 711.12/117</note>
                        <head>
                            <hi rend="italic">The Ambassador in Mexico</hi> (<persName type="from"><hi rend="italic">Fletcher</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Mexico</hi></placeName>, <date calendar="gregorian" when="1918-07-11T10:00:00-06:36">
                                    <hi rend="italic">July 11, 1918, 10 a.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>1263. My statement published to-day on the first page of <hi rend="italic">Excelsior, El Universal</hi>, and <hi rend="italic">El
                                Pueblo.</hi>
                        </p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Fletcher</hi>
                            </signed>
                        </closer>
                    </div>
