    <text>
        <body>
            <div frus:doc-dateTime-max="1918-03-19T16:29:00-05:00"
                frus:doc-dateTime-min="1918-03-19T16:29:00-05:00" n="317"
                subtype="historical-document" type="document" xml:id="d317">
                <note rend="inline" type="source">File No. 837.00/1471</note>
                <head>
                    <hi rend="italic">The Minister in Cuba</hi> (<persName type="from">
                        <hi rend="italic">Gonzales</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Habana</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-19T16:00:00-05:29">
                            <hi rend="italic">March 19, 1918, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Amnesty bill as slightly amended by the Senate passed House yesterday. President
                    signed to-day.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gonzales</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
