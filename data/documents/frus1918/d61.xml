<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-10-25T14:00:00-05:00" frus:doc-dateTime-min="1917-10-25T14:00:00-05:00" n="61" subtype="historical-document" type="document" xml:id="d61">
                        <note rend="inline" type="source">File No. 832.73/118</note>
                        <head>
                            <hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from"><hi rend="italic">Morgan</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#center">[Telegram]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Rio de Janeiro</hi></placeName>, <date calendar="gregorian" when="1917-10-25T16:00:00-03:00">
                                    <hi rend="italic">October 25, 1917, 4 p.m.</hi>
                                </date>
                            </dateline>
                        </opener>
                        <p>Executive decree has been signed giving Western Telegraph Co. permission
                            without monopoly to lay cables between Rio de Janeiro and Ascension
                            Island and between Para and Barbados.</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Morgan</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>