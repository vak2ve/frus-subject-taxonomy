<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-02-21T23:59:59-05:00" frus:doc-dateTime-min="1918-02-21T00:00:00-05:00" n="453" subtype="historical-document" type="document" xml:id="d453">
                        <note rend="inline" type="source">File No. 711.5112/63a</note>
                        <head>
                            <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to
                                the French Ambassador</hi> (<persName type="to"><hi rend="italic">Jusserand</hi></persName>)</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-02-21">
                                    <hi rend="italic">February 21, 1918</hi></date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">My Dear Mr. Ambassador</hi>: It having been finally
                            determined to extend the arbitration convention of February 10, 1908,
                            for a further period of five years instead of indefinitely, I beg to
                            enclose herewith a new draft<note n="2" xml:id="d453fn2">Draft not
                                printed.</note> in English of the proposed agreement and to request
                            that if you find it satisfactory you will kindly supply me with the
                            French equivalent.</p>
                        <p>I am [etc.]</p>
                        <closer>
                            <signed>
                                <hi rend="smallcaps">Robert Lansing</hi>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>