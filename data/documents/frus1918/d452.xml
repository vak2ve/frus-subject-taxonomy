    <text>
        <body>
            <div frus:doc-dateTime-max="1918-02-13T23:59:59-05:00"
                frus:doc-dateTime-min="1918-02-13T00:00:00-05:00" n="452"
                subtype="historical-document" type="document" xml:id="d452">
                <note rend="inline" type="source">File No. 711.5112/64a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        French Ambassador</hi> (<persName type="to">
                        <hi rend="italic">Jusserand</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-02-13">
                            <hi rend="italic">February 13, 1918</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Ambassador</hi>: I enclose herewith a
                        draft<note n="2" xml:id="d452fn2">Draft not printed.</note> of an agreement
                    extending indefinitely the arbitration convention of February 10, 1908, between
                    the United States and France.</p>
                <p>If you find the draft acceptable and will kindly furnish me with the French
                    equivalent of the English text, I shall be glad to have the agreement at once
                    prepared for signature and to fix the time for its signature.</p>
                <p>I am [etc.]</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Robert Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
