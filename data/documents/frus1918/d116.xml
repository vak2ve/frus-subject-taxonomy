    <text>
        <body>
            <div frus:doc-dateTime-max="1918-01-09T15:00:00-05:00"
                frus:doc-dateTime-min="1918-01-09T15:00:00-05:00" n="116"
                subtype="historical-document" type="document" xml:id="d116">
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName type="to">
                        <hi rend="italic">Sharp</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-01-09T15:00:00-05:00">
                            <hi rend="italic">January 9, 1918, 3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3050. Your 2930, December 21, 10 p.m.<note n="1" xml:id="d116fn1">
                        <ref target="frus1917#pg_158">
                            <hi rend="italic">Foreign Relations</hi>, 1917, p. 158</ref>.</note>
                    Department informed by Legation at Peking on January 7 that Japanese signed loan
                    agreement January 6.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
