<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-01-05T18:00:00-05:00" frus:doc-dateTime-min="1918-01-05T18:00:00-05:00" n="222" subtype="historical-document" type="document" xml:id="d222">
                            <note rend="inline" type="source">File No. 818.00/289</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Minister in Panama</hi> (<persName type="to"><hi rend="italic">Price</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-01-05T18:00:00-05:00">
                                        <hi rend="italic">January 5, 1918, 6 p.m.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Your January 3, 3 p.m. Considered advisable not to permit these men
                                to proceed to Nicaragua.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Lansing</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>