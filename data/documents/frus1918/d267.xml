<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-04-26T11:00:00-05:00" frus:doc-dateTime-min="1918-04-26T11:00:00-05:00" n="267" subtype="historical-document" type="document" xml:id="d267">
                            <note rend="inline" type="source">File No. 811.111/3588</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Secretary of State</gloss>
                                    to the Chargé in Costa Rica</hi> (<persName type="to"><hi rend="italic">Johnson</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-04-26T12:00:00-04:00">
                                        <hi rend="italic">April 26, 1918, noon.</hi>
                                    </date>
                                </dateline>
                            </opener>
                            <p>Your March 15, 10 a.m. and April 19, 1 a.m. The United States
                                Government has no objection to Joaquin Tinoco’s going to France via
                                the United States.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Lansing</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>