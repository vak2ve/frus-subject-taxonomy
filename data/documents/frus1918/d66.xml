                subtype="historical-document" type="document" xml:id="d66">
                <note rend="inline" type="source">File No. 832.73/132a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Brazil</hi> (<persName type="to">
                        <hi rend="italic">Morgan</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-01-14T19:00:00-05:00">
                            <hi rend="italic">January 14, 1918, 7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Please inform Brazilian Government O’Shaughnessy in own name authorized by
                    Western Union Telegraph Co. negotiate cable concession.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
