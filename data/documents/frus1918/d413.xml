    <text>
        <body>
            <div frus:doc-dateTime-max="1918-06-25T15:00:00-05:00"
                frus:doc-dateTime-min="1918-06-25T15:00:00-05:00" n="413"
                subtype="historical-document" type="document" xml:id="d413">
                <note rend="inline" type="source">File No. 704.9339/4</note>
                <head>
                    <hi rend="italic">The Minister in Haiti</hi> (<persName type="from">
                        <hi rend="italic">Blanchard</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Port au Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1918-06-25T15:00:00-05:00">
                            <hi rend="italic">June 25, 1918, 3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Department’s June 4, 6 p.m., and June 13, 4 p.m.<note n="2" xml:id="d413fn2">See
                        note 1 on the preceding page.</note> Desired permission granted. I am
                    instructing consuls.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Blanchard</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
