                subtype="historical-document" type="document" xml:id="d506">
                <note rend="inline" type="source">File No. 812.00/21679</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Mexico</hi> (<persName type="to">
                        <hi rend="italic">Summerlin</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-01-26T16:00:00-05:00">
                            <hi rend="italic">January 26, 1918, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>726. You may announce publicly that entire story covered in despatch mentioned in
                    your 720 is sheer fabrication, and on its face propaganda to disturb existing
                    relations between two friendly Governments.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Polk</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
