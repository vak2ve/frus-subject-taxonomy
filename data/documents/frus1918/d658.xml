                subtype="historical-document" type="document" xml:id="d658">
                <note rend="inline" type="source">File No. 812.512/1957</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Mexico</hi> (<persName type="to">
                        <hi rend="italic">Fletcher</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-05-18T20:00:00-04:00">
                            <hi rend="italic">May 18, 1918, 8 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1085. Your 1070, May 14, 2 p.m. Department is pleased to note deterrent effect of
                    its protest and trusts you will be able to impress upon President Carranza the
                    necessity and advisability of radically modifying decree.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
