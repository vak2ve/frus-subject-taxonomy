    <text>
        <body>
            <div frus:doc-dateTime-max="1918-01-09T23:00:00-05:00"
                frus:doc-dateTime-min="1918-01-09T23:00:00-05:00" n="118"
                subtype="historical-document" type="document" xml:id="d118">
                <note rend="inline" type="source">File No. 893.51/1862</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName type="from">
                        <hi rend="italic">Reinsch</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1918-01-10T12:00:00+08:00">
                            <hi rend="italic">January 10, 1918, noon.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your January 8, 6 p.m. Amount of advance ten million yen.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Reinsch</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
