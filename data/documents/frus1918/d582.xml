                subtype="historical-document" type="document" xml:id="d582">
                <note rend="inline" type="source">File No. 612.119/1151</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Mexico</hi> (<persName type="to">
                        <hi rend="italic">Fletcher</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-28T19:00:00-05:00">
                            <hi rend="italic">March 28, 1918, 7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>926. Department approves your proposed reply as outlined in your 909, March 27, 4
                    p.m. Of course you will have in mind subdivision (<hi rend="italic">c</hi>) of
                    paragraph 2 of Department’s 883, March 15, 8 p.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lansing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
