    <text>
        <body>
            <div frus:doc-dateTime-max="1949-09-27T23:59:59-05:00"
                frus:doc-dateTime-min="1949-09-27T00:00:00-05:00" n="170"
                subtype="historical-document" type="document" xml:id="d170">
                <note rend="inline" type="source">IO Files: US/A/1778</note>
                <head>
                    <hi rend="italic">United States Delegation Working Paper</hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">confidential</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">New York</hi>
                        </placeName>,] <date calendar="gregorian" when="1949-09-27">September 27,
                            1949</date>.</dateline>
                </opener>
                <p rend="center">
                    <hi rend="smallcaps">Status of Council Slates</hi>
                </p>
                <p>1. <hi rend="italic">Security Council</hi>
                </p>
                <table cols="2" rows="4">
                    <row>
                        <cell>
                            <hi rend="italic">Retiring Members</hi>
                        </cell>
                        <cell>
                            <hi rend="italic">Recommended Slate</hi>
                        </cell>
                    </row>
                    <row>
                        <cell>Canada</cell>
                        <cell>India</cell>
                    </row>
                    <row>
                        <cell>Argentina</cell>
                        <cell>Ecuador</cell>
                    </row>
                    <row>
                        <cell>Ukrainian SSR</cell>
                        <cell>Yugoslavia</cell>
                    </row>
                </table>
                <p>2. <hi rend="italic">Economic and Social Council</hi>
                </p>
                <table cols="2" rows="7">
                    <row>
                        <cell>
                            <hi rend="italic">Retiring Members</hi>
                        </cell>
                        <cell/>
                    </row>
                    <row>
                        <cell>Byelorussian SSR</cell>
                        <cell>undecided (no announced Soviet candidate; preference for a constituent
                            republic)</cell>
                    </row>
                    <row>
                        <cell>Lebanon</cell>
                        <cell>Pakistan</cell>
                    </row>
                    <row>
                        <cell>New Zealand</cell>
                        <cell>Canada</cell>
                    </row>
                    <row>
                        <cell>Turkey</cell>
                        <cell>Iran</cell>
                    </row>
                    <row>
                        <cell>United States</cell>
                        <cell>United States</cell>
                    </row>
                    <row>
                        <cell>Venezuela</cell>
                        <cell>Mexico (if it is the preferred Latin American candidate)</cell>
                    </row>
                </table>
                <p>3. <hi rend="italic">Trusteeship Council</hi>
                </p>
                <table cols="2" rows="4">
                    <row>
                        <cell>
                            <hi rend="italic">Retiring Members</hi>
                        </cell>
                        <cell/>
                    </row>
                    <row>
                        <cell>Iraq</cell>
                        <cell>Lebanon or Greece (Lebanon, Syria and Iraq all appear to be
                            candidates)</cell>
                    </row>
                    <row>
                        <cell>Mexico</cell>
                        <cell>Dominican Republic</cell>
                    </row>
                    <row>
                        <cell>Costa Rica (resigned; election to fill unexpired one-year term)</cell>
                        <cell>Mexico or Argentina</cell>
                    </row>
                </table>
            </div>
        </body>
    </text>
