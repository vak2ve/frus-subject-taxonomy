<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1949-10-06T17:00:00-05:00" frus:doc-dateTime-min="1949-10-06T17:00:00-05:00" n="52" subtype="historical-document" type="document" xml:id="d52">
                            <note rend="inline" type="source">501.BB/10–649: Telegram</note>
                            <head>
                                <hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the United States Representative at the
                                    United Nations</hi> (<persName type="to"><hi rend="italic">Austin</hi></persName>)</head>
                            <opener>
                                <seg rendition="#left">
                                    <hi rend="smallcaps">secret</hi>
                                </seg>
                                <dateline rendition="#right">
                                    <placeName>
                                        <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1949-10-06T17:00:00-05:00">October 6, 1949—5 p. m.</date>
                                </dateline>
                            </opener>
                            <p>
                                <gloss target="#t_GaDel1">Gadel</gloss> 33. Dept approves draft
                                resolution contained <gloss target="#t_urtel1">urtel</gloss> Oct
                                    6<note n="1" xml:id="d52fn1">
                                    <gloss target="#t_DelGA1">Delga</gloss> 62, <hi rend="italic">supra</hi>.</note> as basis for consultations with other
                                Dels with exception of para relating to repudiation of treaties
                                which Dept proposes be deleted. Dept desires that resolution have as
                                broad and representative sponsorship as possible so that it can be
                                adopted by overwhelming vote.</p>
                            <closer>
                                <signed>
                                    <hi rend="smallcaps">Webb</hi>
                                </signed>
                            </closer>
                        </div>
                        </body></text></TEI>