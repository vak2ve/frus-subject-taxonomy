                                <hi rend="italic">JCS</hi>
                            </head>
                            <item>
                                <gloss target="#t_LTG_1">LTG</gloss> William Y. Smith*</item>
                            <item>
                                <gloss target="#t_LTC_1">LTC</gloss> Kenneth McKim</item>
                        </list>
                    </item>
                    <item>
                        <list>
                            <head>
                                <hi rend="italic">
                                    <gloss target="#t_DCI_1">DCI</gloss>
                                </hi>
                            </head>
                            <item>[<hi rend="italic">3 names not declassified</hi>]</item>
                        </list>
                        <list>
