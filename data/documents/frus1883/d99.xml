                subtype="historical-document" type="document" xml:id="d99">
                <head>No. 99.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Davis</persName> to Mr. <persName
                            type="to">Scruggs</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1883-01-22">
                            <hi rend="italic">January</hi> 22, 1883</date>.</dateline>
                    <seg rendition="#left">No. 40.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I transmit herewith for your information, and in
                    order that you may be prepared for any conference with your British colleague
                    upon the subject, copy of a note from the British minister at this capital, of
                    the 15th instant<note n="*" xml:id="d99fn1">See correspondence with British
                        Minister at Washington.</note> concerning the custody of ships’ papers when
                    in the ports of Colombia.</p>
                <p>I am, &amp;c.,</p>
                <closer>
                    <signed>JOHN DAVIS,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
