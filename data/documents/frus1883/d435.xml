    <text>
        <body>
            <div frus:doc-dateTime-max="1883-06-07T23:59:59-05:00" frus:doc-dateTime-min="1883-06-07T00:00:00-05:00" n="435" subtype="historical-document" type="document" xml:id="d435">
                <head>No. 434.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Frelinghuysen</persName> to Mr. <persName type="to">Cayetano
                                    Romero</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1883-06-07">
                            <hi rend="italic">June</hi> 7,
                                1883</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your note of the 23d ultimo, in relation to the duration of
                            the agreement between the United States and Mexico, providing for the
                            reciprocal crossing of the frontier by troops in pursuit of hostile
                            Indians.</p>
                <p>The understanding of the Department is that the privilege accorded by the
                            agreement of July 29, 1882, ceases after the 18th of August next,
                            pursuant to the subsequent agreement of September 21, 1882, unless the
                            same shall be prolonged by the two Governments.</p>
                <p>Accept, &amp;c.,</p>
                <closer>
                    <signed>FRED’K T. FRELINGHUYSEN.</signed>
                </closer>
            </div>
        </body>
