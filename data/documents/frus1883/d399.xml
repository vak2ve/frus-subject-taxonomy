    <text>
        <body>
            <div frus:doc-dateTime-max="1883-05-25T23:59:59-05:00"
                frus:doc-dateTime-min="1883-05-25T00:00:00-05:00" n="399"
                subtype="historical-document" type="document" xml:id="d399">
                <head>No. 398.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Davis</persName> to Mr. <persName
                            type="to">Morgan</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1883-05-25">
                            <hi rend="italic">May</hi> 25, 1883</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Eleven and twelve received. You may apply for
                        “<hi rend="italic">amparo</hi>,” as suggested, and if necessary engage
                    competent counsel, on reasonable terms, to defend captain and vessel in
                    appellate proceedings.</p>
                <closer>
                    <signed>DAVIS,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
