                subtype="historical-document" type="document" xml:id="d131">
                <head>No. 131.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Davis</persName> to Mr. <persName
                            type="to">Morton</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1883-05-25">
                            <hi rend="italic">May</hi> 25, 1883</date>.</dateline>
                </opener>
                <p>Express to family of Laboulaye sincere condolence and sympathy with them in their
                    bereavement.</p>
                <closer>
                    <signed>DAVIS,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
