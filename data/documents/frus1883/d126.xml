    <text>
        <body>
            <div frus:doc-dateTime-max="1883-04-04T23:59:59-05:00" frus:doc-dateTime-min="1883-04-04T00:00:00-05:00" n="126" subtype="historical-document" type="document" xml:id="d126">
                <head>No. 126.<lb/>
                    <hi rend="italic">Mr. <persName type="from">Frelinghuysen</persName> to Mr. <persName type="to">Morton</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Extract.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1883-04-04">
                            <hi rend="italic">April</hi> 4,
                            1883</date>.</dateline>
                    <seg rendition="#left">No. 247.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I inclose herewith for your information a copy
                        of an instruction concerning the foreign debt of Venezuela, which has been
                        addressed, <hi rend="italic">mutatis mutandis</hi>, to our legations at
                        London, the Hague, Copenhagen, Madrid, and Berlin.<note n="*" xml:id="d126fn1">See correspondence with the United States minister at
                            Berlin, <hi rend="italic">post</hi>.</note>
                </p>
                <p rend="center">* * * * * * *</p>
                <p>I am, &amp;c.,</p>
                <closer>
                    <signed>FRED’K T. FRELINGHUYSEN.</signed>
                </closer>
            </div>
        </body>
    </text>
