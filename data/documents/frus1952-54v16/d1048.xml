                        <note rend="inline" type="source">396.1 GE/7–2254: Telegram</note>
                        <head><hi rend="italic">The Consul at Geneva</hi> (<persName corresp="#p_GFC1" type="from"><hi rend="italic">Gowen</hi></persName>) <hi rend="italic">to the <gloss type="to">Department of State</gloss></hi></head>
                        <opener>
                            <seg rendition="#left"><hi rend="smallcaps">priority</hi></seg>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Geneva</hi></placeName>, <date calendar="gregorian" when="1954-07-22">July 22, 1954</date>.</dateline>
                        </opener>
                        <p>129. <gloss target="#t_mytel1">Mytel</gloss> 127.<note n="1" xml:id="d1048fn1">Dated July 22, not printed.</note> Under Secretary
                            and party left for London 1530 hours Geneva time.</p>
                        <closer><signed><persName corresp="#p_GFC1"><hi rend="smallcaps">Gowen</hi></persName></signed></closer>
