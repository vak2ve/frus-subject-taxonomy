    <text>
        <body>
            <div frus:doc-dateTime-max="1866-11-05T23:59:59-05:00"
                frus:doc-dateTime-min="1866-11-05T00:00:00-05:00" n="9"
                subtype="historical-document" type="document" xml:id="d9">
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <head>
                    <persName type="from">Mr. Campbell</persName> to <persName type="to">the
                        President</persName>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">United States Military Telegraph, War Department.
                                Hamilton, Ohio,</hi>
                        </placeName>
                        <date calendar="gregorian" when="1866-11-05">
                            <hi rend="italic">November</hi> 5, 1866.</date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="italic">To the President of the United States and Secretary of
                        State:</hi>
                </p>
                <p>I shall start for New York with General Sherman, unless directed to go by
                    Washington to-day.</p>
                <closer>
                    <signed>LEWIS D. CAMPBELL.</signed>
                </closer>
            </div>
        </body>
    </text>
