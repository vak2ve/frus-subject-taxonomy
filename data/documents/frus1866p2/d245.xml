    <text>
        <body>
            <div frus:doc-dateTime-max="1866-12-02T23:59:59-05:00" frus:doc-dateTime-min="1866-12-02T00:00:00-05:00" n="245" subtype="historical-document" type="document" xml:id="d245">
                <opener>
                    <dateline rendition="#center">[Telegram received at War Department,
                                    <placeName>Washington, D. C</placeName>, <date calendar="gregorian" when="1866-12-02">December 2, 1866</date>,
                                from cable, December 2, 1866—6.15 p.m.]</dateline>
                </opener>
                <head>
                    <persName type="from">Mr. Hale</persName> to <persName type="to">Mr.
                                Seward</persName>.</head>
                <opener>
                    <placeName>
                        <hi rend="smallcaps">Office U. S. Military
                                Telegraph.</hi>
                    </placeName>
                </opener>
                <p>To <hi rend="smallcaps">Seward,</hi>
                    <hi rend="italic">Washington :</hi>
                </p>
                <p>Have arrested John Surratt, one of President Lincoln’s assassins. No
                            doubt of identity.</p>
                <closer>
                    <signed>HALE, <hi rend="italic">Alexandria.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
