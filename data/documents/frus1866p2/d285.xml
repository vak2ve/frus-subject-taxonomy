<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1866-09-19T23:59:59-05:00" frus:doc-dateTime-min="1866-09-19T00:00:00-05:00" n="285" subtype="historical-document" type="document" xml:id="d285">
                        <head>[Per Atlantic cable.]</head>
                        <opener>
                            <dateline rendition="#right">
                                <placeName><hi rend="smallcaps">London,</hi></placeName>
                                <date calendar="gregorian" when="1866-09-19"><hi rend="italic">September</hi> 19, 1866</date>.</dateline></opener>
                        <p>Plate affair settled. Washburn notified to pass blockade.</p>
                        <closer>
                            <signed>JAMES WATSON WEBB.</signed></closer>
                        <postscript>
                            <p>Hon. <hi rend="smallcaps">William H. Seward,</hi>
                                <hi rend="italic">Secretary of State, Washington, D. C.</hi></p>
                        </postscript>
