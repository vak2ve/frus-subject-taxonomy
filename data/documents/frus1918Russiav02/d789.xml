    <text>
        <body>
            <div frus:doc-dateTime-max="1918-03-13T04:29:00-05:00"
                frus:doc-dateTime-min="1918-03-13T04:29:00-05:00" n="789"
                subtype="historical-document" type="document" xml:id="d789">
                <note rend="inline" type="source">File No. 861.00/1313</note>
                <head>
                    <hi rend="italic">The Consul General at Moscow</hi> (<persName corresp="#p_SM1"
                        type="from">
                        <hi rend="italic">Summers</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                    <note n="1" xml:id="d789fn1">Sent via the Consulate at Vladivostok.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Moscow</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-13T12:00:00+02:31">
                            <hi rend="italic">March 13, 1918, noon</hi>
                        </date>. <lb/> [<hi rend="italic">Received March 17, 1.45
                        p.m.</hi>]</dateline>
                </opener>
                <p>260. Odessa occupied Austro-German troops. No news consul who was instructed go
                    Rostov.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_SM1">
                            <hi rend="smallcaps">Summers</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
