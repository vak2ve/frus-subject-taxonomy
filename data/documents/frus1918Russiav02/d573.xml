    <text>
        <body>
            <div frus:doc-dateTime-max="1918-03-09T15:00:00-05:00"
                frus:doc-dateTime-min="1918-03-09T15:00:00-05:00" n="573"
                subtype="historical-document" type="document" xml:id="d573">
                <note rend="inline" type="source">File No. 861.00/1401a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to">
                        <hi rend="italic">Francis</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-09T15:00:00-05:00">
                            <hi rend="italic">March 9, 1918, 3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>2107. Request Norwegian Consul, Petrograd, deliver following message for
                        <persName corresp="#p_RLCR1">Robins</persName>, head of American Red Cross
                    Commission: <quote rend="blockquote">
                        <p>Please telegraph full statement of conditions at Murmansk as reported by
                                <persName corresp="#p_WMA1">Wardwell</persName> when he arrives,
                            covering political situation, accumulation of supplies if any and
                            condition of railroad transportation.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
