    <text>
        <body>
            <div frus:doc-dateTime-max="1918-05-28T16:00:00-05:00"
                frus:doc-dateTime-min="1918-05-28T16:00:00-05:00" n="751"
                subtype="historical-document" type="document" xml:id="d751">
                <note rend="inline" type="source">File No. 861.00/1856</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Moscow</hi> (<persName corresp="#p_PDC1" type="to">
                        <hi rend="italic">Poole</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-05-28T17:00:00-04:00">
                            <hi rend="italic">May 28, 1918, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>52. Your 529, May 17, 3 p.m. Department will be pleased to learn plans for
                    defense of Trans-Caucasus furnished by <persName corresp="#p_SFW1"
                        >Smith</persName>.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
