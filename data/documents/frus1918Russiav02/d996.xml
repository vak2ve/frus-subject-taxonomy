<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-07-24T15:00:00-05:00" frus:doc-dateTime-min="1918-07-24T15:00:00-05:00" n="996" subtype="historical-document" type="document" xml:id="d996">
                            <note rend="inline" type="source">File No. 811.111/9784g</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Minister in Sweden</hi> (<persName corresp="#p_MIN1" type="to"><hi rend="italic">Morris</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-07-24T16:00:00-04:00"><hi rend="italic">July 24,
                                            1918, 4 p.m.</hi></date></dateline>
                            </opener>
                            <p>972. Your 2527.<note n="1" xml:id="d996fn1">Not printed.</note>
                                Disregard Department’s former instructions and refuse visa
                                    <persName>Kull</persName>.</p>
                            <closer>
                                <signed><persName corresp="#p_PFL1"><hi rend="smallcaps">Polk</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>