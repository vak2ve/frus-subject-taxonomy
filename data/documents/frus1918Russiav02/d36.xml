<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-01-10T23:59:59-05:00" frus:doc-dateTime-min="1918-01-10T00:00:00-05:00" n="36" subtype="historical-document" type="document" xml:id="d36">
                            <note rend="inline" type="source">File No. 861.00/931</note>
                            <head><hi rend="italic">The Consul at Harbin</hi> (<persName corresp="#p_MCK1" type="from"><hi rend="italic">Moser</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Harbin</hi></placeName>, <date calendar="gregorian" when="1918-01-10"><hi rend="italic">January 10,
                                        1918</hi></date>. <lb/> [<hi rend="italic">Received 3.23
                                        p.m.</hi>]</dateline>
                            </opener>
                            <p>Reliable telegram dated 9th states Irkutsk quiet under Bolshevik
                                control. Consuls active protecting foreigners and have refused
                                deliver to Bolsheviks high provisional officials who took refuge in
                                Chinese Consulate.</p>
                            <closer>
                                <signed><persName corresp="#p_MCK1"><hi rend="smallcaps">Moser</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>