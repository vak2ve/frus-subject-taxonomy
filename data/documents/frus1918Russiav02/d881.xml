<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-01-11T18:00:00-05:00" frus:doc-dateTime-min="1918-01-11T18:00:00-05:00" n="881" subtype="historical-document" type="document" xml:id="d881">
                            <note rend="inline" type="source">File No. 861.00/922</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-01-11T18:00:00-05:00"><hi rend="italic">January
                                            11, 1918, 6 p.m.</hi></date></dateline>
                            </opener>
                            <p>1984. Your 2208, January 8, 6 p.m. Department doubts advisability of
                                recognizing Finland at present.</p>
                            <closer>
                                <signed><persName corresp="#p_LR1"><hi rend="smallcaps">Lansing</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>