                subtype="historical-document" type="document" xml:id="d766">
                <note rend="inline" type="source">File No. 861.00/421</note>
                <head>
                    <hi rend="italic">The Ambassador in Russia</hi> (<persName corresp="#p_FDR1"
                        type="from">
                        <hi rend="italic">Francis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Extract]<note n="1" xml:id="d766fn1">Printed
                            in full in <ref target="frus1918Russiav01#pg_159">vol. <hi
                                    rend="smallcaps">i</hi>, p. 159</ref>.</note>
                    </seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Petrograd</hi>
                        </placeName>, <date calendar="gregorian" when="1917-07-16T20:00:00+03:31">
                            <hi rend="italic">July 16, 1917, 8 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received July 18, 9.05 a.m.</hi>]</dateline>
                </opener>
                <p>1519. … Cause [of the resignation of the Cadet Ministers] attributed is that
                    Minister of War, Minister for Foreign Affairs, and Minister of Posts and
                    Telegraphs who returned yesterday from Ukraine had granted that province
                    concessions with which Cadet Party unable to agree. …</p>
                <closer>
                    <signed>
                        <persName corresp="#p_FDR1">
                            <hi rend="smallcaps">Francis</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
