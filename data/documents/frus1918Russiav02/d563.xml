                subtype="historical-document" type="document" xml:id="d563">
                <note rend="inline" type="source">File No. 861.00/3430</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Chargé in Great Britain</hi> (<persName type="to">
                        <hi rend="italic">Laughlin</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-12-17T19:00:00-05:00">
                            <hi rend="italic">December 17, 1918, 7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3471. As this Government desires to keep the Government to which you are
                    accredited fully and frankly informed of all its actions in regard to Russia,
                    please read, without leaving copy, the Minister of Foreign Affairs the following
                    instruction sent December 16 to the American Ambassador at Tokyo. Repeat to
                    Paris and Rome for similar action and to Archangel for confidential information
                    and no action. Paris to inform American mission. [Here follows the instruction,
                        <hi rend="italic">ante</hi>, <ref target="#pg_462">p. 462</ref>.]</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
