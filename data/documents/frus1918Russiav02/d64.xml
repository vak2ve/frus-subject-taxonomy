<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-02-09T18:00:00-05:00" frus:doc-dateTime-min="1918-02-09T18:00:00-05:00" n="64" subtype="historical-document" type="document" xml:id="d64">
                            <note rend="inline" type="source">File No. 811.20293/15a</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Minister in China</hi> (<persName corresp="#p_RPS1" type="to"><hi rend="italic">Reinsch</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-02-09T18:00:00-05:00"><hi rend="italic">February
                                            9, 1918, 6 p.m.</hi></date></dateline>
                            </opener>
                            <p>There are conflicting reports received here as to conditions in
                                eastern Siberia. Please have …, if possible, visit various places
                                and report to you.</p>
                            <closer>
                                <signed><persName corresp="#p_LR1"><hi rend="smallcaps">Lansing</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>