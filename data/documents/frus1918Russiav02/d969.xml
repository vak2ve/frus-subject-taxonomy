<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-08-27T23:59:59-05:00" frus:doc-dateTime-min="1918-08-27T00:00:00-05:00" n="969" subtype="historical-document" type="document" xml:id="d969">
                            <note rend="inline" type="source">File No. 860d.00/267</note>
                            <head><hi rend="italic">The Chargé in Sweden</hi> (<persName corresp="#p_WS1" type="from"><hi rend="italic">Whitehouse</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener>
                                <seg rendition="#center">[Telegram—Extract]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Stockholm</hi></placeName>, <date calendar="gregorian" when="1918-08-27"><hi rend="italic">August 27,
                                        1918</hi></date>. <lb/> [<hi rend="italic">Received August
                                        28, 5.25 a.m.</hi>]</dateline>
                            </opener>
                            <p>2726. Swedish press reports … Finnish-Russian peace negotiations
                                broken off indefinitely. …</p>
                            <closer>
                                <signed><persName corresp="#p_WS1"><hi rend="smallcaps">Whitehouse</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>