    <text>
        <body>
            <div frus:doc-dateTime-max="1918-11-28T06:00:00-05:00"
                frus:doc-dateTime-min="1918-11-28T06:00:00-05:00" n="546"
                subtype="historical-document" type="document" xml:id="d546">
                <note rend="inline" type="source">File No. 861.00/3298</note>
                <head>
                    <hi rend="italic">The Ambassador in Italy</hi> (<persName corresp="#p_PTN1"
                        type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rome</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-28T12:00:00+01:00">
                            <hi rend="italic">November 28, 1918, 12 noon</hi>
                        </date>. <lb/> [<hi rend="italic">Received November 29, 7.17
                        a.m.</hi>]</dateline>
                </opener>
                <p>2422. Referring to the Department’s circular telegram of November 16, 6 p.m., and
                    my telegram 2389.<note n="1" xml:id="d546fn1">Not printed.</note> I have
                    received from the Minister of Foreign Affairs a note stating that Italian
                    Government agrees in principle with our point of view and is ready to support
                    [our representations], and has so telegraphed to Italian Ambassador at
                    Tokyo.</p>
                <p>Paris informed.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PTN1">
                            <hi rend="smallcaps">Nelson Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
