    <text>
        <body>
            <div frus:doc-dateTime-max="1918-03-25T23:00:00-05:00"
                frus:doc-dateTime-min="1918-03-25T23:00:00-05:00" n="127"
                subtype="historical-document" type="document" xml:id="d127">
                <note rend="inline" type="source">File No. 861.00/1367</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName corresp="#p_SW1"
                        type="from">
                        <hi rend="italic">Spencer</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-26T12:00:00+08:00">
                            <hi rend="italic">March 26, 1918, noon</hi>
                        </date>. <lb/> [<hi rend="italic">Received March 26, 7.43
                        a.m.</hi>]</dateline>
                </opener>
                <p>Following from Harbin just received: <quote rend="blockquote">
                        <p>
                            <persName corresp="#p_DLCWS1">Drysdale</persName> and
                                <persName>Morton</persName> telegraphed March 24 prisoners at Chita
                            and northward armed, committing misdeeds. Contrary to orders of German
                            and Austrian officers, very few are joining Red Guard.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <persName corresp="#p_SW1">
                            <hi rend="smallcaps">Spencer</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
