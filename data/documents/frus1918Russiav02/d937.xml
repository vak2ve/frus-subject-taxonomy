<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-05-09T23:59:59-05:00" frus:doc-dateTime-min="1918-05-09T00:00:00-05:00" n="937" subtype="historical-document" type="document" xml:id="d937">
                            <note rend="inline" type="source">File No. 860d.00/123</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the British Ambassador</hi> (<persName corresp="#p_RERDI1" type="to"><hi rend="italic">Reading</hi></persName>)</head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-05-09"><hi rend="italic">May 9,
                                    1918</hi></date>.</dateline>
                            </opener>
                            <p><hi rend="smallcaps">My Dear Mr. Ambassador</hi>: I have received
                                your letter of May 4, 1918, informing me of the action of your
                                Government in regard to the provisional recognition of the <hi rend="italic">de facto</hi> Finnish government, and shall be
                                very glad to know of the final decision reached and how far the
                                conditions laid down by your Government have been accepted and
                                fulfilled.</p>
                            <p>I am [etc.]</p>
                            <closer>
                                <signed><persName corresp="#p_LR1"><hi rend="smallcaps">Robert
                                            Lansing</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>