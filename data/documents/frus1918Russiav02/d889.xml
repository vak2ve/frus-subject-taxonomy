                subtype="historical-document" type="document" xml:id="d889">
                <note rend="inline" type="source">File No. 861.00/1008</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Helsingfors</hi> (<persName corresp="#p_HT2" type="to">
                        <hi rend="italic">Haynes</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-01-29T16:00:00-05:00">
                            <hi rend="italic">January 29, 1918, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Swedish press reports conditions Helsingfors dangerous. Department relies on your
                    judgment as to leaving your post but hopes situation may develop so you can
                    remain. Please acknowledge this.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
