    <text>
        <body>
            <div frus:doc-dateTime-max="1918-11-22T23:59:59-05:00"
                frus:doc-dateTime-min="1918-11-22T00:00:00-05:00" n="533"
                subtype="historical-document" type="document" xml:id="d533">
                <note rend="inline" type="source">File No. 861.00/3260</note>
                <head>
                    <hi rend="italic">The Consul General at Irkutsk</hi> (<persName
                        corresp="#p_HEL1" type="from">
                        <hi rend="italic">Harris</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                    <note n="2" xml:id="d533fn2">Sent via the Legation In China.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Omsk</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-22">
                            <hi rend="italic">November 22, 1918</hi>
                        </date>. <lb/> [<hi rend="italic">Received November 23, 7.28
                        a.m.</hi>]</dateline>
                </opener>
                <p>198. <persName corresp="#p_AND1">Avksentiev</persName> and other three Social
                    Revolutionary leaders now released from prison and being sent out of Siberia in
                    direction Irkutsk.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HEL1">
                            <hi rend="smallcaps">Harris</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
