    <text>
        <body>
            <div frus:doc-dateTime-max="1918-04-16T23:59:59-05:00"
                frus:doc-dateTime-min="1918-04-16T00:00:00-05:00" n="926"
                subtype="historical-document" type="document" xml:id="d926">
                <note rend="inline" type="source">File No. 860d.00/93</note>
                <head>
                    <hi rend="italic">The Minister in Sweden</hi> (<persName corresp="#p_MIN1"
                        type="from">
                        <hi rend="italic">Morris</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Stockholm</hi>
                        </placeName>, <date calendar="gregorian" when="1918-04-16">
                            <hi rend="italic">April 16, 1918</hi>
                        </date>. <lb/> [<hi rend="italic">Received 7.17 p.m.</hi>]</dateline>
                </opener>
                <p>1902. Swedish press reports Finnish press bureau wires <persName>Count von der
                        Goltz</persName> reports April 13 Helsingfors been stormed after three days’
                    desperate fighting. Several thousand prisoners and great quantity booty
                    captured, enemy offering desperate resistance. White prisoners were
                    liberated.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MIN1">
                            <hi rend="smallcaps">Morris</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
