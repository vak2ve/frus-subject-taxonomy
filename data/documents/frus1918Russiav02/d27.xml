                subtype="historical-document" type="document" xml:id="d27">
                <note rend="inline" type="source">File No. 861.00/888</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul at Vladivostok</hi> (<persName corresp="#p_CJK1" type="to">
                        <hi rend="italic">Caldwell</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-01-02T19:00:00-05:00">
                            <hi rend="italic">January 2, 1918, 7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your urgent telegram December 30 noon received yesterday. Department anxious to
                    keep close touch developments also all available information welfare Americans
                    Siberia. Transmit foregoing to Harbin. Embassy Petrograd already advised by
                    Department.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
