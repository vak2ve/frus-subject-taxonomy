    <text>
        <body>
            <div frus:doc-dateTime-max="1918-04-08T17:00:00-05:00"
                frus:doc-dateTime-min="1918-04-08T17:00:00-05:00" n="151"
                subtype="historical-document" type="document" xml:id="d151">
                <note rend="inline" type="source">File No. 861.00/1445</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to">
                        <hi rend="italic">Francis</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-04-08T18:00:00-04:00">
                            <hi rend="italic">April 8, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>53. Your 67, April 4, 4 p.m.<note n="1" xml:id="d151fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_96">p. 96</ref>.</note>
                    Referring Department’s 15, March 20, 7 p.m.<note n="2" xml:id="d151fn2">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_82">p. 82</ref>.</note>
                    Department desires full details <persName>Webster</persName>’s reports.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
