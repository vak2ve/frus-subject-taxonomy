    <text>
        <body>
            <div frus:doc-dateTime-max="1918-10-16T17:00:00-05:00"
                frus:doc-dateTime-min="1918-10-16T17:00:00-05:00" n="667"
                subtype="historical-document" type="document" xml:id="d667">
                <note rend="inline" type="source">File No. 861.00/2640</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to">
                        <hi rend="italic">Francis</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-10-16T18:00:00-04:00">
                            <hi rend="italic">October 16, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>308. Your 385, September 6, 6 p.m.<note n="1" xml:id="d667fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_519">p. 519</ref>.</note>
                    Agreement regarding Murmansk District Council signed tentatively by commanding
                    officer of the <hi rend="italic">Olympia</hi> and referred to this Department by
                    the Secretary of the Navy, has now been approved and Secretary of the Navy so
                    advised October 14.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
