<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-04-27T11:00:00-05:00" frus:doc-dateTime-min="1918-04-27T11:00:00-05:00" n="934" subtype="historical-document" type="document" xml:id="d934">
                            <note rend="inline" type="source">File No. 860d.00/112</note>
                            <head><hi rend="italic">The Minister in Sweden</hi> (<persName corresp="#p_MIN1" type="from"><hi rend="italic">Morris</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Stockholm</hi></placeName>, <date calendar="gregorian" when="1918-04-27T17:00:00+01:00"><hi rend="italic">April 27,
                                            1918, 5 p.m.</hi></date>
                                    <lb/> [<hi rend="italic">Received April 28, 3.34
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>1959. Your 733, April 25, 7 p.m. Have every reason to believe
                                statement therein quoted was made by <persName corresp="#p_MGCGE1">Mannerheim</persName> as it appeared in all Swedish papers.</p>
                            <closer>
                                <signed><persName corresp="#p_MIN1"><hi rend="smallcaps">Morris</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>