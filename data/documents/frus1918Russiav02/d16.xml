<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-12-18T17:00:00-05:00" frus:doc-dateTime-min="1917-12-18T17:00:00-05:00" n="16" subtype="historical-document" type="document" xml:id="d16">
                            <note rend="inline" type="source">File No. 861.00/822</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Minister in China</hi> (<persName corresp="#p_RPS1" type="to"><hi rend="italic">Reinsch</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-12-18T17:00:00-05:00"><hi rend="italic">December
                                            18, 1917, 5 p.m.</hi></date></dateline>
                            </opener>
                            <p>Your telegram December 15, 8 p.m. Ambassador and Consuls in Russia
                                advised that President desires all American representatives to
                                withhold direct communication with Bolshevik government.</p>
                            <closer>
                                <signed><persName corresp="#p_LR1"><hi rend="smallcaps">Lansing</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>