                subtype="historical-document" type="document" xml:id="d726">
                <note rend="inline" type="source">File No. 125.631</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Consul General at Moscow</hi> (<persName corresp="#p_SM1" type="to">
                        <hi rend="italic">Summers</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-01-05T13:00:00-05:00">
                            <hi rend="italic">January 5, 1918, 1 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your 140, December 31, 6 p.m. In case of necessity you may draw not exceeding
                    $5,000 for sending indigent Americans out of the country. If imperative to leave
                    Moscow you should go to some place other than Rostov or headquarters of any
                    sectional movement.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
