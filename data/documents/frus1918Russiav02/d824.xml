    <text>
        <body>
            <div frus:doc-dateTime-max="1918-12-16T23:59:59-05:00"
                frus:doc-dateTime-min="1918-12-16T00:00:00-05:00" n="824"
                subtype="historical-document" type="document" xml:id="d824">
                <note rend="inline" type="source">File No. 861.00/3448</note>
                <head>
                    <hi rend="italic">The Minister in Sweden</hi> (<persName corresp="#p_MIN1"
                        type="from">
                        <hi rend="italic">Morris</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Stockholm</hi>
                        </placeName>, <date calendar="gregorian" when="1918-12-16">
                            <hi rend="italic">December 16, 1918</hi>
                        </date>. <lb/> [<hi rend="italic">Received December 17, 6.40
                        a.m.</hi>]</dateline>
                </opener>
                <p>3347. … Reports from Berlin: Kiev besieged by troops of Ukrainian National League
                    which captured all Ukraine. Political situation very favorable to this league.
                    …</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MIN1">
                            <hi rend="smallcaps">Morris</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
