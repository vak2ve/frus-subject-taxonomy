    <text>
        <body>
            <div frus:doc-dateTime-max="1917-12-14T16:00:00-05:00"
                frus:doc-dateTime-min="1917-12-14T16:00:00-05:00" n="868"
                subtype="historical-document" type="document" xml:id="d868">
                <note rend="inline" type="source">File No. 861.00/835</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to">
                        <hi rend="italic">Francis</hi>
                    </persName>)<note n="2" xml:id="d868fn2">Similar telegram (No. 448) on the same
                        date to the Minister in Sweden.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-12-14T16:00:00-05:00">
                            <hi rend="italic">December 14, 1917, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1899. Referring Department telegram 1890, December 8,<note n="3" xml:id="d868fn3"
                        >See footnote 1, <hi rend="italic">ante</hi>, <ref target="#pg_733">p.
                            733</ref>.</note> have approved following telegram sent by <persName
                        corresp="#p_IKB1">Ignatius</persName>, Finnish Food Commissioner in United
                    States, to Lars Krogius at Haparanda: <quote rend="blockquote">
                        <p>State Department does not object to deputation coming here to state
                            Finland’s case but is not yet prepared to assume any position regarding
                            the recognition.</p>
                    </quote>
                </p>
                <p>Advise Consul, Helsingfors.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
