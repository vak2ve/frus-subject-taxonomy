<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-04-14T23:59:59-05:00" frus:doc-dateTime-min="1918-04-14T00:00:00-05:00" n="925" subtype="historical-document" type="document" xml:id="d925">
                            <note rend="inline" type="source">File No. 860d.00/90</note>
                            <head><hi rend="italic">The Vice Consul at Petrograd</hi> (<persName type="from"><hi rend="italic">Imbrie</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Petrograd</hi></placeName>, <date calendar="gregorian" when="1918-04-14"><hi rend="italic">April 14,
                                        1918</hi></date>. <lb/> [<hi rend="italic">Received 11.05
                                        a.m.</hi>]</dateline>
                            </opener>
                            <p>10. <persName corresp="#p_HT2">Haynes</persName>, Helsingfors,
                                requests Department informed he can no longer communicate. Expects
                                occupation of city but has been assured immunity.</p>
                            <closer>
                                <signed><persName><hi rend="smallcaps">Imbrie</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>