<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-07-30T17:00:00-05:00" frus:doc-dateTime-min="1918-07-30T17:00:00-05:00" n="374" subtype="historical-document" type="document" xml:id="d374">
                            <note rend="inline" type="source">File No. 861.00/2357</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Chargé in China</hi> (<persName corresp="#p_MJVA1" type="to"><hi rend="italic">MacMurray</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-07-30T18:00:00-04:00"><hi rend="italic">July 30,
                                            1918, 6 p.m.</hi></date></dateline>
                            </opener>
                            <p>Your cipher telegram of July 27, 5 p.m. Your understanding of your
                                instructions is correct. Department does not desire to modify its
                                attitude.</p>
                            <closer>
                                <signed><persName corresp="#p_PFL1"><hi rend="smallcaps">Polk</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>