    <text>
        <body>
            <div frus:doc-dateTime-max="1918-03-29T16:00:00-05:00"
                frus:doc-dateTime-min="1918-03-29T16:00:00-05:00" n="129"
                subtype="historical-document" type="document" xml:id="d129">
                <note rend="inline" type="source">File No. 861.00/1358</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Japan</hi> (<persName corresp="#p_MRS1" type="to">
                        <hi rend="italic">Morris</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-29T16:00:00-05:00">
                            <hi rend="italic">March 29, 1918, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your March 23, 3 p.m.<note n="3" xml:id="d129fn3">Not printed.</note> Get in
                    touch with <persName corresp="#p_MTG1">Masaryk</persName> and advise Department
                    fully his views of situation in Russia and possibility of organizing within
                    Russia any effective resistance to Central powers. Also forward any other
                    messages he wishes to transmit. <persName corresp="#p_MTG1">Masaryk</persName>
                    well known to Department as Bohemian patriot.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
