                subtype="historical-document" type="document" xml:id="d237">
                <note rend="inline" type="source">File No. 861.00/1898</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName corresp="#p_SWG1" type="to">
                        <hi rend="italic">Sharp</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-05-31T16:00:00-04:00">
                            <hi rend="italic">May 31, 1918, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>4289. Your 4033, May 29, 11 p.m. There seems to be no justification for a change
                    in the policy of this Government. You will please keep us fully and frequently
                    advised of the conference and its developments.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
