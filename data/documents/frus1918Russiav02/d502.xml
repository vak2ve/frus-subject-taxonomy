                subtype="historical-document" type="document" xml:id="d502">
                <note rend="inline" type="source">File No. 861.00/3017</note>
                <head>
                    <hi rend="italic">The Consul Detailed for Special Duty in Russia and
                        Siberia</hi> (<persName type="from">
                        <hi rend="italic">Jameson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                    <note n="1" xml:id="d502fn1">Sent via the Consulate at Vladivostok (No.
                        212).</note>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Chelyabinsk</hi>
                        </placeName>, <date calendar="gregorian" when="1918-10-19">
                            <hi rend="italic">October 19, 1918</hi>
                        </date>. <lb/> [<hi rend="italic">Received October 22, 3.40
                        a.m.</hi>]</dateline>
                </opener>
                <p>Now that peace negotiations are pending it is more vital than ever that our
                    Government act immediately in accordance with my suggestion.</p>
                <closer>[<signed>
                        <persName>
                            <hi rend="smallcaps">Jameson</hi>
                        </persName>
                    </signed>]</closer>
            </div>
        </body>
