                subtype="historical-document" type="document" xml:id="d918">
                <note rend="inline" type="source">File No. 760d.62/l</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Sweden</hi> (<persName corresp="#p_MIN1" type="to">
                        <hi rend="italic">Morris</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-12-21T15:00:00-05:00">
                            <hi rend="italic">December 21, 1918, 3 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>1392. Your despatch 1492, dated November 18, 1918. Was secret agreement ever
                    accepted by Finland? Also, how long was it to remain in force?</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
