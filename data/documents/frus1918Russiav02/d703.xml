    <text>
        <body>
            <div frus:doc-dateTime-max="1917-11-28T16:00:00-05:00"
                frus:doc-dateTime-min="1917-11-28T16:00:00-05:00" n="703"
                subtype="historical-document" type="document" xml:id="d703">
                <note rend="inline" type="source">File No. 861.00/719</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in France</hi> (<persName corresp="#p_SWG1" type="to">
                        <hi rend="italic">Sharp</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1917-11-28T16:00:00-05:00">
                            <hi rend="italic">November 28, 1917, 4 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>2870. For Colonel <persName corresp="#p_HEM1">House</persName>:</p>
                <p>Department would be glad to have a report from you on the general attitude of
                    your colleagues in the matter of the recognition of the <hi rend="italic">de
                        facto</hi> government of the Trans-Caucasus.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
