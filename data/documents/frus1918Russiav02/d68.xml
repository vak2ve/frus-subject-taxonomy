<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-02-15T03:00:00-05:00" frus:doc-dateTime-min="1918-02-15T03:00:00-05:00" n="68" subtype="historical-document" type="document" xml:id="d68">
                            <note rend="inline" type="source">File No. 861.00/1093</note>
                            <head><hi rend="italic">The Minister in China</hi> (<persName corresp="#p_RPS1" type="from"><hi rend="italic">Reinsch</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1918-02-15T16:00:00+08:00"><hi rend="italic">February
                                            15, 1918, 4 p.m.</hi></date>
                                    <lb/> [<hi rend="italic">Received February 15, 11.07
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>The British are giving small amount financial support <persName corresp="#p_SGG1">Semenov</persName>.</p>
                            <closer>
                                <signed><persName corresp="#p_RPS1"><hi rend="smallcaps">Reinsch</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>