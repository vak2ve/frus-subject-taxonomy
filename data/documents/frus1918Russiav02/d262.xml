<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-06-10T13:00:00-05:00" frus:doc-dateTime-min="1918-06-10T13:00:00-05:00" n="262" subtype="historical-document" type="document" xml:id="d262">
                            <note rend="inline" type="source">File No. 861.00/1965</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-06-10T14:00:00-04:00"><hi rend="italic">June 10,
                                            1918, 2 p.m.</hi></date></dateline>
                            </opener>
                            <p>170. Your 241, June 3, 7 p.m.<note n="1" xml:id="d262fn1"><hi rend="italic">Ante</hi>, <ref target="#pg_188">p.
                                    188</ref>.</note> Department believes instructions to Consul
                                Moscow to communicate with Soviet should, so far as practicable, be
                                limited to matters affecting American interests.</p>
                            <closer>
                                <signed><persName corresp="#p_PFL1"><hi rend="smallcaps">Polk</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>