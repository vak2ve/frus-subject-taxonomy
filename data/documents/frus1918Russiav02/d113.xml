    <text>
        <body>
            <div frus:doc-dateTime-max="1918-03-15T07:34:00-05:00"
                frus:doc-dateTime-min="1918-03-15T07:34:00-05:00" n="113"
                subtype="historical-document" type="document" xml:id="d113">
                <note rend="inline" type="source">File No. 861.00/1300</note>
                <head>
                    <hi rend="italic">The Consul at Harbin</hi> (<persName corresp="#p_MCK1"
                        type="from">
                        <hi rend="italic">Moser</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Harbin</hi>
                        </placeName>, <date calendar="gregorian" when="1918-03-15T21:00:00+08:26">
                            <hi rend="italic">March 15, 1918, 9 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received March 16, 5.22 a.m.</hi>]</dateline>
                </opener>
                <p>To-day <persName corresp="#p_HGDL1">Horvat</persName> informs that Japanese
                    Government have informally requested him to take sole leadership to establish
                    order and independent government Siberia, promising him full support. Your views
                    are requested.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MCK1">
                            <hi rend="smallcaps">Moser</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
