    <text>
        <body>
            <div frus:doc-dateTime-max="1918-01-10T20:00:00-05:00"
                frus:doc-dateTime-min="1918-01-10T20:00:00-05:00" n="39"
                subtype="historical-document" type="document" xml:id="d39">
                <note rend="inline" type="source">File No. 861.00/924</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in China</hi> (<persName corresp="#p_RPS1" type="to">
                        <hi rend="italic">Reinsch</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-01-10T20:00:00-05:00">
                            <hi rend="italic">January 10, 1918, 8 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your January 9, 5 p.m. Have instructed <persName corresp="#p_MCK1"
                        >Moser</persName> to send <persName corresp="#p_DLCWS1">Drysdale</persName>.
                    Speskov may accompany if you and <persName corresp="#p_MCK1">Moser</persName>
                    consider necessary. If so advise Department approximate expense necessary before
                    taking decision.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
