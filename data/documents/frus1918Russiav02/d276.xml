<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-06-15T23:59:59-05:00" frus:doc-dateTime-min="1918-06-15T00:00:00-05:00" n="276" subtype="historical-document" type="document" xml:id="d276">
                            <note rend="inline" type="source">File No. 861.00/2199</note>
                            <head><hi rend="italic">The Consul General at Irkutsk</hi> (<persName corresp="#p_HEL1" type="from"><hi rend="italic">Harris</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi><note n="1" xml:id="d276fn1">Sent via the Consulate at Vladivostok (No.
                                    23).</note></head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Irkutsk</hi></placeName>, <date calendar="gregorian" when="1918-06-15"><hi rend="italic">June 15,
                                        1918</hi></date>. <lb/> [<hi rend="italic">Received July 5,
                                        11.58 a.m.</hi>]</dateline>
                            </opener>
                            <p>Irkutsk to-day is in the hands of 3,000 armed Austrian and German
                                prisoners commanded by prisoner officers. No Czech trains present
                                Irkutsk.</p>
                            <closer>[<signed><persName corresp="#p_HEL1"><hi rend="smallcaps">Harris</hi></persName></signed>]</closer>
                        </div>
                        </body></text></TEI>