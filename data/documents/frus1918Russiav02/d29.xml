<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-01-06T14:00:00-05:00" frus:doc-dateTime-min="1918-01-06T14:00:00-05:00" n="29" subtype="historical-document" type="document" xml:id="d29">
                            <note rend="inline" type="source">File No. 861.00/898</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Consul at Vladivostok</hi> (<persName corresp="#p_CJK1" type="to"><hi rend="italic">Caldwell</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-01-06T14:00:00-05:00"><hi rend="italic">January
                                            6, 1918, 2 p.m.</hi></date></dateline>
                            </opener>
                            <p>Your January 1, 1 a.m. You are authorized to deal with Zemstvo
                                Committee unofficially as temporary administrative institution.</p>
                            <closer>
                                <signed><persName corresp="#p_LR1"><hi rend="smallcaps">Lansing</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>