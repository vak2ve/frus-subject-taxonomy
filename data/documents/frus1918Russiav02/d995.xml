    <text>
        <body>
            <div frus:doc-dateTime-max="1918-07-19T17:00:00-05:00"
                frus:doc-dateTime-min="1918-07-19T17:00:00-05:00" n="995"
                subtype="historical-document" type="document" xml:id="d995">
                <note rend="inline" type="source">File No. 861.00/2251</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Minister in Sweden</hi> (<persName corresp="#p_MIN1" type="to">
                        <hi rend="italic">Morris</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-07-19T18:00:00-04:00">
                            <hi rend="italic">July 19, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>959. Your 2459. No objection to visa passport <persName>Ferdinand Kull</persName>
                    to proceed to America, but Department wishes it clearly understood that it is
                    unwilling to make any commitment as to his reception.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PFL1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
