                <note rend="inline" type="source">Paris Peace Conf. 181.921/72</note>
                <head>
                    <hi rend="italic">General <persName type="from">Bandholtz</persName> to the
                            <gloss type="to">Interallied Military Mission</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Budapest</hi>
                        </placeName>,] <date calendar="gregorian" when="1919-12-13">13 December,
                            1919</date>.</dateline>
                </opener>
                <p rend="flushleft">Subject: Change of Status.</p>
                <p>1. In compliance with telegraphic instructions from the American Commission to
                    Negotiate Peace, the undersigned this date ceases to be a member of the
                    Interallied Military Mission.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">H. H. Bandholtz</hi>
                    </signed>
                </closer>
            </div>
        </body>
