<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1920-02-09T04:00:00-05:00" frus:doc-dateTime-min="1920-02-09T04:00:00-05:00" n="368" subtype="historical-document" type="document" xml:id="d368">
                        <note rend="inline" type="source">763.72119/9004: Telegram</note>
                        <head><hi rend="italic">The Commissioner in Hungary</hi> (<persName type="from"><hi rend="italic">Grant-Smith</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                State</gloss></hi></head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Budapest</hi></placeName>, <date calendar="gregorian" when="1920-02-09T10:00:00+01:00">February 9, 1920—10
                                a.m.</date><lb/>[Received via Paris February 10—12:45
                                p.m.]</dateline></opener>
                        <p>General Bandholtz and staff left Budapest this morning on the direct
                            special train bearing the Hungarian peace delegation to Paris.</p>
                        <closer><signed><hi rend="smallcaps">Grant-Smith</hi></signed></closer>
                    </div>
                </body></text></TEI>