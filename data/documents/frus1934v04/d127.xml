                subtype="historical-document" type="document" xml:id="d127">
                <note rend="inline" type="source">724.3415/4193: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Geneva</hi> (<persName type="from">
                        <hi rend="italic">Gilbert</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Geneva</hi>
                        </placeName>, <date calendar="gregorian" when="1934-09-27T19:00:00+01:00"
                            >September 27, 1934—7 p.m.</date>
                        <lb/>[Received September 27—5:20 p.m.]</dateline>
                </opener>
                <p>277. The resolution cited in my 274, September 26, 8 p.m., was adopted at the
                    closing meeting of the Assembly session this afternoon.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gilbert</hi>
                    </signed>
                </closer>
            </div>
        </body>
