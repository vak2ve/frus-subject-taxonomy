                subtype="historical-document" type="document" xml:id="d86">
                <note rend="inline" type="source">724.3415/3567: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Bolivia</hi> (<persName type="from">
                        <hi rend="italic">Des Portes</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">La Paz</hi>
                        </placeName>, <date calendar="gregorian" when="1934-02-27T11:00:00-04:00"
                            >February 27, 1934—11 a.m.</date>
                        <lb/>[Received 11:50 a.m.]</dateline>
                </opener>
                <p>14. Attitude toward peace proposal generally favorable. Extension of time for
                    reply may be requested. Repeated to Buenos Aires, Asunción.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Des Portes</hi>
                    </signed>
                </closer>
            </div>
        </body>
