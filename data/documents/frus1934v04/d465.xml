    <text>
        <body>
            <div frus:doc-dateTime-max="1934-11-03T10:00:00-05:00"
                frus:doc-dateTime-min="1934-11-03T10:00:00-05:00" n="465"
                subtype="historical-document" type="document" xml:id="d465">
                <note rend="inline" type="source">721.23/2389: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Peru</hi> (<persName type="from">
                        <hi rend="italic">Dearing</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Lima</hi>
                        </placeName>, <date calendar="gregorian" when="1934-11-03T10:00:00-05:00"
                            >November 3, 1934—10 a.m.</date>
                        <lb/>[Received 11:35 a.m.]</dateline>
                </opener>
                <p>105. Peruvian Constituent Assembly by vote of 61 to 11 last night approved Rio de
                    Janeiro Protocol concerning Leticia.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Dearing</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
