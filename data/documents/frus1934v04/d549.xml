                subtype="historical-document" type="document" xml:id="d549">
                <note rend="inline" type="source">713.1311/295: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Guatemala</hi> (<persName type="from">
                        <hi rend="italic">Hanna</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guatemala</hi>
                        </placeName>, <date calendar="gregorian" when="1934-03-15T12:00:00-06:00"
                            >March 15, 1934—noon</date>.<lb/>[Received 2:45 p.m.]</dateline>
                </opener>
                <p>26. Central American Conference assembled this morning. The Guatemalan Minister
                    for Foreign Affairs delivered an address of welcome in which he emphasized
                    desirability of Central American union. The Conference is now organizing in
                    private session.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hanna</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
