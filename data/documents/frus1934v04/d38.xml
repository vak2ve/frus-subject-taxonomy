                subtype="historical-document" type="document" xml:id="d38">
                <note rend="inline" type="source">710.G Commercial Agreement/51: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in El Salvador</hi> (<persName type="from">
                        <hi rend="italic">Corrigan</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San Salvador</hi>
                        </placeName>, <date calendar="gregorian" when="1934-09-25T15:00:00-06:00"
                            >September 25, 1934—3 p.m.</date>
                        <lb/>[Received 5:45 p.m.]</dateline>
                </opener>
                <p>51. I brought to the attention of the Salvadoran Government orally and informally
                    the substance of the information contained in your circular telegram of
                    September 23, 2 p.m., and was informed that <pb facs="0091" n="21"
                        xml:id="pg_21"/> this country has no representative at Geneva at this time.
                    The proposition is well understood by the Salvadoran Foreign Office the
                    Undersecretary having been present at Montevideo when it was under
                    discussion.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Corrigan</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
