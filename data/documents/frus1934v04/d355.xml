                <note rend="inline" type="source">724.3415/4004: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Great Britain</hi> (<persName type="to">
                        <hi rend="italic">Bingham</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-08-15T17:00:00-04:00"
                            >August 15, 1934—5 p.m.</date>
                    </dateline>
                </opener>
                <p>332. Your 463, August 11, noon. You need not make any further effort to obtain
                    the detailed information requested in Department’s 317, July 26, 8 p.m.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
