                subtype="historical-document" type="document" xml:id="d29">
                <note rend="inline" type="source">710.G Commercial Agreement/30: Telegram</note>
                <head>
                    <hi rend="italic">The Consul at Geneva</hi> (<persName type="from">
                        <hi rend="italic">Gilbert</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Geneva</hi>
                        </placeName>, <date calendar="gregorian" when="1934-09-21T17:00:00+01:00"
                            >September 21, 1934—5 p.m.</date>
                        <lb/>[Received September 21—1:05 p.m.]</dateline>
                </opener>
                <p>259. Consulate’s No. 256, September 21, noon, paragraph 6. Request confirmation
                    United States signature Pan American Agreement in time for use by Belgian
                    representative who contemplates reopening question in Second Committee tomorrow
                    morning.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gilbert</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
