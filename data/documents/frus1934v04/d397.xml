<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-09-19T10:00:00-05:00" frus:doc-dateTime-min="1934-09-19T10:00:00-05:00" n="397" subtype="historical-document" type="document" xml:id="d397">
                        <note rend="inline" type="source">725.34/62: Telegram</note>
                        <head><hi rend="italic">The Ambassador m Chile</hi> (<persName type="from"><hi rend="italic">Sevier</hi></persName>) <hi rend="italic">to
                                the <gloss type="to">Secretary of State</gloss></hi></head>
                        <opener>
                            <dateline rendition="#right"><placeName><hi rend="smallcaps">Santiago</hi></placeName>, <date calendar="gregorian" when="1934-09-19T11:00:00-04:00">September 19, 1934—11
                                    a.m.</date><lb/>[Received 11:20 a.m.]</dateline>
                        </opener>
                        <p>91. Chilean-Paraguayan incident has been satisfactorily adjusted along
                            the lines of my telegram 90, September 17, 2 p.m.</p>
                        <closer><signed><hi rend="smallcaps">Sevier</hi></signed></closer>
                    </div>
