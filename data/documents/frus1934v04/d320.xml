<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-06-07T04:00:00-05:00" frus:doc-dateTime-min="1934-06-07T04:00:00-05:00" n="320" subtype="historical-document" type="document" xml:id="d320">
                            <note rend="inline" type="source">724.3415/3800: Telegram</note>
                            <head><hi rend="italic">The Consul at Geneva</hi> (<persName type="from"><hi rend="italic">Gilbert</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Geneva</hi></placeName>, <date calendar="gregorian" when="1934-06-07T10:00:00+01:00">June 7, 1934—10
                                    a.m.</date><lb/>[Received June 7—7:17 a.m.]</dateline>
                            </opener>
                            <p>140. Arms embargo. British Delegation informs me that London has
                                taken action indicated in Consulate’s 135, June 5, 2 p.m., paragraph
                                1.</p>
                            <closer><signed><hi rend="smallcaps">Gilbert</hi></signed></closer>
                        </div>
                        </body></text></TEI>