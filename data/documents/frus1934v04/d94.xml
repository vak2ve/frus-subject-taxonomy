                subtype="historical-document" type="document" xml:id="d94">
                <note rend="inline" type="source">724.3415/3583: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Chile</hi> (<persName type="from">
                        <hi rend="italic">Sevier</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Santiago</hi>
                        </placeName>, <date calendar="gregorian" when="1934-03-03T12:00:00-04:00"
                            >March 3, 1934—noon</date>.<lb/>[Received 12:45 p.m.]</dateline>
                </opener>
                <p>27. My telegram No. 26, February 28, 6 p.m. The Foreign Minister and principal
                    Foreign Office officials have left the city for the weekend. <pb facs="0133"
                        n="63" xml:id="pg_63"/> It is understood that no action by Chile in regard
                    to Paraguay’s rejection of the League formula will be considered prior to early
                    part of next week.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sevier</hi>
                    </signed>
                </closer>
            </div>
        </body>
