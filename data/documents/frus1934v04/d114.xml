                subtype="historical-document" type="document" xml:id="d114">
                <note rend="inline" type="source">724.3415/4086: Telegram</note>
                <head>
                    <hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from">
                        <hi rend="italic">Gibson</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Rio de Janeiro</hi>
                        </placeName>, <date calendar="gregorian" when="1934-09-06T17:00:00-03:00"
                            >September 6, 1934—5 p.m.</date>
                        <lb/>[Received September 6—4:42 p.m.]</dateline>
                </opener>
                <p>208. Reference paragraph 2 my 207, September 5, 6 p.m.<note n="53"
                        xml:id="d114fn53">Not printed.</note> Foreign Office has instructed Bolivian
                        [<hi rend="italic">Brazilian?</hi>] Minister in La Paz to advise Bolivian
                    Minister for Foreign Affairs that in view of the fact that Brazil is not a
                    member of the League it will not accept position on any League committee such as
                    suggested by Bolivia. Repeated to Buenos Aires.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gibson</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
