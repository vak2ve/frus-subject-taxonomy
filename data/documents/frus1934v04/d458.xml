                subtype="historical-document" type="document" xml:id="d458">
                <note rend="inline" type="source">721.23/2308: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Switzerland</hi> (<persName type="to">
                        <hi rend="italic">Wilson</hi>
                    </persName>), <hi rend="italic">at Geneva</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-05-18T20:00:00-04:00"
                            >May 18, 1934—8 p.m.</date>
                    </dateline>
                </opener>
                <p>156. Following cable just received from Gibson at Rio de Janeiro: [Here follows
                    text of telegram No. 89, May 18, 1 p.m., from the Ambassador in Brazil, printed
                    on <ref target="#pg_358">page 358</ref>.] You may of course use your
                    discretion.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
