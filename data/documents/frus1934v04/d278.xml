                <note rend="inline" type="source">724.3415/4267: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Brazil</hi> (<persName type="to">
                        <hi rend="italic">Gibson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-10-18T17:00:00-05:00"
                            >October 18, 1934—5 p.m.</date>
                    </dateline>
                </opener>
                <p>156. Your 288, October 17, 6 p.m. The Department views the proposal most
                    favorably. Please keep the Department fully informed by cable of all
                    developments.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Phillips</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
