                subtype="historical-document" type="document" xml:id="d399">
                <note rend="inline" type="source">721.23/2102a: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Brazil</hi> (<persName type="to">
                        <hi rend="italic">Gibson</hi>
                    </persName>)</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1934-01-26T16:00:00-05:00"
                            >January 26, 1934—4 p.m.</date>
                    </dateline>
                </opener>
                <p>10. Please cable what progress is being made in the Leticia discussions and
                    report more fully by airmail. We should be glad to be currently advised of the
                    information discreetly available to you concerning developments in this
                    situation.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hull</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
