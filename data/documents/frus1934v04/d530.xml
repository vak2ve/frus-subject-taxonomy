                subtype="historical-document" type="document" xml:id="d530">
                <note rend="inline" type="source">713.1311/267: Telegram</note>
                <head>
                    <hi rend="italic">The Minister in Costa Rica</hi> (<persName type="from">
                        <hi rend="italic">Sack</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">San José</hi>
                        </placeName>, <date calendar="gregorian" when="1934-03-05T12:00:00-06:00"
                            >March 5, 1934—noon</date>.<lb/>[Received 3:05 p.m.]</dateline>
                </opener>
                <p>12. Honduran Minister to Costa Rica, Medál, flying tomorrow to Tegucigalpa for
                    conferences before appointment as delegate to Guatemala Conference.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Sack</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
