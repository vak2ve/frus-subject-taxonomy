<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1934-09-27T12:00:00-05:00" frus:doc-dateTime-min="1934-09-27T12:00:00-05:00" n="125" subtype="historical-document" type="document" xml:id="d125">
                            <note rend="inline" type="source">724.3415/4191: Telegram</note>
                            <head><hi rend="italic">The Ambassador in Brazil</hi> (<persName type="from"><hi rend="italic">Gibson</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                                    State</gloss></hi></head>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Rio de
                                            Janeiro</hi></placeName>, <date calendar="gregorian" when="1934-09-27T14:00:00-03:00">September 27, 1934—2
                                        p.m.</date><lb/>[Received September 27—1:35 p.m.]</dateline>
                            </opener>
                            <p>244. Foreign Office has received informal invitation from Avenol to
                                join League Commission. Anxious receive earliest possible moment
                                indication as to line taken in your reply in order to follow same
                                course.</p>
                            <closer><signed><hi rend="smallcaps">Gibson</hi></signed></closer>
                        </div>
                        </body></text></TEI>