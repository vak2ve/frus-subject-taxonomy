                subtype="historical-document" type="document" xml:id="d518">
                <note rend="inline" type="source">713.1311/250: Telegram</note>
                <head>
                    <hi rend="italic">The Chargé in Guatemala</hi> (<persName type="from">
                        <hi rend="italic">Lawton</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Guatemala</hi>
                        </placeName>, <date calendar="gregorian" when="1934-02-17T12:00:00-06:00"
                            >February 17, 1934—noon</date>.<lb/>[Received 2:30 p.m.]</dateline>
                </opener>
                <p>18. Foreign Office has just notified me that Conference will meet March 15.
                    Repeated to Central American missions.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Lawton</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
