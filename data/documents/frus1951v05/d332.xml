                            <head>
                                <hi rend="italic">State Department Draft Minutes of Discussions at
                                    the State–Joint Chiefs of Staff Meeting, May 2, 1951</hi><note n="1" xml:id="d332fn2">This memorandum bears the following
                                    unsigned notation: “State Draft. Not cleared with any of the
                                    participants.”</note>
                            </head>
                            <opener>
                                <seg rendition="#left">
                                    <hi rend="smallcaps">top secret</hi>
                                </seg>
                                <dateline rendition="#right">[<placeName><hi rend="smallcaps">Washington</hi>
                                    </placeName>, <date ana="#date_undated-inferred-from-document-head" calendar="gregorian" when="1951-05-02">May 2,
                                    1951</date>.]</dateline>
                            </opener>
                            <p rend="center">
                                <hi rend="smallcaps">Present</hi>
                            </p>
