<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>The Secretary of State to the
                            Embassy in the Soviet Union</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1947v04</bibl><bibl type="frus-document-id">d451</bibl><bibl type="frus-document-number">451</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1947-02-05T16:00:00-05:00" notAfter="1947-02-05T16:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1947-02-05T16:00:00-05:00" frus:doc-dateTime-min="1947-02-05T16:00:00-05:00" n="451" subtype="historical-document" type="document" xml:id="d451">
                <note rend="inline" type="source">862.24/2–547: Telegram</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                            <gloss type="to">Embassy in the Soviet Union</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1947-02-05T16:00:00-05:00">February 5, 1947—4 p. m.</date>
                    </dateline>
                </opener>
                <p>180. For Ambassador. <gloss target="#t_reDeptel1">ReDeptel</gloss> 83, January
                    17, 7 p. m. Formal Advice of cessation of deliveries under pipeline given Eremin
                    of Soviet Government Purchasing Commission by letter from Lane dated 1/30/47.
                    However, items to which title had been transferred prior to December 31, 1946
                    including items “deemed” transferred in accordance with Agreement of Oct 15,
                    1945 have been released for immediate shipment. Best estimates indicate
                    materials released amount to $9 million.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Marshall</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
