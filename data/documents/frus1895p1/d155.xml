<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1895-09-27T23:59:59-05:00" frus:doc-dateTime-min="1895-09-27T00:00:00-05:00" n="155" subtype="historical-document" type="document" xml:id="d155">
                        <head><hi rend="italic">Mr. <persName type="from">Denby</persName> to Mr.
                                    <persName type="to">Olney</persName></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1895-09-27"><hi rend="italic">September 27,
                                    1895</hi></date>.</dateline></opener>
                        <p>Six criminals executed Chengtu; thirteen punished—banished, imprisonment,
                            bambooing.</p>
                        <closer><signed><hi rend="smallcaps">Denby</hi></signed>.</closer>
                    </div>
