    <text>
        <body>
            <div frus:doc-dateTime-max="1895-06-19T23:59:59-05:00" frus:doc-dateTime-min="1895-06-19T00:00:00-05:00" n="675" subtype="historical-document" type="document" xml:id="d675">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Roosevelt</persName> to
                                Mr. <persName type="to">Olney</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Embassy
                                        of the United States</hi>,<lb/>
                            <hi rend="italic">London</hi>
                        </placeName>, <date calendar="gregorian" when="1895-06-19">
                            <hi rend="italic">June 19,
                                1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Home secretary will release John Curtin Kent on “ticket of leave” as soon
                            as friends arrange to care for him.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Roosevelt.</hi>
                    </signed>
                </closer>
            </div>
        </body>
