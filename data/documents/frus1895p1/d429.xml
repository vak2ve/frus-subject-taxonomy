    <text>
        <body>
            <div frus:doc-dateTime-max="1895-08-29T23:59:59-05:00" frus:doc-dateTime-min="1895-08-29T00:00:00-05:00" n="429" subtype="historical-document" type="document" xml:id="d429">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr.
                                    <persName type="to">Runyon</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-08-29">
                            <hi rend="italic">August 29,
                                1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Private advices from representative of the Mutual Life Company in Prussia
                            indicate favorable outcome if views of the United States vigorously and
                            persistently put forward. This you are authorized to do with good
                            judgment and discretion.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Adee</hi>, <hi rend="italic">Acting</hi>
                    </signed>.</closer>
            </div>
        </body>
