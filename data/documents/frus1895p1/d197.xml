                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Denby</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-12-21">
                            <hi rend="italic">December 21,
                                    1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Ask Hixson and Newell for immediate preparation joint report.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Olney</hi>
                    </signed>.</closer>
            </div>
        </body>
