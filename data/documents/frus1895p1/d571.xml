    <text>
        <body>
            <div frus:doc-dateTime-max="1895-06-04T23:59:59-05:00" frus:doc-dateTime-min="1895-06-04T00:00:00-05:00" n="571" subtype="historical-document" type="document" xml:id="d571">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Mr.
                                    <persName type="to">Bayard</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-06-04">
                            <hi rend="italic">June 4,
                                1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Treasury Department inquires touching nature of bill relative to seals
                            announced for introduction in Parliament by Sir Edward Gray. Please
                            telegraph earliest obtainable information.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Uhl</hi>, <hi rend="italic">Acting.</hi>
                    </signed>
                </closer>
            </div>
        </body>
