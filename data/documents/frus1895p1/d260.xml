    <text>
        <body>
            <div frus:doc-dateTime-max="1895-06-12T23:59:59-05:00" frus:doc-dateTime-min="1895-06-12T00:00:00-05:00" n="260" subtype="historical-document" type="document" xml:id="d260">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Eustis</persName> to
                                    Mr. <persName type="to">Uhl</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Embassy of the United States</hi>,<lb/>
                            <hi rend="italic">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1895-06-12">
                            <hi rend="italic">June 12, 1895</hi>
                        </date>. (Received June
                                    24).</dateline>
                    <seg rendition="#left">No. 315.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                                receipt of your dispatch No. 428, of May 24, with reference to
                                expenses incurred on account of Mr. Bray. In compliance with your
                                instruction, I have this day drawn upon the Secretary of State for
                                the sum of $129.02, amount expended by me, and also for the sum of
                                $1.72, amount lost by exchange. I inclose herewith my accounts for
                                the same.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">J. B.
                                Eustis</hi>
                    </signed>.</closer>
            </div>
        </body>
