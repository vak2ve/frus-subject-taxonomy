                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Captain
                            <persName type="to">Stubbs</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1894-03-10">
                            <hi rend="italic">March 10, 1894</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">A. F. Stubbs</hi>, <hi rend="italic">Master Schooner Henry
                        Crosby:</hi>
                    <lb/>(Care of Smith, Gregory &amp; Winters, New York City.)</p>
                <p>No.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. Q. Gresham</hi>
                    </signed>.</closer>
