<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1895-12-19T23:59:59-05:00" frus:doc-dateTime-min="1895-12-19T00:00:00-05:00" n="28" subtype="historical-document" type="document" xml:id="d28">
                        <head><hi rend="italic">Mr. <persName type="from">Ewing</persName> to Mr.
                                    <persName type="to">Olney</persName></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Brussels</hi></placeName>, <date calendar="gregorian" when="1895-12-19"><hi rend="italic">December 19,
                                    1895</hi></date>.</dateline></opener>
                        <p>Have communicated substance of your instructions to Belgian Government on
                            subject importation American cattle.</p>
                        <closer><signed><hi rend="smallcaps">Ewing</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>