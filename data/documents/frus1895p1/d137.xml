<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1895-09-17T23:59:59-05:00" frus:doc-dateTime-min="1895-09-17T00:00:00-05:00" n="137" subtype="historical-document" type="document" xml:id="d137">
                        <head><hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Denby</persName></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1895-09-17"><hi rend="italic">September 17,
                                    1895</hi></date>.</dateline></opener>
                        <p>Proposition to arrange Szechuan investigation with British consul
                            Chungking not entertained. Press independent commission. Omit
                            missionary, sending Cheshire instead.</p>
                        <closer><signed><hi rend="smallcaps">Olney</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>