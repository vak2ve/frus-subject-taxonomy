    <text>
        <body>
            <div frus:doc-dateTime-max="1895-07-08T23:59:59-05:00" frus:doc-dateTime-min="1895-07-08T00:00:00-05:00" n="268" subtype="historical-document" type="document" xml:id="d268">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr.
                                        <persName type="to">Eustis</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-07-08">
                            <hi rend="italic">July 8,
                                    1895</hi>
                        </date>.</dateline>
                </opener>
                <p>No. 327 received. Your note June 22 to minister foreign affairs
                                entirely approved. Urge also right to see prisoner.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Adee</hi>, <hi rend="italic">Acting</hi>
                    </signed>.</closer>
            </div>
        </body>
