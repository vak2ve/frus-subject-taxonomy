    <text>
        <body>
            <div frus:doc-dateTime-max="1895-01-10T23:59:59-05:00" frus:doc-dateTime-min="1895-01-10T00:00:00-05:00" n="3" subtype="historical-document" type="document" xml:id="d3">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Buchanan</persName> to Mr.
                                    <persName type="to">Gresham</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Buenos Ayres</hi>
                        </placeName>, <date calendar="gregorian" when="1895-01-10">
                            <hi rend="italic">January 10,
                                1895</hi>
                        </date>. (Received Feb. 11.)</dateline>
                    <seg rendition="#left">No. 86.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I cabled you to-day as follows: <quote rend="blockquote">
                        <p rend="flushleft">
                            <hi rend="smallcaps">Gresham</hi>, <hi rend="italic">Washington:</hi>
                        </p>
                        <p>Tariff bill passed; advantages mentioned in my Nos. 63, 64, and
                                    74 secured, except canned goods raised to 15
                            cents.</p>
                    </quote>
                </p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Buchanan</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
