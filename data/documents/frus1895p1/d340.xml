                <head>
                    <hi rend="italic">Mr. <persName type="from">Eustis</persName> to
                                    Mr. <persName type="to">Olney</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1896-01-16">
                            <hi rend="italic">January 16,
                                        1896</hi>
                        </date>.</dateline>
                </opener>
                <p>Reply was too long to be cabled. It left in last Friday’s bag.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Eustis</hi>
                    </signed>.</closer>
            </div>
