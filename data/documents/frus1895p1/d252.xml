                subtype="historical-document" type="document" xml:id="d252">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Eustis</persName> to Mr. <persName
                            type="to">Gresham</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States</hi>,<lb/>
                            <hi rend="italic">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1895-04-25">
                            <hi rend="italic">April 25, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Minister for foreign affairs promises to furnish all information at hand and to
                    telegraph for all other. Permission for Waller to communicate with
                    representative of embassy will be referred to legal authorities.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Eustis</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
