    <text>
        <body>
            <div frus:doc-dateTime-max="1895-06-11T23:59:59-05:00"
                frus:doc-dateTime-min="1895-06-11T00:00:00-05:00" n="537"
                subtype="historical-document" type="document" xml:id="d537">
                <head>
                    <hi rend="italic">Viscount <persName type="from">Gough</persName> to Mr.
                            <persName type="to">Uhl</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">British Embassy</hi>,<lb/>
                            <hi rend="italic">Newport, R. I.</hi>
                        </placeName>, <date calendar="gregorian" when="1895-06-11">
                            <hi rend="italic">June 11, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 6th instant, informing me of the steps taken by the Secretary
                    of the Treasury to facilitate the passage of stores for twenty Canadian mounted
                    police.</p>
                <p>I beg that you will express to Mr. Secretary Carlisle my sense of the courtesy he
                    has shown in this matter.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Hugh Gough</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
