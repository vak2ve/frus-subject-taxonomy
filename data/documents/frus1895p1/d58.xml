                <head>
                    <hi rend="italic">Mr. <persName type="from">Thompson</persName> to Mr.
                                    <persName type="to">Olney</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Petropolis</hi>
                        </placeName>, <date calendar="gregorian" when="1896-01-08">
                            <hi rend="italic">January 8,
                                1896</hi>
                        </date>.</dateline>
                </opener>
                <p>Brazilian Government has declined to arbitrate Trinidad question.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Thompson</hi>
                    </signed>.</closer>
            </div>
        </body>
