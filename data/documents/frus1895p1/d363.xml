<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1895-04-09T23:59:59-05:00" frus:doc-dateTime-min="1895-04-09T00:00:00-05:00" n="363" subtype="historical-document" type="document" xml:id="d363">
                            <head><hi rend="italic">Mr. <persName type="from">Campbell</persName> to
                                    Mr. <persName type="to">Uhl</persName></hi>.</head>
                            <opener><seg rendition="#center">[Telegram.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Port Louis</hi></placeName>, <date calendar="gregorian" when="1895-04-09"><hi rend="italic">April 9,
                                        1895</hi></date>.</dateline></opener>
                            <p>Waller sent to France. His son, expelled from Madagascar, also sent
                                to France.</p>
                            <closer><signed><hi rend="smallcaps">Campbell</hi></signed>.</closer>
                        </div>
                        </body></text></TEI>