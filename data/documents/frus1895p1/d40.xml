    <text>
        <body>
            <div frus:doc-dateTime-max="1895-03-19T23:59:59-05:00" frus:doc-dateTime-min="1895-03-19T00:00:00-05:00" n="40" subtype="historical-document" type="document" xml:id="d40">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Mr.
                                    <persName type="to">Mendonça</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-03-19">
                            <hi rend="italic">March 19,
                                1895</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 6.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the
                            receipt of your note of the 16th instant, announcing the reestablishment
                            of diplomatic relations between Brazil and Portugal, and offering the
                            sincere thanks of your Government to the President for the protection
                            extended by the minister of the United States at Lisbon to citizens of
                            Brazil resident in Portugal.</p>
                <p>I have taken pleasure in communicating the contents of your note to the
                            President and beg to express his gratification at the announcement
                            made.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edwin F. Uhl</hi>,<lb/>
                        <hi rend="italic">Acting Secretary</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
