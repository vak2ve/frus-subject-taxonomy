                subtype="historical-document" type="document" xml:id="d441">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr. <persName
                            type="to">Jackson</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-07-25">
                            <hi rend="italic">July 25, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>It is reported that Louis Stern, wealthy and honorable New York merchant, is in
                    trouble at Kissingen, charged with insulting German official. Ascertain facts
                    and do all you properly can.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Adee</hi>, <hi rend="italic">Acting</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
