    <text>
        <body>
            <div frus:doc-dateTime-max="1896-01-28T23:59:59-05:00"
                frus:doc-dateTime-min="1896-01-28T00:00:00-05:00" n="633"
                subtype="historical-document" type="document" xml:id="d633">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Sir <persName
                            type="to">Julian Pauncefote</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1896-01-28">
                            <hi rend="italic">January 28, 1896</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 304.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to inform you that your
                    notes dated the 16th, 19th, and 24th instant, respectively, in relation to the
                    shooting <pb facs="0754" n="694" xml:id="pg_694"/> of Mr. James Bain, purser of
                    the British steamship <hi rend="italic">Engineer</hi>, have been received, and
                    copies thereof sent to the governor of Louisiana for his information.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Richard Olney.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
