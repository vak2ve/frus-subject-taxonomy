                <head>
                    <hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr. <persName
                            type="to">Denby</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-10-10">
                            <hi rend="italic">October 10, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Instruct Szechuan commission to return by water after completing its labors.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Olney</hi>
                    </signed>.</closer>
            </div>
        </body>
