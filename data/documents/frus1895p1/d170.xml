<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1895-10-10T23:59:59-05:00" frus:doc-dateTime-min="1895-10-10T00:00:00-05:00" n="170" subtype="historical-document" type="document" xml:id="d170">
                        <head><hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Denby</persName></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1895-10-10"><hi rend="italic">October 10,
                                1895</hi></date>.</dateline></opener>
                        <p>Instruct Szechuan commission to return by water after completing its
                            labors.</p>
                        <closer><signed><hi rend="smallcaps">Olney</hi></signed>.</closer>
                    </div>
