<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1895-04-01T23:59:59-05:00" frus:doc-dateTime-min="1895-04-01T00:00:00-05:00" n="362" subtype="historical-document" type="document" xml:id="d362">
                            <head><hi rend="italic">Mr. <persName type="from">Uhl</persName> to Mr.
                                        <persName type="to">Campbell</persName></hi>.</head>
                            <opener><seg rendition="#center">[Telegram.]</seg></opener>
                            <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1895-04-01"><hi rend="italic">April 1,
                                        1895</hi></date>.</dateline></opener>
                            <p>Communicate with Wetter, and report further as to Waller’s
                                imprisonment.</p>
                            <closer><signed><hi rend="smallcaps">Uhl</hi></signed>.</closer>
                        </div>
                        </body></text></TEI>