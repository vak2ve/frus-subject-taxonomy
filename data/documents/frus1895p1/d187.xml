<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1895-11-11T23:59:59-05:00" frus:doc-dateTime-min="1895-11-11T00:00:00-05:00" n="187" subtype="historical-document" type="document" xml:id="d187">
                        <head><hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Denby</persName></hi>.</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1895-11-11"><hi rend="italic">November 11,
                                    1895</hi></date>.</dateline>
                            <seg rendition="#left">No. 1188.]</seg></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have to acknowledge the receipt of your
                            No. 2362, of September 21 last, and to approve your instructions to the
                            Kutien commission on the question of clemency.</p>
                        <p>I am, etc.,</p>
                        <closer><signed><hi rend="smallcaps">Richard Olney</hi></signed>.</closer>
                    </div>
                    </body></text></TEI>