                subtype="historical-document" type="document" xml:id="d360">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Mr. <persName
                            type="to">Campbell</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <date calendar="gregorian" when="1895-03-27">
                            <hi rend="smallcaps">March</hi> 27, 1895</date>.</dateline>
                </opener>
                <p>Newspapers report Waller, formerly United States consul, imprisoned under
                    sentence by court-martial at Tamatave. Inquire. Telegraph facts briefly.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Uhl</hi>, <hi rend="italic">Acting</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
