                subtype="historical-document" type="document" xml:id="d103">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr. <persName
                            type="to">Denby</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-08-20">
                            <hi rend="italic">August 20, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>Your dispatch No. 2278 approved. Carry it out as far as possible notwithstanding
                    your previous withdrawal. Commissioners to investigate and report as to American
                    loss, but not to fix demand.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Adee</hi>, <hi rend="italic">Acting</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
