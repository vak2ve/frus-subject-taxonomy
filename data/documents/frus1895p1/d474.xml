<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1895-10-29T23:59:59-05:00" frus:doc-dateTime-min="1895-10-29T00:00:00-05:00" n="474" subtype="historical-document" type="document" xml:id="d474">
                        <head><hi rend="italic">Mr. <persName type="from">Olney</persName> to Mr.
                                    <persName type="to">Runyon</persName></hi>.</head>
                        <opener><seg rendition="#center">[Telegram.]</seg></opener>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1895-10-29"><hi rend="italic">October 29,
                                1895</hi></date>.</dateline></opener>
                        <p>Stern will not return to undergo imprisonment.</p>
                        <closer>
                            <signed><hi rend="smallcaps">Olney</hi>.</signed>
                        </closer>
                    </div>
