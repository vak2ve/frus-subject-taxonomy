                subtype="historical-document" type="document" xml:id="d654">
                <head>
                    <hi rend="italic">Sir <persName type="from">Julian Pauncefote</persName> to Mr.
                            <persName type="to">Olney</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">British Embassy</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-10-26">
                            <hi rend="italic">October 26, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: Referring to the embassy note of the 19th ultimo
                    to Mr. Adee, and to previous correspondence on the subject of the tax levied on
                    United States vessels entering and clearing from Canadian ports, I have the
                    honor to inform you that the question is still under consideration and will
                    receive prompt attention.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Julian Pauncefote</hi>.</signed>
                </closer>
            </div>
        </body>
    </text>
