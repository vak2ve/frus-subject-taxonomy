    <text>
        <body>
            <div frus:doc-dateTime-max="1895-08-14T23:59:59-05:00" frus:doc-dateTime-min="1895-08-14T00:00:00-05:00" n="95" subtype="historical-document" type="document" xml:id="d95">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Denby</persName> to Mr.
                                    <persName type="to">Olney</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States in
                                    China</hi>
                        </placeName>,<lb/>
                        <date calendar="gregorian" when="1895-08-14">
                            <hi rend="italic">August 14,
                                1895</hi>
                        </date>.</dateline>
                </opener>
                <p>I refused to have anything to do with the Szechuan commission three weeks
                            ago.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Denby</hi>
                    </signed>.</closer>
            </div>
        </body>
