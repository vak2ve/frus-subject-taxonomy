                <head>
                    <hi rend="italic">Mr. <persName type="from">Bayard</persName> to Mr. <persName
                            type="to">Olney</persName>
                    </hi>.</head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1896-01-04">
                            <hi rend="italic">January 4, 1896</hi>
                        </date>.</dateline>
                </opener>
                <p>Will procure and send by next mail newspaper containing report of proceedings of
                    Boston Grammar School in August last.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Bayard</hi>.</signed>
                </closer>
            </div>
        </body>
