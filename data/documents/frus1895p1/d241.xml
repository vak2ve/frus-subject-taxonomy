    <text>
        <body>
            <div frus:doc-dateTime-max="1895-04-05T23:59:59-05:00"
                frus:doc-dateTime-min="1895-04-05T00:00:00-05:00" n="241"
                subtype="historical-document" type="document" xml:id="d241">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Uhl</persName> to Mr. <persName
                            type="to">Wos y Gil</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1895-04-05">
                            <hi rend="italic">April 5, 1895</hi>
                        </date>.</dateline>
                    <seg rendition="#left">No. 3.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 2d instant, stating that the Dominican special envoy has just
                    signed at Paris the protocol for the final settlement of the Franco-Dominican
                    differences, and expressing the appreciation of your Government for the moral
                    support given to it by that of the United States.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Edwin F. Uhl</hi>,<lb/>
                        <hi rend="italic">Acting Secretary</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
