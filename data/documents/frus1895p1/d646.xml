                subtype="historical-document" type="document" xml:id="d646">
                <head>
                    <hi rend="italic">Viscount <persName type="from">Gough</persName> to Mr.
                            <persName type="to">Uhl</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">British Embassy</hi>,<lb/>
                            <hi rend="italic">Newport</hi>
                        </placeName>, <date calendar="gregorian" when="1895-07-05">
                            <hi rend="italic">July 5, 1895</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge, with thanks, the
                    receipt of your note, No. 143, of the 3d instant, respecting the apparently
                    conflicting claims of territorial jurisdiction over certain islands in Lac de
                    Croix, on the northwestern boundary between Minnesota and Manitoba. I have not
                    failed to bring your communication to the notice of Her Majesty’s
                    Government.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gough</hi>
                    </signed>.</closer>
            </div>
        </body>
    </text>
