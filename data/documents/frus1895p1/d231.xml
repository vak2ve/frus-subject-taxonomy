<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1894-10-27T23:59:59-05:00" frus:doc-dateTime-min="1894-10-27T00:00:00-05:00" n="231" subtype="historical-document" type="document" xml:id="d231">
                        <head><hi rend="italic">Mr. <persName type="from">Adee</persName> to Mr.
                                    <persName type="to">Wos y Gil</persName></hi>.</head>
                        <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1894-10-27"><hi rend="italic">October 27,
                                1894</hi></date>.</dateline></opener>
                        <p><hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge receipt of
                            your note of the 26th instant, by which you express the acquiescence of
                            your Government in the rescission of the commercial arrangement of June
                            4, 1891.</p>
                        <p>Accept, etc.,</p>
                        <closer><signed><hi rend="smallcaps">Alvey A. Adee</hi>,<lb/><hi rend="italic">Acting Secretary</hi></signed>.</closer>
                    </div>
                </body></text></TEI>