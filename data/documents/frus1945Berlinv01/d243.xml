    <text>
        <body>
            <div frus:doc-dateTime-max="1945-07-15T06:00:00-05:00"
                frus:doc-dateTime-min="1945-07-15T06:00:00-05:00" n="243"
                subtype="historical-document" type="document" xml:id="d243">
                <note rend="inline" type="source">740.0011 P. W./7–1545: Telegram</note>
                <head>No. 243<lb/>
                    <hi rend="italic">The Ambassador in the United Kingdom</hi> (<persName
                        corresp="#p_WJG2" type="from">
                        <hi rend="italic">Winant</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                        <lb/>
                        <hi rend="smallcaps">us urgent</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-15T12:00:00+01:00"
                            >July 15, 1945—noon.</date>
                    </dateline>
                </opener>
                <p>7144. Foreign Office given substance of Department’s 5773, July 14<note n="1"
                        xml:id="d243fn1">
                        <ref target="#d242">Document No. 242</ref>.</note> this morning.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WJG2">
                            <hi rend="smallcaps">Winant</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
