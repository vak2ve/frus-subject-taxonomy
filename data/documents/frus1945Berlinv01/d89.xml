<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-06-23T23:59:59-05:00" frus:doc-dateTime-min="1945-06-23T00:00:00-05:00" n="89" subtype="historical-document" type="document" xml:id="d89">
                        <note rend="inline" type="source">
                            <persName corresp="#p_LFAWD1">Leahy</persName> Papers: Telegram</note>
                        <head>No. 89 <lb/>
                            <hi rend="italic">President <persName corresp="#p_THS1" type="from">Truman</persName> to Prime Minister <persName corresp="#p_CMWS1" type="to">Churchill</persName>
                            </hi><note n="1" xml:id="d89fn1">Presumably sent to the United States
                                Naval Attaché, London, via the White House Map Room and Navy
                                channels.</note>
                        </head>
                        <opener>
                            <dateline rendition="#right">[<placeName><hi rend="smallcaps">Olympia,
                                        Washington</hi></placeName>,] <date calendar="gregorian" when="1945-06-23">23 June 1945</date>.</dateline>
                        </opener>
                        <p>81. Your 97.<note n="2" xml:id="d89fn2">
                                <ref target="#d88">document No. 88</ref>.</note> I am in
                            agreement.</p>
                    </div>
                    </body></text></TEI>