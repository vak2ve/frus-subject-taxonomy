<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>No. 612
                    The Ambassador in the Soviet Union (
                        Harriman
                    ) to the President and the Secretary of State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv01</bibl><bibl type="frus-document-id">d612</bibl><bibl type="frus-document-number">612</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-07-12T00:00:00-05:00" notAfter="1945-07-12T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-07-12T23:59:59-05:00" frus:doc-dateTime-min="1945-07-12T00:00:00-05:00" n="612" subtype="historical-document" type="document" xml:id="d612">
                <note rend="inline" type="source">761.93/7–1245: Telegram</note>
                <head>No. 612<lb/>
                    <hi rend="italic">The Ambassador in the Soviet Union</hi> (<persName corresp="#p_HK1" type="from">
                        <hi rend="italic">Harriman</hi>
                    </persName>) <hi rend="italic">to the President and the <gloss type="to">Secretary of State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Extract]<note n="1" xml:id="d612fn1">For the full text
                            of this message, see <ref target="#d577">document No. 577</ref>.</note>
                    </seg>
                </opener>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                        <lb/>
                        <hi rend="smallcaps">priority</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Moscow</hi>
                        </placeName>,] <date calendar="gregorian" when="1945-07-12">12 July
                            1945</date>.</dateline>
                </opener>
                <p>Personal and top secret for the President and the Secretary of State from
                        <persName corresp="#p_HK1">Harriman</persName>.</p>
                <p rend="center">. . . . . . .</p>
                <p>
                    <persName corresp="#p_STV1">Soong</persName> suggested to <persName corresp="#p_SMIV2">Stalin</persName> that he return to Chungking to consult
                    the Generalissimo over the points still at issue.<note n="2" xml:id="d612fn2">In
                        the Sino-Soviet negotiations being conducted at Moscow. See <ref target="#d577">document No. 577</ref>.</note>
                    <persName corresp="#p_SMIV2">Stalin</persName> however said that it was better
                    to come to agreement before he met you at Berlin as he wished to decide with you
                    date of his entry into the war. …</p>
                <p rend="center">. . . . . . .</p>
            </div>
        </body>
    </text>
</TEI>
