                                <note rend="inline" type="source">740.00119 (Potsdam)/5–2446</note>
                                <head>No. 259<lb/><hi rend="italic">Briefing Book Paper</hi><note n="1" xml:id="d259fn1">Annex 13 to the attachment to <ref target="#d177">document No. 177</ref>.</note>
                                </head>
                                <opener>
                                    <seg rendition="#center">[Extract]<note n="2" xml:id="d259fn2">For other extracts from this paper, see documents Nos.
                                            398 and 509.</note></seg>
                                </opener>
                                <opener>
                                    <seg rendition="#left">
                                        <hi rend="smallcaps">top secret</hi>
                                    </seg>
                                </opener>
                                <p rend="center">
                                    <hi rend="smallcaps">European Territorial Settlements</hi>
                                </p>
                                <p rend="center">
                                    <hi rend="smallcaps">i. germany</hi>
                                </p>
                                <p rend="center">. . . . . . .</p>
                                <p>… We are opposed to revision of the Danish-German frontier unless
                                    such action is considered necessary in connection with a
                                    possible internationalization of the Kiel Canal.</p>
                                <p rend="center">. . . . . . .</p>
                                <closer>
