<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-07-07T06:00:00-05:00" frus:doc-dateTime-min="1945-07-07T06:00:00-05:00" n="129" subtype="historical-document" type="document" xml:id="d129">
                        <note rend="inline" type="source">740.0011 <gloss target="#t_EW1">EW</gloss>/7–745: Telegram</note>
                        <head>No. 129 <lb/>
                            <hi rend="italic">The Political Adviser in Germany</hi> (<persName corresp="#p_MRD1" type="from"><hi rend="italic">Murphy</hi></persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of State</gloss>
                            </hi>
                        </head>
                        <opener>
                            <seg rendition="#left">
                                <hi rend="smallcaps">secret</hi>
                            </seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Hoechst</hi></placeName>, <date calendar="gregorian" when="1945-07-07T14:00:00+03:00">July 7,
                                    1945—2 p.m.</date>
                            </dateline>
                        </opener>
                        <p>124. Your 61, July 5, 11 a.m.<note n="1" xml:id="d129fn1">
                                <ref target="#d125">Document No. 125</ref>.</note>
                        </p>
                        <p>I thank you for your invitation to attend the meeting of the three heads
                            of govt.</p>
                        <p>
                            <persName corresp="#p_CLGLD1">General Clay</persName> and I are
                            proceeding to Berlin this morning and we shall do everything possible to
                            ensure that satisfactory arrangements are made in Berlin for the <gloss target="#t_Dept1">Dept</gloss>’s delegation. I shall hope to
                            telegraph you an account of the situation tomorrow.</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_MRD1">
                                    <hi rend="smallcaps">Murphy</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>