    <text>
        <body>
            <div frus:doc-dateTime-max="1945-05-28T23:59:59-05:00"
                frus:doc-dateTime-min="1945-05-28T00:00:00-05:00" n="37"
                subtype="historical-document" type="document" xml:id="d37">
                <note rend="inline" type="source">
                    <persName corresp="#p_LFAWD1">Leahy</persName> Papers: Telegram</note>
                <head>No. 37 <lb/>
                    <hi rend="italic">President <persName corresp="#p_THS1" type="from"
                            >Truman</persName> to Prime Minister <persName corresp="#p_CMWS1"
                            type="to">Churchill</persName>
                    </hi>
                    <note n="1" xml:id="d37fn1">Presumably sent to the United States Naval Attaché,
                        London, via Navy channels.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Extract]<note n="2" xml:id="d37fn2">For the first two
                            paragraphs of this message, omitted here, see <ref target="#d142"
                                >document No. 142</ref>.</note>
                    </seg>
                </opener>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1945-05-28">28 May
                            1945</date>.</dateline>
                </opener>
                <p>48. …</p>
                <p rend="center">. . . . . . .</p>
                <p>
                    <persName corresp="#p_SMIV2">Stalin</persName> has informed me through Mr.
                        <persName corresp="#p_HHL1">Hopkins</persName> that he would like to have
                    our three party meeting in the Berlin area and I will reply that I have no
                    objection to the Berlin area.</p>
            </div>
        </body>
    </text>
