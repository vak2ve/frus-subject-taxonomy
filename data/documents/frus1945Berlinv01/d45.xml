<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>No. 45 
                    President Truman to Prime Minister Churchill
                    
                    Presumably sent to the United States Naval Attaché,
                        London, via Navy channels.</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv01</bibl><bibl type="frus-document-id">d45</bibl><bibl type="frus-document-number">45</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-06-01T00:00:00-05:00" notAfter="1945-06-01T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-06-01T23:59:59-05:00" frus:doc-dateTime-min="1945-06-01T00:00:00-05:00" n="45" subtype="historical-document" type="document" xml:id="d45">
                <note rend="inline" type="source">
                    <persName corresp="#p_LFAWD1">Leahy</persName> Papers: Telegram</note>
                <head>No. 45 <lb/>
                    <hi rend="italic">President <persName corresp="#p_THS1" type="from">Truman</persName> to Prime Minister <persName corresp="#p_CMWS1" type="to">Churchill</persName>
                    </hi>
                    <note n="1" xml:id="d45fn1">Presumably sent to the United States Naval Attaché,
                        London, via Navy channels.</note>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1945-06-01">1 June
                            1945</date>.</dateline>
                </opener>
                <p>51. Your number 60.<note n="2" xml:id="d45fn2">
                        <ref target="#d44">document No. 44</ref>.</note>
                    <persName corresp="#p_SMIV2">Marshal Stalin</persName> has informed me that he
                    is agreeable to having our forthcoming meeting in the vicinity of Berlin about
                    July fifteenth, which date also seems to be possible from the point of view of
                    my domestic duties. I am looking forward with pleasure to seeing you at that
                    time and with confidence that the meeting will produce results of great value to
                    the future of our world.</p>
            </div>
        </body>
    </text>
