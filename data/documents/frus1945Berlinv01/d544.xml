    <text>
        <body>
            <div frus:doc-dateTime-max="1945-07-12T23:59:59-05:00"
                frus:doc-dateTime-min="1945-07-12T00:00:00-05:00" n="544"
                subtype="historical-document" type="document" xml:id="d544">
                <note rend="inline" type="source">
                    <persName corresp="#p_THS1">Truman</persName> Papers: Telegram</note>
                <head>No. 544<lb/>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Secretary of War</hi> (<persName corresp="#p_SHL1" type="to">
                        <hi rend="italic">Stimson</hi>
                    </persName>)<note n="1" xml:id="d544fn1">It has not been determined whether this
                        message was dispatched first and then superseded by <ref target="#d545"
                            >document No. 545</ref>, or whether <ref target="#d545">document No.
                            545</ref> was dispatched first and then superseded by this
                        message.</note>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">On Board the</hi> U. S. S. “<hi rend="smallcaps"
                                >Augusta</hi>”</placeName>,] <date calendar="gregorian"
                            when="1945-07-12">12 July 1945</date>.</dateline>
                </opener>
                <p>I have received your No. 95<note n="2" xml:id="d544fn2">
                        <ref target="#d543">Document No. 543</ref>.</note> and discussed it with the
                    President. As the question is a complicated one, I suggest we talk it over at
                        <gloss target="#t_Terminal1">
                        <hi rend="smallcaps">Terminal</hi>
                    </gloss>.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BJF1">
                            <hi rend="smallcaps">Byrnes</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
