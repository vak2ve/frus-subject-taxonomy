<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>No. 148 
                    The British Minister (
                        Balfour
                    ) to the Acting Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv01</bibl><bibl type="frus-document-id">d148</bibl><bibl type="frus-document-number">148</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-06-01T00:00:00-05:00" notAfter="1945-06-01T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-06-01T23:59:59-05:00" frus:doc-dateTime-min="1945-06-01T00:00:00-05:00" n="148" subtype="historical-document" type="document" xml:id="d148">
                <note rend="inline" type="source">740.0011 <gloss target="#t_EW1">E.
                    W.</gloss>/6–145</note>
                <head>No. 148 <lb/>
                    <hi rend="italic">The British Minister</hi> (<persName corresp="#p_BJ1" type="from">
                        <hi rend="italic">Balfour</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                        <lb/>
                        <hi rend="smallcaps">personal</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1945-06-01">1st June,
                            1945</date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Under Secretary</hi>, With reference to my
                    letter of May 29th,<note n="1" xml:id="d148fn1">
                        <ref target="#d144">Document No. 144</ref>.</note> Mr. <persName corresp="#p_EA1">Eden</persName> has asked me to tell you that in view of
                        <persName corresp="#p_SMIV2">Marshal Stalin</persName>’s message about
                    surrendered German naval and merchant ships,<note n="2" xml:id="d148fn2">See
                            <ref target="#d386fn2">document No. 386, footnote 2</ref>.</note> His
                    Majesty’s Government propose the addition of the following item to Section 2 of
                    the Agenda for the forthcoming meeting of Heads of Governments: <quote rend="blockquote">
                        <p>“Disposal of German Fleet and Merchant Ships”.<note n="3" xml:id="d148fn3">The substance of this message was forwarded by
                                    <persName corresp="#p_GJC1">Grew</persName> to <persName corresp="#p_THS1">Truman</persName> on June 5.</note>
                        </p>
                    </quote>
                </p>
                <p>Yours very sincerely,</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BJ1">
                            <hi rend="smallcaps">John Balfour</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
