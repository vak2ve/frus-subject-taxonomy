<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>No. 123 
                    The Secretary of State to the
                        Ambassador in the United Kingdom (
                        Winant
                    )</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv01</bibl><bibl type="frus-document-id">d123</bibl><bibl type="frus-document-number">123</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-07-05T09:00:00-05:00" notAfter="1945-07-05T09:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-07-05T09:00:00-05:00" frus:doc-dateTime-min="1945-07-05T09:00:00-05:00" n="123" subtype="historical-document" type="document" xml:id="d123">
                <note rend="inline" type="source">740.0011 <gloss target="#t_EW1">EW</gloss>/6–2945:
                    Telegram</note>
                <head>No. 123 <lb/>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the United Kingdom</hi> (<persName corresp="#p_WJG2" type="to">
                        <hi rend="italic">Winant</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-05T10:00:00-04:00">July 5, 1945—10 a.m.</date>
                    </dateline>
                </opener>
                <p>5446. You may inform the Foreign Office (<hi rend="italic">your 6566, June
                        29</hi>
                    <note n="l" xml:id="d123fnl">
                        <ref target="#d108">Document No. 108</ref>.</note>) that the State
                    Department Delegation to the Big Three meeting will <pb facs="0278" n="146" xml:id="pg_146"/> include Secretary <persName corresp="#p_BJF1">Byrnes</persName>, Assistant Secretaries <persName corresp="#p_DJC1">Dunn</persName> and <persName corresp="#p_CWL1">Clayton</persName>,
                    Ambassadors <persName corresp="#p_MRD1">Murphy</persName> and <persName corresp="#p_HWA2">Harriman</persName>, <persName corresp="#p_MHF1">H. F.
                        Matthews</persName>, Director of the Office of European Affairs, and several
                    specialists on European and Far Eastern political and economic matters.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BJF1">
                            <hi rend="smallcaps">Byrnes</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
