    <text>
        <body>
            <div frus:doc-dateTime-max="1945-06-06T23:59:59-05:00"
                frus:doc-dateTime-min="1945-06-06T00:00:00-05:00" n="53"
                subtype="historical-document" type="document" xml:id="d53">
                <note rend="inline" type="source">
                    <persName corresp="#p_LFAWD1">Leahy</persName> Papers: Telegram</note>
                <head>No. 53 <lb/>
                    <hi rend="italic">Prime Minister <persName corresp="#p_CMWS1" type="from"
                            >Churchill</persName> to President <persName corresp="#p_THS1" type="to"
                            >Truman</persName>
                    </hi>
                    <note n="1" xml:id="d53fn1">Sent by the United States Military Attaché, London,
                        via Army channels.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1945-06-06">6 June
                            1945</date>.</dateline>
                </opener>
                <p>Prime Minister to President <persName corresp="#p_THS1">Truman</persName>,
                    personal and top secret, Number 75.</p>
                <p>Your Number 61.<note n="2" xml:id="d53fn2">
                        <ref target="#d51">document No. 51</ref>.</note> I accept July 15 and am
                    telling <persName corresp="#p_SMIV2">Stalin</persName>.<note n="3"
                        xml:id="d53fn3">See <hi rend="italic">
                            <persName corresp="#p_SMIV2">Stalin</persName>’s Correspondence</hi>,
                        vol. <hi rend="smallcaps">i</hi>, p. 363.</note>
                </p>
                <p rend="center">. . . . . . .</p>
            </div>
        </body>
    </text>
