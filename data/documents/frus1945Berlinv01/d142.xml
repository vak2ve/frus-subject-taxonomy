    <text>
        <body>
            <div frus:doc-dateTime-max="1945-05-28T23:59:59-05:00"
                frus:doc-dateTime-min="1945-05-28T00:00:00-05:00" n="142"
                subtype="historical-document" type="document" xml:id="d142">
                <note rend="inline" type="source">
                    <persName corresp="#p_LFAWD1">Leahy</persName> Papers: Telegram</note>
                <head>No. 142 <lb/>
                    <hi rend="italic">President <persName corresp="#p_THS1" type="from"
                            >Truman</persName> to Prime Minister <persName corresp="#p_CMWS1"
                            type="to">Churchill</persName>
                    </hi>
                    <note n="1" xml:id="d142fn1">Presumably sent to the United States Naval Attaché
                        London, via Navy channels.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1945-05-28">28 May
                            1945</date>.</dateline>
                </opener>
                <p>48. Your messages 55<note n="2" xml:id="d142fn2">Not printed herein.</note> and
                        56<note n="3" xml:id="d142fn3">
                        <ref target="#d141">Document No. 141</ref>.</note> received.</p>
                <p>I am in general agreement with your reply to <persName corresp="#p_SMIV2"
                        >Stalin</persName> regarding surrendered German naval and merchant ships and
                    I will send him a similar message.<note n="4" xml:id="d142fn4">See <ref
                            target="#d143">document No. 143</ref>. For the final paragraph of this
                        message, omitted here, see <ref target="#d37">document No. 37</ref>.</note>
                </p>
                <p rend="center">. . . . . . .</p>
            </div>
        </body>
    </text>
