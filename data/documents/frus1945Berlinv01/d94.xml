<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>No. 94 
                    The Ambassador in the Soviet Union (
                        Harriman
                    ) to the President’s Chief of Staff (
                        Leahy
                    )Sent by the United States Naval Attaché,
                        Moscow, via Navy channels.</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv01</bibl><bibl type="frus-document-id">d94</bibl><bibl type="frus-document-number">94</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-06-24T00:00:00-05:00" notAfter="1945-06-24T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-06-24T23:59:59-05:00" frus:doc-dateTime-min="1945-06-24T00:00:00-05:00" n="94" subtype="historical-document" type="document" xml:id="d94">
                <note rend="inline" type="source">
                    <persName corresp="#p_LFAWD1">Leahy</persName> Papers: Telegram</note>
                <head>No. 94 <lb/>
                    <hi rend="italic">The Ambassador in the Soviet Union</hi> (<persName corresp="#p_HWA2" type="from">
                        <hi rend="italic">Harriman</hi>
                    </persName>) <hi rend="italic">to the President’s Chief of Staff</hi> (<persName corresp="#p_LFAWD1" type="to">
                        <hi rend="italic">Leahy</hi>
                    </persName>)<note n="1" xml:id="d94fn1">Sent by the United States Naval Attaché,
                        Moscow, via Navy channels.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                        <lb/>
                        <hi rend="smallcaps">routine</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Moscow</hi>
                        </placeName>, <date calendar="gregorian" when="1945-06-24">24 June
                            1945</date>.</dateline>
                </opener>
                <p>(Personal and top secret for <persName corresp="#p_LFAWD1">Admiral
                        Leahy</persName> from <persName corresp="#p_HWA2">Harriman</persName>.)</p>
                <p>
                    <persName corresp="#p_MVM1">Molotov</persName> told me last night that he had
                    consulted <persName corresp="#p_SMIV2">Marshal Stalin</persName> (re your White
                    House Number 300 Navy Number 201630 June 20<note n="2" xml:id="d94fn2">See <ref target="#d79">document No. 79</ref>.</note>) and that the latter had no
                    objection whatsoever to the President bringing his Chiefs of Staff with him to
                    Berlin.</p>
            </div>
        </body>
    </text>
