<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-07-03T23:59:59-05:00" frus:doc-dateTime-min="1945-07-03T00:00:00-05:00" n="114" subtype="historical-document" type="document" xml:id="d114">
                        <note rend="inline" type="source">
                            <persName corresp="#p_LFAWD1">Leahy</persName> Papers: Telegram</note>
                        <head>No. 114 <lb/>
                            <hi rend="italic">The <gloss type="from">President</gloss> to the
                                Ambassador in the Soviet Union</hi> (<persName corresp="#p_HWA2" type="to"><hi rend="italic">Harriman</hi></persName>)<note n="1" xml:id="d114fn1">Presumably sent to the United States Naval Attaché
                                Moscow, via Navy channels.</note>
                        </head>
                        <opener>
                            <seg rendition="#left">
                                <hi rend="smallcaps">top secret</hi>
                            </seg>
                            <dateline rendition="#right">[<placeName><hi rend="smallcaps">Washington</hi></placeName>,] <date calendar="gregorian" when="1945-07-03">3 July 1945</date>.</dateline>
                        </opener>
                        <p>
                            <persName corresp="#p_PEW1">Pauley</persName>, Dr. <persName corresp="#p_LI1">Lubin</persName> and four assistants are authorized
                            to report to President on proposed reparation plan during forthcoming
                            meeting.</p>
                        <p>Army has been notified.</p>
                    </div>
                    </body></text></TEI>