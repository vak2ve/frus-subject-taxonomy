<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>No. 491
                    The Ambassador in Italy
                     (
                        Kirk
                    ) to the Secretary of
                            State ad interim</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv01</bibl><bibl type="frus-document-id">d491</bibl><bibl type="frus-document-number">491</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-06-28T05:00:00-05:00" notAfter="1945-06-28T05:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-06-28T05:00:00-05:00" frus:doc-dateTime-min="1945-06-28T05:00:00-05:00" n="491" subtype="historical-document" type="document" xml:id="d491">
                <note rend="inline" type="source">860c.01/6–2845: Telegram</note>
                <head>No. 491<lb/>
                    <hi rend="italic">The Ambassador in <persName corresp="#p_I2">Italy</persName>
                    </hi> (<persName corresp="#p_KA1" type="from">
                        <hi rend="italic">Kirk</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss> ad interim</hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Caserta</hi>
                        </placeName>, <date calendar="gregorian" when="1945-06-28T12:00:00+02:00">June 28, 1945—noon</date>.</dateline>
                </opener>
                <p>2795. <persName corresp="#p_BP1">Broad</persName> showed us a tel he has just
                        <gloss target="#t_recd1">recd</gloss> from <gloss target="#t_ForOff1">ForOff</gloss> instructing him if <gloss target="#t_SAC1">SAC</gloss>
                    <note n="1" xml:id="d491fn1">
                        <persName corresp="#p_AFMSH1">Field Marshal Sir Harold
                        Alexander</persName>.</note> perceived no objection to proceeding Polish
                        <gloss target="#t_GHQs1">GHQs</gloss> in <persName corresp="#p_I2">Italy</persName> and explain to Gen <persName corresp="#p_ALGW1">Anders</persName> in as favorable a manner as possible why Poles abroad
                    should welcome formation of new Pole Govt. <gloss target="#t_ForOff1">ForOff</gloss> was [<hi rend="italic">has</hi>] authorized <persName corresp="#p_BP1">Broad</persName> to give to <persName corresp="#p_ALGW1">Anders</persName> story of Moscow negotiations more or less as outlined in
                        <gloss target="#t_Depcirtels1">Depcirtels</gloss> on this subject<note n="2" xml:id="d491fn2">Not printed.</note> and to point out obvious advantages
                    accruing to Poland by constitution of new Govt. …</p>
                <p>Sent <gloss target="#t_Dept1">Dept</gloss>, <gloss target="#t_rptd1">rptd</gloss>
                    Moscow 188.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_KA1">
                            <hi rend="smallcaps">Kirk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
