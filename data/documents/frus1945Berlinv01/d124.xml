    <text>
        <body>
            <div frus:doc-dateTime-max="1945-07-05T09:00:00-05:00"
                frus:doc-dateTime-min="1945-07-05T09:00:00-05:00" n="124"
                subtype="historical-document" type="document" xml:id="d124">
                <note rend="inline" type="source">740.0011 <gloss target="#t_EW1">EW</gloss>/7–545:
                    Telegram</note>
                <head>No. 124 <lb/>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in the Soviet Union</hi> (<persName corresp="#p_HWA2" type="to">
                        <hi rend="italic">Harriman</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-05T10:00:00-04:00"
                            >July 5, 1945—10 a.m.</date>
                    </dateline>
                </opener>
                <p>1521. I should like to invite you to be present at the forthcoming meeting of the
                    three Heads of Government. <persName corresp="#p_PEJ1">Page</persName> should
                    accompany you. State Department party expects to arrive in Berlin July 13.</p>
                <p rend="center">. . . . . . .</p>
                <closer>
                    <signed>
                        <persName corresp="#p_BJF1">
                            <hi rend="smallcaps">Byrnes</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
