    <text>
        <body>
            <div frus:doc-dateTime-max="1945-06-25T13:00:00-05:00"
                frus:doc-dateTime-min="1945-06-25T13:00:00-05:00" n="657"
                subtype="historical-document" type="document" xml:id="d657">
                <note rend="inline" type="source">881.00/6–2545: Telegram</note>
                <head>No. 657 <lb/>
                    <hi rend="italic">The Ambassador in the United Kingdom</hi> (<persName
                        corresp="#p_WJG2" type="from">
                        <hi rend="italic">Winant</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Acting Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                        <lb/>
                        <hi rend="smallcaps">us urgent</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1945-06-25T20:00:00+02:00"
                            >June 25, 1945—8 p.m.</date>
                    </dateline>
                </opener>
                <p>6403. French Govt being informed by British Embassy Paris that British Govt
                    agreeable to Paris meeting re Tangier. Details of communication to USSR expected
                    to be concerted Paris at once and we will be promptly informed when
                    communications made.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WJG2">
                            <hi rend="smallcaps">Winant</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
