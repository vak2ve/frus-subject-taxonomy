<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-06-11T23:59:59-05:00" frus:doc-dateTime-min="1945-06-11T00:00:00-05:00" n="56" subtype="historical-document" type="document" xml:id="d56">
                        <note rend="inline" type="source">
                            <persName corresp="#p_LFAWD1">Leahy</persName> Papers: Telegram</note>
                        <head>No. 56 <lb/>
                            <hi rend="italic">President <persName corresp="#p_THS1" type="from">Truman</persName> to Prime Minister <persName corresp="#p_CMWS1" type="to">Churchill</persName>
                            </hi><note n="1" xml:id="d56fn1">Presumably sent to the United States
                                Naval Attaché, London, via Navy channels.</note>
                        </head>
                        <opener>
                            <seg rendition="#left">
                                <hi rend="smallcaps">top secret</hi>
                            </seg>
                            <dateline rendition="#right">[<placeName><hi rend="smallcaps">Washington</hi></placeName>,] <date calendar="gregorian" when="1945-06-11">11 June 1945</date>.</dateline>
                        </opener>
                        <p>67. Your 82.<note n="2" xml:id="d56fn2">
                                <ref target="#d55">document No. 55</ref>.</note> I am in agreement
                            and will instruct <persName corresp="#p_EGADD1">Eisenhower</persName> to
                            make the necessary arrangements to accomplish your expressed
                                desires.<note n="3" xml:id="d56fn3">
                                <p>On June 12, in telegram No. <gloss target="#t_W1">W</gloss>–15519, General of the Army <persName corresp="#p_MGAGC1">George C. Marshall</persName> sent to
                                        <persName corresp="#p_EGADD1">Eisenhower</persName> the text
                                    of the final paragraph of <ref target="#d55">document No.
                                        55</ref>, prefaced with the following instruction
                                    (Department of the Army Files): <quote rend="blockquote">
                                        <p>“The <hi rend="smallcaps">President</hi> directs that you
                                            make necessary advance arrangements to accomplish the
                                            desires expressed in the following quoted message from
                                                <persName corresp="#p_CMWS1">
                                                <hi rend="smallcaps">Churchill</hi>
                                            </persName> with which he is in agreement.”</p>
                                    </quote>
                                </p>
                            </note>
                        </p>
                    </div>
                    </body></text></TEI>