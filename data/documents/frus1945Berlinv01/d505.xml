<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0">
    <teiHeader><fileDesc><titleStmt><title>No. 505
                    The Ambassador in the United Kingdom (
                        Winant
                    ) to the Secretary of
                            State</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv01</bibl><bibl type="frus-document-id">d505</bibl><bibl type="frus-document-number">505</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-07-05T05:00:00-05:00" notAfter="1945-07-05T05:00:00-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-07-05T05:00:00-05:00" frus:doc-dateTime-min="1945-07-05T05:00:00-05:00" n="505" subtype="historical-document" type="document" xml:id="d505">
                <note rend="inline" type="source">860c.01/7–545: Telegram</note>
                <head>No. 505<lb/>
                    <hi rend="italic">The Ambassador in the United Kingdom</hi> (<persName corresp="#p_WJG2" type="from">
                        <hi rend="italic">Winant</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Extract]</seg>
                </opener>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">secret</hi>
                    </seg>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1945-07-05T12:00:00+02:00">July 5, 1945—noon</date>.</dateline>
                </opener>
                <p>6749. …</p>
                <p>Same [British] official<note n="1" xml:id="d505fn1">Not identified.</note> said
                    that <gloss target="#t_FonOff1">FonOff</gloss> had concluded yesterday with
                    Polish Govt in London agreement whereby all leases, including lease on Polish
                        <gloss target="#t_Emb1">Emb</gloss> property, would be taken over by Brit
                    Govt. Most leases are of short duration but Brit Govt will turn them over to new
                    Polish Govt if it so desires or will continue them on own account.</p>
                <p rend="center">. . . . . . .</p>
                <closer>
                    <signed>
                        <persName corresp="#p_WJG2">
                            <hi rend="smallcaps">Winant</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
</TEI>
