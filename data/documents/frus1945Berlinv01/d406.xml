<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-07-04T13:00:00-05:00" frus:doc-dateTime-min="1945-07-04T13:00:00-05:00" n="406" subtype="historical-document" type="document" xml:id="d406">
                                <note rend="inline" type="source">740.00119 <gloss target="#t_EAC1">EAC</gloss>/7–445: Telegram</note>
                                <head>No. 406<lb/><hi rend="italic">The Ambassador in the United
                                        Kingdom</hi> (<persName corresp="#p_WJG2" type="from"><hi rend="italic">Winant</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss>
                                    </hi>
                                </head>
                                <opener>
                                    <seg rendition="#left">
                                        <hi rend="smallcaps">secret</hi>
                                        <lb/>
                                        <hi rend="smallcaps">us urgent―niact</hi>
                                    </seg>
                                    <dateline rendition="#right">
                                        <placeName>
                                            <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1945-07-04T20:00:00+02:00">July 4, 1945—8 p.m.</date>
                                    </dateline>
                                </opener>
                                <p>6740. <hi rend="smallcaps">Comea</hi> 318. Today <gloss target="#t_EAC1">EAC</gloss> approved in substance draft
                                    agreement on French zone in Germany. Texts to be checked
                                    tomorrow by experts subcommittee preparatory to signature.</p>
                                <p>Sent <gloss target="#t_Dept1">Dept</gloss> 6740; <gloss target="#t_rptd1">rptd</gloss> Paris 435 secret for
                                        <persName corresp="#p_CJ1">Caffery</persName> and <persName corresp="#p_MRE1">Murphy</persName>.</p>
                                <closer>
                                    <signed>
                                        <persName corresp="#p_WJG2">
                                            <hi rend="smallcaps">Winant</hi>
                                        </persName>
                                    </signed>
                                </closer>
                            </div>
                            </body></text></TEI>