    <text>
        <body>
            <div frus:doc-dateTime-max="1945-07-09T23:59:59-05:00"
                frus:doc-dateTime-min="1945-07-09T00:00:00-05:00" n="204"
                subtype="historical-document" type="document" xml:id="d204">
                <note rend="inline" type="source">
                    <persName corresp="#p_THS1">Truman</persName> Papers: Telegram</note>
                <head>No. 204 <lb/>
                    <hi rend="italic">The President’s Chief of Staff</hi> (<persName
                        corresp="#p_LFAWD1" type="from">
                        <hi rend="italic">Leahy</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">White House Map
                            Room</gloss>
                    </hi>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">On Board the</hi> U. S. S. “<hi rend="smallcaps"
                                >Augusta</hi>”</placeName>,] <date calendar="gregorian"
                            when="1945-07-09">9 July 1945</date>.</dateline>
                </opener>
                <p>
                    <gloss target="#t_MR1">MR</gloss>–<hi rend="smallcaps">in</hi>–19. Send messages
                    from Ambassador <persName corresp="#p_HWA2">Harriman</persName>
                    <gloss target="#t_MR1">MR</gloss>–<hi rend="smallcaps">out</hi>–64 and 65<note
                        n="1" xml:id="d204fn1">For one of these messages, see <ref target="#d203"
                            >document No. 203</ref>. The other message (not printed) did not
                        recommend preparation of any study for use at the Berlin Conference.</note>
                    to <persName corresp="#p_GJC1">Grew</persName> with information that Secretary
                        <persName corresp="#p_BJF1">Byrnes</persName> wishes him to prepare the
                    studies recommended therein.<note n="2" xml:id="d204fn2">See <ref target="#d252"
                            >documents Nos. 252</ref>, <ref target="#d253">253</ref>, and <ref
                            target="#d579">579</ref>.</note>
                </p>
                <p rend="center">. . . . . . .</p>
            </div>
        </body>
    </text>
