<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-07-13T23:59:59-05:00" frus:doc-dateTime-min="1945-07-13T00:00:00-05:00" n="215" subtype="historical-document" type="document" xml:id="d215">
                        <note rend="inline" type="source">Moscow Embassy Files—500 Berlin
                            Conference</note>
                        <head>No. 215 <lb/>
                            <hi rend="italic">Mr. <persName corresp="#p_PVN1" type="from">V. N.
                                    Pavlov</persName>, of the Soviet Foreign Commissariat, to the
                                First Secretary of Embassy in the Soviet Union</hi> (<persName corresp="#p_PEJ1" type="to"><hi rend="italic">Page</hi></persName>)</head>
                        <opener>
                            <seg rendition="#center">[Translation]</seg>
                        </opener>
                        <opener>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">Moscow</hi></placeName>, <date calendar="gregorian" when="1945-07-13">July 13,
                                1945</date>.</dateline>
                        </opener>
                        <p>
                            <hi rend="smallcaps">Dear Mr. <persName corresp="#p_PEJ1">Page</persName></hi>: At the instruction of the People’s
                            Commissar I request you to inform Mr. <persName corresp="#p_HWA1">W. A.
                                Harriman</persName> that <persName corresp="#p_MVM1">V. M.
                                Molotov</persName> has received his letter of July 12<note n="1" xml:id="d215fn1">For the full text of this message, see <ref target="#d312">document No. 312</ref>.</note> regarding
                            consideration of the reparations problem at the forthcoming meeting of
                            the heads of the three governments.</p>
                        <p>Respectfully yours,</p>
                        <closer>
                            <signed>
                                <persName corresp="#p_PVN1">
                                    <hi rend="smallcaps">Pavlov</hi>
                                </persName>
                            </signed>
                        </closer>
                    </div>
                    </body></text></TEI>