                <keywords scheme="frus-subject-taxonomy">
                    <term ref="rec1c8936cc6bb154a" type="topic" category="warfare" subcategory="world-war-ii" subject="yalta-agreement">Yalta Agreement</term>
                    <term ref="reclX4mzFRYzavuL4" type="topic" category="global-issues" subcategory="elections" subject="free-elections" lcsh-match="no_match">Free elections</term>
                </keywords>
