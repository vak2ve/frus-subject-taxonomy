<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-07-08T12:00:00-05:00" frus:doc-dateTime-min="1945-07-08T12:00:00-05:00" n="409" subtype="historical-document" type="document" xml:id="d409">
                                <note rend="inline" type="source">740.00119 <gloss target="#t_EAC1">EAC</gloss>/7–845: Telegram</note>
                                <head>No. 409<lb/><hi rend="italic">The <gloss type="from">Acting
                                            Secretary of State</gloss> to the Ambassador in the
                                        United Kingdom</hi> (<persName corresp="#p_WJG2" type="to"><hi rend="italic">Winant</hi></persName>)</head>
                                <opener>
                                    <seg rendition="#left">
                                        <hi rend="smallcaps">secret</hi>
                                        <lb/>
                                        <hi rend="smallcaps">us urgent—niact</hi>
                                    </seg>
                                    <dateline rendition="#right">
                                        <placeName>
                                            <hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1945-07-08T13:00:00-04:00">July 8, 1945—1 p.m.</date>
                                    </dateline>
                                </opener>
                                <p>5561. You are authorized to accept the Soviet proposal to omit
                                    final sentence of report accompanying agreement re French zone
                                    in Germany. (Your <hi rend="smallcaps">Comeas</hi> 324<note n="1" xml:id="d409fn1">
                                        <ref target="#d407">Document No. 407</ref>.</note> and
                                        327<note n="2" xml:id="d409fn2">
                                        <ref target="#d408">Document No. 408</ref>.</note>)</p>
                                <closer>
                                    <signed>
                                        <persName corresp="#p_GJC1">
                                            <hi rend="smallcaps">Grew</hi>
                                        </persName>
                                        <lb/>
                                        <persName corresp="#p_LHP1">H[enryl P L[everich]</persName>
                                    </signed>
                                </closer>
                            </div>
                            </body></text></TEI>