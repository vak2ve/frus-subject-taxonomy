<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-06-16T23:59:59-05:00" frus:doc-dateTime-min="1945-06-16T00:00:00-05:00" n="71" subtype="historical-document" type="document" xml:id="d71">
                        <note rend="inline" type="source">
                            <persName corresp="#p_LFAWD1">Leahy</persName> Papers: Telegram</note>
                        <head>No. 71 <lb/>
                            <hi rend="italic">President <persName corresp="#p_THS1" type="from">Truman</persName> to Prime Minister <persName corresp="#p_CMWS1" type="to">Churchill</persName>
                            </hi><note n="1" xml:id="d71fn1">Presumably sent to the United States
                                Naval Attaché, London, via Navy channels.</note>
                        </head>
                        <opener>
                            <seg rendition="#center">[Extract]</seg>
                        </opener>
                        <opener>
                            <seg rendition="#left">
                                <hi rend="smallcaps">top secret</hi>
                            </seg>
                            <dateline rendition="#right">[<placeName><hi rend="smallcaps">Washington</hi></placeName>,] <date calendar="gregorian" when="1945-06-16">16 June 1945</date>.</dateline>
                        </opener>
                        <p>76. Replying to your No. 92,<note n="2" xml:id="d71fn2">
                                <ref target="#d64">document No. 64</ref>.</note> I will be very
                            pleased to agree to any arrangements you may make to accomplish His
                            Majesty’s desires during his projected visit in Berlin.</p>
                        <p rend="center">. . . . . . .</p>
                    </div>
                    </body></text></TEI>