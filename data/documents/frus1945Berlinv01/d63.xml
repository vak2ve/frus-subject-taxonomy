    <text>
        <body>
            <div frus:doc-dateTime-max="1945-06-15T23:59:59-05:00"
                frus:doc-dateTime-min="1945-06-15T00:00:00-05:00" n="63"
                subtype="historical-document" type="document" xml:id="d63">
                <note rend="inline" type="source">
                    <persName corresp="#p_LFAWD1">Leahy</persName> Papers: Telegram</note>
                <head>No. 63 <lb/>
                    <hi rend="italic">President <persName corresp="#p_THS1" type="from"
                            >Truman</persName> to Prime Minister <persName corresp="#p_CMWS1"
                            type="to">Churchill</persName>
                    </hi>
                    <note n="1" xml:id="d63fn1">Presumably sent to the United States Naval Attaché,
                        London, via Navy channels.</note>
                </head>
                <opener>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1945-06-15">15 June
                            1945</date>.</dateline>
                </opener>
                <p>74. Your number 89<note n="2" xml:id="d63fn2">
                        <ref target="#d62">document No. 62</ref>.</note> meets with my
                        approval.<note n="3" xml:id="d63fn3">
                        <persName corresp="#p_LFAWD1">Leahy</persName> notified the Secretary of
                        State on June 15 that the President had approved the code word <gloss
                            target="#t_Terminal1">
                            <hi rend="smallcaps">Terminal</hi>
                        </gloss> for the forthcoming tripartite conference (file No. 740.00119
                        (Potsdam)/6–1545).</note>
                </p>
            </div>
        </body>
    </text>
