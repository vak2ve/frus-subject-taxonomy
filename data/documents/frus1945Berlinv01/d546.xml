                    <term ref="rec9429801e8b840d1" type="topic" category="foreign-economic-policy" subcategory="foreign-aid" subject="lend-lease">Lend-Lease</term>
                    <term ref="rec3ed041a56810f4c" type="topic" category="warfare" subcategory="general" subject="war">War</term>
                </keywords>
