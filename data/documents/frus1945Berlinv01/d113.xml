<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1945-07-01T23:59:59-05:00" frus:doc-dateTime-min="1945-07-01T00:00:00-05:00" n="113" subtype="historical-document" type="document" xml:id="d113">
                        <note rend="inline" type="source">
                            <persName corresp="#p_LFAWD1">Leahy</persName> Papers: Telegram</note>
                        <head>No. 113 <lb/>
                            <hi rend="italic">Prime Minister <persName corresp="#p_CMWS1" type="from">Churchill</persName> to President <persName corresp="#p_THS1" type="to">Truman</persName>
                            </hi><note n="1" xml:id="d113fn1">Sent by the United States Military
                                Attaché, London, via Army channels. <ref target="#d71">Document No.
                                    71</ref>.</note>
                        </head>
                        <opener>
                            <seg rendition="#left">
                                <hi rend="smallcaps">top secret</hi>
                            </seg>
                            <dateline rendition="#right">
                                <placeName>
                                    <hi rend="smallcaps">London</hi></placeName>, <date calendar="gregorian" when="1945-07-01">1 July
                                1945</date>.</dateline>
                        </opener>
                        <p>Prime Minister to President <persName corresp="#p_THS1">Truman</persName>. Personal, private and top secret. No. 99.</p>
                        <p>Your Number 76.<note n="2" xml:id="d113fn2">
                                <ref target="#d71">Document No. 71</ref>.</note>
                        </p>
                        <p>The King has now decided he must visit Ulster in the period during the
                            Berlin conference and therefore your kind telegram on this subject would
                            have no application. You will no doubt have received His Majesty’s
                            invitation to visit this island.<note n="3" xml:id="d113fn3">Not
                                printed.</note>
                        </p>
                    </div>
                    </body></text></TEI>