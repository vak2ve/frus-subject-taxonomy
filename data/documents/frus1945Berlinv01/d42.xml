    <text>
        <body>
            <div frus:doc-dateTime-max="1945-05-30T23:59:59-05:00"
                frus:doc-dateTime-min="1945-05-30T00:00:00-05:00" n="42"
                subtype="historical-document" type="document" xml:id="d42">
                <note rend="inline" type="source">
                    <persName corresp="#p_THS1">Truman</persName> Papers</note>
                <head>No. 42 <lb/>
                    <hi rend="italic">
                        <persName corresp="#p_SMIV2" type="from">Marshal Stalin</persName> to
                        President <persName corresp="#p_THS1" type="to">Truman</persName>
                    </hi>
                    <note n="1" xml:id="d42fn1">Russian original, accompanied by this translation,
                        transmitted by the Soviet Embassy, Washington.</note>
                </head>
                <opener>
                    <seg rendition="#center">[Translation]</seg>
                </opener>
                <p>Secret and personal from Premier <persName corresp="#p_SMIV2">J. V.
                        Stalin</persName> to President <persName corresp="#p_THS1">H. S.
                        Truman</persName>.</p>
                <p>Mr. <persName corresp="#p_HHL1">Hopkins</persName> has transmitted [to] me today
                    your proposal regarding the meeting of the three.<note n="2" xml:id="d42fn2">See
                            <ref target="#d38">document No. 38</ref>.</note> I have no objections
                    against the proposed by you date—July 15th.</p>
                <closer>
                    <dateline rendition="#left">[<placeName>
                            <hi rend="smallcaps">Moscow</hi>
                        </placeName>,] <date calendar="gregorian" when="1945-05-30">May 30,
                            1945</date>.</dateline>
                </closer>
            </div>
        </body>
    </text>
