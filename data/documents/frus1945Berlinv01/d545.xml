                    )</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv01</bibl><bibl type="frus-document-id">d545</bibl><bibl type="frus-document-number">545</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-07-12T00:00:00-05:00" notAfter="1945-07-12T23:59:59-05:00"/></setting></settingDesc>            <textClass>
