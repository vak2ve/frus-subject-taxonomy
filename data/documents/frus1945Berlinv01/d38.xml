    <teiHeader><fileDesc><titleStmt><title>No. 38 
                    The President to the President’s
                        Adviser and Assistant (
                        Hopkins
                    )Presumably sent to the United States
                        Naval Attaché, Moscow, via Navy channels.</title></titleStmt><sourceDesc><bibl type="frus-volume-id">frus1945Berlinv01</bibl><bibl type="frus-document-id">d38</bibl><bibl type="frus-document-number">38</bibl><bibl type="frus-div-subtype">historical-document</bibl></sourceDesc></fileDesc><profileDesc><settingDesc><setting><date notBefore="1945-05-28T00:00:00-05:00" notAfter="1945-05-28T23:59:59-05:00"/></setting></settingDesc></profileDesc></teiHeader><text>
        <body>
            <div frus:doc-dateTime-max="1945-05-28T23:59:59-05:00" frus:doc-dateTime-min="1945-05-28T00:00:00-05:00" n="38" subtype="historical-document" type="document" xml:id="d38">
                <note rend="inline" type="source">
                    <persName corresp="#p_LFAWD1">Leahy</persName> Papers: Telegram</note>
                <head>No. 38 <lb/>
                    <hi rend="italic">The <gloss type="from">President</gloss> to the President’s
                        Adviser and Assistant</hi> (<persName corresp="#p_HHL1" type="to">
                        <hi rend="italic">Hopkins</hi>
                    </persName>)<note n="1" xml:id="d38fn1">Presumably sent to the United States
                        Naval Attaché, Moscow, via Navy channels.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1945-05-28">28 May
                            1945</date>.</dateline>
                </opener>
                <p>274. Your messages 262101<note n="2" xml:id="d38fn2">Not printed.</note> and
                        272211<note n="3" xml:id="d38fn3">
                        <ref target="#d36">document No. 36</ref>.</note> received.</p>
                <p>You may inform <persName corresp="#p_SMIV2">Stalin</persName> that I perceive no
                    objection to meeting in the Berlin area and that about the 15th of July appears
                    to be a practicable date for me.<note n="4" xml:id="d38fn4">See <hi rend="italic">ante</hi>, <ref target="#pg_53">p. 53</ref>.</note>
                </p>
            </div>
        </body>
    </text>
</TEI>
