    <text>
        <body>
            <div frus:doc-dateTime-max="1945-05-29T23:59:59-05:00"
                frus:doc-dateTime-min="1945-05-29T00:00:00-05:00" n="40"
                subtype="historical-document" type="document" xml:id="d40">
                <note rend="inline" type="source">
                    <persName corresp="#p_LFAWD1">Leahy</persName> Papers: Telegram</note>
                <head>No. 40 <lb/>
                    <hi rend="italic">President <persName corresp="#p_THS1" type="from"
                            >Truman</persName> to Prime Minister <persName corresp="#p_CMWS1"
                            type="to">Churchill</persName>
                    </hi>
                    <note n="1" xml:id="d40fn1">Presumably sent to the United States Naval Attaché
                        London, via Navy channels.</note>
                </head>
                <opener>
                    <seg rendition="#left">
                        <hi rend="smallcaps">top secret</hi>
                    </seg>
                    <dateline rendition="#right">[<placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>,] <date calendar="gregorian" when="1945-05-29">29 May
                            1945</date>.</dateline>
                </opener>
                <p>49. Your No. 58<note n="2" xml:id="d40fn2">
                        <ref target="#d39">document No. 39</ref>.</note> received. I am now making a
                    study of a possible date for our three party meeting and hope to have further
                    information on the subject in the not distant future.</p>
            </div>
        </body>
    </text>
