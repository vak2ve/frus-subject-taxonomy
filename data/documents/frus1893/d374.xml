    <text>
        <body>
            <div frus:doc-dateTime-max="1893-03-03T23:59:59-05:00" frus:doc-dateTime-min="1893-03-03T00:00:00-05:00" n="374" subtype="historical-document" type="document" xml:id="d374">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Durham</persName> to Mr.
                                <persName type="to">Wharton</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of
                                    the United States</hi>,<lb/>
                            <hi rend="italic">Port au
                                    Prince</hi>
                        </placeName>, <date calendar="gregorian" when="1893-03-03">
                            <hi rend="italic">March 3, 1893</hi>
                        </date>.
                            (Received March 20.)</dateline>
                    <seg rendition="#left">No. 173.]</seg>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have to confirm my telegram of to-day,
                        informing yon that the President of Haiti had offered me $6,000 in
                        settlement of the Mevs case, and that I propose to accept.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John S. Durham</hi>.</signed>
                </closer>
            </div>
        </body>
