                subtype="historical-document" type="document" xml:id="d47">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Strobel</persName> to Mr. <persName
                            type="to">Thompson</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1893-09-28">
                            <hi rend="italic">September 28, 1893</hi>
                        </date>.</dateline>
                </opener>
                <p>Mr. Strobel, Acting Secretary, directs Mr. Thompson, at the request of the Navy
                    Department, to furnish the commanding officer of the U. S. S. <hi rend="italic"
                        >Charleston</hi> with a copy of order to the effect that further destruction
                    and bloodshed should be prevented by the exertion of all the moral force of the
                    Government of the United States, by protest and otherwise, and that the
                    protection of American persons and property should be made the object of every
                    possible effort.</p>
            </div>
        </body>
