                subtype="historical-document" type="document" xml:id="d433">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Wharton</persName> to Señor
                            <persName type="to">Cayetano Romero</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1893-02-23">
                            <hi rend="italic">February 23, 1893</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Bomero</hi>: I beg to say, for your
                    information, that according to a letter of 20th instant from the War Department,
                    Deputy U. S. Marshal Martiniarard, arrested on the 10th instant at San Ignacio,
                    Tex., Isidoc Ereda and Quiocino, supposed to have aided the bandits who have
                    lately disturbed the peace of Mexico.</p>
                <p>They have been held.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">William F. Wharton</hi>,<lb/>
                        <hi rend="italic">Acting Secretary.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
