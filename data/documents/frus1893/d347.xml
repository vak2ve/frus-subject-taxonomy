                subtype="historical-document" type="document" xml:id="d347">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Sir <persName
                            type="to">Julian Pauncefote</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1893-12-04">
                            <hi rend="italic">December 4, 1893</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: With regard to your note of August 9,
                    1893, of which acknowledgement has been hitherto unavoidably deferred, I have
                    now the pleasure to inform you that the President will feel great satisfaction
                    in bringing to the knowledge of the Congress, in his forthcoming annual message,
                    mutual accord, given to the world conspicuous illustration on several recent
                    occasions.</p>
                <p>I have, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. Q. Gresham.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
