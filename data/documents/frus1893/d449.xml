    <text>
        <body>
            <div frus:doc-dateTime-max="1893-06-15T23:59:59-05:00"
                frus:doc-dateTime-min="1893-06-15T00:00:00-05:00" n="449"
                subtype="historical-document" type="document" xml:id="d449">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Señor
                            <persName type="to">Romero</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1893-06-15">
                            <hi rend="italic">June 15, 1893</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 12th instant, in relation to the firing upon the sentry box at
                    Camargo by soldiers of the U. S. Army, and to say that a translation thereof has
                    been laid before the Secretary of War for his consideration and action.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. Q. Gresham.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
