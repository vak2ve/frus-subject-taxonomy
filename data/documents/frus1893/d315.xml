<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1893-06-24T23:59:59-05:00" frus:doc-dateTime-min="1893-06-24T00:00:00-05:00" n="315" subtype="historical-document" type="document" xml:id="d315">
                    <head><hi rend="italic">Mr. <persName type="from">Gresham</persName> to Mr.
                                <persName type="to">Bayard</persName>.</hi></head>
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Department
                                    of State</hi>,<lb/><hi rend="italic">Washington</hi></placeName>, <date calendar="gregorian" when="1893-06-24"><hi rend="italic">June 24, 1893</hi></date>.
                            (Received June 24.)</dateline></opener>
                    <p>Convey to Her Majesty expression of the heartfelt sorrow of the President and
                        the people of the United States by reason of the appalling catastrophe to
                        the <hi rend="italic">Victoria.</hi></p>
                    <closer><signed><hi rend="smallcaps">Gresham</hi>.</signed></closer>
                </div>
                </body></text></TEI>