                subtype="historical-document" type="document" xml:id="d349">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Sir <persName
                            type="to">Julian Pauncefote</persName>
                    </hi>.</head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1893-12-21">
                            <hi rend="italic">December 21, 1893</hi>
                        </date>
                    </dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Excellency</hi>: I have the honor to acknowledge the
                    receipt of your note of the 13th instant, inclosing a copy of an approved minute
                    of the Canadian privy council on the subject of reciprocal wrecking in the
                    inland waters contiguous to the United States and Canada.</p>
                <p>Adding that the contents of your note will be duly communicated to the Secretary
                    of the Treasury for his information, I have, etc.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. Q. Gresham.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
