                subtype="historical-document" type="document" xml:id="d296">
                <head>
                    <hi rend="italic">Señor <persName type="from">Peralta</persName> to Mr.
                            <persName type="to">Gresham</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of Costa Rica</hi>,<lb/>
                            <hi rend="italic">Washington, D. C.</hi>
                        </placeName>, <date calendar="gregorian" when="1893-12-04">
                            <hi rend="italic">December 4, 1893</hi>
                        </date>. (Received December 5.)</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to acknowledge the receipt of
                    your note of the 2d instant, transmitting, at my request, a copy of that
                    Department’s instruction to the United States minister to Costa Rica expressing
                    the hope of your Government that the boundary question between Costa Rica and
                    Colombia will be brought to an amicable understanding. With my best thanks for
                    this kind communication,</p>
                <p>I beg you, sir, to accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Manuel M. Peralta.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
