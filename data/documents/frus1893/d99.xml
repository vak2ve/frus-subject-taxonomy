    <text>
        <body>
            <div frus:doc-dateTime-max="1893-12-25T23:59:59-05:00" frus:doc-dateTime-min="1893-12-25T00:00:00-05:00" n="99" subtype="historical-document" type="document" xml:id="d99">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Mr.
                                <persName type="to">Thompson</persName>.</hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram.]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department
                                    of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1893-12-25">
                            <hi rend="italic">December 25,
                            1893</hi>
                        </date>.</dateline>
                </opener>
                <p>You should remain in Rio unless danger is greater than reported.</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Gresham.</hi>
                    </signed>
                </closer>
            </div>
        </body>
