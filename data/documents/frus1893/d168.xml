    <text>
        <body>
            <div frus:doc-dateTime-max="1893-03-25T23:59:59-05:00" frus:doc-dateTime-min="1893-03-25T00:00:00-05:00" n="168" subtype="historical-document" type="document" xml:id="d168">
                <head>
                    <hi rend="italic">Senhor <persName type="from">Mendonça</persName> to
                                Mr. <persName type="to">Gresham</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Legation of the United States of Brazil</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1893-03-25">
                            <hi rend="italic">March
                                        25, 1893</hi>
                        </date>. (Received March
                            27.)</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: It is my painful duty to make known to
                            your excellency the sudden and unexpected death, at 9:15 o’clock p.m. to
                            day, of Baron de Aguiar de Andrada, chief of the Brazilian special
                            mission in Washington.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">Salvador
                            Mendonça.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
