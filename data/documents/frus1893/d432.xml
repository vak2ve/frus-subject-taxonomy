    <text>
        <body>
            <div frus:doc-dateTime-max="1893-02-10T23:59:59-05:00"
                frus:doc-dateTime-min="1893-02-10T00:00:00-05:00" n="432"
                subtype="historical-document" type="document" xml:id="d432">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Foster</persName> to Señor <persName
                            type="to">Cayetano Romero</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1893-02-10">
                            <hi rend="italic">February 10, 1893</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">Sir</hi>: I have the honor to state that the contents of
                    your note of 6th instant, in which you make known the views of your Government
                    on the subject of more effectively pursuing the armed disturbers of the peace on
                    the border through greater concert of action by the troops of both governments,
                    have been communicated to the Secretary of War.</p>
                <p>Accept, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">John W. Foster.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
