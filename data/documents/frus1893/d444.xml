                subtype="historical-document" type="document" xml:id="d444">
                <head>
                    <hi rend="italic">Mr. <persName type="from">Gresham</persName> to Señor
                            <persName type="to">Romero</persName>.</hi>
                </head>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Department of State</hi>,<lb/>
                            <hi rend="italic">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1893-05-03">
                            <hi rend="italic">May 3, 1893</hi>
                        </date>.</dateline>
                </opener>
                <p>
                    <hi rend="smallcaps">My Dear Mr. Romero</hi>: I beg to state that, as appears by
                    a letter of the War Department of 1st instant, Lieut. Walker, Third Cavalry, has
                    captured Delfino Garcia, one of Maugua de Agua men—a disturber, as understood,
                    of the peace on the border.</p>
                <p>I am, etc.,</p>
                <closer>
                    <signed>
                        <hi rend="smallcaps">W. Q. Gresham.</hi>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
