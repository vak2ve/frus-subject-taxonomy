<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1893-12-01T23:59:59-05:00" frus:doc-dateTime-min="1893-12-01T00:00:00-05:00" n="85" subtype="historical-document" type="document" xml:id="d85">
                    <head><hi rend="italic">Mr. <persName type="from">Thompson</persName> to Mr.
                                <persName type="to">Gresham</persName>.</hi></head>
                    <opener><seg rendition="#center">[Telegram.]</seg></opener>
                    <opener><dateline rendition="#right"><placeName><hi rend="smallcaps">Legation of
                                    the United States</hi>,<lb/><hi rend="italic">Rio de
                                    Janeiro</hi></placeName>, <date calendar="gregorian" when="1893-12-01"><hi rend="italic">December 1,
                            1893</hi></date>.</dateline></opener>
                    <p>Mello left bay at one this morning, going south in <hi rend="italic">Aquidaban.</hi></p>
                    <closer><signed><hi rend="smallcaps">Thompson.</hi></signed></closer>
                </div>
                </body></text></TEI>