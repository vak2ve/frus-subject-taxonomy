    <text>
        <body>
            <div frus:doc-dateTime-max="1969-10-24T23:59:59-05:00"
                frus:doc-dateTime-min="1969-10-24T00:00:00-05:00" n="147"
                subtype="historical-document" type="document" xml:id="d147">
                <head>147. Memorandum from Secretary of State <persName corresp="#p_RWP1"
                        type="from">Rogers</persName> to President <persName corresp="#p_NRM1"
                        type="to">Nixon</persName>
                    <note n="1" type="source" xml:id="d147fn1">Source: National Archives, <gloss
                            target="#t_RG1">RG</gloss> 59, President’s Evening Reading: Lot File 74
                        D 164. Secret.</note>
                    <note n="2" type="summary" xml:id="d147fn2">
                        <persName corresp="#p_RWP1">Rogers</persName> reported that he had appointed
                            <persName corresp="#p_SHH6">Harry Schwartz</persName> as his Special
                        Assistant for Narcotics Matters.</note>
                </head>
                <dateline>
                    <placeName>Washington</placeName>, <date calendar="gregorian" when="1969-10-24"
                        >October 24, 1969</date>.</dateline>
                <p>
                    <hi rend="underline">MEMORANDUM FOR THE PRESIDENT</hi>-Evening Report</p>
                <p>
                    <hi rend="underline">Narcotics</hi>-As <persName corresp="#p_JUA1">Alex
                        Johnson</persName> reported to the Inter-Agency Meeting held by <persName
                        corresp="#p_KHA1">Henry Kissinger</persName> at the White House this
                    morning, I have appointed <persName corresp="#p_SHH6">Harry Schwartz</persName>,
                    a senior officer in the Department, as my Special Assistant for Narcotics
                    Matters, in order to ensure that the Department acts effectively in coordinating
                    and carrying out your desire for a maximum effort to get the matter of illegal
                    narcotics imports under better control.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_RWP1">William P. Rogers</persName>
                    </signed>
                </closer>
            </div>
        </body>
