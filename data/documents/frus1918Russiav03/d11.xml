    <text>
        <body>
            <div frus:doc-dateTime-max="1917-05-10T16:29:00-05:00"
                frus:doc-dateTime-min="1917-05-10T16:29:00-05:00" n="11"
                subtype="historical-document" type="document" xml:id="d11">
                <note rend="inline" type="source">File No. 861.51/145</note>
                <head>
                    <hi rend="italic">The Ambassador in Russia</hi> (<persName corresp="#p_FDR1"
                        type="from">
                        <hi rend="italic">Francis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Petrograd</hi>
                        </placeName>, <date calendar="gregorian" when="1917-05-11T00:00:00+02:31">
                            <hi rend="italic">May 11, 1917, midnight</hi>
                        </date>. <lb/> [<hi rend="italic">Received May 13, 7 a.m.</hi>]</dateline>
                </opener>
                <p>1275. For Secretary of the Treasury:</p>
                <pb facs="0059" n="9" xml:id="pg_9"/>
                <p>Your 1386 received to-day. May [they?] accept it and Minister for Foreign Affairs
                    says plan entirely satisfactory. Minister of Finance authorized Russian Chargé
                    d’Affaires, Washington, act for Russia until <persName corresp="#p_BBA1"
                        >Bakhmeteff</persName>
                    <note n="1" xml:id="d11fn1">
                        <persName corresp="#p_BBA1">Boris A. Bakhmeteff</persName>, head of the
                        Russian mission to the United States, and later, July 5, 1917, Ambassador at
                        Washington.</note> arrives about June 15.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_FDR1">
                            <hi rend="smallcaps">Francis</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
