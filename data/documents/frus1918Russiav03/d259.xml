<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-08-21T17:00:00-05:00" frus:doc-dateTime-min="1918-08-21T17:00:00-05:00" n="259" subtype="historical-document" type="document" xml:id="d259">
                            <note rend="inline" type="source">File No. 661.939/21</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Chargé in China</hi> (<persName corresp="#p_MJA1" type="to"><hi rend="italic">MacMurray</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-08-21T18:00:00-04:00"><hi rend="italic">August
                                            21, 1918, 6 p.m.</hi></date></dateline>
                            </opener>
                            <p>Your August 17, 8 p.m. You are authorized as you request to support
                                the British Legation in urging the Chinese Government to prohibit
                                passage of supplies to enemy forces.</p>
                            <closer>
                                <signed><persName corresp="#p_LR1"><hi rend="smallcaps">Lansing</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>