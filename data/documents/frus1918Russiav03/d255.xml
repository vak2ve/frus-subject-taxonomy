                subtype="historical-document" type="document" xml:id="d255">
                <note rend="inline" type="source">File No. 661.939/16</note>
                <head>
                    <hi rend="italic">The Minister in China</hi> (<persName corresp="#p_RPS1"
                        type="from">
                        <hi rend="italic">Reinsch</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1918-06-24T16:00:00+08:00">
                            <hi rend="italic">June 24, 1918, 4 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received June 24, 11.22 a.m.</hi>]</dateline>
                </opener>
                <p>The Chinese Government has canceled embargo on exports to Siberia.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_RPS1">
                            <hi rend="smallcaps">Reinsch</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
