    <text>
        <body>
            <div frus:doc-dateTime-max="1917-11-24T08:00:00-05:00"
                frus:doc-dateTime-min="1917-11-24T08:00:00-05:00" n="42"
                subtype="historical-document" type="document" xml:id="d42">
                <note rend="inline" type="source">File No. 861.51/277</note>
                <head>
                    <hi rend="italic">The Special Representative</hi> (<persName corresp="#p_HE1"
                        type="from">
                        <hi rend="italic">House</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Extract]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Paris</hi>
                        </placeName>, <date calendar="gregorian" when="1917-11-24T13:00:00+00:00">
                            <hi rend="italic">November 24, 1917, 1 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received November 25, 1.40 a.m.</hi>]</dateline>
                </opener>
                <p>Your 5860<note n="2" xml:id="d42fn2">Not printed.</note> and 2841. In Great
                    Britain the Russian situation is considered at the moment hopeless. There is no
                    responsible government within sight. I would advise making no more advances at
                    present or permitting any further contracts for purchases. …</p>
                <closer>
                    <signed>
                        <persName corresp="#p_HE1">
                            <hi rend="smallcaps">Edward House</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
