    <text>
        <body>
            <div frus:doc-dateTime-max="1918-07-26T06:00:00-05:00"
                frus:doc-dateTime-min="1918-07-26T06:00:00-05:00" n="476"
                subtype="historical-document" type="document" xml:id="d476">
                <note rend="inline" type="source">File No. 861.85/35</note>
                <head>
                    <hi rend="italic">The Chargé in China</hi> (<persName corresp="#p_MJA1"
                        type="from">
                        <hi rend="italic">MacMurray</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Peking</hi>
                        </placeName>, <date calendar="gregorian" when="1918-07-26T19:00:00+08:00">
                            <hi rend="italic">July 26, 1918, 7 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received July 26, 5.15 p.m.</hi>]</dateline>
                </opener>
                <p>Your July 20, 2 p.m.<note n="1" xml:id="d476fn1">Not printed.</note> Steamship
                        <hi rend="italic">Penza</hi> has resumed regular journeys between
                    Vladivostok and Shanghai and is under no control by the Chinese Government save
                    for a special passport control exercised by the local authorities while within
                    Chinese territorial waters. I am so informing consulate at Vladivostok.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_MJA1">
                            <hi rend="smallcaps">MacMurray</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
