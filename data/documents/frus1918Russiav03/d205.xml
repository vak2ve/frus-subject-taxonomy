<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-09-27T13:00:00-05:00" frus:doc-dateTime-min="1918-09-27T13:00:00-05:00" n="205" subtype="historical-document" type="document" xml:id="d205">
                            <note rend="inline" type="source">File No. 861.00/2776</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-09-27T14:00:00-04:00"><hi rend="italic">September
                                            27, 1918, 2 p.m.</hi></date></dateline>
                            </opener>
                            <p>275. Your 416, September 21, 5 p.m. Four steamers cleared this month
                                for Archangel with supplies. This includes Red Cross ship reported
                                already arrived Murmansk.</p>
                            <closer>
                                <signed><persName corresp="#p_LR1"><hi rend="smallcaps">Lansing</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>