    <text>
        <body>
            <div frus:doc-dateTime-max="1918-09-12T16:00:00-05:00"
                frus:doc-dateTime-min="1918-09-12T16:00:00-05:00" n="86"
                subtype="historical-document" type="document" xml:id="d86">
                <note rend="inline" type="source">File No. 861.00/2504</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to">
                        <hi rend="italic">Francis</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-09-12T17:00:00-04:00">
                            <hi rend="italic">September 12, 1918, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>256. Department considering your 364, August 13, 8 p.m.<note n="1"
                        xml:id="d86fn1">
                        <hi rend="italic">Ante</hi>, <ref target="#pg_58">p. 58</ref>.</note> Has
                    received communication from British Government same subject of currency.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
