                subtype="historical-document" type="document" xml:id="d226">
                <note rend="inline" type="source">File No. 103.96/1479b</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Minister in Norway</hi> (<persName type="to">
                        <hi rend="italic">Schmedeman</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-11-05T17:00:00-05:00">
                            <hi rend="italic">November 5, 1918, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>551. For <persName corresp="#p_OWH1">Owen</persName> from War Trade Board:</p>
                <p>In view of rapidly changing situation, we do not desire you to proceed to
                    Archangel at least for the present. Please proceed to Stockholm with a view to
                    studying the Russian situation from there.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
