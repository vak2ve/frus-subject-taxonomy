<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-04-28T18:00:00-05:00" frus:doc-dateTime-min="1917-04-28T18:00:00-05:00" n="272" subtype="historical-document" type="document" xml:id="d272">
                            <note rend="inline" type="source">File No. 861.77/59</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-04-28T18:00:00-05:00"><hi rend="italic">April 28,
                                            1917, 6 p.m.</hi></date></dateline>
                            </opener>
                            <p>1361. Your 1218, April 24, 6 p.m. Commission of railroad experts are
                                prepared to start for Vladivostok within five days.</p>
                            <closer>
                                <signed><persName corresp="#p_LR1"><hi rend="smallcaps">Lansing</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>