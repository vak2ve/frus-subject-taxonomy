<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-04-02T18:00:00-05:00" frus:doc-dateTime-min="1918-04-02T18:00:00-05:00" n="353" subtype="historical-document" type="document" xml:id="d353">
                            <note rend="inline" type="source">File No. 861.77/349</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-04-02T19:00:00-04:00"><hi rend="italic">April 2,
                                            1918, 7 p.m.</hi></date></dateline>
                            </opener>
                            <p>42. Your March 29, 9 p.m. Department thinks need for railway men
                                should be defined specifically and desires further and clearer
                                statement before decision.</p>
                            <closer>
                                <signed><persName corresp="#p_LR1"><hi rend="smallcaps">Lansing</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>