<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-04-28T20:00:00-05:00" frus:doc-dateTime-min="1918-04-28T20:00:00-05:00" n="363" subtype="historical-document" type="document" xml:id="d363">
                            <note rend="inline" type="source">File No. 861.77/374</note>
                            <head><hi rend="italic">The Minister in China</hi> (<persName corresp="#p_RPS1" type="from"><hi rend="italic">Reinsch</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Peking</hi></placeName>, <date calendar="gregorian" when="1918-04-29T09:00:00+08:00"><hi rend="italic">April 29,
                                            1918, 9 a.m.</hi></date>
                                    <lb/> [<hi rend="italic">Received April 29, 8.17
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>[From <persName corresp="#p_SJF1">Stevens</persName>:]</p>
                            <p>Your cable 23d. I have given your orders to <persName corresp="#p_ECH1">Emerson</persName>. He will go immediately to
                                Vologda.</p>
                            <closer>
                                <signed><persName corresp="#p_RPS1"><hi rend="smallcaps">Reinsch</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>