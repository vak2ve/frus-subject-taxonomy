    <text>
        <body>
            <div frus:doc-dateTime-max="1918-04-06T17:00:00-05:00"
                frus:doc-dateTime-min="1918-04-06T17:00:00-05:00" n="356"
                subtype="historical-document" type="document" xml:id="d356">
                <note rend="inline" type="source">File No. 861.77/353</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to">
                        <hi rend="italic">Francis</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-04-06T18:00:00-04:00">
                            <hi rend="italic">April 6, 1918, 6 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>51. Your 61, April 2, 7 p.m. Department instructed <persName corresp="#p_SJF1"
                        >Stevens</persName> not to send railroad men until we had further full
                    report from you, as requested in Department’s No. 42.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
