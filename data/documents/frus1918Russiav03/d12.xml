<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-05-15T12:29:00-05:00" frus:doc-dateTime-min="1917-05-15T12:29:00-05:00" n="12" subtype="historical-document" type="document" xml:id="d12">
                            <note rend="inline" type="source">File No. 861.51/146</note>
                            <head><hi rend="italic">The Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="from"><hi rend="italic">Francis</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Petrograd</hi></placeName>, <date calendar="gregorian" when="1917-05-15T20:00:00+02:31"><hi rend="italic">May 15,
                                            1917, 8 p.m.</hi></date>
                                    <lb/> [<hi rend="italic">Received May 17, 7.45
                                    a.m.</hi>]</dateline>
                            </opener>
                            <p>1291. Your 1359.<note n="2" xml:id="d12fn2"><hi rend="italic">Ante</hi>, <ref target="#pg_5">p. 5</ref>.</note> Foreign
                                Office now formally advises me at the request of Russian Chargé
                                d’Affaires at Washington that Mr. <persName corresp="#p_OC1">Onou</persName> is designated by the Russian Government to sign
                                in the name of his Government the obligations and make declarations
                                in connection with the bill for credits to the Allies pending the
                                arrival in America of Mr. <persName corresp="#p_BBA1">Bakhmeteff</persName>.</p>
                            <closer>
                                <signed><persName corresp="#p_FDR1"><hi rend="smallcaps">Francis</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>