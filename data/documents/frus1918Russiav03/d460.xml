<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1919-01-09T05:00:00-05:00" frus:doc-dateTime-min="1919-01-09T05:00:00-05:00" n="460" subtype="historical-document" type="document" xml:id="d460">
                            <note rend="inline" type="source">File No. 861.77/605</note>
                            <head><hi rend="italic">The Ambassador in Japan</hi> (<persName corresp="#p_MRS1" type="from"><hi rend="italic">Morris</hi></persName>) <hi rend="italic">to the <gloss type="to">Secretary of State</gloss></hi></head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Tokyo</hi></placeName>, <date calendar="gregorian" when="1919-01-09T19:00:00+09:00"><hi rend="italic">January
                                            9, 1919, 7 p.m.</hi></date>
                                    <lb/> [<hi rend="italic">Received 10.35 p.m.</hi>]</dateline>
                            </opener>
                            <p>Pursuant to <persName corresp="#p_SJF1">Stevens</persName>’s telegram
                                to Department. I have just accepted Japanese plan and negotiations
                                are satisfactorily closed here. Details follow.</p>
                            <closer>
                                <signed><persName corresp="#p_MRS1"><hi rend="smallcaps">Morris</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>