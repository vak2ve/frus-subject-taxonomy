<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-11-09T17:00:00-05:00" frus:doc-dateTime-min="1918-11-09T17:00:00-05:00" n="228" subtype="historical-document" type="document" xml:id="d228">
                            <note rend="inline" type="source">File No. 861.24/105a</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Chargé in Sweden</hi> (<persName corresp="#p_WS1" type="to"><hi rend="italic">Whitehouse</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-11-09T17:00:00-05:00"><hi rend="italic">November
                                            9, 1918, 5 p.m.</hi></date></dateline>
                            </opener>
                            <p>1276. Please telegraph a soon as possible text of
                                    <persName>Huntington</persName>’s<note n="1" xml:id="d228fn1"><persName>William C. Huntington</persName>, Commercial
                                    Attaché.</note> letter to Ambassador giving <hi rend="italic">résume</hi> of expenditures and materials purchased by Goods
                                Exchange; also mail copy by pouch. <persName>Huntington</persName>
                                expresses thanks for official accounts duly received.</p>
                            <closer>
                                <signed><persName corresp="#p_LR1"><hi rend="smallcaps">Lansing</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>