    <text>
        <body>
            <div frus:doc-dateTime-max="1918-02-19T17:00:00-05:00"
                frus:doc-dateTime-min="1918-02-19T17:00:00-05:00" n="341"
                subtype="historical-document" type="document" xml:id="d341">
                <note rend="inline" type="source">File No. 861.77/297a</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Ambassador in Japan</hi> (<persName corresp="#p_MRS1" type="to">
                        <hi rend="italic">Morris</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-02-19T17:00:00-05:00">
                            <hi rend="italic">February 19, 1918, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Department has approved <persName corresp="#p_SJF1">Stevens</persName>’s plan to
                    return to Harbin with <persName corresp="#p_ECH1">Emerson</persName> and party.
                    Please inform him fully regarding Siberian situation and attitude of this
                    Government.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
