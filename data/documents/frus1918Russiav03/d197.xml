                subtype="historical-document" type="document" xml:id="d197">
                <note rend="inline" type="source">File No. 861.00/2648</note>
                <head>
                    <hi rend="italic">The Ambassador in Russia</hi> (<persName corresp="#p_FDR1"
                        type="from">
                        <hi rend="italic">Francis</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram—Extract]<note n="1" xml:id="d197fn1">Printed
                            in full in <ref target="frus1918Russiav02#pg_519">vol. <hi
                                    rend="smallcaps">ii</hi>, p. 519</ref>.</note>
                    </seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Archangel</hi>
                        </placeName>, <date calendar="gregorian" when="1918-09-04T21:00:00+04:31">
                            <hi rend="italic">September 4, 1918, 9 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received September 7, 7.36 p.m.</hi>]</dateline>
                </opener>
                <p>381. <persName corresp="#p_LFO1">Lindley</persName> says 3,000 tons flour will
                    arrive from England September 10 and 6,000 tons additional about the 15th. I
                    hoped we would be first to report food shipments. …</p>
                <closer>
                    <signed>
                        <persName corresp="#p_FDR1">
                            <hi rend="smallcaps">Francis</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
