    <text>
        <body>
            <div frus:doc-dateTime-max="1918-12-31T17:00:00-05:00"
                frus:doc-dateTime-min="1918-12-31T17:00:00-05:00" n="123"
                subtype="historical-document" type="document" xml:id="d123">
                <note rend="inline" type="source">File No. 861.51/437</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Acting Secretary of State</gloss> to
                        the Ambassador in Great Britain</hi> (<persName type="to">
                        <hi rend="italic">Davis</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-12-31T17:00:00-05:00">
                            <hi rend="italic">December 31, 1918, 5 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>3741. [From War Trade Board] for <persName corresp="#p_SLP1"
                        >Sheldon</persName>:<note n="1" xml:id="d123fn1">
                        <persName corresp="#p_SLP1">L. P. Sheldon</persName>, representative in
                        London of the War Trade Board.</note>
                </p>
                <p>1961. Referring Embassy’s 4877, December 24; your 2180. Copy of our
                    recommendations to Paris<note n="2" xml:id="d123fn2">
                        <hi rend="italic">Post</hi>, <ref target="#pg_170">p. 170</ref>.</note> has
                    been forwarded to you and pending action by that conference nothing further will
                    be done with currency matter.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PF1">
                            <hi rend="smallcaps">Polk</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
