    <text>
        <body>
            <div frus:doc-dateTime-max="1918-09-17T18:00:00-05:00"
                frus:doc-dateTime-min="1918-09-17T18:00:00-05:00" n="404"
                subtype="historical-document" type="document" xml:id="d404">
                <note rend="inline" type="source">File No. 861.77/480</note>
                <head>
                    <hi rend="italic">The <gloss type="from">Secretary of State</gloss> to the
                        Chargé in China</hi> (<persName corresp="#p_MJA1" type="to">
                        <hi rend="italic">MacMurray</hi>
                    </persName>)</head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">Washington</hi>
                        </placeName>, <date calendar="gregorian" when="1918-09-17T19:00:00-04:00">
                            <hi rend="italic">September 17, 1918, 7 p.m.</hi>
                        </date>
                    </dateline>
                </opener>
                <p>Your September 16, 5 p.m. This Government does not insist upon the present
                    elimination of <persName corresp="#p_HGL1">Horvat</persName> as an official of
                    the railway.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_LR1">
                            <hi rend="smallcaps">Lansing</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
