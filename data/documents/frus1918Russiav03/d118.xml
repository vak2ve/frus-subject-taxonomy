<?xml version='1.0' encoding='UTF-8'?>
<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-12-23T13:00:00-05:00" frus:doc-dateTime-min="1918-12-23T13:00:00-05:00" n="118" subtype="historical-document" type="document" xml:id="d118">
                            <note rend="inline" type="source">File No. 861.51/379</note>
                            <head><hi rend="italic">The <gloss type="from">Acting Secretary of
                                        State</gloss> to the Consul at Vladivostok</hi> (<persName corresp="#p_CJK1" type="to"><hi rend="italic">Caldwell</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-12-23T13:00:00-05:00"><hi rend="italic">December
                                            23, 1918, 1 p.m.</hi></date></dateline>
                            </opener>
                            <p>Your 221, October 23, 8 p.m.<note n="1" xml:id="d118fn1"><hi rend="italic">Ante</hi>, <ref target="#pg_78">p.
                                    78</ref>.</note> War Department willing to assume expense of
                                printing such notes as may be required for use of American military
                                expeditionary forces in Siberia. Please inform <persName corresp="#p_GMS1">General Graves</persName><note n="2" xml:id="d118fn2"><persName corresp="#p_GMS1">Maj. Gen. William
                                        S. Graves</persName>, commanding the American forces in
                                    Siberia.</note> and <persName corresp="#p_HA1">Heid</persName><note n="3" xml:id="d118fn3"><persName corresp="#p_HA1">August Heid</persName>, representative at
                                    Vladivostok of the War Trade Board.</note> and report what
                                further action, if any, required on part of this Department. No
                                objection to attending conferences informally.</p>
                            <closer>
                                <signed><persName corresp="#p_PF1"><hi rend="smallcaps">Polk</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>