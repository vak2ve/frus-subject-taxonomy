<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-04-10T14:00:00-05:00" frus:doc-dateTime-min="1918-04-10T14:00:00-05:00" n="60" subtype="historical-document" type="document" xml:id="d60">
                            <note rend="inline" type="source">File No. 861.51/303a</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in Great Britain</hi>
                                    (<persName corresp="#p_PW1" type="to"><hi rend="italic">Page</hi></persName>)<note n="1" xml:id="d60fn1">The same,
                                        <hi rend="italic">mutatis mutandis</hi>, on the same date,
                                    to the Ambassador in France (No. 3479).</note></head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-04-10T15:00:00-04:00"><hi rend="italic">April 10,
                                            1918, 3 p.m.</hi></date></dateline>
                            </opener>
                            <p>7203. Department desires to ascertain what policy adopted by Great
                                Britain in regard to meeting interest and principal on Russian
                                obligations.</p>
                            <p>Please report fully as to policy and arrangements made in detail.</p>
                            <closer>
                                <signed><persName corresp="#p_LR1"><hi rend="smallcaps">Lansing</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>