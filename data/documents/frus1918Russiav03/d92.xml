    <text>
        <body>
            <div frus:doc-dateTime-max="1918-09-26T10:00:00-05:00"
                frus:doc-dateTime-min="1918-09-26T10:00:00-05:00" n="92"
                subtype="historical-document" type="document" xml:id="d92">
                <note rend="inline" type="source">File No. 861.00/2798</note>
                <head>
                    <hi rend="italic">The Ambassador in Great Britain</hi> (<persName
                        corresp="#p_PW1" type="from">
                        <hi rend="italic">Page</hi>
                    </persName>) <hi rend="italic">to the <gloss type="to">Secretary of
                            State</gloss>
                    </hi>
                </head>
                <opener>
                    <seg rendition="#center">[Telegram]</seg>
                </opener>
                <opener>
                    <dateline rendition="#right">
                        <placeName>
                            <hi rend="smallcaps">London</hi>
                        </placeName>, <date calendar="gregorian" when="1918-09-26T16:00:00+01:00">
                            <hi rend="italic">September 26, 1918, 4 p.m.</hi>
                        </date>
                        <lb/> [<hi rend="italic">Received September 26, 1.50 p.m.</hi>]</dateline>
                </opener>
                <p>2228. <persName>Rathbone</persName> from <persName corresp="#p_COT1"
                        >Crosby</persName>:</p>
                <p>570. Referring to my No. 535.<note n="1" xml:id="d92fn1">See Ambassador’s No.
                        1961, Sept. 17, 9 p.m., <hi rend="italic">ante</hi>, <ref target="#pg_68">p.
                            68</ref>.</note> British Treasury has arranged for the issue of ruble
                    notes in northern Russia independently of the plan proposed by the French. Full
                    details going to you by mail to-morrow.</p>
                <closer>
                    <signed>
                        <persName corresp="#p_PW1">
                            <hi rend="smallcaps">Page</hi>
                        </persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
