<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1918-05-25T15:00:00-05:00" frus:doc-dateTime-min="1918-05-25T15:00:00-05:00" n="172" subtype="historical-document" type="document" xml:id="d172">
                            <note rend="inline" type="source">File No. 861.24/78</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1918-05-25T16:00:00-04:00"><hi rend="italic">May 25,
                                            1918, 4 p.m.</hi></date></dateline>
                            </opener>
                            <p>138. Your 170, May 16, 7 p.m. Department approves fully and has so
                                advised War Department.</p>
                            <closer>
                                <signed><persName corresp="#p_LR1"><hi rend="smallcaps">Lansing</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>