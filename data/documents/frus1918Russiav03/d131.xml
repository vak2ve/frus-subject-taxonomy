<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:frus="http://history.state.gov/frus/ns/1.0"><text><body><div frus:doc-dateTime-max="1917-12-05T15:00:00-05:00" frus:doc-dateTime-min="1917-12-05T15:00:00-05:00" n="131" subtype="historical-document" type="document" xml:id="d131">
                            <note rend="inline" type="source">File No. 861.48/417</note>
                            <head><hi rend="italic">The <gloss type="from">Secretary of
                                        State</gloss> to the Ambassador in Russia</hi> (<persName corresp="#p_FDR1" type="to"><hi rend="italic">Francis</hi></persName>)</head>
                            <opener>
                                <seg rendition="#center">[Telegram]</seg>
                            </opener>
                            <opener>
                                <dateline rendition="#right"><placeName><hi rend="smallcaps">Washington</hi></placeName>, <date calendar="gregorian" when="1917-12-05T15:00:00-05:00"><hi rend="italic">December
                                            5, 1917, 3 p.m.</hi></date></dateline>
                            </opener>
                            <p>1884. Your 2022, November 24, and 2039, November 26. Department
                                approves recommendations and will endeavor secure delivery boots for
                                supply committee northern railways. Will advise further.</p>
                            <closer>
                                <signed><persName corresp="#p_LR1"><hi rend="smallcaps">Lansing</hi></persName></signed>
                            </closer>
                        </div>
                        </body></text></TEI>